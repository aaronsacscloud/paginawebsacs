---
interface FAQ {
  question: string;
  answer: string;
}

const faqs: FAQ[] = [
  {
    question: '¿Cuánto cuesta SACS?',
    answer: 'Tenemos un plan gratuito con todas las funciones esenciales. Los planes de pago comienzan en $299/mes e incluyen funcionalidades avanzadas como multi-sucursal, reportes premium y AXO (IA).',
  },
  {
    question: '¿Cuánto tiempo toma configurar SACS?',
    answer: 'El setup inicial toma entre 10 y 15 minutos. Incluye crear tu cuenta, configurar tu catálogo y conectar tu primer método de pago. Nuestro equipo te acompaña en cada paso.',
  },
  {
    question: '¿Qué tipo de soporte ofrecen?',
    answer: 'Todos los planes incluyen soporte por chat y email. Los planes Pro y Enterprise cuentan con soporte telefónico prioritario y un account manager dedicado.',
  },
  {
    question: '¿Se integra con otras herramientas?',
    answer: 'Sí. SACS se integra con los principales procesadores de pago en México, plataformas de e-commerce, sistemas contables y herramientas de marketing. También ofrecemos una API abierta.',
  },
  {
    question: '¿Mis datos están seguros?',
    answer: 'Absolutamente. Usamos encriptación de grado bancario (AES-256), servidores en la nube con redundancia y respaldos automáticos cada hora. Cumplimos con las regulaciones de protección de datos de México.',
  },
  {
    question: '¿Puedo migrar desde otro sistema?',
    answer: 'Sí. Nuestro equipo de onboarding te ayuda a migrar tu catálogo, clientes e historial de ventas sin costo adicional. El proceso típico toma de 1 a 3 días hábiles.',
  },
];
---

<section class="faq">
  <div class="container faq-inner">
    <div class="faq-header reveal">
      <span class="faq-eyebrow">FAQ</span>
      <h2 class="faq-title">Preguntas frecuentes</h2>
      <p class="faq-subtitle">¿Tienes otra pregunta? <a href="/contacto" class="faq-contact-link">Escríbenos</a></p>
    </div>
    <div class="faq-list">
      {faqs.map((faq, i) => (
        <details class="faq-item reveal" style={`--i:${i}`}>
          <summary class="faq-summary">
            <span>{faq.question}</span>
            <span class="faq-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5">
                <line x1="9" y1="3" x2="9" y2="15" class="faq-icon-v"/>
                <line x1="3" y1="9" x2="15" y2="9"/>
              </svg>
            </span>
          </summary>
          <div class="faq-answer">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq {
    background: var(--color-bg-primary);
    padding: var(--space-20) 0;
  }

  @media (min-width: 768px) {
    .faq {
      padding: var(--space-24) 0;
    }
  }

  @media (min-width: 1024px) {
    .faq {
      padding: var(--space-32) 0;
    }
  }

  .faq-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  @media (min-width: 1024px) {
    .faq-inner {
      flex-direction: row;
      gap: var(--space-16);
      align-items: flex-start;
    }
  }

  /* ─── Header ─── */
  .faq-header {
    flex-shrink: 0;
  }

  @media (min-width: 1024px) {
    .faq-header {
      position: sticky;
      top: calc(71px + var(--space-10));
      width: 280px;
    }
  }

  .faq-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-3);
  }

  .faq-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
  }

  .faq-subtitle {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .faq-contact-link {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid var(--color-primary);
    padding-bottom: 1px;
  }

  .faq-contact-link:hover {
    text-decoration: none;
    opacity: 0.8;
  }

  /* ─── FAQ List ─── */
  .faq-list {
    flex: 1;
  }

  .faq-item {
    border-top: 1px solid var(--color-border-light);
  }

  .faq-item:last-child {
    border-bottom: 1px solid var(--color-border-light);
  }

  .faq-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5) 0;
    cursor: pointer;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text-primary);
    list-style: none;
    line-height: 1.4;
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-summary::marker {
    content: '';
  }

  .faq-icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    color: var(--color-text-tertiary);
    transition: transform 0.3s ease;
  }

  .faq-icon-v {
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }

  .faq-item[open] .faq-icon-v {
    opacity: 0;
    transform: rotate(90deg);
  }

  .faq-answer {
    padding: 0 0 var(--space-5) 0;
  }

  .faq-answer p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    max-width: 560px;
  }
</style>
