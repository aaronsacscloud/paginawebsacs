---
interface FAQ {
  question: string;
  answer: string;
}

const faqs: FAQ[] = [
  {
    question: '¿Cuánto cuesta SACS?',
    answer: 'Tenemos un plan gratuito con todas las funciones esenciales. Los planes de pago comienzan en $299/mes e incluyen funcionalidades avanzadas como multi-sucursal, reportes premium y AXO (IA).',
  },
  {
    question: '¿Cuánto tiempo toma configurar SACS?',
    answer: 'El setup inicial toma entre 10 y 15 minutos. Incluye crear tu cuenta, configurar tu catálogo y conectar tu primer método de pago. Nuestro equipo te acompaña en cada paso.',
  },
  {
    question: '¿Qué tipo de soporte ofrecen?',
    answer: 'Todos los planes incluyen soporte por chat y email. Los planes Pro y Enterprise cuentan con soporte telefónico prioritario y un account manager dedicado.',
  },
  {
    question: '¿Se integra con otras herramientas?',
    answer: 'Sí. SACS se integra con los principales procesadores de pago en México, plataformas de e-commerce, sistemas contables y herramientas de marketing. También ofrecemos una API abierta.',
  },
  {
    question: '¿Mis datos están seguros?',
    answer: 'Absolutamente. Usamos encriptación de grado bancario (AES-256), servidores en la nube con redundancia y respaldos automáticos cada hora. Cumplimos con las regulaciones de protección de datos de México.',
  },
  {
    question: '¿Puedo migrar desde otro sistema?',
    answer: 'Sí. Nuestro equipo de onboarding te ayuda a migrar tu catálogo, clientes e historial de ventas sin costo adicional. El proceso típico toma de 1 a 3 días hábiles.',
  },
];
---

<section class="faq" id="faq-section">
  <div class="faq-wrapper">
    <div class="faq-header">
      <h2 class="faq-title">Preguntas frecuentes</h2>
      <p class="faq-subtitle">¿Tienes otra pregunta? <a href="/contacto" class="faq-link">Escríbenos</a></p>
    </div>
    <div class="faq-list" id="faq-accordion">
      {faqs.map((faq, i) => (
        <div
          class:list={['faq-item', { active: i === 0 }]}
          data-index={i}
          role="button"
          tabindex="0"
          aria-expanded={i === 0 ? 'true' : 'false'}
        >
          <div class="faq-q">
            <span class="faq-q-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="faq-q-text">{faq.question}</span>
            <span class="faq-q-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
          <div class="faq-a">
            <p>{faq.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .faq {
    background: #fff;
    padding: clamp(64px, 8vw, 120px) 0;
  }

  .faq-wrapper {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }

  /* Header */
  .faq-header {
    text-align: center;
    margin-bottom: clamp(40px, 5vw, 56px);
  }

  .faq-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.08;
    color: var(--color-text-primary);
    margin: 0 0 12px;
  }

  .faq-subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .faq-link {
    color: #2563EB;
    font-weight: 600;
    text-decoration: none;
  }

  .faq-link:hover {
    text-decoration: underline;
  }

  /* List */
  .faq-list {
    display: flex;
    flex-direction: column;
  }

  /* Item */
  .faq-item {
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    cursor: pointer;
    outline: none;
  }

  .faq-item:last-child {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .faq-item:focus-visible {
    outline: 2px solid #2563EB;
    outline-offset: -2px;
    border-radius: 4px;
  }

  /* Question row */
  .faq-q {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 24px 0;
    transition: padding 0.3s ease;
  }

  .faq-q-num {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-text-tertiary);
    flex-shrink: 0;
    width: 28px;
  }

  .faq-q-text {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.35;
    flex: 1;
    letter-spacing: -0.01em;
  }

  .faq-q-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: var(--color-text-tertiary);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), color 0.2s ease;
  }

  .faq-item.active .faq-q-icon {
    transform: rotate(180deg);
    color: #2563EB;
  }

  .faq-item.active .faq-q-num {
    color: #2563EB;
  }

  /* Answer */
  .faq-a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-item.active .faq-a {
    max-height: 300px;
  }

  .faq-a p {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0;
    padding: 0 0 24px 44px;
    max-width: 600px;
  }

  /* Hover */
  .faq-item:hover .faq-q-text {
    color: #2563EB;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .faq-a { transition: none; }
    .faq-q-icon { transition: none; }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .faq {
      padding: clamp(48px, 6vw, 64px) 0;
    }

    .faq-header {
      margin-bottom: 32px;
    }

    .faq-q {
      padding: 20px 0;
      gap: 12px;
    }

    .faq-q-num {
      display: none;
    }

    .faq-q-text {
      font-size: 1rem;
    }

    .faq-a p {
      padding: 0 0 20px 0;
      font-size: 0.9375rem;
    }
  }
</style>

<script>
  const faqAccordion = document.getElementById('faq-accordion');
  const faqItems = faqAccordion?.querySelectorAll('.faq-item');

  faqItems?.forEach((item) => {
    item.addEventListener('click', () => {
      const isActive = item.classList.contains('active');

      // Close all
      faqItems.forEach((it) => {
        it.classList.remove('active');
        it.setAttribute('aria-expanded', 'false');
      });

      // Open clicked (if wasn't active)
      if (!isActive) {
        item.classList.add('active');
        item.setAttribute('aria-expanded', 'true');
      }
    });

    item.addEventListener('keydown', (e: Event) => {
      if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
        e.preventDefault();
        (item as HTMLElement).click();
      }
    });
  });
</script>
