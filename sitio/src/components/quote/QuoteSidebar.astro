---
interface Tab { id: string; label: string; }
interface Props {
  tabs: Tab[];
  initialTab: string;
  total: number;
  totalSinPromo?: number;
  moneda: string;
  empresa: string;
  numero?: string;
  logoUrl?: string;
  template: 'modern' | 'dark' | 'classic';
  isAccepted: boolean;
  isPaid: boolean;
  isExpired: boolean;
  paymentLink?: string;
  vigenciaFecha?: string;
}

const {
  tabs,
  initialTab,
  total,
  totalSinPromo,
  moneda,
  empresa,
  numero,
  template,
  isAccepted,
  isPaid,
  isExpired,
  paymentLink,
  vigenciaFecha,
} = Astro.props;

const fmt = (n: number) => '$' + Math.round(n).toLocaleString('es-MX');
const isClosed = isAccepted || isPaid;
const showCompareTotal = isExpired && !isClosed && typeof totalSinPromo === 'number' && totalSinPromo > total;

// CTA context (Squarespace-style: always black/white, minimal variants)
let ctaLabel = 'Aceptar cotización';
let ctaTarget = '#firma';
let ctaDisabled = false;
let ctaVariant: 'primary' | 'muted' | 'disabled' = 'primary';

if (isExpired && !isClosed) {
  ctaLabel = 'Cotización vencida';
  ctaDisabled = true;
  ctaVariant = 'disabled';
} else if (isPaid) {
  ctaLabel = 'Pagada';
  ctaDisabled = true;
  ctaVariant = 'muted';
} else if (isAccepted && paymentLink) {
  ctaLabel = 'Pagar ahora';
  ctaTarget = paymentLink;
  ctaVariant = 'primary';
} else if (isAccepted) {
  ctaLabel = 'Aceptada';
  ctaDisabled = true;
  ctaVariant = 'muted';
}

const pad = (n: number) => (n < 10 ? '0' + n : String(n));
---

<aside class={`qsb qsb--${template}`} aria-label="Navegación de cotización">
  <!-- Company -->
  <div class="qsb-head">
    <div class="qsb-empresa">{empresa}</div>
    {numero && <div class="qsb-numero">{numero}</div>}
  </div>

  <!-- Total -->
  <div class={`qsb-total ${showCompareTotal ? 'qsb-total--expired' : ''}`}>
    <div class="qsb-total-label">{showCompareTotal ? 'Total ahora' : 'Total'}</div>
    {showCompareTotal && (
      <div class="qsb-total-strike">
        <span class="qsb-total-strike-num">{fmt(total)}</span>
        <span class="qsb-total-strike-tag">con promoción · ya no aplica</span>
      </div>
    )}
    <div class="qsb-total-value">{fmt(showCompareTotal ? (totalSinPromo as number) : total)}</div>
    <div class="qsb-total-sub">
      {moneda}
      {vigenciaFecha && !isClosed && !isExpired ? ` · Vigencia ${vigenciaFecha}` : ''}
      {isExpired && !isClosed && vigenciaFecha ? ` · Venció ${vigenciaFecha}` : ''}
    </div>
  </div>

  <!-- Nav -->
  <nav class="qsb-nav" aria-label="Secciones" role="tablist">
    {tabs.map((t, i) => (
      <a
        href={`#${t.id}`}
        class={`qsb-tab ${t.id === initialTab ? 'qsb-tab--active' : ''}`}
        data-tab-link={t.id}
        role="tab"
        aria-selected={t.id === initialTab ? 'true' : 'false'}
      >
        <span class="qsb-tab-num">{pad(i + 1)}</span>
        <span class="qsb-tab-label">{t.label}</span>
      </a>
    ))}
  </nav>

  <!-- CTA -->
  <div class="qsb-cta-wrap">
    {ctaDisabled ? (
      <div class={`qsb-cta qsb-cta--${ctaVariant}`} aria-disabled="true">{ctaLabel}</div>
    ) : (
      <a
        href={ctaTarget}
        class={`qsb-cta qsb-cta--${ctaVariant}`}
        data-tab-link={ctaTarget.startsWith('#') ? ctaTarget.slice(1) : undefined}
        target={ctaTarget.startsWith('http') ? '_blank' : undefined}
        rel={ctaTarget.startsWith('http') ? 'noopener' : undefined}
      >
        {ctaLabel}
      </a>
    )}
  </div>
</aside>

<style>
  /* ─────────────────────────────────────────
     Squarespace-style sidebar: typographic,
     monochromatic, single accent (teal #2AB5A0)
     ───────────────────────────────────────── */

  .qsb {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding: 28px 24px;
    font-family: inherit;
    font-size: 0.875rem;
    background: transparent;
  }
  .qsb--modern {
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 0;
  }
  .qsb--dark {
    background: #1a1a1a;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .qsb--classic {
    background: #fff;
    border: 1px solid #1a1a1a;
  }

  /* Head: company name + folio */
  .qsb-head {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-bottom: 20px;
    border-bottom: 1px solid #e5e5e5;
  }
  .qsb--dark .qsb-head { border-color: rgba(255,255,255,0.1); }
  .qsb-empresa {
    font-family: var(--font-display, inherit);
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: #1a1a1a;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .qsb--dark .qsb-empresa { color: #fff; }
  .qsb-numero {
    font-size: 0.6875rem;
    font-weight: 500;
    color: #999;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .qsb--dark .qsb-numero { color: rgba(255,255,255,0.5); }

  /* Total: typographic, no gradient */
  .qsb-total {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .qsb-total-label {
    font-size: 0.625rem;
    font-weight: 700;
    color: #999;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .qsb--dark .qsb-total-label { color: rgba(255,255,255,0.5); }
  .qsb-total-value {
    font-family: var(--font-display, inherit);
    font-size: 2rem;
    font-weight: 300;
    line-height: 1;
    color: #1a1a1a;
    letter-spacing: -0.025em;
  }
  .qsb--dark .qsb-total-value { color: #fff; }
  .qsb-total-sub {
    font-size: 0.6875rem;
    color: #999;
    letter-spacing: 0.02em;
  }
  .qsb--dark .qsb-total-sub { color: rgba(255,255,255,0.5); }

  /* Compare price when promo expired */
  .qsb-total-strike {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin-bottom: 2px;
  }
  .qsb-total-strike-num {
    font-family: var(--font-display, inherit);
    font-size: 1rem;
    font-weight: 400;
    color: #b91c1c;
    text-decoration: line-through;
    text-decoration-color: rgba(185,28,28,0.55);
    letter-spacing: -0.015em;
    line-height: 1;
  }
  .qsb-total-strike-tag {
    font-size: 0.625rem;
    font-weight: 600;
    color: #b91c1c;
    opacity: 0.75;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-style: italic;
  }
  .qsb-total--expired .qsb-total-value { color: #047857; }
  .qsb--dark .qsb-total-strike-num { color: #fca5a5; text-decoration-color: rgba(252,165,165,0.55); }
  .qsb--dark .qsb-total-strike-tag { color: #fca5a5; }
  .qsb--dark .qsb-total--expired .qsb-total-value { color: #6ee7b7; }

  /* Nav: typographic list, no icons */
  .qsb-nav {
    display: flex !important;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid #e5e5e5;
  }
  .qsb--dark .qsb-nav { border-color: rgba(255,255,255,0.1); }
  .qsb-tab {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 14px 0 14px 12px;
    text-decoration: none;
    color: #666;
    border-bottom: 1px solid #e5e5e5;
    border-left: 1px solid transparent;
    transition: color 0.18s ease, border-color 0.18s ease, padding-left 0.18s ease;
    position: relative;
  }
  .qsb--dark .qsb-tab { color: rgba(255,255,255,0.55); border-bottom-color: rgba(255,255,255,0.1); }
  .qsb-tab:hover { color: #1a1a1a; padding-left: 16px; }
  .qsb--dark .qsb-tab:hover { color: #fff; }
  .qsb-tab.qsb-tab--active {
    color: #1a1a1a;
    border-left-color: #2AB5A0;
    border-left-width: 2px;
    padding-left: 16px;
  }
  .qsb--dark .qsb-tab.qsb-tab--active { color: #fff; }
  .qsb-tab.qsb-tab--visited { color: #999; }
  .qsb-tab.qsb-tab--visited::before {
    content: '·';
    position: absolute;
    left: 2px;
    top: 50%;
    transform: translateY(-50%);
    color: #2AB5A0;
    font-size: 1.125rem;
    line-height: 1;
  }
  .qsb-tab-num {
    font-size: 0.6875rem;
    font-weight: 500;
    color: #bbb;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    min-width: 20px;
  }
  .qsb--dark .qsb-tab-num { color: rgba(255,255,255,0.35); }
  .qsb-tab.qsb-tab--active .qsb-tab-num { color: #2AB5A0; }
  .qsb-tab-label {
    font-size: 0.9375rem;
    font-weight: 400;
    letter-spacing: 0.002em;
    line-height: 1.3;
  }
  .qsb-tab.qsb-tab--active .qsb-tab-label { font-weight: 500; }

  /* CTA */
  .qsb-cta-wrap { padding-top: 4px; }
  .qsb-cta {
    display: block;
    padding: 16px 18px;
    font-weight: 500;
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: center;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .qsb-cta--primary {
    background: #1a1a1a;
    color: #fff;
    cursor: pointer;
  }
  .qsb-cta--primary:hover {
    background: #2AB5A0;
  }
  .qsb-cta--muted {
    background: transparent;
    color: #2AB5A0;
    border: 1px solid #2AB5A0;
    cursor: default;
  }
  .qsb-cta--disabled {
    background: transparent;
    color: #999;
    border: 1px solid #e5e5e5;
    cursor: not-allowed;
  }
  .qsb--dark .qsb-cta--primary {
    background: #fff;
    color: #1a1a1a;
  }
  .qsb--dark .qsb-cta--primary:hover {
    background: #2AB5A0;
    color: #fff;
  }
  .qsb--dark .qsb-cta--disabled { color: rgba(255,255,255,0.35); border-color: rgba(255,255,255,0.12); }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .qsb-tab, .qsb-cta { transition: none !important; }
    .qsb-tab:hover { padding-left: 12px !important; }
    .qsb-tab.qsb-tab--active { padding-left: 16px !important; }
  }

  @media print { .qsb { display: none !important; } }
</style>
