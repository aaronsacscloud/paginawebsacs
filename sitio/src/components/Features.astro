---
const features = [
  {
    icon: '📦',
    title: 'Inventario inteligente',
    description: 'Gestiona múltiples sucursales, transferencias automáticas y alertas de reabastecimiento. Nunca pierdas una venta por falta de stock.',
  },
  {
    icon: '💳',
    title: 'Punto de venta ágil',
    description: 'Cobra en segundos con múltiples métodos de pago. Facturación CFDI integrada, sin complicaciones fiscales.',
  },
  {
    icon: '👥',
    title: 'CRM que entiende tu cliente',
    description: 'Conoce a tus clientes, segméntalos y crea campañas personalizadas. El retail es relación, no solo transacción.',
  },
  {
    icon: '📊',
    title: 'Reportes accionables',
    description: 'Dashboards en tiempo real que te dicen qué vender, cuándo reordenar y dónde está tu mejor margen.',
  },
];
---

<section class="features section" id="features">
  <div class="container">
    <div class="features-header">
      <span class="eyebrow badge badge-blue">Plataforma todo-en-uno</span>
      <h2 class="features-title">Todo lo que necesitas para operar tu negocio</h2>
      <p class="body-large features-subtitle">
        SACS reúne las herramientas que antes requerían 4 o 5 apps diferentes.
        Un solo lugar, cero fricción.
      </p>
    </div>

    <div class="features-grid">
      {features.map((feature) => (
        <div class="feature-card card">
          <span class="feature-icon" aria-hidden="true">{feature.icon}</span>
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    background: var(--color-bg-secondary);
  }

  .features-header {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: var(--space-16);
  }

  .features-title {
    margin-top: var(--space-5);
    margin-bottom: var(--space-4);
  }

  .features-subtitle {
    color: var(--color-text-secondary);
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .feature-card {
    background: var(--color-bg-card);
    border-radius: var(--radius-xl);
    padding: var(--space-10);
    border: none;
  }

  .feature-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: var(--space-5);
  }

  .feature-card h3 {
    margin-bottom: var(--space-3);
  }

  .feature-card p {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.6;
  }
</style>
