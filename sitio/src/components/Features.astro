---
import { features as defaultFeatures } from '../data/home';

interface Feature {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  features?: Feature[];
  eyebrow?: string;
  title?: string;
  subtitle?: string;
}

const {
  features = defaultFeatures,
  eyebrow = 'Plataforma todo-en-uno',
  title = 'Todo lo que necesitas para operar tu negocio',
  subtitle = 'SACS reúne las herramientas que antes requerían 4 o 5 apps diferentes. Un solo lugar, cero fricción.',
} = Astro.props;
---

<section class="features section" id="features">
  <div class="container">
    <div class="features-header">
      <span class="eyebrow badge badge-blue">{eyebrow}</span>
      <h2 class="features-title">{title}</h2>
      <p class="body-large features-subtitle">{subtitle}</p>
    </div>

    <div class="features-grid">
      {features.map((feature) => (
        <div class="feature-card card">
          <span class="feature-icon" aria-hidden="true">{feature.icon}</span>
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    background: var(--color-bg-secondary);
  }

  .features-header {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: var(--space-16);
  }

  .features-title {
    margin-top: var(--space-5);
    margin-bottom: var(--space-4);
  }

  .features-subtitle {
    color: var(--color-text-secondary);
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .feature-card {
    background: var(--color-bg-card);
    border-radius: var(--radius-xl);
    padding: var(--space-10);
    border: none;
  }

  .feature-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: var(--space-5);
  }

  .feature-card h3 {
    margin-bottom: var(--space-3);
  }

  .feature-card p {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.6;
  }
</style>
