<script>
  const accordion = document.getElementById('showcase-accordion');
  const items = accordion?.querySelectorAll('.accordion-item');
  const mockups = document.querySelectorAll('.mockup');
  let autoPlayTimer: ReturnType<typeof setTimeout> | null = null;
  let currentIndex = 0;

  function activateItem(index: number) {
    if (!items) return;
    currentIndex = index;

    // Update accordion
    items.forEach((item, i) => {
      const isActive = i === index;
      item.classList.toggle('active', isActive);
      item.setAttribute('aria-expanded', String(isActive));

      // Restart progress animation
      if (isActive) {
        const fill = item.querySelector('.accordion-progress-fill') as HTMLElement;
        if (fill) {
          fill.style.animation = 'none';
          // Force reflow
          void fill.offsetHeight;
          fill.style.animation = '';
        }
      }
    });

    // Update mockups
    const targetId = items[index]?.getAttribute('data-id');
    mockups.forEach((mockup) => {
      mockup.classList.toggle('active', mockup.getAttribute('data-mockup') === targetId);
    });
  }

  function startAutoPlay() {
    stopAutoPlay();
    autoPlayTimer = setTimeout(() => {
      const nextIndex = (currentIndex + 1) % (items?.length || 1);
      activateItem(nextIndex);
      startAutoPlay();
    }, 6000);
  }

  function stopAutoPlay() {
    if (autoPlayTimer) {
      clearTimeout(autoPlayTimer);
      autoPlayTimer = null;
    }
  }

  // Click handlers
  items?.forEach((item, i) => {
    item.addEventListener('click', () => {
      activateItem(i);
      startAutoPlay(); // Reset timer on manual click
    });
  });

  // Start auto-play when section is visible
  const showcaseSection = document.getElementById('feature-showcase');
  if (showcaseSection) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            startAutoPlay();
          } else {
            stopAutoPlay();
          }
        });
      },
      { threshold: 0.2 }
    );
    observer.observe(showcaseSection);
  }
</script>
