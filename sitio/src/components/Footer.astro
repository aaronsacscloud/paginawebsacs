---
import { footerLinks } from '../data/navigation';
import { t, getLocalizedUrl } from '../i18n/utils';
import type { Locale } from '../i18n/config';

interface Props { locale?: Locale; }
const { locale = 'es' } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href={getLocalizedUrl('/', locale)} class="footer-logo" aria-label="SACS">
        <svg width="100" height="28" viewBox="0 0 120 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="14" cy="16" r="10" fill="#4B7BE5" opacity="0.9"/>
          <circle cx="22" cy="10" r="10" fill="#E8A838" opacity="0.85"/>
          <circle cx="26" cy="18" r="10" fill="#2AB5A0" opacity="0.85"/>
          <text x="42" y="23" font-family="'Clash Display', sans-serif" font-size="20" font-weight="700" fill="rgba(255,255,255,0.9)">Sacs</text>
        </svg>
      </a>
      <p class="footer-tagline">{t('footer.tagline', locale)}</p>
    </div>

    <div class="footer-col">
      <h4 class="footer-heading">{t('footer.platform', locale)}</h4>
      <ul class="footer-list">
        {footerLinks.vende.map((link) => (
          <li><a href={getLocalizedUrl(link.href, locale)}>{link.label}</a></li>
        ))}
        {footerLinks.controla.map((link) => (
          <li><a href={getLocalizedUrl(link.href, locale)}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h4 class="footer-heading">{t('footer.company', locale)}</h4>
      <ul class="footer-list">
        {footerLinks.empresa.map((link) => (
          <li><a href={getLocalizedUrl(link.href, locale)}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h4 class="footer-heading">{t('footer.resources', locale)}</h4>
      <ul class="footer-list">
        {footerLinks.recursos.map((link) => (
          <li><a href={getLocalizedUrl(link.href, locale)}>{link.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="container">
    <div class="footer-divider"></div>
    <div class="footer-bottom">
      <p class="footer-copyright">&copy; {currentYear} SACS. {t('footer.copyright', locale)}</p>
      <p class="footer-impact">{t('footer.impact', locale)}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-dark);
    color: var(--color-text-on-dark-muted);
    padding-block: var(--space-24);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
    }
  }

  .footer-logo {
    display: inline-block;
    margin-bottom: var(--space-4);
    text-decoration: none;
  }

  .footer-tagline {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-on-dark-subtle);
    max-width: 280px;
  }

  .footer-heading {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-on-dark);
    margin-bottom: var(--space-5);
    letter-spacing: 0;
  }

  .footer-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-list a {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-text-on-dark-subtle);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .footer-list a:hover {
    color: var(--color-text-on-dark);
    text-decoration: none;
  }

  .footer-divider {
    height: 1px;
    background: var(--color-border-on-dark);
    margin-top: var(--space-16);
    margin-bottom: var(--space-6);
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }

  .footer-copyright {
    font-size: 0.75rem;
    color: var(--color-text-on-dark-faint);
  }

  .footer-impact {
    font-size: 0.75rem;
    color: var(--color-secondary);
    font-weight: 500;
  }
</style>
