---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<section class="giro-stats">
  <div class="giro-stats-inner container">
    {stats.map((stat) => (
      <div class="giro-stat">
        <span class="giro-stat-value">{stat.value}</span>
        <span class="giro-stat-label">{stat.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .giro-stats {
    padding: var(--space-12) 0;
    background: var(--color-text-primary, #1A1A2E);
  }

  .giro-stats-inner {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
    text-align: center;
  }

  @media (min-width: 768px) {
    .giro-stats-inner {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .giro-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .giro-stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .giro-stat-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.3;
  }
</style>
