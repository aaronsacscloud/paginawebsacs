---
interface Props {
  title: string;
  description: string;
  points: string[];
  image: string;
  imageAlt: string;
  imageSide?: 'left' | 'right';
}

const { title, description, points, image, imageAlt, imageSide = 'left' } = Astro.props;
---

<section class="giro-split">
  <div class:list={['giro-split-inner', 'container', { 'giro-split-reverse': imageSide === 'right' }]}>
    <div class="giro-split-visual">
      <img src={image} alt={imageAlt} class="giro-split-image" width="800" height="600" loading="lazy" />
    </div>
    <div class="giro-split-content">
      <h2 class="giro-split-title">{title}</h2>
      <p class="giro-split-desc">{description}</p>
      <ul class="giro-split-points">
        {points.map((point) => (
          <li class="giro-split-point">
            <svg class="giro-split-check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
            <span>{point}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .giro-split {
    padding: var(--space-16) 0;
  }

  .giro-split:nth-child(even) {
    background: var(--color-bg-primary, #FAFAF8);
  }

  .giro-split-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  @media (min-width: 1024px) {
    .giro-split-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
      align-items: center;
    }

    .giro-split-reverse {
      direction: rtl;
    }

    .giro-split-reverse > * {
      direction: ltr;
    }
  }

  .giro-split-visual {
    border-radius: 16px;
    overflow: hidden;
    background: var(--color-bg-secondary, #F5F3EE);
  }

  .giro-split-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .giro-split-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .giro-split-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
  }

  .giro-split-desc {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  .giro-split-points {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
    margin-top: var(--space-2);
  }

  .giro-split-point {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
  }

  .giro-split-check {
    flex-shrink: 0;
    color: var(--color-secondary, #2AB5A0);
    margin-top: 2px;
  }
</style>
