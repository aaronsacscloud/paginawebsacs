---
interface FeatureItem {
  num: number;
  label: string;
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  link?: { label: string; href: string };
}

interface Props {
  items: FeatureItem[];
}

const { items } = Astro.props;
---

<section class="pfs-section">
  {items.map((item, i) => (
    <div class="pfs-block">
      <!-- Text top-left -->
      <div class="pfs-block-header container">
        <div class="pfs-block-text">
          <h2 class="pfs-block-title">{item.title}</h2>
          <p class="pfs-block-desc">{item.description}</p>
        </div>
      </div>
      <!-- Tablet with bg -->
      <div class="pfs-block-visual">
        <div class="pfs-block-bg"></div>
        <div class="pfs-tablet-container container">
          <div class="pfs-tablet">
            <div class="pfs-tablet-screen">
              <img src={item.image} alt={item.imageAlt} width="1400" height="900" loading="lazy" />
            </div>
            <div class="pfs-tablet-home"></div>
          </div>
        </div>
      </div>
    </div>
  ))}
</section>

<style>
  .pfs-section {
    background: #fff;
  }

  .pfs-block {
    padding-top: clamp(48px, 6vw, 80px);
    overflow: hidden;
  }

  /* ─── Text ─── */
  .pfs-block-text {
    max-width: 500px;
    margin-bottom: clamp(32px, 4vw, 48px);
  }

  .pfs-block-title {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    color: var(--color-text-primary, #1a1a2e);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 12px;
  }

  .pfs-block-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-secondary, #4A4A4A);
    margin: 0;
  }

  /* ─── Visual area ─── */
  .pfs-block-visual {
    position: relative;
    padding-bottom: clamp(48px, 6vw, 80px);
  }

  .pfs-block-bg {
    position: absolute;
    top: 25%;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, #c4b5a0 0%, #8b7d6b 40%, #5a4f42 100%);
    border-radius: 24px 24px 0 0;
  }

  /* ─── Tablet ─── */
  .pfs-tablet-container {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
  }

  .pfs-tablet {
    width: 100%;
    max-width: 900px;
    background: #fff;
    border-radius: 20px;
    padding: 14px 14px 8px;
    box-shadow:
      0 8px 24px rgba(0, 0, 0, 0.1),
      0 32px 80px rgba(0, 0, 0, 0.12);
  }

  .pfs-tablet-screen {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: #f5f5f5;
    border-radius: 10px;
  }

  .pfs-tablet-screen img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pfs-tablet-home {
    width: 40px;
    height: 5px;
    border-radius: 3px;
    background: #d4d4d4;
    margin: 10px auto 4px;
  }

  /* ─── Reveal ─── */
  .pfs-block-text,
  .pfs-block-visual {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pfs-block.visible .pfs-block-text {
    opacity: 1;
    transform: translateY(0);
  }

  .pfs-block.visible .pfs-block-visual {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 150ms;
  }

  @media (prefers-reduced-motion: reduce) {
    .pfs-block-text,
    .pfs-block-visual {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media (max-width: 767px) {
    .pfs-block-bg {
      border-radius: 16px 16px 0 0;
    }
    .pfs-tablet {
      border-radius: 14px;
      padding: 8px 8px 6px;
    }
    .pfs-tablet-screen {
      border-radius: 6px;
    }
  }
</style>

<script>
  const blocks = document.querySelectorAll('.pfs-block');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced && blocks.length > 0) {
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            obs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    blocks.forEach((b) => obs.observe(b));
  } else {
    blocks.forEach((b) => b.classList.add('visible'));
  }
</script>
