---
import { t } from '../i18n/utils';
import type { Locale } from '../i18n/config';

interface Props { locale?: Locale; }
const { locale = 'es' } = Astro.props;

const WHATSAPP_NUMBER = '5215536634392';
const DEFAULT_MESSAGE = t('whatsapp.message', locale);
---

<div class="whatsapp-float" id="whatsapp-float">
  <a
    id="whatsapp-link"
    href={`https://wa.me/${WHATSAPP_NUMBER}`}
    class="whatsapp-btn"
    target="_blank"
    rel="noopener noreferrer"
    aria-label={t('whatsapp.aria', locale)}
    aria-describedby="whatsapp-tooltip"
    data-number={WHATSAPP_NUMBER}
    data-message={DEFAULT_MESSAGE}
  >
    <svg class="whatsapp-icon" width="28" height="28" viewBox="0 0 24 24" fill="#fff" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    <span class="whatsapp-pulse" aria-hidden="true"></span>
  </a>
  <span class="whatsapp-tooltip" id="whatsapp-tooltip" role="tooltip">{t('whatsapp.tooltip', locale)}</span>
</div>

<style>
  .whatsapp-float {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    z-index: 998;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    opacity: 0;
    transform: translateX(80px);
    transition: opacity var(--duration-slow) var(--ease-default),
                transform var(--duration-slow) var(--ease-spring);
  }

  .whatsapp-float.is-visible {
    opacity: 1;
    transform: translateX(0);
  }

  .whatsapp-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: #25D366;
    color: #fff;
    text-decoration: none;
    box-shadow: 0 4px 14px rgba(37, 211, 102, 0.4);
    transition: transform var(--duration-fast) var(--ease-default),
                box-shadow var(--duration-fast) var(--ease-default);
    cursor: pointer;
  }

  .whatsapp-btn:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.5);
    text-decoration: none;
  }

  .whatsapp-btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  .whatsapp-icon {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }

  /* Pulse ring — 3 iterations then stops */
  .whatsapp-pulse {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid #25D366;
    opacity: 0;
    animation: whatsapp-ring 2s var(--ease-out) 3;
    animation-delay: 1.5s;
    pointer-events: none;
  }

  @keyframes whatsapp-ring {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    100% {
      transform: scale(1.5);
      opacity: 0;
    }
  }

  /* Tooltip — left of button */
  .whatsapp-tooltip {
    position: absolute;
    right: calc(100% + var(--space-3));
    top: 50%;
    transform: translateY(-50%);
    background: #fff;
    color: #1a1a1a;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--duration-fast) var(--ease-default);
  }

  .whatsapp-tooltip::after {
    content: '';
    position: absolute;
    right: -6px;
    top: 50%;
    transform: translateY(-50%);
    border: 6px solid transparent;
    border-left-color: #fff;
  }

  .whatsapp-float:hover .whatsapp-tooltip,
  .whatsapp-btn:focus-visible ~ .whatsapp-tooltip {
    opacity: 1;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .whatsapp-float {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .whatsapp-pulse {
      animation: none;
    }

    .whatsapp-btn {
      transition: none;
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .whatsapp-float {
      bottom: var(--space-4);
      right: var(--space-4);
    }

    .whatsapp-btn {
      width: 52px;
      height: 52px;
      box-shadow: 0 2px 8px rgba(37, 211, 102, 0.35);
    }

    .whatsapp-icon {
      width: 24px;
      height: 24px;
    }

    .whatsapp-tooltip {
      display: none;
    }
  }

  /* Safe area for Safari mobile */
  @supports (bottom: env(safe-area-inset-bottom)) {
    @media (max-width: 767px) {
      .whatsapp-float {
        bottom: calc(var(--space-4) + env(safe-area-inset-bottom, 0px));
      }
    }
  }
</style>

<script>
  {
    const link = document.getElementById('whatsapp-link') as HTMLAnchorElement;
    if (link) {
      const number = link.dataset.number;
      const message = link.dataset.message;
      const fullMessage = `${message} ${window.location.href}`;
      link.href = `https://wa.me/${number}?text=${encodeURIComponent(fullMessage)}`;
    }

    const float = document.getElementById('whatsapp-float');
    if (float) {
      requestAnimationFrame(() => {
        setTimeout(() => {
          float.classList.add('is-visible');
        }, 800);
      });
    }
  }
</script>
