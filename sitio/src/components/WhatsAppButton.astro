---
import { t } from '../i18n/utils';
import type { Locale } from '../i18n/config';

interface Props { locale?: Locale; }
const { locale = 'es' } = Astro.props;

const WHATSAPP_NUMBER = '5215536634392';
const DEFAULT_MESSAGE = t('whatsapp.message', locale);
---

<div class="wa-bar" id="wa-bar">
  <div class="wa-bar-inner">
    <p class="wa-bar-text">
      <span class="wa-bar-text-desktop">¿Tienes dudas? Chatea con un asesor ahora por</span>
      <span class="wa-bar-text-mobile">¿Dudas? Escríbenos por</span>
      <a
        id="wa-bar-link"
        href={`https://wa.me/${WHATSAPP_NUMBER}`}
        class="wa-bar-link"
        target="_blank"
        rel="noopener noreferrer"
        data-number={WHATSAPP_NUMBER}
        data-message={DEFAULT_MESSAGE}
      >WhatsApp</a>
    </p>
    <div class="wa-bar-actions">
      <a
        id="wa-bar-cta"
        href={`https://wa.me/${WHATSAPP_NUMBER}`}
        class="wa-bar-btn"
        target="_blank"
        rel="noopener noreferrer"
        data-number={WHATSAPP_NUMBER}
        data-message={DEFAULT_MESSAGE}
        aria-label="Enviar WhatsApp"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="#fff" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      </a>
      <button class="wa-bar-close" id="wa-bar-close" aria-label="Cerrar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
      </button>
    </div>
  </div>
</div>

<style>
  .wa-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 998;
    padding: 0 16px;
    padding-bottom: 16px;
    pointer-events: none;
    opacity: 0;
    transform: translateY(100%);
    transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .wa-bar.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .wa-bar.is-dismissed,
  .wa-bar.is-hidden-by-card {
    opacity: 0;
    transform: translateY(100%);
    pointer-events: none;
  }

  .wa-bar-inner {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 12px;
    background: #fff;
    border-radius: 16px;
    padding: 10px 10px 10px 20px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.10), 0 1px 4px rgba(0, 0, 0, 0.06);
  }

  .wa-bar-text {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-secondary, #555);
    margin: 0;
    line-height: 1;
    flex: 1;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 3px;
  }

  .wa-bar-text-mobile { display: none; }

  @media (max-width: 767px) {
    .wa-bar-text-desktop { display: none; }
    .wa-bar-text-mobile { display: inline; }
  }

  .wa-bar-link {
    color: var(--color-text-primary, #1a1a2e);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: rgba(26, 26, 46, 0.3);
    text-underline-offset: 2px;
    white-space: nowrap;
    transition: text-decoration-color 0.2s ease;
  }

  .wa-bar-link:hover {
    text-decoration-color: var(--color-text-primary, #1a1a2e);
  }

  .wa-bar-icon {
    display: inline-block;
    vertical-align: -2px;
    margin-right: 2px;
  }

  .wa-bar-actions {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .wa-bar-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #25D366;
    color: #fff;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .wa-bar-btn:hover {
    background: #1ebe5d;
    text-decoration: none;
  }

  .wa-bar-btn:focus-visible {
    outline: 2px solid #25D366;
    outline-offset: 2px;
  }

  .wa-bar-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: none;
    border: none;
    cursor: pointer;
    color: #999;
    transition: color 0.2s ease;
    padding: 0;
  }

  .wa-bar-close:hover {
    color: #333;
  }

  /* Mobile */
  @media (max-width: 767px) {
    .wa-bar {
      padding: 0 8px;
      padding-bottom: 8px;
    }

    .wa-bar-inner {
      padding: 6px 6px 6px 12px;     /* compactado para reducir altura total */
      border-radius: 12px;
      gap: 6px;
    }

    .wa-bar-text {
      font-size: 0.75rem;
      gap: 2px;
    }

    .wa-bar-btn {
      width: 36px;
      height: 36px;
    }

    .wa-bar-close {
      width: 28px;
      height: 28px;
    }
  }

  /* Safe area for Safari mobile */
  @supports (bottom: env(safe-area-inset-bottom)) {
    @media (max-width: 767px) {
      .wa-bar {
        padding-bottom: calc(10px + env(safe-area-inset-bottom, 0px));
      }
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .wa-bar {
      transition: none;
    }
  }
</style>

<script>
  {
    const bar = document.getElementById('wa-bar');
    const closeBtn = document.getElementById('wa-bar-close');
    const link = document.getElementById('wa-bar-link') as HTMLAnchorElement;
    const cta = document.getElementById('wa-bar-cta') as HTMLAnchorElement;

    // Set WhatsApp URLs with current page
    [link, cta].forEach(el => {
      if (el) {
        const num = el.dataset.number || link?.dataset.number;
        const msg = el.dataset.message || link?.dataset.message;
        const fullMsg = `${msg} ${window.location.href}`;
        el.href = `https://wa.me/${num}?text=${encodeURIComponent(fullMsg)}`;
      }
    });

    // Track clicks
    [link, cta].forEach(el => {
      el?.addEventListener('click', () => {
        try {
          if (typeof ttq !== 'undefined') {
            ttq.track('Contact', { content_id: 'whatsapp-bar', content_name: 'whatsapp-chat-bar', content_type: 'product' });
          }
        } catch {}
      });
    });

    // Show after delay
    if (bar) {
      const wasDismissed = sessionStorage.getItem('wa-bar-dismissed');
      if (!wasDismissed) {
        requestAnimationFrame(() => {
          setTimeout(() => {
            bar.classList.add('is-visible');
          }, 1500);
        });
      }
    }

    // Dismiss
    closeBtn?.addEventListener('click', () => {
      if (bar) {
        bar.classList.add('is-dismissed');
        bar.classList.remove('is-visible');
        sessionStorage.setItem('wa-bar-dismissed', '1');
      }
    });

    // Auto-hide when showcase featured cards are in view (to avoid covering their CTAs)
    const watchTargets = document.querySelectorAll('.sq-featured-card');
    if (bar && watchTargets.length > 0 && 'IntersectionObserver' in window) {
      const activeCards = new Set<Element>();
      const io = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) activeCards.add(entry.target);
          else activeCards.delete(entry.target);
        }
        if (bar.classList.contains('is-dismissed')) return;
        if (activeCards.size > 0) bar.classList.add('is-hidden-by-card');
        else bar.classList.remove('is-hidden-by-card');
      }, { rootMargin: '0px 0px -40% 0px' });
      watchTargets.forEach((el) => io.observe(el));
    }
  }
</script>
