---

<section class="final-cta">
  <div class="container final-cta-inner">
    <h2 class="final-cta-title">Empieza hoy. Es gratis.</h2>
    <p class="final-cta-desc">Configura tu negocio en 15 minutos. Sin tarjeta de crédito, sin contratos.</p>
    <a class="final-cta-btn" href="/contacto">Crear cuenta gratis</a>
  </div>
</section>

<style>
  .final-cta {
    background: var(--color-bg-dark);
    padding: var(--space-24) 0;
  }

  @media (min-width: 768px) {
    .final-cta {
      padding: var(--space-32) 0;
    }
  }

  @media (min-width: 1024px) {
    .final-cta {
      padding: var(--space-40) 0;
    }
  }

  .final-cta-inner {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
  }

  .final-cta-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-bottom: var(--space-5);
  }

  .final-cta-desc {
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
    margin-bottom: var(--space-10);
    max-width: 480px;
    margin-inline: auto;
  }

  .final-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.0625rem;
    font-weight: 600;
    padding: 16px 36px;
    border-radius: 6px;
    background: #fff;
    color: #0f0f1a;
    text-decoration: none;
    transition: all 0.2s ease;
    line-height: 1;
  }

  .final-cta-btn:hover {
    background: #f0f0f0;
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(255, 255, 255, 0.15);
    text-decoration: none;
  }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .final-cta-btn:hover {
      transform: none;
    }
  }

  /* ─── Mobile optimization ─── */
  @media (max-width: 767px) {
    .final-cta {
      padding: var(--space-16) 0;
    }

    .final-cta-title {
      font-size: clamp(1.75rem, 7vw, 2.5rem);
    }

    .final-cta-desc {
      font-size: 0.9375rem;
      margin-bottom: var(--space-8);
    }

    .final-cta-btn {
      width: 100%;
      padding: 16px 28px;
      font-size: 1rem;
    }
  }
</style>
