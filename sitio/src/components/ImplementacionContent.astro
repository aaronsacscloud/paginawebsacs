---
import {
  IMPL_METRICS,
  IMPL_STEPS,
  INCLUIDO_ITEMS,
  SOPORTE_ITEMS,
  OUTCOMES,
  CRECIMIENTO_STATS,
  SUMMARY_STEPS,
} from '../data/implementacion';

interface Props {
  variant: 'condensed' | 'full';
  empresa?: string;
  contacto?: string;
  nota?: string;
  isAnnual: boolean;
  quoteUrl?: string;
  implementacionUrl?: string;
}

const { variant, empresa, contacto, nota, isAnnual, quoteUrl, implementacionUrl } = Astro.props;
const isCondensed = variant === 'condensed';
const isFull = variant === 'full';
const greetingName = empresa || contacto || '';
const waNumber = '5215512345678';
const waText = encodeURIComponent('Hola SACS, me interesa contratar el plan anual para incluir toda la implementación.');
const waUrl = `https://wa.me/${waNumber}?text=${waText}`;
---

<section class={`impl-section impl-${variant}`}>
  {isFull && (
    <div class="impl-topbar">
      {quoteUrl && (
        <a href={quoteUrl} class="impl-backlink" aria-label="Volver a la cotización">
          <span class="impl-backlink-arrow" aria-hidden="true">←</span>
          <span>Volver a tu cotización</span>
        </a>
      )}
      <button type="button" class="impl-share" id="implShareBtn" aria-label="Compartir esta página">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="18" cy="5" r="3" stroke="currentColor" stroke-width="2"/><circle cx="6" cy="12" r="3" stroke="currentColor" stroke-width="2"/><circle cx="18" cy="19" r="3" stroke="currentColor" stroke-width="2"/><line x1="8.6" y1="10.5" x2="15.4" y2="6.5" stroke="currentColor" stroke-width="2"/><line x1="8.6" y1="13.5" x2="15.4" y2="17.5" stroke="currentColor" stroke-width="2"/></svg>
        <span class="impl-share-label">Compartir</span>
      </button>
    </div>
  )}

  {isFull && (
    <div class="impl-hero">
      <div class="impl-hero-label">Proceso de implementación</div>
      <h1 class="impl-hero-title">
        {greetingName ? `${greetingName}, ` : ''}empieza a operar en días, no en meses.
      </h1>
      <p class="impl-hero-desc">
        Tu negocio funcionando con SACS en menos de una semana. Nos encargamos de migrar tu información, capacitarte y dejarte operando. Todo incluido en tu plan anual.
      </p>
      <div class="impl-metrics">
        {IMPL_METRICS.map((m, i) => (
          <div class="impl-metric">
            <div class="impl-metric-num">{String(i + 1).padStart(2, '0')}</div>
            <div class="impl-metric-value">{m.value}</div>
            <div class="impl-metric-label">{m.label}</div>
          </div>
        ))}
      </div>
    </div>
  )}

  {isCondensed && (
    <div class="impl-heading">
      <div class="impl-heading-label">¿Qué sigue cuando contratas?</div>
      <h2 class="impl-heading-title">Empieza a operar en días, no en meses.</h2>
      <p class="impl-heading-desc">Tu negocio funcionando con SACS en menos de una semana. Así se ve el proceso completo:</p>
    </div>
  )}

  {!isAnnual && (
    <div class="impl-warn">
      <div class="impl-warn-body">
        <div class="impl-warn-eyebrow">Solo plan anual</div>
        <div class="impl-warn-title">Este proceso se incluye al contratar plan anual.</div>
        <p class="impl-warn-text">
          En plan mensual no aplica la migración completa ni las sesiones 1-a-1 con consultor. Contrata anual y te migramos toda tu información, capacitamos a tu equipo, y te damos 2 sesiones con un experto — todo sin costo adicional.
        </p>
        <div class="impl-warn-ctas">
          <a href={waUrl} target="_blank" rel="noopener" class="impl-warn-cta impl-warn-cta--primary">Hablar con asesor</a>
          {quoteUrl && <a href={quoteUrl} class="impl-warn-cta impl-warn-cta--ghost">Volver a tu cotización</a>}
        </div>
      </div>
    </div>
  )}

  {nota && (
    <div class="impl-nota">
      <span class="impl-nota-label">Nota para ti:</span>
      <span>{nota}</span>
    </div>
  )}

  <!-- Process steps -->
  <div class="impl-steps">
    {IMPL_STEPS.map((step, idx) => (
      <div class="impl-step">
        <div class="impl-step-rail">
          <div class="impl-step-num">{String(idx + 1).padStart(2, '0')}</div>
        </div>
        <div class="impl-step-body">
          <div class="impl-step-badge">{step.dayBadge}</div>
          <h3 class="impl-step-title">{step.title}</h3>
          <p class="impl-step-desc">{step.description}</p>
          <ul class="impl-step-bullets">
            {step.bullets.map(b => <li><span class="impl-step-bullet-mark">·</span>{b}</li>)}
          </ul>
          {isFull && (
            <div class="impl-step-duration">{step.durationBadge.text}</div>
          )}
        </div>
      </div>
    ))}
  </div>

  <!-- Incluido en tu plan -->
  <div class="impl-included">
    <div class="impl-included-head">
      <h3 class="impl-included-title">{isAnnual ? 'Todo lo que recibes con tu pago anual.' : 'Lo que recibes al contratar plan anual.'}</h3>
      <p class="impl-included-desc">Además del proceso de implementación, tu plan anual incluye recursos de aprendizaje y soporte continuo para que nunca te quedes sin ayuda.</p>
    </div>
    <div class="impl-included-grid">
      {INCLUIDO_ITEMS.map((item, i) => (
        <div class="impl-included-card">
          <div class="impl-included-num">{String(i + 1).padStart(2, '0')}</div>
          <h4 class="impl-included-card-title">{item.title}</h4>
          <p class="impl-included-card-desc">{item.description}</p>
        </div>
      ))}
    </div>
  </div>

  {isFull && (
    <>
      <!-- Soporte continuo -->
      <div class="impl-support">
        <div class="impl-support-head">
          <h3 class="impl-support-title">Nunca te quedas sin ayuda.</h3>
          <p class="impl-support-desc">Desde sesiones 1-a-1 con consultores hasta chat 24/7, tienes múltiples canales para resolver cualquier duda en el momento que la necesites.</p>
        </div>
        <div class="impl-support-grid">
          {SOPORTE_ITEMS.map((s, i) => (
            <div class="impl-support-card">
              <div class="impl-support-num">{String(i + 1).padStart(2, '0')}</div>
              <h4 class="impl-support-card-title">{s.title}</h4>
              <p class="impl-support-card-desc">{s.description}</p>
              {s.badge && <div class="impl-support-badge">{s.badge}</div>}
            </div>
          ))}
        </div>
      </div>

      <!-- Lo que logras -->
      <div class="impl-outcomes">
        <div class="impl-outcomes-head">
          <h3 class="impl-outcomes-title">Al final del proceso, tienes todo conectado.</h3>
          <p class="impl-outcomes-desc">Tu negocio no solo opera en una tienda física. Tienes presencia digital completa con todos tus canales de venta sincronizados en un solo sistema.</p>
        </div>
        <div class="impl-outcomes-grid">
          {OUTCOMES.map((o, i) => (
            <div class="impl-outcome-card">
              <div class="impl-outcome-num">{String(i + 1).padStart(2, '0')}</div>
              <h4 class="impl-outcome-title">{o.title}</h4>
              <p class="impl-outcome-desc">{o.description}</p>
              <ul class="impl-outcome-bullets">
                {o.bullets.map(b => <li><span class="impl-outcome-bullet-mark">·</span>{b}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <!-- Crecimiento -->
      <div class="impl-grow">
        <div class="impl-grow-head">
          <h3 class="impl-grow-title">Después del primer proceso, crecer es fácil.</h3>
          <p class="impl-grow-desc">El primer proceso de implementación es el más complejo porque incluye toda la migración. Después de eso, agregar otra sucursal es rápido y sencillo.</p>
        </div>
        <div class="impl-grow-hero">
          <h4 class="impl-grow-hero-title">Otra sucursal en menos de 7 días.</h4>
          <p class="impl-grow-hero-desc">Una vez que tienes la primera tienda operando, la información ya está en el sistema. Agregar otra sucursal es solo configurar un nuevo punto de venta — sin migración, sin capacitación desde cero.</p>
          <ul class="impl-grow-bullets">
            <li><span class="impl-grow-bullet-mark">·</span>Misma información, nueva ubicación</li>
            <li><span class="impl-grow-bullet-mark">·</span>Inventario independiente por sucursal</li>
            <li><span class="impl-grow-bullet-mark">·</span>Reportes consolidados o por sucursal</li>
            <li><span class="impl-grow-bullet-mark">·</span>Lo haces tú mismo con lo que ya aprendiste</li>
          </ul>
        </div>
        <div class="impl-grow-stats">
          {CRECIMIENTO_STATS.map(s => (
            <div class="impl-grow-stat">
              <div class="impl-grow-stat-value">{s.value}</div>
              <div class="impl-grow-stat-label">{s.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Resumen visual -->
      <div class="impl-summary">
        <div class="impl-summary-head">
          <h3 class="impl-summary-title">De pago a operación, así de simple.</h3>
          <p class="impl-summary-desc">Tu recorrido completo en 5 pasos. Todo incluido, todo acompañado.</p>
        </div>
        <div class="impl-summary-grid">
          {SUMMARY_STEPS.map((s, i) => (
            <div class="impl-summary-step">
              <div class="impl-summary-num">{String(i + 1).padStart(2, '0')}</div>
              <h4 class="impl-summary-step-title">{s.title}</h4>
              <p class="impl-summary-step-desc">{s.description}</p>
              <div class="impl-summary-timing">{s.timing}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Footer CTAs -->
      <div class="impl-footer-cta">
        <h3 class="impl-footer-title">{isAnnual ? 'Todo listo para arrancar.' : 'Empieza a operar esta semana.'}</h3>
        <p class="impl-footer-desc">
          {isAnnual
            ? 'Regresa a tu cotización cuando quieras o contáctanos si necesitas algo más.'
            : 'Plan anual con implementación completa. Migración, capacitación, soporte y todos tus canales conectados. Tú solo mandas tu información — nosotros hacemos el resto.'}
        </p>
        <div class="impl-footer-buttons">
          {quoteUrl && <a href={quoteUrl} class="impl-btn impl-btn--primary">← Volver a tu cotización</a>}
          <a href={waUrl} target="_blank" rel="noopener" class="impl-btn impl-btn--secondary">Hablar con un asesor</a>
        </div>
      </div>
    </>
  )}

  {isCondensed && implementacionUrl && (
    <div class="impl-cta">
      <a href={implementacionUrl} class="impl-cta-link">Ver proceso completo con soporte, outcomes y crecimiento →</a>
    </div>
  )}
</section>

{isFull && !isAnnual && (
  <div class="impl-sticky-bar" id="implStickyBar" aria-hidden="true">
    <div class="impl-sticky-inner">
      <div class="impl-sticky-text">
        <span class="impl-sticky-highlight">¿Quieres toda esta implementación?</span>
        <span class="impl-sticky-sub">Está incluida al cambiar a plan anual.</span>
      </div>
      <div class="impl-sticky-ctas">
        <a href={waUrl} target="_blank" rel="noopener" class="impl-sticky-btn">Cambiar a anual</a>
        {quoteUrl && <a href={quoteUrl} class="impl-sticky-btn impl-sticky-btn--ghost">Cotización</a>}
      </div>
    </div>
  </div>
)}

<style>
  /* ═══════════════════════════════════════════════
     Squarespace-style: monochromatic, typographic,
     single accent (teal #2AB5A0), no gradients,
     no shadows, generous whitespace.
     ═══════════════════════════════════════════════ */

  .impl-section {
    max-width: 680px;
    margin: 0 auto;
    padding: 48px 48px;
    font-family: inherit;
    color: #1a1a1a;
  }
  .impl-full { padding: 56px 56px 96px; max-width: 820px; }
  .impl-condensed { padding: 40px 48px; }

  /* ── Top bar ── */
  .impl-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 1px solid #e5e5e5;
  }
  .impl-backlink,
  .impl-share {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 0;
    background: transparent;
    border: none;
    color: #666;
    font-family: inherit;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    cursor: pointer;
    transition: color 0.15s ease;
  }
  .impl-backlink:hover,
  .impl-share:hover { color: #2AB5A0; }
  .impl-backlink-arrow { font-size: 1rem; line-height: 1; }
  .impl-share.impl-share--copied { color: #2AB5A0; }

  /* ── Hero ── */
  .impl-hero {
    padding: 64px 0 80px;
    text-align: left;
    border-bottom: 1px solid #e5e5e5;
    margin-bottom: 64px;
  }
  .impl-hero-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 24px;
  }
  .impl-hero-title {
    font-family: var(--font-display, inherit);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin: 0 0 24px;
    color: #1a1a1a;
    max-width: 820px;
  }
  .impl-hero-desc {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: #666;
    margin: 0 0 48px;
    max-width: 640px;
  }
  .impl-metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 40px;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid #e5e5e5;
  }
  .impl-metric {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .impl-metric-num {
    font-size: 0.6875rem;
    font-weight: 500;
    color: #bbb;
    letter-spacing: 0.08em;
  }
  .impl-metric-value {
    font-family: var(--font-display, inherit);
    font-size: 1.875rem;
    font-weight: 300;
    color: #1a1a1a;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .impl-metric-label {
    font-size: 0.8125rem;
    color: #999;
    line-height: 1.4;
  }

  /* ── Condensed heading ── */
  .impl-heading {
    padding: 8px 0 32px;
    margin-bottom: 32px;
    border-bottom: 1px solid #e5e5e5;
  }
  .impl-heading-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 14px;
  }
  .impl-heading-title {
    font-family: var(--font-display, inherit);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0 0 10px;
    color: #1a1a1a;
  }
  .impl-heading-desc {
    font-size: 0.9375rem;
    color: #666;
    line-height: 1.5;
    margin: 0;
    max-width: 540px;
  }

  /* ── Monthly warn banner (mono) ── */
  .impl-warn {
    background: #fafafa;
    border-left: 2px solid #1a1a1a;
    padding: 24px 28px;
    margin-bottom: 48px;
  }
  .impl-warn-body { display: flex; flex-direction: column; gap: 10px; }
  .impl-warn-eyebrow {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #999;
  }
  .impl-warn-title {
    font-family: var(--font-display, inherit);
    font-weight: 500;
    font-size: 1.125rem;
    color: #1a1a1a;
    letter-spacing: -0.01em;
  }
  .impl-warn-text {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.55;
    margin: 0;
  }
  .impl-warn-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 6px;
  }
  .impl-warn-cta {
    display: inline-block;
    padding: 12px 22px;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .impl-warn-cta--primary { background: #1a1a1a; color: #fff; }
  .impl-warn-cta--primary:hover { background: #2AB5A0; }
  .impl-warn-cta--ghost {
    background: transparent;
    color: #1a1a1a;
    border: 1px solid #1a1a1a;
  }
  .impl-warn-cta--ghost:hover { background: #1a1a1a; color: #fff; }

  /* ── Admin note ── */
  .impl-nota {
    padding: 16px 0;
    margin-bottom: 48px;
    border-top: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
    font-size: 0.875rem;
    color: #666;
    line-height: 1.5;
  }
  .impl-nota-label {
    font-weight: 600;
    color: #1a1a1a;
    letter-spacing: 0.02em;
    margin-right: 8px;
  }

  /* ── Steps (numbered, typographic, no shadows) ── */
  .impl-steps {
    display: flex;
    flex-direction: column;
    margin-bottom: 64px;
  }
  .impl-step {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 28px;
    padding: 32px 0;
    border-top: 1px solid #e5e5e5;
  }
  .impl-step:last-child { border-bottom: 1px solid #e5e5e5; }
  .impl-step-rail {
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    padding-top: 6px;
  }
  .impl-step-num {
    font-family: var(--font-display, inherit);
    font-size: 1.5rem;
    font-weight: 300;
    color: #bbb;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .impl-step-body { min-width: 0; }
  .impl-step-badge {
    display: inline-block;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 12px;
  }
  .impl-step-title {
    font-family: var(--font-display, inherit);
    font-size: 1.375rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.25;
    margin: 0 0 10px;
    color: #1a1a1a;
  }
  .impl-step-desc {
    font-size: 0.9375rem;
    color: #666;
    line-height: 1.55;
    margin: 0 0 20px;
    max-width: 620px;
  }
  .impl-step-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .impl-step-bullets li {
    font-size: 0.875rem;
    color: #444;
    line-height: 1.55;
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }
  .impl-step-bullet-mark {
    color: #2AB5A0;
    font-weight: 700;
    flex-shrink: 0;
    font-size: 1rem;
    line-height: 1.3;
  }
  .impl-step-duration {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #999;
    padding: 4px 0;
    border-top: 1px solid #e5e5e5;
    margin-top: 14px;
    padding-top: 10px;
  }

  /* ── Incluido ── */
  .impl-included {
    padding: 64px 0;
    margin-bottom: 64px;
    border-top: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
  }
  .impl-included-head {
    margin-bottom: 48px;
    max-width: 640px;
  }
  .impl-included-title {
    font-family: var(--font-display, inherit);
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
    color: #1a1a1a;
  }
  .impl-included-desc {
    font-size: 0.9375rem;
    color: #666;
    line-height: 1.55;
    margin: 0;
  }
  .impl-included-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 40px 48px;
  }
  .impl-included-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .impl-included-num {
    font-size: 0.6875rem;
    font-weight: 500;
    color: #bbb;
    letter-spacing: 0.08em;
    margin-bottom: 2px;
  }
  .impl-included-card-title {
    font-family: var(--font-display, inherit);
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    margin: 0 0 4px;
    color: #1a1a1a;
  }
  .impl-included-card-desc {
    font-size: 0.8125rem;
    color: #666;
    line-height: 1.55;
    margin: 0;
  }

  /* ── Support ── */
  .impl-support {
    padding: 48px 0;
    margin-bottom: 64px;
    border-bottom: 1px solid #e5e5e5;
  }
  .impl-support-head { margin-bottom: 40px; max-width: 640px; }
  .impl-support-title {
    font-family: var(--font-display, inherit);
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0 0 12px;
    color: #1a1a1a;
  }
  .impl-support-desc {
    font-size: 0.9375rem;
    color: #666;
    line-height: 1.55;
    margin: 0;
  }
  .impl-support-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 40px 48px;
  }
  .impl-support-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .impl-support-num {
