---
interface Tool {
  icon: string;
  title: string;
  description: string;
  bullets?: string[];
  image?: string;
  imageAlt?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  items: Tool[];
}

const { eyebrow, title, subtitle, items } = Astro.props;
---

<section class="sq2-discovery reveal-section">
  <div class="sq2-discovery-inner container">
    <header class="sq2-discovery-header">
      {eyebrow && <span class="sq2-discovery-eyebrow reveal-item">{eyebrow}</span>}
      <h2 class="sq2-discovery-title reveal-item" style="--reveal-delay: 80ms">{title}</h2>
      {subtitle && <p class="sq2-discovery-subtitle reveal-item" style="--reveal-delay: 140ms">{subtitle}</p>}
    </header>

    <div class="sq2-discovery-grid">
      {items.map((item, i) => (
        <div class={`sq2-discovery-card reveal-item${item.image ? ' sq2-discovery-card--with-image' : ''}`} style={`--reveal-delay: ${180 + i * 80}ms`}>
          {item.image && (
            <div class="sq2-discovery-card-media">
              <img src={item.image} alt={item.imageAlt || ''} width="1536" height="1024" loading="lazy" />
            </div>
          )}
          <div class="sq2-discovery-card-body">
            {!item.image && <div class="sq2-discovery-icon" set:html={item.icon} />}
            <h3 class="sq2-discovery-card-title">{item.title}</h3>
            <p class="sq2-discovery-card-desc">{item.description}</p>
            {item.bullets && item.bullets.length > 0 && (
              <ul class="sq2-discovery-list">
                {item.bullets.map((b) => (
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M5 12l5 5L20 7" />
                    </svg>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .sq2-discovery {
    background: #fff;
    padding: clamp(72px, 10vw, 140px) 0;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
  }

  .sq2-discovery-header {
    max-width: 760px;
    margin: 0 auto clamp(40px, 5vw, 64px);
    text-align: center;
  }

  .sq2-discovery-eyebrow {
    display: inline-block;
    font-family: var(--font-body, 'Plus Jakarta Sans', sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #4B7BE5;
    margin-bottom: 16px;
  }

  .sq2-discovery-title {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: #1a1a2e;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 16px;
  }

  .sq2-discovery-subtitle {
    font-size: clamp(0.9375rem, 1.4vw, 1.0625rem);
    line-height: 1.65;
    color: #4A4A4A;
    margin: 0;
  }

  .sq2-discovery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .sq2-discovery-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }
  }

  .sq2-discovery-card {
    padding: clamp(24px, 3vw, 36px) clamp(20px, 2.5vw, 32px);
    border-radius: 18px;
    background: #FAFAF8;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sq2-discovery-card--with-image {
    padding: 0;
    overflow: hidden;
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  .sq2-discovery-card-media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #FAFAF8;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }

  .sq2-discovery-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sq2-discovery-card--with-image .sq2-discovery-card-body {
    padding: clamp(24px, 3vw, 32px) clamp(22px, 2.5vw, 30px) clamp(28px, 3vw, 36px);
  }

  .sq2-discovery-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.06);
  }

  .sq2-discovery-icon {
    width: 44px;
    height: 44px;
    background: rgba(75, 123, 229, 0.1);
    color: #4B7BE5;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
  }

  .sq2-discovery-icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  .sq2-discovery-card-title {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1a1a2e;
    letter-spacing: -0.02em;
    margin: 0 0 10px;
  }

  .sq2-discovery-card-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #4A4A4A;
    margin: 0 0 16px;
  }

  .sq2-discovery-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sq2-discovery-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.875rem;
    color: #1a1a2e;
    line-height: 1.5;
  }

  .sq2-discovery-list svg {
    color: #4B7BE5;
    flex-shrink: 0;
    margin-top: 4px;
  }

  @media (max-width: 767px) {
    .sq2-discovery-card:hover {
      transform: none;
      box-shadow: none;
    }
  }
</style>
