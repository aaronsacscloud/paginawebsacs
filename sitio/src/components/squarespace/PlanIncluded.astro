---
interface FeatureGroup {
  category: string;
  items: string[];
  planName: string;
}

interface Plan {
  name: string;
  monthly: { mxn: number };
  annual: { mxn: number };
  annualTotal: { mxn: number };
  cta: { href: string };
}

interface Props {
  featureLabel: string;
  plan: Plan;
  inheritedPlanName?: string;
  featureGroups: FeatureGroup[];
}

const { featureLabel, plan, inheritedPlanName, featureGroups } = Astro.props;
---

<section class="pl-section">
  <div class="pl-inner container">
    <div class="pl-header">
      <div>
        <h2 class="pl-title">{featureLabel} incluido en el plan {plan.name}</h2>
        <p class="pl-subtitle">Todo lo que necesitas desde ${plan.monthly.mxn.toLocaleString('en-US')} MXN/mes{inheritedPlanName ? ` · incluye todo lo del plan ${inheritedPlanName}` : ''}.</p>
      </div>
      <a href="/planes" class="pl-link">Ver todos los planes
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="pl-card">
      <div class="pl-card-top">
        <div class="pl-price-col">
          <span class="pl-plan-name">{plan.name}</span>
          <div class="pl-price-row">
            <span class="pl-price">${plan.monthly.mxn.toLocaleString('en-US')}</span>
            <span class="pl-period">MXN /mes por sucursal</span>
          </div>
          <p class="pl-annual">Pago anual: <strong>${plan.annual.mxn.toLocaleString('en-US')}/mes</strong> · ${plan.annualTotal.mxn.toLocaleString('en-US')}/año <span class="pl-save">Ahorra 2 meses</span></p>
        </div>
        <div class="pl-ctas">
          <a href="/prueba-gratis" class="pl-cta pl-cta--solid">Prueba 7 días gratis</a>
          <a href={plan.cta.href} class="pl-cta">Inicia ahora</a>
        </div>
      </div>

      <div class="pl-grid">
        {featureGroups.map((group) => (
          <div class="pl-group">
            <h4 class="pl-cat">
              {group.category}
              {inheritedPlanName && group.planName !== plan.name && (
                <span class="pl-from">Plan {group.planName}</span>
              )}
            </h4>
            <ul class="pl-list">
              {group.items.map((item) => (
                <li class="pl-item">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2AB5A0" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .pl-section {
    padding: clamp(64px, 8vw, 100px) 0;
    background: #fff;
  }

  .pl-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: clamp(32px, 4vw, 48px);
    flex-wrap: wrap;
  }

  .pl-title {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    color: var(--color-text-primary, #1a1a2e);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0;
  }

  .pl-subtitle {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--color-text-secondary, #4A4A4A);
    margin: 8px 0 0;
  }

  .pl-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-secondary, #4A4A4A);
    text-decoration: none;
    padding: 10px 20px;
    border: 1.5px solid rgba(0, 0, 0, 0.12);
    border-radius: var(--radius-full, 50px);
    transition: border-color 0.2s ease;
    white-space: nowrap;
  }

  .pl-link:hover {
    border-color: rgba(0, 0, 0, 0.3);
    text-decoration: none;
  }

  .pl-card {
    background: var(--color-bg-primary, #FAFAF8);
    border-radius: 20px;
    padding: clamp(28px, 4vw, 40px);
  }

  .pl-card-top {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-bottom: clamp(24px, 3vw, 32px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    margin-bottom: clamp(24px, 3vw, 32px);
  }

  @media (min-width: 768px) {
    .pl-card-top {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .pl-plan-name {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-tertiary, #8c8c8c);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: block;
    margin-bottom: 4px;
  }

  .pl-price-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .pl-price {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--color-text-primary, #1a1a2e);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .pl-period {
    font-size: 0.875rem;
    color: var(--color-text-tertiary, #8c8c8c);
  }

  .pl-annual {
    font-size: 0.8125rem;
    color: var(--color-text-tertiary, #8c8c8c);
    margin: 8px 0 0;
  }

  .pl-annual strong {
    color: var(--color-text-primary, #1a1a2e);
  }

  .pl-save {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    color: #2AB5A0;
    background: rgba(42, 181, 160, 0.1);
    padding: 2px 8px;
    border-radius: 4px;
    margin-left: 6px;
  }

  .pl-ctas {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .pl-cta {
    display: inline-block;
    text-align: center;
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.875rem;
    font-weight: 700;
    padding: 12px 28px;
    border-radius: var(--radius-full, 50px);
    text-decoration: none;
    transition: all 0.2s ease;
    color: var(--color-text-primary, #1a1a2e);
    border: 1.5px solid rgba(0, 0, 0, 0.15);
    background: transparent;
    white-space: nowrap;
  }

  .pl-cta:hover {
    border-color: rgba(0, 0, 0, 0.3);
    text-decoration: none;
  }

  .pl-cta--solid {
    background: var(--color-text-primary, #1a1a2e);
    color: #fff;
    border-color: var(--color-text-primary, #1a1a2e);
  }

  .pl-cta--solid:hover {
    background: #2a2a3e;
    border-color: #2a2a3e;
  }

  .pl-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(24px, 3vw, 32px);
  }

  @media (min-width: 640px) {
    .pl-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .pl-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .pl-cat {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-text-primary, #1a1a2e);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .pl-from {
    font-size: 0.625rem;
    font-weight: 600;
    color: #6b6b75;
    background: #f2f2f5;
    padding: 2px 8px;
    border-radius: 50px;
    text-transform: none;
    letter-spacing: 0;
  }

  .pl-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pl-item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--color-text-secondary, #4A4A4A);
  }

  .pl-item svg {
    flex-shrink: 0;
    margin-top: 1px;
  }
</style>
