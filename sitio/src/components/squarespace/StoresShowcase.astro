---
interface Store {
  name: string;
  category: string;
  location: string;
  image: string;
  imageAlt: string;
  href?: string;
  accent?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  ctaLabel?: string;
  ctaHref?: string;
  stores: Store[];
}

const { eyebrow, title, subtitle, ctaLabel, ctaHref, stores } = Astro.props;
---

<section class="sq2-stores reveal-section">
  <div class="sq2-stores-inner container">
    <header class="sq2-stores-header">
      {eyebrow && <span class="sq2-stores-eyebrow reveal-item">{eyebrow}</span>}
      <h2 class="sq2-stores-title reveal-item" style="--reveal-delay: 80ms">{title}</h2>
      {subtitle && <p class="sq2-stores-subtitle reveal-item" style="--reveal-delay: 140ms">{subtitle}</p>}
    </header>

    <div class="sq2-stores-grid">
      {stores.map((store, i) => (
        <a
          class="sq2-store reveal-item"
          href={store.href || '#'}
          style={`--reveal-delay: ${200 + i * 80}ms; --accent: ${store.accent || '#4B7BE5'}`}
        >
          <div class="sq2-store-media">
            <img
              src={store.image}
              alt={store.imageAlt}
              width="800"
              height="600"
              loading="lazy"
            />
          </div>
          <div class="sq2-store-meta">
            <span class="sq2-store-category">{store.category}</span>
            <h3 class="sq2-store-name">{store.name}</h3>
            <span class="sq2-store-location">
              {store.location}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M13 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    {ctaLabel && (
      <div class="sq2-stores-cta reveal-item" style="--reveal-delay: 600ms">
        <a class="sq2-stores-link" href={ctaHref || '#'}>{ctaLabel}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    )}
  </div>
</section>

<style>
  .sq2-stores {
    background: #fff;
    padding: clamp(72px, 10vw, 140px) 0;
  }

  .sq2-stores-header {
    max-width: 760px;
    margin: 0 auto clamp(40px, 5vw, 64px);
    text-align: center;
  }

  .sq2-stores-eyebrow {
    display: inline-block;
    font-family: var(--font-body, 'Plus Jakarta Sans', sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #4B7BE5;
    margin-bottom: 16px;
  }

  .sq2-stores-title {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: #1a1a2e;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 16px;
  }

  .sq2-stores-subtitle {
    font-size: clamp(0.9375rem, 1.4vw, 1.0625rem);
    line-height: 1.65;
    color: #4A4A4A;
    margin: 0;
  }

  .sq2-stores-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(20px, 2vw, 28px);
  }

  @media (min-width: 768px) {
    .sq2-stores-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .sq2-store {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 18px;
    overflow: hidden;
    background: #fff;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sq2-store:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.1);
    text-decoration: none;
  }

  .sq2-store-media {
    aspect-ratio: 4 / 3;
    background: #f5f3ee;
    overflow: hidden;
    border-radius: 14px;
  }

  .sq2-store-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sq2-store:hover .sq2-store-media img {
    transform: scale(1.03);
  }

  .sq2-store-meta {
    padding: 18px 4px 4px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .sq2-store-category {
    font-family: var(--font-body, 'Plus Jakarta Sans', sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent, #4B7BE5);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .sq2-store-name {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 1.1875rem;
    font-weight: 700;
    color: #1a1a2e;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .sq2-store-location {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #6b6b6b;
    transition: color 0.3s ease, gap 0.3s ease;
  }

  .sq2-store:hover .sq2-store-location {
    color: var(--accent, #4B7BE5);
    gap: 12px;
  }

  .sq2-stores-cta {
    text-align: center;
    margin-top: clamp(32px, 4vw, 48px);
  }

  .sq2-stores-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.875rem;
    font-weight: 700;
    color: #1a1a2e;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border-bottom: 1.5px solid #1a1a2e;
    padding-bottom: 4px;
    transition: color 0.3s ease, border-color 0.3s ease, gap 0.3s ease;
  }

  .sq2-stores-link:hover {
    color: #4B7BE5;
    border-color: #4B7BE5;
    gap: 12px;
    text-decoration: none;
  }

  @media (max-width: 767px) {
    .sq2-store:hover {
      transform: none;
      box-shadow: none;
    }
    .sq2-store:hover .sq2-store-media img { transform: none; }
  }
</style>
