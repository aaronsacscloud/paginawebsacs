---
interface Props {
  text: string;
  accent: string;
  bg?: string;
}

const { text, accent, bg = '#0a0a0a' } = Astro.props;
---

<section class="sq2-manifesto reveal-section" style={`--mf-bg: ${bg};`}>
  <div class="sq2-manifesto-inner container">
    <h2 class="sq2-manifesto-text reveal-item">
      <span class="sq2-manifesto-text-base">{text}</span>{' '}<span class="sq2-manifesto-text-accent">{accent}</span>
    </h2>
  </div>
</section>

<style>
  .sq2-manifesto {
    background: var(--mf-bg);
    padding: clamp(120px, 18vw, 240px) 0;
    overflow: hidden;
  }

  .sq2-manifesto-inner {
    max-width: 1400px;
  }

  .sq2-manifesto-text {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: clamp(2.5rem, 7.2vw, 7rem);
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 0.98;
    margin: 0;
    color: #fff;
  }

  .sq2-manifesto-text-base {
    color: #fff;
  }

  .sq2-manifesto-text-accent {
    color: #4B7BE5;
  }

  @media (max-width: 640px) {
    .sq2-manifesto-text {
      letter-spacing: -0.035em;
    }
  }
</style>
