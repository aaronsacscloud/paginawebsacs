---
interface SupportItem {
  eyebrow?: string;
  title: string;
  description: string;
  href: string;
  ctaLabel: string;
}

interface Props {
  items: SupportItem[];
}

const { items } = Astro.props;
---

<section class="sq2-support reveal-section">
  <div class="sq2-support-inner container">
    <div class="sq2-support-grid">
      {items.map((item, i) => (
        <a class="sq2-support-card reveal-item" href={item.href} style={`--reveal-delay: ${100 + i * 100}ms`}>
          {item.eyebrow && <span class="sq2-support-eyebrow">{item.eyebrow}</span>}
          <h3 class="sq2-support-title">{item.title}</h3>
          <p class="sq2-support-desc">{item.description}</p>
          <span class="sq2-support-cta">
            {item.ctaLabel}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .sq2-support {
    background: #1a1a2e;
    padding: clamp(64px, 8vw, 110px) 0;
  }

  .sq2-support-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 768px) {
    .sq2-support-grid {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
  }

  .sq2-support-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 18px;
    padding: clamp(28px, 3.5vw, 44px);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: background 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
  }

  .sq2-support-card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(255, 255, 255, 0.14);
    transform: translateY(-3px);
    text-decoration: none;
  }

  .sq2-support-eyebrow {
    font-family: var(--font-body, 'Plus Jakarta Sans', sans-serif);
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .sq2-support-title {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .sq2-support-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .sq2-support-cta {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    padding-top: clamp(20px, 2.5vw, 28px);
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.8125rem;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    transition: gap 0.3s ease;
  }

  .sq2-support-card:hover .sq2-support-cta {
    gap: 12px;
  }

  @media (max-width: 767px) {
    .sq2-support-card:hover {
      transform: none;
    }
  }
</style>
