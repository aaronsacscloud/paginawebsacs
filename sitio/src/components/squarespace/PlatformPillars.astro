---
interface Pillar {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  bg: string;
  textColor?: string;
  href?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  items: Pillar[];
}

const { eyebrow, title, subtitle, items } = Astro.props;
---

<section class="sq2-pillars reveal-section">
  <div class="sq2-pillars-inner container">
    <header class="sq2-pillars-header">
      <div class="sq2-pillars-header-left">
        {eyebrow && <span class="sq2-pillars-eyebrow reveal-item">{eyebrow}</span>}
        <h2 class="sq2-pillars-title reveal-item" style="--reveal-delay: 80ms">{title}</h2>
      </div>
      {subtitle && <p class="sq2-pillars-subtitle reveal-item" style="--reveal-delay: 140ms">{subtitle}</p>}
    </header>

    <div class="sq2-pillars-grid">
      {items.map((item, i) => {
        const Tag = (item.href ? 'a' : 'div') as 'a' | 'div';
        const props = item.href ? { href: item.href } : {};
        return (
          <Tag
            class="sq2-pillar reveal-item"
            style={`--bg: ${item.bg}; --fg: ${item.textColor || '#fff'}; --reveal-delay: ${180 + i * 80}ms;`}
            {...props}
          >
            <div class="sq2-pillar-text">
              <h3 class="sq2-pillar-title">{item.title}</h3>
              <p class="sq2-pillar-desc">{item.description}</p>
            </div>
            <div class="sq2-pillar-media">
              <img src={item.image} alt={item.imageAlt} width="1024" height="1536" loading="lazy" />
            </div>
            {item.href && (
              <span class="sq2-pillar-arrow" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M13 5l7 7-7 7" />
                </svg>
              </span>
            )}
          </Tag>
        );
      })}
    </div>
  </div>
</section>

<style>
  .sq2-pillars {
    background: #fff;
    padding: clamp(72px, 10vw, 140px) 0;
  }

  .sq2-pillars-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-bottom: clamp(40px, 5vw, 64px);
  }

  @media (min-width: 900px) {
    .sq2-pillars-header {
      grid-template-columns: 1.2fr 1fr;
      gap: 48px;
      align-items: end;
    }
  }

  .sq2-pillars-eyebrow {
    display: inline-block;
    font-family: var(--font-body, 'Plus Jakarta Sans', sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #4B7BE5;
    margin-bottom: 12px;
  }

  .sq2-pillars-title {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 700;
    color: #1a1a2e;
    letter-spacing: -0.035em;
    line-height: 1.02;
    margin: 0;
  }

  .sq2-pillars-subtitle {
    font-size: clamp(0.9375rem, 1.4vw, 1.0625rem);
    line-height: 1.6;
    color: #4A4A4A;
    margin: 0;
    max-width: 460px;
  }

  .sq2-pillars-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }

  @media (min-width: 640px) {
    .sq2-pillars-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  @media (min-width: 1024px) {
    .sq2-pillars-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 22px;
    }
  }

  .sq2-pillar {
    position: relative;
    display: flex;
    flex-direction: column;
    aspect-ratio: 3 / 4;
    background: var(--bg);
    color: var(--fg);
    border-radius: 22px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }

  a.sq2-pillar:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.18);
    text-decoration: none;
  }

  .sq2-pillar-text {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: clamp(20px, 2.5vw, 28px) clamp(20px, 2.5vw, 28px) 0;
    z-index: 2;
  }

  .sq2-pillar-title {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: clamp(1.125rem, 1.6vw, 1.4rem);
    font-weight: 700;
    color: var(--fg);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0 0 8px;
  }

  .sq2-pillar-desc {
    font-size: 0.9rem;
    line-height: 1.45;
    color: color-mix(in srgb, var(--fg) 78%, transparent);
    margin: 0;
  }

  .sq2-pillar-media {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .sq2-pillar-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sq2-pillar-arrow {
    position: absolute;
    bottom: clamp(16px, 2vw, 22px);
    right: clamp(16px, 2vw, 22px);
    z-index: 3;
    color: var(--fg);
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  a.sq2-pillar:hover .sq2-pillar-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    a.sq2-pillar:hover {
      transform: none;
      box-shadow: none;
    }
  }
</style>
