---
interface Pillar {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  bg: string;
  textColor?: string;
  href?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  items: Pillar[];
}

const { eyebrow, title, subtitle, items } = Astro.props;
---

<section class="sq2-pillars reveal-section">
  <div class="sq2-pillars-inner container">
    <header class="sq2-pillars-header">
      <div class="sq2-pillars-header-left">
        {eyebrow && <span class="sq2-pillars-eyebrow reveal-item">{eyebrow}</span>}
        <h2 class="sq2-pillars-title reveal-item" style="--reveal-delay: 80ms">{title}</h2>
      </div>
      {subtitle && <p class="sq2-pillars-subtitle reveal-item" style="--reveal-delay: 140ms">{subtitle}</p>}
    </header>

    <div class="sq2-pillars-grid">
      {items.map((item, i) => (
        <div
          class="sq2-pillar reveal-item"
          style={`--bg: ${item.bg}; --fg: ${item.textColor || '#fff'}; --reveal-delay: ${180 + i * 80}ms;`}
        >
          <div class="sq2-pillar-text">
            <h3 class="sq2-pillar-title">{item.title}</h3>
            <p class="sq2-pillar-desc">{item.description}</p>
          </div>
          <div class="sq2-pillar-media">
            <img src={item.image} alt={item.imageAlt} width="1024" height="1536" loading="lazy" />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .sq2-pillars {
    background: #fff;
    padding: clamp(72px, 10vw, 140px) 0;
  }

  .sq2-pillars-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-bottom: clamp(40px, 5vw, 64px);
  }

  @media (min-width: 900px) {
    .sq2-pillars-header {
      grid-template-columns: 1.2fr 1fr;
      gap: 48px;
      align-items: end;
    }
  }

  .sq2-pillars-eyebrow {
    display: inline-block;
    font-family: var(--font-body, 'Plus Jakarta Sans', sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #4B7BE5;
    margin-bottom: 12px;
  }

  .sq2-pillars-title {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 700;
    color: #1a1a2e;
    letter-spacing: -0.035em;
    line-height: 1.02;
    margin: 0;
  }

  .sq2-pillars-subtitle {
    font-size: clamp(0.9375rem, 1.4vw, 1.0625rem);
    line-height: 1.6;
    color: #4A4A4A;
    margin: 0;
    max-width: 460px;
  }

  .sq2-pillars-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }

  @media (min-width: 640px) {
    .sq2-pillars-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  @media (min-width: 1024px) {
    .sq2-pillars-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 22px;
    }
  }

  .sq2-pillar {
    position: relative;
    display: flex;
    flex-direction: column;
    aspect-ratio: 3 / 5;
    background: var(--bg);
    color: var(--fg);
    border-radius: 22px;
    overflow: hidden;
  }

  .sq2-pillar-text {
    position: relative;
    padding: clamp(24px, 2.6vw, 32px) clamp(22px, 2.4vw, 28px) clamp(18px, 2vw, 22px);
    z-index: 2;
    flex: 0 0 auto;
  }

  .sq2-pillar-title {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: clamp(1.25rem, 1.7vw, 1.5rem);
    font-weight: 700;
    color: var(--fg);
    letter-spacing: -0.02em;
    line-height: 1.12;
    margin: 0 0 10px;
  }

  .sq2-pillar-desc {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: color-mix(in srgb, var(--fg) 78%, transparent);
    margin: 0;
  }

  .sq2-pillar-media {
    position: relative;
    flex: 1 1 auto;
    min-height: 0;
    z-index: 1;
  }

  .sq2-pillar-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

</style>
