---
import { navLinks } from '../data/navigation';

const currentPath = Astro.url.pathname;
---

<header class="nav" id="nav">
  <div class="nav-inner container">
    <a href="/" class="nav-logo" aria-label="SACS — Inicio">
      <svg width="140" height="38" viewBox="0 0 140 38" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="15" cy="20" r="11" fill="#5B8AE5"/>
        <circle cx="24" cy="12" r="11" fill="#E8B54E"/>
        <circle cx="28" cy="22" r="11" fill="#38C5A8"/>
        <text x="46" y="27" font-family="'Clash Display', sans-serif" font-size="22" font-weight="700" fill="currentColor">Sacs</text>
      </svg>
    </a>

    <nav class="nav-links" aria-label="Navegación principal">
      {navLinks.map((link) => (
        <div class:list={['nav-item', { 'has-dropdown': !!link.children }]}>
          <a
            href={link.href}
            class:list={['nav-link', { active: currentPath.startsWith(link.href) && link.href !== '/' }]}
          >
            {link.label}
            {link.children && (
              <svg class="nav-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </a>

          {link.children && (
            <div class="mega-dropdown">
              <div class="mega-dropdown-inner container">
                <div class="mega-layout">
                  <!-- Left: Product links -->
                  <div class="mega-nav-col">
                    <span class="mega-nav-label">Producto</span>
                    {link.children.map((child, i) => (
                      <a href={child.href} class:list={['mega-nav-link', { 'is-active': i === 0 }]} data-panel={child.icon}>
                        {child.label}
                        <svg class="mega-nav-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                      </a>
                    ))}
                    <div class="mega-nav-divider"></div>
                    <a href="/producto" class="mega-nav-all">
                      Ver todo el producto
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                  </div>

                  <!-- Right: Feature preview cards (one panel per section) -->
                  <div class="mega-cards-col">
                    <!-- Panel: Punto de venta -->
                    <div class="mega-panel is-active" data-panel-id="pos">
                      <a href="/producto#pos" class="mega-card"><div class="mega-card-img bg-blue"><svg viewBox="0 0 280 160" fill="none"><rect x="16" y="12" width="248" height="136" rx="8" fill="#fff" fill-opacity="0.9"/><rect x="28" y="24" width="100" height="8" rx="4" fill="#e5e7eb"/><rect x="28" y="40" width="140" height="6" rx="3" fill="#f3f4f6"/><rect x="28" y="56" width="80" height="24" rx="6" fill="#4B7BE5" fill-opacity="0.1"/><text x="44" y="72" font-size="10" fill="#4B7BE5" font-weight="600" font-family="system-ui">$2,450</text><rect x="28" y="90" width="220" height="1" fill="#f3f4f6"/><rect x="28" y="102" width="60" height="6" rx="3" fill="#e5e7eb"/><rect x="180" y="100" width="68" height="28" rx="6" fill="#4B7BE5"/><text x="196" y="118" font-size="9" fill="#fff" font-weight="600" font-family="system-ui">Cobrar</text></svg></div><span class="mega-card-label">Terminal de cobro</span></a>
                      <a href="/producto#pos" class="mega-card"><div class="mega-card-img bg-blue"><svg viewBox="0 0 280 160" fill="none"><rect x="16" y="12" width="248" height="136" rx="8" fill="#fff" fill-opacity="0.9"/><rect x="28" y="24" width="60" height="8" rx="4" fill="#e5e7eb"/><rect x="28" y="44" width="60" height="40" rx="8" fill="#4B7BE5" fill-opacity="0.08"/><rect x="100" y="44" width="60" height="40" rx="8" fill="#2AB5A0" fill-opacity="0.08"/><rect x="172" y="44" width="60" height="40" rx="8" fill="#E8A838" fill-opacity="0.08"/><text x="39" y="68" font-size="8" fill="#4B7BE5" font-weight="500" font-family="system-ui">Tarjeta</text><text x="118" y="68" font-size="8" fill="#2AB5A0" font-weight="500" font-family="system-ui">QR</text><text x="177" y="68" font-size="8" fill="#E8A838" font-weight="500" font-family="system-ui">Efectivo</text><rect x="28" y="100" width="204" height="6" rx="3" fill="#f3f4f6"/><rect x="28" y="116" width="140" height="6" rx="3" fill="#f3f4f6"/></svg></div><span class="mega-card-label">Métodos de pago</span></a>
                    </div>

                    <!-- Panel: Comercio electrónico -->
                    <div class="mega-panel" data-panel-id="ecom">
                      <a href="/producto#ecommerce" class="mega-card"><div class="mega-card-img bg-teal"><svg viewBox="0 0 280 160" fill="none"><rect x="16" y="12" width="248" height="136" rx="8" fill="#fff" fill-opacity="0.9"/><rect x="28" y="24" width="70" height="8" rx="4" fill="#2AB5A0"/><text x="34" y="31" font-size="6" fill="#fff" font-weight="700" font-family="system-ui">MI TIENDA</text><rect x="28" y="44" width="100" height="60" rx="6" fill="#f3f4f6"/><rect x="140" y="44" width="100" height="60" rx="6" fill="#f3f4f6"/><rect x="28" y="114" width="60" height="6" rx="3" fill="#e5e7eb"/><rect x="28" y="126" width="40" height="6" rx="3" fill="#2AB5A0" fill-opacity="0.3"/><rect x="140" y="114" width="60" height="6" rx="3" fill="#e5e7eb"/><rect x="140" y="126" width="40" height="6" rx="3" fill="#2AB5A0" fill-opacity="0.3"/></svg></div><span class="mega-card-label">Tienda online</span></a>
                      <a href="/producto#ecommerce" class="mega-card"><div class="mega-card-img bg-teal"><svg viewBox="0 0 280 160" fill="none"><rect x="16" y="12" width="248" height="136" rx="8" fill="#fff" fill-opacity="0.9"/><rect x="28" y="24" width="80" height="8" rx="4" fill="#e5e7eb"/><rect x="28" y="44" width="50" height="50" rx="6" fill="#f3f4f6"/><rect x="88" y="44" width="100" height="6" rx="3" fill="#e5e7eb"/><rect x="88" y="56" width="70" height="6" rx="3" fill="#f3f4f6"/><rect x="88" y="72" width="40" height="14" rx="4" fill="#2AB5A0" fill-opacity="0.15"/><text x="94" y="82" font-size="7" fill="#2AB5A0" font-weight="600" font-family="system-ui">$850</text><rect x="28" y="106" width="50" height="50" rx="6" fill="#f3f4f6" fill-opacity="0.6"/><rect x="88" y="106" width="100" height="6" rx="3" fill="#e5e7eb"/><rect x="88" y="118" width="70" height="6" rx="3" fill="#f3f4f6"/></svg></div><span class="mega-card-label">Catálogo de productos</span></a>
                    </div>

                    <!-- Panel: Pedidos y logística -->
                    <div class="mega-panel" data-panel-id="ship">
                      <a href="/producto#pedidos" class="mega-card"><div class="mega-card-img bg-gold"><svg viewBox="0 0 280 160" fill="none"><rect x="16" y="12" width="248" height="136" rx="8" fill="#fff" fill-opacity="0.9"/><rect x="28" y="24" width="90" height="8" rx="4" fill="#e5e7eb"/><rect x="28" y="46" width="220" height="28" rx="6" fill="#E8A838" fill-opacity="0.06"/><rect x="38" y="54" width="8" height="8" rx="4" fill="#2AB5A0"/><rect x="54" y="56" width="80" height="5" rx="2.5" fill="#e5e7eb"/><rect x="190" y="54" width="48" height="12" rx="6" fill="#2AB5A0" fill-opacity="0.15"/><text x="196" y="63" font-size="6" fill="#2AB5A0" font-weight="600" font-family="system-ui">Entregado</text><rect x="28" y="84" width="220" height="28" rx="6" fill="#f9fafb"/><rect x="38" y="92" width="8" height="8" rx="4" fill="#E8A838"/><rect x="54" y="94" width="80" height="5" rx="2.5" fill="#e5e7eb"/><rect x="190" y="92" width="48" height="12" rx="6" fill="#E8A838" fill-opacity="0.15"/><text x="198" y="101" font-size="6" fill="#E8A838" font-weight="600" font-family="system-ui">En ruta</text><rect x="28" y="122" width="220" height="20" rx="6" fill="#f9fafb"/><rect x="38" y="128" width="8" height="8" rx="4" fill="#4B7BE5"/><rect x="54" y="130" width="80" height="5" rx="2.5" fill="#e5e7eb"/></svg></div><span class="mega-card-label">Rastreo de pedidos</span></a>
                      <a href="/producto#pedidos" class="mega-card"><div class="mega-card-img bg-gold"><svg viewBox="0 0 280 160" fill="none"><rect x="16" y="12" width="248" height="136" rx="8" fill="#fff" fill-opacity="0.9"/><rect x="28" y="24" width="80" height="8" rx="4" fill="#e5e7eb"/><rect x="28" y="48" width="60" height="44" rx="8" fill="#E8A838" fill-opacity="0.08"/><rect x="100" y="48" width="60" height="44" rx="8" fill="#4B7BE5" fill-opacity="0.08"/><rect x="172" y="48" width="60" height="44" rx="8" fill="#2AB5A0" fill-opacity="0.08"/><text x="38" y="76" font-size="14" fill="#E8A838" font-weight="700" font-family="system-ui">24</text><text x="114" y="76" font-size="14" fill="#4B7BE5" font-weight="700" font-family="system-ui">8</text><text x="192" y="76" font-size="14" fill="#2AB5A0" font-weight="700" font-family="system-ui">3</text><rect x="28" y="100" width="60" height="5" rx="2.5" fill="#e5e7eb"/><rect x="100" y="100" width="60" height="5" rx="2.5" fill="#e5e7eb"/><rect x="172" y="100" width="60" height="5" rx="2.5" fill="#e5e7eb"/><rect x="28" y="120" width="204" height="6" rx="3" fill="#f3f4f6"/></svg></div><span class="mega-card-label">Fulfillment</span></a>
                    </div>

                    <!-- Panel: Gestión de inventario -->
                    <div class="mega-panel" data-panel-id="inv">
                      <a href="/producto#inventario" class="mega-card"><div class="mega-card-img bg-blue"><svg viewBox="0 0 280 160" fill="none"><rect x="16" y="12" width="248" height="136" rx="8" fill="#fff" fill-opacity="0.9"/><rect x="28" y="24" width="80" height="8" rx="4" fill="#e5e7eb"/><rect x="28" y="44" width="220" height="1" fill="#f3f4f6"/><rect x="28" y="56" width="60" height="6" rx="3" fill="#9ca3af"/><rect x="120" y="56" width="30" height="6" rx="3" fill="#9ca3af"/><rect x="180" y="56" width="30" height="6" rx="3" fill="#9ca3af"/><rect x="28" y="72" width="80" height="6" rx="3" fill="#e5e7eb"/><rect x="120" y="72" width="20" height="6" rx="3" fill="#e5e7eb"/><rect x="180" y="70" width="36" height="14" rx="7" fill="#2AB5A0" fill-opacity="0.15"/><text x="188" y="80" font-size="7" fill="#2AB5A0" font-weight="600" font-family="system-ui">OK</text><rect x="28" y="92" width="80" height="6" rx="3" fill="#e5e7eb"/><rect x="120" y="92" width="20" height="6" rx="3" fill="#e5e7eb"/><rect x="180" y="90" width="36" height="14" rx="7" fill="#E8A838" fill-opacity="0.15"/><text x="186" y="100" font-size="7" fill="#E8A838" font-weight="600" font-family="system-ui">Bajo</text><rect x="28" y="112" width="80" height="6" rx="3" fill="#e5e7eb"/><rect x="120" y="112" width="20" height="6" rx="3" fill="#e5e7eb"/><rect x="180" y="110" width="36" height="14" rx="7" fill="#2AB5A0" fill-opacity="0.15"/><text x="188" y="120" font-size="7" fill="#2AB5A0" font-weight="600" font-family="system-ui">OK</text></svg></div><span class="mega-card-label">Control de stock</span></a>
                      <a href="/producto#inventario" class="mega-card"><div class="mega-card-img bg-blue"><svg viewBox="0 0 280 160" fill="none"><rect x="16" y="12" width="248" height="136" rx="8" fill="#fff" fill-opacity="0.9"/><rect x="28" y="24" width="100" height="8" rx="4" fill="#e5e7eb"/><rect x="28" y="48" width="100" height="56" rx="8" fill="#4B7BE5" fill-opacity="0.06"/><text x="50" y="72" font-size="8" fill="#4B7BE5" font-weight="600" font-family="system-ui">Sucursal A</text><text x="50" y="86" font-size="10" fill="#4B7BE5" font-weight="700" font-family="system-ui">248 SKU</text><rect x="140" y="48" width="100" height="56" rx="8" fill="#2AB5A0" fill-opacity="0.06"/><text x="160" y="72" font-size="8" fill="#2AB5A0" font-weight="600" font-family="system-ui">Sucursal B</text><text x="160" y="86" font-size="10" fill="#2AB5A0" font-weight="700" font-family="system-ui">185 SKU</text><rect x="28" y="116" width="212" height="6" rx="3" fill="#f3f4f6"/><rect x="28" y="130" width="140" height="5" rx="2.5" fill="#f3f4f6"/></svg></div><span class="mega-card-label">Multi-sucursal</span></a>
                    </div>

                    <!-- Panel: Clientes y fidelización -->
                    <div class="mega-panel" data-panel-id="crm">
                      <a href="/producto#clientes" class="mega-card"><div class="mega-card-img bg-gold"><svg viewBox="0 0 280 160" fill="none"><rect x="16" y="12" width="248" height="136" rx="8" fill="#fff" fill-opacity="0.9"/><circle cx="60" cy="52" r="18" fill="#E8A838" fill-opacity="0.1"/><text x="53" y="57" font-size="12" fill="#E8A838" font-weight="700" font-family="system-ui">MC</text><rect x="90" y="42" width="80" height="8" rx="4" fill="#e5e7eb"/><rect x="90" y="56" width="50" height="5" rx="2.5" fill="#f3f4f6"/><rect x="28" y="84" width="60" height="5" rx="2.5" fill="#9ca3af"/><rect x="28" y="96" width="40" height="12" rx="3" fill="#E8A838" fill-opacity="0.1"/><text x="34" y="105" font-size="7" fill="#E8A838" font-weight="600" font-family="system-ui">VIP</text><rect x="100" y="84" width="60" height="5" rx="2.5" fill="#9ca3af"/><rect x="100" y="96" width="60" height="8" rx="4" fill="#e5e7eb"/><rect x="180" y="84" width="60" height="5" rx="2.5" fill="#9ca3af"/><rect x="180" y="96" width="60" height="8" rx="4" fill="#e5e7eb"/><rect x="28" y="120" width="212" height="6" rx="3" fill="#f3f4f6"/></svg></div><span class="mega-card-label">Perfiles de cliente</span></a>
                      <a href="/producto#clientes" class="mega-card"><div class="mega-card-img bg-gold"><svg viewBox="0 0 280 160" fill="none"><rect x="16" y="12" width="248" height="136" rx="8" fill="#fff" fill-opacity="0.9"/><rect x="28" y="24" width="100" height="8" rx="4" fill="#e5e7eb"/><rect x="28" y="48" width="65" height="70" rx="8" fill="#E8A838" fill-opacity="0.06"/><rect x="38" y="58" width="44" height="4" rx="2" fill="#e5e7eb"/><text x="38" y="80" font-size="16" fill="#E8A838" font-weight="700" font-family="system-ui">847</text><rect x="38" y="100" width="30" height="4" rx="2" fill="#f3f4f6"/><rect x="103" y="48" width="65" height="70" rx="8" fill="#4B7BE5" fill-opacity="0.06"/><rect x="113" y="58" width="44" height="4" rx="2" fill="#e5e7eb"/><text x="113" y="80" font-size="16" fill="#4B7BE5" font-weight="700" font-family="system-ui">92%</text><rect x="113" y="100" width="30" height="4" rx="2" fill="#f3f4f6"/><rect x="178" y="48" width="65" height="70" rx="8" fill="#2AB5A0" fill-opacity="0.06"/><rect x="188" y="58" width="44" height="4" rx="2" fill="#e5e7eb"/><text x="188" y="80" font-size="16" fill="#2AB5A0" font-weight="700" font-family="system-ui">$366</text><rect x="188" y="100" width="30" height="4" rx="2" fill="#f3f4f6"/></svg></div><span class="mega-card-label">Programa de lealtad</span></a>
                    </div>

                    <!-- Panel: Automatización IA -->
                    <div class="mega-panel" data-panel-id="axo">
                      <a href="/producto#axo" class="mega-card"><div class="mega-card-img bg-teal"><svg viewBox="0 0 280 160" fill="none"><rect x="16" y="12" width="248" height="136" rx="8" fill="#fff" fill-opacity="0.9"/><rect x="28" y="24" width="50" height="8" rx="4" fill="#2AB5A0"/><text x="34" y="31" font-size="7" fill="#fff" font-weight="700" font-family="system-ui">AXO</text><rect x="28" y="44" width="200" height="36" rx="8" fill="#f9fafb"/><rect x="38" y="52" width="160" height="5" rx="2.5" fill="#d1d5db"/><rect x="38" y="62" width="120" height="5" rx="2.5" fill="#e5e7eb"/><rect x="28" y="92" width="90" height="26" rx="6" fill="#2AB5A0" fill-opacity="0.12"/><text x="38" y="109" font-size="8" fill="#2AB5A0" font-weight="600" font-family="system-ui">Aplicar cambio</text><rect x="28" y="128" width="220" height="12" rx="6" fill="#f3f4f6"/><rect x="36" y="131" width="80" height="5" rx="2.5" fill="#d1d5db"/></svg></div><span class="mega-card-label">Copiloto AXO</span></a>
                      <a href="/producto#axo" class="mega-card"><div class="mega-card-img bg-teal"><svg viewBox="0 0 280 160" fill="none"><rect x="16" y="12" width="248" height="136" rx="8" fill="#fff" fill-opacity="0.9"/><rect x="28" y="24" width="80" height="8" rx="4" fill="#e5e7eb"/><rect x="28" y="46" width="220" height="32" rx="6" fill="#2AB5A0" fill-opacity="0.06"/><rect x="38" y="54" width="10" height="10" rx="5" fill="#2AB5A0" fill-opacity="0.3"/><rect x="56" y="56" width="140" height="5" rx="2.5" fill="#d1d5db"/><rect x="28" y="88" width="220" height="32" rx="6" fill="#E8A838" fill-opacity="0.06"/><rect x="38" y="96" width="10" height="10" rx="5" fill="#E8A838" fill-opacity="0.3"/><rect x="56" y="98" width="140" height="5" rx="2.5" fill="#d1d5db"/><rect x="28" y="130" width="220" height="12" rx="6" fill="#f3f4f6"/></svg></div><span class="mega-card-label">Alertas inteligentes</span></a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          )}
