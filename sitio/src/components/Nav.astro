      ))}
    </nav>

    <div class="nav-actions">
      <a href="/contacto" class="nav-action-link">Contacto</a>
      <a href="#" class="nav-action-link">Iniciar sesión</a>
      <a href="/contacto" class="btn-nav-cta">Empieza gratis</a>
    </div>

    <button
      class="nav-hamburger"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>

  <!-- Mega dropdown backdrop -->
  <div class="mega-backdrop" id="mega-backdrop"></div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav class="mobile-nav" aria-label="Navegación móvil">
      {navLinks.map((link) => (
        <>
          <a href={link.href} class="mobile-link">{link.label}</a>
          {link.children && (
            <div class="mobile-sub-links">
              {link.children.map((child) => (
                <a href={child.href} class="mobile-sub-link">{child.label}</a>
              ))}
            </div>
          )}
        </>
      ))}
      <div class="mobile-divider"></div>
      <a href="/contacto" class="mobile-link mobile-link-secondary">Contacto</a>
      <a href="#" class="mobile-link mobile-link-secondary">Iniciar sesión</a>
      <a href="/contacto" class="btn-mobile-cta">
        Empieza gratis
      </a>
    </nav>
  </div>
</header>

<style>
  /* ─── Nav base: transparent over hero ─── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: 71px;
    background: transparent;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .nav.scrolled {
    background: #fff;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 1px 12px rgba(0, 0, 0, 0.04);
  }

  /* When mega menu is open, force white bg */
  .nav.mega-open {
    background: #fff;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 1px 12px rgba(0, 0, 0, 0.04);
  }

  /* mega-open inherits defaults — no color overrides needed */

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: var(--space-8);
  }

  /* ─── Logo ─── */
  .nav-logo {
    color: var(--color-text-primary);
    text-decoration: none;
    flex-shrink: 0;
    transition: color 0.3s ease;
  }


  .nav-logo:hover {
    text-decoration: none;
  }

  /* ─── Center nav links ─── */
  .nav-links {
    display: none;
    align-items: center;
    gap: var(--space-1);
  }

  @media (min-width: 1024px) {
    .nav-links {
      display: flex;
    }
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease, background 0.2s ease;
    line-height: 1;
    padding: 8px 14px;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    letter-spacing: -0.01em;
  }

  .nav-link:hover {
    color: var(--color-text-primary);
    text-decoration: none;
    background: rgba(0, 0, 0, 0.04);
  }

  .nav-link.active {
    color: var(--color-text-primary);
    font-weight: 700;
  }

  .nav-chevron {
    width: 10px;
    height: 6px;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-item.has-dropdown.is-open .nav-chevron {
    transform: rotate(180deg);
  }

  /* ─── Mega dropdown ─── */
  .mega-dropdown {
    position: fixed;
    top: 71px;
    left: 0;
    right: 0;
    background: #fff;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    padding: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1001;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1), 0 1px 3px rgba(0, 0, 0, 0.04);
  }

  .nav-item.has-dropdown.is-open .mega-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .mega-dropdown-inner {
    padding-top: 40px;
    padding-bottom: 44px;
  }

  .mega-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 40px;
    align-items: center;
  }

  /* ─── Left column: nav links ─── */
  .mega-nav-col {
    display: flex;
    flex-direction: column;
    border-right: 1px solid rgba(0, 0, 0, 0.06);
    padding-right: 40px;
  }

  .mega-nav-label {
    font-family: 'Sora', sans-serif;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary, #9ca3af);
    margin-bottom: 16px;
  }

  .mega-nav-link {
    font-family: 'Sora', sans-serif;
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--color-text-secondary, #6b7280);
    text-decoration: none;
    padding: 10px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: color 0.15s ease, font-weight 0.15s ease;
    line-height: 1.2;
  }

  .mega-nav-link:hover,
  .mega-nav-link.is-active {
    color: var(--color-text-primary, #1a1a2e);
    text-decoration: none;
    font-weight: 600;
  }

  .mega-nav-link.is-active .mega-nav-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .mega-nav-arrow {
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.15s ease, transform 0.15s ease;
    flex-shrink: 0;
  }

  .mega-nav-link:hover .mega-nav-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .mega-nav-divider {
    height: 1px;
    background: rgba(0, 0, 0, 0.06);
    margin: 12px 0;
  }

  .mega-nav-all {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary, #9ca3af);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 0;
    transition: color 0.15s ease;
  }

  .mega-nav-all:hover {
    color: var(--color-text-primary, #1a1a2e);
    text-decoration: none;
  }

  /* ─── Right column: feature cards ─── */
  .mega-cards-col {
    align-self: center;
  }

  .mega-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-decoration: none;
    border-radius: 12px;
    transition: transform 0.2s ease;
  }

  .mega-card:hover {
    transform: translateY(-2px);
    text-decoration: none;
  }

  .mega-card-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: box-shadow 0.2s ease;
  }

  .mega-card-img.bg-blue { background: #f0f4ff; }
  .mega-card-img.bg-teal { background: #eefbf8; }
  .mega-card-img.bg-gold { background: #fef9f0; }

  /* Panels */
  .mega-panel {
    display: none;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .mega-panel.is-active {
    display: grid;
    animation: panelFade 0.25s ease;
  }

  @keyframes panelFade {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .mega-card:hover .mega-card-img {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .mega-card-img svg {
    width: 100%;
    height: 100%;
  }

  .mega-card-label {
    font-family: 'Sora', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-primary, #1a1a2e);
    text-align: center;
    letter-spacing: -0.01em;
  }

  .mega-card:hover .mega-card-label {
    color: #4B7BE5;
  }

  /* ─── Backdrop ─── */
  .mega-backdrop {
    position: fixed;
    top: 71px;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.2);
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }

  .mega-backdrop.active {
    opacity: 1;
    visibility: visible;
  }

  /* ─── Right side actions ─── */
  .nav-actions {
    display: none;
    align-items: center;
    gap: var(--space-1);
    flex-shrink: 0;
  }

  @media (min-width: 1024px) {
    .nav-actions {
      display: flex;
    }
  }

  .nav-action-link {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 8px 14px;
    border-radius: 6px;
    transition: color 0.2s ease;
    white-space: nowrap;
  }

  .nav-action-link:hover {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  /* CTA button */
  .btn-nav-cta {
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: 6px;
    background: #0f0f1a;
    color: #fff;
    text-decoration: none;
    transition: all 0.2s ease;
    white-space: nowrap;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    border: 1px solid #0f0f1a;
  }

  .btn-nav-cta:hover {
    background: #333;
    border-color: #333;
    text-decoration: none;
    transform: translateY(-1px);
  }

  /* ─── Hamburger ─── */
  .nav-hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px;
    background: none;
    border: none;
    cursor: pointer;
  }

  @media (min-width: 1024px) {
    .nav-hamburger {
      display: none;
    }
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--color-text-primary);
    border-radius: 2px;
    transition: all 0.2s ease;
  }

  .nav-hamburger[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }

  .nav-hamburger[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .nav-hamburger[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ─── Mobile menu ─── */
  .mobile-menu {
    position: fixed;
    top: 71px;
    left: 0;
    right: 0;
    bottom: 0;
    background: #0f0f1a;
    padding: var(--space-6) var(--space-5);
    transform: translateX(100%);
    transition: transform 0.3s var(--ease-default);
    z-index: 999;
    overflow-y: auto;
  }

  .mobile-menu.open {
    transform: translateX(0);
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .mobile-link {
    font-size: 1.125rem;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    padding: var(--space-3) var(--space-4);
    border-radius: 8px;
    transition: background 0.2s ease;
  }

  .mobile-link:hover {
    background: rgba(255, 255, 255, 0.06);
    text-decoration: none;
  }

  .mobile-link-secondary {
    color: rgba(255, 255, 255, 0.6);
    font-weight: 500;
  }

  .mobile-sub-links {
    display: flex;
    flex-direction: column;
    padding-left: var(--space-4);
    gap: 0;
  }

  .mobile-sub-link {
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    border-radius: 6px;
    transition: color 0.2s ease;
  }

  .mobile-sub-link:hover {
    color: #fff;
    text-decoration: none;
  }

  .mobile-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin: var(--space-3) var(--space-4);
  }

  .btn-mobile-cta {
    display: block;
    text-align: center;
    font-size: 1rem;
    font-weight: 600;
    padding: 14px 28px;
    border-radius: 6px;
    background: #fff;
    color: #0f0f1a;
    text-decoration: none;
    margin-top: var(--space-4);
    transition: background 0.2s ease;
  }

  .btn-mobile-cta:hover {
    background: #f0f0f0;
    text-decoration: none;
  }

  @media (min-width: 1024px) {
    .mobile-menu {
      display: none;
    }
  }
</style>

<script>
  const hamburger = document.querySelector('.nav-hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  const nav = document.getElementById('nav');
  const backdrop = document.getElementById('mega-backdrop');

  // ─── Mega dropdown: hover with intent ───
  const dropdownItems = document.querySelectorAll('.nav-item.has-dropdown');
  let closeTimeout: ReturnType<typeof setTimeout> | null = null;

  function openMega(item: Element) {
    if (closeTimeout) {
      clearTimeout(closeTimeout);
      closeTimeout = null;
    }
    // Close any other open dropdowns
    dropdownItems.forEach((other) => {
      if (other !== item) other.classList.remove('is-open');
    });
    item.classList.add('is-open');
    nav?.classList.add('mega-open');
    backdrop?.classList.add('active');
  }

  function closeMega(item: Element) {
    closeTimeout = setTimeout(() => {
      item.classList.remove('is-open');
      const anyOpen = document.querySelector('.nav-item.has-dropdown.is-open');
      if (!anyOpen) {
        nav?.classList.remove('mega-open');
        backdrop?.classList.remove('active');
      }
    }, 150);
  }

  function closeAll() {
    if (closeTimeout) {
      clearTimeout(closeTimeout);
      closeTimeout = null;
    }
    dropdownItems.forEach((item) => item.classList.remove('is-open'));
    nav?.classList.remove('mega-open');
    backdrop?.classList.remove('active');
  }

  dropdownItems.forEach((item) => {
    const dropdown = item.querySelector('.mega-dropdown');

    item.addEventListener('mouseenter', () => openMega(item));
    item.addEventListener('mouseleave', () => closeMega(item));

    // Keep dropdown open when hovering over it
    dropdown?.addEventListener('mouseenter', () => {
      if (closeTimeout) {
        clearTimeout(closeTimeout);
        closeTimeout = null;
      }
    });
    dropdown?.addEventListener('mouseleave', () => closeMega(item));
  });

  // Close on backdrop click
  backdrop?.addEventListener('click', closeAll);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeAll();
  });

  // ─── Panel switching on nav link hover ───
  const megaNavLinks = document.querySelectorAll('.mega-nav-link[data-panel]');
  const megaPanels = document.querySelectorAll('.mega-panel[data-panel-id]');

  megaNavLinks.forEach((link) => {
    link.addEventListener('mouseenter', () => {
      const panelId = link.getAttribute('data-panel');

      // Update active nav link
      megaNavLinks.forEach((l) => l.classList.remove('is-active'));
      link.classList.add('is-active');

      // Switch panel
      megaPanels.forEach((panel) => {
        if (panel.getAttribute('data-panel-id') === panelId) {
          panel.classList.add('is-active');
        } else {
          panel.classList.remove('is-active');
        }
      });
    });
  });

  // ─── Hamburger toggle ───
  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!isOpen));
    mobileMenu?.classList.toggle('open');
    mobileMenu?.setAttribute('aria-hidden', String(isOpen));
    document.body.style.overflow = isOpen ? '' : 'hidden';

    if (!isOpen) {
      nav?.classList.add('scrolled');
    } else if (window.scrollY <= 10) {
      nav?.classList.remove('scrolled');
    }
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger?.setAttribute('aria-expanded', 'false');
      mobileMenu?.classList.remove('open');
      mobileMenu?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (window.scrollY <= 10) {
        nav?.classList.remove('scrolled');
      }
    });
  });

  // ─── Scroll: toggle transparent ↔ white ───
  let ticking = false;

  function updateNav() {
    const isMobileOpen = hamburger?.getAttribute('aria-expanded') === 'true';
    const isMegaOpen = nav?.classList.contains('mega-open');
    if (isMobileOpen || isMegaOpen) return;

    if (window.scrollY > 10) {
      nav?.classList.add('scrolled');
    } else {
      nav?.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        updateNav();
        ticking = false;
      });
      ticking = true;
    }
  });

  updateNav();
</script>
