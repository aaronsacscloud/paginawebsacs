<style>
  /* ═══════════════════════════════════════════
     BLOQUE 1: Banner — Fondo claro con texturas
     ═══════════════════════════════════════════ */

  .hero-banner {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #FFFFFF;
    overflow: hidden;
    padding-top: 110px;
    padding-bottom: var(--space-12, 3rem);
  }

  /* ─── Gradient mesh orbs + noise texture ─── */
  .hero-shapes {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  /* Noise grain overlay for depth */
  .hero-shapes::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    opacity: 0.5;
    mix-blend-mode: multiply;
  }

  .shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  /* SACS Blue gradient orb — top-right */
  .shape-circle-1 {
    top: -10%;
    right: -5%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(75, 123, 229, 0.08) 0%, transparent 70%);
  }

  /* Teal orb — bottom-left */
  .shape-circle-2 {
    bottom: -15%;
    left: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(42, 181, 160, 0.06) 0%, transparent 70%);
  }

  /* Gold accent — subtle, center-right */
  .shape-square-1 {
    top: 40%;
    right: 20%;
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(232, 168, 56, 0.05) 0%, transparent 70%);
    filter: blur(100px);
  }

  /* Dot pattern — subtle grid */
  .shape-dots {
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    border-radius: 0;
    filter: none;
    background-image: radial-gradient(circle, rgba(0, 0, 0, 0.06) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.4;
  }

  .hero-banner-content {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    flex-direction: column;
    max-width: var(--max-width);
    width: 100%;
    margin-inline: auto;
    padding-inline: var(--space-5);
  }

  @media (min-width: 768px) { .hero-banner-content { padding-inline: var(--space-10); } }

  @media (min-width: 1024px) {
    .hero-banner-content {
      padding-inline: var(--space-16);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
      align-items: center;
    }
  }

  .hero-text {
    padding-top: var(--space-8);
    padding-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .hero-text {
      padding-top: var(--space-10);
      padding-bottom: var(--space-8);
    }
  }

  @media (min-width: 1024px) {
    .hero-text {
      padding-top: var(--space-12);
      padding-bottom: var(--space-10);
    }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 7vw, 4.75rem);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 1.5vw, 1.175rem);
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 500px;
    margin-bottom: var(--space-10);
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both;
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;
  }

  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-btn {
    font-size: 0.875rem;
    font-weight: 600;
    padding: 14px 28px;
    border-radius: var(--radius-full);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    transition: all 0.2s ease;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero-btn:hover { text-decoration: none; }

  .hero-btn-filled { background: var(--color-primary); color: #fff; }
  .hero-btn-filled:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 24px rgba(75, 123, 229, 0.3);
  }

  .hero-btn-outline {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid rgba(0, 0, 0, 0.15);
  }
  .hero-btn-outline:hover {
    background: rgba(0, 0, 0, 0.04);
    border-color: rgba(0, 0, 0, 0.25);
    transform: translateY(-1px);
  }

  /* Bottom bar — credibility badges */
  .hero-bottom-bar {
    padding-top: var(--space-8);
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.55s both;
  }

  .hero-badges {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  @media (min-width: 768px) {
    .hero-badges { gap: var(--space-8); }
  }

  .hero-badge {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .hero-badge-icon {
    flex-shrink: 0;
    color: var(--color-text-tertiary);
  }

  .hero-badge-value {
    display: block;
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.2;
  }

  .hero-badge-label {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    line-height: 1.2;
  }

  .hero-badge-divider {
    width: 1px;
    height: 28px;
    background: rgba(0, 0, 0, 0.12);
    display: none;
  }

  @media (min-width: 768px) {
    .hero-badge-divider { display: block; }
  }

  /* ─── Hero image (right side) ─── */
  .hero-visual {
    display: none;
    position: relative;
    align-self: center;
  }

  @media (min-width: 1024px) {
    .hero-visual {
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }

  .hero-image-wrapper {
    position: relative;
    animation: heroImageIn 1s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  .hero-image {
    width: 100%;
    max-width: 600px;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-xl, 20px);
    object-fit: cover;
    object-position: center 55%;
  }

  @keyframes heroImageIn {
    from {
      opacity: 0;
      transform: translateY(40px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* ─── Floating notifications ─── */
  .hero-notif {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 14px;
    padding: 10px 14px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12), 0 0 0 1px rgba(0, 0, 0, 0.04);
    opacity: 0;
    white-space: nowrap;
  }

  /* Slot positions — notifs 1-3 are slot A, 4-6 are slot B (rotate) */
  .hero-notif-1, .hero-notif-4 {
    bottom: 52%;
    left: -8%;
  }

  .hero-notif-2, .hero-notif-5 {
    bottom: 32%;
    right: -6%;
  }

  .hero-notif-3, .hero-notif-6 {
    bottom: 14%;
    left: 2%;
  }

  /* First wave — appear and stay for 4s, then fade out */
  .hero-notif-1 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.2s both,
               notifFadeOut 0.5s ease 5.2s forwards;
  }
  .hero-notif-2 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.8s both,
               notifFadeOut 0.5s ease 5.8s forwards;
  }
  .hero-notif-3 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 2.4s both,
               notifFadeOut 0.5s ease 6.4s forwards;
  }

  /* Second wave — appear after first wave fades and STAY visible */
  .hero-notif-4 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 5.8s both;
  }
  .hero-notif-5 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 6.4s both;
  }
  .hero-notif-6 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 7.0s both;
  }

  @keyframes notifSlideIn {
    from {
      opacity: 0;
      transform: translateX(-20px) scale(0.9);
    }
    to {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
  }

  @keyframes notifPulse {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @keyframes notifFadeOut {
    from {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
    to {
      opacity: 0;
      transform: translateX(-10px) scale(0.95);
    }
  }

  .hero-notif-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-notif-icon-loyalty { background: #25D366; }
  .hero-notif-icon-shop { background: var(--color-primary, #4B7BE5); }
  .hero-notif-icon-inventory { background: #2AB5A0; }
  .hero-notif-icon-receiving { background: #4B7BE5; }
  .hero-notif-icon-shrink { background: #E8A838; }
  .hero-notif-icon-restock { background: #E54B4B; }

  .hero-notif-body {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .hero-notif-title {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-text-primary, #1A1A1A);
    letter-spacing: -0.01em;
  }

  .hero-notif-msg {
    font-size: 0.625rem;
    color: var(--color-text-secondary, #4A4A4A);
    line-height: 1.3;
  }

  .hero-notif-time {
    font-size: 0.5625rem;
    color: var(--color-text-tertiary, #8C8C8C);
    flex-shrink: 0;
  }

  .hero-notif-badge {
    font-size: 0.5625rem;
    font-weight: 700;
    color: #fff;
    background: #E54B4B;
    border-radius: 50px;
    padding: 2px 6px;
    flex-shrink: 0;
  }

  @media (max-width: 1023px) {
    .hero-notif { display: none; }
  }

  /* ═══════════════════════════════════════════
     BLOQUE 2: Tablet 3D — scroll-driven
     ═══════════════════════════════════════════ */

  .hero-tablet-section {
    --tablet-tilt: 1;
    --tablet-bg-progress: 0;
    background: color-mix(
      in srgb,
      var(--color-bg-primary, #FAFAF8) calc((1 - var(--tablet-bg-progress)) * 100%),
      #f5f5f7
    );
    height: 1200vh;
    position: relative;
    transition: background 0.05s linear;
  }

  .hero-tablet-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    padding: 24px;
    padding-top: 110px;
    box-sizing: border-box;
    overflow: hidden;
  }

  /* ── Backgrounds — Apple-inspired deep tones + sacred geometry ── */
  .tablet-bg-patterns {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .tablet-bg-layer {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tablet-bg-layer.active {
    opacity: 1;
  }

  /* ── POS — Clean white with soft blue ambient glow + Seed of Life ── */
  .tablet-bg-layer[data-bg="pos"] {
    background: #f5f5f7;
  }
  .tablet-bg-layer[data-bg="pos"]::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 15%, rgba(75,123,229,0.08) 0%, transparent 70%),
      radial-gradient(ellipse 50% 45% at 85% 80%, rgba(100,150,255,0.06) 0%, transparent 55%),
      radial-gradient(ellipse 120% 80% at 50% 100%, rgba(75,123,229,0.04) 0%, transparent 50%);
  }
  .tablet-bg-layer[data-bg="pos"]::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='200' height='200' viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='rgba(0,0,0,0.04)' stroke-width='0.5'%3E%3Ccircle cx='100' cy='100' r='30'/%3E%3Ccircle cx='100' cy='70' r='30'/%3E%3Ccircle cx='126' cy='85' r='30'/%3E%3Ccircle cx='126' cy='115' r='30'/%3E%3Ccircle cx='100' cy='130' r='30'/%3E%3Ccircle cx='74' cy='115' r='30'/%3E%3Ccircle cx='74' cy='85' r='30'/%3E%3C/g%3E%3C/svg%3E");
    background-size: 200px 200px;
    opacity: 0.5;
  }

  /* ── Stock — Warm off-white with soft teal glow + Flower of Life ── */
  .tablet-bg-layer[data-bg="stock"] {
    background: #f5f7f6;
  }
  .tablet-bg-layer[data-bg="stock"]::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 55% at 75% 20%, rgba(26,138,118,0.07) 0%, transparent 65%),
      radial-gradient(ellipse 50% 45% at 15% 75%, rgba(22,112,95,0.05) 0%, transparent 55%),
      radial-gradient(ellipse 120% 80% at 50% 100%, rgba(26,138,118,0.03) 0%, transparent 50%);
  }
  .tablet-bg-layer[data-bg="stock"]::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='240' height='208' viewBox='0 0 240 208' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='rgba(0,0,0,0.035)' stroke-width='0.5'%3E%3Ccircle cx='60' cy='104' r='30'/%3E%3Ccircle cx='90' cy='52' r='30'/%3E%3Ccircle cx='150' cy='52' r='30'/%3E%3Ccircle cx='180' cy='104' r='30'/%3E%3Ccircle cx='150' cy='156' r='30'/%3E%3Ccircle cx='90' cy='156' r='30'/%3E%3Ccircle cx='120' cy='104' r='30'/%3E%3Ccircle cx='120' cy='52' r='30'/%3E%3Ccircle cx='60' cy='52' r='30'/%3E%3Ccircle cx='180' cy='52' r='30'/%3E%3Ccircle cx='180' cy='156' r='30'/%3E%3Ccircle cx='120' cy='156' r='30'/%3E%3Ccircle cx='60' cy='156' r='30'/%3E%3C/g%3E%3C/svg%3E");
    background-size: 240px 208px;
    opacity: 0.5;
  }

  /* ── CRM — Soft warm white with amber glow + Metatron's Cube ── */
  .tablet-bg-layer[data-bg="crm"] {
    background: #f7f5f3;
  }
  .tablet-bg-layer[data-bg="crm"]::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 65% 50% at 20% 25%, rgba(212,149,46,0.07) 0%, transparent 65%),
      radial-gradient(ellipse 55% 40% at 80% 75%, rgba(184,125,36,0.05) 0%, transparent 55%),
      radial-gradient(ellipse 120% 80% at 50% 100%, rgba(212,149,46,0.03) 0%, transparent 50%);
  }
  .tablet-bg-layer[data-bg="crm"]::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='260' height='260' viewBox='0 0 260 260' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='rgba(0,0,0,0.03)' stroke-width='0.5'%3E%3Ccircle cx='130' cy='130' r='60'/%3E%3Ccircle cx='130' cy='70' r='30'/%3E%3Ccircle cx='182' cy='100' r='30'/%3E%3Ccircle cx='182' cy='160' r='30'/%3E%3Ccircle cx='130' cy='190' r='30'/%3E%3Ccircle cx='78' cy='160' r='30'/%3E%3Ccircle cx='78' cy='100' r='30'/%3E%3Cline x1='130' y1='70' x2='182' y2='100'/%3E%3Cline x1='182' y1='100' x2='182' y2='160'/%3E%3Cline x1='182' y1='160' x2='130' y2='190'/%3E%3Cline x1='130' y1='190' x2='78' y2='160'/%3E%3Cline x1='78' y1='160' x2='78' y2='100'/%3E%3Cline x1='78' y1='100' x2='130' y2='70'/%3E%3Cline x1='130' y1='70' x2='182' y2='160'/%3E%3Cline x1='182' y1='100' x2='78' y2='160'/%3E%3Cline x1='182' y1='160' x2='78' y2='100'/%3E%3Cline x1='130' y1='190' x2='130' y2='70'/%3E%3Cline x1='78' y1='100' x2='182' y2='160'/%3E%3Cline x1='78' y1='160' x2='182' y2='100'/%3E%3C/g%3E%3C/svg%3E");
    background-size: 260px 260px;
    opacity: 0.4;
  }

  /* ── AI — Cool light gray with violet glow + Sri Yantra ── */
  .tablet-bg-layer[data-bg="ai"] {
    background: #f5f4f7;
  }
  .tablet-bg-layer[data-bg="ai"]::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 75% 55% at 70% 15%, rgba(91,44,142,0.07) 0%, transparent 65%),
      radial-gradient(ellipse 55% 45% at 20% 80%, rgba(120,60,180,0.05) 0%, transparent 55%),
      radial-gradient(ellipse 120% 80% at 50% 100%, rgba(91,44,142,0.03) 0%, transparent 50%);
  }
  .tablet-bg-layer[data-bg="ai"]::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='280' height='280' viewBox='0 0 280 280' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='rgba(0,0,0,0.03)' stroke-width='0.5'%3E%3Ccircle cx='140' cy='140' r='80'/%3E%3Ccircle cx='140' cy='140' r='55'/%3E%3Ccircle cx='140' cy='140' r='30'/%3E%3Cpolygon points='140,60 210,180 70,180'/%3E%3Cpolygon points='140,220 70,100 210,100'/%3E%3Cpolygon points='140,80 195,165 85,165'/%3E%3Cpolygon points='140,200 85,115 195,115'/%3E%3C/g%3E%3C/svg%3E");
    background-size: 280px 280px;
    opacity: 0.4;
  }

  .tablet-section-header {
    position: relative;
    z-index: 2;
    text-align: center;
    margin-bottom: var(--space-5);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .tablet-section-eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(0,0,0,0.4);
  }

  .tablet-section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 800;
    color: #1d1d1f;
    letter-spacing: -0.04em;
    line-height: 1;
    transition: color 0.5s ease;
  }

  /* light-bg overrides no longer needed — section is always light */

  .tablet-section-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary, #4B7BE5);
    border: 1.5px solid var(--color-primary, #4B7BE5);
    background: none;
    padding: 10px 24px;
    border-radius: var(--radius-full, 50px);
    text-decoration: none;
    transition: all 0.3s ease;
    letter-spacing: 0.02em;
  }

  .tablet-section-cta:hover {
    background: rgba(75,123,229,0.06);
    border-color: var(--color-primary, #4B7BE5);
    gap: 12px;
  }

  /* ── 3-column layout: pills | tablet | details ── */
  .tablet-3col {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
    width: 100%;
  }

  @media (min-width: 1200px) {
    .tablet-3col {
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: var(--space-6);
      padding-inline: var(--space-4);
    }
  }

  /* ── Left: vertical pills ── */
  .tablet-pills-col {
    display: none;
    flex-direction: column;
    gap: 4px;
    flex-shrink: 0;
    width: 180px;
  }

  @media (min-width: 1200px) {
    .tablet-pills-col { display: flex; }
  }

  .tablet-vpill {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border: none;
    background: transparent;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.25s ease;
  }

  .tablet-vpill:hover {
    background: rgba(0,0,0,0.04);
  }

  .tablet-vpill.active {
    background: rgba(0,0,0,0.06);
  }

  .tablet-vpill-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: rgba(0,0,0,0.06);
    color: rgba(0,0,0,0.3);
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
    transition: all 0.25s ease;
  }

  .tablet-vpill.active .tablet-vpill-num {
    background: #1d1d1f;
    color: #fff;
  }

  .tablet-vpill-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgba(0,0,0,0.35);
    transition: color 0.25s ease;
  }

  .tablet-vpill.active .tablet-vpill-label {
    color: #1d1d1f;
  }

  /* ── Sub-items inside step groups ── */
  .tablet-step-group {
    display: flex;
    flex-direction: column;
  }

  .tablet-sub-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-left: 36px;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.35s ease, opacity 0.3s ease, margin 0.3s ease;
    margin-top: 0;
  }

  .tablet-step-group.active .tablet-sub-list {
    max-height: 200px;
    opacity: 1;
    margin-top: 4px;
  }

  .tablet-sub-pill {
    display: block;
    text-align: left;
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgba(0,0,0,0.3);
    padding: 5px 10px;
    border: none;
    background: transparent;
    border-radius: 6px;
    cursor: pointer;
    transition: color 0.2s ease, background 0.2s ease;
    white-space: normal;
    line-height: 1.3;
  }

  .tablet-sub-pill:hover {
    color: rgba(0,0,0,0.55);
    background: rgba(0,0,0,0.03);
  }

  .tablet-sub-pill.active {
    color: #1d1d1f;
    background: rgba(0,0,0,0.05);
  }

  /* ── Right: details ── */
  .tablet-details-col {
    display: none;
    flex-shrink: 0;
    width: 220px;
    min-height: 120px;
  }

  @media (min-width: 1200px) {
    .tablet-details-col { display: block; }
  }

  .tablet-detail {
    display: none;
  }

  .tablet-detail.active {
    display: block;
    animation: detailFadeIn 0.35s ease both;
  }

  @keyframes detailFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .tablet-detail-desc {
    color: rgba(0,0,0,0.55);
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0;
  }

  .tablet-detail-cta {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: var(--space-5);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-primary, #4B7BE5);
    text-decoration: none;
    transition: color 0.2s ease, gap 0.2s ease;
  }

  .tablet-detail-cta:hover {
    color: #1d1d1f;
    gap: 8px;
    text-decoration: none;
  }

  /* light-bg eyebrow override no longer needed */

  .hero-tablet-wrapper {
    position: relative;
    z-index: 2;
    perspective: 1800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
    width: 100%;
    flex: 1;
    min-width: 0;
  }

  .hero-tablet-frame {
    position: relative;
    width: 92vw;
    max-width: 900px;
    background: #1d1d1f;
    border-radius: 16px;
    padding: 10px;
    box-shadow:
      0 40px 120px rgba(0, 0, 0, 0.12),
      0 20px 50px rgba(0, 0, 0, 0.08),
      0 0 0 1px rgba(0, 0, 0, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    transform: rotateX(calc(8deg * var(--tablet-tilt))) rotateY(calc(-4deg * var(--tablet-tilt)));
    transform-style: preserve-3d;
    transition: transform 0.1s linear;
    transform-origin: center center;
  }

  @media (min-width: 768px) {
    .hero-tablet-frame {
      border-radius: 24px;
      padding: 16px;
    }
  }

  @media (min-width: 1200px) {
    .hero-tablet-frame {
      border-radius: 30px;
      padding: 22px;
      width: 100%;
      max-width: none;
    }
  }

  .tablet-camera {
    position: absolute;
    top: 7px;
    left: 50%;
    transform: translateX(-50%);
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #2a2a2e;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  @media (min-width: 768px) {
    .tablet-camera { top: 9px; }
  }

  .tablet-screen {
    position: relative;
    width: 100%;
    border-radius: 6px;
    overflow: hidden;
    background: #fff;
    aspect-ratio: 16 / 10;
  }

  @media (min-width: 768px) {
    .tablet-screen {
      border-radius: 10px;
    }
  }

  @media (min-width: 1200px) {
    .tablet-screen {
      border-radius: 14px;
    }
  }

  .tablet-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: scale(0.96);
    transition: opacity 0.5s ease, transform 0.5s ease;
    pointer-events: none;
  }

  .tablet-slide.active {
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
    position: relative;
  }

  .tablet-slide-img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: contain;
    object-position: center;
    display: block;
    background: #fff;
  }

  .tablet-slide-img-dark {
    object-fit: contain;
    object-position: center center;
    background: #1b1b1b;
  }

  /* Social grid slide */
  .social-grid-slide {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    padding: 32px;
    height: 100%;
    align-content: center;
  }
  .social-grid-card {
    background: #fff;
    border-radius: 16px;
    padding: 24px;
    display: flex;
    align-items: flex-start;
    gap: 14px;
    border: 1px solid rgba(0,0,0,0.06);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .social-grid-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }
  .social-grid-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .social-grid-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .social-grid-text strong {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .social-grid-text span {
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  /* Apartados dashboard screen */
  .apt-screen {
    height: 100%;
    background: #fff;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .apt-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 20px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    flex-shrink: 0;
  }
  .apt-topbar-left { display: flex; align-items: center; gap: 10px; }
  .apt-topbar-title { font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--color-text-primary); }
  .apt-topbar-badge { font-size: 11px; font-weight: 600; color: #4B7BE5; background: rgba(75,123,229,0.08); padding: 3px 8px; border-radius: 100px; }
  .apt-topbar-btn { font-size: 11px; font-weight: 700; color: #fff; background: #1A1A1A; border: none; border-radius: 8px; padding: 7px 14px; cursor: pointer; }

  /* Process timeline */
  .apt-timeline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(0,0,0,0.04);
    flex-shrink: 0;
  }
  .apt-step { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .apt-step-icon {
    width: 28px; height: 28px; border-radius: 50%;
    background: #eee; color: rgba(0,0,0,0.3);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700;
  }
  .apt-step-icon--done { background: #2AB5A0; color: #fff; }
  .apt-step-icon--active { background: #4B7BE5; color: #fff; }
  .apt-step-label { font-size: 10px; font-weight: 600; color: rgba(0,0,0,0.35); }
  .apt-step--done .apt-step-label { color: #2AB5A0; }
  .apt-step--active .apt-step-label { color: #4B7BE5; font-weight: 700; }
  .apt-step-line { width: 32px; height: 2px; background: #eee; margin-bottom: 16px; }
  .apt-step-line--done { background: #2AB5A0; }

  /* Body: detail + rules */
  .apt-body {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 16px;
    padding: 16px 20px;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  /* Detail card */
  .apt-detail-card {
    background: #fafafa;
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .apt-detail-header { display: flex; justify-content: space-between; align-items: flex-start; }
  .apt-detail-id { font-family: var(--font-display); font-size: 13px; font-weight: 700; color: var(--color-text-primary); }
  .apt-detail-client { font-size: 11px; color: var(--color-text-secondary); margin-top: 2px; }
  .apt-status-badge { font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 100px; }
  .apt-status--active { color: #4B7BE5; background: rgba(75,123,229,0.08); }

  .apt-detail-product { display: flex; gap: 10px; align-items: center; }
  .apt-product-thumb { width: 48px; height: 48px; border-radius: 8px; background: linear-gradient(135deg, #f0c4c8, #e8a0a8); flex-shrink: 0; }
  .apt-product-name { font-size: 12.5px; font-weight: 700; color: var(--color-text-primary); }
  .apt-product-meta { font-size: 10.5px; color: var(--color-text-secondary); }
  .apt-product-price { font-size: 13px; font-weight: 800; color: var(--color-text-primary); margin-top: 2px; }

  .apt-detail-payments { display: flex; flex-direction: column; gap: 6px; }
  .apt-payment-row { display: flex; justify-content: space-between; font-size: 11px; color: var(--color-text-secondary); }
  .apt-payment-paid { color: #2AB5A0; font-weight: 600; }
  .apt-payment-row--pending { color: var(--color-text-primary); font-weight: 600; }
  .apt-payment-pending { color: #E8A838; font-weight: 600; }
  .apt-payment-bar { height: 6px; background: #eee; border-radius: 3px; overflow: hidden; }
  .apt-payment-fill { height: 100%; background: linear-gradient(90deg, #2AB5A0, #4B7BE5); border-radius: 3px; transition: width 1s ease; }
  .apt-payment-summary { display: flex; justify-content: space-between; font-size: 10px; color: rgba(0,0,0,0.35); }

  /* Rules sidebar */
  .apt-rules {
    background: #fafafa;
    border-radius: 12px;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .apt-rules-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(0,0,0,0.35); margin-bottom: 2px; }
  .apt-rule { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--color-text-secondary); }
  .apt-rule-dot { width: 7px; height: 7px; border-radius: 50%; background: #ddd; flex-shrink: 0; }
  .apt-rule-dot--on { background: #2AB5A0; }

  .apt-wa-notif {
    display: flex; gap: 8px; align-items: flex-start;
    background: rgba(37,211,102,0.06); border-radius: 8px; padding: 10px;
    margin-top: 4px; border-left: 3px solid #25D366;
  }
  .apt-wa-icon { font-size: 16px; }
  .apt-wa-text { font-size: 10.5px; line-height: 1.4; color: var(--color-text-secondary); }
  .apt-wa-text strong { color: var(--color-text-primary); font-size: 11px; }

  .tablet-slide .pm-window {
    border-radius: 0;
    box-shadow: none;
    height: 100%;
  }

  /* ── WhatsApp Carousel ── */
  .wa-carousel {
    width: 100%;
    position: relative;
    overflow: hidden;
    background: #fff;
    aspect-ratio: 16 / 10;
  }
  .wa-carousel-track {
    position: absolute;
    inset: 0;
    bottom: 28px;
  }
  .wa-carousel-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }
  .wa-carousel-slide--active {
    opacity: 1;
    pointer-events: auto;
  }
  .wa-carousel-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .wa-carousel-dots {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 8px 0;
    z-index: 2;
  }
  .wa-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: #ccc;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s, transform 0.3s;
  }
  .wa-dot--active {
    background: #25D366;
    transform: scale(1.3);
  }

  /* ── Social Commerce in Tablet ── */
  .sc-tablet-wrap {
    width: 100%;
    display: flex;
    flex-direction: column;
    background: #FAFAF8;
    aspect-ratio: 16 / 10;
  }
  .sc-tablet-tabs {
    display: flex;
    gap: 4px;
    padding: 8px 10px;
    background: #fff;
    border-bottom: 1px solid #eee;
    flex-shrink: 0;
  }
  .sc-ttab {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 6px 12px;
    border-radius: 100px;
    border: 1px solid #e0e0e0;
    background: #fff;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.25s ease;
    white-space: nowrap;
  }
  .sc-ttab:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .sc-ttab--active {
    background: var(--color-text-primary);
    color: #fff;
    border-color: var(--color-text-primary);
  }
  .sc-ttab--active:hover {
    color: #fff;
    border-color: var(--color-text-primary);
  }
  .sc-ttab svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }
  .sc-tablet-panels {
    flex: 1;
    position: relative;
    overflow: hidden;
  }
  .sc-tablet-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .sc-tablet-img--active {
    opacity: 1;
  }

  /* Pill navigation */
  .tablet-nav {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }

  .tablet-nav-track {
    position: relative;
    display: inline-flex;
    background: rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-full, 9999px);
    padding: 3px;
    gap: 2px;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .tablet-nav-indicator {
    position: absolute;
    top: 3px;
    bottom: 3px;
    left: 3px;
    width: 0;
    background: rgba(255, 255, 255, 0.15);
    border-radius: calc(var(--radius-full, 9999px) - 2px);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    z-index: 0;
  }

  .tablet-nav-pill {
    position: relative;
    z-index: 1;
    padding: 8px 16px;
    font-family: var(--font-body, system-ui);
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.45);
    background: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.3s ease;
    line-height: 1;
  }

  .tablet-nav-pill:hover:not(.active) {
    color: rgba(255, 255, 255, 0.7);
  }

  .tablet-nav-pill.active {
    color: #fff;
    font-weight: 600;
  }

  @media (max-width: 1023px) {
    .tablet-nav-pill {
      padding: 6px 12px;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 767px) {
    .tablet-nav-track {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      max-width: calc(100vw - 32px);
      scrollbar-width: none;
    }
    .tablet-nav-track::-webkit-scrollbar { display: none; }
    .tablet-nav-pill {
      padding: 6px 10px;
      font-size: 0.6875rem;
    }
  }

  /* ── Mobile: Stacked Cards layout ── */
  @media (max-width: 767px) {
    /* Hide the entire desktop tablet UI */
    .hero-tablet-section {
      height: auto;
      padding: 0;
      background: #fff;
      overflow-x: hidden;
    }
    .hero-tablet-sticky {
      position: relative;
      height: auto;
      padding: 0;
      overflow: hidden;
    }
    .tablet-section-header,
    .tablet-3col,
    .tablet-pills-col,
    .hero-tablet-wrapper,
    .tablet-details-col {
      display: none !important;
    }

    /* ── Mobile Cards Styles ── */
    .mobile-cards { display: block !important; padding: 32px 0 16px; }

    .mc-step { padding: 24px 0; }
    .mc-step--alt { background: #f8f8f8; }

    .mc-step-header { padding: 0 20px; margin-bottom: 14px; }
    .mc-step-num {
      display: inline-flex; align-items: center; justify-content: center;
      width: 26px; height: 26px; border-radius: 50%;
      background: var(--dark-primary, #1A1A1A); color: #fff;
      font-family: var(--font-display); font-size: 12px; font-weight: 700;
      margin-bottom: 6px;
    }
    .mc-step-title {
      font-family: var(--font-display); font-size: clamp(1.3rem, 5.5vw, 1.6rem);
      font-weight: 800; color: #1A1A1A; line-height: 1.15; letter-spacing: -0.5px;
    }

    .mc-carousel {
      display: flex; gap: 12px; padding: 0 20px;
      overflow-x: auto; scroll-snap-type: x mandatory;
      scrollbar-width: none; -ms-overflow-style: none;
      -webkit-overflow-scrolling: touch;
    }
    .mc-carousel::-webkit-scrollbar { display: none; }

    .mc-card {
      flex: 0 0 85%; scroll-snap-align: center;
      background: #fff; border-radius: 16px; overflow: hidden;
      box-shadow: 0 2px 16px rgba(0,0,0,0.06);
    }
    .mc-step--alt .mc-card { background: #fff; }

    .mc-card-visual {
      width: 100%; aspect-ratio: 4/3; overflow: hidden;
      background: #f0f0f0;
    }
    .mc-card-visual--dark { background: #111; }
    .mc-card-visual img,
    .mc-card-visual video {
      width: 100%; height: 100%; object-fit: cover;
    }

    .mc-card-body { padding: 14px 16px 18px; }
    .mc-card-title {
      font-family: var(--font-display); font-size: 16px; font-weight: 700;
      color: #1A1A1A; margin-bottom: 4px;
    }
    .mc-card-desc {
      font-family: var(--font-body); font-size: 13px;
      color: #888; line-height: 1.5;
    }

    /* Single-card steps: make card full width */
    .mc-carousel:has(.mc-card:only-child) .mc-card {
      flex: 0 0 100%;
    }
  }


  /* ═══════════════════════════════════════════
     BLOQUE 2.3b: Social Commerce
     ═══════════════════════════════════════════ */
  .social-commerce-section {
    padding: clamp(80px, 10vw, 140px) 0 clamp(64px, 8vw, 100px);
    background: #FFFFFF;
    position: relative;
    overflow: hidden;
    border-top: 1px solid rgba(0,0,0,0.04);
  }
  .sc-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }
  .sc-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto clamp(40px, 6vw, 72px);
  }
  .sc-eyebrow {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    margin-bottom: 12px;
  }
  .sc-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin: 0 0 16px;
  }
  .sc-subtitle {
    font-size: clamp(0.9375rem, 1.3vw, 1.125rem);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* Tabs */
  .sc-tabs {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: clamp(32px, 4vw, 48px);
  }
  .sc-tab {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 100px;
    border: 1.5px solid rgba(0,0,0,0.1);
    background: #fff;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.25s ease;
  }
  .sc-tab:hover { border-color: rgba(0,0,0,0.2); }
  .sc-tab--active {
    background: var(--color-text-primary);
    color: #fff;
    border-color: var(--color-text-primary);
  }
  .sc-tab-icon { display: flex; align-items: center; }

  /* Sync badge */
  .sc-sync-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-secondary);
    margin-bottom: clamp(24px, 3vw, 40px);
  }
  .sc-sync-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #2AB5A0;
    flex-shrink: 0;
  }

  /* Flow panels */
  .sc-flow {
    margin-bottom: clamp(40px, 6vw, 64px);
    border-radius: var(--radius-xl, 16px);
    overflow: hidden;
    position: relative;
  }
  .sc-flow-panel { display: none; }
  .sc-flow-panel--active { display: block; }
  .sc-flow-img { width: 100%; height: auto; display: block; }

  /* Entrance animation */
  .social-commerce-section .sc-header,
  .social-commerce-section .sc-tabs,
  .social-commerce-section .sc-flow {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .social-commerce-section .sc-tabs { transition-delay: 0.15s; }
  .social-commerce-section .sc-flow { transition-delay: 0.3s; }
  .social-commerce-section.sc-visible .sc-header,
  .social-commerce-section.sc-visible .sc-tabs,
  .social-commerce-section.sc-visible .sc-flow {
    opacity: 1;
    transform: translateY(0);
  }

  /* Marquee */
  .sc-marquee-section {
    padding: 0 0 clamp(48px, 6vw, 72px);
    overflow: hidden;
    background: #FFFFFF;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  }
  .sc-marquee-row {
    overflow: hidden;
    white-space: nowrap;
    margin-bottom: 10px;
    display: flex;
    justify-content: center;
  }
  .sc-marquee-track {
    display: inline-flex;
    gap: 10px;
    animation: sc-marquee-scroll 35s linear infinite;
  }
  .sc-marquee-row--2 .sc-marquee-track {
    animation-direction: reverse;
    animation-duration: 40s;
  }
  @keyframes sc-marquee-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .sc-pill {
    display: inline-flex;
    align-items: center;
    padding: 14px 28px;
    border-radius: 100px;
    font-family: var(--font-display);
    font-size: clamp(16px, 1.6vw, 22px);
    font-weight: 800;
    letter-spacing: -0.01em;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .sc-pill--light {
    background: #fff;
    color: var(--color-text-primary);
    border: 1.5px solid rgba(0, 0, 0, 0.08);
  }
  .sc-pill--whatsapp { background: #EAF4FE; color: #3A6BBF; border: 1.5px solid #D0E4F9; }
  .sc-pill--tiktok { background: #E6F7F3; color: #1F9180; border: 1.5px solid #C4ECE4; }
  .sc-pill--instagram { background: #FDF5E6; color: #C08A2A; border: 1.5px solid #F5E6C4; }
  .sc-pill--facebook { background: #EEF2FD; color: #4068C0; border: 1.5px solid #D6DEF5; }
  .sc-pill--chatgpt { background: #E8F5F0; color: #1E8F7A; border: 1.5px solid #C8E8DE; }
  @media (prefers-reduced-motion: reduce) {
    .sc-marquee-track { animation: none; }
  }
  @media (max-width: 599px) {
    .sc-pill { padding: 10px 20px; font-size: 14px; }
  }

  /* ═══════════════════════════════════════════
     Inventario Inteligente Multisucursal
     ═══════════════════════════════════════════ */
  .inv-intel-section {
    background: var(--color-bg-primary, #FAFAF8);
    padding: clamp(80px, 10vw, 140px) 0;
  }
  .inv-intel-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
