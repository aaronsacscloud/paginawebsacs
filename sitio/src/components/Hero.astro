  .sq-features-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    pointer-events: none;
  }

  .sq-features-img:first-child {
    position: relative;
  }

  /* Mobile: simple crossfade */
