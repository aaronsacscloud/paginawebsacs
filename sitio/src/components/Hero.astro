---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
}

const {
  eyebrow = 'Comercio Consciente',
  title,
  subtitle,
  primaryCTA = { label: 'Empieza gratis', href: '/contacto' },
  secondaryCTA = { label: 'Conoce a AXO', href: '/producto#axo' },
} = Astro.props;
---

<section class="hero">
  <div class="hero-bg">
    <div class="hero-gradient"></div>
  </div>
  <div class="container hero-content">
    <span class="hero-eyebrow eyebrow">{eyebrow}</span>
    <h1 class="display-xl hero-title">{title}</h1>
    <p class="body-large hero-subtitle">{subtitle}</p>
    <div class="hero-ctas">
      <a href={primaryCTA.href} class="btn btn-white btn-lg">
        {primaryCTA.label}
        <span class="btn-arrow" aria-hidden="true">&rarr;</span>
      </a>
      {secondaryCTA && (
        <a href={secondaryCTA.href} class="btn btn-outline-white btn-lg">
          {secondaryCTA.label}
          <span class="btn-arrow" aria-hidden="true">&rarr;</span>
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 72px; /* nav height */
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #1A1A2E 0%, #16213E 50%, #1A1A2E 100%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding-block: var(--space-32);
    max-width: 800px;
  }

  @media (min-width: 768px) {
    .hero-content {
      padding-block: var(--space-40);
    }
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-full);
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-8);
  }

  .hero-title {
    color: #fff;
    margin-bottom: var(--space-6);
  }

  .hero-subtitle {
    color: rgba(255, 255, 255, 0.7);
    max-width: 560px;
    margin-bottom: var(--space-10);
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .btn-arrow {
    transition: transform var(--duration-fast) ease;
  }

  .btn:hover .btn-arrow {
    transform: translateX(3px);
  }
</style>
