  /* Pill navigation */
  .tablet-nav {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }

  .tablet-nav-track {
    position: relative;
    display: inline-flex;
    background: rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-full, 9999px);
    padding: 3px;
    gap: 2px;
    border: 1px solid rgba(255, 255, 255, 0.06);
