  }
  .inv-intel-row--header {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(0,0,0,0.35);
    background: rgba(0,0,0,0.02);
    padding: 10px 20px;
  }
  .inv-intel-row--highlight {
    background: rgba(42,181,160,0.04);
  }
  .inv-intel-prod {
    font-weight: 600;
    color: var(--color-text-primary);
  }
  .inv-intel-action {
