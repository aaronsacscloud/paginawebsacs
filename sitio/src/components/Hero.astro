  .omni-tags {
    display: flex;
    gap: 4px;
  }
  .omni-tag {
    font-family: var(--font-display);
    font-size: 7px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 999px;
    background: #1A1A1A;
    color: #fff;
  }
  .omni-tag--alt {
    background: rgba(42,181,160,0.14);
    color: #1A8F7A;
  }
  .omni-stats {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
  }
  .omni-stat {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 10px;
    padding: 8px 10px;
  }
  .omni-stat-label {
    font-size: 7px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(0,0,0,0.5);
    margin-bottom: 3px;
  }
  .omni-stat-value {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .omni-section-label {
    font-size: 7px;
    text-transform: uppercase;
