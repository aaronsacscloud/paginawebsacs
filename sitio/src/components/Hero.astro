    margin-bottom: 12px;
  }


  /* ═══════════════════════════════════════════
     BLOQUE 2.4: Casos de éxito — Reels
     ═══════════════════════════════════════════ */

  .reels-section {
    padding: clamp(64px, 8vw, 120px) 0 clamp(64px, 8vw, 100px);
    background: #f5f5f7;
    overflow: hidden;
  }
  .reels-header {
    max-width: 1200px;
    margin: 0 auto clamp(40px, 5vw, 64px);
    padding: 0 var(--space-6, 24px);
    text-align: center;
  }
  .reels-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 800;
    color: #1d1d1f;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin: 0;
  }
  .reels-subtitle {
    font-size: clamp(0.9375rem, 1.5vw, 1.125rem);
    color: rgba(0,0,0,0.45);
    margin: var(--space-4, 16px) auto 0;
    max-width: 560px;
    line-height: 1.5;
  }
  .reels-track-wrapper {
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .reels-track-wrapper::-webkit-scrollbar { display: none; }
  .reels-track {
    display: flex;
    gap: clamp(16px, 2vw, 24px);
    padding: 16px clamp(24px, 5vw, calc((100vw - 1200px) / 2 + 24px));
    width: max-content;
  }
  .reel-card {
    position: relative;
    width: clamp(340px, 42vw, 520px);
    aspect-ratio: 3 / 4;
    border-radius: 20px;
    overflow: hidden;
    flex-shrink: 0;
    scroll-snap-align: center;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    cursor: pointer;
    transform: translateY(32px);
    opacity: 0;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.35s ease;
    transition-delay: calc(var(--reel-idx, 0) * 80ms);
  }
  .reel-card.in-view {
    transform: translateY(0);
    opacity: 1;
  }
  .reel-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 12px 40px rgba(0,0,0,0.15);
  }
  .reel-card.in-view:hover {
    transform: translateY(-6px) scale(1.02);
  }
  .reel-card--highlight {
    scroll-snap-align: center;
    display: flex;
    flex-direction: column;
    background: #1A1A1A;
    aspect-ratio: auto;
  }
  .reel-hl-photo {
    overflow: hidden;
    min-height: 0;
    position: relative;
    max-height: 420px;
  }
  .reel-hl-photo img,
  .reel-highlight-bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    display: block;
  }
  .reel-highlight-bg {
    position: absolute;
    inset: 0;
  }
  .reel-hl-info {
    padding: 18px 20px 20px;
    color: #fff;
    flex-shrink: 0;
    background: #1A1A1A;
    position: relative;
    z-index: 1;
  }
  .reel-hl-stats {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 16px;
  }
  .reel-hl-stat {
    display: flex;
    flex-direction: column;
  }
  .reel-hl-stat-num {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    color: #fff;
  }
  .reel-hl-stat-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    color: rgba(255,255,255,0.55);
    margin-top: 4px;
  }
  .reel-hl-stat-divider {
    width: 1px;
    height: 36px;
    background: rgba(255,255,255,0.15);
    flex-shrink: 0;
  }
  .reel-tag {
    display: inline-flex;
    align-self: flex-start;
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.85);
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(8px);
    border-radius: 100px;
    padding: 4px 12px;
  }
  .reel-brand {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.4vw, 1.25rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
  }
  @media (max-width: 1024px) {
    .reels-section { padding: 48px 0 40px; }
    .reels-header { margin-bottom: 20px; }
    .reels-title { font-size: 1.4rem; }
    .reels-subtitle { font-size: 0.85rem; }
    .reels-track { gap: 12px; padding: 8px 16px; }
    .reel-card {
      width: 65vw;
      max-width: 280px;
      aspect-ratio: 9 / 16;
      border-radius: 16px;
    }
    .reel-card--highlight {
      aspect-ratio: 9 / 16;
      position: relative;
    }
    .reel-hl-photo,
    .reel-highlight-bg {
      position: absolute;
      inset: 0;
      max-height: none;
    }
    .reel-hl-photo img { width: 100%; height: 100%; object-fit: cover; }
    .reel-hl-info {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 40px 14px 14px;
      background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.5) 60%, transparent 100%);
      z-index: 1;
    }
    .reel-hl-stat-num { font-size: 1.3rem; }
    .reel-hl-stat-label { font-size: 10px; }
    .reel-hl-stats { gap: 10px; margin-top: 8px; }
    .reel-hl-stat-divider { height: 28px; }
  }


  /* ═══════════════════════════════════════════
     BLOQUE 2.35: Scrollytelling — sticky image + features
     ═══════════════════════════════════════════ */

  .scrolly-section {
    position: relative;
    background: #fff;
    display: block;
  }

  @media (min-width: 1024px) {
    .scrolly-section {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Sticky image — takes full left half, sticks to viewport */
  .scrolly-media {
    display: none;
  }

  @media (min-width: 1024px) {
    .scrolly-media {
      display: block;
      position: sticky;
      top: 72px;
      height: calc(100vh - 72px);
      overflow: hidden;
    }
  }

  .scrolly-img-wrap {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    margin: 24px;
    width: calc(100% - 48px);
    height: calc(100% - 48px);
  }

  /* Fondos — colores del logo */
  .scrolly-bg {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.22, 0.68, 0, 1);
    z-index: 0;
  }

  .scrolly-bg.active { opacity: 1; }

  .scrolly-bg-0 { background: #F5F5F3; }
  .scrolly-bg-1 { background: #F0F0EE; }
  .scrolly-bg-2 { background: #EDECEA; }
  .scrolly-bg-3 { background: #F2F1EF; }

  /* Images — simple crossfade */
  .scrolly-img {
    position: absolute;
    inset: 3%;
    width: 94%;
    height: 94%;
    object-fit: cover;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    z-index: 2;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .scrolly-img.active {
    opacity: 1;
  }

  /* Features column — normal scrolling flow */
  .scrolly-features {
    display: flex;
    flex-direction: column;
    padding: 0 var(--space-5);
  }

  @media (min-width: 1024px) {
    .scrolly-features {
      padding: 0 var(--space-12) 0 var(--space-10);
    }
  }

  .scrolly-item {
    padding: var(--space-10) 0;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .scrolly-item:last-child {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  @media (min-width: 1024px) {
    .scrolly-item {
      padding: var(--space-12) 0;
      min-height: 60vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .scrolly-item:first-child {
      padding-top: 20vh;
    }

    .scrolly-item:last-child {
      padding-bottom: 20vh;
    }
  }

  .scrolly-item-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text-tertiary, #8C8C8C);
    margin-bottom: var(--space-4);
    transition: color 0.4s ease;
  }

  .scrolly-item-desc {
    font-size: clamp(0.95rem, 1.2vw, 1.0625rem);
    line-height: 1.6;
    color: var(--color-text-tertiary, #8C8C8C);
    max-width: 480px;
    transition: color 0.4s ease;
  }

  .scrolly-item.active .scrolly-item-title {
    color: var(--color-text-primary, #1A1A1A);
  }

  .scrolly-item.active .scrolly-item-desc {
    color: var(--color-text-secondary, #4A4A4A);
  }


  /* ═══════════════════════════════════════════
     BLOQUE 3: Plataforma — Square-style accordion
     ═══════════════════════════════════════════ */

  .platform-section {
    background: var(--color-bg-secondary);
    padding: var(--space-20) var(--space-5);
  }

  @media (min-width: 768px) {
    .platform-section { padding: var(--space-24) var(--space-10); }
  }

  @media (min-width: 1024px) {
    .platform-section { padding: var(--space-32) var(--space-16); }
  }

  .platform-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  @media (min-width: 1024px) {
    .platform-inner {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-16);
    }
  }

  /* Left column */
  .platform-text-col {
    flex: 1;
    max-width: 560px;
  }

  .platform-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
  }

  .platform-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.035em;
    color: var(--color-text-primary);
    margin-bottom: var(--space-10);
  }

  /* Accordion */
  .platform-accordion {
    display: flex;
    flex-direction: column;
  }

  .accordion-item {
    border-top: 1px solid var(--color-border);
  }

  .accordion-item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .accordion-header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-5) 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.5vw, 1.1875rem);
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.3;
    text-align: left;
  }

  .accordion-header:hover {
    color: var(--color-primary);
  }

  .accordion-icon {
    flex-shrink: 0;
    color: var(--color-text-tertiary);
    transition: transform 0.3s ease;
  }

  .accordion-icon .icon-v {
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }

  .accordion-item.active .accordion-icon .icon-v {
    opacity: 0;
    transform: rotate(90deg);
  }

  .accordion-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .accordion-item.active .accordion-body {
    max-height: 200px;
  }

  .accordion-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
    padding-right: var(--space-8);
  }

  .accordion-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1.5px solid var(--color-text-primary);
    padding-bottom: 1px;
    margin-bottom: var(--space-5);
  }

  .accordion-link:hover {
    text-decoration: none;
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .accordion-progress {
    height: 3px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 2px;
    margin-bottom: var(--space-2);
    overflow: hidden;
  }

  .accordion-progress-fill {
    height: 100%;
    width: 0%;
    background: var(--color-primary);
    border-radius: 2px;
  }

  .accordion-item.active .accordion-progress-fill {
    animation: accordionFill 5s linear forwards;
  }

  @keyframes accordionFill {
    from { width: 0%; }
    to { width: 100%; }
  }

  /* Right column — painterly background + mockup */
  .platform-visual-col {
    flex: 1;
    position: relative;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    min-height: 480px;
  }

  @media (min-width: 768px) {
    .platform-visual-col { min-height: 560px; }
  }

  @media (min-width: 1024px) {
    .platform-visual-col {
      position: sticky;
      top: 100px;
      min-height: 600px;
    }
  }

  /* Neutral warm background */
  .platform-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(160deg, #e8e4dc 0%, #ddd8d0 50%, #d4cfc6 100%);
  }

  .platform-bg-texture {
    position: absolute;
    inset: 0;
    opacity: 0.25;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.3) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(255, 255, 255, 0.2) 0%, transparent 40%);
    mix-blend-mode: overlay;
  }

  .platform-mockup-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 520px;
    margin: var(--space-10) auto;
    min-height: 380px;
  }

  @media (min-width: 768px) {
    .platform-mockup-wrapper {
      margin: var(--space-12) auto;
      min-height: 440px;
    }
  }

  .platform-mockup {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    pointer-events: none;
  }

  .platform-mockup.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    position: relative;
  }

  /* Window mockup — estilo macOS */
  .pm-window {
    background: #fff;
    border-radius: var(--radius-xl);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.08), 0 0 0 1px rgba(0, 0, 0, 0.04);
    overflow: hidden;
  }

  .pm-titlebar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 14px 20px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .pm-dots {
    display: flex;
    gap: 6px;
  }

  .pm-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .pm-titlebar-text {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .pm-content {
    padding: 20px;
    display: flex;
    gap: 16px;
  }

  /* POS grid mockup */
  .pm-grid {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .pm-product {
    text-align: left;
  }

  .pm-product-img {
    width: 100%;
    aspect-ratio: 1;
    background: #e8e4dc;
    border-radius: var(--radius-md);
    margin-bottom: 8px;
  }

  .pm-product.selected .pm-product-img {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .pm-product-bar {
    height: 6px;
    width: 60%;
    background: #e5e5e5;
    border-radius: 3px;
    margin-bottom: 6px;
  }

  .pm-product span {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .pm-sidebar {
    width: 160px;
    flex-shrink: 0;
    padding-left: 16px;
    border-left: 1px solid rgba(0, 0, 0, 0.06);
  }

  .pm-sidebar-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 12px;
  }

  .pm-sidebar-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 0;
  }

  .pm-sidebar-bar {
    height: 5px;
    width: 60px;
    background: #e5e5e5;
    border-radius: 3px;
  }

  .pm-sidebar-row span {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .pm-sidebar-total {
    display: flex;
    justify-content: space-between;
    padding-top: 12px;
    margin-top: 12px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 14px;
    color: var(--color-text-primary);
  }

  .pm-sidebar-total strong { font-weight: 700; }

  .pm-sidebar-btn {
    margin-top: 16px;
    background: var(--color-primary);
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    text-align: center;
    padding: 10px;
    border-radius: var(--radius-full);
  }

  /* ── Conteo Físico ── */
  .conteo-split {
    display: flex;
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #f5f5f5;
  }
  .conteo-photo {
    flex: 1.2;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f0eded;
  }
  .conteo-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }
  .conteo-card {
    position: absolute;
    bottom: 12px;
    left: 12px;
    right: 40%;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(10px);
    border-radius: 10px;
    padding: 10px 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
  .conteo-card-title {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 700;
    color: #1A1A1A;
    margin-bottom: 6px;
  }
  .conteo-card-header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    font-size: 8px;
    font-weight: 700;
    color: #8C8C8C;
    text-transform: uppercase;
    padding-bottom: 4px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .conteo-card-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    font-size: 10px;
    color: #4A4A4A;
    padding: 4px 0;
  }
  .conteo-diff-neg { color: #E54B4B; font-weight: 700; }
  .conteo-diff-ok { color: #2AB5A0; font-weight: 700; }

  /* iPhone mockup */
  .conteo-phone-wrap {
    flex: 0.8;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
  }
  .conteo-phone {
    width: 140px;
    background: #000;
    border-radius: 22px;
    padding: 5px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.15);
  }
  .conteo-phone-notch {
    width: 50px;
    height: 12px;
    background: #000;
    border-radius: 0 0 8px 8px;
    margin: 0 auto -1px;
    position: relative;
    z-index: 2;
  }
  .conteo-phone-screen {
    background: #fff;
    border-radius: 18px;
    overflow: hidden;
    height: 260px;
    position: relative;
  }

  /* Frames — auto-cycling animation */
  .conteo-frame {
    position: absolute;
    inset: 0;
    opacity: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .conteo-frame--1 { animation: conteo-cycle-1 6s ease infinite; }
  .conteo-frame--2 { animation: conteo-cycle-2 6s ease infinite; }
  .conteo-frame--3 { animation: conteo-cycle-3 6s ease infinite; }

  @keyframes conteo-cycle-1 {
    0%, 5% { opacity: 0; }
    8%, 28% { opacity: 1; }
    33%, 100% { opacity: 0; }
  }
  @keyframes conteo-cycle-2 {
    0%, 30% { opacity: 0; }
    35%, 50% { opacity: 1; }
    55%, 100% { opacity: 0; }
  }
  @keyframes conteo-cycle-3 {
    0%, 52% { opacity: 0; }
    58%, 92% { opacity: 1; }
    97%, 100% { opacity: 0; }
  }

  /* Frame 1: Camera */
  .conteo-camera-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #2a2a2a 0%, #1a1a1a 100%);
  }
  .conteo-viewfinder {
    position: relative;
    width: 80px;
    height: 80px;
    z-index: 1;
  }
  .conteo-vf-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    border-color: #fff;
    border-style: solid;
    border-width: 0;
  }
  .conteo-vf-tl { top: 0; left: 0; border-top-width: 2px; border-left-width: 2px; }
  .conteo-vf-tr { top: 0; right: 0; border-top-width: 2px; border-right-width: 2px; }
  .conteo-vf-bl { bottom: 0; left: 0; border-bottom-width: 2px; border-left-width: 2px; }
  .conteo-vf-br { bottom: 0; right: 0; border-bottom-width: 2px; border-right-width: 2px; }
  .conteo-scan-line {
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: #4B7BE5;
    animation: conteo-scan-move 1.5s ease-in-out infinite;
  }
  @keyframes conteo-scan-move {
    0%, 100% { top: 0; }
    50% { top: 100%; }
  }
  .conteo-camera-label {
    position: relative;
    z-index: 1;
    font-size: 9px;
    color: rgba(255,255,255,0.6);
    margin-top: 12px;
  }

  /* Frame 2: Detected */
  .conteo-detected {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .conteo-barcode svg {
    width: 90px;
    height: 40px;
  }
  .conteo-flash {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    color: #2AB5A0;
    margin-top: 8px;
    background: rgba(42,181,160,0.08);
    padding: 4px 12px;
    border-radius: 6px;
  }

  /* Frame 3: Result */
  .conteo-result {
    padding: 16px 12px;
    text-align: center;
    width: 100%;
  }
  .conteo-result-header {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    color: #8C8C8C;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 10px;
  }
  .conteo-result-product {
    display: flex;
    align-items: center;
    gap: 8px;
    text-align: left;
    padding: 8px;
    background: #f9f9f9;
    border-radius: 8px;
    margin-bottom: 12px;
  }
  .conteo-result-img {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
  }
  .conteo-result-name {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    color: #1A1A1A;
  }
  .conteo-result-sku {
    font-family: var(--font-body);
    font-size: 9px;
    color: #8C8C8C;
  }
  .conteo-result-count {
    margin-bottom: 10px;
  }
  .conteo-result-label {
    font-size: 9px;
    color: #8C8C8C;
    display: block;
    margin-bottom: 2px;
  }
  .conteo-count-number {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.02em;
  }
  .conteo-count-of {
    font-family: var(--font-body);
    font-size: 13px;
    color: #8C8C8C;
  }
  .conteo-result-btn {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    background: #1A1A1A;
    border: none;
    border-radius: 8px;
    padding: 7px 20px;
    cursor: pointer;
    animation: conteo-btn-pulse 2s ease-in-out infinite;
  }
  @keyframes conteo-btn-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.06); }
  }
  .conteo-result-done {
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 600;
    color: #2AB5A0;
    margin-top: 8px;
    opacity: 0;
    animation: conteo-done-show 0.4s ease 4.2s forwards;
  }
  @keyframes conteo-done-show {
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .conteo-frame { animation: none; }
    .conteo-frame--3 { opacity: 1; }
    .conteo-scan-line { animation: none; }
    .conteo-result-btn { animation: none; }
  }

  /* ── Recepción de mercancía ── */
  .recepcion-split {
    display: flex;
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #f5f5f5;
  }
  .recepcion-photo {
    flex: 1.2;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e8e4e0;
  }
  .recepcion-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
  }

  /* Phone mockup */
  .recepcion-phone-wrap {
    flex: 0.8;
    display: flex;
    align-items: center;
