    font-size: 14px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .crm2-kpi-trend {
    font-size: 7px;
    color: rgba(0,0,0,0.5);
    font-weight: 600;
  }
  .crm2-kpi-trend--up { color: #1A8F7A; }
  .crm2-kpi-trend--teal { color: #1A8F7A; }

  /* Tabs */
  .crm2-tabs {
    display: flex;
    gap: 18px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    padding: 0 2px;
    position: relative;
  }
  .crm2-tab {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    color: rgba(0,0,0,0.5);
    padding: 8px 0 10px;
    cursor: pointer;
    transition: color 0.3s;
    position: relative;
  }
  /* Active state via animation — 5 tabs across 16s loop */
  .crm2-tab--0 { animation: crm2-tab-0 16s ease-in-out infinite; }
  .crm2-tab--1 { animation: crm2-tab-1 16s ease-in-out infinite; }
  .crm2-tab--2 { animation: crm2-tab-2 16s ease-in-out infinite; }
  .crm2-tab--3 { animation: crm2-tab-3 16s ease-in-out infinite; }
  .crm2-tab--4 { animation: crm2-tab-4 16s ease-in-out infinite; }
  @keyframes crm2-tab-0 { 0%,18%{color:#1A1A1A;} 22%,100%{color:rgba(0,0,0,0.5);} }
  @keyframes crm2-tab-1 { 0%,18%{color:rgba(0,0,0,0.5);} 22%,38%{color:#1A1A1A;} 42%,100%{color:rgba(0,0,0,0.5);} }
  @keyframes crm2-tab-2 { 0%,38%{color:rgba(0,0,0,0.5);} 42%,58%{color:#1A1A1A;} 62%,100%{color:rgba(0,0,0,0.5);} }
  @keyframes crm2-tab-3 { 0%,58%{color:rgba(0,0,0,0.5);} 62%,78%{color:#1A1A1A;} 82%,100%{color:rgba(0,0,0,0.5);} }
  @keyframes crm2-tab-4 { 0%,78%{color:rgba(0,0,0,0.5);} 82%,100%{color:#1A1A1A;} }

  /* Indicator widths sized to match each tab label
     Tabs: Información (≈75px) · Conversaciones (≈100px) · Compras (≈58px) · Recomendaciones IA (≈124px) · Lealtad (≈48px)
     Tab gap is 18px, tabs start at left:2px */
  .crm2-tab-indicator {
    position: absolute;
    bottom: -1px;
    left: 2px;
    height: 2px;
    background: #1A1A1A;
    border-radius: 1px;
    width: 75px;
    animation: crm2-tab-ind 16s ease-in-out infinite;
  }
  @keyframes crm2-tab-ind {
    0%, 18%   { left: 2px;   width: 75px; }
    22%, 38%  { left: 95px;  width: 100px; }
    42%, 58%  { left: 213px; width: 58px; }
    62%, 78%  { left: 289px; width: 124px; }
    82%, 100% { left: 431px; width: 48px; }
  }

  /* Panels */
  .crm2-panels {
    flex: 1;
    position: relative;
    min-height: 0;
  }
  .crm2-panel {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s, transform 0.4s;
  }
  .crm2-panel--0 { animation: crm2-panel-0 16s ease-in-out infinite; }
  .crm2-panel--1 { animation: crm2-panel-1 16s ease-in-out infinite; }
  .crm2-panel--2 { animation: crm2-panel-2 16s ease-in-out infinite; }
  .crm2-panel--3 { animation: crm2-panel-3 16s ease-in-out infinite; }
  .crm2-panel--4 { animation: crm2-panel-4 16s ease-in-out infinite; }
  @keyframes crm2-panel-0 {
    0%, 18%   { opacity: 1; transform: translateY(0); }
    22%, 100% { opacity: 0; transform: translateY(-6px); }
  }
  @keyframes crm2-panel-1 {
    0%, 18%   { opacity: 0; transform: translateY(8px); }
    22%, 38%  { opacity: 1; transform: translateY(0); }
    42%, 100% { opacity: 0; transform: translateY(-6px); }
  }
  @keyframes crm2-panel-2 {
    0%, 38%   { opacity: 0; transform: translateY(8px); }
    42%, 58%  { opacity: 1; transform: translateY(0); }
    62%, 100% { opacity: 0; transform: translateY(-6px); }
  }
  @keyframes crm2-panel-3 {
    0%, 58%   { opacity: 0; transform: translateY(8px); }
    62%, 78%  { opacity: 1; transform: translateY(0); }
    82%, 100% { opacity: 0; transform: translateY(-6px); }
  }
  @keyframes crm2-panel-4 {
    0%, 78%   { opacity: 0; transform: translateY(8px); }
    82%, 100% { opacity: 1; transform: translateY(0); }
  }

  .crm2-panel-grid {
    display: grid;
    grid-template-columns: 0.85fr 1fr;
    gap: 10px;
    height: 100%;
  }
  .crm2-card {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 10px;
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .crm2-card--full { width: 100%; height: 100%; }
  .crm2-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }
  .crm2-card-title {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .crm2-card-link {
    font-size: 8px;
    color: #1A1A1A;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .crm2-card-tag {
    font-size: 7px;
    font-weight: 800;
    letter-spacing: 0.08em;
    background: #F5F5F7;
    color: rgba(0,0,0,0.65);
    padding: 2px 7px;
    border-radius: 4px;
  }
  .crm2-card-tag--gold { color: #B8956A; background: rgba(184,149,106,0.14); }

  /* Donut chart */
  .crm2-donut {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 10px;
    align-items: center;
    flex: 1;
  }
  .crm2-donut-legend {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 8px;
    color: rgba(0,0,0,0.7);
    font-weight: 600;
  }
  .crm2-donut-item { display: flex; align-items: center; gap: 5px; }
  .crm2-donut-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  /* Timeline events */
  .crm2-timeline { display: flex; flex-direction: column; gap: 5px; flex: 1; }
  .crm2-event {
    display: grid;
    grid-template-columns: 60px 1fr auto;
    align-items: center;
    gap: 8px;
    background: #FAFAFA;
    border-radius: 6px;
    padding: 6px 8px;
  }
  .crm2-event-channel,
  .crm2-tchan {
    font-family: var(--font-display);
    font-size: 7px;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: #fff;
    padding: 2px 6px;
    border-radius: 3px;
    text-align: center;
    min-width: 56px;
  }
  .crm2-channel--store    { background: #1A1A1A; }
  .crm2-channel--online   { background: #4B7BE5; }
  .crm2-channel--wa       { background: #25D366; }
  .crm2-channel--ig       { background: #C13584; }
  .crm2-event-title {
    font-size: 8.5px;
    font-weight: 700;
    color: #1A1A1A;
  }
  .crm2-event-detail {
    font-size: 7px;
    color: rgba(0,0,0,0.55);
    margin-top: 1px;
  }
  .crm2-event-date {
    font-size: 7px;
    color: rgba(0,0,0,0.45);
  }

  /* Table */
  .crm2-table { display: flex; flex-direction: column; gap: 0; }
  .crm2-trow {
    display: grid;
    grid-template-columns: 2.5fr 1fr 1fr 0.7fr;
    align-items: center;
    gap: 12px;
    padding: 7px 4px;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    font-size: 9px;
  }
  .crm2-trow:last-child { border-bottom: none; }
  .crm2-trow--head {
    font-size: 7px;
    color: rgba(0,0,0,0.5);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    border-bottom: 1px solid rgba(0,0,0,0.10);
  }
  .crm2-tprod {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #1A1A1A;
    font-weight: 600;
  }
  .crm2-tprod img {
    width: 28px;
    height: 28px;
    border-radius: 4px;
    object-fit: cover;
    background: #F2F1EE;
  }
  .crm2-tdate { color: rgba(0,0,0,0.55); }
  .crm2-tprice { font-family: var(--font-display); font-weight: 800; color: #1A1A1A; text-align: right; }

  /* Recommendations */
  .crm2-recos {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    flex: 1;
    margin-bottom: 8px;
  }
  .crm2-reco {
    background: #FAFAFA;
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 8px;
    padding: 6px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .crm2-reco-img {
    aspect-ratio: 4/5;
    border-radius: 4px;
    overflow: hidden;
    background: #F2F1EE;
    margin-bottom: 4px;
  }
  .crm2-reco-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .crm2-reco-name {
    font-size: 8.5px;
    font-weight: 700;
    color: #1A1A1A;
  }
  .crm2-reco-meta {
    font-size: 7px;
    color: rgba(0,0,0,0.5);
  }
  .crm2-reco-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 4px;
  }
  .crm2-reco-price {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    color: #1A1A1A;
  }
  .crm2-reco-match {
    background: #2AB5A0;
    color: #fff;
    font-size: 8px;
    font-weight: 800;
    padding: 1px 6px;
    border-radius: 3px;
  }
  .crm2-recos-foot {
    display: flex;
    justify-content: space-between;
    font-size: 7.5px;
    color: rgba(0,0,0,0.55);
    padding-top: 6px;
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  /* Wallet — light Square style */
  .crm2-wallet {
    background: #FFFFFF;
    color: #1A1A1A;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 10px;
    padding: 14px 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    box-shadow: 0 2px 8px -2px rgba(20,20,30,0.05);
  }
  .crm2-wallet-label {
    font-size: 7px;
    color: rgba(0,0,0,0.5);
    letter-spacing: 0.1em;
    font-weight: 700;
  }
  .crm2-wallet-value {
    font-family: var(--font-display);
    font-size: 30px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #1A1A1A;
  }
  .crm2-wallet-cents {
    font-size: 16px;
    color: rgba(0,0,0,0.4);
    font-weight: 600;
  }
  .crm2-wallet-progress { margin-top: auto; }
  .crm2-wallet-bar {
    width: 100%;
    height: 4px;
    background: rgba(0,0,0,0.06);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 4px;
  }
  .crm2-wallet-fill {
    height: 100%;
    width: 70%;
    background: linear-gradient(90deg, #2AB5A0, #4B7BE5);
    border-radius: 2px;
    animation: crm2-wallet-grow 16s ease-in-out infinite;
  }
  @keyframes crm2-wallet-grow {
    0%, 78%   { width: 50%; }
    100%      { width: 72%; }
  }
  .crm2-wallet-levels {
    display: flex;
    justify-content: space-between;
    font-size: 6.5px;
    font-weight: 700;
    color: rgba(0,0,0,0.4);
    letter-spacing: 0.06em;
  }
  .crm2-wallet-cur { color: #1A8F7A; }
  .crm2-wallet-next { color: rgba(0,0,0,0.25); }
  .crm2-wallet-hint {
    font-size: 7px;
    color: rgba(0,0,0,0.5);
    text-align: center;
    margin-top: 4px;
  }

  /* Movements */
  .crm2-mov { display: flex; flex-direction: column; gap: 4px; flex: 1; }
  .crm2-mov-row {
    display: grid;
    grid-template-columns: 22px 1fr auto;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    background: #FAFAFA;
    border-radius: 6px;
  }
  .crm2-mov-ic {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    font-weight: 800;
  }
  .crm2-mov-ic--up   { background: rgba(42,181,160,0.14); color: #1A8F7A; }
  .crm2-mov-ic--down { background: #F5F5F7; color: rgba(0,0,0,0.5); }
  .crm2-mov-name {
    font-size: 8.5px;
    font-weight: 700;
    color: #1A1A1A;
  }
  .crm2-mov-date {
    font-size: 6.5px;
    color: rgba(0,0,0,0.5);
    margin-top: 1px;
  }
  .crm2-mov-amt {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
  }
  .crm2-mov-amt--pos { color: #1A8F7A; }
  .crm2-mov-amt--neg { color: rgba(0,0,0,0.55); }

  /* ── Panel 0: Información del cliente ── */
  .crm2-info-grid {
    display: grid;
    grid-template-columns: 0.95fr 1fr;
    gap: 10px;
    height: 100%;
  }
  .crm2-info-rows {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .crm2-info-row {
    display: grid;
    grid-template-columns: 18px 80px 1fr;
    gap: 8px;
    align-items: center;
    padding: 7px 10px;
    background: #FAFAFA;
    border-radius: 6px;
    font-size: 8.5px;
  }
  .crm2-info-ic {
    width: 18px;
    height: 18px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(0,0,0,0.55);
    font-size: 10px;
  }
  .crm2-info-ic--wa { background: rgba(37,211,102,0.12); color: #22a85a; border-color: rgba(37,211,102,0.25); }
  .crm2-info-label {
    font-size: 7px;
    color: rgba(0,0,0,0.5);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
  }
  .crm2-info-value {
    font-size: 8.5px;
    color: #1A1A1A;
    font-weight: 600;
  }
  .crm2-info-pill {
    display: inline-block;
    background: rgba(42,181,160,0.14);
    color: #1A8F7A;
    font-size: 6.5px;
    font-weight: 800;
    padding: 1px 6px;
    border-radius: 4px;
    margin-left: 6px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ── Panel 1: Conversaciones ── */
  .crm2-conv-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 12px;
    flex: 1;
    min-height: 0;
  }
  .crm2-conv-list {
    display: flex;
    flex-direction: column;
    gap: 5px;
    overflow: hidden;
  }
  .crm2-conv-row {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 10px;
    padding: 8px 10px;
    background: #FAFAFA;
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 8px;
  }
  .crm2-conv-row--active {
    background: #fff;
    border-color: rgba(42,181,160,0.3);
    box-shadow: 0 1px 4px -1px rgba(42,181,160,0.10);
  }
  .crm2-conv-ch {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .crm2-conv-ch--wa    { background: #25D366; }
  .crm2-conv-ch--email { background: #4B7BE5; }
  .crm2-conv-ch--call  { background: #2AB5A0; }
  .crm2-conv-body { min-width: 0; }
  .crm2-conv-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
  }
  .crm2-conv-name {
    font-size: 8.5px;
    font-weight: 800;
    color: #1A1A1A;
  }
  .crm2-conv-time {
    font-size: 7px;
    color: rgba(0,0,0,0.45);
    flex-shrink: 0;
  }
  .crm2-conv-msg {
    font-size: 8px;
    color: rgba(0,0,0,0.65);
    line-height: 1.4;
    margin-top: 2px;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .crm2-conv-meta { margin-top: 4px; }
  .crm2-conv-tag {
    display: inline-block;
    font-size: 6.5px;
    font-weight: 700;
    color: rgba(0,0,0,0.55);
    background: #F5F5F7;
    padding: 1px 6px;
    border-radius: 999px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .crm2-conv-tag--ok {
    color: #1A8F7A;
    background: rgba(42,181,160,0.14);
  }

  .crm2-conv-stats {
    background: #FAFAFA;
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 10px;
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .crm2-conv-stats-title {
    font-size: 7px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(0,0,0,0.5);
    margin-bottom: 2px;
  }
  .crm2-conv-stat {
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: 8px;
    align-items: center;
  }
  .crm2-conv-stat-icon {
    width: 24px;
    height: 24px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .crm2-conv-stat-name {
    font-size: 9px;
    font-weight: 700;
    color: #1A1A1A;
  }
  .crm2-conv-stat-meta {
    font-size: 7px;
    color: rgba(0,0,0,0.55);
    margin-top: 1px;
  }
  .crm2-conv-foot {
    margin-top: auto;
  }

  /* AI summary card */
  .crm2-card--ai {
    background: linear-gradient(180deg, #FFFFFF 0%, #F8FAFE 100%);
    border-color: rgba(75,123,229,0.18);
    position: relative;
  }
  .crm2-card--ai::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, #4B7BE5, #2AB5A0);
    border-radius: 10px 10px 0 0;
  }
  .crm2-ai-typing-cue {
    color: #4B7BE5 !important;
    text-decoration: none !important;
    font-weight: 700;
    font-size: 8px;
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }
  .crm2-ai-dots {
    display: inline-block;
    margin-left: 2px;
    animation: crm2-ai-dots-blink 1.2s steps(4) infinite;
  }
  @keyframes crm2-ai-dots-blink {
    0%   { opacity: 0; }
    25%  { opacity: 0.4; }
    50%  { opacity: 0.7; }
    75%  { opacity: 1; }
    100% { opacity: 0; }
  }
  .crm2-ai-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 10px;
    overflow: hidden;
  }
  .crm2-ai-line {
    font-size: 8.5px;
    line-height: 1.55;
    color: rgba(0,0,0,0.75);
    opacity: 0;
    transform: translateY(4px);
  }
  .crm2-ai-line strong { color: #1A1A1A; font-weight: 700; }
  .crm2-ai-line--1 { animation: crm2-ai-line-in 16s ease-in-out infinite; }
  .crm2-ai-line--2 { animation: crm2-ai-line-in 16s ease-in-out infinite; animation-delay: 0.6s; }
  .crm2-ai-line--3 { animation: crm2-ai-line-in 16s ease-in-out infinite; animation-delay: 1.2s; }
  .crm2-ai-line--4 { animation: crm2-ai-line-in 16s ease-in-out infinite; animation-delay: 1.8s; }
  @keyframes crm2-ai-line-in {
    0%, 4%   { opacity: 0; transform: translateY(4px); }
    10%, 18% { opacity: 1; transform: translateY(0); }
    22%, 100% { opacity: 0; transform: translateY(-2px); }
  }
  .crm2-ai-actions {
    display: flex;
    gap: 6px;
    margin-top: auto;
  }
  .crm2-ai-btn {
    flex: 1;
    background: #1A1A1A;
