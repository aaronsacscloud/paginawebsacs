  }

  .scrolly-item:last-child {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  @media (min-width: 1024px) {
    .scrolly-item {
      padding: var(--space-12) 0;
      min-height: 60vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .scrolly-item:first-child {
      padding-top: 20vh;
    }

    .scrolly-item:last-child {
      padding-bottom: 20vh;
    }
  }

  .scrolly-item-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text-primary, #1A1A1A);
    margin-bottom: var(--space-4);
  }

  .scrolly-item-desc {
    font-size: clamp(0.95rem, 1.2vw, 1.0625rem);
    line-height: 1.6;
    color: var(--color-text-secondary, #4A4A4A);
    max-width: 480px;
  }


  /* ═══════════════════════════════════════════
     BLOQUE 3: Plataforma — Square-style accordion
     ═══════════════════════════════════════════ */

  .platform-section {
    background: var(--color-bg-secondary);
    padding: var(--space-20) var(--space-5);
  }

  @media (min-width: 768px) {
    .platform-section { padding: var(--space-24) var(--space-10); }
  }

  @media (min-width: 1024px) {
    .platform-section { padding: var(--space-32) var(--space-16); }
  }

  .platform-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  @media (min-width: 1024px) {
    .platform-inner {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-16);
    }
  }

  /* Left column */
  .platform-text-col {
    flex: 1;
    max-width: 560px;
  }

  .platform-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
  }

  .platform-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.035em;
    color: var(--color-text-primary);
    margin-bottom: var(--space-10);
  }

  /* Accordion */
  .platform-accordion {
    display: flex;
    flex-direction: column;
  }

  .accordion-item {
    border-top: 1px solid var(--color-border);
  }

  .accordion-item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .accordion-header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-5) 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.5vw, 1.1875rem);
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.3;
    text-align: left;
  }

  .accordion-header:hover {
    color: var(--color-primary);
  }

  .accordion-icon {
    flex-shrink: 0;
    color: var(--color-text-tertiary);
    transition: transform 0.3s ease;
  }

  .accordion-icon .icon-v {
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }

  .accordion-item.active .accordion-icon .icon-v {
    opacity: 0;
    transform: rotate(90deg);
  }

  .accordion-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .accordion-item.active .accordion-body {
    max-height: 200px;
  }

  .accordion-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
    padding-right: var(--space-8);
  }

  .accordion-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1.5px solid var(--color-text-primary);
    padding-bottom: 1px;
    margin-bottom: var(--space-5);
  }

  .accordion-link:hover {
    text-decoration: none;
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .accordion-progress {
    height: 3px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 2px;
    margin-bottom: var(--space-2);
    overflow: hidden;
  }

  .accordion-progress-fill {
    height: 100%;
    width: 0%;
    background: var(--color-primary);
    border-radius: 2px;
  }

  .accordion-item.active .accordion-progress-fill {
    animation: accordionFill 5s linear forwards;
  }

  @keyframes accordionFill {
    from { width: 0%; }
    to { width: 100%; }
  }

  /* Right column — painterly background + mockup */
  .platform-visual-col {
    flex: 1;
    position: relative;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    min-height: 480px;
  }

  @media (min-width: 768px) {
    .platform-visual-col { min-height: 560px; }
  }

  @media (min-width: 1024px) {
    .platform-visual-col {
      position: sticky;
      top: 100px;
      min-height: 600px;
    }
  }

  /* Neutral warm background */
  .platform-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(160deg, #e8e4dc 0%, #ddd8d0 50%, #d4cfc6 100%);
  }

  .platform-bg-texture {
    position: absolute;
    inset: 0;
    opacity: 0.25;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.3) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(255, 255, 255, 0.2) 0%, transparent 40%);
    mix-blend-mode: overlay;
  }

  .platform-mockup-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 520px;
    margin: var(--space-10) auto;
    min-height: 380px;
  }

  @media (min-width: 768px) {
    .platform-mockup-wrapper {
      margin: var(--space-12) auto;
      min-height: 440px;
    }
  }

  .platform-mockup {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    pointer-events: none;
  }

  .platform-mockup.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    position: relative;
  }

  /* Window mockup — estilo macOS */
  .pm-window {
    background: #fff;
    border-radius: var(--radius-xl);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.08), 0 0 0 1px rgba(0, 0, 0, 0.04);
    overflow: hidden;
  }

  .pm-titlebar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 14px 20px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .pm-dots {
    display: flex;
    gap: 6px;
  }

  .pm-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .pm-titlebar-text {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .pm-content {
    padding: 20px;
    display: flex;
    gap: 16px;
  }

  /* POS grid mockup */
  .pm-grid {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .pm-product {
    text-align: left;
  }

  .pm-product-img {
    width: 100%;
    aspect-ratio: 1;
    background: #e8e4dc;
    border-radius: var(--radius-md);
    margin-bottom: 8px;
  }

  .pm-product.selected .pm-product-img {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .pm-product-bar {
    height: 6px;
    width: 60%;
    background: #e5e5e5;
    border-radius: 3px;
    margin-bottom: 6px;
  }

  .pm-product span {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .pm-sidebar {
    width: 160px;
    flex-shrink: 0;
    padding-left: 16px;
    border-left: 1px solid rgba(0, 0, 0, 0.06);
  }

  .pm-sidebar-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 12px;
  }

  .pm-sidebar-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 0;
  }

  .pm-sidebar-bar {
    height: 5px;
    width: 60px;
    background: #e5e5e5;
    border-radius: 3px;
  }

  .pm-sidebar-row span {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .pm-sidebar-total {
    display: flex;
    justify-content: space-between;
    padding-top: 12px;
    margin-top: 12px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 14px;
    color: var(--color-text-primary);
  }

  .pm-sidebar-total strong { font-weight: 700; }

  .pm-sidebar-btn {
    margin-top: 16px;
    background: var(--color-primary);
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    text-align: center;
    padding: 10px;
    border-radius: var(--radius-full);
  }

  /* ── Conteo Físico ── */
  .conteo-split {
    display: flex;
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #f5f5f5;
  }
  .conteo-photo {
    flex: 1.2;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f0eded;
  }
  .conteo-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }
  .conteo-card {
    position: absolute;
    bottom: 12px;
    left: 12px;
    right: 40%;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(10px);
    border-radius: 10px;
    padding: 10px 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
  .conteo-card-title {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 700;
    color: #1A1A1A;
    margin-bottom: 6px;
  }
  .conteo-card-header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    font-size: 8px;
    font-weight: 700;
    color: #8C8C8C;
    text-transform: uppercase;
    padding-bottom: 4px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .conteo-card-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    font-size: 10px;
    color: #4A4A4A;
    padding: 4px 0;
  }
  .conteo-diff-neg { color: #E54B4B; font-weight: 700; }
  .conteo-diff-ok { color: #2AB5A0; font-weight: 700; }

  /* iPhone mockup */
  .conteo-phone-wrap {
    flex: 0.8;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
  }
  .conteo-phone {
    width: 140px;
    background: #000;
    border-radius: 22px;
    padding: 5px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.15);
  }
  .conteo-phone-notch {
    width: 50px;
    height: 12px;
    background: #000;
    border-radius: 0 0 8px 8px;
    margin: 0 auto -1px;
    position: relative;
    z-index: 2;
  }
  .conteo-phone-screen {
    background: #fff;
    border-radius: 18px;
    overflow: hidden;
    height: 260px;
    position: relative;
  }

  /* Frames — auto-cycling animation */
  .conteo-frame {
    position: absolute;
    inset: 0;
    opacity: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .conteo-frame--1 { animation: conteo-cycle-1 6s ease infinite; }
  .conteo-frame--2 { animation: conteo-cycle-2 6s ease infinite; }
  .conteo-frame--3 { animation: conteo-cycle-3 6s ease infinite; }

  @keyframes conteo-cycle-1 {
    0%, 5% { opacity: 0; }
    8%, 28% { opacity: 1; }
    33%, 100% { opacity: 0; }
  }
  @keyframes conteo-cycle-2 {
    0%, 30% { opacity: 0; }
    35%, 50% { opacity: 1; }
    55%, 100% { opacity: 0; }
  }
  @keyframes conteo-cycle-3 {
    0%, 52% { opacity: 0; }
    58%, 92% { opacity: 1; }
    97%, 100% { opacity: 0; }
  }

  /* Frame 1: Camera */
  .conteo-camera-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #2a2a2a 0%, #1a1a1a 100%);
  }
  .conteo-viewfinder {
    position: relative;
    width: 80px;
    height: 80px;
    z-index: 1;
  }
  .conteo-vf-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    border-color: #fff;
    border-style: solid;
    border-width: 0;
  }
  .conteo-vf-tl { top: 0; left: 0; border-top-width: 2px; border-left-width: 2px; }
  .conteo-vf-tr { top: 0; right: 0; border-top-width: 2px; border-right-width: 2px; }
  .conteo-vf-bl { bottom: 0; left: 0; border-bottom-width: 2px; border-left-width: 2px; }
  .conteo-vf-br { bottom: 0; right: 0; border-bottom-width: 2px; border-right-width: 2px; }
  .conteo-scan-line {
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: #4B7BE5;
    animation: conteo-scan-move 1.5s ease-in-out infinite;
  }
  @keyframes conteo-scan-move {
    0%, 100% { top: 0; }
    50% { top: 100%; }
  }
  .conteo-camera-label {
    position: relative;
    z-index: 1;
    font-size: 9px;
    color: rgba(255,255,255,0.6);
    margin-top: 12px;
  }

  /* Frame 2: Detected */
  .conteo-detected {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .conteo-barcode svg {
    width: 90px;
    height: 40px;
  }
  .conteo-flash {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    color: #2AB5A0;
    margin-top: 8px;
    background: rgba(42,181,160,0.08);
    padding: 4px 12px;
    border-radius: 6px;
  }

  /* Frame 3: Result */
  .conteo-result {
    padding: 16px 12px;
    text-align: center;
    width: 100%;
  }
  .conteo-result-header {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    color: #8C8C8C;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 10px;
  }
  .conteo-result-product {
    display: flex;
    align-items: center;
    gap: 8px;
    text-align: left;
    padding: 8px;
    background: #f9f9f9;
    border-radius: 8px;
    margin-bottom: 12px;
  }
  .conteo-result-img {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
  }
  .conteo-result-name {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    color: #1A1A1A;
  }
  .conteo-result-sku {
    font-family: var(--font-body);
    font-size: 9px;
    color: #8C8C8C;
  }
  .conteo-result-count {
    margin-bottom: 10px;
  }
  .conteo-result-label {
    font-size: 9px;
    color: #8C8C8C;
    display: block;
    margin-bottom: 2px;
  }
  .conteo-count-number {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.02em;
  }
  .conteo-count-of {
    font-family: var(--font-body);
    font-size: 13px;
    color: #8C8C8C;
  }
  .conteo-result-btn {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    background: #1A1A1A;
    border: none;
    border-radius: 8px;
    padding: 7px 20px;
    cursor: pointer;
    animation: conteo-btn-pulse 2s ease-in-out infinite;
  }
  @keyframes conteo-btn-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.06); }
  }
  .conteo-result-done {
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 600;
    color: #2AB5A0;
    margin-top: 8px;
    opacity: 0;
    animation: conteo-done-show 0.4s ease 4.2s forwards;
  }
  @keyframes conteo-done-show {
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .conteo-frame { animation: none; }
    .conteo-frame--3 { opacity: 1; }
    .conteo-scan-line { animation: none; }
    .conteo-result-btn { animation: none; }
  }

  /* ── Recepción de mercancía ── */
  .recepcion-split {
    display: flex;
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #f5f5f5;
  }
  .recepcion-photo {
    flex: 1.2;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e8e4e0;
  }
  .recepcion-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
  }

  /* Phone mockup */
  .recepcion-phone-wrap {
    flex: 0.8;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  .recepcion-phone {
    width: 55%;
    max-width: 180px;
    aspect-ratio: 9 / 19;
    background: #1A1A1A;
    border-radius: 28px;
    padding: 8px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.15);
    position: relative;
  }
  .recepcion-phone-notch {
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 35%;
    height: 14px;
    background: #1A1A1A;
    border-radius: 0 0 10px 10px;
    z-index: 2;
  }
  .recepcion-phone-screen {
    width: 100%;
    height: 100%;
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    position: relative;
  }

  /* Frames */
  .recepcion-frame {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
  }
  .recepcion-frame--1 {
    animation: recepcion-frame1 6s ease infinite;
  }
  .recepcion-frame--2 {
    animation: recepcion-frame2 6s ease infinite;
  }
  .recepcion-frame--3 {
    animation: recepcion-frame3 6s ease infinite;
  }

  @keyframes recepcion-frame1 {
    0%, 5%   { opacity: 1; }
    28%, 100% { opacity: 0; }
  }
  @keyframes recepcion-frame2 {
    0%, 28%  { opacity: 0; }
    33%, 55% { opacity: 1; }
    60%, 100% { opacity: 0; }
  }
  @keyframes recepcion-frame3 {
    0%, 58%  { opacity: 0; }
    65%, 95% { opacity: 1; }
    100%     { opacity: 0; }
  }

  /* Frame 1: QR Scanner */
  .recepcion-scan-bg {
    position: absolute;
    inset: 0;
    background: #111;
  }
  .recepcion-qr-target {
    width: 50%;
    aspect-ratio: 1;
    position: relative;
    z-index: 1;
  }
  .recepcion-qr-corner {
    position: absolute;
    width: 18px;
    height: 18px;
    border-color: #fff;
    border-style: solid;
    border-width: 0;
  }
  .recepcion-qr-tl { top: 0; left: 0; border-top-width: 3px; border-left-width: 3px; border-radius: 4px 0 0 0; }
  .recepcion-qr-tr { top: 0; right: 0; border-top-width: 3px; border-right-width: 3px; border-radius: 0 4px 0 0; }
  .recepcion-qr-bl { bottom: 0; left: 0; border-bottom-width: 3px; border-left-width: 3px; border-radius: 0 0 0 4px; }
  .recepcion-qr-br { bottom: 0; right: 0; border-bottom-width: 3px; border-right-width: 3px; border-radius: 0 0 4px 0; }
  .recepcion-scan-line {
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: #22c55e;
    box-shadow: 0 0 8px rgba(34,197,94,0.6);
    animation: recepcion-scanline 1.5s ease-in-out infinite;
  }
  @keyframes recepcion-scanline {
    0%, 100% { top: 10%; }
    50% { top: 85%; }
  }
  .recepcion-scan-label {
    position: relative;
    z-index: 1;
    color: rgba(255,255,255,0.7);
    font-family: var(--font-body);
    font-size: 8px;
    margin-top: 12px;
  }

  /* Frame 2: Detected */
  .recepcion-detected {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .recepcion-qr-icon {
    width: 40px;
    height: 40px;
  }
  .recepcion-flash {
    font-family: var(--font-body);
