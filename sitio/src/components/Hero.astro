  .hero-btn-outline:hover {
    background: rgba(0, 0, 0, 0.04);
    border-color: rgba(0, 0, 0, 0.25);
    transform: translateY(-1px);
  }

  /* Bottom bar — credibility badges */
  .hero-bottom-bar {
    padding-top: var(--space-8);
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.55s both;
  }

  .hero-badges {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  @media (min-width: 768px) {
    .hero-badges { gap: var(--space-8); }
  }

  .hero-badge {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .hero-badge-icon {
    flex-shrink: 0;
    color: var(--color-text-tertiary);
  }

  .hero-badge-value {
    display: block;
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.2;
  }

  .hero-badge-label {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    line-height: 1.2;
  }

  .hero-badge-divider {
    width: 1px;
    height: 28px;
    background: rgba(0, 0, 0, 0.12);
    display: none;
  }

  @media (min-width: 768px) {
    .hero-badge-divider { display: block; }
  }

  /* ─── Mobile hero image ─── */
  .hero-mobile-visual {
    display: block;
    margin-top: var(--space-8);
    position: relative;
  }

  @media (min-width: 1024px) {
    .hero-mobile-visual {
      display: none;
    }
  }

  .hero-mobile-image-wrapper {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.1), 0 4px 12px rgba(0, 0, 0, 0.06);
  }

  .hero-mobile-image {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    object-position: center 55%;
    display: block;
  }

  /* ─── Mobile floating notifs ─── */
  .hero-mobile-notif {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 12px;
    padding: 8px 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12), 0 0 0 1px rgba(0, 0, 0, 0.04);
    animation: mobileNotifIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-mobile-notif-1 {
    top: 12%;
    right: 4%;
    animation-delay: 0.8s;
  }

  .hero-mobile-notif-2 {
    bottom: 12%;
    left: 4%;
    animation-delay: 1.2s;
  }

  @keyframes mobileNotifIn {
    from { opacity: 0; transform: translateY(8px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .hmn-icon {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .hmn-icon-shop {
    background: linear-gradient(135deg, #4B7BE5, #3B6BD4);
  }

  .hmn-icon-inv {
    background: linear-gradient(135deg, #2AB5A0, #1DA090);
  }

  .hmn-body {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hmn-title {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-text-primary, #1a1a2e);
    line-height: 1.2;
  }

  .hmn-msg {
    font-size: 0.625rem;
    font-weight: 500;
    color: var(--color-text-tertiary, #8c8c8c);
    line-height: 1.3;
  }

  /* ─── Hero image (right side) ─── */
  .hero-visual {
    display: none;
    position: relative;
    align-self: center;
  }

  @media (min-width: 1024px) {
    .hero-visual {
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }

  .hero-image-wrapper {
    position: relative;
    animation: heroImageIn 1s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  .hero-image {
    width: 100%;
    max-width: 600px;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-xl, 20px);
    object-fit: cover;
    object-position: center 55%;
  }

  @keyframes heroImageIn {
    from {
      opacity: 0;
      transform: translateY(40px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* ─── Floating notifications ─── */
  .hero-notif {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 14px;
    padding: 10px 14px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12), 0 0 0 1px rgba(0, 0, 0, 0.04);
    opacity: 0;
    white-space: nowrap;
  }

  /* Slot positions — notifs 1-3 are slot A, 4-6 are slot B (rotate) */
  .hero-notif-1, .hero-notif-4 {
    bottom: 52%;
    left: -8%;
  }

  .hero-notif-2, .hero-notif-5 {
    bottom: 32%;
    right: -6%;
  }

  .hero-notif-3, .hero-notif-6 {
    bottom: 14%;
    left: 2%;
  }

  /* First wave — appear and stay for 4s, then fade out */
  .hero-notif-1 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.2s both,
               notifFadeOut 0.5s ease 5.2s forwards;
  }
  .hero-notif-2 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.8s both,
               notifFadeOut 0.5s ease 5.8s forwards;
  }
  .hero-notif-3 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 2.4s both,
               notifFadeOut 0.5s ease 6.4s forwards;
  }

  /* Second wave — appear after first wave fades and STAY visible */
  .hero-notif-4 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 5.8s both;
  }
  .hero-notif-5 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 6.4s both;
  }
  .hero-notif-6 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 7.0s both;
  }

  @keyframes notifSlideIn {
    from {
      opacity: 0;
      transform: translateX(-20px) scale(0.9);
    }
    to {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
  }

  @keyframes notifPulse {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @keyframes notifFadeOut {
    from {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
    to {
      opacity: 0;
      transform: translateX(-10px) scale(0.95);
    }
  }

  .hero-notif-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-notif-icon-loyalty { background: #25D366; }
  .hero-notif-icon-shop { background: var(--color-primary, #4B7BE5); }
  .hero-notif-icon-inventory { background: #2AB5A0; }
  .hero-notif-icon-receiving { background: #4B7BE5; }
  .hero-notif-icon-shrink { background: #E8A838; }
  .hero-notif-icon-restock { background: #E54B4B; }

  .hero-notif-body {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .hero-notif-title {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-text-primary, #1A1A1A);
    letter-spacing: -0.01em;
  }

  .hero-notif-msg {
    font-size: 0.625rem;
    color: var(--color-text-secondary, #4A4A4A);
    line-height: 1.3;
  }

  .hero-notif-time {
    font-size: 0.5625rem;
    color: var(--color-text-tertiary, #8C8C8C);
    flex-shrink: 0;
  }

  .hero-notif-badge {
    font-size: 0.5625rem;
    font-weight: 700;
    color: #fff;
    background: #E54B4B;
    border-radius: 50px;
    padding: 2px 6px;
    flex-shrink: 0;
  }

  @media (max-width: 1023px) {
    .hero-notif { display: none; }
  }

  /* ═══════════════════════════════════════════
     BLOQUE 2: Tablet 3D — scroll-driven
     ═══════════════════════════════════════════ */

  .hero-tablet-section {
    --tablet-tilt: 0;
    height: auto;
    position: relative;
    background: transparent;
  }

  .hero-tablet-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    padding: 24px;
    padding-top: 88px; /* clears the sticky nav (~71px) with breathing room */
    box-sizing: border-box;
    overflow: hidden;
  }

  /* ── Backgrounds — Apple-inspired deep tones + sacred geometry ── */
  .tablet-bg-patterns {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .tablet-bg-layer {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tablet-bg-layer.active {
    opacity: 1;
  }

  /* ── POS — Clean white with soft blue ambient glow + Seed of Life ── */
  .tablet-bg-layer[data-bg="pos"] {
    background: #f5f5f7;
  }
  .tablet-bg-layer[data-bg="pos"]::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 15%, rgba(75,123,229,0.08) 0%, transparent 70%),
      radial-gradient(ellipse 50% 45% at 85% 80%, rgba(100,150,255,0.06) 0%, transparent 55%),
      radial-gradient(ellipse 120% 80% at 50% 100%, rgba(75,123,229,0.04) 0%, transparent 50%);
  }
  .tablet-bg-layer[data-bg="pos"]::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='200' height='200' viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='rgba(0,0,0,0.04)' stroke-width='0.5'%3E%3Ccircle cx='100' cy='100' r='30'/%3E%3Ccircle cx='100' cy='70' r='30'/%3E%3Ccircle cx='126' cy='85' r='30'/%3E%3Ccircle cx='126' cy='115' r='30'/%3E%3Ccircle cx='100' cy='130' r='30'/%3E%3Ccircle cx='74' cy='115' r='30'/%3E%3Ccircle cx='74' cy='85' r='30'/%3E%3C/g%3E%3C/svg%3E");
    background-size: 200px 200px;
    opacity: 0.5;
  }

  /* ── Stock — Warm off-white with soft teal glow + Flower of Life ── */
  .tablet-bg-layer[data-bg="stock"] {
    background: #f5f7f6;
  }
  .tablet-bg-layer[data-bg="stock"]::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 55% at 75% 20%, rgba(26,138,118,0.07) 0%, transparent 65%),
      radial-gradient(ellipse 50% 45% at 15% 75%, rgba(22,112,95,0.05) 0%, transparent 55%),
      radial-gradient(ellipse 120% 80% at 50% 100%, rgba(26,138,118,0.03) 0%, transparent 50%);
  }
  .tablet-bg-layer[data-bg="stock"]::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='240' height='208' viewBox='0 0 240 208' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='rgba(0,0,0,0.035)' stroke-width='0.5'%3E%3Ccircle cx='60' cy='104' r='30'/%3E%3Ccircle cx='90' cy='52' r='30'/%3E%3Ccircle cx='150' cy='52' r='30'/%3E%3Ccircle cx='180' cy='104' r='30'/%3E%3Ccircle cx='150' cy='156' r='30'/%3E%3Ccircle cx='90' cy='156' r='30'/%3E%3Ccircle cx='120' cy='104' r='30'/%3E%3Ccircle cx='120' cy='52' r='30'/%3E%3Ccircle cx='60' cy='52' r='30'/%3E%3Ccircle cx='180' cy='52' r='30'/%3E%3Ccircle cx='180' cy='156' r='30'/%3E%3Ccircle cx='120' cy='156' r='30'/%3E%3Ccircle cx='60' cy='156' r='30'/%3E%3C/g%3E%3C/svg%3E");
    background-size: 240px 208px;
    opacity: 0.5;
  }

  /* ── CRM — Soft warm white with amber glow + Metatron's Cube ── */
  .tablet-bg-layer[data-bg="crm"] {
    background: #f7f5f3;
  }
  .tablet-bg-layer[data-bg="crm"]::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 65% 50% at 20% 25%, rgba(212,149,46,0.07) 0%, transparent 65%),
      radial-gradient(ellipse 55% 40% at 80% 75%, rgba(184,125,36,0.05) 0%, transparent 55%),
      radial-gradient(ellipse 120% 80% at 50% 100%, rgba(212,149,46,0.03) 0%, transparent 50%);
  }
  .tablet-bg-layer[data-bg="crm"]::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='260' height='260' viewBox='0 0 260 260' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='rgba(0,0,0,0.03)' stroke-width='0.5'%3E%3Ccircle cx='130' cy='130' r='60'/%3E%3Ccircle cx='130' cy='70' r='30'/%3E%3Ccircle cx='182' cy='100' r='30'/%3E%3Ccircle cx='182' cy='160' r='30'/%3E%3Ccircle cx='130' cy='190' r='30'/%3E%3Ccircle cx='78' cy='160' r='30'/%3E%3Ccircle cx='78' cy='100' r='30'/%3E%3Cline x1='130' y1='70' x2='182' y2='100'/%3E%3Cline x1='182' y1='100' x2='182' y2='160'/%3E%3Cline x1='182' y1='160' x2='130' y2='190'/%3E%3Cline x1='130' y1='190' x2='78' y2='160'/%3E%3Cline x1='78' y1='160' x2='78' y2='100'/%3E%3Cline x1='78' y1='100' x2='130' y2='70'/%3E%3Cline x1='130' y1='70' x2='182' y2='160'/%3E%3Cline x1='182' y1='100' x2='78' y2='160'/%3E%3Cline x1='182' y1='160' x2='78' y2='100'/%3E%3Cline x1='130' y1='190' x2='130' y2='70'/%3E%3Cline x1='78' y1='100' x2='182' y2='160'/%3E%3Cline x1='78' y1='160' x2='182' y2='100'/%3E%3C/g%3E%3C/svg%3E");
    background-size: 260px 260px;
    opacity: 0.4;
  }

  /* ── AI — Cool light gray with violet glow + Sri Yantra ── */
  .tablet-bg-layer[data-bg="ai"] {
    background: #f5f4f7;
  }
  .tablet-bg-layer[data-bg="ai"]::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 75% 55% at 70% 15%, rgba(91,44,142,0.07) 0%, transparent 65%),
      radial-gradient(ellipse 55% 45% at 20% 80%, rgba(120,60,180,0.05) 0%, transparent 55%),
      radial-gradient(ellipse 120% 80% at 50% 100%, rgba(91,44,142,0.03) 0%, transparent 50%);
  }
  .tablet-bg-layer[data-bg="ai"]::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='280' height='280' viewBox='0 0 280 280' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='rgba(0,0,0,0.03)' stroke-width='0.5'%3E%3Ccircle cx='140' cy='140' r='80'/%3E%3Ccircle cx='140' cy='140' r='55'/%3E%3Ccircle cx='140' cy='140' r='30'/%3E%3Cpolygon points='140,60 210,180 70,180'/%3E%3Cpolygon points='140,220 70,100 210,100'/%3E%3Cpolygon points='140,80 195,165 85,165'/%3E%3Cpolygon points='140,200 85,115 195,115'/%3E%3C/g%3E%3C/svg%3E");
    background-size: 280px 280px;
    opacity: 0.4;
  }

  .tablet-section-header {
    position: relative;
    z-index: 2;
    text-align: center;
    margin-bottom: clamp(12px, 1.5vw, 20px);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .tablet-section-eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(0,0,0,0.4);
  }

  .tablet-section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 800;
    color: #1d1d1f;
    letter-spacing: -0.04em;
    line-height: 1;
    transition: color 0.5s ease, opacity 0.2s ease;
  }
  .tablet-section-title.is-changing,
  .tablet-section-subtitle.is-changing {
    opacity: 0;
  }

  .tablet-section-subtitle {
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    font-weight: 400;
    color: rgba(0, 0, 0, 0.55);
    margin: 4px 0 0;
    line-height: 1.4;
    transition: opacity 0.2s ease;
  }

  /* light-bg overrides no longer needed — section is always light */

  .tablet-section-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary, #4B7BE5);
    border: 1.5px solid var(--color-primary, #4B7BE5);
    background: none;
    padding: 10px 24px;
    border-radius: var(--radius-full, 50px);
    text-decoration: none;
    transition: all 0.3s ease;
    letter-spacing: 0.02em;
  }

  .tablet-section-cta:hover {
    background: rgba(75,123,229,0.06);
    border-color: var(--color-primary, #4B7BE5);
    gap: 12px;
  }

  /* ── 2-column layout: sidebar accordion | iPad ── */
  .tablet-3col {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
    width: 100%;
  }

  @media (min-width: 1200px) {
    .tablet-3col {
      flex-direction: row;
      align-items: flex-start;
      justify-content: center;
      gap: var(--space-6);
      padding-inline: var(--space-4);
    }
  }

  /* ── Left: vertical pills (accordion único) ── */
  .tablet-pills-col {
    display: none;
    flex-direction: column;
    gap: 4px;
    flex-shrink: 0;
    width: 240px;
    min-height: 360px; /* reserva alto del pilar más alto (Vende = 4 subs) — evita layout shift */
    padding-top: 8px;
  }

  @media (min-width: 1200px) {
    .tablet-pills-col { display: flex; }
  }

  .tablet-vpill {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border: none;
    background: transparent;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.25s ease;
    width: 100%;
  }

  .tablet-vpill:hover {
    background: rgba(0,0,0,0.04);
  }

  .tablet-vpill.active {
    background: transparent;
  }

  .tablet-vpill-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #e5e5e9;
    color: rgba(0,0,0,0.45);
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
    transition: all 0.25s ease;
  }

  .tablet-vpill.active .tablet-vpill-num {
    background: var(--color-primary, #4B7BE5);
    color: #fff;
  }

  .tablet-vpill-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgba(0,0,0,0.45);
    transition: color 0.25s ease;
    flex: 1;
    text-align: left;
  }

  .tablet-vpill.active .tablet-vpill-label {
    color: #1a1a2e;
  }

  .tablet-vpill-chevron {
    color: rgba(0,0,0,0.3);
    flex-shrink: 0;
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1), color 0.25s ease;
  }

  .tablet-vpill.active .tablet-vpill-chevron {
    color: #1a1a2e;
    transform: rotate(90deg);
  }

  /* ── Sub-items inside step groups (collapsible accordion) ── */
  .tablet-step-group {
    display: flex;
    flex-direction: column;
  }

  .tablet-sub-list {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-left: 38px;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      max-height 0.32s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.24s ease;
  }

  .tablet-step-group.is-open .tablet-sub-list {
    max-height: 280px;
    opacity: 1;
  }

  /* Sliding dot indicator that travels between active sublinks */
  .tablet-sub-indicator {
    position: absolute;
    left: 24px;
    top: 14px; /* aligns with first sub-pill text baseline */
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary, #4B7BE5);
    opacity: 0;
    transform: translateY(0);
    transition:
      transform 0.28s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.2s ease;
    pointer-events: none;
  }

  .tablet-step-group.is-open .tablet-sub-indicator {
    opacity: 1;
  }

  .tablet-sub-pill {
    display: block;
    position: relative;
    text-align: left;
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgba(0,0,0,0.42);
    padding: 6px 10px;
    border: none;
    background: transparent;
    border-radius: 6px;
    cursor: pointer;
    transition: color 0.2s ease;
    white-space: normal;
    line-height: 1.3;
  }

  /* Ghost dot on hover (anticipates click) */
  .tablet-sub-pill::before {
    content: '';
    position: absolute;
    left: -14px;
    top: 50%;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary, #4B7BE5);
    opacity: 0;
    transform: translateY(-50%);
    transition: opacity 0.18s ease;
    pointer-events: none;
  }

  .tablet-sub-pill:hover {
    color: #1a1a2e;
  }

  .tablet-sub-pill:hover::before {
    opacity: 0.3;
  }

  .tablet-sub-pill.active {
    color: #1a1a2e;
    font-weight: 600;
  }

  /* ── Info block: label + desc + CTA centrados bajo el iPad ── */
  .tablet-info-block {
    position: relative;
    z-index: 2;
    margin: clamp(12px, 2vw, 20px) auto 0;
    max-width: 540px;
    text-align: center;
    min-height: 100px; /* reserva para evitar layout shift entre subs */
    padding-inline: var(--space-4);
  }

  .tablet-info {
    position: absolute;
    inset: 0;
    padding-inline: inherit;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.24s ease, transform 0.24s ease;
    pointer-events: none;
  }

  .tablet-info.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    transition-delay: 0.1s; /* cascada coordinada con el slide del iPad */
  }

  .tablet-info-label {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1a1a2e;
    letter-spacing: -0.01em;
    margin: 0 0 6px;
  }

  .tablet-info-desc {
    color: rgba(26, 26, 46, 0.6);
    font-size: 0.9375rem;
    line-height: 1.5;
    margin: 0;
  }

  .tablet-info-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 12px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary, #4B7BE5);
    text-decoration: none;
    transition: gap 0.2s ease;
  }

  .tablet-info-cta:hover {
    gap: 10px;
    text-decoration: none;
  }

  /* ── prefers-reduced-motion: kill the polish, keep the function ── */
  @media (prefers-reduced-motion: reduce) {
    .tablet-sub-list,
    .tablet-sub-indicator,
    .tablet-vpill-chevron,
    .tablet-info,
    .tablet-section-title,
    .tablet-section-subtitle,
    .pillar-acc-body,
    .pillar-acc-label,
    .pillar-acc-icon,
    .pillar-acc-icon::before,
    .pillar-acc-icon::after,
    .pillar-acc-cta,
    .pillar-acc-cta::after,
    .tablet-slide {
      transition: none !important;
    }
    .tablet-info {
      transform: none !important;
    }
  }

  /* ════ 4 Pillar Sections — Apple-level scroll choreography ════ */
  .pillar-section {
    position: relative;
    padding: clamp(72px, 10vw, 144px) 0;
    overflow: hidden;
    --center-distance: 0;
    --reveal-progress: 0;
  }
  /* Palette: Apple-inspired pillar rhythm
     Vende       → off-white frío (#FBFBFD) — open, energético
     Controla    → near-black (#1D1D1F) — control = autoridad visual
     Fideliza    → white (#FFFFFF) — humano, claro y limpio
     Automatiza  → soft Squarespace gray (#F5F5F7) con halo azul SACS — futurista calmo */
  .pillar-section--pos    { background: #FBFBFD; }
  .pillar-section--stock  { background: #1D1D1F; color: #fff; }
  .pillar-section--crm    { background: #ffffff; }
  .pillar-section--ai     { background: #F5F5F7; }

  /* Hard cuts between sections — no gradient seams (Apple style) */

  /* Subtle dot patterns: white dots on dark stock, dark dots on gray AI with blue spotlight */
  .pillar-bg-pattern {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
  }
  .pillar-section--stock .pillar-bg-pattern {
    opacity: 1;
    background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.045) 1px, transparent 0);
    background-size: 28px 28px;
  }
  .pillar-section--ai .pillar-bg-pattern {
    opacity: 1;
    background-image:
      radial-gradient(ellipse 60% 50% at 50% 40%, rgba(75, 123, 229, 0.08) 0%, transparent 70%),
      radial-gradient(circle at 1px 1px, rgba(0,0,0,0.045) 1px, transparent 0);
    background-size: auto, 28px 28px;
  }

  .pillar-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(32px, 5vw, 56px);
    align-items: stretch;
    max-width: 1520px;
    margin: 0 auto;
    padding-inline: clamp(20px, 3vw, 40px);
  }
  @media (min-width: 1024px) {
    .pillar-inner {
      grid-template-columns: minmax(360px, 0.82fr) minmax(0, 1.7fr);
      gap: clamp(40px, 5.5vw, 80px);
    }
    /* Zigzag: pillar-section--left flips iPad to the left, text to right */
    .pillar-section--left .pillar-inner {
      grid-template-columns: minmax(0, 1.7fr) minmax(360px, 0.82fr);
    }
    .pillar-section--left .pillar-visual { order: 1; }
    .pillar-section--left .pillar-text   { order: 2; }
  }

  .pillar-text {
    max-width: 540px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .pillar-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.45);
    margin-bottom: 16px;
  }
  .pillar-eyebrow::before {
    content: "";
    width: 24px;
    height: 1px;
    background: currentColor;
    opacity: 0.5;
  }

  .pillar-h2 {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: clamp(2rem, 3.6vw, 3rem);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.03em;
    color: #1D1D1F;
    margin: 0 0 12px;
  }

  .pillar-subtitle {
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    color: rgba(0,0,0,0.55);
    line-height: 1.5;
    margin: 0 0 28px;
    max-width: 480px;
  }

  /* Modern accordion — thin borders, generous spacing, subtle hover */
  .pillar-accordion {
    border-top: 1px solid rgba(0,0,0,0.08);
  }

  .pillar-acc {
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .pillar-acc-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    background: none;
    border: none;
    padding: 20px 0;
    cursor: pointer;
    font: inherit;
    color: inherit;
    text-align: left;
    transition: opacity 0.2s ease;
  }
  .pillar-acc:not(.is-open) .pillar-acc-btn:hover .pillar-acc-label {
    transform: translateX(4px);
  }
  .pillar-acc:not(.is-open) .pillar-acc-btn:hover .pillar-acc-icon {
    color: #0a0a0a;
  }

  .pillar-acc-label {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: clamp(1.0625rem, 1.4vw, 1.25rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: #0a0a0a;
    line-height: 1.25;
    transition: transform 0.28s cubic-bezier(0.4,0,0.2,1);
    transform-origin: left center;
    display: inline-block;
  }
  .pillar-acc.is-open .pillar-acc-label {
    color: #0a0a0a;
  }

  /* Refined +/− icon: two strokes, the vertical fades+rotates */
  .pillar-acc-icon {
    position: relative;
    width: 24px;
    height: 24px;
    color: rgba(0,0,0,0.5);
    flex-shrink: 0;
    transition: color 0.2s ease;
  }
  .pillar-acc-icon::before,
  .pillar-acc-icon::after {
    content: "";
    position: absolute;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.32s cubic-bezier(0.4,0,0.2,1), opacity 0.24s ease;
  }
  .pillar-acc-icon::before {
    /* horizontal bar */
    top: 50%; left: 0; right: 0;
    height: 1.5px;
    transform: translateY(-50%);
  }
  .pillar-acc-icon::after {
    /* vertical bar */
    left: 50%; top: 0; bottom: 0;
    width: 1.5px;
    transform: translateX(-50%);
  }
  .pillar-acc.is-open .pillar-acc-icon::after {
    transform: translateX(-50%) rotate(90deg);
    opacity: 0;
  }
  /* Hide the old SVG—we now draw the icon in CSS */
  .pillar-acc-icon .acc-v,
  .pillar-acc-icon .acc-h {
    display: none;
  }

  .pillar-acc-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4,0,0.2,1);
  }
  .pillar-acc.is-open .pillar-acc-body {
    max-height: 280px;
  }

  .pillar-acc-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgba(0,0,0,0.62);
    margin: 0 0 14px;
    max-width: 480px;
  }

  .pillar-acc-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #0a0a0a;
    text-decoration: none;
    padding-bottom: 20px;
    position: relative;
    transition: gap 0.24s ease;
  }
  .pillar-acc-cta::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 16px;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform-origin: left;
    transition: transform 0.32s cubic-bezier(0.4,0,0.2,1);
  }
  .pillar-acc-cta:hover {
    gap: 14px;
  }
  .pillar-acc-cta:hover::after {
    transform: scaleX(1.05);
  }

  /* Visual column — dominant, full-height */
  .pillar-visual {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    min-width: 0;
    align-self: stretch;
  }

  .pillar-frame {
    width: 100%;
    max-width: 1180px !important;
    transform: none !important;
    box-shadow: none !important;
    /* Cool-tinted shadow that harmonizes with off-white frío bg of Vende */
    filter: drop-shadow(0 40px 80px rgba(20, 30, 60, 0.13)) drop-shadow(0 16px 32px rgba(20, 30, 60, 0.07));
  }
  /* Heavy dark shadow for Controla on near-black bg */
  .pillar-section--stock .pillar-frame {
    filter: drop-shadow(0 40px 80px rgba(0,0,0,0.55)) drop-shadow(0 16px 32px rgba(0,0,0,0.3));
  }
  /* Automatiza on light gray: standard cool drop-shadow (matches Vende treatment) */
  .pillar-section--ai .pillar-frame {
    filter: drop-shadow(0 40px 80px rgba(20, 30, 60, 0.13)) drop-shadow(0 16px 32px rgba(20, 30, 60, 0.07));
  }

  /* Dark variant — Controla (stock) only */
  .pillar-section--stock .pillar-h2,
  .pillar-section--stock .pillar-acc-label,
  .pillar-section--stock .pillar-acc.is-open .pillar-acc-label,
  .pillar-section--stock .pillar-acc-cta {
    color: #fff;
  }
  .pillar-section--stock .pillar-eyebrow,
  .pillar-section--stock .pillar-acc-icon {
    color: rgba(255,255,255,0.55);
  }
  /* Automatiza eyebrow: SACS blue — único acento de marca en eyebrows */
  .pillar-section--ai .pillar-eyebrow {
    color: rgba(75, 123, 229, 0.9);
  }
  .pillar-section--stock .pillar-subtitle {
    color: rgba(255,255,255,0.6);
  }
  .pillar-section--stock .pillar-acc-desc {
    color: rgba(255,255,255,0.62);
  }
  .pillar-section--stock .pillar-accordion,
  .pillar-section--stock .pillar-acc {
    border-color: rgba(255,255,255,0.12);
  }
  .pillar-section--stock .pillar-acc:not(.is-open) .pillar-acc-btn:hover .pillar-acc-icon {
    color: #fff;
  }

  /* Slide crossfade inside each pillar's iPad */
  .pillar-frame .tablet-slide {
    transition: opacity 0.24s ease;
  }

  /* Hide pillar-sections on mobile (mobile-cards takes over) */
  @media (max-width: 1023px) {
    .pillar-section { display: none; }
    /* Hide desktop continuation sections on mobile — they sit between desktop pillars */
    .sq-features--unified,
    .ops-admin-section { display: none; }
  }

  /* ── Controla continuation: Operación administrativa ── */
  .ops-admin-section {
    position: relative;
    background: #1D1D1F;
    color: #fff;
    padding: clamp(40px, 6vw, 88px) 0 clamp(96px, 12vw, 160px);
    overflow: hidden;
    border: none;
    margin-top: -1px;
  }
  .pillar-section--stock {
    border: none;
  }
  /* Hard cut to crm (white) — no gradient seam */
  /* Subtle dot pattern matching dark stock pillar */
  .ops-admin-section::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.045) 1px, transparent 0);
    background-size: 28px 28px;
    opacity: 0.6;
  }
  .ops-admin-inner {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }
  .ops-admin-header {
    text-align: center;
    max-width: 760px;
    margin: 0 auto clamp(48px, 6vw, 80px);
  }
  .ops-admin-eyebrow {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: clamp(14px, 1.6vw, 22px);
  }
  .ops-admin-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #fff;
    margin: 0 0 clamp(16px, 2vw, 24px);
  }
  .ops-admin-desc {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 auto;
    max-width: 56ch;
  }
  /* Cards float on the dark bg — slightly lifted shade + soft white borders */
  .ops-admin-grid {
    border-top: none;
  }
  .pillar-section--stock .pillar-acc:last-child {
    border-bottom: none;
  }
  .ops-admin-grid .inv-intel-card {
    background: #26262A;
    border: none;
  }
  .ops-admin-grid .inv-intel-card-title {
    color: #fff;
  }
  .ops-admin-grid .inv-intel-card-desc {
    color: rgba(255, 255, 255, 0.62);
  }
  /* Icons on dark bg: full opacity + light strokes, preserving accent colors */
  .ops-admin-grid .inv-intel-card-icon {
    opacity: 1;
  }
  .ops-admin-grid .inv-intel-card-icon svg * {
    stroke: rgba(255, 255, 255, 0.78) !important;
  }
  .ops-admin-grid .inv-intel-card-icon svg [stroke="#2AB5A0"] {
    stroke: #2AB5A0 !important;
  }
  .ops-admin-grid .inv-intel-card-icon svg [stroke="#E8A838"] {
    stroke: #E8A838 !important;
  }
  .ops-admin-grid .inv-intel-card-icon svg text {
    fill: rgba(255, 255, 255, 0.85) !important;
  }

  /* Reveal coreografiado del header */
  @media (prefers-reduced-motion: no-preference) {
    .ops-admin-eyebrow,
    .ops-admin-title,
    .ops-admin-desc {
      opacity: 0;
      transform: translateY(20px);
      transition:
        opacity 700ms cubic-bezier(0.16, 1, 0.3, 1),
        transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .ops-admin-section.is-entering .ops-admin-eyebrow { opacity: 1; transform: none; transition-delay: 0ms; }
    .ops-admin-section.is-entering .ops-admin-title   { opacity: 1; transform: none; transition-delay: 80ms; }
    .ops-admin-section.is-entering .ops-admin-desc    { opacity: 1; transform: none; transition-delay: 180ms; }
  }

  /* ── Fideliza continuation: CRM + marketing relacional ── */
  /* Light Squarespace canvas (#FBFBFD) to flow seamlessly from the white
     Fideliza pillar above. SACS-blue accent for the loyalty/CRM theme. */
  .loyalty-pro-section {
    position: relative;
    background: #FBFBFD;
    color: var(--color-text-primary);
    padding: clamp(40px, 6vw, 88px) 0 clamp(96px, 12vw, 160px);
    overflow: hidden;
    border: none;
    margin-top: -1px;
  }
  /* Soft dot grid in deep blue, very subtle — texture without weight */
  .loyalty-pro-section::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image:
      radial-gradient(circle at 1px 1px, rgba(75, 123, 229, 0.10) 1px, transparent 0);
    background-size: 28px 28px;
    opacity: 0.55;
  }
  /* Subtle indigo halo behind the header for depth */
  .loyalty-pro-section::after {
    content: "";
    position: absolute;
    top: -180px;
    left: 50%;
    transform: translateX(-50%);
    width: min(820px, 92vw);
    height: 420px;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(ellipse at center, rgba(75, 123, 229, 0.10) 0%, transparent 65%);
  }
  @media (max-width: 767px) {
    .loyalty-pro-section::after { display: none; }
  }
  .loyalty-pro-inner {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }
  .loyalty-pro-header {
    text-align: center;
    max-width: 760px;
    margin: 0 auto clamp(48px, 6vw, 80px);
  }
  .loyalty-pro-eyebrow {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #4B7BE5;
    margin-bottom: clamp(14px, 1.6vw, 22px);
  }
  .loyalty-pro-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #1A1A1A;
    margin: 0 0 clamp(16px, 2vw, 24px);
  }
  .loyalty-pro-desc {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    line-height: 1.55;
    color: #5C5C66;
    margin: 0 auto;
    max-width: 60ch;
  }
  /* Cards float on the off-white canvas: white tile + ultra-thin border */
  .loyalty-pro-grid {
    border-top: none;
  }
  .loyalty-pro-grid .inv-intel-card {
    background: #FFFFFF;
    border: 1px solid rgba(20, 20, 30, 0.06);
    border-right: 1px solid rgba(20, 20, 30, 0.06);
    border-bottom: 1px solid rgba(20, 20, 30, 0.06);
    transition:
      box-shadow 0.25s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.25s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .loyalty-pro-grid .inv-intel-card:hover {
    box-shadow: 0 6px 22px -8px rgba(75, 123, 229, 0.18);
    transform: translateY(-2px);
  }
  .loyalty-pro-grid .inv-intel-card-title {
    color: #1A1A1A;
  }
  .loyalty-pro-grid .inv-intel-card-desc {
    color: #5C5C66;
  }
  .loyalty-pro-grid .inv-intel-card-icon {
    opacity: 1;
    margin-bottom: 22px;
  }
  .loyalty-pro-grid .inv-intel-card-icon svg {
    width: 30px;
    height: 30px;
  }
  /* Light-canvas icons: deep gray base + SACS-blue accent */
  .loyalty-pro-grid .inv-intel-card-icon svg * {
    stroke: #1A1A1A !important;
    fill: none !important;
  }
  .loyalty-pro-grid .inv-intel-card-icon svg [stroke="#4B7BE5"] {
    stroke: #4B7BE5 !important;
  }
  .loyalty-pro-grid .inv-intel-card-icon svg [fill="#4B7BE5"] {
    fill: #4B7BE5 !important;
  }
  .loyalty-pro-grid .inv-intel-card-icon svg text {
    fill: #1A1A1A !important;
  }

  /* Reveal coreografiado del header — same timing as ops-admin */
  @media (prefers-reduced-motion: no-preference) {
    .loyalty-pro-eyebrow,
    .loyalty-pro-title,
    .loyalty-pro-desc {
      opacity: 0;
      transform: translateY(20px);
      transition:
        opacity 700ms cubic-bezier(0.16, 1, 0.3, 1),
        transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .loyalty-pro-section.is-entering .loyalty-pro-eyebrow { opacity: 1; transform: none; transition-delay: 0ms; }
    .loyalty-pro-section.is-entering .loyalty-pro-title   { opacity: 1; transform: none; transition-delay: 80ms; }
    .loyalty-pro-section.is-entering .loyalty-pro-desc    { opacity: 1; transform: none; transition-delay: 180ms; }
  }

  /* Mobile: hide on small screens to match the ops-admin pattern (cards live inside mobile flow) */
  @media (max-width: 767px) {
    .loyalty-pro-section {
      padding: clamp(48px, 8vw, 72px) 0 clamp(48px, 8vw, 72px);
    }
    .loyalty-pro-section::before { background-size: 22px 22px; }
  }

  /* ── Unified WhatsApp Commerce (continuation of pos pillar) ── */
  /* Removes the hard border-top so it flows seamlessly from white pos pillar.
     Adds a soft gradient seam at bottom that fades into stock pillar's gray. */
  .sq-features--unified {
    position: relative;
    border-top: none !important;
    background: #FBFBFD;
    padding-top: 0;
  }
  .sq-features--unified .sq-features-header {
    padding-top: clamp(8px, 2vw, 32px);
    padding-bottom: clamp(40px, 6vw, 72px);
  }
  /* Hard cut into Controla's near-black — no gradient seam */
  .sq-features--unified .sq-features-inner {
    position: relative;
    z-index: 1;
    padding-bottom: clamp(60px, 8vw, 120px);
  }

  /* ════ Apple-level scroll choreography ════ */
  @media (prefers-reduced-motion: no-preference) and (min-width: 1024px) {
    /* Initial state — content hidden, ready to reveal */
    .pillar-eyebrow,
    .pillar-h2,
    .pillar-subtitle,
    .pillar-acc {
      opacity: 0;
      transform: translateY(28px);
      transition:
        opacity 700ms cubic-bezier(0.16, 1, 0.3, 1),
        transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
      will-change: opacity, transform;
    }

    .pillar-section--right .pillar-frame {
      opacity: 0;
      transform: translateX(56px) translateY(40px) scale(0.96);
      transition:
        opacity 900ms cubic-bezier(0.16, 1, 0.3, 1),
        transform 900ms cubic-bezier(0.16, 1, 0.3, 1);
      will-change: opacity, transform;
    }
    .pillar-section--left .pillar-frame {
      opacity: 0;
      transform: translateX(-56px) translateY(40px) scale(0.96);
      transition:
        opacity 900ms cubic-bezier(0.16, 1, 0.3, 1),
        transform 900ms cubic-bezier(0.16, 1, 0.3, 1);
      will-change: opacity, transform;
    }

    /* Reveal sequence — staggered choreography */
    .pillar-section.is-entering .pillar-eyebrow {
      opacity: 1; transform: none;
      transition-delay: 0ms;
    }
    .pillar-section.is-entering .pillar-h2 {
      opacity: 1; transform: none;
      transition-delay: 80ms;
    }
    .pillar-section.is-entering .pillar-subtitle {
      opacity: 1; transform: none;
      transition-delay: 220ms;
    }
    .pillar-section.is-entering .pillar-acc {
      opacity: 1; transform: none;
      transition-delay: calc(320ms + var(--i, 0) * 70ms);
    }
    .pillar-section.is-entering .pillar-frame {
      opacity: 1; transform: none;
      transition-delay: 180ms;
    }

    /* Parallax + 3D tilt — driven by --center-distance (-1..1) */
    .pillar-section.is-active .pillar-frame {
      transform:
        translateY(calc(var(--center-distance) * -22px))
        perspective(1600px)
        rotateY(calc(var(--center-distance) * 3deg))
        rotateX(calc(var(--center-distance) * -1.5deg));
      transition: none;
    }
    .pillar-section--left.is-active .pillar-frame {
      transform:
        translateY(calc(var(--center-distance) * -22px))
        perspective(1600px)
        rotateY(calc(var(--center-distance) * -3deg))
        rotateX(calc(var(--center-distance) * -1.5deg));
    }

    /* Subtle bg-pattern parallax — opposite direction for depth */
    .pillar-section.is-active .pillar-bg-pattern {
      transform: translateY(calc(var(--center-distance) * 16px));
      transition: none;
    }

    /* Background tinting — body dims as AI section enters */
    body.is-cinema {
      transition: background-color 700ms cubic-bezier(0.65, 0, 0.35, 1);
    }
  }

  /* ── AI pillar special treatment — spotlight + breathing ── */
  .pillar-section--ai .pillar-frame {
    box-shadow: none !important;
  }
  .pillar-section--ai.is-revealed .pillar-frame {
    filter:
      drop-shadow(0 0 140px rgba(120, 180, 255, 0.10))
      drop-shadow(0 50px 90px rgba(0,0,0,0.7))
      drop-shadow(0 16px 32px rgba(0,0,0,0.4));
    transition: filter 1100ms cubic-bezier(0.65, 0, 0.35, 1);
  }

  @keyframes pillar-breathe {
    0%, 100% { filter: brightness(1); }
    50%      { filter: brightness(1.07); }
  }
  @media (prefers-reduced-motion: no-preference) {
    .pillar-section--ai.is-revealed .tablet-slide.active {
      animation: pillar-breathe 3.2s ease-in-out infinite;
    }
  }

  /* light-bg eyebrow override no longer needed */

