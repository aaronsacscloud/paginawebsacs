  /* ═══════════════════════════════════════════
     SMALL MOBILE — max-width: 399px (iPhone SE)
     ═══════════════════════════════════════════ */
  @media (max-width: 399px) {
    .hero-title {
      font-size: 1.875rem;
    }

    .hero-badges {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3, 0.75rem);
    }

    .zt-text {
      font-size: 1.375rem;
    }

    .sc-title {
      font-size: 1.5rem;
    }

    .inv-intel-title {
      font-size: 1.5rem;
    }

    .htv2-title {
      font-size: 1.375rem;
    }

    .reels-title {
      font-size: 1.2rem;
    }

    .section-cta {
      font-size: 0.9375rem;
      padding: 14px 24px;
    }

    .mc-step-title {
      font-size: 1.2rem;
    }

    .mc-card {
      flex: 0 0 90%;
    }
