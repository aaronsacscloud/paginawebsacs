    font-size: 12px;
    letter-spacing: 0.18em;
    color: #1A1A1A;
  }
  .ec-nav-links {
    display: flex;
    gap: 14px;
    font-size: 8px;
    font-weight: 600;
    color: rgba(0,0,0,0.7);
    letter-spacing: 0.04em;
  }
  .ec-nav-icons {
    display: flex;
    gap: 8px;
    font-size: 11px;
    color: rgba(0,0,0,0.7);
  }
  .ec-cart-ic { position: relative; }

  .ec-hero {
    flex-shrink: 0;
    width: 100%;
    height: 360px;
    position: relative;
    color: #fff;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 22px 30px 24px;
    overflow: hidden;
  }
  .ec-hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/recomendaciones-productos.webp');
    background-size: cover;
    background-position: center 25%;
    transform: scale(1.05);
    animation: ec-hero-zoom 14s ease-out infinite;
  }
  @keyframes ec-hero-zoom {
    0%   { transform: scale(1.05); }
    8%   { transform: scale(1.12); }
    30%  { transform: scale(1.05); }
    100% { transform: scale(1.05); }
  }
  .ec-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(20,20,30,0.0) 0%, rgba(20,20,30,0.3) 60%, rgba(20,20,30,0.7) 100%);
  }
  .ec-hero-eyebrow {
    position: relative;
    font-family: var(--font-display);
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.32em;
    color: rgba(255,255,255,0.85);
    margin-bottom: 8px;
  }
  .ec-hero-title {
    position: relative;
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: 14px;
    max-width: 70%;
  }
  .ec-hero-cta {
    position: relative;
    display: flex;
    gap: 8px;
  }
  .ec-hero-btn {
    padding: 9px 18px;
    font-family: var(--font-display);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.06em;
    background: rgba(255,255,255,0.12);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: 999px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .ec-hero-btn--primary {
    background: #fff;
    color: #1A1A1A;
    border-color: #fff;
  }
  .ec-hero-scroll-cue {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 8px;
    color: rgba(255,255,255,0.7);
    font-weight: 600;
    letter-spacing: 0.1em;
    animation: ec-scroll-bounce 1.4s ease-in-out infinite;
  }
  @keyframes ec-scroll-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); opacity: 0.7; }
    50%      { transform: translateX(-50%) translateY(-3px); opacity: 1; }
  }

  /* Below-fold sections */
  .ec-section {
    flex-shrink: 0;
    padding: 28px 30px 22px;
    background: #fff;
  }
  .ec-section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 16px;
  }
  .ec-section-eyebrow {
    font-family: var(--font-display);
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.32em;
    color: rgba(0,0,0,0.55);
    margin-bottom: 4px;
  }
  .ec-section-title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
    line-height: 1.15;
  }
  .ec-section-link {
    font-size: 9px;
    font-weight: 700;
    color: #1A1A1A;
    text-decoration: underline;
    text-underline-offset: 3px;
    letter-spacing: 0.04em;
  }
  .ec-best-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .ec-best { display: flex; flex-direction: column; gap: 4px; }
  .ec-best-img {
    aspect-ratio: 4/5;
    background: #F2F1EE;
    overflow: hidden;
    border-radius: 4px;
    margin-bottom: 6px;
  }
  .ec-best-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ec-best-name {
    font-size: 9px;
    font-weight: 700;
    color: #1A1A1A;
  }
  .ec-best-meta {
    font-size: 7px;
    color: rgba(0,0,0,0.5);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }
  .ec-best-price {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    color: #1A1A1A;
    margin-top: 2px;
  }

  .ec-story {
    flex-shrink: 0;
    background: #1A1A1A;
    color: #fff;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    min-height: 220px;
  }
  .ec-story-img { height: 100%; overflow: hidden; }
  .ec-story-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ec-story-body {
    padding: 30px 36px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .ec-story-eyebrow {
    font-family: var(--font-display);
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.32em;
    color: rgba(255,255,255,0.55);
    margin-bottom: 4px;
  }
  .ec-story-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: 8px;
  }
  .ec-story-text {
    font-size: 10px;
    line-height: 1.5;
    color: rgba(255,255,255,0.7);
    margin-bottom: 8px;
  }
  .ec-story-link {
    font-size: 9px;
    font-weight: 700;
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 3px;
    letter-spacing: 0.04em;
    width: fit-content;
  }

  .ec-look {
    flex-shrink: 0;
    padding: 28px 30px 32px;
    background: #FAFAFA;
  }
  .ec-look-head { margin-bottom: 14px; }
  .ec-look-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 10px;
    height: 220px;
  }
  .ec-look-tile {
    overflow: hidden;
    border-radius: 6px;
    background: #F2F1EE;
  }
  .ec-look-tile img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ec-look-tile--lg { grid-row: 1; }
  .ec-look-col {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 10px;
  }

  /* ─── Layer: CATÁLOGO ─── */
  .ec-catalog-head {
    text-align: center;
    padding: 14px 0 8px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .ec-catalog-title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .ec-catalog-meta {
    font-size: 8px;
    color: rgba(0,0,0,0.55);
    margin-top: 2px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .ec-grid {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    padding: 14px 18px;
  }
  .ec-prod {
    background: #fff;
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: transform 0.3s ease;
  }
  .ec-prod-img {
    aspect-ratio: 4/5;
    background: #F2F1EE;
    overflow: hidden;
  }
  .ec-prod-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ec-prod-name {
    font-size: 8px;
    font-weight: 700;
    color: #1A1A1A;
    padding: 5px 8px 1px;
  }
  .ec-prod-price {
    font-family: var(--font-display);
    font-size: 9px;
    font-weight: 700;
    color: #1A1A1A;
    padding: 0 8px 6px;
  }
  .ec-prod-add {
    position: absolute;
    inset: auto 0 0 0;
    background: #1A1A1A;
    color: #fff;
    text-align: center;
    padding: 6px;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.04em;
    transform: translateY(100%);
    animation: ec-add-show 14s ease-in-out infinite;
  }
  @keyframes ec-add-show {
    0%, 25%   { transform: translateY(100%); }
    27%, 30%  { transform: translateY(0); }
    32%, 100% { transform: translateY(100%); }
  }
  .ec-prod--target {
    animation: ec-prod-pulse 14s ease-in-out infinite;
  }
  @keyframes ec-prod-pulse {
    0%, 22%   { box-shadow: 0 0 0 0 rgba(42,181,160,0); transform: scale(1); }
    24%, 28%  { box-shadow: 0 0 0 4px rgba(42,181,160,0.25); transform: scale(1.03); }
    30%, 100% { box-shadow: 0 0 0 0 rgba(42,181,160,0); transform: scale(1); }
  }

  /* ─── Layer: CART DRAWER ─── */
  .ec-cart-overlay {
    position: absolute;
    inset: 0;
    background: rgba(20,20,30,0.30);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }
  .ec-cart-drawer {
    position: absolute;
    top: 0; bottom: 0; right: 0;
    width: 38%;
    background: #fff;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    box-shadow: -10px 0 30px -8px rgba(20,20,30,0.18);
  }
  .ec-cart-head {
    display: flex;
    align-items: center;
    gap: 8px;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .ec-cart-title {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 800;
    color: #1A1A1A;
  }
  .ec-cart-count {
    font-size: 8px;
    color: rgba(0,0,0,0.55);
    flex: 1;
  }
  .ec-cart-close {
    font-size: 14px;
    color: rgba(0,0,0,0.55);
    line-height: 1;
  }
  .ec-cart-item {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .ec-cart-item img {
    width: 60px;
    height: 76px;
    object-fit: cover;
    border-radius: 4px;
    background: #F2F1EE;
  }
  .ec-cart-name {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .ec-cart-meta {
    font-size: 7.5px;
    color: rgba(0,0,0,0.55);
    margin-top: 2px;
  }
  .ec-cart-price {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 800;
    color: #1A1A1A;
    margin-top: 4px;
  }
  .ec-cart-totals {
    display: flex;
    flex-direction: column;
    gap: 3px;
    margin-top: auto;
  }
  .ec-cart-row {
    display: flex;
    justify-content: space-between;
    font-size: 9px;
    color: rgba(0,0,0,0.7);
  }
  .ec-cart-row span:last-child { font-weight: 700; color: #1A1A1A; }
  .ec-cart-row--small { font-size: 8px; color: rgba(0,0,0,0.5); }
  .ec-cart-row--total {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 800;
    border-top: 1px solid rgba(0,0,0,0.08);
    padding-top: 6px;
    margin-top: 4px;
  }
  .ec-cart-cta {
    background: #1A1A1A;
    color: #fff;
    text-align: center;
    padding: 10px;
    font-family: var(--font-display);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.06em;
    border-radius: 6px;
  }
  .ec-cart-secure {
    text-align: center;
    font-size: 7px;
    color: rgba(0,0,0,0.5);
  }

  /* ─── Layer: CHECKOUT (Shopify-style) ─── */
  .ec-checkout-grid {
    flex: 1;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    height: 100%;
    background: #fff;
  }
  .ec-checkout-form {
    padding: 14px 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow: hidden;
  }
  .ec-checkout-step {
    font-family: var(--font-display);
    font-size: 9px;
    font-weight: 800;
    color: #1A1A1A;
    margin-top: 6px;
    letter-spacing: 0.04em;
  }
  .ec-checkout-step:first-child { margin-top: 0; }
  .ec-checkout-input {
    background: #FAFAFA;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 5px;
    padding: 6px 10px;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .ec-checkout-label {
    font-size: 6.5px;
    color: rgba(0,0,0,0.5);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }
  .ec-checkout-val {
    font-size: 9px;
    color: #1A1A1A;
    font-weight: 600;
  }
  .ec-checkout-shipping { display: flex; flex-direction: column; gap: 4px; }
  .ec-ship {
    display: grid;
    grid-template-columns: 14px 1fr auto;
    align-items: center;
    gap: 8px;
    background: #FAFAFA;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 5px;
    padding: 6px 10px;
    font-size: 8.5px;
  }
  .ec-ship--active {
    border-color: #1A1A1A;
    background: #fff;
  }
  .ec-ship-radio {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #1A1A1A;
    box-shadow: inset 0 0 0 2px #fff;
  }
  .ec-ship-radio--off {
    background: transparent;
    border: 1px solid rgba(0,0,0,0.22);
    box-shadow: none;
  }
  .ec-ship-name { color: #1A1A1A; font-weight: 600; }
  .ec-ship-price { font-weight: 700; color: #1A1A1A; }

  .ec-pay-tabs { display: flex; gap: 4px; }
  .ec-pay-tab {
    flex: 1;
    text-align: center;
    padding: 5px 6px;
    font-size: 8px;
    font-weight: 700;
    color: rgba(0,0,0,0.55);
    background: #FAFAFA;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 5px;
  }
  .ec-pay-tab--active {
    background: #1A1A1A;
    color: #fff;
    border-color: #1A1A1A;
  }
  .ec-pay-card {
    background: #FAFAFA;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 5px;
    padding: 7px 10px;
  }
  .ec-pay-card-num {
    font-family: 'SF Mono', 'Menlo', monospace;
    font-size: 10px;
    font-weight: 700;
    color: #1A1A1A;
    letter-spacing: 0.08em;
    margin-bottom: 3px;
  }
  .ec-pay-card-row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 7.5px;
    color: rgba(0,0,0,0.55);
    font-weight: 600;
  }
  .ec-pay-card-brand {
    margin-left: auto;
    background: #1A1F71;
    color: #fff;
    padding: 1px 5px;
    border-radius: 2px;
    font-family: var(--font-display);
    font-size: 8px;
    font-weight: 800;
    letter-spacing: 0.04em;
  }
  .ec-checkout-confirm {
    margin-top: auto;
    background: #1A1A1A;
    color: #fff;
    text-align: center;
    padding: 10px;
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    border-radius: 6px;
  }

  .ec-checkout-summary {
    background: #FAFAFA;
    border-left: 1px solid rgba(0,0,0,0.06);
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ec-checkout-summary-title {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(0,0,0,0.55);
  }
  .ec-summary-item {
    display: grid;
    grid-template-columns: 50px 1fr auto;
    gap: 8px;
    align-items: center;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .ec-summary-item img {
    width: 50px;
    height: 60px;
    object-fit: cover;
    border-radius: 4px;
  }
  .ec-summary-name { font-size: 9px; font-weight: 700; color: #1A1A1A; }
  .ec-summary-meta { font-size: 7px; color: rgba(0,0,0,0.55); }
  .ec-summary-price { font-family: var(--font-display); font-weight: 800; font-size: 10px; }
  .ec-summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 8.5px;
    color: rgba(0,0,0,0.65);
  }
  .ec-summary-row span:last-child { font-weight: 700; color: #1A1A1A; }
  .ec-summary-row--total {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 800;
    border-top: 1px solid rgba(0,0,0,0.08);
    padding-top: 6px;
    margin-top: 4px;
  }

  /* ─── Layer: SUCCESS (mostly seen on mobile) ─── */
  .ec-layer--ok {
    background: #FAFAFA;
    align-items: center;
    justify-content: center;
    padding: 18px;
  }
  .ec-ok-card {
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .ec-ok-check {
    margin-bottom: 8px;
  }
  .ec-ok-check svg { width: 44px; height: 44px; }
  .ec-ok-path {
    stroke-dasharray: 30;
    stroke-dashoffset: 30;
    animation: ec-ok-draw 14s ease-in-out infinite;
  }
  @keyframes ec-ok-draw {
    0%, 76%   { stroke-dashoffset: 30; }
    82%, 100% { stroke-dashoffset: 0; }
  }
  .ec-ok-title {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 800;
    color: #1A1A1A;
    margin-bottom: 4px;
    letter-spacing: -0.01em;
  }
  .ec-ok-num {
    font-family: 'SF Mono', 'Menlo', monospace;
    font-size: 9px;
    color: rgba(0,0,0,0.55);
    margin-bottom: 10px;
    letter-spacing: 0.08em;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    padding: 3px 8px;
    border-radius: 4px;
  }
  .ec-ok-desc {
    font-size: 8px;
    line-height: 1.5;
    color: rgba(0,0,0,0.65);
    margin-bottom: 12px;
    max-width: 80%;
  }
  .ec-ok-stats {
    display: flex;
    gap: 8px;
    width: 100%;
    margin-bottom: 14px;
  }
  .ec-ok-stat {
    flex: 1;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 6px;
    padding: 7px 8px;
    text-align: left;
  }
  .ec-ok-stat-label {
    display: block;
    font-size: 6.5px;
    color: rgba(0,0,0,0.5);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    margin-bottom: 2px;
  }
  .ec-ok-stat-value {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .ec-ok-cta {
    background: #1A1A1A;
    color: #fff;
    padding: 9px 24px;
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  @media (prefers-reduced-motion: reduce) {
    .ec-frame *, .ec-frame ::before, .ec-frame ::after { animation: none !important; }
    .ec-device { width: 96%; height: 92%; }
    .ec-layer--home { opacity: 1; }
    .ec-layer--catalog, .ec-layer--cart, .ec-layer--checkout, .ec-layer--ok { display: none; }
  }

  /* ── Recepción de mercancía — photo intro → phone flow → entry report ── */
  .rec2-frame {
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #0E0E12;
    background-image:
      radial-gradient(ellipse 60% 50% at 30% 50%, rgba(75,123,229,0.10), transparent 65%),
      radial-gradient(circle at 1px 1px, rgba(255,255,255,0.04) 1px, transparent 0);
    background-size: auto, 24px 24px;
    padding: 3% 3.5%;
    overflow: hidden;
    position: relative;
  }

  /* Phone — fixed at LEFT throughout the loop */
  .rec2-phone-wrap {
    position: absolute;
    top: 3%;
    left: 4%;
    width: 26%;
    height: 94%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }
  .rec2-phone {
    width: 100%;
    max-width: 280px;
    aspect-ratio: 9 / 19;
    background: #2A2A2E;
    border-radius: 32px;
    padding: 6px;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.08) inset,
      0 0 0 1px rgba(255,255,255,0.10),
      0 24px 60px -16px rgba(0,0,0,0.55);
    position: relative;
  }
  .rec2-phone-notch {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    width: 28%;
    height: 11px;
    background: #0A0A0C;
    border-radius: 999px;
    z-index: 2;
  }
  .rec2-phone-screen {
    width: 100%;
    height: 100%;
    background: #FAFAFA;
    border-radius: 26px;
    overflow: hidden;
    position: relative;
  }

  /* Layers */
  .rec2-layer {
    position: absolute;
    inset: 0;
    opacity: 0;
    padding: 22px 12px 12px;
    display: flex;
    flex-direction: column;
    font-family: var(--font-body);
    color: #1A1A1A;
  }
  .rec2-layer--xml  { animation: rec2-layer-xml 14s ease-in-out infinite; }
  .rec2-layer--oc   { animation: rec2-layer-oc 14s ease-in-out infinite; }
  .rec2-layer--rcv  { animation: rec2-layer-rcv 14s ease-in-out infinite; }
  .rec2-layer--done { animation: rec2-layer-done 14s ease-in-out infinite; }

  /* Timeline — full loop dedicated to the system flow:
     0-22%   XML upload
     25-47%  OC generated
     50-72%  Receiving (scan)
     75-100% Done */
  @keyframes rec2-layer-xml {
    0%, 22%   { opacity: 1; }
    25%, 100% { opacity: 0; }
  }
  @keyframes rec2-layer-oc {
    0%, 22%   { opacity: 0; }
    25%, 47%  { opacity: 1; }
    50%, 100% { opacity: 0; }
  }
  @keyframes rec2-layer-rcv {
    0%, 47%   { opacity: 0; }
    50%, 72%  { opacity: 1; }
    75%, 100% { opacity: 0; }
  }
  @keyframes rec2-layer-done {
    0%, 72%   { opacity: 0; }
    75%, 100% { opacity: 1; }
  }

  /* Common phone elements */
  .rec2-top {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }
  .rec2-top-back { color: rgba(0,0,0,0.5); font-size: 14px; line-height: 1; }
  .rec2-top-title {
    flex: 1;
    text-align: center;
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    color: #1A1A1A;
  }
  .rec2-top-action,
  .rec2-top-tag,
  .rec2-top-prog {
    font-size: 8px;
    color: rgba(0,0,0,0.55);
    font-weight: 700;
  }
  .rec2-top-tag {
    background: #1A1A1A;
    color: #fff;
    padding: 2px 6px;
    border-radius: 3px;
    letter-spacing: 0.06em;
  }
  .rec2-top-prog {
    font-family: 'SF Mono', 'Menlo', monospace;
    background: rgba(42,181,160,0.12);
    color: #1A8F7A;
    padding: 2px 6px;
    border-radius: 4px;
  }

  /* Layer 1: XML upload */
  .rec2-step-tag {
    font-family: 'SF Mono', 'Menlo', monospace;
    font-size: 7px;
    color: #4B7BE5;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-align: center;
    margin-bottom: 4px;
  }
  .rec2-step-title {
    text-align: center;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 800;
    color: #1A1A1A;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
  }
  .rec2-drop {
    flex: 1;
    border: 2px dashed rgba(0,0,0,0.18);
    border-radius: 10px;
    padding: 14px 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #fff;
    margin-bottom: 8px;
  }
  .rec2-drop-ic {
    width: 50px;
    height: 50px;
    background: rgba(75,123,229,0.10);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 10px;
    animation: rec2-drop-pulse 1.6s ease-in-out infinite;
  }
  @keyframes rec2-drop-pulse {
    0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(75,123,229,0); }
    50%      { transform: scale(1.06); box-shadow: 0 0 0 8px rgba(75,123,229,0.15); }
  }
  .rec2-drop-title {
    font-family: var(--font-display);
    font-size: 9.5px;
    font-weight: 800;
    color: #1A1A1A;
    margin-bottom: 2px;
  }
  .rec2-drop-sub {
    font-size: 7px;
    color: rgba(0,0,0,0.5);
    margin-bottom: 12px;
  }
  .rec2-drop-file {
    width: 100%;
    display: grid;
    grid-template-columns: 28px 1fr 18px;
    gap: 8px;
    align-items: center;
    background: rgba(42,181,160,0.10);
    border: 1px solid rgba(42,181,160,0.25);
    border-radius: 6px;
    padding: 6px 8px;
  }
  .rec2-drop-file-ic {
    width: 28px;
    height: 28px;
    background: #fff;
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4B7BE5;
    font-size: 14px;
    font-weight: 800;
  }
  .rec2-drop-file-name {
    font-size: 8px;
    font-weight: 700;
    color: #1A1A1A;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .rec2-drop-file-meta {
    font-size: 6.5px;
    color: rgba(0,0,0,0.55);
  }
  .rec2-drop-file-ok {
    color: #2AB5A0;
    font-size: 12px;
    font-weight: 800;
    text-align: center;
  }

  .rec2-cta {
    background: #1A1A1A;
    color: #fff;
    text-align: center;
    padding: 9px;
    border-radius: 8px;
    font-family: var(--font-display);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin-top: auto;
  }

  /* Layer 2: OC */
  .rec2-oc-num {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.02em;
    text-align: center;
    margin-bottom: 4px;
  }
  .rec2-oc-supplier {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 8px;
    padding: 7px 10px;
    margin-bottom: 8px;
  }
  .rec2-oc-supplier-ic {
    width: 26px;
    height: 26px;
    background: #1A1A1A;
    color: #fff;
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
  }
  .rec2-oc-supplier-name {
    font-size: 8.5px;
    font-weight: 700;
    color: #1A1A1A;
  }
  .rec2-oc-supplier-rfc {
    font-family: 'SF Mono', 'Menlo', monospace;
    font-size: 6.5px;
    color: rgba(0,0,0,0.55);
    margin-top: 1px;
    letter-spacing: 0.04em;
  }
  .rec2-oc-items { display: flex; flex-direction: column; gap: 4px; margin-bottom: 8px; }
  .rec2-oc-item {
    display: grid;
    grid-template-columns: 28px 1fr auto;
    gap: 8px;
    align-items: center;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 6px;
    padding: 5px 8px;
    animation: rec2-oc-item-in 14s ease-in-out infinite;
  }
  .rec2-oc-item img {
    width: 28px;
    height: 28px;
    border-radius: 4px;
    object-fit: cover;
    background: #F2F1EE;
  }
  .rec2-oc-item-name { font-size: 8px; font-weight: 700; color: #1A1A1A; }
  .rec2-oc-item-sku {
    font-family: 'SF Mono', 'Menlo', monospace;
    font-size: 6.5px;
    color: rgba(0,0,0,0.5);
  }
  .rec2-oc-item-qty {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 800;
    color: #1A1A1A;
  }
  .rec2-oc-item:nth-child(1) { animation-delay: 0s; }
  .rec2-oc-item:nth-child(2) { animation-delay: 0.15s; }
  .rec2-oc-item:nth-child(3) { animation-delay: 0.30s; }
  @keyframes rec2-oc-item-in {
    0%, 25%   { opacity: 0; transform: translateY(6px); }
    28%, 100% { opacity: 1; transform: translateY(0); }
  }
  .rec2-oc-totals {
    background: #FAFAFA;
    border-radius: 6px;
    padding: 7px 10px;
    margin-bottom: 8px;
  }
  .rec2-oc-total-row {
    display: flex;
    justify-content: space-between;
    font-size: 8px;
    color: rgba(0,0,0,0.6);
    padding: 1px 0;
  }
  .rec2-oc-total-row span:last-child { color: #1A1A1A; font-weight: 700; }
  .rec2-oc-total-row--small { font-size: 7px; color: rgba(0,0,0,0.45); }
  .rec2-oc-total-row--grand {
    border-top: 1px solid rgba(0,0,0,0.08);
    padding-top: 4px;
    margin-top: 3px;
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 800;
  }

  /* Layer 3: Receiving */
  .rec2-scan-vf {
    width: 70%;
    aspect-ratio: 1;
    align-self: center;
    position: relative;
    background: #1A1A1A;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  .rec2-vf-c {
    position: absolute;
    width: 18px;
    height: 18px;
    border-color: #2AB5A0;
    border-style: solid;
    border-width: 0;
  }
  .rec2-vf-tl { top: 6px; left: 6px; border-top-width: 2.5px; border-left-width: 2.5px; border-top-left-radius: 4px; }
  .rec2-vf-tr { top: 6px; right: 6px; border-top-width: 2.5px; border-right-width: 2.5px; border-top-right-radius: 4px; }
  .rec2-vf-bl { bottom: 6px; left: 6px; border-bottom-width: 2.5px; border-left-width: 2.5px; border-bottom-left-radius: 4px; }
  .rec2-vf-br { bottom: 6px; right: 6px; border-bottom-width: 2.5px; border-right-width: 2.5px; border-bottom-right-radius: 4px; }
  .rec2-scan-line {
    position: absolute;
    top: 12%;
    left: 12%;
    right: 12%;
    height: 2px;
    background: linear-gradient(90deg, transparent, #2AB5A0, transparent);
    box-shadow: 0 0 10px #2AB5A0;
    animation: rec2-scan-line-move 1.6s ease-in-out infinite;
  }
  @keyframes rec2-scan-line-move {
    0%, 100% { top: 12%; }
    50%      { top: 84%; }
  }
  .rec2-scan-target {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rec2-scan-hint {
    text-align: center;
    font-size: 8px;
    font-weight: 600;
    color: rgba(0,0,0,0.6);
    margin-bottom: 8px;
  }
  .rec2-rcv-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: auto;
  }
  .rec2-rcv-row {
    display: grid;
    grid-template-columns: 1fr auto 18px;
    gap: 8px;
    align-items: center;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 6px;
    padding: 6px 9px;
    font-size: 8.5px;
  }
  .rec2-rcv-row--done {
    border-color: rgba(42,181,160,0.30);
    background: rgba(42,181,160,0.06);
  }
  .rec2-rcv-row--active {
    border-color: #1A1A1A;
    animation: rec2-rcv-pulse 1.4s ease-in-out infinite;
  }
  @keyframes rec2-rcv-pulse {
    0%, 100% { background: #fff; }
    50%      { background: rgba(75,123,229,0.06); }
  }
  .rec2-rcv-name { font-weight: 700; color: #1A1A1A; }
  .rec2-rcv-qty {
    font-family: var(--font-display);
    font-weight: 800;
    color: #1A1A1A;
  }
  .rec2-rcv-check { color: #2AB5A0; font-weight: 800; text-align: center; }
  .rec2-rcv-dots { color: rgba(0,0,0,0.5); font-weight: 700; text-align: center; letter-spacing: 0.1em; }

  /* Layer 4: Done */
  .rec2-layer--done {
    align-items: center;
    text-align: center;
    justify-content: center;
  }
  .rec2-done-check { margin-bottom: 8px; }
  .rec2-done-check svg { width: 48px; height: 48px; }
  .rec2-done-path {
    stroke-dasharray: 30;
    stroke-dashoffset: 30;
    animation: rec2-done-draw 14s ease-in-out infinite;
  }
  @keyframes rec2-done-draw {
    0%, 72%  { stroke-dashoffset: 30; }
    78%, 100% { stroke-dashoffset: 0; }
  }
  .rec2-done-title {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 800;
    color: #1A1A1A;
    margin-bottom: 3px;
  }
  .rec2-done-sub {
    font-family: 'SF Mono', 'Menlo', monospace;
    font-size: 8px;
    color: rgba(0,0,0,0.55);
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    padding: 2px 8px;
    border-radius: 4px;
    margin-bottom: 12px;
    letter-spacing: 0.06em;
  }
  .rec2-done-stats {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 10px;
  }
  .rec2-done-stat {
    display: flex;
    justify-content: space-between;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 8.5px;
    color: rgba(0,0,0,0.7);
    font-weight: 600;
  }
  .rec2-done-stat span:last-child { font-family: var(--font-display); font-weight: 800; color: #1A1A1A; }
  .rec2-pos { color: #1A8F7A !important; }

  /* Side report — emerges on the right, occupies the bigger half */
  .rec2-report-wrap {
    position: absolute;
    top: 3%;
    right: 4%;
    height: 94%;
    width: 56%;
    display: flex;
    align-items: center;
    z-index: 1;
  }
  .rec2-report {
    width: 100%;
    background: #fff;
    border-radius: 12px;
    padding: 14px 16px;
    box-shadow:
      0 0 0 1px rgba(0,0,0,0.04),
      0 20px 50px -16px rgba(0,0,0,0.45);
    color: #1A1A1A;
    font-family: var(--font-body);
    transform: translateX(40px);
    opacity: 0;
    animation: rec2-report-emerge 14s ease-in-out infinite;
  }
  @keyframes rec2-report-emerge {
    0%, 72%  { transform: translateX(40px); opacity: 0; }
    78%, 100% { transform: translateX(0); opacity: 1; }
  }
  .rec2-report-head {
    border-bottom: 1px solid rgba(0,0,0,0.08);
    padding-bottom: 8px;
    margin-bottom: 10px;
  }
  .rec2-report-title-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 3px;
  }
  .rec2-report-title {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .rec2-report-tag {
    font-family: 'SF Mono', 'Menlo', monospace;
    font-size: 7px;
    font-weight: 700;
    color: #1A8F7A;
    background: rgba(42,181,160,0.12);
    padding: 2px 6px;
    border-radius: 4px;
    letter-spacing: 0.06em;
  }
  .rec2-report-meta {
    display: flex;
    justify-content: space-between;
    font-size: 7.5px;
    color: rgba(0,0,0,0.55);
  }
  .rec2-report-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    margin-bottom: 10px;
  }
  .rec2-report-stat {
    background: #FAFAFA;
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 6px;
    padding: 7px 9px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .rec2-report-stat--ok {
    background: rgba(42,181,160,0.08);
    border-color: rgba(42,181,160,0.18);
  }
  .rec2-report-stat-label {
    font-size: 6.5px;
    color: rgba(0,0,0,0.5);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }
  .rec2-report-stat-value {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .rec2-report-stat-value--money { color: #1A1A1A; font-size: 11.5px; }

  .rec2-report-section-label {
    font-size: 7px;
    color: rgba(0,0,0,0.5);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    margin-bottom: 6px;
  }
  .rec2-report-list { display: flex; flex-direction: column; gap: 4px; margin-bottom: 10px; }
  .rec2-report-row {
    display: grid;
    grid-template-columns: 32px 1fr auto;
    gap: 8px;
    align-items: center;
    background: #FAFAFA;
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 6px;
    padding: 6px 8px;
  }
  .rec2-report-row img {
    width: 32px;
    height: 32px;
    border-radius: 4px;
    object-fit: cover;
    background: #F2F1EE;
  }
  .rec2-report-row-name {
    font-size: 8.5px;
    font-weight: 700;
    color: #1A1A1A;
  }
  .rec2-report-row-meta {
    font-size: 6.5px;
    color: rgba(0,0,0,0.55);
    margin-top: 1px;
    font-family: 'SF Mono', 'Menlo', monospace;
  }
  .rec2-report-row-meta strong { color: #1A8F7A; font-weight: 800; font-family: var(--font-display); font-size: 8px; }
  .rec2-report-row-delta {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 800;
  }

  .rec2-report-foot {
    border-top: 1px solid rgba(0,0,0,0.06);
    padding-top: 8px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .rec2-report-foot-row {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 7.5px;
    color: rgba(0,0,0,0.6);
  }
  .rec2-report-foot-ic { font-size: 10px; }

  @media (prefers-reduced-motion: reduce) {
    .rec2-frame *, .rec2-frame ::before, .rec2-frame ::after { animation: none !important; }
    .rec2-layer--xml, .rec2-layer--oc, .rec2-layer--rcv { opacity: 0; display: none; }
    .rec2-layer--done { opacity: 1; }
    .rec2-done-path { stroke-dashoffset: 0; }
    .rec2-report { transform: none; opacity: 1; }
  }

  /* ── Auditoría y conteo físico — bigger phone + discrepancy report ── */
  .cnt-frame {
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #1D1D1F;
    background-image:
      radial-gradient(ellipse 70% 50% at 30% 50%, rgba(75,123,229,0.10), transparent 65%),
      radial-gradient(circle at 1px 1px, rgba(255,255,255,0.04) 1px, transparent 0);
    background-size: auto, 24px 24px;
    padding: 3% 3.5%;
    overflow: hidden;
  }
  .cnt-grid {
    display: grid;
    grid-template-columns: 0.7fr 1fr;
    grid-template-rows: 100%;
    gap: 18px;
    height: 100%;
    align-items: stretch;
  }

  /* Phone — bigger and centered */
  .cnt-phone-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
    height: 100%;
  }
  .cnt-phone {
    width: auto;
    max-width: 100%;
    height: 100%;
    aspect-ratio: 9 / 19;
    background: #2A2A2E;
    border-radius: 32px;
    padding: 7px;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.08) inset,
      0 0 0 1px rgba(255,255,255,0.10),
      0 24px 60px -16px rgba(0,0,0,0.55),
      0 8px 24px -8px rgba(0,0,0,0.30);
    position: relative;
  }
  .cnt-phone-notch {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    width: 28%;
    height: 11px;
    background: #0A0A0C;
    border-radius: 999px;
    z-index: 2;
  }
  .cnt-phone-screen {
    width: 100%;
    height: 100%;
    background: #FAFAFA;
    border-radius: 26px;
    overflow: hidden;
    position: relative;
  }

  .cnt-layer {
    position: absolute;
    inset: 0;
    opacity: 0;
    display: flex;
    flex-direction: column;
    font-family: var(--font-body);
    color: #1A1A1A;
  }
  .cnt-layer--list  { animation: cnt-layer-list 12s ease-in-out infinite; }
  .cnt-layer--scan  { animation: cnt-layer-scan 12s ease-in-out infinite; }
  .cnt-layer--prod  { animation: cnt-layer-prod 12s ease-in-out infinite; }
  .cnt-layer--done  { animation: cnt-layer-done 12s ease-in-out infinite; }

  /* Timeline (12s):
     0-15%    Lista de productos a contar (intro · "Iniciar auditoría")
     18-38%   Scanner viewfinder (con producto + barcode + scan line)
     41-62%   Product card con counter animado
     66-100%  Done summary (& report emerges in right column) */
  @keyframes cnt-layer-list {
    0%, 15%   { opacity: 1; }
    18%, 100% { opacity: 0; }
  }
  @keyframes cnt-layer-scan {
    0%, 17%   { opacity: 0; }
    20%, 38%  { opacity: 1; }
    41%, 100% { opacity: 0; }
  }
  @keyframes cnt-layer-prod {
    0%, 40%   { opacity: 0; }
    43%, 62%  { opacity: 1; }
    65%, 100% { opacity: 0; }
  }
  @keyframes cnt-layer-done {
    0%, 64%   { opacity: 0; }
    67%, 100% { opacity: 1; }
  }

  /* List layer (intro: Auditoría completa) */
  .cnt-layer--list { padding: 0; }
  .cnt-list-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #1A1A1A 0%, #2A2A2E 100%);
  }
  .cnt-list-top {
    position: relative;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 22px 12px 6px;
    z-index: 1;
  }
  .cnt-list-back { color: #fff; font-size: 16px; line-height: 1; }
  .cnt-list-title {
    color: #fff;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 10.5px;
    flex: 1;
    text-align: center;
    margin-right: 14px;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .cnt-list-batch {
    color: rgba(255,255,255,0.7);
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.12);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: 'SF Mono', 'Menlo', monospace;
    font-size: 7px;
    font-weight: 700;
    letter-spacing: 0.04em;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .cnt-list-meta {
    position: relative;
    z-index: 1;
    padding: 0 12px 8px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .cnt-list-meta-row {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 7.5px;
    color: rgba(255,255,255,0.65);
    font-weight: 600;
  }
  .cnt-list-meta-dot {
    width: 6px; height: 6px;
    background: #2AB5A0;
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgba(42,181,160,0.20);
    animation: cnt-list-dot-pulse 1.6s ease-in-out infinite;
  }
  @keyframes cnt-list-dot-pulse {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.55; }
  }
  .cnt-list-eyebrow {
    position: relative;
    z-index: 1;
    font-size: 6.5px;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.55);
    text-transform: uppercase;
    padding: 10px 12px 6px;
  }
  .cnt-list-items {
    position: relative;
    z-index: 1;
    flex: 1;
    overflow: hidden;
    padding: 0 12px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    min-height: 0;
  }
  .cnt-list-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5px 8px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 6px;
    flex-shrink: 0;
  }
  .cnt-list-item img {
    width: 26px;
    height: 26px;
    border-radius: 4px;
    object-fit: cover;
    background: rgba(255,255,255,0.06);
    flex-shrink: 0;
  }
  .cnt-list-info { flex: 1; min-width: 0; }
  .cnt-list-name {
    font-size: 8.5px;
    font-weight: 700;
    color: #fff;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  .cnt-list-sku {
    font-size: 6.5px;
    color: rgba(255,255,255,0.45);
    font-family: 'SF Mono', 'Menlo', monospace;
    margin-top: 1px;
    letter-spacing: 0.04em;
  }
  .cnt-list-exp {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 800;
    color: #2AB5A0;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }
  .cnt-list-item--more {
    background: transparent;
    border: 1px dashed rgba(255,255,255,0.15);
    justify-content: center;
    color: rgba(255,255,255,0.50);
    font-size: 8px;
    font-weight: 600;
  }
  .cnt-list-cta {
    position: relative;
    z-index: 1;
    margin: 8px 12px 14px;
    padding: 11px 14px;
    background: #2AB5A0;
    color: #fff;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: -0.01em;
    box-shadow: 0 8px 22px -8px rgba(42,181,160,0.55);
    animation: cnt-list-cta-pulse 2.4s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes cnt-list-cta-pulse {
    0%, 100% { box-shadow: 0 8px 18px -8px rgba(42,181,160,0.50); transform: scale(1); }
    50%      { box-shadow: 0 8px 26px -6px rgba(42,181,160,0.75); transform: scale(1.015); }
  }

  /* Scanner layer */
  .cnt-scan-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #1A1A1A 0%, #2A2A2E 100%);
  }
  .cnt-scan-top {
    position: relative;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 22px 12px 8px;
    z-index: 1;
  }
  .cnt-scan-back {
    color: #fff;
    font-size: 16px;
    line-height: 1;
  }
  .cnt-scan-title {
    color: #fff;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 11px;
    flex: 1;
    text-align: center;
  }
  .cnt-scan-batch {
    font-family: 'SF Mono', 'Menlo', monospace;
    font-size: 8px;
    color: rgba(255,255,255,0.6);
    background: rgba(255,255,255,0.10);
    padding: 2px 6px;
    border-radius: 4px;
  }
  .cnt-scan-vf {
    position: relative;
    margin: 14px 24px 0;
    aspect-ratio: 1;
    align-self: center;
    width: 70%;
    max-width: 160px;
    z-index: 1;
    background: radial-gradient(ellipse at center, rgba(42,181,160,0.06) 0%, transparent 70%);
    overflow: hidden;
  }
  .cnt-scan-product {
    position: absolute;
    inset: 8%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    animation: cnt-scan-product-cycle 3.2s ease-in-out infinite;
  }
  .cnt-scan-product img {
    width: 58%;
    height: auto;
    max-height: 60%;
    object-fit: contain;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.45));
    border-radius: 4px;
  }
  .cnt-scan-barcode {
    width: 78%;
    height: 18px;
    background: #fff;
    border-radius: 2px;
    padding: 3px 4px;
    display: flex;
    align-items: stretch;
    gap: 1.5px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.30);
  }
  .cnt-scan-barcode span {
    flex: 1;
    background: #1A1A1A;
    border-radius: 0.5px;
  }
  .cnt-scan-barcode span:nth-child(2n)   { flex: 0.5; }
  .cnt-scan-barcode span:nth-child(3n)   { flex: 1.6; }
  .cnt-scan-barcode span:nth-child(5n)   { flex: 0.7; }
  .cnt-scan-barcode span:nth-child(7n)   { flex: 1.3; }
  .cnt-scan-barcode span:nth-child(11n)  { flex: 0.4; }
  .cnt-scan-barcode span:nth-child(13n)  { flex: 1.8; }
  @keyframes cnt-scan-product-cycle {
    0%, 100% { opacity: 1; transform: scale(1); }
    45%      { opacity: 1; transform: scale(1.02); }
    52%      { opacity: 1; transform: scale(0.96); filter: brightness(1.4); }
    62%      { opacity: 0.4; transform: scale(0.92); }
    72%      { opacity: 1; transform: scale(1); }
  }
  .cnt-vf-c {
    position: absolute;
    width: 18px;
    height: 18px;
    border-color: #2AB5A0;
    border-style: solid;
    border-width: 0;
  }
  .cnt-vf-tl { top: 0; left: 0; border-top-width: 2.5px; border-left-width: 2.5px; border-top-left-radius: 4px; }
  .cnt-vf-tr { top: 0; right: 0; border-top-width: 2.5px; border-right-width: 2.5px; border-top-right-radius: 4px; }
  .cnt-vf-bl { bottom: 0; left: 0; border-bottom-width: 2.5px; border-left-width: 2.5px; border-bottom-left-radius: 4px; }
  .cnt-vf-br { bottom: 0; right: 0; border-bottom-width: 2.5px; border-right-width: 2.5px; border-bottom-right-radius: 4px; }
  .cnt-scan-line {
    position: absolute;
    top: 10%;
    left: 8%;
    right: 8%;
    height: 2px;
    background: linear-gradient(90deg, transparent, #2AB5A0, transparent);
    box-shadow: 0 0 10px #2AB5A0;
    animation: cnt-scan-line-move 1.6s ease-in-out infinite;
  }
  @keyframes cnt-scan-line-move {
    0%, 100% { top: 8%; }
    50%      { top: 88%; }
  }
  .cnt-scan-hint {
    position: relative;
    text-align: center;
    color: rgba(255,255,255,0.7);
    font-size: 8px;
    font-weight: 600;
    margin-top: 10px;
    z-index: 1;
  }
  .cnt-scan-progress {
    position: relative;
    margin-top: auto;
    padding: 12px 14px 14px;
    background: rgba(255,255,255,0.06);
    border-top: 1px solid rgba(255,255,255,0.08);
    z-index: 1;
  }
  .cnt-scan-progress-label {
    display: block;
    font-size: 6.5px;
    color: rgba(255,255,255,0.55);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .cnt-scan-progress-bar {
    width: 100%;
    height: 3px;
    background: rgba(255,255,255,0.12);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 4px;
  }
  .cnt-scan-progress-fill {
    height: 100%;
    background: #2AB5A0;
    border-radius: 2px;
    width: 17%;
    animation: cnt-scan-progress-fill 12s ease-in-out infinite;
  }
  @keyframes cnt-scan-progress-fill {
    0%, 18%   { width: 17%; }
    32%       { width: 60%; }
    62%       { width: 100%; }
    100%      { width: 100%; }
  }
  .cnt-scan-progress-meta {
    font-size: 8px;
    color: rgba(255,255,255,0.7);
    font-weight: 600;
    display: flex;
    justify-content: space-between;
  }
  .cnt-counter {
    color: #2AB5A0;
    font-family: var(--font-display);
    font-weight: 800;
    animation: cnt-counter-grow 12s steps(8) infinite;
  }
  @keyframes cnt-counter-grow {
    0%     { content: '42'; }
  }

  /* Flash layer */
  .cnt-layer--flash {
    background: #fff;
    align-items: center;
    justify-content: center;
    padding: 30px 20px;
  }
  .cnt-flash-card {
    text-align: center;
    animation: cnt-flash-pop 12s ease-in-out infinite;
  }
  @keyframes cnt-flash-pop {
    0%, 32% { transform: scale(0.85); opacity: 0; }
    35%     { transform: scale(1.05); opacity: 1; }
    37%, 40% { transform: scale(1); opacity: 1; }
    42%, 100% { opacity: 0; }
  }
  .cnt-flash-bar {
    width: 70%;
    height: 50px;
    margin: 0 auto 14px;
  }
  .cnt-flash-sku {
    font-family: 'SF Mono', 'Menlo', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #1A1A1A;
    margin-bottom: 8px;
  }
  .cnt-flash-ok {
    display: inline-block;
    padding: 5px 14px;
    background: rgba(42,181,160,0.14);
    color: #1A8F7A;
    font-family: var(--font-display);
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.04em;
    border-radius: 999px;
  }

  /* Product layer (dark theme — congruent con list y scan) */
  .cnt-layer--prod {
    padding: 22px 14px 14px;
    background: linear-gradient(180deg, #1A1A1A 0%, #2A2A2E 100%);
  }
  .cnt-prod-top {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }
  .cnt-prod-back { color: #fff; font-size: 14px; line-height: 1; }
  .cnt-prod-title {
    flex: 1;
    text-align: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 10.5px;
    color: #fff;
    margin-right: 14px;
    letter-spacing: -0.01em;
  }
  .cnt-prod-card {
    text-align: center;
    margin-bottom: 14px;
  }
  .cnt-prod-img {
    width: 64px;
    height: 76px;
    margin: 0 auto 7px;
    border-radius: 7px;
    overflow: hidden;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
  }
  .cnt-prod-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cnt-prod-name {
    font-family: var(--font-display);
    font-size: 12.5px;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.01em;
  }
  .cnt-prod-meta {
    font-size: 7.5px;
    color: rgba(255,255,255,0.55);
    margin-top: 3px;
    font-family: 'SF Mono', 'Menlo', monospace;
    letter-spacing: 0.04em;
  }
  .cnt-prod-count {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 10px;
    padding: 11px 12px;
    margin-bottom: 10px;
  }
  .cnt-prod-count-label {
    display: block;
    text-align: center;
    font-size: 6.5px;
    color: rgba(255,255,255,0.50);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 800;
    margin-bottom: 7px;
  }
  .cnt-prod-count-row {
    display: grid;
    grid-template-columns: 28px 1fr 28px;
    align-items: center;
    gap: 10px;
  }
  .cnt-prod-count-btn {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 13px;
  }
  .cnt-prod-count-btn--plus {
    background: #2AB5A0;
    color: #fff;
    border-color: #2AB5A0;
    animation: cnt-plus-pulse 12s ease-in-out infinite;
  }
  @keyframes cnt-plus-pulse {
    0%, 50%   { box-shadow: 0 0 0 0 rgba(42,181,160,0); }
    53%       { box-shadow: 0 0 0 6px rgba(42,181,160,0.45); }
    56%, 100% { box-shadow: 0 0 0 0 rgba(42,181,160,0); }
  }
  .cnt-prod-count-num {
    text-align: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 24px;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .cnt-prod-num-anim {
    animation: cnt-num-tick 12s steps(2) infinite;
  }
  @keyframes cnt-num-tick {
    0%, 53%  { content: '23'; }
    56%, 100% { content: '24'; }
  }
  .cnt-prod-num-of {
    display: block;
    font-size: 8px;
    color: rgba(255,255,255,0.45);
    font-weight: 600;
    margin-top: 3px;
    letter-spacing: 0;
  }
  .cnt-prod-status {
    text-align: center;
    font-size: 8px;
    margin-bottom: 12px;
    position: relative;
    height: 20px;
  }
  .cnt-prod-status-pending,
  .cnt-prod-status-done {
    position: absolute;
    left: 0;
    right: 0;
    transition: opacity 0.3s;
  }
  .cnt-prod-status-pending { color: rgba(255,255,255,0.55); animation: cnt-status-pend 12s ease-in-out infinite; }
  .cnt-prod-status-done    { color: #2AB5A0; opacity: 0; font-weight: 800; animation: cnt-status-done 12s ease-in-out infinite; }
  @keyframes cnt-status-pend { 0%,53%{opacity:1;} 56%,100%{opacity:0;} }
  @keyframes cnt-status-done { 0%,53%{opacity:0;} 56%,100%{opacity:1;} }

  .cnt-prod-cta {
    text-align: center;
    background: #2AB5A0;
    color: #fff;
    padding: 11px;
    border-radius: 10px;
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.02em;
    margin-top: auto;
    box-shadow: 0 8px 22px -8px rgba(42,181,160,0.55);
    animation: cnt-list-cta-pulse 2.4s ease-in-out infinite;
  }

  /* Done layer (dark theme) */
  .cnt-layer--done {
    padding: 24px 14px 16px;
    align-items: center;
    text-align: center;
    justify-content: center;
    background: linear-gradient(180deg, #1A1A1A 0%, #2A2A2E 100%);
  }
  .cnt-done-check {
    margin-bottom: 8px;
    animation: cnt-done-pop 12s ease-in-out infinite;
  }
  @keyframes cnt-done-pop {
    0%, 64% { transform: scale(0.85); opacity: 0; }
    70%     { transform: scale(1.08); opacity: 1; }
    74%, 100% { transform: scale(1); opacity: 1; }
  }
  .cnt-done-check svg { width: 54px; height: 54px; }
  .cnt-done-check svg circle:first-of-type { fill: rgba(42,181,160,0.10); }
  .cnt-done-path {
    stroke-dasharray: 30;
    stroke-dashoffset: 30;
    animation: cnt-done-draw 12s ease-in-out infinite;
  }
  @keyframes cnt-done-draw {
    0%, 66%  { stroke-dashoffset: 30; }
    72%, 100% { stroke-dashoffset: 0; }
  }
  .cnt-done-title {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 800;
    color: #fff;
    margin-bottom: 4px;
    letter-spacing: -0.01em;
  }
  .cnt-done-num {
    font-family: 'SF Mono', 'Menlo', monospace;
    font-size: 10px;
    color: rgba(255,255,255,0.65);
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    padding: 3px 9px;
    border-radius: 4px;
    letter-spacing: 0.06em;
    margin-bottom: 14px;
  }
  .cnt-done-stats {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 14px;
  }
  .cnt-done-stat {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 7px;
    padding: 8px 12px;
    font-size: 9.5px;
    color: rgba(255,255,255,0.65);
    font-weight: 600;
  }
  .cnt-done-stat span:last-child {
    font-family: var(--font-display);
    font-weight: 800;
    color: #fff;
    font-size: 11px;
  }
  .cnt-pos { color: #2AB5A0 !important; }
  .cnt-neg { color: #FF6B6B !important; }
  .cnt-done-cta {
    background: #2AB5A0;
    color: #fff;
    padding: 11px 26px;
    border-radius: 10px;
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.02em;
    box-shadow: 0 8px 22px -8px rgba(42,181,160,0.55);
    animation: cnt-list-cta-pulse 2.4s ease-in-out infinite;
  }

  /* ─── Right column: Discrepancy report ─── */
  .cnt-report-wrap {
    display: flex;
    align-items: center;
  }
  .cnt-report {
    width: 100%;
    background: #fff;
    border-radius: 12px;
    padding: 14px 16px 14px;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.6) inset,
      0 0 0 1px rgba(0,0,0,0.04),
      0 20px 50px -16px rgba(0,0,0,0.45),
      0 6px 16px -6px rgba(0,0,0,0.20);
    color: #1A1A1A;
    font-family: var(--font-body);
    transform: translateX(40px);
    opacity: 0;
    animation: cnt-report-emerge 12s ease-in-out infinite;
  }
  @keyframes cnt-report-emerge {
    0%, 64%   { transform: translateX(40px); opacity: 0; }
    74%, 100% { transform: translateX(0); opacity: 1; }
  }

  .cnt-report-head {
    border-bottom: 1px solid rgba(0,0,0,0.08);
    padding-bottom: 8px;
    margin-bottom: 10px;
  }
  .cnt-report-title-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 3px;
  }
  .cnt-report-title {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .cnt-report-tag {
    font-family: 'SF Mono', 'Menlo', monospace;
    font-size: 7.5px;
    font-weight: 700;
    color: #1A8F7A;
    background: rgba(42,181,160,0.12);
    padding: 2px 7px;
    border-radius: 4px;
    letter-spacing: 0.06em;
  }
  .cnt-report-meta {
    display: flex;
    justify-content: space-between;
    font-size: 8px;
    color: rgba(0,0,0,0.55);
  }

  .cnt-stats {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 8px;
    margin-bottom: 12px;
  }
  .cnt-stat {
    background: #FAFAFA;
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 8px;
    padding: 8px 10px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .cnt-stat--diff {
    background: rgba(42,181,160,0.06);
    border-color: rgba(42,181,160,0.20);
  }
  .cnt-stat-label {
    font-size: 7px;
    color: rgba(0,0,0,0.5);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }
  .cnt-stat-value {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .cnt-stat-value--neg { color: #1A8F7A; }
  .cnt-stat-value--money { color: #c62828; font-size: 13px; }

  .cnt-disc-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 10px;
  }
  .cnt-disc-head {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 8px;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin-bottom: 6px;
  }
  .cnt-disc-head--pos { color: #1A8F7A; }
  .cnt-disc-head--neg { color: #c62828; }
  .cnt-disc-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .cnt-disc-head--pos .cnt-disc-dot { background: #2AB5A0; }
  .cnt-disc-head--neg .cnt-disc-dot { background: #c62828; }
  .cnt-disc-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .cnt-disc-row {
    display: grid;
    grid-template-columns: 24px 1fr auto;
    align-items: center;
    gap: 8px;
    background: #FAFAFA;
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 6px;
    padding: 5px 8px 5px 5px;
  }
  .cnt-disc-row img {
    width: 24px;
    height: 24px;
    border-radius: 4px;
    object-fit: cover;
    background: #F2F1EE;
  }
  .cnt-disc-name {
    font-size: 8px;
    font-weight: 700;
    color: #1A1A1A;
  }
  .cnt-disc-sku {
    font-family: 'SF Mono', 'Menlo', monospace;
    font-size: 6.5px;
    color: rgba(0,0,0,0.5);
    margin-top: 1px;
    letter-spacing: 0.04em;
  }
  .cnt-disc-delta {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: -0.01em;
  }
  .cnt-disc-delta--pos { color: #1A8F7A; }
  .cnt-disc-delta--neg { color: #c62828; }

  .cnt-report-foot {
    display: flex;
    align-items: center;
    gap: 6px;
    padding-top: 10px;
    border-top: 1px solid rgba(0,0,0,0.06);
    font-size: 7.5px;
    color: rgba(0,0,0,0.55);
  }
  .cnt-report-foot-ic { font-size: 9px; color: rgba(0,0,0,0.5); }

  @media (prefers-reduced-motion: reduce) {
    .cnt-frame *, .cnt-frame ::before, .cnt-frame ::after { animation: none !important; }
    .cnt-layer--scan, .cnt-layer--flash, .cnt-layer--prod { opacity: 0; display: none; }
    .cnt-layer--done { opacity: 1; }
    .cnt-done-path { stroke-dashoffset: 0; }
    .cnt-report { transform: none; opacity: 1; }
  }

  /* ── Pedidos y Apartados — 3-screen flow (Carrito → Anticipo 30% → Apartado creado) ── */
  .apt3-frame {
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #FAFAFA;
    padding: 2.4% 3% 2.6%;
    font-family: var(--font-body);
    color: #1A1A1A;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }

  /* Topbar */
  .apt3-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4px 4px 12px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    margin-bottom: 14px;
    flex-shrink: 0;
    gap: 14px;
  }
  .apt3-topbar-left { display: flex; align-items: center; gap: 8px; }
  .apt3-topbar-title {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .apt3-topbar-badge {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 9px;
    font-weight: 700;
    color: rgba(0,0,0,0.55);
    background: #F0F0F2;
    padding: 3px 7px;
    border-radius: 4px;
    letter-spacing: 0.04em;
  }

  /* 3-step indicator */
  .apt3-steps {
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
  }
  .apt3-step {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 9px;
    font-weight: 700;
    color: rgba(0,0,0,0.4);
    letter-spacing: 0.02em;
  }
  .apt3-step-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: rgba(0,0,0,0.10);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .apt3-step-dot::after {
    content: "";
    width: 5px;
    height: 5px;
    background: #fff;
    border-radius: 50%;
    opacity: 0;
  }
  .apt3-step-connector {
    width: 32px;
    height: 2px;
    background: rgba(0,0,0,0.10);
    border-radius: 999px;
    margin: 0 8px;
    position: relative;
    overflow: hidden;
  }
  .apt3-step-connector > span {
    position: absolute;
    inset: 0;
    background: #2AB5A0;
    width: 0;
    border-radius: 999px;
  }
  .apt3-step--1 { animation: apt3-step-1 14s ease-in-out infinite; }
  .apt3-step--2 { animation: apt3-step-2 14s ease-in-out infinite; }
  .apt3-step--3 { animation: apt3-step-3 14s ease-in-out infinite; }
  .apt3-step--1 .apt3-step-dot { animation: apt3-dot-1 14s ease-in-out infinite; }
  .apt3-step--2 .apt3-step-dot { animation: apt3-dot-2 14s ease-in-out infinite; }
  .apt3-step--3 .apt3-step-dot { animation: apt3-dot-3 14s ease-in-out infinite; }
  .apt3-step--1 .apt3-step-dot::after { animation: apt3-dot-after-1 14s ease-in-out infinite; }
  .apt3-step--2 .apt3-step-dot::after { animation: apt3-dot-after-2 14s ease-in-out infinite; }
  .apt3-step--3 .apt3-step-dot::after { animation: apt3-dot-after-3 14s ease-in-out infinite; }
  .apt3-step-connector--1 > span { animation: apt3-conn-1 14s ease-in-out infinite; }
  .apt3-step-connector--2 > span { animation: apt3-conn-2 14s ease-in-out infinite; }

  @keyframes apt3-step-1 {
    0%, 30%   { color: #1A8F7A; }
    33%, 100% { color: rgba(0,0,0,0.4); }
  }
  @keyframes apt3-step-2 {
    0%, 32%   { color: rgba(0,0,0,0.4); }
    35%, 65%  { color: #1A8F7A; }
    68%, 100% { color: rgba(0,0,0,0.4); }
  }
  @keyframes apt3-step-3 {
    0%, 65%   { color: rgba(0,0,0,0.4); }
    68%, 100% { color: #1A8F7A; font-weight: 800; }
  }
  @keyframes apt3-dot-1 {
    0%, 30%   { background: #2AB5A0; transform: scale(1.05); }
    33%, 100% { background: #2AB5A0; transform: scale(1); }
  }
  @keyframes apt3-dot-2 {
    0%, 32%   { background: rgba(0,0,0,0.10); transform: scale(1); }
    35%, 65%  { background: #2AB5A0; transform: scale(1.05); }
    68%, 100% { background: #2AB5A0; transform: scale(1); }
  }
  @keyframes apt3-dot-3 {
    0%, 65%   { background: rgba(0,0,0,0.10); transform: scale(1); }
    68%, 100% { background: #2AB5A0; transform: scale(1.08); }
  }
  @keyframes apt3-dot-after-1 {
    0%, 30%   { opacity: 1; }
    33%, 100% { opacity: 1; }
  }
  @keyframes apt3-dot-after-2 {
    0%, 32%   { opacity: 0; }
    35%, 100% { opacity: 1; }
  }
  @keyframes apt3-dot-after-3 {
    0%, 65%   { opacity: 0; }
    68%, 100% { opacity: 1; }
  }
  @keyframes apt3-conn-1 {
    0%, 30%   { width: 0; }
    35%, 100% { width: 100%; }
  }
  @keyframes apt3-conn-2 {
    0%, 65%   { width: 0; }
    70%, 100% { width: 100%; }
  }

  /* Stage container */
  .apt3-stage {
    flex: 1;
    position: relative;
    min-height: 0;
  }
  .apt3-screen {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
  }
  .apt3-screen--cart    { animation: apt3-screen-cart    14s ease-in-out infinite; }
  .apt3-screen--deposit { animation: apt3-screen-deposit 14s ease-in-out infinite; }
  .apt3-screen--ok      { animation: apt3-screen-ok      14s ease-in-out infinite; }
  @keyframes apt3-screen-cart {
    0% { opacity: 0; transform: translateY(8px); }
    3%, 28% { opacity: 1; transform: translateY(0); }
    32%, 100% { opacity: 0; transform: translateY(-8px); }
  }
  @keyframes apt3-screen-deposit {
    0%, 30%   { opacity: 0; transform: translateY(8px); }
    35%, 60%  { opacity: 1; transform: translateY(0); }
    64%, 100% { opacity: 0; transform: translateY(-8px); }
  }
  @keyframes apt3-screen-ok {
    0%, 63%   { opacity: 0; transform: translateY(8px); }
    68%, 98%  { opacity: 1; transform: translateY(0); }
    100%      { opacity: 0; transform: translateY(-8px); }
  }

  /* ── Stage 1 — Cart ── */
  .apt3-customer {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 7px 11px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 9px;
    margin-bottom: 6px;
    flex-shrink: 0;
  }
  .apt3-customer-avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2AB5A0, #4B7BE5);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .apt3-customer-body { flex: 1; min-width: 0; }
  .apt3-customer-name {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 800;
    color: #1A1A1A;
  }
  .apt3-customer-meta {
    font-size: 8.5px;
    color: rgba(0,0,0,0.55);
    margin-top: 2px;
  }
  .apt3-customer-tag {
    font-size: 7.5px;
    font-weight: 800;
    letter-spacing: 0.08em;
    background: rgba(75,123,229,0.10);
    color: #4B7BE5;
    padding: 4px 7px;
    border-radius: 4px;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .apt3-items {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 6px;
    min-height: 0;
  }
  .apt3-item {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 5px 9px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 7px;
    flex-shrink: 0;
  }
  .apt3-item img {
    width: 32px;
    height: 32px;
    border-radius: 5px;
    object-fit: cover;
    flex-shrink: 0;
  }
  .apt3-item-body { flex: 1; min-width: 0; }
  .apt3-item-name {
    font-size: 10.5px;
    font-weight: 700;
    color: #1A1A1A;
  }
  .apt3-item-meta {
    font-size: 8px;
    color: rgba(0,0,0,0.5);
    margin-top: 2px;
  }
  .apt3-item-price {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }

  .apt3-cart-foot { flex-shrink: 0; }
  .apt3-cart-total-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 8px 14px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 10px 10px 0 0;
    border-bottom: none;
  }
  .apt3-cart-total-label {
    font-size: 10px;
    color: rgba(0,0,0,0.65);
    font-weight: 600;
  }
  .apt3-cart-total-value {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.02em;
  }

  .apt3-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: inherit;
    font-weight: 700;
    border: none;
    cursor: default;
    color: #fff;
  }
  .apt3-btn--cart {
    width: 100%;
    padding: 11px 14px;
    font-size: 13px;
    background: #1A1A1A;
    border-radius: 0 0 10px 10px;
    box-shadow: 0 8px 24px -10px rgba(20,20,30,0.30);
    animation: apt3-btn-glow 2.4s ease-in-out infinite;
  }
  @keyframes apt3-btn-glow {
    0%, 100% { box-shadow: 0 8px 20px -10px rgba(20,20,30,0.25); transform: scale(1); }
    50%      { box-shadow: 0 8px 28px -8px rgba(42,181,160,0.45); transform: scale(1.005); }
  }
  .apt3-cart-rule {
    font-size: 8px;
    color: rgba(0,0,0,0.5);
    text-align: center;
    margin-top: 7px;
  }

  /* ── Stage 2 — Deposit ── */
  .apt3-back {
    font-size: 9.5px;
    color: rgba(0,0,0,0.55);
    font-weight: 600;
    margin-bottom: 6px;
    flex-shrink: 0;
  }
  .apt3-deposit-eyebrow {
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: #1A8F7A;
    text-align: center;
    margin-bottom: 8px;
    flex-shrink: 0;
  }
  .apt3-deposit-card {
    display: flex;
    background: #fff;
    border: 1.5px solid rgba(42,181,160,0.30);
    border-radius: 12px;
    padding: 16px 12px;
    margin-bottom: 10px;
    box-shadow: 0 6px 22px -10px rgba(42,181,160,0.25);
    flex-shrink: 0;
  }
  .apt3-deposit-block {
    flex: 1;
    text-align: center;
  }
  .apt3-deposit-divider {
    width: 1px;
    background: rgba(0,0,0,0.08);
    margin: 0 14px;
    flex-shrink: 0;
  }
  .apt3-deposit-label {
    font-size: 8px;
    font-weight: 800;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.5);
    margin-bottom: 4px;
  }
  .apt3-deposit-value {
    font-family: var(--font-display);
    font-size: 30px;
    font-weight: 800;
    color: #128C4A;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .apt3-deposit-value--secondary {
    color: rgba(0,0,0,0.7);
  }
  .apt3-deposit-sub {
    font-size: 8px;
    color: rgba(0,0,0,0.5);
    margin-top: 4px;
  }

  .apt3-methods {
    display: flex;
    gap: 6px;
    margin-bottom: 10px;
    flex-shrink: 0;
  }
  .apt3-method {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 8px 6px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.10);
    border-radius: 7px;
    font-size: 9.5px;
    font-weight: 700;
    color: rgba(0,0,0,0.55);
  }
  .apt3-method--active {
    border: 1.5px solid #1A1A1A;
    background: rgba(0,0,0,0.04);
    color: #1A1A1A;
  }
  .apt3-method-ic {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .apt3-btn--pay {
    width: 100%;
    padding: 13px;
    font-size: 13px;
    background: linear-gradient(135deg, #1A1A1A 0%, #2A2A2A 100%);
    border-radius: 10px;
    margin-top: auto;
    box-shadow: 0 8px 26px -10px rgba(20,20,30,0.32);
    animation: apt3-btn-glow 2.4s ease-in-out infinite;
    flex-shrink: 0;
  }
  .apt3-deposit-note {
    font-size: 8.5px;
    color: rgba(0,0,0,0.55);
    text-align: center;
    margin-top: 8px;
    line-height: 1.4;
    flex-shrink: 0;
  }

  /* ── Stage 3 — Apartado exitoso ── */
  .apt3-ok-hero {
    text-align: center;
    margin-bottom: 12px;
    flex-shrink: 0;
  }
  .apt3-ok-check {
    display: inline-block;
    animation: apt3-ok-pop 1s ease-out;
    animation-iteration-count: 1;
  }
  .apt3-screen--ok .apt3-ok-check { animation: apt3-ok-pop 14s ease-in-out infinite; }
  @keyframes apt3-ok-pop {
    0%, 65% { transform: scale(0.7); opacity: 0; }
    72%     { transform: scale(1.1); opacity: 1; }
    78%, 98% { transform: scale(1); opacity: 1; }
    100%    { transform: scale(0.95); opacity: 0; }
  }
  .apt3-ok-title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
    margin-top: 6px;
  }
  .apt3-ok-sub {
    font-size: 9.5px;
    color: rgba(0,0,0,0.55);
    margin-top: 2px;
  }

  .apt3-summary {
    flex: 1;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 12px;
    padding: 4px 16px;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .apt3-summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 7px 0;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .apt3-summary-row:last-of-type { border-bottom: none; }
  .apt3-summary-label {
    font-size: 9.5px;
    color: rgba(0,0,0,0.55);
    font-weight: 600;
  }
  .apt3-summary-value {
    font-size: 10.5px;
    font-weight: 700;
    color: #1A1A1A;
    font-variant-numeric: tabular-nums;
  }
  .apt3-summary-value--paid  { color: #128C4A; }
  .apt3-summary-value--due   { color: #B45309; }
  .apt3-summary-value--stock { color: #1A8F7A; }
  .apt3-summary-pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 8px;
    background: rgba(42,181,160,0.10);
    border: 1px solid rgba(42,181,160,0.28);
    border-radius: 999px;
    font-size: 9px;
    font-weight: 800;
    color: #1A8F7A;
    letter-spacing: 0.02em;
  }
  .apt3-summary-pill-dot {
    width: 6px; height: 6px;
    background: #2AB5A0;
    border-radius: 50%;
    animation: apt3-pulse 1.6s ease-in-out infinite;
  }

  .apt3-bottom-status {
    margin-top: 10px;
    padding: 10px 14px;
    background: linear-gradient(135deg, rgba(42,181,160,0.10), rgba(75,123,229,0.05));
    border: 1px solid rgba(42,181,160,0.28);
    border-radius: 10px;
    display: flex;
    align-items: center;
    gap: 9px;
    flex-shrink: 0;
  }
  .apt3-bottom-status-dot {
    width: 9px; height: 9px;
    background: #2AB5A0;
    border-radius: 50%;
    flex-shrink: 0;
    animation: apt3-pulse 1.6s ease-in-out infinite;
  }
  .apt3-bottom-status-txt {
    font-size: 10px;
    color: #1A1A1A;
    line-height: 1.4;
  }
  .apt3-bottom-status-txt strong { color: #1A8F7A; font-weight: 800; }
  @keyframes apt3-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(42,181,160,0.55); }
    50%      { box-shadow: 0 0 0 5px rgba(42,181,160,0); }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .apt3-frame *, .apt3-frame ::before, .apt3-frame ::after { animation: none !important; }
    .apt3-screen { opacity: 0; transform: none; }
    .apt3-screen--ok { opacity: 1; }
    .apt3-step { color: #1A8F7A; font-weight: 800; }
    .apt3-step-dot { background: #2AB5A0; }
    .apt3-step-dot::after { opacity: 1; }
    .apt3-step-connector > span { width: 100%; }
  }

  /* ── Pedidos y Apartados (legacy apt2 — no longer rendered) ── */
  .apt2-frame {
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #FAFAFA;
    padding: 2.4% 3%;
    font-family: var(--font-body);
    color: #1A1A1A;
    display: flex;
    flex-direction: column;
    gap: 14px;
    overflow: hidden;
  }

  /* Top bar */
  .apt2-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 4px 4px 10px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .apt2-topbar-left { display: flex; align-items: center; gap: 10px; }
  .apt2-topbar-title {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .apt2-topbar-badge {
    font-family: 'SF Mono', 'Menlo', monospace;
    font-size: 9px;
    font-weight: 700;
    color: rgba(0,0,0,0.55);
    background: #F5F5F7;
    padding: 3px 8px;
    border-radius: 4px;
    letter-spacing: 0.04em;
  }
  .apt2-status-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px 4px 8px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 999px;
    font-size: 9px;
    font-weight: 700;
    color: #1A1A1A;
    position: relative;
  }
  .apt2-status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4B7BE5;
    animation: apt2-status-color 10s ease-in-out infinite;
  }
  @keyframes apt2-status-color {
    0%, 22%   { background: #4B7BE5; box-shadow: 0 0 0 3px rgba(75,123,229,0.18); }
    25%, 47%  { background: #2AB5A0; box-shadow: 0 0 0 3px rgba(42,181,160,0.18); }
    50%, 72%  { background: #E8A838; box-shadow: 0 0 0 3px rgba(232,168,56,0.18); }
    75%, 100% { background: #2AB5A0; box-shadow: 0 0 0 3px rgba(42,181,160,0.22); }
  }
  .apt2-status-txt { display: none; }
  .apt2-status-txt--1 { display: inline; animation: apt2-status-1 10s ease-in-out infinite; }
  .apt2-status-txt--2 { display: inline; position: absolute; right: 10px; opacity: 0; animation: apt2-status-2 10s ease-in-out infinite; }
  .apt2-status-txt--3 { display: inline; position: absolute; right: 10px; opacity: 0; animation: apt2-status-3 10s ease-in-out infinite; }
  .apt2-status-txt--4 { display: inline; position: absolute; right: 10px; opacity: 0; animation: apt2-status-4 10s ease-in-out infinite; }
  @keyframes apt2-status-1 { 0%,22%{opacity:1;} 25%,100%{opacity:0;} }
  @keyframes apt2-status-2 { 0%,22%{opacity:0;} 25%,47%{opacity:1;} 50%,100%{opacity:0;} }
  @keyframes apt2-status-3 { 0%,47%{opacity:0;} 50%,72%{opacity:1;} 75%,100%{opacity:0;} }
  @keyframes apt2-status-4 { 0%,72%{opacity:0;} 75%,100%{opacity:1;} }

  /* Stepper — 4 circles + 3 lines */
  .apt2-stepper {
    display: grid;
    grid-template-columns: auto 1fr auto 1fr auto 1fr auto;
    align-items: center;
    padding: 6px 24px 4px;
    gap: 0;
  }
  .apt2-step { display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .apt2-step-circle {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(0,0,0,0.4);
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 800;
    position: relative;
    transition: background 0.4s, border-color 0.4s, color 0.4s;
  }
  .apt2-step-num,
  .apt2-step-check { position: absolute; transition: opacity 0.3s ease; }
  .apt2-step-check { width: 14px; height: 14px; opacity: 0; }
  .apt2-step-label {
    font-size: 9px;
    font-weight: 700;
    color: rgba(0,0,0,0.45);
    letter-spacing: 0.02em;
    transition: color 0.4s ease;
  }
  .apt2-step-line {
    height: 2px;
    background: rgba(0,0,0,0.10);
    margin: 0 6px;
    margin-bottom: 18px;
    border-radius: 1px;
    overflow: hidden;
    position: relative;
  }
  .apt2-step-line::after {
    content: "";
    position: absolute;
    inset: 0;
    background: #2AB5A0;
    transform-origin: left center;
    transform: scaleX(0);
    transition: transform 0.6s ease;
  }

  /* Step active/done states animated via keyframes */
  .apt2-step--1 .apt2-step-circle { animation: apt2-circle-1 10s ease-in-out infinite; }
  .apt2-step--1 .apt2-step-num    { animation: apt2-num-1    10s ease-in-out infinite; }
  .apt2-step--1 .apt2-step-check  { animation: apt2-check-1  10s ease-in-out infinite; }
  .apt2-step--1 .apt2-step-label  { animation: apt2-label-1  10s ease-in-out infinite; }

  .apt2-step--2 .apt2-step-circle { animation: apt2-circle-2 10s ease-in-out infinite; }
  .apt2-step--2 .apt2-step-num    { animation: apt2-num-2    10s ease-in-out infinite; }
  .apt2-step--2 .apt2-step-check  { animation: apt2-check-2  10s ease-in-out infinite; }
  .apt2-step--2 .apt2-step-label  { animation: apt2-label-2  10s ease-in-out infinite; }

  .apt2-step--3 .apt2-step-circle { animation: apt2-circle-3 10s ease-in-out infinite; }
  .apt2-step--3 .apt2-step-num    { animation: apt2-num-3    10s ease-in-out infinite; }
  .apt2-step--3 .apt2-step-check  { animation: apt2-check-3  10s ease-in-out infinite; }
  .apt2-step--3 .apt2-step-label  { animation: apt2-label-3  10s ease-in-out infinite; }

  .apt2-step--4 .apt2-step-circle { animation: apt2-circle-4 10s ease-in-out infinite; }
  .apt2-step--4 .apt2-step-num    { animation: apt2-num-4    10s ease-in-out infinite; }
  .apt2-step--4 .apt2-step-check  { animation: apt2-check-4  10s ease-in-out infinite; }
  .apt2-step--4 .apt2-step-label  { animation: apt2-label-4  10s ease-in-out infinite; }

  .apt2-step-line--1::after { animation: apt2-line-1 10s ease-in-out infinite; }
  .apt2-step-line--2::after { animation: apt2-line-2 10s ease-in-out infinite; }
  .apt2-step-line--3::after { animation: apt2-line-3 10s ease-in-out infinite; }

  /* Step 1: active 0-22%, done 22-100% */
  @keyframes apt2-circle-1 {
    0%, 22%   { background: #1A1A1A; border-color: #1A1A1A; color: #fff; }
    25%, 100% { background: #2AB5A0; border-color: #2AB5A0; color: #fff; }
  }
  @keyframes apt2-num-1   { 0%,22%{opacity:1;} 25%,100%{opacity:0;} }
  @keyframes apt2-check-1 { 0%,22%{opacity:0;} 25%,100%{opacity:1;} }
  @keyframes apt2-label-1 {
    0%, 22%   { color: #1A1A1A; }
    25%, 100% { color: #1A8F7A; }
  }

  /* Step 2 */
  @keyframes apt2-circle-2 {
    0%, 22%   { background: #fff; border-color: rgba(0,0,0,0.12); color: rgba(0,0,0,0.4); }
    25%, 47%  { background: #1A1A1A; border-color: #1A1A1A; color: #fff; }
    50%, 100% { background: #2AB5A0; border-color: #2AB5A0; color: #fff; }
  }
  @keyframes apt2-num-2   { 0%,47%{opacity:1;} 50%,100%{opacity:0;} }
  @keyframes apt2-check-2 { 0%,47%{opacity:0;} 50%,100%{opacity:1;} }
  @keyframes apt2-label-2 {
    0%, 22%   { color: rgba(0,0,0,0.45); }
    25%, 47%  { color: #1A1A1A; }
    50%, 100% { color: #1A8F7A; }
  }

  /* Step 3 */
  @keyframes apt2-circle-3 {
    0%, 47%   { background: #fff; border-color: rgba(0,0,0,0.12); color: rgba(0,0,0,0.4); }
    50%, 72%  { background: #1A1A1A; border-color: #1A1A1A; color: #fff; }
    75%, 100% { background: #2AB5A0; border-color: #2AB5A0; color: #fff; }
  }
  @keyframes apt2-num-3   { 0%,72%{opacity:1;} 75%,100%{opacity:0;} }
  @keyframes apt2-check-3 { 0%,72%{opacity:0;} 75%,100%{opacity:1;} }
  @keyframes apt2-label-3 {
    0%, 47%   { color: rgba(0,0,0,0.45); }
    50%, 72%  { color: #1A1A1A; }
    75%, 100% { color: #1A8F7A; }
  }

  /* Step 4 */
  @keyframes apt2-circle-4 {
    0%, 72%   { background: #fff; border-color: rgba(0,0,0,0.12); color: rgba(0,0,0,0.4); }
    75%, 100% { background: #2AB5A0; border-color: #2AB5A0; color: #fff; }
  }
  @keyframes apt2-num-4   { 0%,72%{opacity:1;} 75%,100%{opacity:0;} }
  @keyframes apt2-check-4 { 0%,72%{opacity:0;} 75%,100%{opacity:1;} }
  @keyframes apt2-label-4 {
    0%, 72%   { color: rgba(0,0,0,0.45); }
    75%, 100% { color: #1A8F7A; font-weight: 800; }
  }

  /* Lines fill on transition */
  @keyframes apt2-line-1 {
    0%, 22%   { transform: scaleX(0); }
    25%, 100% { transform: scaleX(1); }
  }
  @keyframes apt2-line-2 {
    0%, 47%   { transform: scaleX(0); }
    50%, 100% { transform: scaleX(1); }
  }
  @keyframes apt2-line-3 {
    0%, 72%   { transform: scaleX(0); }
    75%, 100% { transform: scaleX(1); }
  }

  /* Body */
  .apt2-body {
    flex: 1;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 14px;
    min-height: 0;
  }
  .apt2-card {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 10px;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .apt2-product {
    display: grid;
    grid-template-columns: 44px 1fr auto;
    align-items: center;
    gap: 10px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .apt2-product-thumb {
    width: 44px;
    height: 44px;
    border-radius: 6px;
    overflow: hidden;
    background: #F5F5F7;
  }
  .apt2-product-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .apt2-product-name {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .apt2-product-meta {
    font-size: 8px;
    color: rgba(0,0,0,0.55);
    margin-top: 2px;
  }
  .apt2-product-price {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }

  /* Payments rows — animated paid state */
  .apt2-payments { display: flex; flex-direction: column; gap: 6px; }
  .apt2-pay {
    display: grid;
    grid-template-columns: 14px 1fr auto auto;
    align-items: center;
    gap: 10px;
    padding: 6px 8px;
    background: #FAFAFA;
    border-radius: 6px;
    font-size: 9px;
  }
  .apt2-pay-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(0,0,0,0.18);
    transition: background 0.3s;
  }
  .apt2-pay-label { color: #1A1A1A; font-weight: 600; }
  .apt2-pay-amount {
    font-family: var(--font-display);
    font-weight: 700;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .apt2-pay-status { font-size: 8px; font-weight: 700; min-width: 60px; text-align: right; position: relative; }
  .apt2-pay-status-pending,
  .apt2-pay-status-paid {
    position: absolute;
    right: 0;
    transition: opacity 0.3s ease;
  }
  .apt2-pay-status-pending { color: rgba(0,0,0,0.45); }
  .apt2-pay-status-paid    { color: #1A8F7A; opacity: 0; }

  .apt2-pay--1 .apt2-pay-dot           { animation: apt2-paydot-1 10s ease-in-out infinite; }
  .apt2-pay--1 .apt2-pay-status-pending { animation: apt2-paypend-1 10s ease-in-out infinite; }
  .apt2-pay--1 .apt2-pay-status-paid    { animation: apt2-paypaid-1 10s ease-in-out infinite; }
  .apt2-pay--2 .apt2-pay-dot           { animation: apt2-paydot-2 10s ease-in-out infinite; }
  .apt2-pay--2 .apt2-pay-status-pending { animation: apt2-paypend-2 10s ease-in-out infinite; }
  .apt2-pay--2 .apt2-pay-status-paid    { animation: apt2-paypaid-2 10s ease-in-out infinite; }
  .apt2-pay--3 .apt2-pay-dot           { animation: apt2-paydot-3 10s ease-in-out infinite; }
  .apt2-pay--3 .apt2-pay-status-pending { animation: apt2-paypend-3 10s ease-in-out infinite; }
  .apt2-pay--3 .apt2-pay-status-paid    { animation: apt2-paypaid-3 10s ease-in-out infinite; }

  /* Pay 1 paid at 25% */
  @keyframes apt2-paydot-1   { 0%,22%{background:rgba(0,0,0,0.18);} 25%,100%{background:#2AB5A0;} }
  @keyframes apt2-paypend-1  { 0%,22%{opacity:1;} 25%,100%{opacity:0;} }
  @keyframes apt2-paypaid-1  { 0%,22%{opacity:0;} 25%,100%{opacity:1;} }
  /* Pay 2 paid at 50% */
  @keyframes apt2-paydot-2   { 0%,47%{background:rgba(0,0,0,0.18);} 50%,100%{background:#2AB5A0;} }
  @keyframes apt2-paypend-2  { 0%,47%{opacity:1;} 50%,100%{opacity:0;} }
  @keyframes apt2-paypaid-2  { 0%,47%{opacity:0;} 50%,100%{opacity:1;} }
  /* Pay 3 paid at 75% */
  @keyframes apt2-paydot-3   { 0%,72%{background:rgba(0,0,0,0.18);} 75%,100%{background:#2AB5A0;} }
  @keyframes apt2-paypend-3  { 0%,72%{opacity:1;} 75%,100%{opacity:0;} }
  @keyframes apt2-paypaid-3  { 0%,72%{opacity:0;} 75%,100%{opacity:1;} }

  /* Progress bar */
  .apt2-progress-wrap {
    margin-top: auto;
  }
  .apt2-progress-bar {
    width: 100%;
    height: 4px;
    background: rgba(0,0,0,0.08);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 6px;
  }
  .apt2-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #2AB5A0, #4B7BE5);
    border-radius: 2px;
    width: 0;
    animation: apt2-progress 10s ease-in-out infinite;
  }
  @keyframes apt2-progress {
    0%, 22%   { width: 0; }
    25%, 47%  { width: 20%; }
    50%, 72%  { width: 60%; }
    75%, 100% { width: 100%; }
  }
  .apt2-progress-meta {
    display: flex;
    justify-content: space-between;
    font-size: 8px;
    color: rgba(0,0,0,0.55);
  }
  .apt2-progress-paid, .apt2-progress-due {
    position: relative;
    display: inline-block;
  }
  .apt2-progress-paid > span,
  .apt2-progress-due > span {
    position: absolute;
    left: 0;
    top: 0;
    transition: opacity 0.3s;
  }
  .apt2-progress-paid > span:not(.apt2-progress-paid-of) { opacity: 0; }
  .apt2-progress-paid-of {
    position: relative !important;
    margin-left: 26px;
    color: rgba(0,0,0,0.4);
  }
  .apt2-progress-paid--1 { animation: apt2-paid-1 10s ease-in-out infinite; }
  .apt2-progress-paid--2 { animation: apt2-paid-2 10s ease-in-out infinite; }
  .apt2-progress-paid--3 { animation: apt2-paid-3 10s ease-in-out infinite; }
  .apt2-progress-paid--4 { animation: apt2-paid-4 10s ease-in-out infinite; }
  @keyframes apt2-paid-1 { 0%,22%{opacity:1;color:#1A1A1A;font-weight:700;} 25%,100%{opacity:0;} }
  @keyframes apt2-paid-2 { 0%,22%{opacity:0;} 25%,47%{opacity:1;color:#1A8F7A;font-weight:700;} 50%,100%{opacity:0;} }
  @keyframes apt2-paid-3 { 0%,47%{opacity:0;} 50%,72%{opacity:1;color:#1A8F7A;font-weight:700;} 75%,100%{opacity:0;} }
  @keyframes apt2-paid-4 { 0%,72%{opacity:0;} 75%,100%{opacity:1;color:#1A8F7A;font-weight:800;} }

  .apt2-progress-due { min-width: 130px; text-align: right; }
  .apt2-progress-due > span {
    left: auto;
    right: 0;
    opacity: 0;
  }
  .apt2-progress-due--1 { animation: apt2-due-1 10s ease-in-out infinite; }
  .apt2-progress-due--2 { animation: apt2-due-2 10s ease-in-out infinite; }
  .apt2-progress-due--3 { animation: apt2-due-3 10s ease-in-out infinite; }
  .apt2-progress-due--4 { animation: apt2-due-4 10s ease-in-out infinite; }
  @keyframes apt2-due-1 { 0%,22%{opacity:1;} 25%,100%{opacity:0;} }
  @keyframes apt2-due-2 { 0%,22%{opacity:0;} 25%,47%{opacity:1;} 50%,100%{opacity:0;} }
  @keyframes apt2-due-3 { 0%,47%{opacity:0;} 50%,72%{opacity:1;} 75%,100%{opacity:0;} }
  @keyframes apt2-due-4 { 0%,72%{opacity:0;} 75%,100%{opacity:1;color:#1A8F7A;font-weight:800;} }

  /* Side: contextual events that swap with the stage */
  .apt2-side {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 10px;
    padding: 14px;
    position: relative;
    overflow: hidden;
  }
  .apt2-side-event {
    position: absolute;
    inset: 14px;
    display: flex;
    gap: 10px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s, transform 0.4s;
  }
  .apt2-side-event--1 { animation: apt2-side-1 10s ease-in-out infinite; }
  .apt2-side-event--2 { animation: apt2-side-2 10s ease-in-out infinite; }
  .apt2-side-event--3 { animation: apt2-side-3 10s ease-in-out infinite; }
  .apt2-side-event--4 { animation: apt2-side-4 10s ease-in-out infinite; }
  @keyframes apt2-side-1 {
    0%, 22%  { opacity: 1; transform: translateY(0); }
    25%, 100% { opacity: 0; transform: translateY(-8px); }
  }
  @keyframes apt2-side-2 {
    0%, 22%   { opacity: 0; transform: translateY(8px); }
    25%, 47%  { opacity: 1; transform: translateY(0); }
    50%, 100% { opacity: 0; transform: translateY(-8px); }
  }
  @keyframes apt2-side-3 {
    0%, 47%   { opacity: 0; transform: translateY(8px); }
    50%, 72%  { opacity: 1; transform: translateY(0); }
    75%, 100% { opacity: 0; transform: translateY(-8px); }
  }
  @keyframes apt2-side-4 {
    0%, 72%  { opacity: 0; transform: translateY(8px); }
    75%, 100% { opacity: 1; transform: translateY(0); }
  }
  .apt2-side-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 14px;
  }
  .apt2-side-icon--ok    { background: rgba(42,181,160,0.12); color: #1A8F7A; }
  .apt2-side-icon--cash  { background: rgba(75,123,229,0.12); color: #4B7BE5; }
  .apt2-side-icon--wa    { background: #25D366; color: #fff; }
  .apt2-side-body { flex: 1; min-width: 0; }
  .apt2-side-title {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 800;
    color: #1A1A1A;
    margin-bottom: 4px;
    letter-spacing: -0.01em;
  }
  .apt2-side-desc {
    font-size: 8.5px;
    color: rgba(0,0,0,0.55);
    line-height: 1.45;
  }
  .apt2-side-quote {
    font-size: 9px;
    color: rgba(0,0,0,0.65);
    line-height: 1.45;
    padding: 6px 8px;
    background: #F5F5F7;
    border-radius: 6px;
    font-style: italic;
  }

  @media (prefers-reduced-motion: reduce) {
    .apt2-frame *, .apt2-frame ::before, .apt2-frame ::after { animation: none !important; }
    .apt2-progress-fill { width: 100%; }
    .apt2-side-event--1, .apt2-side-event--2, .apt2-side-event--3 { display: none; }
    .apt2-side-event--4 { opacity: 1; transform: none; }
    .apt2-status-txt--1, .apt2-status-txt--2, .apt2-status-txt--3 { display: none; }
    .apt2-status-txt--4 { display: inline; opacity: 1; position: static; }
  }

  /* ── Cambios y devoluciones slide — fills tablet, animated flow ── */
  .rtn-frame {
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #FAFAFA;
    padding: 2.4% 3% 2.4%;
    font-family: var(--font-body);
    color: #1A1A1A;
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
    overflow: hidden;
  }

  /* Top bar */
  .rtn-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4px 6px 8px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    flex-shrink: 0;
  }
  .rtn-topbar-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .rtn-topbar-back {
    font-size: 16px;
    color: rgba(0,0,0,0.45);
    line-height: 1;
  }
  .rtn-topbar-title {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .rtn-topbar-meta {
    font-size: 8px;
    color: rgba(0,0,0,0.5);
  }

  .rtn-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 12px;
    flex: 1;
    min-height: 0;
  }
  .rtn-mini-label {
    font-size: 7px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.45);
    margin-bottom: 6px;
  }
  .rtn-mini-label--mt { margin-top: 10px; }
  .rtn-search-col, .rtn-action-col {
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  /* Items list with thumbnails — sized so 7 items fit cleanly in 16:10 */
  .rtn-items {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .rtn-item {
    display: grid;
    grid-template-columns: 30px 1fr auto;
    align-items: center;
    gap: 8px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 7px;
    padding: 4px 8px 4px 4px;
  }
  .rtn-item--selected {
    border-color: rgba(42,181,160,0.45);
    background: rgba(42,181,160,0.05);
    box-shadow: 0 1px 4px -1px rgba(42,181,160,0.10);
  }
  .rtn-thumb {
    width: 30px;
    height: 30px;
    border-radius: 5px;
    overflow: hidden;
    background: #F5F5F7;
    flex-shrink: 0;
  }
  .rtn-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .rtn-thumb--sm {
    width: 30px;
    height: 30px;
    border-radius: 5px;
  }
  .rtn-item-body {
    min-width: 0;
  }
  .rtn-item-name {
    font-size: 8.5px;
    font-weight: 700;
    color: #1A1A1A;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .rtn-item-meta {
    font-size: 6.5px;
    color: rgba(0,0,0,0.5);
    margin-top: 1px;
    letter-spacing: 0.02em;
  }
  .rtn-item-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .rtn-check {
    width: 14px;
    height: 14px;
    border-radius: 4px;
    background: #2AB5A0;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .rtn-check--off {
    background: transparent;
    border: 1px solid rgba(0,0,0,0.22);
  }
  .rtn-item-price {
    font-family: var(--font-display);
    font-size: 8.5px;
    font-weight: 700;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .rtn-item-price--off {
    color: rgba(0,0,0,0.45);
    font-weight: 600;
  }

  /* Swap (cambio por) row */
  .rtn-swap {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 6px;
    align-items: center;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 8px;
    padding: 7px 8px;
  }
  .rtn-swap-item {
    display: flex;
    align-items: center;
    gap: 6px;
    min-width: 0;
  }
  .rtn-swap-item--new .rtn-swap-name { color: #2AB5A0; }
  .rtn-swap-body { min-width: 0; }
  .rtn-swap-name {
    font-size: 8px;
    font-weight: 700;
    color: #1A1A1A;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .rtn-swap-meta {
    font-size: 6.5px;
    color: rgba(0,0,0,0.5);
    margin-top: 1px;
  }
  .rtn-swap-arrow {
    color: rgba(0,0,0,0.4);
    font-size: 14px;
    line-height: 1;
  }

  /* Action column */
  .rtn-options {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 8px;
  }
  .rtn-opt {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 6px;
    padding: 7px 9px;
    font-size: 8.5px;
  }
  .rtn-opt--active {
    border-color: #1A1A1A;
    background: #fff;
  }
  .rtn-opt-radio {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #1A1A1A;
    border: 2px solid #1A1A1A;
    box-shadow: inset 0 0 0 2px #fff;
    flex-shrink: 0;
  }
  .rtn-opt-radio--off {
    background: transparent;
    border: 1px solid rgba(0,0,0,0.22);
    box-shadow: none;
  }
  .rtn-opt-name {
    color: #1A1A1A;
    font-weight: 600;
  }
  .rtn-summary {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 8px;
    padding: 9px 10px;
    margin-bottom: 8px;
  }
  .rtn-summary-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 8px;
    color: rgba(0,0,0,0.6);
    padding: 2px 0;
  }
  .rtn-summary-strike {
    text-decoration: line-through;
    color: rgba(0,0,0,0.4);
  }
  .rtn-summary-row--total {
    border-top: 1px solid rgba(0,0,0,0.08);
    margin-top: 4px;
    padding-top: 6px;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 11px;
    color: #1A1A1A;
  }
  .rtn-summary-pos { color: #2AB5A0; }

  .rtn-method { margin-bottom: 8px; }
  .rtn-method-row {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }
  .rtn-method-pill {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 999px;
    padding: 4px 9px;
    font-size: 7.5px;
    font-weight: 600;
    color: rgba(0,0,0,0.55);
    letter-spacing: 0.02em;
  }
  .rtn-method-pill--active {
    background: #1A1A1A;
    border-color: #1A1A1A;
    color: #fff;
  }

  .rtn-cta {
    appearance: none;
    border: none;
    cursor: pointer;
    width: 100%;
    background: #1A1A1A;
    color: #fff;
    font-family: var(--font-display);
    font-size: 9.5px;
    font-weight: 700;
    text-align: center;
    padding: 9px;
    border-radius: 8px;
    margin-bottom: 6px;
    letter-spacing: 0.03em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    animation: rtn-cta-loop 8s ease-in-out infinite;
  }
  .rtn-cta-arrow {
    transition: transform 0.4s ease;
    display: inline-block;
  }
  @keyframes rtn-cta-loop {
    0%, 35% { background: #1A1A1A; transform: scale(1); }
    40% { background: #2AB5A0; transform: scale(0.97); }
    45%, 100% { background: #1A1A1A; transform: scale(1); }
  }
  .rtn-foot {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 7px;
    color: rgba(0,0,0,0.5);
  }
  .rtn-foot-ic {
    font-size: 9px;
    color: rgba(0,0,0,0.45);
  }

  /* Success modal — fades in midway through the loop */
  .rtn-modal {
    position: absolute;
    inset: 0;
    background: rgba(20,20,30,0.40);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    animation: rtn-modal-loop 8s ease-in-out infinite;
  }
  .rtn-modal-card {
    width: 56%;
    max-width: 380px;
    background: #FFFFFF;
    border-radius: 14px;
    padding: 18px 20px 16px;
    box-shadow: 0 16px 48px -12px rgba(20,20,30,0.30);
    text-align: center;
    transform: scale(0.94);
    animation: rtn-modal-card-loop 8s ease-in-out infinite;
  }
  .rtn-modal-check {
    margin: 0 auto 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rtn-modal-check svg { width: 36px; height: 36px; }
  .rtn-modal-check-path {
    stroke-dasharray: 30;
    stroke-dashoffset: 30;
    animation: rtn-modal-check-loop 8s ease-in-out infinite;
  }
  .rtn-modal-title {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }
  .rtn-modal-desc {
    font-size: 8px;
    color: rgba(0,0,0,0.55);
    margin-bottom: 10px;
    line-height: 1.4;
  }
  .rtn-modal-rows {
    background: #FAFAFA;
    border-radius: 8px;
    padding: 8px 10px;
    text-align: left;
  }
  .rtn-modal-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 7.5px;
    color: rgba(0,0,0,0.6);
    padding: 2px 0;
  }
  .rtn-modal-row span:last-child {
    font-weight: 700;
    color: #1A1A1A;
  }
  .rtn-modal-pos { color: #2AB5A0 !important; }

  /* Animation timeline (shared across modal layers):
     0–48%   → idle (form visible, modal hidden)
     48–55%  → CTA pressed (rtn-cta-loop)
     55–60%  → modal fade-in
     60–92%  → modal visible, check stroke draws
     92–100% → modal fade-out, return to idle */
  @keyframes rtn-modal-loop {
    0%, 55%   { opacity: 0; pointer-events: none; }
    60%, 92%  { opacity: 1; pointer-events: auto; }
    100%      { opacity: 0; pointer-events: none; }
  }
  @keyframes rtn-modal-card-loop {
    0%, 55%   { transform: scale(0.94) translateY(8px); }
    62%, 92%  { transform: scale(1) translateY(0); }
    100%      { transform: scale(0.94) translateY(8px); }
  }
  @keyframes rtn-modal-check-loop {
    0%, 60%   { stroke-dashoffset: 30; }
    72%, 92%  { stroke-dashoffset: 0; }
    100%      { stroke-dashoffset: 30; }
  }

  @media (prefers-reduced-motion: reduce) {
    .rtn-cta, .rtn-modal, .rtn-modal-card, .rtn-modal-check-path {
      animation: none !important;
    }
    .rtn-modal { display: none; }
  }

  /* ── Cobro móvil — line-busting slide (3 phone layers + emerging ticket) ── */
  .mob-frame {
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #FAFAFA;
    padding: 2.4% 3%;
    overflow: hidden;
  }
  .mob-grid {
    display: grid;
    grid-template-columns: 0.78fr 1fr;
    grid-template-rows: 100%;
    gap: 18px;
    height: 100%;
    align-items: stretch;
  }
  .mob-phone-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .mob-phone {
    width: 88%;
    max-width: 220px;
    aspect-ratio: 9 / 19;
    background: #E8E8EC;
    border-radius: 28px;
    padding: 6px;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.6) inset,
      0 0 0 1px rgba(0,0,0,0.06),
      0 12px 32px -8px rgba(20,20,30,0.18),
      0 4px 12px -4px rgba(20,20,30,0.10);
    position: relative;
  }
  .mob-phone-notch {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 28%;
    height: 10px;
    background: #1A1A1A;
    border-radius: 999px;
    z-index: 2;
  }
  .mob-phone-screen {
    width: 100%;
    height: 100%;
    background: #FAFAFA;
    border-radius: 22px;
    overflow: hidden;
    position: relative;
  }

  /* Three stacked layers, animated via opacity */
  .mob-layer {
    position: absolute;
    inset: 0;
    padding: 22px 8px 8px;
    display: flex;
    flex-direction: column;
    font-family: var(--font-body);
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .mob-layer--cart      { animation: mob-layer-cart 8s ease-in-out infinite; }
  .mob-layer--tap       { animation: mob-layer-tap 8s ease-in-out infinite; }
  .mob-layer--ok        { animation: mob-layer-ok 8s ease-in-out infinite; }

  @keyframes mob-layer-cart {
    0%, 28%   { opacity: 1; }
    33%, 100% { opacity: 0; }
  }
  @keyframes mob-layer-tap {
    0%, 33%   { opacity: 0; }
    38%, 55%  { opacity: 1; }
    60%, 100% { opacity: 0; }
  }
  @keyframes mob-layer-ok {
    0%, 60%   { opacity: 0; }
    65%, 100% { opacity: 1; }
  }

  /* Cart layer */
  .mob-app-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 6px;
  }
  .mob-app-store {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 8px;
    color: #1A1A1A;
    letter-spacing: 0.02em;
  }
  .mob-app-user {
    font-size: 6px;
    color: rgba(0,0,0,0.5);
    margin-top: 1px;
  }
  .mob-app-cart-badge {
    width: 16px;
    height: 16px;
    background: #2AB5A0;
    color: #fff;
    border-radius: 50%;
    font-size: 8px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mob-scan-card {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px;
    background: #fff;
    border: 1px dashed rgba(0,0,0,0.18);
    border-radius: 8px;
    margin-bottom: 6px;
  }
  .mob-scan-ic {
    width: 22px;
    height: 22px;
    background: #1A1A1A;
    color: #fff;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    flex-shrink: 0;
  }
  .mob-scan-title {
    font-family: var(--font-display);
    font-size: 7.5px;
    font-weight: 700;
    color: #1A1A1A;
  }
  .mob-scan-sub {
    font-size: 6px;
    color: rgba(0,0,0,0.5);
    margin-top: 1px;
  }
  .mob-cart {
    display: flex;
    flex-direction: column;
    gap: 3px;
    margin-bottom: 4px;
    flex: 1;
    overflow: hidden;
  }
  .mob-cart-item {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 3px 5px 3px 3px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 6px;
  }
  .mob-cart-thumb {
    width: 20px;
    height: 20px;
    border-radius: 4px;
    flex-shrink: 0;
    overflow: hidden;
    background: #F5F5F7;
  }
  .mob-cart-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .mob-cart-body { flex: 1; min-width: 0; }
  .mob-cart-name {
    font-size: 6.5px;
    font-weight: 700;
    color: #1A1A1A;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .mob-cart-meta {
    font-size: 5.5px;
    color: rgba(0,0,0,0.5);
    margin-top: 1px;
  }
  .mob-total {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 6px 4px 4px;
    border-top: 1px solid rgba(0,0,0,0.08);
  }
  .mob-total-label {
    font-size: 7px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(0,0,0,0.55);
    font-weight: 700;
  }
  .mob-total-value {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .mob-pay-btn {
    background: #1A1A1A;
    color: #fff;
    text-align: center;
    padding: 8px;
    border-radius: 8px;
    font-family: var(--font-display);
    font-size: 8.5px;
    font-weight: 700;
    letter-spacing: 0.03em;
    margin: 4px 0 4px;
  }
  .mob-pay-alts {
    text-align: center;
    font-size: 5.5px;
    color: rgba(0,0,0,0.45);
    font-weight: 600;
  }
  .mob-pay-sep { margin: 0 3px; }

  /* Animated cursor pointing to "Cobrar" button (cart layer only) */
  .mob-cursor {
    position: absolute;
    top: 14%;
    left: 78%;
    width: 20px;
    height: 20px;
    z-index: 5;
    pointer-events: none;
    opacity: 0;
    transform: translate(0, 0) scale(1);
    animation: mob-cursor-cycle 8s ease-in-out infinite;
    filter: drop-shadow(0 3px 5px rgba(0,0,0,0.28));
  }
  .mob-cursor-arrow {
    display: block;
    width: 100%;
    height: 100%;
  }
  .mob-cursor-pulse {
    position: absolute;
    top: -4px;
    left: -4px;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid rgba(42,181,160,0.85);
    transform: scale(0.4);
    opacity: 0;
    animation: mob-cursor-click 8s ease-in-out infinite;
  }
  @keyframes mob-cursor-cycle {
    0%   { opacity: 0; transform: translate(8px, -8px) scale(1); }
    4%   { opacity: 0; transform: translate(8px, -8px) scale(1); }
    8%   { opacity: 1; transform: translate(8px, -8px) scale(1); }
    20%  { opacity: 1; transform: translate(-58px, 352px) scale(1); }
    23%  { opacity: 1; transform: translate(-58px, 352px) scale(0.78); }
    26%  { opacity: 1; transform: translate(-58px, 352px) scale(1); }
    29%  { opacity: 1; transform: translate(-58px, 352px) scale(1); }
    33%  { opacity: 0; transform: translate(-58px, 352px) scale(1); }
    100% { opacity: 0; transform: translate(-58px, 352px) scale(1); }
  }
  @keyframes mob-cursor-click {
    0%, 21%   { transform: scale(0.4); opacity: 0; }
    23%       { transform: scale(0.5); opacity: 0.9; }
    28%       { transform: scale(2.6); opacity: 0; }
    100%      { transform: scale(2.6); opacity: 0; }
  }

  /* Tap-to-Pay layer */
  .mob-layer--tap { padding: 22px 12px 12px; }
  .mob-tap-back {
    font-size: 7px;
    color: rgba(0,0,0,0.5);
    font-weight: 600;
    margin-bottom: 8px;
  }
  .mob-tap-amount {
    text-align: center;
    margin-bottom: 12px;
  }
  .mob-tap-amount-label {
    font-size: 6.5px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(0,0,0,0.45);
    font-weight: 700;
    margin-bottom: 3px;
  }
  .mob-tap-amount-value {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .mob-tap-amount-sub {
    font-size: 6px;
    color: rgba(0,0,0,0.5);
    margin-top: 3px;
  }
  .mob-tap-zone {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    position: relative;
  }
  .mob-tap-ring {
    position: absolute;
    width: 90px;
    height: 90px;
    border-radius: 50%;
    border: 1.5px solid rgba(42,181,160,0.4);
    animation: mob-tap-ring-pulse 1.6s ease-in-out infinite;
  }
  @keyframes mob-tap-ring-pulse {
    0%, 100% { transform: scale(0.85); opacity: 0.8; }
    50%      { transform: scale(1.05); opacity: 0; }
  }
  .mob-tap-icon {
    width: 60px;
    height: 60px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px -4px rgba(20,20,30,0.10);
    z-index: 1;
  }
  .mob-tap-title {
    font-family: var(--font-display);
    font-size: 9.5px;
    font-weight: 800;
    color: #1A1A1A;
    margin-top: 4px;
    z-index: 1;
  }
  .mob-tap-sub {
    font-size: 6px;
    color: rgba(0,0,0,0.5);
    z-index: 1;
  }
  .mob-tap-methods { text-align: center; }
  .mob-tap-method {
    font-size: 6px;
    font-weight: 600;
    color: rgba(0,0,0,0.55);
    margin-bottom: 2px;
  }
  .mob-tap-method-alt {
    font-size: 5.5px;
    color: rgba(0,0,0,0.4);
  }

  /* Success layer */
  .mob-layer--ok {
    padding: 22px 14px 12px;
    align-items: center;
    text-align: center;
    justify-content: center;
  }
  .mob-ok-check {
    margin-bottom: 8px;
  }
  .mob-ok-check svg { width: 44px; height: 44px; }
  .mob-ok-path {
    stroke-dasharray: 30;
    stroke-dashoffset: 30;
    animation: mob-ok-path-draw 8s ease-in-out infinite;
  }
  @keyframes mob-ok-path-draw {
    0%, 65%   { stroke-dashoffset: 30; }
    72%, 100% { stroke-dashoffset: 0; }
  }
  .mob-ok-title {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 800;
    color: #1A1A1A;
    margin-bottom: 4px;
    letter-spacing: -0.01em;
  }
  .mob-ok-amount {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 4px;
  }
  .mob-ok-meta {
    font-size: 6px;
    color: rgba(0,0,0,0.5);
    margin-bottom: 14px;
  }
  .mob-ok-actions {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: 100%;
  }
  .mob-ok-act {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 6px 8px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 6px;
    font-size: 7px;
    font-weight: 600;
    color: rgba(0,0,0,0.7);
  }
  .mob-ok-act--primary {
    background: rgba(42,181,160,0.12);
    border-color: rgba(42,181,160,0.3);
    color: #1A8F7A;
  }
  .mob-ok-act-ic {
    font-size: 8px;
    font-weight: 700;
  }

  /* ── Right column staging: card (Tap-to-Pay) → ticket (Pago aprobado) ── */
  .mob-right-stage {
    position: relative;
    height: 100%;
    min-height: 0;
  }
  .mob-right-stage > .mob-card-wrap,
  .mob-right-stage > .mob-ticket-wrap {
    position: absolute;
    inset: 0;
  }

  /* ── Right column: 3D credit card (visible in Tap-to-Pay phase) ── */
  .mob-card-wrap {
    height: 100%;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1400px;
    overflow: hidden;
    padding: 0 4%;
  }
  .mob-card-stage {
    width: 100%;
    max-width: 380px;
    aspect-ratio: 1.586 / 1;
    position: relative;
    transform-style: preserve-3d;
  }
  .mob-card-3d {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    opacity: 0;
    transform: translateX(60px) rotateY(-55deg) rotateX(8deg) translateZ(0);
    animation: mob-card-enter 8s ease-in-out infinite, mob-card-float 6s ease-in-out infinite;
    will-change: transform;
  }
  @keyframes mob-card-enter {
    0%, 30%   { opacity: 0; transform: translateX(60px) rotateY(-55deg) rotateX(8deg); }
    38%       { opacity: 1; transform: translateX(0) rotateY(-14deg) rotateX(7deg); }
    58%       { opacity: 1; transform: translateX(0) rotateY(-14deg) rotateX(7deg); }
    66%, 100% { opacity: 0; transform: translateX(-40px) rotateY(28deg) rotateX(7deg); }
  }
  @keyframes mob-card-float {
    0%, 100% { translate: 0 0; }
    50%      { translate: 0 -6px; }
  }
  .mob-card-shadow {
    position: absolute;
    left: 8%;
    right: 8%;
    bottom: -22px;
    height: 18px;
    background: radial-gradient(ellipse at center, rgba(20,20,30,0.28), transparent 70%);
    filter: blur(4px);
    opacity: 0.7;
    z-index: 0;
  }
  .mob-card-front {
    position: absolute;
    inset: 0;
    border-radius: 18px;
    padding: 7% 8% 7% 8%;
    color: #fff;
    background:
      linear-gradient(135deg, #1A1F3A 0%, #2A3268 45%, #4253A5 100%);
    box-shadow:
      0 38px 60px -22px rgba(20,20,30,0.50),
      0 22px 40px -14px rgba(75,123,229,0.35),
      inset 0 1.5px 0 rgba(255,255,255,0.22),
      inset 0 -1.5px 0 rgba(0,0,0,0.20);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
    backface-visibility: hidden;
  }
  .mob-card-shine {
    position: absolute;
    inset: -30%;
    background: linear-gradient(115deg,
      transparent 35%,
      rgba(255,255,255,0.08) 47%,
      rgba(255,255,255,0.18) 50%,
      rgba(255,255,255,0.08) 53%,
      transparent 65%);
    pointer-events: none;
    animation: mob-card-shine-move 5s ease-in-out infinite;
  }
  @keyframes mob-card-shine-move {
    0%, 100% { transform: translateX(-25%); opacity: 0.6; }
    50%      { transform: translateX(28%); opacity: 1; }
  }
  .mob-card-grid {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 80% 20%, rgba(255,255,255,0.08), transparent 35%),
      radial-gradient(circle at 15% 90%, rgba(75,123,229,0.18), transparent 50%);
    pointer-events: none;
  }
  .mob-card-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    z-index: 1;
  }
  .mob-card-brand {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: #fff;
  }
  .mob-card-contact {
    transform: rotate(90deg);
    transform-origin: center;
  }
  .mob-card-chip {
    position: relative;
    z-index: 1;
    margin: 8px 0 6px;
  }
  .mob-card-chip svg {
    display: block;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }
  .mob-card-number {
    display: flex;
    gap: 14px;
    font-size: 18px;
    letter-spacing: 0.10em;
    font-weight: 700;
    position: relative;
    z-index: 1;
    text-shadow: 0 1px 2px rgba(0,0,0,0.35);
    color: #fff;
  }
  .mob-card-num-block {
    font-variant-numeric: tabular-nums;
  }
  .mob-card-num-mask {
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.85);
  }
  .mob-card-row--bottom {
    align-items: flex-end;
    margin-top: auto;
  }
  .mob-card-info {
    display: flex;
    gap: 18px;
    align-items: flex-end;
  }
  .mob-card-info-block { line-height: 1.2; }
  .mob-card-label {
    font-size: 7px;
    letter-spacing: 0.12em;
    font-weight: 700;
    color: rgba(255,255,255,0.55);
    margin-bottom: 3px;
    font-family: var(--font-body);
  }
  .mob-card-name {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    font-family: var(--font-body);
    color: #fff;
  }
  .mob-card-exp {
    font-size: 12px;
    font-weight: 700;
    font-family: var(--font-body);
    color: #fff;
    font-variant-numeric: tabular-nums;
  }
  .mob-card-network {
    text-align: right;
  }
  .mob-card-visa {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #fff;
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
  }

  /* ── Right column: Receipt-style ticket (legacy, no longer rendered) ── */
  /* ── Receipt: 80mm thermal printer style ── */
  .mob-ticket-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 0;
    height: 100%;
    padding: 0 8%;
  }
  .mob-ticket {
    width: 100%;
    max-width: 240px;
    position: relative;
    background: transparent;
    transform: translateX(40px);
    opacity: 0;
    animation: mob-ticket-emerge 8s ease-in-out infinite;
    font-family: ui-monospace, "SF Mono", Menlo, "Courier New", monospace;
    color: #1A1A1A;
    display: flex;
    flex-direction: column;
    max-height: 100%;
    filter: drop-shadow(0 18px 36px rgba(20,20,30,0.18)) drop-shadow(0 4px 12px rgba(20,20,30,0.08));
    min-height: 0;
  }
  @keyframes mob-ticket-emerge {
    0%, 62%   { transform: translateX(40px) scale(0.96); opacity: 0; }
    70%       { transform: translateX(0) scale(1); opacity: 1; }
    98%       { transform: translateX(0) scale(1); opacity: 1; }
    100%      { transform: translateX(-12px) scale(0.99); opacity: 0; }
  }

  /* Zigzag perforated edges (top + bottom) */
  .mob-ticket-zigzag {
    height: 5px;
    background:
      linear-gradient(-45deg, transparent 33.3%, #fff 33.4%) 0 0 / 6px 100%,
      linear-gradient(45deg, transparent 33.3%, #fff 33.4%) 3px 0 / 6px 100%;
    background-color: transparent;
    flex-shrink: 0;
  }
  .mob-ticket-zigzag--top { transform: rotate(180deg); }

  .mob-ticket-inner {
    flex: 1;
    background: #FFFFFE;
    padding: 8px 12px 10px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-height: 0;
    font-size: 7px;
    line-height: 1.35;
  }

  .mob-ticket-head {
    text-align: center;
    margin-bottom: 5px;
  }
  .mob-ticket-brand {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 0.12em;
    color: #1A1A1A;
    line-height: 1;
  }
  .mob-ticket-store {
    font-size: 6.5px;
    color: rgba(0,0,0,0.7);
    font-weight: 700;
    margin-top: 3px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .mob-ticket-rfc {
    font-size: 6px;
    color: rgba(0,0,0,0.5);
    margin-top: 1px;
    letter-spacing: 0.04em;
  }
  .mob-ticket-stub {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin: 4px 0 2px;
    font-size: 6.5px;
  }
  .mob-ticket-stub-row {
    display: flex;
    justify-content: space-between;
    color: rgba(0,0,0,0.55);
  }
  .mob-ticket-stub-row span:last-child {
    color: #1A1A1A;
    font-weight: 700;
  }
  .mob-ticket-divider {
    height: 0;
    border-top: 1px dashed rgba(0,0,0,0.30);
    margin: 5px 0;
  }
  .mob-ticket-divider--dashed {
    border-top: 1px dashed rgba(0,0,0,0.30);
    margin: 5px 0;
    height: 0;
    background: none;
  }

  .mob-ticket-items {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin: 1px 0;
    font-size: 6.5px;
  }
  .mob-ticket-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 6px;
    align-items: baseline;
  }
  .mob-ticket-item img {
    display: none;
  }
  .mob-ticket-item-name {
    color: #1A1A1A;
    font-weight: 600;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  .mob-ticket-item-name::before {
    content: "1× ";
    color: rgba(0,0,0,0.45);
    font-weight: 500;
  }
  .mob-ticket-item-price {
    font-weight: 700;
    color: #1A1A1A;
    font-variant-numeric: tabular-nums;
  }

  .mob-ticket-totals {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin-top: 4px;
    font-size: 6.5px;
  }
  .mob-ticket-total-row {
    display: flex;
    justify-content: space-between;
    color: rgba(0,0,0,0.65);
  }
  .mob-ticket-total-row span:last-child {
    font-weight: 700;
    color: #1A1A1A;
    font-variant-numeric: tabular-nums;
  }
  .mob-ticket-total-row--grand {
    margin-top: 4px;
    padding-top: 5px;
    border-top: 1px dashed rgba(0,0,0,0.30);
    font-size: 10px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .mob-ticket-total-row--grand span:first-child { color: #1A1A1A; }
  .mob-ticket-total-row--grand span:last-child {
    font-size: 11px;
    letter-spacing: 0;
  }

  .mob-ticket-pay {
    margin-top: 5px;
    padding: 5px 0;
    border-top: 1px dashed rgba(0,0,0,0.30);
    border-bottom: 1px dashed rgba(0,0,0,0.30);
    background: transparent;
    border-radius: 0;
  }
  .mob-ticket-pay-method {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 6.5px;
  }
  .mob-ticket-pay-brand {
    font-weight: 800;
    background: #1A1A1A;
    color: #fff;
    padding: 1px 5px;
    border-radius: 2px;
    letter-spacing: 0.06em;
    font-size: 7px;
  }
  .mob-ticket-pay-num {
    color: #1A1A1A;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .mob-ticket-pay-tag {
    margin-left: auto;
    font-size: 5.5px;
    color: rgba(0,0,0,0.55);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.10em;
  }
  .mob-ticket-pay-auth {
    font-size: 6px;
    color: rgba(0,0,0,0.55);
    margin-top: 2px;
    letter-spacing: 0.04em;
  }

  /* Thank you block */
  .mob-ticket-thanks {
    text-align: center;
    margin-top: 5px;
    margin-bottom: 5px;
  }
  .mob-ticket-thanks-text {
    font-weight: 800;
    font-size: 9px;
    color: #1A1A1A;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .mob-ticket-thanks-sub {
    font-size: 6px;
    color: rgba(0,0,0,0.55);
    margin-top: 2px;
    letter-spacing: 0.02em;
  }
  .mob-ticket-thanks-sub strong { color: #1A8F7A; font-weight: 800; }

  /* Invoice + QR */
  .mob-ticket-invoice {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 5px 6px;
    background: transparent;
    border: 1px dashed rgba(0,0,0,0.30);
    border-radius: 0;
  }
  .mob-ticket-qr {
    flex-shrink: 0;
    padding: 2px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.10);
    border-radius: 2px;
  }
  .mob-ticket-qr svg { display: block; width: 38px; height: 38px; }
  .mob-ticket-invoice-txt {
    flex: 1;
    min-width: 0;
  }
  .mob-ticket-invoice-title {
    font-weight: 800;
    font-size: 7px;
    color: #1A1A1A;
    margin-bottom: 1px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .mob-ticket-invoice-sub {
    font-size: 5.5px;
    color: rgba(0,0,0,0.55);
    line-height: 1.3;
    margin-bottom: 3px;
  }
  .mob-ticket-wa-tag {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 5.5px;
    color: #1A8F7A;
    font-weight: 800;
    background: rgba(42,181,160,0.14);
    padding: 1px 5px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .mob-ticket-wa-ic {
    font-size: 6px;
    font-weight: 800;
  }

  @media (prefers-reduced-motion: reduce) {
    .mob-layer, .mob-layer--cart, .mob-layer--tap, .mob-layer--ok,
    .mob-tap-ring, .mob-ok-path, .mob-ticket {
      animation: none !important;
    }
    .mob-layer--ok { opacity: 1; }
    .mob-layer--cart, .mob-layer--tap { opacity: 0; }
    .mob-ticket { transform: none; opacity: 1; }
    .mob-ok-path { stroke-dashoffset: 0; }
  }

  /* ── WhatsApp Carousel ── */
  .wa-carousel {
    width: 100%;
    position: relative;
    overflow: hidden;
    background: #fff;
    aspect-ratio: 16 / 10;
  }
  .wa-carousel-track {
    position: absolute;
    inset: 0;
    bottom: 28px;
  }
  .wa-carousel-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }
  .wa-carousel-slide--active {
    opacity: 1;
    pointer-events: auto;
  }
  .wa-carousel-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .wa-carousel-dots {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 8px 0;
    z-index: 2;
  }
  .wa-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: #ccc;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s, transform 0.3s;
  }
  .wa-dot--active {
    background: #25D366;
    transform: scale(1.3);
  }

  /* ── Social Commerce in Tablet ── */
  .sc-tablet-wrap {
    width: 100%;
    display: flex;
    flex-direction: column;
    background: #FAFAF8;
    aspect-ratio: 16 / 10;
  }
  .sc-tablet-tabs {
    display: flex;
    gap: 4px;
    padding: 8px 10px;
    background: #fff;
    border-bottom: 1px solid #eee;
    flex-shrink: 0;
  }
  .sc-ttab {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 6px 12px;
    border-radius: 100px;
    border: 1px solid #e0e0e0;
    background: #fff;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.25s ease;
    white-space: nowrap;
  }
  .sc-ttab:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .sc-ttab--active {
    background: var(--color-text-primary);
    color: #fff;
    border-color: var(--color-text-primary);
  }
  .sc-ttab--active:hover {
    color: #fff;
    border-color: var(--color-text-primary);
  }
  .sc-ttab svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }
  .sc-tablet-panels {
    flex: 1;
    position: relative;
    overflow: hidden;
  }
  .sc-tablet-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .sc-tablet-img--active {
    opacity: 1;
  }

  /* Pill navigation */
  .tablet-nav {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }

  .tablet-nav-track {
    position: relative;
    display: inline-flex;
    background: rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-full, 9999px);
    padding: 3px;
    gap: 2px;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .tablet-nav-indicator {
    position: absolute;
    top: 3px;
    bottom: 3px;
    left: 3px;
    width: 0;
    background: rgba(255, 255, 255, 0.15);
    border-radius: calc(var(--radius-full, 9999px) - 2px);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    z-index: 0;
  }

  .tablet-nav-pill {
    position: relative;
    z-index: 1;
    padding: 8px 16px;
    font-family: var(--font-body, system-ui);
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.45);
    background: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.3s ease;
    line-height: 1;
  }

  .tablet-nav-pill:hover:not(.active) {
    color: rgba(255, 255, 255, 0.7);
  }

  .tablet-nav-pill.active {
    color: #fff;
    font-weight: 600;
  }

  @media (max-width: 1023px) {
    .tablet-nav-pill {
      padding: 6px 12px;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 767px) {
    .tablet-nav-track {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      max-width: calc(100vw - 32px);
      scrollbar-width: none;
    }
    .tablet-nav-track::-webkit-scrollbar { display: none; }
    .tablet-nav-pill {
      padding: 6px 10px;
      font-size: 0.6875rem;
    }
  }

  /* ── Mobile: Stacked Cards layout ── */
  @media (max-width: 767px) {
    /* Hide the entire desktop tablet UI */
    .hero-tablet-section {
      height: auto;
      padding: 0;
      background: #fff;
      /* overflow: clip (instead of hidden) so descendant position:sticky still works */
      overflow-x: clip;
    }
    .hero-tablet-sticky {
      position: relative;
      height: auto;
      padding: 0;
      overflow-x: clip;
    }
    .tablet-section-header,
    .tablet-3col,
    .tablet-pills-col,
    .hero-tablet-wrapper,
    .tablet-info-block {
      display: none !important;
    }

    /* ── Mobile Cards Styles ── */
    .mobile-cards { display: block !important; padding: 0 0 16px; }

    /* Sticky chip nav (mirrors the desktop sidebar — all 4 always visible) */
    .mc-tabs {
      position: sticky;
      top: 64px; /* clears the global fixed nav (~71px) */
      z-index: 5;
      display: flex;
      gap: 6px;
      padding: 12px 16px;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      -webkit-overflow-scrolling: touch;
      /* Solid bg (no backdrop-filter on mobile per perf rules) */
      background: #ffffff;
      border-bottom: 1px solid rgba(0,0,0,0.06);
      box-shadow: 0 1px 0 rgba(0,0,0,0.02);
    }
    .mc-tabs::-webkit-scrollbar { display: none; }

    .mc-tab {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      flex-shrink: 0;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(0,0,0,0.04);
      color: rgba(0,0,0,0.55);
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: -0.01em;
      text-decoration: none;
      transition: background 0.2s ease, color 0.2s ease;
      scroll-snap-align: start;
    }
    .mc-tab:hover { color: #1A1A1A; }
    .mc-tab.active {
      background: #1A1A1A;
      color: #fff;
    }
    .mc-tab-num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: rgba(0,0,0,0.08);
      color: rgba(0,0,0,0.55);
      font-size: 10px;
      font-weight: 800;
      transition: background 0.2s ease, color 0.2s ease;
    }
    .mc-tab.active .mc-tab-num {
      background: rgba(255,255,255,0.2);
      color: #fff;
    }

    .mc-step { padding: 32px 0; scroll-margin-top: 130px; background: #fff; }
    .mc-step--alt { background: #f5f5f7; }
    /* Step 4 = Automatiza → black variant, like desktop */
    #mc-step-4 { background: #0a0a0a; }
    #mc-step-4 .mc-step-title { color: #fff; }
    #mc-step-4 .mc-step-eyebrow { color: rgba(255,255,255,0.55); }
    #mc-step-4 .mc-card { background: #1a1a1d; box-shadow: 0 2px 16px rgba(0,0,0,0.4); }
    #mc-step-4 .mc-card-title { color: #fff; }
    #mc-step-4 .mc-card-desc { color: rgba(255,255,255,0.62); }

    .mc-step-header { padding: 0 20px; margin-bottom: 18px; }
    .mc-step-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--font-display); font-size: 0.6875rem; font-weight: 700;
      letter-spacing: 0.22em; text-transform: uppercase; color: rgba(0,0,0,0.45);
      margin-bottom: 10px;
    }
    .mc-step-eyebrow::before {
      content: ""; width: 18px; height: 1px; background: currentColor; opacity: 0.5;
    }
    .mc-step-num {
      display: inline-flex; align-items: center; justify-content: center;
      width: 24px; height: 24px; border-radius: 50%;
      background: rgba(0,0,0,0.08); color: rgba(0,0,0,0.55);
      font-family: var(--font-display); font-size: 11px; font-weight: 700;
      margin-right: 6px;
    }
    #mc-step-4 .mc-step-num { background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.7); }
    .mc-step-title {
      font-family: var(--font-display); font-size: clamp(1.5rem, 6vw, 1.875rem);
      font-weight: 800; color: #0a0a0a; line-height: 1.05; letter-spacing: -0.025em;
      margin: 0;
    }

    .mc-carousel {
      display: flex; gap: 12px; padding: 0 20px;
      overflow-x: auto; scroll-snap-type: x mandatory;
      scrollbar-width: none; -ms-overflow-style: none;
      -webkit-overflow-scrolling: touch;
    }
    .mc-carousel::-webkit-scrollbar { display: none; }

    .mc-card {
      flex: 0 0 85%; scroll-snap-align: center;
      background: #fff; border-radius: 14px; overflow: hidden;
      box-shadow: 0 12px 32px rgba(0,0,0,0.08), 0 4px 8px rgba(0,0,0,0.04);
    }
    .mc-step--alt .mc-card { background: #fff; }

    .mc-card-visual {
      width: 100%; aspect-ratio: 4/3; overflow: hidden;
      background: #f0f0f0;
    }
    .mc-card-visual--dark { background: #111; }
    .mc-card-visual img,
    .mc-card-visual video {
      width: 100%; height: 100%; object-fit: cover;
    }

    /* ── Mini Apartados UI ── */
    .mc-apt-visual { background: #fff; padding: 12px; }
    .mc-apt-ui { font-family: var(--font-body); font-size: 11px; color: #333; }
    .mc-apt-topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
    .mc-apt-title { font-weight: 700; font-size: 12px; color: #1a1a2e; }
    .mc-apt-badge { font-size: 9px; font-weight: 600; padding: 2px 8px; border-radius: 99px; border: 1px solid #2AB5A0; color: #2AB5A0; }
    .mc-apt-client { color: #888; font-size: 10px; margin-bottom: 10px; }
    .mc-apt-product { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; padding: 8px; background: #fafafa; border-radius: 8px; }
    .mc-apt-thumb { width: 32px; height: 32px; border-radius: 6px; background: #f0c4c4; flex-shrink: 0; }
    .mc-apt-name { font-weight: 700; font-size: 11px; color: #1a1a2e; }
    .mc-apt-meta { font-size: 10px; color: #888; }
    .mc-apt-payments { display: flex; flex-direction: column; gap: 4px; margin-bottom: 8px; }
    .mc-apt-row { display: flex; justify-content: space-between; font-size: 10px; }
    .mc-apt-paid { color: #2AB5A0; font-weight: 600; }
    .mc-apt-pending { color: #E8A838; font-weight: 600; }
    .mc-apt-bar { height: 4px; background: #eee; border-radius: 4px; overflow: hidden; margin-bottom: 4px; }
    .mc-apt-fill { height: 100%; width: 60%; background: linear-gradient(90deg, #2AB5A0, #4B7BE5); border-radius: 4px; }
    .mc-apt-summary { font-size: 9px; color: #888; text-align: center; }

    /* ── Mini Catálogo UI ── */
    .mc-cat-visual { background: #fff; padding: 14px; }
    .mc-cat-ui { font-family: var(--font-body); color: #333; -webkit-font-smoothing: antialiased; }
    .mc-cat-topbar { display: flex; align-items: baseline; gap: 6px; margin-bottom: 10px; }
    .mc-cat-title { font-weight: 700; font-size: 13px; color: #1a1a2e; }
    .mc-cat-count { font-size: 11px; color: #999; }
    .mc-cat-tabs { display: flex; gap: 12px; margin-bottom: 10px; padding-bottom: 7px; border-bottom: 1px solid #eee; }
    .mc-cat-tab { font-size: 11px; color: #999; }
    .mc-cat-tab--active { color: #4B7BE5; font-weight: 600; border-bottom: 2px solid #4B7BE5; padding-bottom: 5px; margin-bottom: -8px; }
    .mc-cat-header { display: grid; grid-template-columns: 1fr 44px 1fr; gap: 6px; padding: 4px 0; font-size: 9px; color: #aaa; text-transform: uppercase; font-weight: 600; letter-spacing: 0.04em; }
    .mc-cat-row { display: grid; grid-template-columns: 1fr 44px 1fr; gap: 6px; align-items: center; padding: 6px 0; border-bottom: 1px solid #f5f5f5; }
    .mc-cat-row--alert { background: #fff5f5; margin: 0 -14px; padding-left: 14px; padding-right: 14px; }
    .mc-cat-col-name { display: flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .mc-cat-thumb { width: 28px; height: 28px; border-radius: 6px; object-fit: cover; flex-shrink: 0; image-rendering: -webkit-optimize-contrast; }
    .mc-cat-col-stock { text-align: center; }
    .mc-cat-pill { display: inline-block; font-size: 11px; font-weight: 700; min-width: 24px; text-align: center; padding: 2px 6px; border-radius: 6px; }
    .mc-cat-pill--ok { background: #E8F5E9; color: #2e7d32; }
    .mc-cat-pill--low { background: #FFF3E0; color: #e65100; }
    .mc-cat-col-loc { display: flex; flex-wrap: wrap; gap: 3px; }
    .mc-cat-loc { font-size: 9px; padding: 2px 5px; border-radius: 4px; background: #f0f0f0; color: #666; white-space: nowrap; }

    .mc-card-body { padding: 16px 18px 20px; }
    .mc-card-title {
      font-family: var(--font-display); font-size: 17px; font-weight: 700;
      color: #0a0a0a; margin-bottom: 6px; letter-spacing: -0.01em;
    }
    .mc-card-desc {
      font-family: var(--font-body); font-size: 13.5px;
      color: rgba(0,0,0,0.62); line-height: 1.55;
    }

    /* Single-card steps: make card full width */
    .mc-carousel:has(.mc-card:only-child) .mc-card {
      flex: 0 0 100%;
    }
  }


  /* ═══════════════════════════════════════════
     BLOQUE 2.3b: Social Commerce
     ═══════════════════════════════════════════ */
  .social-commerce-section {
    padding: clamp(80px, 10vw, 140px) 0 clamp(64px, 8vw, 100px);
    background: #FFFFFF;
    position: relative;
    overflow: hidden;
    border-top: 1px solid rgba(0,0,0,0.04);
  }
  .sc-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }
  .sc-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto clamp(40px, 6vw, 72px);
  }
  .sc-eyebrow {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    margin-bottom: 12px;
  }
  .sc-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin: 0 0 16px;
  }
  .sc-subtitle {
    font-size: clamp(0.9375rem, 1.3vw, 1.125rem);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* Tabs */
  .sc-tabs {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: clamp(32px, 4vw, 48px);
  }
  .sc-tab {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 100px;
    border: 1.5px solid rgba(0,0,0,0.1);
    background: #fff;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.25s ease;
  }
  .sc-tab:hover { border-color: rgba(0,0,0,0.2); }
  .sc-tab--active {
    background: var(--color-text-primary);
    color: #fff;
    border-color: var(--color-text-primary);
  }
  .sc-tab-icon { display: flex; align-items: center; }

  /* Sync badge */
  .sc-sync-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-secondary);
    margin-bottom: clamp(24px, 3vw, 40px);
  }
  .sc-sync-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #2AB5A0;
    flex-shrink: 0;
  }

  /* Flow panels */
  .sc-flow {
    margin-bottom: clamp(40px, 6vw, 64px);
    border-radius: var(--radius-xl, 16px);
    overflow: hidden;
    position: relative;
  }
  .sc-flow-panel { display: none; }
  .sc-flow-panel--active { display: block; }
  .sc-flow-img { width: 100%; height: auto; display: block; }

  /* No entrance animation — content visible immediately */

  /* ═══ OPCIÓN A: Text Reveal por Scroll ═══ */
  .tr-section {
    position: relative;
    height: 200vh;
    background: #0A0A0A;
  }

  .tr-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Aurora blobs */
  .tr-aurora {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .tr-aurora-blob {
    position: absolute;
    border-radius: 50%;
    opacity: 0.12;
  }

  .tr-aurora-blob-1 {
    width: 500px;
    height: 500px;
    top: -10%;
    left: -10%;
    background: radial-gradient(circle, #4B7BE5 0%, transparent 70%);
  }

  .tr-aurora-blob-2 {
    width: 400px;
    height: 400px;
    bottom: -10%;
    right: -10%;
    background: radial-gradient(circle, #2AB5A0 0%, transparent 70%);
  }

  @media (max-width: 767px) {
    .tr-aurora-blob { display: none; }
  }

  .tr-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    padding: 0 clamp(24px, 5vw, 64px);
    text-align: center;
  }

  .tr-text {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4.5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.03em;
    color: rgba(255, 255, 255, 0.15);
    margin: 0;
  }

  .tr-text :global(.tr-word) {
    display: inline;
    transition: color 0.15s ease;
  }

  .tr-text :global(.tr-word.lit) {
    color: #fff;
  }

  /* ═══ OPCIÓN B: Flip Words ═══ */
  .fw-section {
    position: relative;
    min-height: 100vh;
    background: #0A0A0A;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .fw-aurora {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .fw-aurora-blob {
    position: absolute;
    border-radius: 50%;
    opacity: 0.12;
  }

  .fw-aurora-blob-1 {
    width: 500px;
    height: 500px;
    top: -10%;
    left: -10%;
    background: radial-gradient(circle, #4B7BE5 0%, transparent 70%);
  }

  .fw-aurora-blob-2 {
    width: 400px;
    height: 400px;
    bottom: -10%;
    right: -10%;
    background: radial-gradient(circle, #2AB5A0 0%, transparent 70%);
  }

  @media (max-width: 767px) {
    .fw-aurora-blob { display: none; }
  }

  .fw-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 clamp(24px, 5vw, 64px);
  }

  .fw-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.035em;
    color: #fff;
  }

  .fw-flipper {
    display: inline-block;
    position: relative;
    min-width: 4em;
    vertical-align: bottom;
  }

  .fw-word {
    display: block;
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    opacity: 0;
    filter: blur(8px);
    transform: translateY(30px);
    transition: opacity 0.4s ease, filter 0.4s ease, transform 0.4s ease;
    color: #4B7BE5;
  }

  .fw-word--active {
    position: relative;
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }

  .fw-word--exit {
    opacity: 0;
    filter: blur(8px);
    transform: translateY(-30px);
  }

  /* ═══ Pattern Interrupt: Zoom Typo (estilo Apple) ═══ */
  .zt-section {
    position: relative;
    height: 300vh;
    background: #0A0A0A;
  }

  .zt-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .zt-text-wrap {
    position: relative;
    width: 100%;
    text-align: center;
    padding: 0 clamp(24px, 5vw, 64px);
  }

  .zt-text {
    font-family: var(--font-display);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    color: #fff;
    margin: 0;
    /* Start scale — huge, only middle letters visible */
    font-size: clamp(3rem, 8vw, 6rem);
    transform: scale(var(--zt-scale, 8));
    transform-origin: center center;
  }

  .zt-strike-text {
    position: relative;
    text-decoration: line-through;
    text-decoration-color: transparent;
    text-decoration-thickness: 0.06em;
    transition: text-decoration-color 0.5s ease, color 0.5s ease 0.1s;
  }

  .zt-strike-text.struck {
    text-decoration-color: #E53E3E;
    color: rgba(255, 255, 255, 0.3);
  }

  @media (prefers-reduced-motion: reduce) {
    .zt-text {
      transform: scale(1) !important;
    }
    .zt-section {
      height: auto;
    }
  }

  /* ═══════════════════════════════════════════
     Inventario Inteligente Multisucursal
     ═══════════════════════════════════════════ */
  .inv-intel-section {
    background: transparent;
    padding: clamp(80px, 10vw, 140px) 0 clamp(40px, 5vw, 64px);
  }
  .inv-intel-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }

  /* Hero: text + visual */
  .inv-intel-hero {
    display: flex;
    flex-direction: column;
    gap: clamp(32px, 5vw, 64px);
    margin-bottom: clamp(56px, 8vw, 96px);
  }
  @media (min-width: 1024px) {
    .inv-intel-hero {
      flex-direction: row;
      align-items: center;
    }
  }
  .inv-intel-text {
    flex: 1;
    min-width: 0;
  }
  .inv-intel-eyebrow {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-tertiary, #8C8C8C);
    margin-bottom: 16px;
  }
  .inv-intel-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    margin: 0 0 20px;
    max-width: 520px;
  }
  .inv-intel-desc {
    font-size: clamp(1rem, 1.3vw, 1.125rem);
    line-height: 1.65;
    color: var(--color-text-secondary);
    max-width: 480px;
    margin: 0;
  }

  /* Visual: screen mockup */
  .inv-intel-visual {
    flex: 1.2;
    min-width: 0;
  }
  .inv-intel-tablet-img {
    width: 100%;
    height: auto;
    border-radius: 24px;
    box-shadow: none;
    mix-blend-mode: multiply;
    transform: perspective(1200px) rotateY(25deg) rotateX(5deg) scale(0.95);
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .inv-intel-visual.visible .inv-intel-tablet-img {
    transform: perspective(1200px) rotateY(0deg) rotateX(0deg) scale(1);
  }
  .inv-intel-screen {
    background: #fff;
    border-radius: 20px;
    border: 1px solid rgba(0,0,0,0.06);
    overflow: hidden;
  }
  .inv-intel-screen-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .inv-intel-screen-title {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .inv-intel-screen-badge {
    font-size: 11px;
    font-weight: 700;
    color: #2AB5A0;
    background: rgba(42,181,160,0.1);
    padding: 4px 10px;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Table */
  .inv-intel-screen-body {
    padding: 0;
  }
  .inv-intel-row {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 0.6fr) 1.2fr;
    align-items: center;
    padding: 12px 20px;
    font-size: 13px;
    color: var(--color-text-secondary);
    border-bottom: 1px solid rgba(0,0,0,0.04);
    gap: 8px;
  }
  .inv-intel-row--header {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(0,0,0,0.35);
    background: rgba(0,0,0,0.02);
    padding: 10px 20px;
  }
  .inv-intel-row--highlight {
    background: rgba(42,181,160,0.04);
  }
  .inv-intel-prod {
    font-weight: 600;
    color: var(--color-text-primary);
  }
  .inv-intel-action {
    font-size: 12px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 6px;
    white-space: nowrap;
  }
  .inv-intel-action--transfer { background: rgba(75,123,229,0.1); color: #4B7BE5; }
  .inv-intel-action--restock { background: rgba(42,181,160,0.1); color: #2AB5A0; }
  .inv-intel-action--promo { background: rgba(232,168,56,0.1); color: #C08A2A; }
  .inv-intel-action--buy { background: rgba(75,123,229,0.1); color: #4B7BE5; }
  .inv-intel-action--liquidate { background: rgba(232,67,147,0.08); color: #D63384; }

  .inv-intel-screen-footer {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    font-size: 12px;
    color: rgba(0,0,0,0.4);
    border-top: 1px solid rgba(0,0,0,0.04);
  }
  .inv-intel-footer-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #2AB5A0;
    flex-shrink: 0;
  }

  /* Feature cards grid — Square style with separators */
  .inv-intel-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    background: transparent;
    border-radius: 0;
    overflow: visible;
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(0,0,0,0.08);
  }
  @media (max-width: 767px) {
    .inv-intel-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .inv-intel-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .inv-intel-card {
    padding: clamp(28px, 3vw, 40px) clamp(20px, 2.5vw, 28px);
    border-bottom: 1px solid rgba(0,0,0,0.08);
    border-right: 1px solid rgba(0,0,0,0.08);
