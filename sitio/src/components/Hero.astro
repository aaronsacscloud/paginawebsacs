    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    font-size: 12px;
    color: rgba(0,0,0,0.4);
    border-top: 1px solid rgba(0,0,0,0.04);
  }
  .inv-intel-footer-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #2AB5A0;
    flex-shrink: 0;
