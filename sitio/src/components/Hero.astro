</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.innerWidth < 768;

  // ═══ Hero floating notifications — play once, last wave stays ═══
  // No loop needed: notifs 1-3 appear and fade, notifs 4-6 appear and stay permanently.

  // ═══ Pillar Sections (Square-style accordion + iPad per pillar) ═══
  const pillarSections = document.querySelectorAll<HTMLElement>('.pillar-section');

  // Apartados phone frame animation (runs only when pos-apartados slide is active)
  let apartadosTimer: ReturnType<typeof setInterval> | null = null;
  function startApartadosLoop(slide: HTMLElement) {
    if (apartadosTimer) { clearInterval(apartadosTimer); apartadosTimer = null; }
    if (prefersReducedMotion) return;
    const frames = slide.querySelectorAll<HTMLElement>('.wa-frame');
    if (frames.length === 0) return;
    let aptActive = 0;
    frames.forEach((f, i) => { f.classList.remove('active', 'exit-left'); if (i === 0) f.classList.add('active'); });
    apartadosTimer = setInterval(() => {
      const prev = aptActive;
      aptActive = (aptActive + 1) % frames.length;
      frames.forEach((f, i) => {
        f.classList.remove('active', 'exit-left');
        if (i === prev) f.classList.add('exit-left');
        if (i === aptActive) f.classList.add('active');
      });
    }, 4000);
  }
  function stopApartadosLoop() {
    if (apartadosTimer) { clearInterval(apartadosTimer); apartadosTimer = null; }
  }

  pillarSections.forEach((section) => {
    const accs = section.querySelectorAll<HTMLElement>('.pillar-acc');
    const slides = section.querySelectorAll<HTMLDivElement>('.tablet-slide');

    function activateIdx(idx: number) {
      accs.forEach((a, i) => {
        const open = i === idx;
        a.classList.toggle('is-open', open);
        const btn = a.querySelector<HTMLButtonElement>('.pillar-acc-btn');
        if (btn) btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      slides.forEach((s, i) => s.classList.toggle('active', i === idx));
      // Trigger apartados loop if its slide just became active
      const activeSlide = slides[idx] as HTMLElement | undefined;
      if (activeSlide?.dataset.slide === 'pos-apartados') {
        startApartadosLoop(activeSlide);
      } else if (section.dataset.pillar === 'pos') {
        // Inside Vende section but on a different slide → stop the loop
        stopApartadosLoop();
      }
    }

    function closeAll() {
      accs.forEach((a) => {
        a.classList.remove('is-open');
        const btn = a.querySelector<HTMLButtonElement>('.pillar-acc-btn');
        if (btn) btn.setAttribute('aria-expanded', 'false');
      });
      if (section.dataset.pillar === 'pos') stopApartadosLoop();
    }

    accs.forEach((acc, idx) => {
      const btn = acc.querySelector<HTMLButtonElement>('.pillar-acc-btn');
      btn?.addEventListener('click', (e) => {
        // If the click was on the inner CTA link, let the link navigate
        const target = e.target as HTMLElement | null;
        if (target?.closest('.pillar-acc-cta')) return;
        if (acc.classList.contains('is-open')) {
          closeAll();
        } else {
          activateIdx(idx);
        }
      });
    });

    // Bootstrap apartados loop if its slide is the initially active one
    const initiallyActive = section.querySelector<HTMLElement>('.tablet-slide.active');
    if (initiallyActive?.dataset.slide === 'pos-apartados') startApartadosLoop(initiallyActive);
  });

  // ═══ Apple-level scroll choreography ═══
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isDesktop = window.matchMedia('(min-width: 1024px)').matches;

  if (!reduceMotion && isDesktop && pillarSections.length) {
    const aiSection = document.querySelector<HTMLElement>('.pillar-section--ai');
    const activeSet = new Set<HTMLElement>();

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        const el = e.target as HTMLElement;
        const r = e.intersectionRatio;
        el.classList.toggle('is-entering', r >= 0.15);
        el.classList.toggle('is-revealed', r >= 0.35);
        const wasActive = el.classList.contains('is-active');
        const nowActive = r >= 0.4;
        el.classList.toggle('is-active', nowActive);
        if (nowActive) activeSet.add(el); else activeSet.delete(el);
        if (nowActive && !wasActive) el.style.willChange = 'transform';
        else if (!nowActive && wasActive) el.style.willChange = 'auto';

        // Cinema mode — body dims as AI section enters
        if (el === aiSection) {
          document.body.classList.toggle('is-cinema', r >= 0.25);
        }
      });
    }, { threshold: [0, 0.15, 0.35, 0.4, 0.6, 1] });

    pillarSections.forEach((p) => io.observe(p));

    let rafId: number | null = null;
    const tick = () => {
      const vh = window.innerHeight;
      activeSet.forEach((el) => {
        const r = el.getBoundingClientRect();
        const center = (r.top + r.height / 2) - vh / 2;
        const cd = Math.max(-1, Math.min(1, center / (vh / 2)));
        el.style.setProperty('--center-distance', cd.toFixed(3));
      });
      rafId = activeSet.size > 0 ? requestAnimationFrame(tick) : null;
    };
    const onScroll = () => {
      if (rafId == null && activeSet.size > 0) rafId = requestAnimationFrame(tick);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    // Kick off once in case section is already in view at load
    onScroll();
  }

  // ═══ Mobile sticky chip nav (mc-tabs) — scrollspy + click-to-jump ═══
  const mcTabs = document.querySelectorAll<HTMLAnchorElement>('.mc-tab');
  const mcSteps = document.querySelectorAll<HTMLElement>('.mc-step[data-mc-step]');
  if (mcTabs.length && mcSteps.length) {
    const setActiveTab = (stepNum: string) => {
      mcTabs.forEach((t) => t.classList.toggle('active', t.dataset.mcTab === stepNum));
    };
    // Click → smooth scroll to the matching step
    mcTabs.forEach((tab) => {
      tab.addEventListener('click', (e) => {
        e.preventDefault();
        const stepNum = tab.dataset.mcTab;
        const target = document.getElementById(`mc-step-${stepNum}`);
        if (!target) return;
        setActiveTab(stepNum || '1');
        const globalNav = document.querySelector('header.nav') as HTMLElement | null;
        const tabsBar = document.querySelector('.mc-tabs') as HTMLElement | null;
        const offset = (globalNav?.offsetHeight ?? 71) + (tabsBar?.offsetHeight ?? 56) + 8;
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: 'smooth' });
      });
    });
    // Scrollspy: activate the tab whose step is closest to the top of the viewport
    const spyObs = new IntersectionObserver((entries) => {
      // Pick the entry with the smallest top distance that is intersecting
      let best: IntersectionObserverEntry | null = null;
      entries.forEach((e) => {
        if (e.isIntersecting && (!best || e.intersectionRatio > best.intersectionRatio)) {
          best = e;
        }
      });
      if (best) {
        const stepNum = (best.target as HTMLElement).dataset.mcStep;
        if (stepNum) setActiveTab(stepNum);
      }
    }, { rootMargin: '-30% 0px -55% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] });
    mcSteps.forEach((s) => spyObs.observe(s));
  }

  // ═══ WhatsApp Commerce — entrance reveals ═══
  const sqHeader = document.querySelector('.sq-header-reveal');
  const sqMedia = document.querySelector('.sq-media-reveal');

  if (!prefersReducedMotion) {
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          revealObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    if (sqHeader) revealObs.observe(sqHeader);
    if (sqMedia) revealObs.observe(sqMedia);
  } else {
    sqHeader?.classList.add('visible');
    sqMedia?.classList.add('visible');
  }

  // ═══ WhatsApp Commerce — image switch + bg color shift on scroll ═══
  const sqBlocks = Array.from(document.querySelectorAll<HTMLElement>('.sq-features--sc .sq-feature-block'));
  const sqImgs = Array.from(document.querySelectorAll<HTMLImageElement>('.sq-features--sc .sq-features-img'));
  const sqPhoneBg = document.querySelector<HTMLElement>('.sq-phone-bg');

  if (sqBlocks.length > 0 && sqImgs.length > 0) {
    const isMobile = window.innerWidth < 1024;
    const sqObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const block = entry.target as HTMLElement;
            const idx = sqBlocks.indexOf(block);
            const newSrc = block.dataset.sqImg;
            if (newSrc) {
              sqImgs.forEach(img => {
                img.classList.toggle('sq-img--active', img.dataset.sqSrc === newSrc);
              });
            }
            // Mark active block
            sqBlocks.forEach(b => b.classList.remove('active'));
            block.classList.add('active');
            // Update background color
            if (sqPhoneBg) {
              sqPhoneBg.dataset.bgStep = String(idx + 1);
            }
          }
        });
      },
      { threshold: isMobile ? 0.3 : 0.6, rootMargin: isMobile ? '-30% 0px -30% 0px' : '0px' }
    );
    sqBlocks.forEach(b => sqObserver.observe(b));
  }

  // ═══ Restart slide animations on scroll-into-view ═══
  // Cuando una sección con animaciones entra al viewport, reinicia
  // todas las animaciones CSS de sus hijos para que arranquen desde 0%.
  {
    const ANIM_CONTAINER_SELECTORS = [
      '.pillar-frame',          // tablet slides de cada pillar (Vende/Controla/Fideliza/Automatiza)
      '.recepcion-split',       // Recepción de mercancía
      '.loyalty-split',         // Lealtad / fideliza
      '.reco-split',            // Recomendaciones de productos
      '.axo-split',             // AI Empresarial (Axo)
      '.mc-card',               // Tarjetas del carousel mobile
    ].join(',');

    const restartContainerAnims = (container: Element) => {
      // Recopila descendientes que tienen animación activa
      const animated: Array<{ el: HTMLElement; orig: string }> = [];
      const all = container.querySelectorAll<HTMLElement>('*');
      all.forEach(el => {
        const cs = window.getComputedStyle(el);
        const name = cs.animationName;
        if (name && name !== 'none' && cs.animationDuration !== '0s') {
          animated.push({ el, orig: el.style.animation });
          el.style.animation = 'none';
        }
      });
      if (animated.length === 0) return;
      // Reflow para forzar reset
      void (container as HTMLElement).offsetHeight;
      // Restaura la animación en el siguiente frame
      requestAnimationFrame(() => {
        animated.forEach(({ el, orig }) => {
          el.style.animation = orig || '';
        });
      });
    };

    const restartObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          restartContainerAnims(entry.target);
        }
      });
    }, { threshold: 0.35 });

    document.querySelectorAll(ANIM_CONTAINER_SELECTORS).forEach(el => restartObs.observe(el));
  }

  // ═══ Inventario tablet rotate-in ═══
  const invVisual = document.querySelector('.inv-intel-visual');
  if (invVisual) {
    const invObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          invObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });
    invObs.observe(invVisual);
  }

  // ═══ OPCIÓN A: Text Reveal por Scroll ═══
  const trSection = document.getElementById('tr-section');
  const trTextEl = document.getElementById('tr-text');

  if (trSection && trTextEl) {
    // Wrap each word in a span
    const rawText = trTextEl.textContent?.trim() || '';
    trTextEl.innerHTML = rawText.split(/\s+/).map(w => `<span class="tr-word">${w}</span>`).join(' ');
    const trWords = trTextEl.querySelectorAll<HTMLElement>('.tr-word');

    let trTicking = false;
    const updateTextReveal = () => {
      const rect = trSection.getBoundingClientRect();
      const sH = trSection.offsetHeight;
      const vh = window.innerHeight;
      const scrolled = -rect.top;
      const scrollable = sH - vh;
      const progress = Math.max(0, Math.min(1, scrolled / scrollable));

      // Map progress to word illumination
      const total = trWords.length;
      trWords.forEach((word, i) => {
        const wordStart = i / total;
        const wordEnd = (i + 1) / total;
        if (progress >= wordEnd) {
          word.classList.add('lit');
        } else if (progress >= wordStart) {
          word.classList.add('lit');
        } else {
          word.classList.remove('lit');
        }
      });
    };

    window.addEventListener('scroll', () => {
      if (!trTicking) {
        requestAnimationFrame(() => { updateTextReveal(); trTicking = false; });
        trTicking = true;
      }
    }, { passive: true });
    updateTextReveal();
  }

  // ═══ OPCIÓN B: Flip Words (activar si se descomenta el HTML) ═══
  const fwFlipper = document.getElementById('fw-flipper');
  if (fwFlipper) {
    const fwWords = fwFlipper.querySelectorAll<HTMLElement>('.fw-word');
    let fwIndex = 0;
    const FW_INTERVAL = 3000;

    setInterval(() => {
      const current = fwWords[fwIndex];
      current.classList.remove('fw-word--active');
      current.classList.add('fw-word--exit');

      fwIndex = (fwIndex + 1) % fwWords.length;
      const next = fwWords[fwIndex];
      next.classList.remove('fw-word--exit');
      next.classList.add('fw-word--active');

      // Clean exit class after transition
      setTimeout(() => { current.classList.remove('fw-word--exit'); }, 400);
    }, FW_INTERVAL);
  }

  // ═══ Pattern Interrupt: Zoom Typo (estilo Apple) ═══
  const ztSection = document.getElementById('zt-section');
  const ztText = document.getElementById('zt-text');

  if (ztSection && ztText) {
    const ZT_SCALE_START = 8;
    const ZT_SCALE_END = 1;
    let ztTicking = false;
    let ztXFired = false;
    const ztStrikeText = ztText.querySelector<HTMLElement>('.zt-strike-text');

    const updateZoomTypo = () => {
      const rect = ztSection.getBoundingClientRect();
      const sH = ztSection.offsetHeight;
      const vh = window.innerHeight;
      const scrolled = -rect.top;
      const scrollable = sH - vh;
      const progress = Math.max(0, Math.min(1, scrolled / scrollable));

      // Ease-out for smooth deceleration at the end
      const eased = 1 - Math.pow(1 - progress, 3);
      const scale = ZT_SCALE_START - (ZT_SCALE_START - ZT_SCALE_END) * eased;

      ztText.style.setProperty('--zt-scale', String(scale));

      // Trigger X animation when zoom is nearly done
      if (progress > 0.85 && !ztXFired) {
        ztXFired = true;
        if (ztStrikeText) ztStrikeText.classList.add('struck');
      } else if (progress < 0.8 && ztXFired) {
        ztXFired = false;
        if (ztStrikeText) ztStrikeText.classList.remove('struck');
      }
    };

    window.addEventListener('scroll', () => {
      if (!ztTicking) {
        requestAnimationFrame(() => { updateZoomTypo(); ztTicking = false; });
        ztTicking = true;
      }
    }, { passive: true });
    updateZoomTypo();
  }

  // ═══ Reels — staggered entrance on scroll ═══
  const reelCards = document.querySelectorAll<HTMLElement>('.reel-card');
  if (reelCards.length > 0) {
    const reelObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).classList.add('in-view');
          reelObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    reelCards.forEach((card) => reelObs.observe(card));
  }

  // ═══ Scrollytelling — sticky image + features ═══
  const scrollyItems = document.querySelectorAll<HTMLElement>('.scrolly-item');
  const scrollyImgs = document.querySelectorAll<HTMLElement>('.scrolly-img');
  const scrollyBgs = document.querySelectorAll<HTMLElement>('.scrolly-bg');

  if (scrollyItems.length > 0 && scrollyImgs.length > 0) {
    const scrollyObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const idx = (entry.target as HTMLElement).dataset.scrollyIdx;
            scrollyItems.forEach((item) =>
              item.classList.toggle('active', item.dataset.scrollyIdx === idx)
            );
            scrollyImgs.forEach((img) =>
              img.classList.toggle('active', img.dataset.scrollyImg === idx)
            );
            scrollyBgs.forEach((bg) =>
              bg.classList.toggle('active', bg.dataset.scrollyBg === idx)
            );
          }
        });
      },
      { rootMargin: '-35% 0px -35% 0px' }
    );
    scrollyItems.forEach((item) => scrollyObserver.observe(item));
  }




  // ═══ Platform accordion ═══
  const accordionItems = document.querySelectorAll<HTMLDivElement>('.accordion-item');
  const platformMockups = document.querySelectorAll<HTMLDivElement>('.platform-mockup');

  const accordionToMockup: Record<string, string> = {
    pos: 'pos',
    stock: 'stock',
    crm: 'crm',
    reports: 'reports',
    ai: 'ai',
  };

  if (accordionItems.length > 0) {
    let activeAccordion = 0;
    let accInterval: ReturnType<typeof setInterval> | null = null;
    const ACC_MS = 5000;

    function setActiveAccordion(index: number) {
      const ucId = accordionItems[index]?.dataset.accordion || '';

      accordionItems.forEach((item, i) => {
        const isActive = i === index;
        item.classList.toggle('active', isActive);
        const btn = item.querySelector('.accordion-header');
        if (btn) btn.setAttribute('aria-expanded', String(isActive));
      });

      const mockupId = accordionToMockup[ucId] || '';
      platformMockups.forEach((m) => m.classList.toggle('active', m.dataset.mockup === mockupId));

      activeAccordion = index;
    }

    function startAccCycle() {
      stopAccCycle();
      accInterval = setInterval(() => {
        setActiveAccordion((activeAccordion + 1) % accordionItems.length);
      }, ACC_MS);
    }

    function stopAccCycle() {
      if (accInterval) { clearInterval(accInterval); accInterval = null; }
    }

    accordionItems.forEach((item, i) => {
      const header = item.querySelector('.accordion-header');
      if (header) {
        header.addEventListener('click', () => {
          stopAccCycle();
          setActiveAccordion(i);
          startAccCycle();
        });
      }
    });

    if (!prefersReducedMotion) startAccCycle();
    setActiveAccordion(0);
  }

  // ═══ WhatsApp Carousel ═══
  (() => {
    const slides = document.querySelectorAll<HTMLElement>('.wa-carousel-slide');
    const dots = document.querySelectorAll<HTMLElement>('.wa-dot');
    if (!slides.length) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval>;
    const INTERVAL = 4000;

    function goTo(idx: number) {
      slides[current]?.classList.remove('wa-carousel-slide--active');
      dots[current]?.classList.remove('wa-dot--active');
      current = idx % slides.length;
      slides[current]?.classList.add('wa-carousel-slide--active');
      dots[current]?.classList.add('wa-dot--active');
    }

    function startAutoplay() {
      timer = setInterval(() => goTo(current + 1), INTERVAL);
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        clearInterval(timer);
        const idx = parseInt(dot.dataset.waSlide || '0', 10);
        goTo(idx);
        startAutoplay();
      });
    });

    if (!prefersReducedMotion) startAutoplay();

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) clearInterval(timer);
      else if (!prefersReducedMotion) startAutoplay();
    });
  })();

  // ═══ Social Commerce Tabs + Entrance ═══
  (() => {
    const section = document.querySelector<HTMLElement>('.social-commerce-section');
    const tabs = document.querySelectorAll<HTMLButtonElement>('.sc-tab');
    const panels = document.querySelectorAll<HTMLElement>('.sc-flow-panel');

    if (section && !prefersReducedMotion) {
      const io = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          section.classList.add('sc-visible');
          io.disconnect();
        }
      }, { threshold: 0.1 });
      io.observe(section);
    } else if (section) {
      section.classList.add('sc-visible');
    }

    function switchToTab(idx: number) {
      const tab = tabs[idx];
      if (!tab) return;
      const platform = tab.dataset.scPlatform;
      if (!platform) return;
      tabs.forEach(t => t.classList.remove('sc-tab--active'));
      tab.classList.add('sc-tab--active');
      panels.forEach(p => {
        const isTarget = p.dataset.scPanel === platform;
        p.classList.remove('sc-flow-panel--active');
        if (isTarget) p.classList.add('sc-flow-panel--active');
      });
    }

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => switchToTab(i));
    });
  })();

  // ═══ Ops admin section — header reveal ═══
  const opsAdminSection = document.querySelector<HTMLElement>('.ops-admin-section');
  if (opsAdminSection && !reduceMotion) {
    const opsObs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.intersectionRatio >= 0.18) {
          (e.target as HTMLElement).classList.add('is-entering');
          opsObs.unobserve(e.target);
        }
      });
    }, { threshold: [0, 0.18, 0.4] });
    opsObs.observe(opsAdminSection);
  } else if (opsAdminSection) {
    opsAdminSection.classList.add('is-entering');
  }

  // ═══ Loyalty pro section — header reveal (mirror of ops-admin) ═══
  const loyaltyProSection = document.querySelector<HTMLElement>('.loyalty-pro-section');
  if (loyaltyProSection && !reduceMotion) {
    const loyObs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.intersectionRatio >= 0.18) {
          (e.target as HTMLElement).classList.add('is-entering');
          loyObs.unobserve(e.target);
        }
      });
    }, { threshold: [0, 0.18, 0.4] });
    loyObs.observe(loyaltyProSection);
  } else if (loyaltyProSection) {
    loyaltyProSection.classList.add('is-entering');
  }

  // ═══ Inventory intel cards — staggered fade-up on scroll ═══
  const intelCards = document.querySelectorAll<HTMLElement>('.inv-intel-card');
  if (intelCards.length > 0) {
    const intelObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const card = entry.target as HTMLElement;
          const idx = Array.from(intelCards).indexOf(card);
          const delay = (idx % 3) * 100;
          setTimeout(() => card.classList.add('in-view'), delay);
          intelObs.unobserve(card);
        }
      });
    }, { threshold: 0.1 });
    intelCards.forEach((card) => intelObs.observe(card));
  }

  // ═══ Tools cards — staggered fade-up on scroll ═══
  const toolsCards = document.querySelectorAll<HTMLElement>('.htv2-card');
  if (toolsCards.length > 0) {
    const toolsObs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const card = entry.target as HTMLElement;
          const row = card.parentElement;
          const siblings = row ? Array.from(row.children) : [card];
          const sibIdx = siblings.indexOf(card);
          const delay = sibIdx * 120; // stagger within each row
          setTimeout(() => card.classList.add('in-view'), delay);
          toolsObs.unobserve(card);
        }
      });
    }, { threshold: 0.15 });
    toolsCards.forEach((card) => toolsObs.observe(card));
  }
</script>
