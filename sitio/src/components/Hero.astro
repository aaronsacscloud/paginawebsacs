---
import BeforeAfter from './BeforeAfter.astro';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
}

const {
  eyebrow = 'Comercio Consciente',
  title,
  subtitle,
  primaryCTA = { label: 'Empieza gratis', href: '/contacto' },
  secondaryCTA = { label: 'Ver demo', href: '/producto' },
} = Astro.props;

const steps = [
  {
    id: 'pos',
    step: 1,
    verb: 'Vende',
    title: 'Vende más en cada punto',
    bgKey: 'pos',
    subs: [
      { id: 'pos-pdv', label: 'Punto de Venta', desc: 'Cobra con tarjeta, efectivo o transferencia desde cualquier dispositivo.', image: '/images/screen-pos.png' },
      { id: 'pos-ecommerce', label: 'eCommerce', desc: 'Tu tienda en línea conectada al mismo inventario y clientes.', image: null },
      { id: 'pos-whatsapp', label: 'WhatsApp', desc: 'Vende y da seguimiento directo por WhatsApp Business.', image: null },
    ],
  },
  {
    id: 'stock',
    step: 2,
    verb: 'Controla',
    title: 'Controla tu stock en tiempo real',
    bgKey: 'stock',
    subs: [
      { id: 'stock-inventario', label: 'Inventario multi-sucursal', desc: 'Stock por sucursal y CEDIS en tiempo real, siempre sincronizado.', image: null },
      { id: 'stock-traspasos', label: 'Traspasos entre CEDIS', desc: 'Mueve mercancía entre bodegas y sucursales con un clic.', image: null },
      { id: 'stock-alertas', label: 'Alertas de reabasto', desc: 'Recibe alertas automáticas cuando un producto está por agotarse.', image: null },
    ],
  },
  {
    id: 'crm',
    step: 3,
    verb: 'Fideliza',
    title: 'Fideliza a cada cliente',
    bgKey: 'crm',
    subs: [
      { id: 'crm-lealtad', label: 'Programa de lealtad', desc: 'Programa de puntos integrado al cobro, sin apps extra.', image: null },
      { id: 'crm-seguimiento', label: 'Seguimiento de clientes', desc: 'Historial de compras, preferencias y seguimiento automático.', image: null },
      { id: 'crm-promos', label: 'Promociones', desc: 'Lanza promociones personalizadas por segmento o comportamiento.', image: null },
    ],
  },
  {
    id: 'ai',
    step: 4,
    verb: 'Automatiza',
    title: 'Automatiza con inteligencia',
    bgKey: 'ai',
    subs: [
      { id: 'ai-reabasto', label: 'Sugerencias de reabasto', desc: 'AXO analiza tus ventas y te sugiere qué reabastecer y cuándo.', image: null },
      { id: 'ai-prediccion', label: 'Predicción de demanda', desc: 'Anticipa la demanda por producto, sucursal y temporada.', image: null },
      { id: 'ai-ordenes', label: 'Órdenes automáticas', desc: 'Genera órdenes de compra automáticas con un clic.', image: null },
    ],
  },
];

const allSubs = steps.flatMap((s, stepIdx) =>
  s.subs.map((sub) => ({ ...sub, stepIdx, stepId: s.id, stepTitle: s.title, bgKey: s.bgKey }))
);

// Backward compat for platform accordion
const useCases = [
  { id: 'pos', title: 'Vende desde cualquier punto', desc: 'Convierte cualquier dispositivo en un punto de venta. Cobra con tarjeta, efectivo o transferencia en segundos.', cta: 'Ver más' },
  { id: 'stock', title: 'Controla stock sin esfuerzo', desc: 'Alertas de reabasto, movimientos entre sucursales y conteo rápido desde el celular.', cta: 'Ver más' },
  { id: 'crm', title: 'Fideliza a cada cliente', desc: 'Captura datos automáticamente, segmenta por comportamiento y lanza promociones personalizadas.', cta: 'Ver más' },
  { id: 'reports', title: 'Reportes que sí entiendes', desc: 'Dashboards claros con las métricas que importan. Sin Excel, sin complicaciones.', cta: 'Ver más' },
  { id: 'ai', title: 'IA que te asesora', desc: 'AXO analiza tus datos y te sugiere qué hacer: reabastecer, lanzar promo o ajustar precio.', cta: 'Ver más' },
];
---

<!-- ═══ BLOQUE 1: Banner — Fondo claro con texturas ═══ -->
<section class="hero-banner" id="hero-section">
  <!-- Texturas decorativas -->
  <div class="hero-shapes" aria-hidden="true">
    <div class="shape shape-circle-1"></div>
    <div class="shape shape-circle-2"></div>
    <div class="shape shape-square-1"></div>
    <div class="shape shape-dots"></div>
  </div>

  <div class="hero-banner-content">
    <div class="hero-text">
      <h1 class="hero-title">{title}</h1>
      <p class="hero-subtitle">{subtitle}</p>
      <div class="hero-ctas">
        <a href={primaryCTA.href} class="hero-btn hero-btn-filled">
          {primaryCTA.label}
        </a>
        <a href={secondaryCTA.href} class="hero-btn hero-btn-outline">
          {secondaryCTA.label}
        </a>
      </div>

      <!-- Credibility badges -->
      <div class="hero-bottom-bar">
        <div class="hero-badges">
          <div class="hero-badge">
            <svg class="hero-badge-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M10 1l2.39 4.84L18 6.71l-4 3.9.94 5.5L10 13.48l-4.94 2.63.94-5.5-4-3.9 5.61-.87L10 1z" fill="#E8A838"/>
            </svg>
            <div>
              <span class="hero-badge-value">4.8/5</span>
              <span class="hero-badge-label">Google Reviews</span>
            </div>
          </div>
          <div class="hero-badge-divider"></div>
          <div class="hero-badge">
            <svg class="hero-badge-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <rect x="2" y="4" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M6 10h8M10 7v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <div>
              <span class="hero-badge-value">+3,000</span>
              <span class="hero-badge-label">Marcas activas en México y Latam</span>
            </div>
          </div>
          <div class="hero-badge-divider"></div>
          <div class="hero-badge">
            <svg class="hero-badge-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M10 2a8 8 0 100 16 8 8 0 000-16z" stroke="currentColor" stroke-width="1.5"/>
              <path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div>
              <span class="hero-badge-value">99.9%</span>
              <span class="hero-badge-label">Uptime</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Hero image + floating notifications -->
    <div class="hero-visual">
      <div class="hero-image-wrapper">
        <img
          src="/images/hero-sacs-store.png"
          alt="Persona usando SACS en tablet en su tienda de ropa"
          class="hero-image"
          width="900"
          height="600"
          loading="eager"
        />
        <!-- Notificaciones animadas sobre la imagen -->
        <div class="hero-notif hero-notif-1" aria-hidden="true">
          <div class="hero-notif-icon hero-notif-icon-loyalty">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.325 0-4.47-.744-6.227-2.01l-.435-.326-2.847.954.954-2.847-.326-.435A9.956 9.956 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>
          </div>
          <div class="hero-notif-body">
            <span class="hero-notif-title">Fidelización</span>
            <span class="hero-notif-msg">5 seguimientos pendientes de clientes</span>
          </div>
          <span class="hero-notif-badge">5</span>
        </div>

        <div class="hero-notif hero-notif-2" aria-hidden="true">
          <div class="hero-notif-icon hero-notif-icon-shop">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M20 4H4v2l1 1v11h14V7l1-1V4zM9 18v-4h6v4H9zm9 0h-1v-5a1 1 0 00-1-1H8a1 1 0 00-1 1v5H6V7.5l-.5-.5h13l-.5.5V18z"/><path d="M3 2h18a1 1 0 011 1v1H2V3a1 1 0 011-1z"/></svg>
          </div>
          <div class="hero-notif-body">
            <span class="hero-notif-title">Tienda en línea</span>
            <span class="hero-notif-msg">Pedido #384 — $1,290</span>
          </div>
          <span class="hero-notif-badge">+1</span>
        </div>

        <div class="hero-notif hero-notif-3" aria-hidden="true">
          <div class="hero-notif-icon hero-notif-icon-inventory">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </div>
          <div class="hero-notif-body">
            <span class="hero-notif-title">Nivelación de inventario</span>
            <span class="hero-notif-msg">Transferir 40 uds. a Suc. Centro</span>
          </div>
          <span class="hero-notif-time">Sugerencia</span>
        </div>

        <div class="hero-notif hero-notif-4" aria-hidden="true">
          <div class="hero-notif-icon hero-notif-icon-receiving">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M12 2L2 7v10l10 5 10-5V7L12 2z" fill="none" stroke="#fff" stroke-width="1.5"/><path d="M12 12v10M2 7l10 5 10-5" fill="none" stroke="#fff" stroke-width="1.5"/><path d="M8 4.5l8 4" fill="none" stroke="#fff" stroke-width="1.5"/></svg>
          </div>
          <div class="hero-notif-body">
            <span class="hero-notif-title">Recepción de mercancía</span>
            <span class="hero-notif-msg">OC #192 llega mañana — 120 pzas.</span>
          </div>
          <span class="hero-notif-time">Mañana</span>
        </div>

        <div class="hero-notif hero-notif-5" aria-hidden="true">
          <div class="hero-notif-icon hero-notif-icon-shrink">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M12 9v2m0 4h.01M5.07 19H18.93a2 2 0 001.73-3L13.73 4a2 2 0 00-3.46 0L3.34 16a2 2 0 001.73 3z" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="hero-notif-body">
            <span class="hero-notif-title">Alerta de merma</span>
            <span class="hero-notif-msg">Suc. Polanco: 2.3% esta semana</span>
          </div>
          <span class="hero-notif-badge">!</span>
        </div>

        <div class="hero-notif hero-notif-6" aria-hidden="true">
          <div class="hero-notif-icon hero-notif-icon-restock">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M23 4l-6 6M17 4h6v6M1 20l6-6m0 6H1v-6" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="hero-notif-body">
            <span class="hero-notif-title">Reabasto automático</span>
            <span class="hero-notif-msg">12 SKUs bajo mínimo en CEDIS</span>
          </div>
          <span class="hero-notif-badge">12</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ BLOQUE 2: Tablet — paso a paso ═══ -->
<section class="hero-tablet-section" id="tablet-section">
  <div class="hero-tablet-sticky">
    <!-- Fondos oaxaqueños por paso -->
    <div class="tablet-bg-patterns">
      <div class="tablet-bg-layer active" data-bg="pos"></div>
      <div class="tablet-bg-layer" data-bg="stock"></div>
      <div class="tablet-bg-layer" data-bg="crm"></div>
      <div class="tablet-bg-layer" data-bg="ai"></div>
    </div>

    <div class="tablet-section-header">
      <h2 class="tablet-section-title" id="tablet-section-title">{steps[0].title}</h2>
    </div>

    <div class="tablet-3col">
      <!-- Left: vertical pills -->
      <nav class="tablet-pills-col" aria-label="Pasos SACS">
        {steps.map((s, si) => (
          <div class={`tablet-step-group${si === 0 ? ' active' : ''}`} data-step={si}>
            <button
              class={`tablet-vpill${si === 0 ? ' active' : ''}`}
              data-tablet-step={si}
              type="button"
            >
              <span class="tablet-vpill-num">{s.step}</span>
              <span class="tablet-vpill-label">{s.verb}</span>
            </button>
            <div class="tablet-sub-list">
              {s.subs.map((sub, j) => (
                <button
                  class={`tablet-sub-pill${si === 0 && j === 0 ? ' active' : ''}`}
                  data-sub-global={allSubs.findIndex(x => x.id === sub.id)}
                  type="button"
                >
                  {sub.label}
                </button>
              ))}
            </div>
          </div>
        ))}
      </nav>

      <!-- Center: tablet -->
      <div class="hero-tablet-wrapper">
        <div class="hero-tablet-frame">
          <div class="tablet-camera"></div>
          <div class="tablet-screen">
            {/* ── Vende: Punto de Venta ── */}
            <div class="tablet-slide active" data-slide="pos-pdv">
              <img src="/images/screen-pos.png" alt="Punto de Venta SACS" class="tablet-slide-img" />
            </div>

            {/* ── Vende: eCommerce ── */}
            <div class="tablet-slide" data-slide="pos-ecommerce">
              <img src="/images/screen-ecommerce.png" alt="eCommerce SACS — Tienda en línea con catálogo y checkout" class="tablet-slide-img tablet-slide-img-dark" />
            </div>

            {/* ── Vende: WhatsApp ── */}
            <div class="tablet-slide" data-slide="pos-whatsapp">
              <div class="pm-window">
                <div class="pm-titlebar">
                  <div class="pm-dots"><span style="background:#FF5F57"></span><span style="background:#FFBD2E"></span><span style="background:#27C93F"></span></div>
                  <span class="pm-titlebar-text">WhatsApp Commerce</span>
                </div>
                <div class="pm-content pm-content-chat">
                  <div class="pm-chat-msg pm-chat-user">Hola, ¿tienen el Café Orgánico 250g?</div>
                  <div class="pm-chat-msg pm-chat-ai">¡Sí! Tenemos 128 unidades en stock. ¿Te envío el link de pago?</div>
                  <div class="pm-chat-msg pm-chat-user">Sí, 3 bolsas por favor</div>
                  <div class="pm-chat-msg pm-chat-ai">Listo, link enviado por $870. Entrega mañana 🚚</div>
                </div>
              </div>
            </div>

            {/* ── Controla: Inventario ── */}
            <div class="tablet-slide" data-slide="stock-inventario">
              <div class="pm-window">
                <div class="pm-titlebar">
                  <div class="pm-dots"><span style="background:#FF5F57"></span><span style="background:#FFBD2E"></span><span style="background:#27C93F"></span></div>
                  <span class="pm-titlebar-text">Inventario</span>
                </div>
                <div class="pm-content pm-content-list">
                  <div class="pm-list-header"><span>Producto</span><span>Stock</span><span>Estado</span></div>
                  <div class="pm-list-row"><span>Café Orgánico 250g</span><span>128</span><span class="pm-status-ok">En stock</span></div>
                  <div class="pm-list-row alert"><span>Miel de Agave 500ml</span><span>3</span><span class="pm-status-low">Bajo</span></div>
                  <div class="pm-list-row"><span>Jabón Artesanal</span><span>56</span><span class="pm-status-ok">En stock</span></div>
                  <div class="pm-list-row"><span>Chocolate 70%</span><span>89</span><span class="pm-status-ok">En stock</span></div>
                  <div class="pm-list-row"><span>Vela Aromática</span><span>34</span><span class="pm-status-ok">En stock</span></div>
                </div>
              </div>
            </div>

            {/* ── Controla: Traspasos ── */}
            <div class="tablet-slide" data-slide="stock-traspasos">
              <div class="pm-window">
                <div class="pm-titlebar">
                  <div class="pm-dots"><span style="background:#FF5F57"></span><span style="background:#FFBD2E"></span><span style="background:#27C93F"></span></div>
                  <span class="pm-titlebar-text">Traspasos</span>
                </div>
                <div class="pm-content pm-content-list">
                  <div class="pm-list-header"><span>Movimiento</span><span>Pzas</span><span>Estado</span></div>
                  <div class="pm-list-row"><span>CEDIS → Suc. Centro</span><span>40</span><span class="pm-status-ok">En tránsito</span></div>
                  <div class="pm-list-row"><span>Suc. Norte → CEDIS</span><span>25</span><span class="pm-status-ok">Completado</span></div>
                  <div class="pm-list-row"><span>CEDIS → Suc. Sur</span><span>60</span><span class="pm-status-low">Pendiente</span></div>
                </div>
              </div>
            </div>

            {/* ── Controla: Alertas ── */}
            <div class="tablet-slide" data-slide="stock-alertas">
              <div class="pm-window">
                <div class="pm-titlebar">
                  <div class="pm-dots"><span style="background:#FF5F57"></span><span style="background:#FFBD2E"></span><span style="background:#27C93F"></span></div>
                  <span class="pm-titlebar-text">Alertas de reabasto</span>
                </div>
                <div class="pm-content pm-content-list">
                  <div class="pm-list-header"><span>Producto</span><span>Stock</span><span>Acción</span></div>
                  <div class="pm-list-row alert"><span>Miel de Agave 500ml</span><span>3</span><span class="pm-status-low">Reabastecer</span></div>
                  <div class="pm-list-row alert"><span>Crema de Cacao</span><span>5</span><span class="pm-status-low">Reabastecer</span></div>
                  <div class="pm-list-row"><span>Vela Aromática</span><span>34</span><span class="pm-status-ok">OK</span></div>
                  <div class="pm-list-row"><span>Jabón Artesanal</span><span>56</span><span class="pm-status-ok">OK</span></div>
                </div>
              </div>
            </div>

            {/* ── Fideliza: Programa de lealtad ── */}
            <div class="tablet-slide" data-slide="crm-lealtad">
              <div class="pm-window">
                <div class="pm-titlebar">
                  <div class="pm-dots"><span style="background:#FF5F57"></span><span style="background:#FFBD2E"></span><span style="background:#27C93F"></span></div>
                  <span class="pm-titlebar-text">Programa de lealtad</span>
                </div>
                <div class="pm-content pm-content-list">
                  <div class="pm-list-header"><span>Cliente</span><span>Puntos</span><span>Nivel</span></div>
                  <div class="pm-list-row"><span>María López</span><span>1,240</span><span class="pm-status-ok">VIP</span></div>
                  <div class="pm-list-row"><span>Carlos Ruiz</span><span>680</span><span class="pm-status-ok">Gold</span></div>
                  <div class="pm-list-row"><span>Ana García</span><span>320</span><span class="pm-status-ok">Silver</span></div>
                  <div class="pm-list-row"><span>Pedro Mendoza</span><span>90</span><span class="pm-status-low">Nuevo</span></div>
                </div>
              </div>
            </div>

            {/* ── Fideliza: Seguimiento de clientes ── */}
            <div class="tablet-slide" data-slide="crm-seguimiento">
              <div class="pm-window">
                <div class="pm-titlebar">
                  <div class="pm-dots"><span style="background:#FF5F57"></span><span style="background:#FFBD2E"></span><span style="background:#27C93F"></span></div>
                  <span class="pm-titlebar-text">Clientes</span>
                </div>
                <div class="pm-content pm-content-crm">
                  <div class="pm-crm-profile">
                    <div class="pm-crm-avatar">ML</div>
                    <div>
                      <div class="pm-crm-name">María López</div>
                      <div class="pm-crm-tag">VIP · 23 compras</div>
                    </div>
                  </div>
                  <div class="pm-crm-stats">
                    <div class="pm-crm-stat"><span>Ticket promedio</span><strong>$890</strong></div>
                    <div class="pm-crm-stat"><span>Última visita</span><strong>Hace 2 días</strong></div>
                    <div class="pm-crm-stat"><span>Puntos</span><strong>1,240</strong></div>
                  </div>
                </div>
              </div>
            </div>

            {/* ── Fideliza: Promociones ── */}
            <div class="tablet-slide" data-slide="crm-promos">
              <div class="pm-window">
                <div class="pm-titlebar">
                  <div class="pm-dots"><span style="background:#FF5F57"></span><span style="background:#FFBD2E"></span><span style="background:#27C93F"></span></div>
                  <span class="pm-titlebar-text">Promociones</span>
                </div>
                <div class="pm-content pm-content-list">
                  <div class="pm-list-header"><span>Promoción</span><span>Alcance</span><span>Estado</span></div>
                  <div class="pm-list-row"><span>2x1 Café Orgánico</span><span>VIP</span><span class="pm-status-ok">Activa</span></div>
                  <div class="pm-list-row"><span>15% en Jabones</span><span>Todos</span><span class="pm-status-ok">Activa</span></div>
                  <div class="pm-list-row"><span>Puntos dobles sábado</span><span>Gold+</span><span class="pm-status-low">Próxima</span></div>
                </div>
              </div>
            </div>

            {/* ── Automatiza: Sugerencias de reabasto ── */}
            <div class="tablet-slide" data-slide="ai-reabasto">
              <div class="pm-window">
                <div class="pm-titlebar">
                  <div class="pm-dots"><span style="background:#FF5F57"></span><span style="background:#FFBD2E"></span><span style="background:#27C93F"></span></div>
                  <span class="pm-titlebar-text">AXO — Tu copiloto IA</span>
