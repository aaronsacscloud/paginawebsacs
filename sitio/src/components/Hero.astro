      transition: none;
      opacity: 1;
      transform: none;
    }

    .accordion-item.active .accordion-progress-fill {
      animation: none;
      width: 100%;
    }

    .hero-video-section {
      padding: 0 var(--space-6) var(--space-6);
    }

    .hero-video-card {
      border-radius: var(--radius-xl);
    }
