  .ec-layer--checkout { animation: ec-layer-checkout 14s ease-in-out infinite; }
  .ec-layer--ok       { animation: ec-layer-ok 14s ease-in-out infinite; }

  /* Timeline:
     0-30%   Home con scroll natural (hero → destacados → historia → lookbook)
     33-55%  Catálogo (Ver más → ficha)
     44-55%  Cart drawer
     58-76%  Checkout (device starts shrinking at 70%)
     79-100% Success in mobile */
  @keyframes ec-layer-home {
    0%, 30%   { opacity: 1; }
    33%, 100% { opacity: 0; }
  }
  @keyframes ec-layer-catalog {
    0%, 32%   { opacity: 0; }
    35%, 55%  { opacity: 1; }
    58%, 100% { opacity: 0; }
  }
  @keyframes ec-layer-cart {
    0%, 43%   { opacity: 0; }
    45%, 55%  { opacity: 1; }
    58%, 100% { opacity: 0; }
  }
  @keyframes ec-layer-checkout {
    0%, 58%   { opacity: 0; }
    60%, 76%  { opacity: 1; }
    78%, 100% { opacity: 0; }
  }
  @keyframes ec-layer-ok {
    0%, 78%   { opacity: 0; }
    81%, 100% { opacity: 1; }
