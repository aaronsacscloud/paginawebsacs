  /* ── Unified WhatsApp Commerce (continuation of pos pillar) ── */
  /* Removes the hard border-top so it flows seamlessly from white pos pillar.
     Adds a soft gradient seam at bottom that fades into stock pillar's gray. */
  .sq-features--unified {
