  .tablet-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: scale(0.96);
    transition: opacity 0.5s ease, transform 0.5s ease;
    pointer-events: none;
  }

  .tablet-slide.active {
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
    position: relative;
  }

  .tablet-slide-img {
    width: 100%;
