    border-radius: 10px;
    max-width: 88%;
    opacity: 0;
    transform: translateY(6px);
    animation: axo-msg-loop 10s ease infinite;
  }
  .axo-msg--1 { animation-delay: 0.3s; }
  .axo-msg--2 { animation-delay: 1.4s; }
  .axo-msg--3 { animation-delay: 2.6s; }
  .axo-msg--4 { animation-delay: 3.8s; }
  .axo-msg--5 { animation-delay: 4.8s; }
  @keyframes axo-msg-loop {
    0%       { opacity: 0; transform: translateY(6px); }
    5%, 75%  { opacity: 1; transform: translateY(0); }
    85%, 100%{ opacity: 0; transform: translateY(-4px); }
  }
  .axo-msg-ai {
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.85);
    align-self: flex-start;
    border-bottom-left-radius: 3px;
  }
  .axo-msg-user {
    background: #2AB5A0;
    color: #fff;
    align-self: flex-end;
    border-bottom-right-radius: 3px;
  }
  .axo-msg-label {
    display: block;
    font-size: 7px;
    font-weight: 700;
    color: #2AB5A0;
    margin-bottom: 2px;
    letter-spacing: 0.5px;
  }

  /* Action card */
  .axo-action-card {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(42,181,160,0.1);
    border: 1px solid rgba(42,181,160,0.2);
    border-radius: 8px;
    padding: 5px 6px;
    margin-top: 3px;
  }
  .axo-action-icon {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #2AB5A0;
    color: #fff;
    font-size: 9px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .axo-action-title {
    font-family: var(--font-display);
    font-size: 9px;
    font-weight: 700;
    color: #fff;
  }
  .axo-action-detail {
    font-size: 7px;
    color: rgba(255,255,255,0.4);
  }

  /* Typing indicator */
  .axo-chat-header::after {
    content: '';
    display: block;
    width: 6px;
    height: 6px;
    background: #2AB5A0;
    border-radius: 50%;
    margin: 6px auto 0;
    animation: axo-pulse 1.5s ease-in-out infinite;
  }
  @keyframes axo-pulse {
    0%, 100% { opacity: 0.3; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  /* Chat input */
  .axo-chat-input {
    margin-top: auto;
    padding: 6px 10px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    font-family: var(--font-body);
    font-size: 8px;
    color: rgba(255,255,255,0.25);
  }

  @media (prefers-reduced-motion: reduce) {
    .axo-msg { animation: none; opacity: 1; transform: none; }
  }

  /* ── Catálogo enriquecido (inventario) ── */
  .cat-window {
    display: flex;
    flex-direction: column;
    border-radius: 0;
    box-shadow: none;
    height: 100%;
    font-family: var(--font-body);
  }
  .cat-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    border-bottom: 1px solid #eee;
    background: #fff;
    gap: 8px;
  }
  .cat-topbar-left {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .cat-topbar-title {
    font-size: 13px;
    font-weight: 700;
    color: #1A1A1A;
  }
  .cat-topbar-count {
    font-size: 11px;
    color: #8C8C8C;
  }
  .cat-topbar-actions {
    display: flex;
    gap: 4px;
  }
  .cat-btn {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    padding: 5px 10px;
    border-radius: 6px;
    border: 1px solid #e0e0e0;
    background: #fff;
    color: #4A4A4A;
    cursor: pointer;
    white-space: nowrap;
  }
  .cat-btn--primary {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }
  .cat-filters {
    display: flex;
    gap: 8px;
    padding: 8px 14px;
    border-bottom: 1px solid #f0f0f0;
    background: #fafafa;
  }
  .cat-filter-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }
  .cat-filter-label {
    font-size: 9px;
    color: #8C8C8C;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .cat-filter-value {
    font-size: 10px;
    color: #1A1A1A;
    font-weight: 500;
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 4px;
    padding: 3px 6px;
  }
  .cat-tabs-bar {
    display: flex;
    gap: 0;
    border-bottom: 1px solid #eee;
    padding: 0 14px;
  }
  .cat-tab-item {
    font-size: 10px;
    font-weight: 600;
    color: #8C8C8C;
    padding: 7px 10px;
    border-bottom: 2px solid transparent;
    cursor: pointer;
  }
  .cat-tab-item--active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }
  .cat-table {
    flex: 1;
    overflow: hidden;
  }
  .cat-table-header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1.5fr;
    gap: 4px;
    padding: 6px 14px;
    font-size: 9px;
    font-weight: 700;
    color: #8C8C8C;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    border-bottom: 1px solid #eee;
  }
  .cat-table-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1.5fr;
    gap: 4px;
    padding: 6px 14px;
    font-size: 10px;
    color: #4A4A4A;
    align-items: center;
    border-bottom: 1px solid #f5f5f5;
  }
  .cat-table-row--alert {
    background: #FFF5F5;
  }
  .cat-col-name {
    display: flex;
    align-items: center;
    gap: 6px;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .cat-prod-thumb {
    width: 24px;
    height: 24px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    flex-shrink: 0;
  }
  .cat-prod-thumb-img {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
    margin-right: 2px;
  }
  .cat-col-actions {
    display: flex;
    gap: 3px;
  }
  .cat-mini-btn {
    font-size: 10px;
    background: #f5f5f5;
    border: 1px solid #eee;
    border-radius: 4px;
    padding: 2px 5px;
    cursor: pointer;
    line-height: 1;
  }
  .cat-stock-pill {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 10px;
    font-size: 10px;
    font-weight: 700;
  }
  .cat-stock-pill--ok {
    background: #E8F5E9;
    color: #2E7D32;
  }
  .cat-stock-pill--low {
    background: #FFEBEE;
    color: #C62828;
  }
  .cat-col-loc {
    display: flex;
    gap: 3px;
    flex-wrap: wrap;
  }
  .cat-loc-badge {
    font-size: 8px;
    font-weight: 600;
    padding: 2px 5px;
    border-radius: 3px;
    background: #f0f0f0;
    color: #666;
    white-space: nowrap;
  }

  /* Variant rows */
  .cat-table-row--variant {
    background: #fafafa;
    font-size: 9px;
    color: #8C8C8C;
    padding: 4px 14px 4px 28px;
  }
  .cat-indent {
    color: #ccc;
    margin-right: 4px;
  }
  .cat-variant-badge {
    font-size: 8px;
    background: #EDE7F6;
    color: #7C3AED;
    padding: 1px 5px;
    border-radius: 3px;
    margin-left: 4px;
    font-weight: 600;
  }

  /* Import overlay + animation */
  .cat-import-overlay {
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    opacity: 1;
    pointer-events: auto;
  }
  .cat-import-modal {
    background: #fff;
    border-radius: 12px;
    padding: 20px 28px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    text-align: center;
    width: 260px;
  }
  .cat-import-icon {
    font-size: 28px;
    margin-bottom: 8px;
  }
  .cat-import-title {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    color: #1A1A1A;
    margin-bottom: 12px;
  }
  .cat-import-file {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #f5f5f5;
    padding: 8px 10px;
    border-radius: 8px;
    margin-bottom: 12px;
  }
  .cat-import-file-icon { font-size: 16px; }
  .cat-import-file-name {
    font-size: 11px;
    font-weight: 600;
    color: #1A1A1A;
    flex: 1;
    text-align: left;
  }
  .cat-import-file-size {
    font-size: 10px;
    color: #8C8C8C;
  }
  .cat-import-progress {
    height: 6px;
    background: #eee;
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  .cat-import-bar {
    height: 100%;
    width: 0%;
    background: var(--color-primary);
    border-radius: 3px;
    transition: width 0.1s linear;
  }
  .cat-import--active .cat-import-bar {
    animation: cat-import-fill 0.84s ease-out forwards;
  }
  @keyframes cat-import-fill {
    0% { width: 0%; }
    30% { width: 40%; }
    60% { width: 75%; }
    100% { width: 100%; }
  }
  .cat-import-status {
    font-size: 11px;
    color: #8C8C8C;
  }
  .cat-import-done {
    font-size: 12px;
    font-weight: 700;
    color: #2E7D32;
    margin-top: 8px;
    opacity: 0;
  }
  .cat-import--active .cat-import-done {
    animation: cat-import-done-show 0.4s ease 1.4s forwards;
  }
  @keyframes cat-import-done-show {
    0% { opacity: 0; transform: translateY(4px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .cat-import--active .cat-import-status {
    animation: cat-import-status-hide 0.3s ease 1.3s forwards;
  }
  @keyframes cat-import-status-hide {
    to { opacity: 0; height: 0; margin: 0; }
  }

  /* Inventario list */
  .pm-content-list {
    flex-direction: column;
    gap: 0;
  }

  .pm-list-header {
    display: grid;
    grid-template-columns: 1fr 80px 80px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pm-list-row {
    display: grid;
    grid-template-columns: 1fr 80px 80px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
    font-size: 14px;
    color: var(--color-text-secondary);
  }

  .pm-list-row.alert { background: rgba(229, 75, 75, 0.04); }

  .pm-status-ok {
    font-size: 12px;
    font-weight: 600;
    color: #1a8a78;
    background: rgba(42, 181, 160, 0.1);
    padding: 2px 8px;
    border-radius: var(--radius-full);
    display: inline-block;
    width: fit-content;
  }

  .pm-status-low {
    font-size: 12px;
    font-weight: 600;
    color: #c0392b;
    background: rgba(229, 75, 75, 0.1);
    padding: 2px 8px;
    border-radius: var(--radius-full);
    display: inline-block;
    width: fit-content;
  }

  /* CRM */
  .pm-content-crm {
    flex-direction: column;
    gap: var(--space-5);
  }

  .pm-crm-profile {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .pm-crm-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    font-size: 18px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .pm-crm-name { font-size: 16px; font-weight: 700; color: var(--color-text-primary); }
  .pm-crm-tag { font-size: 13px; color: var(--color-text-tertiary); margin-top: 2px; }

  .pm-crm-stats {
    display: flex;
    flex-direction: column;
  }

  .pm-crm-stat {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    font-size: 14px;
    color: var(--color-text-secondary);
  }

  .pm-crm-stat strong {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  /* Reports */
  .pm-content-reports {
    flex-direction: column;
    gap: var(--space-5);
  }

  .pm-report-kpis {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .pm-kpi-val {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }

  .pm-kpi-label {
    display: block;
    font-size: 13px;
    color: var(--color-text-tertiary);
    margin-top: 4px;
  }

  .pm-chart {
    width: 100%;
    height: 100px;
  }

  /* Chat */
  .pm-content-chat {
    flex-direction: column;
    gap: 10px;
  }

  .pm-chat-msg {
    font-size: 14px;
    line-height: 1.5;
    padding: 12px 16px;
    border-radius: 14px;
    max-width: 85%;
  }

  .pm-chat-ai {
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }

  .pm-chat-user {
    background: var(--color-primary);
    color: #fff;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }


  /* ═══════════════════════════════════════════
     BLOQUE 2.4: Bento Grid — Multisucursal
     ═══════════════════════════════════════════ */

  .bento-section {
    background: var(--color-bg-primary);
    padding: var(--space-20, 80px) 0;
  }

  @media (min-width: 1024px) {
    .bento-section { padding: var(--space-32, 128px) 0; }
  }

  .bento-header {
    text-align: center;
    margin-bottom: var(--space-10, 40px);
  }

  .bento-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-tertiary, #8C8C8C);
    margin-bottom: var(--space-3, 12px);
  }

  .bento-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    max-width: 680px;
    margin-inline: auto;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4, 16px);
  }

  @media (min-width: 640px) {
    .bento-grid { grid-template-columns: repeat(2, 1fr); gap: var(--space-5, 20px); }
  }

  @media (min-width: 1024px) {
    .bento-grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-6, 24px); }
  }

  .bento-card {
    background: var(--color-bg-card, #fff);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: var(--radius-xl, 20px);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .bento-card:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
    transform: translateY(-4px);
  }

  @media (min-width: 640px) {
    .bento-card-lg { grid-column: span 2; }
  }

  .bento-visual {
    position: relative;
    padding: var(--space-8, 32px) var(--space-6, 24px);
    min-height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bento-visual-dashboard { background: #111118; }
  .bento-visual-stock { background: var(--color-bg-secondary, #F5F3EE); }
  .bento-visual-transfer { background: var(--color-bg-secondary, #F5F3EE); }
  .bento-visual-axo { background: #111118; }

  /* BOPIS timeline */
  .bento-visual-bopis { background: var(--color-bg-secondary, #F5F3EE); }
  .bento-bopis-timeline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 24px 16px;
  }
  .bento-bopis-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .bento-bopis-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    color: var(--color-text-primary);
  }
  .bento-bopis-icon--done {
    background: #2AB5A0;
    color: #fff;
  }
  .bento-bopis-icon--done svg { stroke: #fff; }
  .bento-bopis-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-align: center;
    white-space: nowrap;
  }
  .bento-bopis-arrow {
    font-size: 18px;
    color: rgba(0,0,0,0.2);
    margin-bottom: 20px;
  }

  /* Offline icon */
  .bento-visual-offline { background: var(--color-bg-secondary, #F5F3EE); }
  .bento-offline-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 24px 16px;
    position: relative;
  }
  .bento-offline-icon { position: relative; }
  .bento-offline-check {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(40%, -80%);
  }
  .bento-offline-badge {
    font-size: 11px;
    font-weight: 700;
    color: #2AB5A0;
    background: rgba(42,181,160,0.1);
    padding: 4px 10px;
    border-radius: 100px;
    letter-spacing: -0.01em;
  }

  .bento-text { padding: var(--space-5, 20px) var(--space-6, 24px) var(--space-8, 32px); }

  .bento-card-title {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: var(--space-2, 8px);
  }

  .bento-card-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-secondary, #4A4A4A);
  }

  /* Card 1: Dashboard map */
  .bento-map {
    position: relative;
    width: 100%;
    max-width: 400px;
    aspect-ratio: 2 / 1;
  }

  .bento-map-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .bento-map-dot {
    position: absolute;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-primary, #4B7BE5);
    box-shadow: 0 0 8px rgba(75, 123, 229, 0.6);
    z-index: 1;
  }

  .bento-dot-ping {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid var(--color-primary, #4B7BE5);
    opacity: 0;
    animation: bentoPing 2.5s ease-out infinite;
  }

  .bento-map-dot:nth-child(2) .bento-dot-ping { animation-delay: 0.6s; }
  .bento-map-dot:nth-child(3) .bento-dot-ping { animation-delay: 1.2s; }
  .bento-map-dot:nth-child(4) .bento-dot-ping { animation-delay: 1.8s; }

  @keyframes bentoPing {
    0% { opacity: 0.7; transform: scale(1); }
    100% { opacity: 0; transform: scale(2.5); }
  }

  /* Card 2: Stock counter */
  .bento-counter {
    width: 100%;
    max-width: 260px;
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 12px);
  }

  .bento-counter-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 12px;
    background: #fff;
    border-radius: 8px;
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  .bento-counter-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary, #4A4A4A);
  }

  .bento-counter-val {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .bento-counter-bar {
    height: 6px;
