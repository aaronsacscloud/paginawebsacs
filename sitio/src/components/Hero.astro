    position: relative;
    height: 100%;
    overflow: hidden;
  }
  .social-devices-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* Floating logo badges — row above tablet */
  .social-floating-logos {
    position: absolute;
    top: 10px;
    left: 30%;
    right: 0;
    display: flex;
    justify-content: center;
    gap: 12px;
    pointer-events: none;
    z-index: 3;
  }
  .floating-logo {
    width: 40px;
    height: 40px;
    border-radius: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 14px rgba(0,0,0,0.15);
    opacity: 0;
    flex-shrink: 0;
  }
  .floating-logo--tiktok {
    background: #010101;
  }
  .floating-logo--instagram {
    background: linear-gradient(135deg,#833AB4,#E1306C,#F77737);
  }
  .floating-logo--facebook {
    background: #1877F2;
  }
  .floating-logo--google {
    background: #fff;
  }
  .floating-logo--chatgpt {
    background: #1A1A1A;
  }

  /* Logos only animate when slide is active */
  .tablet-slide:not(.active) .floating-logo {
    opacity: 0;
    animation: none;
  }
  .tablet-slide.active .floating-logo {
    animation: floatAppear 0.6s ease-out forwards, floatHover 3s ease-in-out 0.6s infinite;
  }
  .tablet-slide.active .floating-logo--tiktok  { animation-delay: 0.1s, 0.7s; }
  .tablet-slide.active .floating-logo--instagram { animation-delay: 0.25s, 0.85s; }
  .tablet-slide.active .floating-logo--facebook { animation-delay: 0.4s, 1.0s; }
  .tablet-slide.active .floating-logo--google   { animation-delay: 0.55s, 1.15s; }
  .tablet-slide.active .floating-logo--chatgpt  { animation-delay: 0.7s, 1.3s; }

  @keyframes floatAppear {
    0% {
      opacity: 0;
      transform: translateY(20px) scale(0.7);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes floatHover {
    0%, 100% {
      transform: translateY(0);
