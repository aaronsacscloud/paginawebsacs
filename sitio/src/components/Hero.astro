<style>
  /* ═══════════════════════════════════════════
     BLOQUE 1: Banner — Fondo claro con texturas
     ═══════════════════════════════════════════ */

  .hero-banner {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #FFFFFF;
    overflow: hidden;
    padding-top: 110px;
    padding-bottom: var(--space-12, 3rem);
  }

  /* ─── Gradient mesh orbs + noise texture ─── */
  .hero-shapes {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  /* Noise grain overlay for depth */
  .hero-shapes::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    opacity: 0.5;
    mix-blend-mode: multiply;
  }

  .shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  /* SACS Blue gradient orb — top-right */
  .shape-circle-1 {
    top: -10%;
    right: -5%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(75, 123, 229, 0.08) 0%, transparent 70%);
  }

  /* Teal orb — bottom-left */
  .shape-circle-2 {
    bottom: -15%;
    left: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(42, 181, 160, 0.06) 0%, transparent 70%);
  }

  /* Gold accent — subtle, center-right */
  .shape-square-1 {
    top: 40%;
    right: 20%;
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(232, 168, 56, 0.05) 0%, transparent 70%);
    filter: blur(100px);
  }

  /* Dot pattern — subtle grid */
  .shape-dots {
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    border-radius: 0;
    filter: none;
    background-image: radial-gradient(circle, rgba(0, 0, 0, 0.06) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.4;
  }

  .hero-banner-content {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    flex-direction: column;
    max-width: var(--max-width);
    width: 100%;
    margin-inline: auto;
    padding-inline: var(--space-5);
  }

  @media (min-width: 768px) { .hero-banner-content { padding-inline: var(--space-10); } }

  @media (min-width: 1024px) {
    .hero-banner-content {
      padding-inline: var(--space-16);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
      align-items: center;
    }
  }

  .hero-text {
    padding-top: var(--space-8);
    padding-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .hero-text {
      padding-top: var(--space-10);
      padding-bottom: var(--space-8);
    }
  }

  @media (min-width: 1024px) {
    .hero-text {
      padding-top: var(--space-12);
      padding-bottom: var(--space-10);
    }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 7vw, 4.75rem);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    margin-bottom: var(--space-6);
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 1.5vw, 1.175rem);
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 500px;
    margin-bottom: var(--space-10);
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both;
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;
  }

  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-btn {
    font-size: 0.875rem;
    font-weight: 600;
    padding: 14px 28px;
    border-radius: var(--radius-full);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    transition: all 0.2s ease;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero-btn:hover { text-decoration: none; }

  .hero-btn-filled { background: var(--color-primary); color: #fff; }
  .hero-btn-filled:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 24px rgba(75, 123, 229, 0.3);
  }

  .hero-btn-outline {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid rgba(0, 0, 0, 0.15);
  }
  .hero-btn-outline:hover {
    background: rgba(0, 0, 0, 0.04);
    border-color: rgba(0, 0, 0, 0.25);
    transform: translateY(-1px);
  }

  /* Bottom bar — credibility badges */
  .hero-bottom-bar {
    padding-top: var(--space-8);
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.55s both;
  }

  .hero-badges {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  @media (min-width: 768px) {
    .hero-badges { gap: var(--space-8); }
  }

  .hero-badge {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .hero-badge-icon {
    flex-shrink: 0;
    color: var(--color-text-tertiary);
  }

  .hero-badge-value {
    display: block;
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.2;
  }

  .hero-badge-label {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    line-height: 1.2;
  }

  .hero-badge-divider {
    width: 1px;
    height: 28px;
    background: rgba(0, 0, 0, 0.12);
    display: none;
  }

  @media (min-width: 768px) {
    .hero-badge-divider { display: block; }
  }

  /* ─── Hero image (right side) ─── */
  .hero-visual {
    display: none;
    position: relative;
    align-self: center;
  }

  @media (min-width: 1024px) {
    .hero-visual {
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }

  .hero-image-wrapper {
    position: relative;
    animation: heroImageIn 1s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  .hero-image {
    width: 100%;
    max-width: 600px;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-xl, 20px);
    object-fit: cover;
    object-position: center 55%;
  }

  @keyframes heroImageIn {
    from {
      opacity: 0;
      transform: translateY(40px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* ─── Floating notifications ─── */
  .hero-notif {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 14px;
    padding: 10px 14px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12), 0 0 0 1px rgba(0, 0, 0, 0.04);
    opacity: 0;
    white-space: nowrap;
  }

  /* Slot positions — notifs 1-3 are slot A, 4-6 are slot B (rotate) */
  .hero-notif-1, .hero-notif-4 {
    bottom: 52%;
    left: -8%;
  }

  .hero-notif-2, .hero-notif-5 {
    bottom: 32%;
    right: -6%;
  }

  .hero-notif-3, .hero-notif-6 {
    bottom: 14%;
    left: 2%;
  }

  /* First wave — appear and stay for 4s, then fade out */
  .hero-notif-1 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.2s both,
               notifFadeOut 0.5s ease 5.2s forwards;
  }
  .hero-notif-2 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.8s both,
               notifFadeOut 0.5s ease 5.8s forwards;
  }
  .hero-notif-3 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 2.4s both,
               notifFadeOut 0.5s ease 6.4s forwards;
  }

  /* Second wave — appear after first wave fades */
  .hero-notif-4 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 5.8s both,
               notifFadeOut 0.5s ease 9.8s forwards;
  }
  .hero-notif-5 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 6.4s both,
               notifFadeOut 0.5s ease 10.4s forwards;
  }
  .hero-notif-6 {
    animation: notifSlideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 7.0s both,
               notifFadeOut 0.5s ease 11.0s forwards;
  }

  @keyframes notifSlideIn {
    from {
      opacity: 0;
      transform: translateX(-20px) scale(0.9);
    }
    to {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
  }

  @keyframes notifPulse {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @keyframes notifFadeOut {
    from {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
    to {
      opacity: 0;
      transform: translateX(-10px) scale(0.95);
    }
  }

  .hero-notif-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-notif-icon-loyalty { background: #25D366; }
  .hero-notif-icon-shop { background: var(--color-primary, #4B7BE5); }
  .hero-notif-icon-inventory { background: #2AB5A0; }
  .hero-notif-icon-receiving { background: #4B7BE5; }
  .hero-notif-icon-shrink { background: #E8A838; }
  .hero-notif-icon-restock { background: #E54B4B; }

  .hero-notif-body {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .hero-notif-title {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-text-primary, #1A1A1A);
    letter-spacing: -0.01em;
  }

  .hero-notif-msg {
    font-size: 0.625rem;
    color: var(--color-text-secondary, #4A4A4A);
    line-height: 1.3;
  }

  .hero-notif-time {
    font-size: 0.5625rem;
    color: var(--color-text-tertiary, #8C8C8C);
    flex-shrink: 0;
  }

  .hero-notif-badge {
    font-size: 0.5625rem;
    font-weight: 700;
    color: #fff;
    background: #E54B4B;
    border-radius: 50px;
    padding: 2px 6px;
    flex-shrink: 0;
  }

  @media (max-width: 1023px) {
    .hero-notif { display: none; }
  }

  /* ═══════════════════════════════════════════
     BLOQUE 2: Tablet 3D — scroll-driven
     ═══════════════════════════════════════════ */

  .hero-tablet-section {
    --tablet-tilt: 1;
    --tablet-bg-progress: 0;
    background: color-mix(
      in srgb,
      var(--color-bg-primary, #FAFAF8) calc((1 - var(--tablet-bg-progress)) * 100%),
      #4B7BE5
    );
    height: 400vh;
    position: relative;
    transition: background 0.05s linear;
  }

  .hero-tablet-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    padding: 24px;
    padding-top: 110px;
    box-sizing: border-box;
    overflow: hidden;
  }

  /* ── Fondos oaxaqueños ── */
  .tablet-bg-patterns {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .tablet-bg-layer {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .tablet-bg-layer.active {
    opacity: 1;
  }

  /* ── Fondos oaxaqueños por módulo ── */

  /* POS — Azul SACS con greca geométrica sutil */
  .tablet-bg-layer[data-bg="pos"] {
    background:
      url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 30h10v-10h10v10h10v-10h10v10h10v-10h10' fill='none' stroke='rgba(255,255,255,0.06)' stroke-width='1.5'/%3E%3Cpath d='M0 50h10v-10h10v10h10v-10h10v10h10v-10h10' fill='none' stroke='rgba(255,255,255,0.04)' stroke-width='1.5'/%3E%3C/svg%3E") repeat,
      linear-gradient(160deg, #4B7BE5 0%, #3A5FBB 50%, #2D4A99 100%);
  }

  /* Inventario — Teal profundo con patrón de rombos zapotecas */
  .tablet-bg-layer[data-bg="stock"] {
    background:
      url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 0L40 20L20 40L0 20Z' fill='none' stroke='rgba(255,255,255,0.07)' stroke-width='1'/%3E%3Cpath d='M20 8L32 20L20 32L8 20Z' fill='none' stroke='rgba(255,255,255,0.04)' stroke-width='1'/%3E%3C/svg%3E") repeat,
      linear-gradient(160deg, #1A8A76 0%, #16705F 50%, #0E5A4C 100%);
  }

  /* CRM/Clientes — Dorado cálido con espirales de códice */
  .tablet-bg-layer[data-bg="crm"] {
    background:
      url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='40' cy='40' r='20' fill='none' stroke='rgba(255,255,255,0.06)' stroke-width='1'/%3E%3Ccircle cx='40' cy='40' r='12' fill='none' stroke='rgba(255,255,255,0.04)' stroke-width='1'/%3E%3Ccircle cx='40' cy='40' r='30' fill='none' stroke='rgba(255,255,255,0.03)' stroke-width='1'/%3E%3C/svg%3E") repeat,
      linear-gradient(160deg, #D4952E 0%, #B87D24 50%, #96641B 100%);
  }

  /* AXO/IA — Violeta profundo con grecas escalonadas */
  .tablet-bg-layer[data-bg="ai"] {
    background:
      url("data:image/svg+xml,%3Csvg width='48' height='48' viewBox='0 0 48 48' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 24h8v-8h8v8h8v-8h8v8h8v-8h8' fill='none' stroke='rgba(255,255,255,0.06)' stroke-width='1'/%3E%3Cpath d='M4 36h8v-8h8v8h8v-8h8v8h8' fill='none' stroke='rgba(255,255,255,0.04)' stroke-width='1'/%3E%3Cpath d='M0 12h8v-8h8v8h8v-8h8v8h8v-8h8' fill='none' stroke='rgba(255,255,255,0.03)' stroke-width='1'/%3E%3C/svg%3E") repeat,
      linear-gradient(160deg, #5B2C8E 0%, #4A2272 50%, #3A1A5C 100%);
  }

  /* Grain texture overlay on all tablet backgrounds */
  .tablet-bg-layer::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    opacity: 0.6;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  .tablet-section-header {
    position: relative;
    z-index: 2;
    text-align: center;
    margin-bottom: var(--space-5);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .tablet-section-eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.6);
  }

  .tablet-section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.04em;
    line-height: 1;
    transition: color 0.5s ease;
  }

  .hero-tablet-section.light-bg .tablet-section-title {
    color: var(--color-text-primary, #1A1A1A);
  }
  .hero-tablet-section.light-bg .tablet-section-cta {
    color: var(--color-primary, #4B7BE5);
    border-color: var(--color-primary, #4B7BE5);
  }
  .hero-tablet-section.light-bg .tablet-section-cta:hover {
    background: rgba(75,123,229,0.08);
  }
  .hero-tablet-section.light-bg .tablet-nav-track {
    background: rgba(0,0,0,0.06);
    border-color: rgba(0,0,0,0.04);
  }
  .hero-tablet-section.light-bg .tablet-nav-pill {
    color: rgba(0,0,0,0.4);
  }
  .hero-tablet-section.light-bg .tablet-nav-pill.active {
    color: var(--color-text-primary, #1A1A1A);
  }
  .hero-tablet-section.light-bg .tablet-nav-indicator {
    background: rgba(0,0,0,0.1);
  }

  .tablet-section-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.4);
    background: none;
    padding: 10px 24px;
    border-radius: var(--radius-full, 50px);
    text-decoration: none;
    transition: all 0.3s ease;
    letter-spacing: 0.02em;
  }

  .tablet-section-cta:hover {
    background: rgba(255,255,255,0.15);
    border-color: rgba(255,255,255,0.7);
    gap: 12px;
  }

  /* ── 3-column layout: pills | tablet | details ── */
  .tablet-3col {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
    width: 100%;
  }

  @media (min-width: 1200px) {
    .tablet-3col {
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: var(--space-6);
      padding-inline: var(--space-4);
    }
  }

  /* ── Left: vertical pills ── */
  .tablet-pills-col {
    display: none;
    flex-direction: column;
    gap: 4px;
    flex-shrink: 0;
    width: 180px;
  }

  @media (min-width: 1200px) {
    .tablet-pills-col { display: flex; }
  }

  .tablet-vpill {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border: none;
    background: transparent;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.25s ease;
  }

  .tablet-vpill:hover {
    background: rgba(255,255,255,0.08);
  }

  .tablet-vpill.active {
    background: rgba(255,255,255,0.12);
  }

  .tablet-vpill-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.4);
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
    transition: all 0.25s ease;
  }

  .tablet-vpill.active .tablet-vpill-num {
    background: #fff;
    color: #4B7BE5;
  }

  .tablet-vpill-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgba(255,255,255,0.4);
    transition: color 0.25s ease;
  }

  .tablet-vpill.active .tablet-vpill-label {
    color: #fff;
  }

  /* ── Right: details ── */
  .tablet-details-col {
    display: none;
    flex-shrink: 0;
    width: 220px;
    min-height: 120px;
  }

  @media (min-width: 1200px) {
    .tablet-details-col { display: block; }
  }

  .tablet-detail {
    display: none;
  }

  .tablet-detail.active {
    display: block;
    animation: detailFadeIn 0.35s ease both;
  }

  @keyframes detailFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .tablet-detail-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .tablet-detail-item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    color: rgba(255,255,255,0.7);
    font-size: 0.8125rem;
    line-height: 1.4;
  }

  .tablet-detail-item svg {
    flex-shrink: 0;
    margin-top: 1px;
  }

  .tablet-detail-cta {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: var(--space-5);
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.2s ease, gap 0.2s ease;
  }

  .tablet-detail-cta:hover {
    color: #fff;
    gap: 8px;
    text-decoration: none;
  }

  .hero-tablet-section.light-bg .tablet-section-eyebrow {
    color: rgba(0,0,0,0.4);
  }

  .hero-tablet-wrapper {
    position: relative;
    z-index: 2;
    perspective: 1800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
    width: 100%;
    flex: 1;
    min-width: 0;
  }

  .hero-tablet-frame {
    position: relative;
    width: 92vw;
    max-width: 900px;
    background: #1a1a2e;
    border-radius: 16px;
    padding: 10px;
    box-shadow:
      0 60px 160px rgba(0, 0, 0, 0.4),
      0 30px 60px rgba(0, 0, 0, 0.25),
      0 0 0 1px rgba(255, 255, 255, 0.08),
      0 0 80px rgba(75, 123, 229, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
    transform: rotateX(calc(8deg * var(--tablet-tilt))) rotateY(calc(-4deg * var(--tablet-tilt)));
    transform-style: preserve-3d;
    transition: transform 0.1s linear;
    transform-origin: center center;
  }

  @media (min-width: 768px) {
    .hero-tablet-frame {
      border-radius: 24px;
      padding: 16px;
    }
  }

  @media (min-width: 1200px) {
    .hero-tablet-frame {
      border-radius: 30px;
      padding: 22px;
      width: 100%;
      max-width: none;
    }
  }

  .tablet-camera {
    position: absolute;
    top: 7px;
    left: 50%;
    transform: translateX(-50%);
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #2a2a3e;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  @media (min-width: 768px) {
    .tablet-camera { top: 9px; }
  }

  .tablet-screen {
    position: relative;
    width: 100%;
    border-radius: 6px;
    overflow: hidden;
    background: #fff;
    aspect-ratio: 16 / 10;
  }

  @media (min-width: 768px) {
    .tablet-screen {
      border-radius: 10px;
    }
  }

  @media (min-width: 1200px) {
    .tablet-screen {
      border-radius: 14px;
    }
  }

  .tablet-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: scale(0.96);
    transition: opacity 0.5s ease, transform 0.5s ease;
    pointer-events: none;
  }

  .tablet-slide.active {
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
    position: relative;
  }

  .tablet-slide-img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: left top;
    display: block;
  }

  .tablet-slide .pm-window {
    border-radius: 0;
    box-shadow: none;
    height: 100%;
  }

  /* Pill navigation */
  .tablet-nav {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }

  .tablet-nav-track {
    position: relative;
    display: inline-flex;
    background: rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-full, 9999px);
    padding: 3px;
    gap: 2px;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .tablet-nav-indicator {
    position: absolute;
    top: 3px;
    bottom: 3px;
    left: 3px;
    width: 0;
    background: rgba(255, 255, 255, 0.15);
    border-radius: calc(var(--radius-full, 9999px) - 2px);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    z-index: 0;
  }

  .tablet-nav-pill {
    position: relative;
    z-index: 1;
    padding: 8px 16px;
    font-family: var(--font-body, system-ui);
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.45);
    background: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.3s ease;
    line-height: 1;
  }

  .tablet-nav-pill:hover:not(.active) {
    color: rgba(255, 255, 255, 0.7);
  }

  .tablet-nav-pill.active {
    color: #fff;
    font-weight: 600;
  }

  @media (max-width: 1023px) {
    .tablet-nav-pill {
      padding: 6px 12px;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 767px) {
    .tablet-nav-track {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      max-width: calc(100vw - 32px);
      scrollbar-width: none;
    }
    .tablet-nav-track::-webkit-scrollbar { display: none; }
    .tablet-nav-pill {
      padding: 6px 10px;
      font-size: 0.6875rem;
    }
  }

  /* Mobile: no 3D tilt, full width */
  @media (max-width: 767px) {
    .hero-tablet-section {
      height: auto;
      padding: var(--space-10) 0;
      background: #4B7BE5;
    }

    .hero-tablet-sticky {
      position: relative;
      height: auto;
      padding: 16px;
    }

    .hero-tablet-frame {
      transform: none !important;
      width: 100%;
      max-width: none;
      padding: 8px;
      border-radius: 14px;
    }

    .hero-tablet-wrapper {
      perspective: none;
    }
  }

  /* ═══════════════════════════════════════════
     BLOQUE 2.3: Feature showcase — imagen + texto
     ═══════════════════════════════════════════ */

  .feature-showcase {
    background: #fff;
    padding: var(--space-20) 0;
    overflow: hidden;
  }

  .fs-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .fs-inner {
      flex-direction: row-reverse;
      gap: var(--space-16);
      align-items: center;
    }
  }

  .fs-image-col {
    flex: 1;
    min-width: 0;
  }

  .fs-image-wrapper {
    position: relative;
  }

  .fs-image {
    width: 100%;
    border-radius: var(--radius-xl, 20px);
    object-fit: cover;
    aspect-ratio: 4 / 3;
  }

  /* Floating cards */
  .fs-float-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 12px;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 16px;
    padding: 14px 18px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12), 0 0 0 1px rgba(0, 0, 0, 0.04);
    bottom: 12%;
    left: -4%;
    opacity: 0;
  }

  .fs-image-wrapper.in-view .fs-float-card {
    animation:
      fsCardIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) both,
      fsCardFloat 5s ease-in-out 0.7s infinite;
  }

  .fs-float-card-2 {
    bottom: auto;
    left: auto;
    top: 8%;
    right: -4%;
  }

  .fs-image-wrapper.in-view .fs-float-card-2 {
    animation:
      fsCardIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both,
      fsCardFloat 5s ease-in-out 1.1s infinite;
  }

  @keyframes fsCardIn {
    from {
      opacity: 0;
      transform: translateY(24px) scale(0.92);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes fsCardFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .fs-float-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(232, 168, 56, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fs-float-icon-green {
    background: rgba(42, 181, 160, 0.1);
  }

  .fs-float-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .fs-float-title {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-text-primary, #1A1A1A);
    letter-spacing: -0.01em;
  }

  .fs-float-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    color: var(--color-text-secondary, #4A4A4A);
  }

  .fs-float-badge {
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #2AB5A0;
    background: rgba(42, 181, 160, 0.1);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .fs-float-up {
    color: #2AB5A0;
    font-weight: 700;
  }

  /* Text column */
  .fs-text-col {
    flex: 1;
    min-width: 0;
  }

  .fs-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-text-primary, #1A1A1A);
    margin-bottom: var(--space-5);
  }

  .fs-desc {
    font-size: clamp(1rem, 1.3vw, 1.125rem);
    line-height: 1.6;
    color: var(--color-text-secondary, #4A4A4A);
    max-width: 480px;
    margin-bottom: var(--space-8);
  }

  .fs-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-primary, #4B7BE5);
    text-decoration: none;
    transition: gap 0.3s ease;
  }

  .fs-cta:hover {
    gap: 12px;
  }

  @media (max-width: 1023px) {
    .fs-float-card {
      padding: 10px 14px;
      border-radius: 12px;
    }
    .fs-float-card-2 { display: none; }
  }

  /* ═══════════════════════════════════════════
     BLOQUE 2.35: Scrollytelling — sticky image + features
     ═══════════════════════════════════════════ */

  .scrolly-section {
    position: relative;
    background: #fff;
    display: block;
  }

  @media (min-width: 1024px) {
    .scrolly-section {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Sticky image — takes full left half, sticks to viewport */
  .scrolly-media {
    display: none;
  }

  @media (min-width: 1024px) {
    .scrolly-media {
      display: block;
      position: sticky;
      top: 72px;
      height: calc(100vh - 72px);
      overflow: hidden;
    }
  }

  .scrolly-img-wrap {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    margin: 24px;
    width: calc(100% - 48px);
    height: calc(100% - 48px);
  }

  /* Fondos — colores del logo */
  .scrolly-bg {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.22, 0.68, 0, 1);
    z-index: 0;
  }

  .scrolly-bg.active { opacity: 1; }

  .scrolly-bg-0 { background: #F5F5F3; }
  .scrolly-bg-1 { background: #F0F0EE; }
  .scrolly-bg-2 { background: #EDECEA; }
  .scrolly-bg-3 { background: #F2F1EF; }

  /* Images — simple crossfade */
  .scrolly-img {
    position: absolute;
    inset: 3%;
    width: 94%;
    height: 94%;
    object-fit: cover;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    z-index: 2;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .scrolly-img.active {
    opacity: 1;
  }

  /* Features column — normal scrolling flow */
  .scrolly-features {
    display: flex;
    flex-direction: column;
    padding: 0 var(--space-5);
  }

  @media (min-width: 1024px) {
    .scrolly-features {
      padding: 0 var(--space-12) 0 var(--space-10);
    }
  }

  .scrolly-item {
    padding: var(--space-10) 0;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .scrolly-item:last-child {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  @media (min-width: 1024px) {
    .scrolly-item {
      padding: var(--space-12) 0;
      min-height: 60vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .scrolly-item:first-child {
      padding-top: 20vh;
    }

    .scrolly-item:last-child {
      padding-bottom: 20vh;
    }
  }

  .scrolly-item-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text-tertiary, #8C8C8C);
    margin-bottom: var(--space-4);
    transition: color 0.4s ease;
  }

  .scrolly-item-desc {
    font-size: clamp(0.95rem, 1.2vw, 1.0625rem);
    line-height: 1.6;
    color: var(--color-text-tertiary, #8C8C8C);
    max-width: 480px;
    transition: color 0.4s ease;
  }

  .scrolly-item.active .scrolly-item-title {
    color: var(--color-text-primary, #1A1A1A);
  }

  .scrolly-item.active .scrolly-item-desc {
    color: var(--color-text-secondary, #4A4A4A);
  }

  /* ═══════════════════════════════════════════
     BLOQUE 2.5: Social proof — expanding panels
     ═══════════════════════════════════════════ */

  .hero-social-proof {
    background: var(--color-bg-primary);
    padding: var(--space-20) 0;
  }

  .sp-header {
    margin-bottom: var(--space-12);
    text-align: center;
  }

  .sp-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.04em;
    line-height: 1;
    max-width: 900px;
    margin-inline: auto;
  }

  /* Panels container */
  .sp-panels {
    display: flex;
    gap: 6px;
    height: 520px;
    padding-inline: var(--space-5);
    max-width: 1400px;
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .sp-panels {
      height: 560px;
      gap: 8px;
      padding-inline: var(--space-8);
    }
  }

  @media (min-width: 1024px) {
    .sp-panels { height: 600px; }
  }

  /* Individual panel */
  .sp-panel {
    position: relative;
    flex: 1;
    min-width: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    cursor: pointer;
    background: var(--panel-bg) no-repeat;
    transition: flex 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sp-panel.active {
    flex: 4;
  }

  @media (min-width: 768px) {
    .sp-panel.active { flex: 3.5; }
  }

  /* Gradient overlay from bottom */
  .sp-panel-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.6) 0%,
      rgba(0, 0, 0, 0.15) 40%,
      transparent 70%
    );
    z-index: 1;
    transition: background 0.5s ease;
  }

  .sp-panel.active .sp-panel-overlay {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.08) 50%,
      transparent 70%
    );
  }

  /* Label — always visible, large text */
  .sp-panel-label {
    position: absolute;
    z-index: 2;
    font-family: var(--font-display);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.03em;
    transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
    /* Collapsed: vertical, centered */
    bottom: var(--space-6);
    left: 50%;
    transform: translateX(-50%);
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    white-space: nowrap;
    writing-mode: vertical-lr;
    text-orientation: mixed;
  }

  .sp-panel.active .sp-panel-label {
    /* Expanded: horizontal, top-left */
    writing-mode: horizontal-tb;
    text-orientation: initial;
    font-size: clamp(2rem, 4vw, 3.5rem);
    top: var(--space-8);
    left: var(--space-6);
    bottom: auto;
    transform: none;
  }

  @media (min-width: 768px) {
    .sp-panel.active .sp-panel-label {
      top: var(--space-10);
      left: var(--space-8);
    }
  }

  /* Detail — only visible when active */
  .sp-panel-detail {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: var(--space-6);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease 0.15s, transform 0.5s ease 0.15s;
    pointer-events: none;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  @media (min-width: 768px) {
    .sp-panel-detail { padding: var(--space-8); }
  }

  .sp-panel.active .sp-panel-detail {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .sp-panel-stat {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-2);
  }

  .sp-panel-quote {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 var(--space-4);
    max-width: 400px;
  }

  .sp-panel-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #fff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.5);
    padding-bottom: 2px;
  }

  /* Mobile: stack vertically */
  @media (max-width: 639px) {
    .sp-panels {
      flex-direction: column;
      height: auto;
    }

    .sp-panel {
      height: 80px;
      flex: none !important;
      transition: height 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .sp-panel.active {
      height: 360px;
    }

    .sp-panel-label {
      writing-mode: horizontal-tb;
      text-orientation: initial;
      left: var(--space-5);
      bottom: 50%;
      transform: translateY(50%);
      font-size: 1.25rem;
    }

    .sp-panel.active .sp-panel-label {
      bottom: auto;
      top: var(--space-5);
      left: var(--space-5);
      transform: none;
      font-size: 1.75rem;
    }
  }

  /* ═══════════════════════════════════════════
     BLOQUE 3: Plataforma — Square-style accordion
     ═══════════════════════════════════════════ */

  .platform-section {
    background: var(--color-bg-secondary);
    padding: var(--space-20) var(--space-5);
  }

  @media (min-width: 768px) {
    .platform-section { padding: var(--space-24) var(--space-10); }
  }

  @media (min-width: 1024px) {
    .platform-section { padding: var(--space-32) var(--space-16); }
  }

  .platform-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  @media (min-width: 1024px) {
    .platform-inner {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--space-16);
    }
  }

  /* Left column */
  .platform-text-col {
    flex: 1;
    max-width: 560px;
  }

  .platform-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
  }

  .platform-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.035em;
    color: var(--color-text-primary);
    margin-bottom: var(--space-10);
  }

  /* Accordion */
  .platform-accordion {
    display: flex;
    flex-direction: column;
  }

  .accordion-item {
    border-top: 1px solid var(--color-border);
  }

  .accordion-item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .accordion-header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-5) 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.5vw, 1.1875rem);
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.3;
    text-align: left;
  }

  .accordion-header:hover {
    color: var(--color-primary);
  }

  .accordion-icon {
    flex-shrink: 0;
    color: var(--color-text-tertiary);
    transition: transform 0.3s ease;
  }

  .accordion-icon .icon-v {
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }

  .accordion-item.active .accordion-icon .icon-v {
    opacity: 0;
    transform: rotate(90deg);
  }

  .accordion-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .accordion-item.active .accordion-body {
    max-height: 200px;
  }

  .accordion-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
    padding-right: var(--space-8);
  }

  .accordion-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1.5px solid var(--color-text-primary);
    padding-bottom: 1px;
    margin-bottom: var(--space-5);
  }

  .accordion-link:hover {
    text-decoration: none;
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .accordion-progress {
    height: 3px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 2px;
    margin-bottom: var(--space-2);
    overflow: hidden;
  }

  .accordion-progress-fill {
    height: 100%;
    width: 0%;
    background: var(--color-primary);
    border-radius: 2px;
  }

  .accordion-item.active .accordion-progress-fill {
    animation: accordionFill 5s linear forwards;
  }

  @keyframes accordionFill {
    from { width: 0%; }
    to { width: 100%; }
  }

  /* Right column — painterly background + mockup */
  .platform-visual-col {
    flex: 1;
    position: relative;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    min-height: 480px;
  }

  @media (min-width: 768px) {
    .platform-visual-col { min-height: 560px; }
  }

  @media (min-width: 1024px) {
    .platform-visual-col {
      position: sticky;
      top: 100px;
      min-height: 600px;
    }
  }

  /* Neutral warm background */
  .platform-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(160deg, #e8e4dc 0%, #ddd8d0 50%, #d4cfc6 100%);
  }

  .platform-bg-texture {
    position: absolute;
    inset: 0;
    opacity: 0.25;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.3) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(255, 255, 255, 0.2) 0%, transparent 40%);
    mix-blend-mode: overlay;
  }

  .platform-mockup-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 520px;
    margin: var(--space-10) auto;
    min-height: 380px;
  }

  @media (min-width: 768px) {
    .platform-mockup-wrapper {
      margin: var(--space-12) auto;
      min-height: 440px;
    }
  }

  .platform-mockup {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    pointer-events: none;
  }

  .platform-mockup.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    position: relative;
  }

  /* Window mockup — estilo macOS */
  .pm-window {
    background: #fff;
    border-radius: var(--radius-xl);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.08), 0 0 0 1px rgba(0, 0, 0, 0.04);
    overflow: hidden;
  }

  .pm-titlebar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 14px 20px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .pm-dots {
    display: flex;
    gap: 6px;
  }

  .pm-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .pm-titlebar-text {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .pm-content {
    padding: 20px;
    display: flex;
    gap: 16px;
  }

  /* POS grid mockup */
  .pm-grid {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .pm-product {
    text-align: left;
  }

  .pm-product-img {
    width: 100%;
    aspect-ratio: 1;
    background: #e8e4dc;
    border-radius: var(--radius-md);
    margin-bottom: 8px;
  }

  .pm-product.selected .pm-product-img {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .pm-product-bar {
    height: 6px;
    width: 60%;
    background: #e5e5e5;
    border-radius: 3px;
    margin-bottom: 6px;
  }

  .pm-product span {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .pm-sidebar {
    width: 160px;
    flex-shrink: 0;
    padding-left: 16px;
    border-left: 1px solid rgba(0, 0, 0, 0.06);
  }

  .pm-sidebar-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 12px;
  }

  .pm-sidebar-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 0;
  }

  .pm-sidebar-bar {
    height: 5px;
    width: 60px;
    background: #e5e5e5;
    border-radius: 3px;
  }

  .pm-sidebar-row span {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .pm-sidebar-total {
    display: flex;
    justify-content: space-between;
    padding-top: 12px;
    margin-top: 12px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 14px;
    color: var(--color-text-primary);
  }

  .pm-sidebar-total strong { font-weight: 700; }

  .pm-sidebar-btn {
    margin-top: 16px;
    background: var(--color-primary);
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    text-align: center;
    padding: 10px;
    border-radius: var(--radius-full);
  }

  /* Inventario list */
  .pm-content-list {
    flex-direction: column;
    gap: 0;
  }

  .pm-list-header {
    display: grid;
    grid-template-columns: 1fr 80px 80px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pm-list-row {
    display: grid;
    grid-template-columns: 1fr 80px 80px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
    font-size: 14px;
    color: var(--color-text-secondary);
  }

  .pm-list-row.alert { background: rgba(229, 75, 75, 0.04); }

  .pm-status-ok {
    font-size: 12px;
    font-weight: 600;
    color: #1a8a78;
    background: rgba(42, 181, 160, 0.1);
    padding: 2px 8px;
    border-radius: var(--radius-full);
    display: inline-block;
    width: fit-content;
  }

  .pm-status-low {
    font-size: 12px;
    font-weight: 600;
