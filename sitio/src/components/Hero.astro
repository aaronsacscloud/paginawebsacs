      -webkit-backdrop-filter: none;
      background: rgba(255, 255, 255, 0.2);
    }

    /* ── Section CTAs — stack vertically on mobile ── */
    .section-ctas {
      flex-direction: column;
      gap: 10px;
      margin-top: clamp(28px, 4vw, 40px);
