  .cat-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    border-bottom: 1px solid #eee;
    background: #fff;
    gap: 8px;
  }
  .cat-topbar-left {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .cat-topbar-title {
    font-size: 13px;
    font-weight: 700;
    color: #1A1A1A;
  }
  .cat-topbar-count {
    font-size: 11px;
    color: #8C8C8C;
  }
  .cat-topbar-actions {
    display: flex;
    gap: 4px;
  }
  .cat-btn {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    padding: 5px 10px;
    border-radius: 6px;
    border: 1px solid #e0e0e0;
    background: #fff;
    color: #4A4A4A;
    cursor: pointer;
    white-space: nowrap;
  }
  .cat-btn--primary {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }
  .cat-filters {
    display: flex;
    gap: 8px;
    padding: 8px 14px;
    border-bottom: 1px solid #f0f0f0;
    background: #fafafa;
  }
  .cat-filter-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }
  .cat-filter-label {
    font-size: 9px;
    color: #8C8C8C;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .cat-filter-value {
    font-size: 10px;
    color: #1A1A1A;
    font-weight: 500;
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 4px;
    padding: 3px 6px;
  }
  .cat-tabs-bar {
    display: flex;
    gap: 0;
    border-bottom: 1px solid #eee;
    padding: 0 14px;
  }
  .cat-tab-item {
    font-size: 10px;
    font-weight: 600;
    color: #8C8C8C;
    padding: 7px 10px;
    border-bottom: 2px solid transparent;
    cursor: pointer;
  }
  .cat-tab-item--active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }
  .cat-table {
    flex: 1;
    overflow: hidden;
  }
  .cat-table-header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1.5fr;
    gap: 4px;
    padding: 6px 14px;
    font-size: 9px;
    font-weight: 700;
    color: #8C8C8C;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    border-bottom: 1px solid #eee;
  }
  .cat-table-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1.5fr;
    gap: 4px;
    padding: 6px 14px;
    font-size: 10px;
    color: #4A4A4A;
    align-items: center;
    border-bottom: 1px solid #f5f5f5;
  }
  .cat-table-row--alert {
    background: #FFF5F5;
  }
  .cat-col-name {
    display: flex;
    align-items: center;
    gap: 6px;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .cat-prod-thumb {
    width: 24px;
    height: 24px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    flex-shrink: 0;
  }
  .cat-col-actions {
    display: flex;
    gap: 3px;
  }
  .cat-mini-btn {
    font-size: 10px;
    background: #f5f5f5;
    border: 1px solid #eee;
    border-radius: 4px;
    padding: 2px 5px;
    cursor: pointer;
    line-height: 1;
  }
  .cat-stock-pill {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 10px;
    font-size: 10px;
    font-weight: 700;
  }
  .cat-stock-pill--ok {
    background: #E8F5E9;
    color: #2E7D32;
  }
  .cat-stock-pill--low {
    background: #FFEBEE;
    color: #C62828;
  }
  .cat-col-loc {
    display: flex;
    gap: 3px;
    flex-wrap: wrap;
  }
  .cat-loc-badge {
    font-size: 8px;
    font-weight: 600;
    padding: 2px 5px;
    border-radius: 3px;
    background: #f0f0f0;
    color: #666;
    white-space: nowrap;
  }

  /* Variant rows */
  .cat-table-row--variant {
    background: #fafafa;
    font-size: 9px;
    color: #8C8C8C;
    padding: 4px 14px 4px 28px;
  }
  .cat-indent {
    color: #ccc;
    margin-right: 4px;
  }
  .cat-variant-badge {
    font-size: 8px;
    background: #EDE7F6;
    color: #7C3AED;
    padding: 1px 5px;
    border-radius: 3px;
    margin-left: 4px;
    font-weight: 600;
  }

  /* Import overlay + animation */
  .cat-import-overlay {
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    opacity: 1;
    pointer-events: auto;
  }
  .cat-import-modal {
    background: #fff;
    border-radius: 12px;
    padding: 20px 28px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    text-align: center;
    width: 260px;
  }
  .cat-import-icon {
    font-size: 28px;
    margin-bottom: 8px;
  }
  .cat-import-title {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    color: #1A1A1A;
    margin-bottom: 12px;
  }
  .cat-import-file {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #f5f5f5;
    padding: 8px 10px;
    border-radius: 8px;
    margin-bottom: 12px;
  }
  .cat-import-file-icon { font-size: 16px; }
  .cat-import-file-name {
    font-size: 11px;
    font-weight: 600;
    color: #1A1A1A;
    flex: 1;
    text-align: left;
  }
  .cat-import-file-size {
    font-size: 10px;
    color: #8C8C8C;
  }
  .cat-import-progress {
    height: 6px;
    background: #eee;
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  .cat-import-bar {
    height: 100%;
    width: 0%;
    background: var(--color-primary);
    border-radius: 3px;
    transition: width 0.1s linear;
  }
  .cat-import--active .cat-import-bar {
    animation: cat-import-fill 1.2s ease-out forwards;
  }
  @keyframes cat-import-fill {
    0% { width: 0%; }
    30% { width: 40%; }
    60% { width: 75%; }
    100% { width: 100%; }
  }
  .cat-import-status {
    font-size: 11px;
    color: #8C8C8C;
  }
  .cat-import-done {
    font-size: 12px;
    font-weight: 700;
    color: #2E7D32;
    margin-top: 8px;
    opacity: 0;
  }
  .cat-import--active .cat-import-done {
    animation: cat-import-done-show 0.4s ease 1.4s forwards;
  }
  @keyframes cat-import-done-show {
    0% { opacity: 0; transform: translateY(4px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .cat-import--active .cat-import-status {
    animation: cat-import-status-hide 0.3s ease 1.3s forwards;
  }
  @keyframes cat-import-status-hide {
    to { opacity: 0; height: 0; margin: 0; }
  }

  /* Inventario list */
  .pm-content-list {
    flex-direction: column;
    gap: 0;
  }

  .pm-list-header {
    display: grid;
    grid-template-columns: 1fr 80px 80px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pm-list-row {
    display: grid;
    grid-template-columns: 1fr 80px 80px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
    font-size: 14px;
    color: var(--color-text-secondary);
  }

  .pm-list-row.alert { background: rgba(229, 75, 75, 0.04); }

  .pm-status-ok {
    font-size: 12px;
    font-weight: 600;
    color: #1a8a78;
    background: rgba(42, 181, 160, 0.1);
    padding: 2px 8px;
    border-radius: var(--radius-full);
    display: inline-block;
    width: fit-content;
  }

  .pm-status-low {
    font-size: 12px;
    font-weight: 600;
    color: #c0392b;
    background: rgba(229, 75, 75, 0.1);
    padding: 2px 8px;
    border-radius: var(--radius-full);
    display: inline-block;
    width: fit-content;
  }

  /* CRM */
  .pm-content-crm {
    flex-direction: column;
    gap: var(--space-5);
  }

  .pm-crm-profile {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .pm-crm-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    font-size: 18px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .pm-crm-name { font-size: 16px; font-weight: 700; color: var(--color-text-primary); }
  .pm-crm-tag { font-size: 13px; color: var(--color-text-tertiary); margin-top: 2px; }

  .pm-crm-stats {
    display: flex;
    flex-direction: column;
  }

  .pm-crm-stat {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    font-size: 14px;
    color: var(--color-text-secondary);
  }

  .pm-crm-stat strong {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  /* Reports */
  .pm-content-reports {
    flex-direction: column;
    gap: var(--space-5);
  }

  .pm-report-kpis {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .pm-kpi-val {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }

  .pm-kpi-label {
    display: block;
    font-size: 13px;
    color: var(--color-text-tertiary);
    margin-top: 4px;
  }

  .pm-chart {
    width: 100%;
    height: 100px;
  }

  /* Chat */
  .pm-content-chat {
    flex-direction: column;
    gap: 10px;
  }

  .pm-chat-msg {
    font-size: 14px;
    line-height: 1.5;
    padding: 12px 16px;
    border-radius: 14px;
    max-width: 85%;
  }

  .pm-chat-ai {
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }

  .pm-chat-user {
    background: var(--color-primary);
    color: #fff;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }


  /* ═══════════════════════════════════════════
     BLOQUE 2.4: Bento Grid — Multisucursal
     ═══════════════════════════════════════════ */

  .bento-section {
    background: var(--color-bg-primary);
    padding: var(--space-20, 80px) 0;
  }

  @media (min-width: 1024px) {
    .bento-section { padding: var(--space-32, 128px) 0; }
  }

  .bento-header {
    text-align: center;
    margin-bottom: var(--space-10, 40px);
  }

  .bento-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-tertiary, #8C8C8C);
    margin-bottom: var(--space-3, 12px);
  }

  .bento-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    max-width: 680px;
    margin-inline: auto;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4, 16px);
  }

  @media (min-width: 640px) {
    .bento-grid { grid-template-columns: repeat(2, 1fr); gap: var(--space-5, 20px); }
  }

  @media (min-width: 1024px) {
    .bento-grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-6, 24px); }
  }

  .bento-card {
    background: var(--color-bg-card, #fff);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: var(--radius-xl, 20px);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .bento-card:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
    transform: translateY(-4px);
  }

  @media (min-width: 640px) {
    .bento-card-lg { grid-column: span 2; }
  }

  .bento-visual {
    position: relative;
    padding: var(--space-8, 32px) var(--space-6, 24px);
    min-height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bento-visual-dashboard { background: #111118; }
  .bento-visual-stock { background: var(--color-bg-secondary, #F5F3EE); }
  .bento-visual-transfer { background: var(--color-bg-secondary, #F5F3EE); }
  .bento-visual-axo { background: #111118; }

  /* BOPIS timeline */
  .bento-visual-bopis { background: var(--color-bg-secondary, #F5F3EE); }
  .bento-bopis-timeline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 24px 16px;
  }
  .bento-bopis-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .bento-bopis-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    color: var(--color-text-primary);
  }
  .bento-bopis-icon--done {
    background: #2AB5A0;
    color: #fff;
  }
  .bento-bopis-icon--done svg { stroke: #fff; }
  .bento-bopis-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-align: center;
    white-space: nowrap;
  }
  .bento-bopis-arrow {
    font-size: 18px;
    color: rgba(0,0,0,0.2);
    margin-bottom: 20px;
  }

  /* Offline icon */
  .bento-visual-offline { background: var(--color-bg-secondary, #F5F3EE); }
  .bento-offline-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 24px 16px;
    position: relative;
  }
  .bento-offline-icon { position: relative; }
  .bento-offline-check {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(40%, -80%);
  }
  .bento-offline-badge {
    font-size: 11px;
    font-weight: 700;
    color: #2AB5A0;
    background: rgba(42,181,160,0.1);
    padding: 4px 10px;
    border-radius: 100px;
    letter-spacing: -0.01em;
  }

  .bento-text { padding: var(--space-5, 20px) var(--space-6, 24px) var(--space-8, 32px); }

  .bento-card-title {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: var(--space-2, 8px);
  }

  .bento-card-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-secondary, #4A4A4A);
  }

  /* Card 1: Dashboard map */
  .bento-map {
    position: relative;
    width: 100%;
    max-width: 400px;
    aspect-ratio: 2 / 1;
  }

  .bento-map-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .bento-map-dot {
    position: absolute;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-primary, #4B7BE5);
    box-shadow: 0 0 8px rgba(75, 123, 229, 0.6);
    z-index: 1;
  }

  .bento-dot-ping {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid var(--color-primary, #4B7BE5);
    opacity: 0;
    animation: bentoPing 2.5s ease-out infinite;
  }

  .bento-map-dot:nth-child(2) .bento-dot-ping { animation-delay: 0.6s; }
  .bento-map-dot:nth-child(3) .bento-dot-ping { animation-delay: 1.2s; }
  .bento-map-dot:nth-child(4) .bento-dot-ping { animation-delay: 1.8s; }

  @keyframes bentoPing {
    0% { opacity: 0.7; transform: scale(1); }
    100% { opacity: 0; transform: scale(2.5); }
  }

  /* Card 2: Stock counter */
  .bento-counter {
    width: 100%;
    max-width: 260px;
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 12px);
  }

  .bento-counter-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 12px;
    background: #fff;
    border-radius: 8px;
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  .bento-counter-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary, #4A4A4A);
  }

  .bento-counter-val {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .bento-counter-bar {
    height: 6px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 3px;
    overflow: hidden;
    margin-top: 4px;
  }

  .bento-counter-fill {
    height: 100%;
    width: 72%;
    background: var(--color-secondary, #2AB5A0);
    border-radius: 3px;
  }

  /* Card 3: Transfer */
  .bento-transfer {
    display: flex;
    align-items: center;
    gap: var(--space-4, 16px);
    justify-content: center;
  }

  .bento-store-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .bento-store-letter {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .bento-store-qty {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-tertiary, #8C8C8C);
  }

  .bento-qty-positive { color: var(--color-secondary, #2AB5A0); }

  .bento-transfer-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .bento-transfer-badge {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-secondary, #2AB5A0);
  }

  /* Card 4: AXO suggestion */
  .bento-axo-suggestion {
    width: 100%;
    max-width: 400px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .bento-axo-header {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .bento-axo-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-secondary, #2AB5A0);
    box-shadow: 0 0 6px rgba(42, 181, 160, 0.6);
  }

  .bento-axo-label {
    font-size: 0.6875rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .bento-axo-msg {
    font-size: 0.875rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
  }

  .bento-axo-msg strong { color: #fff; font-weight: 600; }

  .bento-axo-actions {
    display: flex;
    gap: 8px;
    margin-top: 4px;
  }

  .bento-axo-btn {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 8px 16px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .bento-axo-btn:hover { opacity: 0.85; }

  .bento-axo-btn-primary {
    background: var(--color-secondary, #2AB5A0);
    color: #fff;
  }

  .bento-axo-btn-ghost {
    background: transparent;
    color: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  /* ─── Mobile performance: disable heavy effects ─── */
  @media (max-width: 767px) {
    /* Kill expensive background patterns (4 SVG data URIs + 12 radial gradients) */
    .tablet-bg-patterns { display: none; }

    /* Kill hero decorative shapes (blur filters + noise texture) */
    .hero-shapes { display: none; }

    /* Replace expensive backdrop-filter with solid bg on notifications */
    .hero-notif {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: rgba(255, 255, 255, 0.97);
    }

    /* Simplify heavy box-shadows */
    .hero-tablet-frame {
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    }

    .scrolly-img {
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    }

    /* Disable 3D transforms */
    .hero-tablet-frame {
      transform: none !important;
      will-change: auto;
    }
  }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .hero-title,
    .hero-subtitle,
    .hero-ctas,
    .hero-bottom-bar,
    .hero-image-wrapper,
    .hero-image,
    .platform-mockup,
    .accordion-body,
    .tablet-slide {
      transition: none;
      animation: none;
      opacity: 1;
      transform: none;
    }

    .accordion-item.active .accordion-progress-fill {
      animation: none;
      width: 100%;
    }

    .hero-tablet-section {
      height: auto;
      padding: var(--space-12) 0;
      background: #f5f5f7;
    }

    .hero-tablet-sticky {
      position: relative;
      height: auto;
    }

    .hero-tablet-frame {
      transform: none !important;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.innerWidth < 768;

  // ═══ Hero floating notifications — play once, last wave stays ═══
  // No loop needed: notifs 1-3 appear and fade, notifs 4-6 appear and stay permanently.

  // ═══ Tablet scroll-driven animation (12 sub-sections) ═══
  const tabletSection = document.querySelector<HTMLElement>('.hero-tablet-section');
  const tabletFrame = document.querySelector<HTMLElement>('.hero-tablet-frame');
  const tabletSlides = document.querySelectorAll<HTMLDivElement>('.tablet-slide');
  const bgLayers = document.querySelectorAll<HTMLElement>('.tablet-bg-layer');
  const sectionTitleEl = document.getElementById('tablet-section-title');
  const detailPanels = document.querySelectorAll<HTMLElement>('.tablet-detail');
  const stepGroups = document.querySelectorAll<HTMLElement>('.tablet-step-group');
  const vpills = document.querySelectorAll<HTMLButtonElement>('.tablet-vpill');
  const subPills = document.querySelectorAll<HTMLButtonElement>('.tablet-sub-pill');

  // Map each sub to its step index and title
  const subStepMap = [
    { stepIdx: 0, title: 'Vende más en cada punto' },
    { stepIdx: 0, title: 'Pedidos y apartados sin esfuerzo' },
    { stepIdx: 0, title: 'Tu tienda online, siempre abierta' },
    { stepIdx: 1, title: 'Todo tu inventario sincronizado' },
    { stepIdx: 1, title: 'Conteo físico en segundos' },
    { stepIdx: 1, title: 'Recibe mercancía sin errores' },
    { stepIdx: 2, title: 'Premia a tus mejores clientes' },
    { stepIdx: 2, title: 'Recomienda lo que van a amar' },
    { stepIdx: 3, title: 'Tu negocio con IA integrada' },
  ];

  // Map step index to bg layer index (1:1)
  const bgKeys = ['pos', 'stock', 'crm', 'ai'];

  function setActiveSub(globalIdx: number) {
    // Update slides
    tabletSlides.forEach((s, i) => s.classList.toggle('active', i === globalIdx));
    // Update detail panels
    detailPanels.forEach((d, i) => d.classList.toggle('active', i === globalIdx));
    // Update sub pills
    subPills.forEach((p, i) => p.classList.toggle('active', i === globalIdx));
    // Update step groups (expand active, collapse others)
    const stepIdx = subStepMap[globalIdx]?.stepIdx ?? 0;
    stepGroups.forEach((g, i) => g.classList.toggle('active', i === stepIdx));
    vpills.forEach((p, i) => p.classList.toggle('active', i === stepIdx));
    // Update bg layers (one per step, not per sub)
    bgLayers.forEach((l, i) => l.classList.toggle('active', i === stepIdx));
    // Update title
    if (sectionTitleEl) sectionTitleEl.textContent = subStepMap[globalIdx]?.title || subStepMap[0].title;

    // Animate apartados phone when its slide is active
    if (apartadosTimer) { clearInterval(apartadosTimer); apartadosTimer = null; }
    const activeSlide = tabletSlides[globalIdx];
    if (activeSlide?.dataset.slide === 'pos-apartados') {
      const frames = activeSlide.querySelectorAll<HTMLElement>('.wa-frame');
      if (frames.length > 0 && !prefersReducedMotion) {
        let aptActive = 0;
        frames.forEach((f, i) => { f.classList.remove('active', 'exit-left'); if (i === 0) f.classList.add('active'); });
        apartadosTimer = setInterval(() => {
          const prev = aptActive;
          aptActive = (aptActive + 1) % frames.length;
          frames.forEach((f, i) => {
            f.classList.remove('active', 'exit-left');
            if (i === prev) f.classList.add('exit-left');
            if (i === aptActive) f.classList.add('active');
          });
        }, 4000);
      }
    }
  }
  let apartadosTimer: ReturnType<typeof setInterval> | null = null;

  // Flag to ignore scroll-driven updates during programmatic scrolls
  let scrollLocked = false;
  let scrollLockTimer: ReturnType<typeof setTimeout> | null = null;

  function lockScroll() {
    scrollLocked = true;
    if (scrollLockTimer) clearTimeout(scrollLockTimer);
    scrollLockTimer = setTimeout(() => { scrollLocked = false; }, 800);
  }

  if (!prefersReducedMotion && !isMobile && tabletSection && tabletFrame) {
    let lastSubIdx = -1;
    let rafPending = false;
    const vh = window.innerHeight;

    const onTabletScroll = () => {
      if (rafPending || scrollLocked) return;
      rafPending = true;
      requestAnimationFrame(() => {
        rafPending = false;
        if (scrollLocked) return;
        const rect = tabletSection.getBoundingClientRect();
        const sectionH = tabletSection.offsetHeight;
        const scrolled = -rect.top;
        const scrollable = sectionH - vh;

        if (scrolled < 0 || scrolled > scrollable) return;

        const totalProgress = scrolled / scrollable;

        let bgProgress: number;
        if (totalProgress < 0.05) {
          bgProgress = totalProgress / 0.05;
        } else if (totalProgress > 0.95) {
          bgProgress = 1 - ((totalProgress - 0.95) / 0.05);
        } else {
          bgProgress = 1;
        }
        tabletSection.style.setProperty('--tablet-bg-progress', String(bgProgress));

        const tiltEnd = 0.06;
        const tilt = Math.max(0, 1 - (totalProgress / tiltEnd));
        tabletSection.style.setProperty('--tablet-tilt', String(tilt));

        const slideStart = 0.06;
        const slideEnd = 0.95;
        const slideProgress = Math.max(0, Math.min(1,
          (totalProgress - slideStart) / (slideEnd - slideStart)
        ));

        const numSubs = tabletSlides.length;
        const subIdx = Math.min(numSubs - 1, Math.floor(slideProgress * numSubs));

        if (subIdx !== lastSubIdx) {
          setActiveSub(subIdx);
          lastSubIdx = subIdx;
        }
      });
    };

    window.addEventListener('scroll', onTabletScroll, { passive: true });
    onTabletScroll();
  } else if (isMobile) {
    // Mobile: click/tap + swipe navigation (no auto-cycle)
    setActiveSub(0);

    // Touch swipe on tablet frame to cycle slides
    if (tabletFrame) {
      let touchStartX = 0;
      let touchStartY = 0;
      tabletFrame.addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
      }, { passive: true });
      tabletFrame.addEventListener('touchend', (e) => {
        const dx = e.changedTouches[0].clientX - touchStartX;
        const dy = e.changedTouches[0].clientY - touchStartY;
        if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy) * 1.5) {
          let cur = 0;
          tabletSlides.forEach((s, i) => { if (s.classList.contains('active')) cur = i; });
          const next = dx < 0
            ? Math.min(tabletSlides.length - 1, cur + 1)
            : Math.max(0, cur - 1);
          if (next !== cur) setActiveSub(next);
        }
      }, { passive: true });
    }
  } else {
    setActiveSub(0);
  }

  // Step pill clicks → jump to first sub of that step
  // Build a map of stepIdx → first sub index
  const stepFirstSub: number[] = [];
  subStepMap.forEach((entry, i) => {
    if (stepFirstSub[entry.stepIdx] === undefined) stepFirstSub[entry.stepIdx] = i;
  });

  vpills.forEach((pill, stepIdx) => {
    pill.addEventListener('click', () => {
      const firstSubIdx = stepFirstSub[stepIdx] ?? 0;
      lockScroll();
      setActiveSub(firstSubIdx);
      if (tabletSection && !isMobile) {
        const sectionH = tabletSection.offsetHeight;
        const vh = window.innerHeight;
        const scrollable = sectionH - vh;
        const slideStart = 0.06;
        const slideEnd = 0.95;
        const subProgress = firstSubIdx / tabletSlides.length;
        const totalProgress = slideStart + subProgress * (slideEnd - slideStart);
        const sectionTop = tabletSection.getBoundingClientRect().top + window.scrollY;
        window.scrollTo({ top: sectionTop + totalProgress * scrollable, behavior: 'smooth' });
      }
    });
  });

  // Sub pill clicks
  subPills.forEach((pill) => {
    pill.addEventListener('click', () => {
      const globalIdx = parseInt(pill.dataset.subGlobal || '0', 10);
      lockScroll();
      setActiveSub(globalIdx);
      if (tabletSection && !isMobile) {
        const sectionH = tabletSection.offsetHeight;
        const vh = window.innerHeight;
        const scrollable = sectionH - vh;
        const slideStart = 0.06;
        const slideEnd = 0.95;
        const subProgress = globalIdx / tabletSlides.length;
        const totalProgress = slideStart + subProgress * (slideEnd - slideStart);
        const sectionTop = tabletSection.getBoundingClientRect().top + window.scrollY;
        window.scrollTo({ top: sectionTop + totalProgress * scrollable, behavior: 'smooth' });
      }
    });
  });

  // ═══ Why SACS — scrollytelling with images ═══
  const whyItems = document.querySelectorAll<HTMLElement>('.why-sacs-item');
  const whyImgs = document.querySelectorAll<HTMLElement>('.why-sacs-img');

  if (whyItems.length > 0 && whyImgs.length > 0) {
    const whyObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const idx = (entry.target as HTMLElement).dataset.whyIdx;
            whyItems.forEach(item => item.classList.toggle('active', item.dataset.whyIdx === idx));
            whyImgs.forEach(img => img.classList.toggle('active', img.dataset.whyImg === idx));
          }
        });
      },
      { threshold: 0.3, rootMargin: '0px 0px -30% 0px' }
    );
    whyItems.forEach(item => whyObserver.observe(item));
  }

  // ═══ Square-style sticky features — GSAP ScrollTrigger (Apple-style) ═══
  const sqSection = document.querySelector<HTMLElement>('.sq-features--sc');
  const sqBlocks = Array.from(document.querySelectorAll<HTMLElement>('.sq-features--sc .sq-feature-block'));
  const sqImgs = Array.from(document.querySelectorAll<HTMLImageElement>('.sq-features--sc .sq-features-img'));

  if (sqSection && sqBlocks.length > 0 && sqImgs.length > 0 && window.innerWidth >= 1024 && !prefersReducedMotion) {
    // Set initial states
    gsap.set(sqImgs[0], { opacity: 1, scale: 1, y: 0, filter: 'blur(0px)' });
    for (let i = 1; i < sqImgs.length; i++) {
      gsap.set(sqImgs[i], { opacity: 0, scale: 0.82, y: 60, filter: 'blur(8px)' });
    }
    gsap.set(sqBlocks[0], { opacity: 1 });
    for (let i = 1; i < sqBlocks.length; i++) {
      gsap.set(sqBlocks[i], { opacity: 0.15 });
    }

    // Create scrub timelines for each transition
    sqBlocks.forEach((block, i) => {
      if (i === 0) return;

      const prevImg = sqImgs[i - 1];
      const nextImg = sqImgs[i];
      const prevBlock = sqBlocks[i - 1];

      if (!prevImg || !nextImg) return;

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: block,
          start: 'top 80%',
          end: 'top 20%',
          scrub: 0.8,
        },
      });

      // Outgoing image: shrink + blur + fade + move up
      tl.to(prevImg, {
        opacity: 0, scale: 0.85, y: -40, filter: 'blur(6px)',
        ease: 'none', duration: 1
      }, 0);

      // Incoming image: grow + unblur + fade in + move up from below
      tl.fromTo(nextImg,
        { opacity: 0, scale: 0.82, y: 60, filter: 'blur(8px)' },
        { opacity: 1, scale: 1, y: 0, filter: 'blur(0px)', ease: 'none', duration: 1 },
      0);

      // Text transitions
      tl.fromTo(block, { opacity: 0.15 }, { opacity: 1, ease: 'none', duration: 1 }, 0);
      if (prevBlock) {
        tl.to(prevBlock, { opacity: 0.15, ease: 'none', duration: 1 }, 0);
      }
    });

  } else if (sqBlocks.length > 0) {
    // Mobile fallback: IntersectionObserver
    const sqObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const block = entry.target as HTMLElement;
            const section = block.closest('.sq-features');
            section?.querySelectorAll('.sq-feature-block').forEach(b => b.classList.remove('active'));
            block.classList.add('active');
            const newSrc = block.dataset.sqImg;
            if (newSrc && section) {
              section.querySelectorAll<HTMLImageElement>('.sq-features-img').forEach(img => {
                img.classList.toggle('sq-img--active', img.dataset.sqSrc === newSrc);
              });
            }
          }
        });
      },
      { threshold: 0.6 }
    );
    sqBlocks.forEach(b => sqObserver.observe(b));
  }

  // ═══ Reels — reveal on scroll with stagger ═══
  const reelCards = document.querySelectorAll('.reel-card');
  if (reelCards.length > 0) {
    const reelsObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            reelsObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    reelCards.forEach((card) => reelsObserver.observe(card));
  }

  // ═══ Scrollytelling — sticky image + features ═══
  const scrollyItems = document.querySelectorAll<HTMLElement>('.scrolly-item');
  const scrollyImgs = document.querySelectorAll<HTMLElement>('.scrolly-img');
  const scrollyBgs = document.querySelectorAll<HTMLElement>('.scrolly-bg');

  if (scrollyItems.length > 0 && scrollyImgs.length > 0) {
    const scrollyObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const idx = (entry.target as HTMLElement).dataset.scrollyIdx;
            scrollyItems.forEach((item) =>
              item.classList.toggle('active', item.dataset.scrollyIdx === idx)
            );
            scrollyImgs.forEach((img) =>
              img.classList.toggle('active', img.dataset.scrollyImg === idx)
            );
            scrollyBgs.forEach((bg) =>
              bg.classList.toggle('active', bg.dataset.scrollyBg === idx)
            );
          }
        });
      },
      { rootMargin: '-35% 0px -35% 0px' }
    );
    scrollyItems.forEach((item) => scrollyObserver.observe(item));
  }




  // ═══ Platform accordion ═══
  const accordionItems = document.querySelectorAll<HTMLDivElement>('.accordion-item');
  const platformMockups = document.querySelectorAll<HTMLDivElement>('.platform-mockup');

  const accordionToMockup: Record<string, string> = {
    pos: 'pos',
    stock: 'stock',
    crm: 'crm',
    reports: 'reports',
    ai: 'ai',
  };

  if (accordionItems.length > 0) {
    let activeAccordion = 0;
    let accInterval: ReturnType<typeof setInterval> | null = null;
    const ACC_MS = 5000;

    function setActiveAccordion(index: number) {
      const ucId = accordionItems[index]?.dataset.accordion || '';

      accordionItems.forEach((item, i) => {
        const isActive = i === index;
        item.classList.toggle('active', isActive);
        const btn = item.querySelector('.accordion-header');
        if (btn) btn.setAttribute('aria-expanded', String(isActive));
      });

      const mockupId = accordionToMockup[ucId] || '';
      platformMockups.forEach((m) => m.classList.toggle('active', m.dataset.mockup === mockupId));

      activeAccordion = index;
    }

    function startAccCycle() {
      stopAccCycle();
      accInterval = setInterval(() => {
        setActiveAccordion((activeAccordion + 1) % accordionItems.length);
      }, ACC_MS);
    }

    function stopAccCycle() {
      if (accInterval) { clearInterval(accInterval); accInterval = null; }
    }

    accordionItems.forEach((item, i) => {
      const header = item.querySelector('.accordion-header');
      if (header) {
        header.addEventListener('click', () => {
          stopAccCycle();
          setActiveAccordion(i);
          startAccCycle();
        });
      }
    });

    if (!prefersReducedMotion) startAccCycle();
    setActiveAccordion(0);
  }

  // ═══ WhatsApp Carousel ═══
  (() => {
    const slides = document.querySelectorAll<HTMLElement>('.wa-carousel-slide');
    const dots = document.querySelectorAll<HTMLElement>('.wa-dot');
    if (!slides.length) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval>;
    const INTERVAL = 4000;

    function goTo(idx: number) {
      slides[current]?.classList.remove('wa-carousel-slide--active');
      dots[current]?.classList.remove('wa-dot--active');
      current = idx % slides.length;
      slides[current]?.classList.add('wa-carousel-slide--active');
      dots[current]?.classList.add('wa-dot--active');
    }

    function startAutoplay() {
      timer = setInterval(() => goTo(current + 1), INTERVAL);
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        clearInterval(timer);
        const idx = parseInt(dot.dataset.waSlide || '0', 10);
        goTo(idx);
        startAutoplay();
      });
    });

    if (!prefersReducedMotion) startAutoplay();

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) clearInterval(timer);
      else if (!prefersReducedMotion) startAutoplay();
    });
  })();

  // ═══ Catalog Import Animation — auto-plays when slide becomes active ═══
  (() => {
    const overlay = document.getElementById('cat-import-overlay');
    const slide = document.querySelector('[data-slide="stock-inventario"]');
    if (!overlay || !slide) return;

    let hasPlayed = false;

    const playImport = () => {
      if (hasPlayed) return;
      hasPlayed = true;
      // Start with overlay visible (import in progress)
      overlay.classList.add('cat-import--active');
      // After animation finishes, hide overlay to reveal data table
      setTimeout(() => {
        overlay.style.transition = 'opacity 0.5s ease';
        overlay.style.opacity = '0';
        setTimeout(() => {
          overlay.classList.remove('cat-import--active');
          overlay.style.pointerEvents = 'none';
        }, 500);
      }, 2200);
    };

    // Watch for the slide becoming active (via class change)
    const observer = new MutationObserver(() => {
      if (slide.classList.contains('active')) playImport();
    });
    observer.observe(slide, { attributes: true, attributeFilter: ['class'] });

    // Also check if already active on load
    if (slide.classList.contains('active')) playImport();
  })();

  // ═══ Social Commerce Tabs + Entrance ═══
  (() => {
    const section = document.querySelector<HTMLElement>('.social-commerce-section');
    const tabs = document.querySelectorAll<HTMLButtonElement>('.sc-tab');
    const panels = document.querySelectorAll<HTMLElement>('.sc-flow-panel');

    if (section && !prefersReducedMotion) {
      const io = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          section.classList.add('sc-visible');
          io.disconnect();
        }
      }, { threshold: 0.1 });
      io.observe(section);
    } else if (section) {
      section.classList.add('sc-visible');
    }

    function switchToTab(idx: number) {
      const tab = tabs[idx];
      if (!tab) return;
      const platform = tab.dataset.scPlatform;
      if (!platform) return;
      tabs.forEach(t => t.classList.remove('sc-tab--active'));
      tab.classList.add('sc-tab--active');
      panels.forEach(p => {
        const isTarget = p.dataset.scPanel === platform;
        p.classList.remove('sc-flow-panel--active');
        if (isTarget) p.classList.add('sc-flow-panel--active');
      });
    }

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => switchToTab(i));
    });
  })();
</script>
