  .omni-event {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 8px;
    padding: 7px 9px;
  }
  .omni-event-channel {
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: 7px;
    font-weight: 800;
    text-transform: uppercase;
