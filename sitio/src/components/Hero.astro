---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
}

const {
  eyebrow = 'Comercio Consciente',
  title,
  subtitle,
  primaryCTA = { label: 'Prueba 7 dias gratis', href: '/prueba-gratis' },
  secondaryCTA = { label: 'Ver demo', href: '/producto' },
} = Astro.props;

const steps = [
  {
    id: 'pos',
    step: 1,
    verb: 'Vende',
    title: 'Vende más en cada punto',
    subtitle: 'Una plataforma, todos los canales.',
    bgKey: 'pos',
    subs: [
      { id: 'pos-pdv', label: 'Punto de Venta', desc: 'Cobra con tarjeta, efectivo, transferencia o monedero — y combínalos en una sola venta. iPad, celular o computadora, con o sin internet. El cajero nunca se queda parado.', href: '/producto/punto-de-venta', image: '/images/screen-pos.webp' },
      { id: 'pos-cambios', label: 'Cambios y devoluciones', desc: 'Cambia talla, devuelve con ticket o sin él, abona a monedero o reembolsa al método original. Política configurable, autorización por gerente y trazabilidad completa.', href: '/producto/punto-de-venta', image: null },
      { id: 'pos-movil', label: 'Cobro móvil — line-busting', desc: 'Acerca al cliente desde el piso de venta: escanea, cobra y envía ticket por WhatsApp desde el celular del vendedor. Sin filas en hora pico, sin perder ventas.', href: '/producto/punto-de-venta', image: null },
      { id: 'pos-apartados', label: 'Pedidos y Apartados', desc: 'Toma anticipo, bloquea el stock, cobra a plazos y convierte el apartado en venta cuando termina. Recordatorios automáticos por email y WhatsApp.', href: '/producto/apartados-y-pedidos', image: null },
      { id: 'pos-ecommerce', label: 'Tienda en línea', desc: 'Tu tienda en línea conectada al mismo inventario, clientes y precios. Cada venta online baja stock en la sucursal correcta al segundo.', href: '/producto/tienda-en-linea', image: null },
      { id: 'pos-social', label: 'Vende en META & TikTok Shop', desc: 'Conecta tu catálogo a Instagram, Facebook y TikTok Shop con stock y cobro sincronizados — sin re-publicar nada.', href: '/producto/social-commerce', image: null },
    ],
  },
  {
    id: 'stock',
    step: 2,
    verb: 'Controla',
    title: 'Controla tu operación en tiempo real',
    subtitle: 'Un solo inventario, todas tus sucursales.',
    bgKey: 'stock',
    subs: [
      { id: 'stock-inventario', label: 'Inventario multi-sucursal', desc: 'Stock por sucursal y CEDIS en tiempo real, sincronizado al segundo. Vende donde sea, descuenta donde corresponde.', href: '/producto/inventario-omnicanal', image: null },
      { id: 'stock-conteo', label: 'Auditoría y conteo físico', desc: 'Escanea códigos de barras con tu celular y actualiza el inventario en segundos. Audita por sucursal, sin laptops, sin Excel y sin paros operativos.', href: '/producto/conteo-fisico', image: null },
      { id: 'stock-alertas', label: 'Recepción de mercancía', desc: 'Recibe pedidos escaneando cajas, valida cantidades contra la OC y actualiza tu inventario al instante.', href: '/producto/ordenes-de-compra', image: null },
    ],
  },
  {
    id: 'crm',
    step: 3,
    verb: 'Fideliza',
    title: 'Fideliza a cada cliente',
    subtitle: 'Cada cliente reconocido en cada visita.',
    bgKey: 'crm',
    subs: [
      { id: 'crm-lealtad', label: 'Monedero electrónico', desc: 'Saldo recargable con cashback automático en cada compra. El cliente lo acumula y canjea desde el POS o el portal — sin apps extra, sin tarjetas físicas, sin terceros.', href: '/producto/programa-de-lealtad', image: null },
      { id: 'crm-seguimiento', label: 'Recomendaciones de productos', desc: 'Sugiere prendas y artículos basados en las últimas compras de cada cliente — desde el POS y desde la tienda en línea.', href: '/producto/clientes-y-crm', image: null },
      { id: 'crm-omnicanal', label: 'CRM Omnicanal', desc: 'Una sola ficha por cliente con su historial de tienda física, ecommerce, redes sociales y WhatsApp — segmentación automática por comportamiento real.', href: '/producto/clientes-y-crm', image: null },
      { id: 'crm-email', label: 'Email marketing', desc: 'Editor visual, segmentación por comportamiento de compra, A/B testing y métricas en tiempo real. Sin Mailchimp, sin tarifas extra — todo conectado a tus ventas reales.', href: '/producto/marketing-por-correo', image: null },
      { id: 'crm-whatsapp', label: 'WhatsApp marketing', desc: 'Broadcasts a segmentos con plantillas pre-aprobadas por Meta. 90% de apertura, conectado al CRM, métricas reales — sin pagar por mensaje fallido.', href: '/producto/marketing-por-whatsapp', image: null },
    ],
  },
  {
    id: 'ai',
    step: 4,
    verb: 'Automatiza',
    title: 'Automatiza con inteligencia',
    subtitle: 'AXO opera por ti, 24/7.',
    bgKey: 'ai',
    subs: [
      { id: 'ai-empresarial', label: 'IA Empresarial', desc: 'AXO analiza tus ventas, predice demanda, automatiza órdenes de compra y responde por WhatsApp con tu catálogo real.', href: '/producto/axo-copiloto-ia', image: null },
    ],
  },
];

const allSubs = steps.flatMap((s, stepIdx) =>
  s.subs.map((sub) => ({ ...sub, stepIdx, stepId: s.id, stepTitle: s.title, bgKey: s.bgKey }))
);

// Scroll-driven animation covers subs 0-5 (Vende ×4 + Controla first 2)
// Subs 6-9 are still accessible via click on the nav pills

// Backward compat for platform accordion
const useCases = [
  { id: 'pos', title: 'Vende desde cualquier punto', desc: 'Convierte cualquier dispositivo en un punto de venta. Cobra con tarjeta, efectivo o transferencia en segundos.', cta: 'Ver más' },
  { id: 'stock', title: 'Controla stock sin esfuerzo', desc: 'Alertas de reabasto, movimientos entre sucursales y conteo rápido desde el celular.', cta: 'Ver más' },
  { id: 'crm', title: 'Fideliza a cada cliente', desc: 'Captura datos automáticamente, segmenta por comportamiento y lanza promociones personalizadas.', cta: 'Ver más' },
  { id: 'reports', title: 'Reportes que sí entiendes', desc: 'Dashboards claros con las métricas que importan. Sin Excel, sin complicaciones.', cta: 'Ver más' },
  { id: 'ai', title: 'IA que te asesora', desc: 'AXO analiza tus datos y te sugiere qué hacer: reabastecer, lanzar promo o ajustar precio.', cta: 'Ver más' },
];
---

<!-- ═══ BLOQUE 1: Banner — Fondo claro con texturas ═══ -->
<section class="hero-banner" id="hero-section">
  <!-- Texturas decorativas -->
  <div class="hero-shapes" aria-hidden="true">
    <div class="shape shape-circle-1"></div>
    <div class="shape shape-circle-2"></div>
    <div class="shape shape-square-1"></div>
    <div class="shape shape-dots"></div>
  </div>

  <div class="hero-banner-content">
    <div class="hero-text">
      <h1 class="hero-title">{title}</h1>
      <p class="hero-subtitle">{subtitle}</p>
      <div class="hero-ctas">
        <a href={primaryCTA.href} class="hero-btn hero-btn-filled">
          {primaryCTA.label}
        </a>
        <a href={secondaryCTA.href} class="hero-btn hero-btn-outline">
          {secondaryCTA.label}
        </a>
      </div>

      <!-- Credibility badges -->
      <div class="hero-bottom-bar">
        <div class="hero-badges">
          <div class="hero-badge">
            <svg class="hero-badge-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M10 1l2.39 4.84L18 6.71l-4 3.9.94 5.5L10 13.48l-4.94 2.63.94-5.5-4-3.9 5.61-.87L10 1z" fill="#E8A838"/>
            </svg>
            <div>
              <span class="hero-badge-value">4.8/5</span>
              <span class="hero-badge-label">Google Reviews</span>
            </div>
          </div>
          <div class="hero-badge-divider"></div>
          <div class="hero-badge">
            <svg class="hero-badge-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <rect x="2" y="4" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M6 10h8M10 7v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <div>
              <span class="hero-badge-value">+3,000</span>
              <span class="hero-badge-label">Marcas activas en México y Latam</span>
            </div>
          </div>
          <div class="hero-badge-divider"></div>
          <div class="hero-badge">
            <svg class="hero-badge-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M10 2a8 8 0 100 16 8 8 0 000-16z" stroke="currentColor" stroke-width="1.5"/>
              <path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div>
              <span class="hero-badge-value">99.9%</span>
              <span class="hero-badge-label">Uptime</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile hero image -->
      <div class="hero-mobile-visual">
        <div class="hero-mobile-image-wrapper">
          <img
            src="/images/hero-sacs-store.webp"
            alt="Persona usando SACS en tablet en su tienda de ropa"
            class="hero-mobile-image"
            width="900"
            height="600"
            loading="eager"
          />
          <div class="hero-mobile-notif hero-mobile-notif-1" aria-hidden="true">
            <div class="hmn-icon hmn-icon-shop">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#fff"><path d="M20 4H4v2l1 1v11h14V7l1-1V4zM9 18v-4h6v4H9zm9 0h-1v-5a1 1 0 00-1-1H8a1 1 0 00-1 1v5H6V7.5l-.5-.5h13l-.5.5V18z"/><path d="M3 2h18a1 1 0 011 1v1H2V3a1 1 0 011-1z"/></svg>
            </div>
            <div class="hmn-body">
              <span class="hmn-title">Tienda en línea</span>
              <span class="hmn-msg">Pedido #384 — $1,290</span>
            </div>
          </div>
          <div class="hero-mobile-notif hero-mobile-notif-2" aria-hidden="true">
            <div class="hmn-icon hmn-icon-inv">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#fff"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            </div>
            <div class="hmn-body">
              <span class="hmn-title">Inventario</span>
              <span class="hmn-msg">Transferir 40 uds. a Suc. Centro</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Hero image + floating notifications -->
    <div class="hero-visual">
      <div class="hero-image-wrapper">
        <img
          src="/images/hero-sacs-store.webp"
          alt="Persona usando SACS en tablet en su tienda de ropa"
          class="hero-image"
          width="900"
          height="600"
          loading="eager"
          fetchpriority="high"
        />
        <!-- Notificaciones animadas sobre la imagen -->
        <div class="hero-notif hero-notif-1" aria-hidden="true">
          <div class="hero-notif-icon hero-notif-icon-loyalty">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.325 0-4.47-.744-6.227-2.01l-.435-.326-2.847.954.954-2.847-.326-.435A9.956 9.956 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>
          </div>
          <div class="hero-notif-body">
            <span class="hero-notif-title">Fidelización</span>
            <span class="hero-notif-msg">5 seguimientos pendientes de clientes</span>
          </div>
          <span class="hero-notif-badge">5</span>
        </div>

        <div class="hero-notif hero-notif-2" aria-hidden="true">
          <div class="hero-notif-icon hero-notif-icon-shop">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M20 4H4v2l1 1v11h14V7l1-1V4zM9 18v-4h6v4H9zm9 0h-1v-5a1 1 0 00-1-1H8a1 1 0 00-1 1v5H6V7.5l-.5-.5h13l-.5.5V18z"/><path d="M3 2h18a1 1 0 011 1v1H2V3a1 1 0 011-1z"/></svg>
          </div>
          <div class="hero-notif-body">
            <span class="hero-notif-title">Tienda en línea</span>
            <span class="hero-notif-msg">Pedido #384 — $1,290</span>
          </div>
          <span class="hero-notif-badge">+1</span>
        </div>

        <div class="hero-notif hero-notif-3" aria-hidden="true">
          <div class="hero-notif-icon hero-notif-icon-inventory">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </div>
          <div class="hero-notif-body">
            <span class="hero-notif-title">Nivelación de inventario</span>
            <span class="hero-notif-msg">Transferir 40 uds. a Suc. Centro</span>
          </div>
          <span class="hero-notif-time">Sugerencia</span>
        </div>

        <div class="hero-notif hero-notif-4" aria-hidden="true">
          <div class="hero-notif-icon hero-notif-icon-receiving">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M12 2L2 7v10l10 5 10-5V7L12 2z" fill="none" stroke="#fff" stroke-width="1.5"/><path d="M12 12v10M2 7l10 5 10-5" fill="none" stroke="#fff" stroke-width="1.5"/><path d="M8 4.5l8 4" fill="none" stroke="#fff" stroke-width="1.5"/></svg>
          </div>
          <div class="hero-notif-body">
            <span class="hero-notif-title">Recepción de mercancía</span>
            <span class="hero-notif-msg">OC #192 llega mañana — 120 pzas.</span>
          </div>
          <span class="hero-notif-time">Mañana</span>
        </div>

        <div class="hero-notif hero-notif-5" aria-hidden="true">
          <div class="hero-notif-icon hero-notif-icon-shrink">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M12 9v2m0 4h.01M5.07 19H18.93a2 2 0 001.73-3L13.73 4a2 2 0 00-3.46 0L3.34 16a2 2 0 001.73 3z" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="hero-notif-body">
            <span class="hero-notif-title">Alerta de merma</span>
            <span class="hero-notif-msg">Suc. Polanco: 2.3% esta semana</span>
          </div>
          <span class="hero-notif-badge">!</span>
        </div>

        <div class="hero-notif hero-notif-6" aria-hidden="true">
          <div class="hero-notif-icon hero-notif-icon-restock">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M23 4l-6 6M17 4h6v6M1 20l6-6m0 6H1v-6" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="hero-notif-body">
            <span class="hero-notif-title">Reabasto automático</span>
            <span class="hero-notif-msg">12 SKUs bajo mínimo en CEDIS</span>
          </div>
          <span class="hero-notif-badge">12</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ BLOQUE 2: Tablet — paso a paso ═══ -->
<section class="hero-tablet-section" id="tablet-section">
  <!-- ─── 4 Pillar Sections (Square-style: accordion left + iPad right) ─── -->

  <!-- ── Pillar 1: Vende ── -->
  <div class="pillar-section pillar-section--pos pillar-section--right" data-pillar="pos">
    <div class="pillar-bg-pattern" aria-hidden="true"></div>
    <div class="pillar-inner container">
      <div class="pillar-text">
        <span class="pillar-eyebrow">{steps[0].verb.toUpperCase()}</span>
        <h2 class="pillar-h2">{steps[0].title}.</h2>
        <p class="pillar-subtitle">{steps[0].subtitle}</p>
        <div class="pillar-accordion" role="tablist" aria-label="Opciones de Vende">
          {steps[0].subs.map((sub, i) => (
            <div class={`pillar-acc${i === 0 ? ' is-open' : ''}`} data-acc-idx={i} style={`--i:${i}`}>
              <button class="pillar-acc-btn" type="button" aria-expanded={i === 0 ? 'true' : 'false'} data-slide-target={sub.id}>
                <span class="pillar-acc-label">{sub.label}</span>
                <span class="pillar-acc-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path class="acc-h" d="M5 12h14"/><path class="acc-v" d="M12 5v14"/></svg>
                </span>
              </button>
              <div class="pillar-acc-body">
                <p class="pillar-acc-desc">{sub.desc}</p>
                <a href={sub.href} class="pillar-acc-cta">Conocer más
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="pillar-visual">
        <div class="hero-tablet-frame pillar-frame">
          <div class="tablet-camera"></div>
          <div class="tablet-screen">
            {/* ── Vende: Punto de Venta ── */}
            <div class="tablet-slide active" data-slide="pos-pdv">
              <img src="/images/screen-pos.webp" alt="Punto de Venta SACS" class="tablet-slide-img" loading="lazy" />
            </div>

            {/* ── Vende: Cambios y devoluciones ── */}
            <div class="tablet-slide" data-slide="pos-cambios">
              <div class="rtn-frame">
                <div class="rtn-topbar">
                  <div class="rtn-topbar-left">
                    <span class="rtn-topbar-back">‹</span>
                    <span class="rtn-topbar-title">Cambio · Ticket A-78443</span>
                  </div>
                  <div class="rtn-topbar-meta">Andrea G. · Polanco · 28 abr 11:42</div>
                </div>
                <div class="rtn-grid">
                  <div class="rtn-search-col">
                    <div class="rtn-mini-label">SELECCIONA EL ITEM A CAMBIAR</div>
                    <div class="rtn-items">
                      <div class="rtn-item rtn-item--selected">
                        <div class="rtn-thumb"><img src="/images/reco-blusa.webp" alt="Blusa satinada" loading="lazy" width="80" height="80" /></div>
                        <div class="rtn-item-body">
                          <div class="rtn-item-name">Blusa satinada</div>
                          <div class="rtn-item-meta">Talla M · SKU 78440</div>
                        </div>
                        <div class="rtn-item-right">
                          <span class="rtn-check">✓</span>
                          <span class="rtn-item-price">$1,290</span>
                        </div>
                      </div>
                      <div class="rtn-item">
                        <div class="rtn-thumb"><img src="/images/reco-falda.webp" alt="Falda midi plisada" loading="lazy" width="80" height="80" /></div>
                        <div class="rtn-item-body">
                          <div class="rtn-item-name">Falda midi plisada</div>
                          <div class="rtn-item-meta">Talla 28 · SKU 78441</div>
                        </div>
                        <div class="rtn-item-right">
                          <span class="rtn-check rtn-check--off"></span>
                          <span class="rtn-item-price rtn-item-price--off">$1,250</span>
                        </div>
                      </div>
                      <div class="rtn-item">
                        <div class="rtn-thumb"><img src="/images/reco-blazer.webp" alt="Blazer oversize" loading="lazy" width="80" height="80" /></div>
                        <div class="rtn-item-body">
                          <div class="rtn-item-name">Blazer oversize</div>
                          <div class="rtn-item-meta">Talla S · SKU 78442</div>
                        </div>
                        <div class="rtn-item-right">
                          <span class="rtn-check rtn-check--off"></span>
                          <span class="rtn-item-price rtn-item-price--off">$880</span>
                        </div>
                      </div>
                      <div class="rtn-item">
                        <div class="rtn-thumb"><img src="/images/reco-falda.webp" alt="Pantalón palazzo" loading="lazy" width="80" height="80" /></div>
                        <div class="rtn-item-body">
                          <div class="rtn-item-name">Pantalón palazzo</div>
                          <div class="rtn-item-meta">Talla 30 · SKU 78443</div>
                        </div>
                        <div class="rtn-item-right">
                          <span class="rtn-check rtn-check--off"></span>
                          <span class="rtn-item-price rtn-item-price--off">$1,490</span>
                        </div>
                      </div>
                      <div class="rtn-item">
                        <div class="rtn-thumb"><img src="/images/reco-blusa.webp" alt="Camiseta crop" loading="lazy" width="80" height="80" /></div>
                        <div class="rtn-item-body">
                          <div class="rtn-item-name">Camiseta crop algodón</div>
                          <div class="rtn-item-meta">Talla S · SKU 78444</div>
                        </div>
                        <div class="rtn-item-right">
                          <span class="rtn-check rtn-check--off"></span>
                          <span class="rtn-item-price rtn-item-price--off">$590</span>
                        </div>
                      </div>
                      <div class="rtn-item">
