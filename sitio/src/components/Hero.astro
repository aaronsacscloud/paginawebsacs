<style>
  /* ═══════════════════════════════════════════
     BLOQUE 1: Banner — Fondo claro con texturas
     ═══════════════════════════════════════════ */

  .hero-banner {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #FFFFFF;
    overflow: hidden;
    padding-top: 110px;
    padding-bottom: var(--space-12, 3rem);
  }

  /* ─── Gradient mesh orbs + noise texture ─── */
  .hero-shapes {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  /* Noise grain overlay for depth */
  .hero-shapes::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    opacity: 0.5;
    mix-blend-mode: multiply;
  }

  .shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  /* SACS Blue gradient orb — top-right */
  .shape-circle-1 {
    top: -10%;
    right: -5%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(75, 123, 229, 0.08) 0%, transparent 70%);
  }

  /* Teal orb — bottom-left */
  .shape-circle-2 {
    bottom: -15%;
    left: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(42, 181, 160, 0.06) 0%, transparent 70%);
  }

  /* Gold accent — subtle, center-right */
  .shape-square-1 {
    top: 40%;
    right: 20%;
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(232, 168, 56, 0.05) 0%, transparent 70%);
    filter: blur(100px);
  }

  /* Dot pattern — subtle grid */
  .shape-dots {
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    border-radius: 0;
    filter: none;
    background-image: radial-gradient(circle, rgba(0, 0, 0, 0.06) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.4;
  }

  .hero-banner-content {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    flex-direction: column;
    max-width: var(--max-width);
