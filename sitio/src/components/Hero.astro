</style>

<script>
  // ═══ Scroll-driven video transitions ═══
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const videoSection = document.querySelector<HTMLElement>('.hero-video-section');
  const videoSticky = document.querySelector<HTMLElement>('.hero-video-sticky');
  const checkItems = document.querySelectorAll<HTMLLIElement>('.hero-check-item');
  const videoMockups = document.querySelectorAll<HTMLDivElement>('[data-overlay]');

  function setActiveCheck(index: number) {
    checkItems.forEach((item, i) => item.classList.toggle('active', i === index));
    videoMockups.forEach((m) => {
      const id = m.dataset.overlay;
      const featureId = checkItems[index]?.dataset.feature;
      m.classList.toggle('active', id === featureId);
    });
  }

  if (!prefersReducedMotion && videoSection && videoSticky) {
    let lastFeatureIdx = -1;

    const onScroll = () => {
      const rect = videoSection.getBoundingClientRect();
      const sectionH = videoSection.offsetHeight;
      const vh = window.innerHeight;
      const scrolled = -rect.top;
      const scrollable = sectionH - vh;

      if (scrolled < 0 || scrolled > scrollable) {
        if (scrolled > scrollable) {
          videoSticky.style.setProperty('--vid-progress', '1');
        }
        return;
      }

      const totalProgress = scrolled / scrollable;

      const contractEnd = 0.15;
      const vidProgress = Math.min(1, totalProgress / contractEnd);
      videoSticky.style.setProperty('--vid-progress', String(vidProgress));

      const featureStart = 0.15;
      const featureEnd = 0.92;
      const featureProgress = Math.max(0, Math.min(1,
        (totalProgress - featureStart) / (featureEnd - featureStart)
      ));

      const numFeatures = checkItems.length;
      const featureIdx = Math.min(numFeatures - 1, Math.floor(featureProgress * numFeatures));

      if (featureIdx !== lastFeatureIdx) {
        setActiveCheck(featureIdx);
        lastFeatureIdx = featureIdx;
      }
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  } else {
    setActiveCheck(0);
    if (videoSticky) videoSticky.style.setProperty('--vid-progress', '1');
  }

  // ═══ Expanding panels ═══
  const panels = document.querySelectorAll<HTMLElement>('.sp-panel');
  if (panels.length > 0) {
    let panelInterval: ReturnType<typeof setInterval> | null = null;
    let activePanel = 0;
    const PANEL_MS = 4500;

    function setActivePanel(idx: number) {
      panels.forEach((p, i) => p.classList.toggle('active', i === idx));
      activePanel = idx;
    }

    function startPanelCycle() {
      stopPanelCycle();
      panelInterval = setInterval(() => {
        setActivePanel((activePanel + 1) % panels.length);
      }, PANEL_MS);
    }

    function stopPanelCycle() {
      if (panelInterval) { clearInterval(panelInterval); panelInterval = null; }
    }

    panels.forEach((panel, i) => {
      panel.addEventListener('click', () => {
        stopPanelCycle();
        setActivePanel(i);
        startPanelCycle();
      });
    });

    if (!prefersReducedMotion) startPanelCycle();
  }

  // ═══ Platform accordion ═══
  const accordionItems = document.querySelectorAll<HTMLDivElement>('.accordion-item');
  const platformMockups = document.querySelectorAll<HTMLDivElement>('.platform-mockup');

  const accordionToMockup: Record<string, string> = {
    pos: 'pos',
    stock: 'stock',
    crm: 'crm',
    reports: 'reports',
    ai: 'ai',
  };

  if (accordionItems.length > 0) {
    let activeAccordion = 0;
    let accInterval: ReturnType<typeof setInterval> | null = null;
    const ACC_MS = 5000;

    function setActiveAccordion(index: number) {
      const ucId = accordionItems[index]?.dataset.accordion || '';

      accordionItems.forEach((item, i) => {
        const isActive = i === index;
        item.classList.toggle('active', isActive);
        const btn = item.querySelector('.accordion-header');
        if (btn) btn.setAttribute('aria-expanded', String(isActive));
      });

      const mockupId = accordionToMockup[ucId] || '';
      platformMockups.forEach((m) => m.classList.toggle('active', m.dataset.mockup === mockupId));

      activeAccordion = index;
    }

    function startAccCycle() {
      stopAccCycle();
      accInterval = setInterval(() => {
        setActiveAccordion((activeAccordion + 1) % accordionItems.length);
      }, ACC_MS);
    }

    function stopAccCycle() {
      if (accInterval) { clearInterval(accInterval); accInterval = null; }
    }

    accordionItems.forEach((item, i) => {
      const header = item.querySelector('.accordion-header');
      if (header) {
        header.addEventListener('click', () => {
          stopAccCycle();
          setActiveAccordion(i);
          startAccCycle();
        });
      }
    });

    if (!prefersReducedMotion) startAccCycle();
    setActiveAccordion(0);
  }
</script>
