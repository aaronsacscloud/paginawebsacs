     Sticky Features — estilo Square Bitcoin
     ═══════════════════════════════════════════ */

  .sq-features {
    background: #fff;
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  .sq-features-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
