  /* ── CRM Omnicanal slide (legacy, unused) ── */
  .omni-frame {
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #FAFAFA;
    padding: 4.5% 5%;
    display: flex;
    flex-direction: column;
    gap: 14px;
    color: #1A1A1A;
    font-family: var(--font-body);
  }
  .omni-header {
    display: flex;
