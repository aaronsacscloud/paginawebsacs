  }
  .mk-metric-fill {
    height: 100%;
    background: #4B7BE5;
    border-radius: 2px;
    width: var(--mk-bar-w, 0%);
  }
  .mk-metric-fill--green { background: #2AB5A0; }
  /* Animated bar fill — runs once per slide entry */
  .mk-bar--anim {
    width: 0;
    animation: mk-bar-fill 1.4s cubic-bezier(0.25, 0.8, 0.3, 1) 0.2s forwards;
  }
  @keyframes mk-bar-fill {
    from { width: 0; }
    to   { width: var(--mk-bar-w, 100%); }
  }

  /* ROI card — light Square-style, anchored at bottom */
  .mk-roi {
    margin-top: auto;
    padding: 12px 14px;
    background: linear-gradient(135deg, rgba(42,181,160,0.10), rgba(75,123,229,0.06));
    border: 1px solid rgba(42,181,160,0.30);
    color: #1A1A1A;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    box-shadow: 0 2px 12px -4px rgba(42,181,160,0.18);
    position: relative;
  }
  .mk-roi-label {
    font-size: 7.5px;
    color: rgba(0,0,0,0.55);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
  }
  .mk-roi-value {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 800;
    color: #1A8F7A;
    letter-spacing: -0.03em;
    line-height: 1;
    animation: mk-roi-glow 4s ease-in-out infinite;
  }
  @keyframes mk-roi-glow {
    0%, 100% { text-shadow: 0 0 0 rgba(42,181,160,0); }
    50%      { text-shadow: 0 0 16px rgba(42,181,160,0.45); }
  }
  .mk-roi-note {
    font-size: 7.5px;
    color: rgba(0,0,0,0.55);
    line-height: 1.4;
  }

  /* ── Email marketing slide ── */
  .mk-email-frame {
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #FAFAFA;
    padding: 2% 2.5%;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .mk-email-grid {
    display: grid;
    grid-template-columns: 1fr 0.78fr;
    gap: 10px;
    height: 100%;
    min-height: 0;
  }
  .mk-email-preview {
    display: flex;
    align-items: stretch;
    justify-content: center;
  }
  .mk-email-window {
    width: 100%;
    height: 100%;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 8px 24px -8px rgba(20,20,30,0.12);
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .mk-email-toolbar {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 6px 10px;
    background: #F5F5F7;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    flex-shrink: 0;
  }
  .mk-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(0,0,0,0.18);
  }
  .mk-dot:nth-child(1) { background: #FF5F57; }
  .mk-dot:nth-child(2) { background: #FEBC2E; }
  .mk-dot:nth-child(3) { background: #28C840; }
  .mk-email-from {
    margin-left: 8px;
    font-size: 7px;
    color: rgba(0,0,0,0.55);
    font-family: 'SF Mono', 'Menlo', monospace;
    letter-spacing: 0.02em;
  }
  /* Real email-client headers */
  .mk-email-headers {
    background: #FBFBFD;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    padding: 7px 12px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .mk-email-headers-row {
    display: grid;
    grid-template-columns: 38px 1fr;
    gap: 8px;
    font-size: 7px;
  }
  .mk-email-h-label {
    color: rgba(0,0,0,0.45);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }
  .mk-email-h-val {
    color: #1A1A1A;
    font-weight: 600;
  }
  .mk-email-h-subj { font-weight: 700; }

  .mk-email-content {
    padding: 10px 14px 10px;
    flex: 1;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  /* Follow-up tag */
  .mk-email-tag {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgba(42,181,160,0.10);
    color: #1A8F7A;
    border: 1px solid rgba(42,181,160,0.20);
    border-radius: 999px;
    padding: 3px 8px;
    font-size: 6px;
    font-weight: 800;
    letter-spacing: 0.12em;
    margin-bottom: 6px;
  }
  .mk-email-tag-dot {
    width: 5px;
    height: 5px;
    background: #2AB5A0;
    border-radius: 50%;
    animation: mk-email-tag-pulse 1.6s ease-in-out infinite;
  }
  @keyframes mk-email-tag-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(42,181,160,0.5); }
    50%      { box-shadow: 0 0 0 4px rgba(42,181,160,0); }
  }
  .mk-email-brand {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 12px;
    letter-spacing: 0.18em;
    color: #1A1A1A;
    margin-bottom: 6px;
    padding-bottom: 6px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .mk-email-subject {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 800;
    color: #1A1A1A;
    margin-bottom: 5px;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .mk-email-greeting {
    font-size: 7.5px;
    color: #1A1A1A;
    margin-bottom: 3px;
    font-weight: 600;
  }
  .mk-email-text {
    font-size: 7px;
    line-height: 1.5;
    color: rgba(0,0,0,0.7);
    margin-bottom: 8px;
  }
  .mk-email-text strong { color: #1A1A1A; font-weight: 700; }

  /* Product grid (real items) */
  .mk-email-products {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 5px;
    margin-bottom: 8px;
  }
  .mk-email-prod {
    background: #FAFAFA;
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 6px;
    padding: 4px;
    opacity: 0;
    transform: translateY(8px);
    animation: mk-email-prod-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .mk-email-prod:nth-child(1) { animation-delay: 0.1s; }
  .mk-email-prod:nth-child(2) { animation-delay: 0.25s; }
  .mk-email-prod:nth-child(3) { animation-delay: 0.40s; }
  @keyframes mk-email-prod-in {
    to { opacity: 1; transform: translateY(0); }
  }
  .mk-email-prod-img {
    aspect-ratio: 4 / 5;
    background: #F2F1EE;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 4px;
  }
  .mk-email-prod-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .mk-email-prod-name {
    font-size: 7px;
    font-weight: 700;
    color: #1A1A1A;
    padding: 0 2px;
    margin-bottom: 2px;
  }
  .mk-email-prod-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 2px 2px;
  }
  .mk-email-prod-price {
    font-family: var(--font-display);
    font-size: 8px;
    font-weight: 800;
    color: #1A1A1A;
  }
  .mk-email-prod-match {
    font-size: 6px;
    font-weight: 800;
    color: #1A8F7A;
    background: rgba(42,181,160,0.14);
    padding: 1px 4px;
    border-radius: 3px;
    letter-spacing: 0.02em;
  }

  .mk-email-cta {
    display: inline-block;
    padding: 6px 12px;
    background: #1A1A1A;
    color: #fff;
    font-family: var(--font-display);
    font-size: 7.5px;
    font-weight: 700;
    border-radius: 5px;
    letter-spacing: 0.04em;
    margin-bottom: 4px;
    align-self: flex-start;
  }
  .mk-email-note {
    font-size: 6px;
    color: rgba(0,0,0,0.5);
    margin-bottom: 6px;
    font-style: italic;
  }

  /* Email footer (sells the realism) */
  .mk-email-footer {
    border-top: 1px solid rgba(0,0,0,0.06);
    padding-top: 5px;
    margin-top: auto;
    text-align: center;
  }
  .mk-email-foot-text {
    font-size: 5.5px;
    color: rgba(0,0,0,0.45);
    line-height: 1.4;
  }
  .mk-email-foot-text span {
    color: rgba(0,0,0,0.6);
    text-decoration: underline;
  }

  .mk-email-stats {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 12px;
    padding: 12px 12px 10px;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 8px -2px rgba(20,20,30,0.05);
    overflow: hidden;
    height: 100%;
    min-height: 0;
  }

  /* ── WhatsApp marketing slide ── */
  .mk-wa-frame {
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #FAFAFA;
    padding: 4% 5%;
  }
  .mk-wa-grid {
    display: grid;
    grid-template-columns: 0.85fr 1fr;
    gap: 14px;
    height: 100%;
    align-items: center;
  }
  .mk-wa-phone-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .mk-wa-phone {
    width: 92%;
    aspect-ratio: 9 / 19;
    background: #E8E8EC;
    border-radius: 22px;
    padding: 5px;
    box-shadow:
      0 0 0 1px rgba(0,0,0,0.06),
      0 8px 24px -8px rgba(20,20,30,0.18);
    position: relative;
  }
  .mk-wa-phone-notch {
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 26%;
    height: 8px;
    background: #1A1A1A;
    border-radius: 999px;
    z-index: 2;
  }
  .mk-wa-phone-screen {
    width: 100%;
    height: 100%;
    background: #ECE5DD;
    border-radius: 17px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .mk-wa-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 14px 8px 8px;
    background: #075E54;
    color: #fff;
  }
  .mk-wa-back {
    font-size: 14px;
    line-height: 1;
    color: #fff;
    flex-shrink: 0;
  }
  .mk-wa-contact-name {
    font-size: 8px;
    font-weight: 700;
  }
  .mk-wa-contact-status {
    font-size: 6px;
    color: rgba(255,255,255,0.7);
    margin-top: 1px;
  }
  .mk-wa-thread {
    flex: 1;
    padding: 8px 6px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .mk-wa-bubble {
    max-width: 88%;
    padding: 6px 8px;
    border-radius: 8px;
    font-size: 7px;
    line-height: 1.4;
    color: #1A1A1A;
    box-shadow: 0 1px 2px rgba(0,0,0,0.08);
  }
  .mk-wa-bubble--in {
    background: #fff;
    align-self: flex-start;
    border-top-left-radius: 2px;
  }
  .mk-wa-bubble--out {
    background: #DCF8C6;
    align-self: flex-end;
    border-top-right-radius: 2px;
  }
  .mk-wa-template-tag {
    font-size: 5px;
    font-weight: 700;
    color: #25D366;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 3px;
  }
  .mk-wa-msg { margin-bottom: 3px; }
  .mk-wa-msg:last-of-type { margin-bottom: 0; }
  .mk-wa-msg strong { font-weight: 700; }
  .mk-wa-cta {
    margin-top: 4px;
    padding: 4px 6px;
    border: 1px solid rgba(37,211,102,0.4);
    color: #25D366;
    font-weight: 700;
    text-align: center;
    border-radius: 4px;
    font-size: 6px;
  }
  .mk-wa-time {
    font-size: 5px;
    color: rgba(0,0,0,0.4);
    margin-top: 3px;
    text-align: right;
  }
  .mk-wa-stats {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 10px;
    padding: 12px;
    display: flex;
    flex-direction: column;
  }
  .mk-wa-stats .mk-metric-fill,
  .mk-wa2-panel .mk-metric-fill { background: #25D366; }
  .mk-wa-stats .mk-roi-value,
  .mk-wa2-panel .mk-roi-value { color: #128C4A; }
  /* Override of the gradient ROI for the WA palette */
  .mk-wa-stats .mk-roi,
  .mk-wa2-panel .mk-roi {
    background: linear-gradient(135deg, rgba(37,211,102,0.12), rgba(75,123,229,0.05));
    border-color: rgba(37,211,102,0.30);
    box-shadow: 0 2px 12px -4px rgba(37,211,102,0.18);
  }

  /* ── WhatsApp marketing v2 — multi-stage flow (18s loop) ── */
  .mk-wa-grid--v2 {
    grid-template-columns: 1fr 0.85fr;
    grid-template-rows: 100%;
    align-items: stretch;
  }
  .mk-wa-grid--v2 .mk-wa-phone-wrap {
    height: 100%;
    min-height: 0;
    align-self: center;
  }
  .mk-wa-grid--v2 .mk-wa-phone {
    width: auto;
    max-width: 100%;
    height: 100%;
    aspect-ratio: 9 / 19;
  }
  .mk-wa2-panel {
    position: relative;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 10px;
    padding: 14px 14px 12px;
    height: 100%;
    min-height: 0;
    overflow: hidden;
  }
  .mk-wa2-layer {
    position: absolute;
    inset: 14px 14px 12px;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
  }
  .mk-wa2-layer--filters  { animation: mk-wa2-filters 18s ease-in-out infinite; }
  .mk-wa2-layer--template { animation: mk-wa2-template 18s ease-in-out infinite; }
  .mk-wa2-layer--sending  { animation: mk-wa2-sending 18s ease-in-out infinite; }
  .mk-wa2-layer--stats    { animation: mk-wa2-stats 18s ease-in-out infinite; }

  @keyframes mk-wa2-filters {
    0% { opacity: 0; transform: translateY(8px); }
    3%, 21% { opacity: 1; transform: translateY(0); }
    24%, 100% { opacity: 0; transform: translateY(-6px); }
  }
  @keyframes mk-wa2-template {
    0%, 23% { opacity: 0; transform: translateY(8px); }
    28%, 46% { opacity: 1; transform: translateY(0); }
    49%, 100% { opacity: 0; transform: translateY(-6px); }
  }
  @keyframes mk-wa2-sending {
    0%, 48% { opacity: 0; transform: translateY(8px); }
    53%, 71% { opacity: 1; transform: translateY(0); }
    74%, 100% { opacity: 0; transform: translateY(-6px); }
  }
  @keyframes mk-wa2-stats {
    0%, 73% { opacity: 0; transform: translateY(8px); }
    78%, 98% { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(-6px); }
  }

  .mk-wa2-step {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 7px;
    font-weight: 700;
    color: #128C4A;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 6px;
  }
  .mk-wa2-step-num {
    width: 13px; height: 13px;
    border-radius: 50%;
    background: #25D366;
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 7px;
    font-weight: 700;
  }
  .mk-wa2-title {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: #1A1A1A;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  /* Filters */
  .mk-wa2-rules {
    display: flex;
    flex-direction: column;
    gap: 5px;
    margin-bottom: auto;
  }
  .mk-wa2-rule {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 8px;
    color: #2A2A2A;
    padding: 6px 8px;
    background: #F5FAF7;
    border: 1px solid rgba(37,211,102,0.18);
    border-radius: 5px;
    line-height: 1.3;
  }
  .mk-wa2-rule strong { font-weight: 700; color: #1A1A1A; }
  .mk-wa2-check {
    flex-shrink: 0;
    width: 13px; height: 13px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(37,211,102,0.14);
    border-radius: 50%;
  }
  .mk-wa2-rule--add {
    background: transparent;
    border: 1px dashed rgba(0,0,0,0.18);
    color: rgba(0,0,0,0.45);
    justify-content: center;
    font-weight: 600;
  }

  .mk-wa2-btn {
    margin-top: 9px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 7px 11px;
    border-radius: 6px;
    font-size: 8px;
    font-weight: 700;
    border: none;
    cursor: default;
    align-self: flex-start;
    font-family: inherit;
  }
  .mk-wa2-btn--primary {
    background: #1A1A1A;
    color: #fff;
  }
  .mk-wa2-btn--send {
    background: #25D366;
    color: #fff;
    align-self: stretch;
    margin-top: auto;
    padding: 8px 11px;
    font-size: 9px;
    box-shadow: 0 4px 12px -4px rgba(37,211,102,0.45);
    animation: mk-wa2-btn-pulse 2.4s ease-in-out infinite;
  }
  @keyframes mk-wa2-btn-pulse {
    0%, 100% { box-shadow: 0 4px 12px -4px rgba(37,211,102,0.45); transform: scale(1); }
    50% { box-shadow: 0 4px 18px -2px rgba(37,211,102,0.65); transform: scale(1.015); }
  }

  /* Animated cursors that click on Filtrar / Enviar buttons */
  .mk-wa2-cursor {
    position: absolute;
    width: 18px;
    height: 18px;
    pointer-events: none;
    z-index: 5;
    filter: drop-shadow(0 3px 5px rgba(0,0,0,0.30));
    opacity: 0;
  }
  .mk-wa2-cursor svg {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 1;
  }
  .mk-wa2-cursor-pulse {
    position: absolute;
    top: -6px;
    left: -6px;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 2px solid #25D366;
    transform: scale(0.4);
    opacity: 0;
  }
  /* Cursor 1 — clicks "Filtrar audiencia" (during stage 1, ~3-22% of 18s loop) */
  .mk-wa2-cursor--filter {
    bottom: 20px;
    left: 38px;
    animation: mk-wa2-cur-filter 18s ease-in-out infinite;
  }
  .mk-wa2-cursor--filter .mk-wa2-cursor-pulse {
    animation: mk-wa2-cur-pulse-filter 18s ease-in-out infinite;
  }
  @keyframes mk-wa2-cur-filter {
    0%        { opacity: 0; transform: translate(150px, -200px) scale(1); }
    3%        { opacity: 1; transform: translate(150px, -200px) scale(1); }
    14%       { opacity: 1; transform: translate(0, 0) scale(1); }
    16%       { opacity: 1; transform: translate(0, 0) scale(0.78); }
    19%       { opacity: 1; transform: translate(0, 0) scale(1); }
    21%       { opacity: 1; transform: translate(0, 0) scale(1); }
    24%, 100% { opacity: 0; transform: translate(0, 0) scale(1); }
  }
  @keyframes mk-wa2-cur-pulse-filter {
    0%, 14%   { opacity: 0; transform: scale(0.4); }
    16%       { opacity: 0.85; transform: scale(0.5); }
    20%       { opacity: 0; transform: scale(2.4); }
    100%      { opacity: 0; transform: scale(2.4); }
  }
  /* Cursor 2 — clicks "Enviar broadcast" (during stage 2, ~28-47% of 18s loop) */
  .mk-wa2-cursor--send {
    bottom: 22px;
    left: 50%;
    margin-left: -9px;
    animation: mk-wa2-cur-send 18s ease-in-out infinite;
  }
  .mk-wa2-cursor--send .mk-wa2-cursor-pulse {
    animation: mk-wa2-cur-pulse-send 18s ease-in-out infinite;
  }
  @keyframes mk-wa2-cur-send {
    0%, 26%   { opacity: 0; transform: translate(110px, -200px) scale(1); }
    28%       { opacity: 1; transform: translate(110px, -200px) scale(1); }
    39%       { opacity: 1; transform: translate(0, 0) scale(1); }
    41%       { opacity: 1; transform: translate(0, 0) scale(0.78); }
    44%       { opacity: 1; transform: translate(0, 0) scale(1); }
    46%       { opacity: 1; transform: translate(0, 0) scale(1); }
    49%, 100% { opacity: 0; transform: translate(0, 0) scale(1); }
  }
  @keyframes mk-wa2-cur-pulse-send {
    0%, 39%   { opacity: 0; transform: scale(0.4); }
    41%       { opacity: 0.85; transform: scale(0.5); }
    45%       { opacity: 0; transform: scale(2.4); }
    100%      { opacity: 0; transform: scale(2.4); }
  }

  /* Template stage */
  .mk-wa2-result {
    background: linear-gradient(135deg, rgba(37,211,102,0.10), rgba(37,211,102,0.04));
    border: 1px solid rgba(37,211,102,0.30);
    border-radius: 7px;
    padding: 7px 10px;
    margin-bottom: 9px;
    display: flex;
    align-items: baseline;
    gap: 7px;
  }
  .mk-wa2-result-num {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: #128C4A;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .mk-wa2-result-lbl {
    font-size: 8px;
    color: #2A2A2A;
  }
  .mk-wa2-tmpl {
    background: #FAFAFA;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 6px;
    padding: 7px 8px;
    margin-bottom: auto;
  }
  .mk-wa2-tmpl-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 6.5px;
    margin-bottom: 5px;
    padding-bottom: 5px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .mk-wa2-tmpl-tag {
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #1A1A1A;
  }
  .mk-wa2-tmpl-status {
    color: #25D366;
    font-weight: 700;
  }
  .mk-wa2-tmpl-body {
    font-size: 8px;
    line-height: 1.45;
    color: #2A2A2A;
  }
  .mk-wa2-tmpl-body strong { color: #1A1A1A; font-weight: 700; }
  .mk-wa2-tmpl-body > div { margin-bottom: 3px; }
  .mk-wa2-tmpl-body > div:last-child { margin-bottom: 0; }
  .mk-wa2-var {
    background: rgba(75,123,229,0.12);
    color: #4B7BE5;
    padding: 0 3px;
    border-radius: 3px;
    font-weight: 700;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 7.5px;
  }

  /* Sending stage */
  .mk-wa2-send {
    margin: auto;
    text-align: center;
    width: 100%;
  }
  .mk-wa2-send-icon {
    display: inline-flex;
    width: 46px; height: 46px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(37,211,102,0.10);
    margin-bottom: 7px;
    animation: mk-wa2-send-bob 1.4s ease-in-out infinite;
  }
  @keyframes mk-wa2-send-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
  }
  .mk-wa2-send-title {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    color: #1A1A1A;
    margin-bottom: 2px;
  }
  .mk-wa2-send-sub {
    font-size: 7.5px;
    color: rgba(0,0,0,0.55);
    margin-bottom: 9px;
  }
  .mk-wa2-send-bar {
    width: 76%;
    margin: 0 auto;
    height: 4px;
    background: rgba(0,0,0,0.06);
    border-radius: 999px;
    overflow: hidden;
  }
  .mk-wa2-send-fill {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, #25D366, #128C4A);
    border-radius: 999px;
    animation: mk-wa2-send-fill 18s linear infinite;
  }
  @keyframes mk-wa2-send-fill {
    0%, 49% { width: 0%; }
    53% { width: 6%; }
    71% { width: 100%; }
    74%, 100% { width: 100%; }
  }
  .mk-wa2-send-count {
    font-size: 7px;
    color: rgba(0,0,0,0.55);
    margin-top: 6px;
    font-variant-numeric: tabular-nums;
  }

  /* Phone thread overlays */
  .mk-wa-thread { position: relative; }
  .mk-wa2-thread-empty {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 5px;
    pointer-events: none;
    z-index: 1;
    animation: mk-wa2-empty 18s ease-in-out infinite;
  }
  .mk-wa2-empty-icon {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: rgba(0,0,0,0.04);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mk-wa2-empty-text {
    font-size: 7px;
    color: rgba(0,0,0,0.5);
  }
  @keyframes mk-wa2-empty {
    0%, 49% { opacity: 1; }
    53%, 100% { opacity: 0; }
  }

  .mk-wa2-bubble--anim {
    opacity: 0;
    transform: translateY(6px) scale(0.96);
  }
  .mk-wa2-bubble--1 { animation: mk-wa2-bubble1 18s ease-in-out infinite; }
  .mk-wa2-bubble--2 { animation: mk-wa2-bubble2 18s ease-in-out infinite; }
  @keyframes mk-wa2-bubble1 {
    0%, 52% { opacity: 0; transform: translateY(6px) scale(0.96); }
    56%, 96% { opacity: 1; transform: translateY(0) scale(1); }
    100% { opacity: 0; transform: translateY(-4px) scale(0.97); }
  }
  @keyframes mk-wa2-bubble2 {
    0%, 62% { opacity: 0; transform: translateY(6px) scale(0.96); }
    66%, 96% { opacity: 1; transform: translateY(0) scale(1); }
    100% { opacity: 0; transform: translateY(-4px) scale(0.97); }
  }

  /* Reduced motion — disable all marketing animations */
  @media (prefers-reduced-motion: reduce) {
    .mk-bar--anim,
    .mk-email-prod,
    .mk-roi-value,
    .mk-email-tag-dot,
    .mk-wa2-layer,
    .mk-wa2-bubble--anim,
    .mk-wa2-thread-empty,
    .mk-wa2-send-fill,
    .mk-wa2-send-icon,
    .mk-wa2-btn--send,
    .mk-wa2-cursor,
    .mk-wa2-cursor-pulse {
      animation: none !important;
    }
    .mk-wa2-cursor { display: none; }
    .mk-bar--anim { width: var(--mk-bar-w, 100%); }
    .mk-email-prod { opacity: 1; transform: none; }
    .mk-wa2-layer { opacity: 0; transform: none; }
    .mk-wa2-layer--stats { opacity: 1; }
    .mk-wa2-bubble--anim { opacity: 1; transform: none; }
    .mk-wa2-thread-empty { display: none; }
    .mk-wa2-send-fill { width: 100%; }
  }

  /* ── AXO IA Empresarial ── */
  .axo-split {
    display: flex;
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #FAFAFA;
  }
  .axo-video-wrap {
    flex: 1.2;
    overflow: hidden;
  }
  .axo-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  .axo-phone-wrap {
    flex: 0.8;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  .axo-phone {
    width: 65%;
    max-width: 220px;
    aspect-ratio: 9 / 19;
    background: #E8E8EC;
    border-radius: 28px;
    padding: 6px;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.6) inset,
      0 0 0 1px rgba(0,0,0,0.06),
      0 12px 32px -8px rgba(20,20,30,0.18),
      0 4px 12px -4px rgba(20,20,30,0.10);
    position: relative;
  }
  .axo-phone-notch {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 28%;
    height: 10px;
    background: #1A1A1A;
    border-radius: 999px;
    z-index: 2;
  }
  .axo-phone-screen {
    width: 100%;
    height: 100%;
    background: #FAFAFA;
    border-radius: 22px;
    overflow: hidden;
  }

  /* AXO Chat */
  .axo-chat {
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 22px 8px 8px;
  }
  .axo-chat-header {
    text-align: center;
    margin-bottom: 10px;
  }
  .axo-chat-logo {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 800;
    color: #2AB5A0;
    letter-spacing: 3px;
  }
  .axo-chat-subtitle {
    font-family: var(--font-body);
    font-size: 7px;
    color: rgba(0,0,0,0.45);
    margin-top: 1px;
  }

  .axo-chat-messages {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 5px;
    overflow: hidden;
  }
  .axo-msg {
    font-family: var(--font-body);
    font-size: 8px;
    line-height: 1.4;
    padding: 6px 8px;
    border-radius: 10px;
    max-width: 88%;
    opacity: 0;
    transform: translateY(6px);
    animation: axo-msg-loop 10s ease infinite;
  }
  .axo-msg--1 { animation-delay: 0.3s; }
  .axo-msg--2 { animation-delay: 1.4s; }
  .axo-msg--3 { animation-delay: 2.6s; }
  .axo-msg--4 { animation-delay: 3.8s; }
  .axo-msg--5 { animation-delay: 4.8s; }
  @keyframes axo-msg-loop {
    0%       { opacity: 0; transform: translateY(6px); }
    5%, 75%  { opacity: 1; transform: translateY(0); }
    85%, 100%{ opacity: 0; transform: translateY(-4px); }
  }
  .axo-msg-ai {
    background: #FFFFFF;
    border: 1px solid rgba(0,0,0,0.06);
    color: #1A1A1A;
    align-self: flex-start;
    border-bottom-left-radius: 3px;
    box-shadow: 0 1px 2px rgba(20,20,30,0.04);
  }
  .axo-msg-user {
    background: #2AB5A0;
    color: #fff;
    align-self: flex-end;
    border-bottom-right-radius: 3px;
  }
  .axo-msg-label {
    display: block;
    font-size: 7px;
    font-weight: 700;
    color: #2AB5A0;
    margin-bottom: 2px;
    letter-spacing: 0.5px;
  }

  /* Action card */
  .axo-action-card {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(42,181,160,0.10);
    border: 1px solid rgba(42,181,160,0.25);
    border-radius: 8px;
    padding: 5px 6px;
    margin-top: 3px;
  }
  .axo-action-icon {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #2AB5A0;
    color: #fff;
    font-size: 9px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .axo-action-title {
    font-family: var(--font-display);
    font-size: 9px;
    font-weight: 700;
    color: #1A1A1A;
  }
  .axo-action-detail {
    font-size: 7px;
    color: rgba(0,0,0,0.5);
  }

  /* Typing indicator */
  .axo-chat-header::after {
    content: '';
    display: block;
    width: 6px;
    height: 6px;
    background: #2AB5A0;
    border-radius: 50%;
    margin: 6px auto 0;
    animation: axo-pulse 1.5s ease-in-out infinite;
  }
  @keyframes axo-pulse {
    0%, 100% { opacity: 0.3; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  /* Chat input */
  .axo-chat-input {
    margin-top: auto;
    padding: 7px 10px;
    background: #FFFFFF;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 12px;
    font-family: var(--font-body);
    font-size: 8px;
    color: rgba(0,0,0,0.4);
  }

  @media (prefers-reduced-motion: reduce) {
    .axo-msg { animation: none; opacity: 1; transform: none; }
  }

  /* ── Catálogo enriquecido (inventario) ── */
  .cat-window {
    display: flex;
    flex-direction: column;
    border-radius: 0;
    box-shadow: none;
    height: 100%;
    font-family: var(--font-body);
  }
  .cat-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    border-bottom: 1px solid #eee;
    background: #fff;
    gap: 8px;
  }
  .cat-topbar-left {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .cat-topbar-title {
    font-size: 13px;
    font-weight: 700;
    color: #1A1A1A;
  }
  .cat-topbar-count {
    font-size: 11px;
    color: #8C8C8C;
  }
  .cat-topbar-actions {
    display: flex;
    gap: 4px;
  }
  .cat-btn {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    padding: 5px 10px;
    border-radius: 6px;
    border: 1px solid #e0e0e0;
    background: #fff;
    color: #4A4A4A;
    cursor: pointer;
    white-space: nowrap;
  }
  .cat-btn--primary {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }
  .cat-filters {
    display: flex;
    gap: 8px;
    padding: 8px 14px;
    border-bottom: 1px solid #f0f0f0;
    background: #fafafa;
  }
  .cat-filter-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }
  .cat-filter-label {
    font-size: 9px;
    color: #8C8C8C;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .cat-filter-value {
    font-size: 10px;
    color: #1A1A1A;
    font-weight: 500;
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 4px;
    padding: 3px 6px;
  }
  .cat-tabs-bar {
    display: flex;
    gap: 0;
    border-bottom: 1px solid #eee;
    padding: 0 14px;
  }
  .cat-tab-item {
    font-size: 10px;
    font-weight: 600;
    color: #8C8C8C;
    padding: 7px 10px;
    border-bottom: 2px solid transparent;
    cursor: pointer;
  }
  .cat-tab-item--active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }
  .cat-table {
    flex: 1;
    overflow: hidden;
  }
  .cat-table-header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1.5fr;
    gap: 4px;
    padding: 6px 14px;
    font-size: 9px;
    font-weight: 700;
    color: #8C8C8C;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    border-bottom: 1px solid #eee;
  }
  .cat-table-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1.5fr;
    gap: 4px;
    padding: 6px 14px;
    font-size: 10px;
    color: #4A4A4A;
    align-items: center;
    border-bottom: 1px solid #f5f5f5;
  }
  .cat-table-row--alert {
    background: #FFF5F5;
  }
  .cat-col-name {
    display: flex;
    align-items: center;
    gap: 6px;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .cat-prod-thumb {
    width: 24px;
    height: 24px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    flex-shrink: 0;
  }
  .cat-prod-thumb-img {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
    margin-right: 2px;
  }
  .cat-col-actions {
    display: flex;
    gap: 3px;
  }
  .cat-mini-btn {
    font-size: 10px;
    background: #f5f5f5;
    border: 1px solid #eee;
    border-radius: 4px;
    padding: 2px 5px;
    cursor: pointer;
    line-height: 1;
  }
  .cat-stock-pill {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 10px;
    font-size: 10px;
    font-weight: 700;
  }
  .cat-stock-pill--ok {
    background: #E8F5E9;
    color: #2E7D32;
  }
  .cat-stock-pill--low {
    background: #FFEBEE;
    color: #C62828;
  }
  .cat-col-loc {
    display: flex;
    gap: 3px;
    flex-wrap: wrap;
  }
  .cat-loc-badge {
    font-size: 8px;
    font-weight: 600;
    padding: 2px 5px;
    border-radius: 3px;
    background: #f0f0f0;
    color: #666;
    white-space: nowrap;
  }

  /* Variant rows */
  .cat-table-row--variant {
    background: #fafafa;
    font-size: 9px;
    color: #8C8C8C;
    padding: 4px 14px 4px 28px;
  }
  .cat-indent {
    color: #ccc;
    margin-right: 4px;
  }
  .cat-variant-badge {
    font-size: 8px;
    background: #EDE7F6;
    color: #7C3AED;
    padding: 1px 5px;
    border-radius: 3px;
    margin-left: 4px;
    font-weight: 600;
  }

  /* Import overlay + animation */
  .cat-import-overlay {
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    opacity: 1;
    pointer-events: auto;
  }
  .cat-import-modal {
    background: #fff;
    border-radius: 12px;
    padding: 20px 28px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    text-align: center;
    width: 260px;
  }
  .cat-import-icon {
    font-size: 28px;
    margin-bottom: 8px;
  }
  .cat-import-title {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    color: #1A1A1A;
    margin-bottom: 12px;
  }
  .cat-import-file {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #f5f5f5;
    padding: 8px 10px;
    border-radius: 8px;
    margin-bottom: 12px;
  }
  .cat-import-file-icon { font-size: 16px; }
  .cat-import-file-name {
    font-size: 11px;
    font-weight: 600;
    color: #1A1A1A;
    flex: 1;
    text-align: left;
  }
  .cat-import-file-size {
    font-size: 10px;
    color: #8C8C8C;
  }
  .cat-import-progress {
    height: 6px;
    background: #eee;
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  .cat-import-bar {
    height: 100%;
    width: 0%;
    background: var(--color-primary);
    border-radius: 3px;
    transition: width 0.1s linear;
  }
  .cat-import--active .cat-import-bar {
    animation: cat-import-fill 0.84s ease-out forwards;
  }
  @keyframes cat-import-fill {
    0% { width: 0%; }
    30% { width: 40%; }
    60% { width: 75%; }
    100% { width: 100%; }
  }
  .cat-import-status {
    font-size: 11px;
    color: #8C8C8C;
  }
  .cat-import-done {
    font-size: 12px;
    font-weight: 700;
    color: #2E7D32;
    margin-top: 8px;
    opacity: 0;
  }
  .cat-import--active .cat-import-done {
    animation: cat-import-done-show 0.4s ease 1.4s forwards;
  }
  @keyframes cat-import-done-show {
    0% { opacity: 0; transform: translateY(4px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .cat-import--active .cat-import-status {
    animation: cat-import-status-hide 0.3s ease 1.3s forwards;
  }
  @keyframes cat-import-status-hide {
    to { opacity: 0; height: 0; margin: 0; }
  }

  /* Inventario list */
  .pm-content-list {
    flex-direction: column;
    gap: 0;
  }

  .pm-list-header {
    display: grid;
    grid-template-columns: 1fr 80px 80px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pm-list-row {
    display: grid;
    grid-template-columns: 1fr 80px 80px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
    font-size: 14px;
    color: var(--color-text-secondary);
  }

  .pm-list-row.alert { background: rgba(229, 75, 75, 0.04); }

  .pm-status-ok {
    font-size: 12px;
    font-weight: 600;
    color: #1a8a78;
    background: rgba(42, 181, 160, 0.1);
    padding: 2px 8px;
    border-radius: var(--radius-full);
    display: inline-block;
    width: fit-content;
  }

  .pm-status-low {
    font-size: 12px;
    font-weight: 600;
    color: #c0392b;
    background: rgba(229, 75, 75, 0.1);
    padding: 2px 8px;
    border-radius: var(--radius-full);
    display: inline-block;
    width: fit-content;
  }

  /* CRM */
  .pm-content-crm {
    flex-direction: column;
    gap: var(--space-5);
  }

  .pm-crm-profile {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .pm-crm-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    font-size: 18px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .pm-crm-name { font-size: 16px; font-weight: 700; color: var(--color-text-primary); }
  .pm-crm-tag { font-size: 13px; color: var(--color-text-tertiary); margin-top: 2px; }

  .pm-crm-stats {
    display: flex;
    flex-direction: column;
  }

  .pm-crm-stat {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    font-size: 14px;
    color: var(--color-text-secondary);
  }

  .pm-crm-stat strong {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  /* Reports */
  .pm-content-reports {
    flex-direction: column;
    gap: var(--space-5);
  }

  .pm-report-kpis {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .pm-kpi-val {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 800;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }

  .pm-kpi-label {
    display: block;
    font-size: 13px;
    color: var(--color-text-tertiary);
    margin-top: 4px;
  }

  .pm-chart {
    width: 100%;
    height: 100px;
  }

  /* Chat */
  .pm-content-chat {
    flex-direction: column;
    gap: 10px;
  }

  .pm-chat-msg {
    font-size: 14px;
    line-height: 1.5;
    padding: 12px 16px;
    border-radius: 14px;
    max-width: 85%;
  }

  .pm-chat-ai {
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }

  .pm-chat-user {
    background: var(--color-primary);
    color: #fff;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }


  /* ═══════════════════════════════════════════
     BLOQUE 2.4: Bento Grid — Multisucursal
     ═══════════════════════════════════════════ */

  .bento-section {
    background: var(--color-bg-primary);
    padding: var(--space-20, 80px) 0;
  }

  @media (min-width: 1024px) {
    .bento-section { padding: var(--space-32, 128px) 0; }
  }

  .bento-header {
    text-align: center;
    margin-bottom: var(--space-10, 40px);
  }

  .bento-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-tertiary, #8C8C8C);
    margin-bottom: var(--space-3, 12px);
  }

  .bento-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    max-width: 680px;
    margin-inline: auto;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4, 16px);
  }

  @media (min-width: 640px) {
    .bento-grid { grid-template-columns: repeat(2, 1fr); gap: var(--space-5, 20px); }
  }

  @media (min-width: 1024px) {
    .bento-grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-6, 24px); }
  }

  .bento-card {
    background: var(--color-bg-card, #fff);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: var(--radius-xl, 20px);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .bento-card:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
    transform: translateY(-4px);
  }

  @media (min-width: 640px) {
    .bento-card-lg { grid-column: span 2; }
  }

  .bento-visual {
    position: relative;
    padding: var(--space-8, 32px) var(--space-6, 24px);
    min-height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bento-visual-dashboard { background: #111118; }
  .bento-visual-stock { background: var(--color-bg-secondary, #F5F3EE); }
  .bento-visual-transfer { background: var(--color-bg-secondary, #F5F3EE); }
  .bento-visual-axo { background: #111118; }

  /* BOPIS timeline */
  .bento-visual-bopis { background: var(--color-bg-secondary, #F5F3EE); }
  .bento-bopis-timeline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 24px 16px;
  }
  .bento-bopis-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .bento-bopis-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    color: var(--color-text-primary);
  }
  .bento-bopis-icon--done {
    background: #2AB5A0;
    color: #fff;
  }
  .bento-bopis-icon--done svg { stroke: #fff; }
  .bento-bopis-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-align: center;
    white-space: nowrap;
  }
  .bento-bopis-arrow {
    font-size: 18px;
    color: rgba(0,0,0,0.2);
    margin-bottom: 20px;
  }

  /* Offline icon */
  .bento-visual-offline { background: var(--color-bg-secondary, #F5F3EE); }
  .bento-offline-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 24px 16px;
    position: relative;
  }
  .bento-offline-icon { position: relative; }
  .bento-offline-check {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(40%, -80%);
  }
  .bento-offline-badge {
    font-size: 11px;
    font-weight: 700;
    color: #2AB5A0;
    background: rgba(42,181,160,0.1);
    padding: 4px 10px;
    border-radius: 100px;
    letter-spacing: -0.01em;
  }

  .bento-text { padding: var(--space-5, 20px) var(--space-6, 24px) var(--space-8, 32px); }

  .bento-card-title {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: var(--space-2, 8px);
  }

  .bento-card-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-secondary, #4A4A4A);
  }

  /* Card 1: Dashboard map */
  .bento-map {
    position: relative;
    width: 100%;
    max-width: 400px;
    aspect-ratio: 2 / 1;
  }

  .bento-map-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .bento-map-dot {
    position: absolute;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-primary, #4B7BE5);
    box-shadow: 0 0 8px rgba(75, 123, 229, 0.6);
    z-index: 1;
  }

  .bento-dot-ping {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid var(--color-primary, #4B7BE5);
    opacity: 0;
    animation: bentoPing 2.5s ease-out infinite;
  }

  .bento-map-dot:nth-child(2) .bento-dot-ping { animation-delay: 0.6s; }
  .bento-map-dot:nth-child(3) .bento-dot-ping { animation-delay: 1.2s; }
  .bento-map-dot:nth-child(4) .bento-dot-ping { animation-delay: 1.8s; }

  @keyframes bentoPing {
    0% { opacity: 0.7; transform: scale(1); }
    100% { opacity: 0; transform: scale(2.5); }
  }

  /* Card 2: Stock counter */
  .bento-counter {
    width: 100%;
    max-width: 260px;
    display: flex;
    flex-direction: column;
    gap: var(--space-3, 12px);
  }

  .bento-counter-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 12px;
    background: #fff;
    border-radius: 8px;
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  .bento-counter-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary, #4A4A4A);
  }

  .bento-counter-val {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .bento-counter-bar {
    height: 6px;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 3px;
    overflow: hidden;
    margin-top: 4px;
  }

  .bento-counter-fill {
    height: 100%;
    width: 72%;
    background: var(--color-secondary, #2AB5A0);
    border-radius: 3px;
  }

  /* Card 3: Transfer */
  .bento-transfer {
    display: flex;
    align-items: center;
    gap: var(--space-4, 16px);
    justify-content: center;
  }

  .bento-store-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .bento-store-letter {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .bento-store-qty {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-tertiary, #8C8C8C);
  }

  .bento-qty-positive { color: var(--color-secondary, #2AB5A0); }

  .bento-transfer-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .bento-transfer-badge {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-secondary, #2AB5A0);
  }

  /* Card 4: AXO suggestion */
  .bento-axo-suggestion {
    width: 100%;
    max-width: 400px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .bento-axo-header {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .bento-axo-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-secondary, #2AB5A0);
    box-shadow: 0 0 6px rgba(42, 181, 160, 0.6);
  }

  .bento-axo-label {
    font-size: 0.6875rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .bento-axo-msg {
    font-size: 0.875rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
  }

  .bento-axo-msg strong { color: #fff; font-weight: 600; }

  .bento-axo-actions {
    display: flex;
    gap: 8px;
    margin-top: 4px;
  }

  .bento-axo-btn {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 8px 16px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .bento-axo-btn:hover { opacity: 0.85; }

  .bento-axo-btn-primary {
    background: var(--color-secondary, #2AB5A0);
    color: #fff;
  }

  .bento-axo-btn-ghost {
    background: transparent;
    color: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  /* ─── Mobile performance: disable heavy effects ─── */
  @media (max-width: 767px) {
    /* Kill expensive background patterns (4 SVG data URIs + 12 radial gradients) */
    .tablet-bg-patterns { display: none; }

    /* Kill hero decorative shapes (blur filters + noise texture) */
    .hero-shapes { display: none; }

    /* Replace expensive backdrop-filter with solid bg on notifications */
    .hero-notif {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: rgba(255, 255, 255, 0.97);
    }

    /* Simplify heavy box-shadows */
    .hero-tablet-frame {
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    }

    .scrolly-img {
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    }

    /* Disable 3D transforms */
    .hero-tablet-frame {
      transform: none !important;
      will-change: auto;
    }
  }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .hero-title,
    .hero-subtitle,
    .hero-ctas,
    .hero-bottom-bar,
    .hero-image-wrapper,
    .hero-image,
    .platform-mockup,
    .accordion-body,
    .tablet-slide {
      transition: none;
      animation: none;
      opacity: 1;
      transform: none;
    }

    .accordion-item.active .accordion-progress-fill {
      animation: none;
      width: 100%;
    }

    .hero-tablet-section {
      height: auto;
      padding: var(--space-12) 0;
      background: #f5f5f7;
    }

    .hero-tablet-sticky {
      position: relative;
      height: auto;
    }

    .hero-tablet-frame {
      transform: none !important;
    }
  }

  /* ═══ Section CTAs ═══ */
  .section-ctas {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: clamp(40px, 5vw, 56px);
    flex-wrap: wrap;
  }

  .section-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    padding: 18px 44px;
    border-radius: 100px;
    text-decoration: none;
    line-height: 1;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease, background 0.2s ease, border-color 0.2s ease;
  }

  .section-cta--filled {
    background: #2563EB;
    color: #fff;
  }

  .section-cta--filled:hover {
    background: #1D4FD7;
    transform: translateY(-3px);
    box-shadow: 0 10px 32px rgba(37, 99, 235, 0.3);
    text-decoration: none;
  }

  .section-cta--outline {
    background: transparent;
    color: #2563EB;
    border: 1.5px solid #2563EB;
  }

  .section-cta--outline:hover {
    background: rgba(37, 99, 235, 0.06);
    transform: translateY(-3px);
    text-decoration: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .section-cta:hover { transform: none; }
  }

  /* ═══════════════════════════════════════════
     MOBILE OPTIMIZATION — max-width: 767px
     ═══════════════════════════════════════════ */
  @media (max-width: 767px) {
    /* ── Hero Banner ── */
    .hero-banner {
      padding-top: 90px;
      padding-bottom: var(--space-8, 2rem);
    }

    .hero-title {
      font-size: clamp(2rem, 8.5vw, 2.75rem);
      margin-bottom: var(--space-4, 1rem);
      line-height: 0.95;
    }

    .hero-subtitle {
      font-size: 0.9375rem;
      margin-bottom: var(--space-6, 1.5rem);
    }

    .hero-text {
      padding-top: var(--space-4, 1rem);
      padding-bottom: var(--space-4, 1rem);
    }

    .hero-ctas {
      flex-direction: column;
      gap: var(--space-2, 0.5rem);
    }

    .hero-btn {
      width: 100%;
      justify-content: center;
      padding: 14px 24px;
      font-size: 0.8125rem;
    }

    .hero-bottom-bar {
