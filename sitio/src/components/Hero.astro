  .omni-channel--store { background: #1A1A1A; }
  .omni-channel--online { background: #4B7BE5; }
  .omni-channel--wa { background: #25D366; }
  .omni-channel--ig { background: #C13584; }
  .omni-event-body {
    flex: 1;
    min-width: 0;
  }
  .omni-event-title {
    font-size: 9px;
    font-weight: 700;
    color: #1A1A1A;
    margin-bottom: 1px;
  }
  .omni-event-detail {
    font-size: 7px;
    color: rgba(0,0,0,0.55);
    overflow: hidden;
