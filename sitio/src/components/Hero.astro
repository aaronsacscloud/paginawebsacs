  }
  .inv-intel-text {
    flex: 1;
    min-width: 0;
  }
  .inv-intel-eyebrow {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #2AB5A0;
    margin-bottom: 16px;
  }
  .inv-intel-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    margin: 0 0 20px;
    max-width: 520px;
  }
  .inv-intel-desc {
    font-size: clamp(1rem, 1.3vw, 1.125rem);
    line-height: 1.65;
