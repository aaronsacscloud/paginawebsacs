    height: 100%;
    border-radius: 0 20px 20px 0;
    overflow: hidden;
  }
  .why-sacs-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .why-sacs-img.active {
    opacity: 1;
  }

  /* Features — right half */
  .why-sacs-features {
    display: flex;
    flex-direction: column;
    padding: 0 var(--space-5, 20px);
  }
  @media (min-width: 1024px) {
