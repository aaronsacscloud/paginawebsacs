  /* ── Email + WhatsApp marketing — shared right column ── */
  .mk-stats-header { margin-bottom: 6px; }
  .mk-stats-title {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .mk-stats-segment {
    font-size: 7px;
    color: rgba(0,0,0,0.5);
    margin-top: 2px;
  }
  .mk-stats-segment strong { color: #1A1A1A; font-weight: 700; }
  .mk-metric { margin-bottom: 7px; }
  .mk-metric-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 3px;
  }
  .mk-metric-label {
    font-size: 7.5px;
    color: rgba(0,0,0,0.55);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }
  .mk-metric-value {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 800;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }
  .mk-metric-bar {
    width: 100%;
    height: 3px;
    background: rgba(0,0,0,0.06);
    border-radius: 2px;
