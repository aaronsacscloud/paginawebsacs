  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .hero-title,
    .hero-subtitle,
    .hero-ctas,
    .hero-bottom-bar,
    .hero-image-wrapper,
    .hero-image,
    .platform-mockup,
    .accordion-body,
    .tablet-slide {
      transition: none;
      animation: none;
      opacity: 1;
      transform: none;
    }

    .accordion-item.active .accordion-progress-fill {
      animation: none;
      width: 100%;
    }

    .hero-tablet-section {
      height: auto;
      padding: var(--space-12) 0;
      background: #4B7BE5;
    }

    .hero-tablet-sticky {
      position: relative;
      height: auto;
    }

    .hero-tablet-frame {
      transform: none !important;
    }
  }
</style>

<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.innerWidth < 768;

  // ═══ Tablet scroll-driven animation ═══
  const tabletSection = document.querySelector<HTMLElement>('.hero-tablet-section');
  const tabletFrame = document.querySelector<HTMLElement>('.hero-tablet-frame');
  const tabletSlides = document.querySelectorAll<HTMLDivElement>('.tablet-slide');
  const tabletPills = document.querySelectorAll<HTMLButtonElement>('.tablet-vpill');
  const bgLayers = document.querySelectorAll<HTMLElement>('.tablet-bg-layer');
  const sectionTitleEl = document.getElementById('tablet-section-title');
  const detailPanels = document.querySelectorAll<HTMLElement>('.tablet-detail');

  const slideTitles = [
    'Vende más en cada punto',
    'Controla tu stock en tiempo real',
    'Fideliza a cada cliente',
    'Automatiza con inteligencia',
  ];

  function setActiveSlide(index: number) {
    tabletSlides.forEach((s, i) => s.classList.toggle('active', i === index));
    tabletPills.forEach((p, i) => p.classList.toggle('active', i === index));
    bgLayers.forEach((l, i) => l.classList.toggle('active', i === index));
    detailPanels.forEach((d, i) => d.classList.toggle('active', i === index));
    if (sectionTitleEl) sectionTitleEl.textContent = slideTitles[index] || slideTitles[0];
  }

  if (!prefersReducedMotion && !isMobile && tabletSection && tabletFrame) {
    let lastSlideIdx = -1;

    const onTabletScroll = () => {
      const rect = tabletSection.getBoundingClientRect();
      const sectionH = tabletSection.offsetHeight;
      const vh = window.innerHeight;
      const scrolled = -rect.top;
      const scrollable = sectionH - vh;

      if (scrolled < 0 || scrolled > scrollable) return;

      const totalProgress = scrolled / scrollable;

      let bgProgress: number;
      if (totalProgress < 0.10) {
        bgProgress = totalProgress / 0.10;
      } else if (totalProgress > 0.90) {
        bgProgress = 1 - ((totalProgress - 0.90) / 0.10);
      } else {
        bgProgress = 1;
      }
      tabletSection.style.setProperty('--tablet-bg-progress', String(bgProgress));

      const tiltEnd = 0.12;
      const tilt = Math.max(0, 1 - (totalProgress / tiltEnd));
      tabletSection.style.setProperty('--tablet-tilt', String(tilt));

      const slideStart = 0.12;
      const slideEnd = 0.90;
      const slideProgress = Math.max(0, Math.min(1,
        (totalProgress - slideStart) / (slideEnd - slideStart)
      ));

      const numSlides = tabletSlides.length;
      const slideIdx = Math.min(numSlides - 1, Math.floor(slideProgress * numSlides));

      if (slideIdx !== lastSlideIdx) {
        setActiveSlide(slideIdx);
        lastSlideIdx = slideIdx;
      }
    };

    window.addEventListener('scroll', onTabletScroll, { passive: true });
    onTabletScroll();
  } else if (isMobile && !prefersReducedMotion) {
    let mobileSlideIdx = 0;
    setActiveSlide(0);
    setInterval(() => {
      mobileSlideIdx = (mobileSlideIdx + 1) % tabletSlides.length;
      setActiveSlide(mobileSlideIdx);
    }, 4000);
  } else {
    setActiveSlide(0);
  }

  // Pill clicks
  tabletPills.forEach((pill, i) => {
    pill.addEventListener('click', () => setActiveSlide(i));
  });

  // ═══ Scrollytelling — sticky image + features ═══
  const scrollyItems = document.querySelectorAll<HTMLElement>('.scrolly-item');
  const scrollyImgs = document.querySelectorAll<HTMLElement>('.scrolly-img');
  const scrollyBgs = document.querySelectorAll<HTMLElement>('.scrolly-bg');

  if (scrollyItems.length > 0 && scrollyImgs.length > 0) {
    const scrollyObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const idx = (entry.target as HTMLElement).dataset.scrollyIdx;
            scrollyItems.forEach((item) =>
              item.classList.toggle('active', item.dataset.scrollyIdx === idx)
            );
            scrollyImgs.forEach((img) =>
              img.classList.toggle('active', img.dataset.scrollyImg === idx)
            );
            scrollyBgs.forEach((bg) =>
              bg.classList.toggle('active', bg.dataset.scrollyBg === idx)
            );
          }
        });
      },
      { rootMargin: '-35% 0px -35% 0px' }
    );
    scrollyItems.forEach((item) => scrollyObserver.observe(item));
  }

  // ═══ Feature showcase — reveal on scroll ═══
  const fsWrapper = document.querySelector('.fs-image-wrapper');
  if (fsWrapper) {
    const fsObserver = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          fsWrapper.classList.add('in-view');
          fsObserver.disconnect();
        }
      },
      { threshold: 0.3 }
    );
    fsObserver.observe(fsWrapper);
  }

  // ═══ Expanding panels ═══
  const panels = document.querySelectorAll<HTMLElement>('.sp-panel');
  if (panels.length > 0) {
    let panelInterval: ReturnType<typeof setInterval> | null = null;
    let activePanel = 0;
    const PANEL_MS = 4500;

    function setActivePanel(idx: number) {
      panels.forEach((p, i) => p.classList.toggle('active', i === idx));
      activePanel = idx;
    }

    function startPanelCycle() {
      stopPanelCycle();
      panelInterval = setInterval(() => {
        setActivePanel((activePanel + 1) % panels.length);
      }, PANEL_MS);
    }

    function stopPanelCycle() {
      if (panelInterval) { clearInterval(panelInterval); panelInterval = null; }
    }

    panels.forEach((panel, i) => {
      panel.addEventListener('click', () => {
        stopPanelCycle();
        setActivePanel(i);
        startPanelCycle();
      });
    });

    if (!prefersReducedMotion) startPanelCycle();
  }

  // ═══ Platform accordion ═══
  const accordionItems = document.querySelectorAll<HTMLDivElement>('.accordion-item');
  const platformMockups = document.querySelectorAll<HTMLDivElement>('.platform-mockup');

  const accordionToMockup: Record<string, string> = {
    pos: 'pos',
    stock: 'stock',
    crm: 'crm',
    reports: 'reports',
    ai: 'ai',
  };

  if (accordionItems.length > 0) {
    let activeAccordion = 0;
    let accInterval: ReturnType<typeof setInterval> | null = null;
    const ACC_MS = 5000;

    function setActiveAccordion(index: number) {
      const ucId = accordionItems[index]?.dataset.accordion || '';

      accordionItems.forEach((item, i) => {
        const isActive = i === index;
        item.classList.toggle('active', isActive);
        const btn = item.querySelector('.accordion-header');
        if (btn) btn.setAttribute('aria-expanded', String(isActive));
      });

      const mockupId = accordionToMockup[ucId] || '';
      platformMockups.forEach((m) => m.classList.toggle('active', m.dataset.mockup === mockupId));

      activeAccordion = index;
    }

    function startAccCycle() {
      stopAccCycle();
      accInterval = setInterval(() => {
        setActiveAccordion((activeAccordion + 1) % accordionItems.length);
      }, ACC_MS);
    }

    function stopAccCycle() {
      if (accInterval) { clearInterval(accInterval); accInterval = null; }
    }

    accordionItems.forEach((item, i) => {
      const header = item.querySelector('.accordion-header');
      if (header) {
        header.addEventListener('click', () => {
          stopAccCycle();
          setActiveAccordion(i);
          startAccCycle();
        });
      }
    });

    if (!prefersReducedMotion) startAccCycle();
    setActiveAccordion(0);
  }
</script>
