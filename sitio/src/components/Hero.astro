  /* Visual: screen mockup */
  .inv-intel-visual {
    flex: 1.2;
    min-width: 0;
  }
  .inv-intel-screen {
    background: #fff;
    border-radius: 20px;
    border: 1px solid rgba(0,0,0,0.06);
    overflow: hidden;
  }
  .inv-intel-screen-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .inv-intel-screen-title {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .inv-intel-screen-badge {
    font-size: 11px;
    font-weight: 700;
    color: #2AB5A0;
    background: rgba(42,181,160,0.1);
    padding: 4px 10px;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Table */
  .inv-intel-screen-body {
    padding: 0;
  }
  .inv-intel-row {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 0.6fr) 1.2fr;
    align-items: center;
    padding: 12px 20px;
    font-size: 13px;
    color: var(--color-text-secondary);
    border-bottom: 1px solid rgba(0,0,0,0.04);
    gap: 8px;
  }
  .inv-intel-row--header {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(0,0,0,0.35);
    background: rgba(0,0,0,0.02);
    padding: 10px 20px;
  }
  .inv-intel-row--highlight {
    background: rgba(42,181,160,0.04);
  }
  .inv-intel-prod {
    font-weight: 600;
    color: var(--color-text-primary);
  }
  .inv-intel-action {
    font-size: 12px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 6px;
    white-space: nowrap;
  }
  .inv-intel-action--transfer { background: rgba(75,123,229,0.1); color: #4B7BE5; }
  .inv-intel-action--restock { background: rgba(42,181,160,0.1); color: #2AB5A0; }
  .inv-intel-action--promo { background: rgba(232,168,56,0.1); color: #C08A2A; }
  .inv-intel-action--buy { background: rgba(75,123,229,0.1); color: #4B7BE5; }
  .inv-intel-action--liquidate { background: rgba(232,67,147,0.08); color: #D63384; }

  .inv-intel-screen-footer {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    font-size: 12px;
    color: rgba(0,0,0,0.4);
    border-top: 1px solid rgba(0,0,0,0.04);
  }
  .inv-intel-footer-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #2AB5A0;
    flex-shrink: 0;
  }

  /* Feature cards grid — Square style with separators */
  .inv-intel-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    background: transparent;
    border-radius: 0;
    overflow: visible;
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(0,0,0,0.08);
  }
  @media (max-width: 767px) {
    .inv-intel-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .inv-intel-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .inv-intel-card {
    padding: clamp(28px, 3vw, 40px) clamp(20px, 2.5vw, 28px);
    border-bottom: 1px solid rgba(0,0,0,0.08);
    border-right: 1px solid rgba(0,0,0,0.08);
  }
  .inv-intel-card:nth-child(3n) { border-right: none; }
  .inv-intel-card:nth-child(n+4) { border-bottom: none; }
  @media (max-width: 767px) {
    .inv-intel-card { border-right: none; }
    .inv-intel-card:nth-child(n+4) { border-bottom: 1px solid rgba(0,0,0,0.08); }
    .inv-intel-card:last-child { border-bottom: none; }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .inv-intel-card:nth-child(3n) { border-right: 1px solid rgba(0,0,0,0.08); }
    .inv-intel-card:nth-child(2n) { border-right: none; }
  }
  .inv-intel-card-icon {
    display: block;
    margin-bottom: 20px;
    opacity: 0.4;
  }
  .inv-intel-card-icon svg {
    width: 28px;
    height: 28px;
  }
  .inv-intel-card-icon svg * {
    stroke: #1A1A1A !important;
    fill: none !important;
  }
  .inv-intel-card-icon svg circle[fill],
  .inv-intel-card-icon svg rect[fill] {
    fill: none !important;
  }
  .inv-intel-card-icon svg text {
    fill: #1A1A1A !important;
    stroke: none !important;
  }
  .inv-intel-card-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 8px;
    letter-spacing: -0.01em;
  }
  .inv-intel-card-desc {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* Responsive: table scroll on mobile */
  @media (max-width: 767px) {
    .inv-intel-screen-body { overflow-x: auto; }
    .inv-intel-row { min-width: 500px; }
  }

  /* ═══════════════════════════════════════════
     Por qué SACS — Scrollytelling with images
     ═══════════════════════════════════════════ */
  .why-sacs-section {
    position: relative;
    background: #fff;
    display: block;
  }
  @media (min-width: 1024px) {
    .why-sacs-section {
      /* no padding — handled by children */
    }
  }
  .why-sacs-scrolly {
    position: relative;
    display: block;
  }
  @media (min-width: 1024px) {
    .why-sacs-scrolly {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Sticky image — left half */
  .why-sacs-media {
    display: none;
  }
  @media (min-width: 1024px) {
    .why-sacs-media {
      display: block;
      position: sticky;
      top: 72px;
      height: calc(100vh - 72px);
      overflow: hidden;
    }
