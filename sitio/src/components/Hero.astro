    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: rgba(37, 211, 102, 0.08);
    top: 10%;
    right: -15%;
    filter: blur(60px);
    transition: top 0.6s ease, background 0.5s ease;
  }

  /* Fondo blanco unificado en todos los pasos — solo el glow cambia ligeramente */
  .sq-phone-bg[data-bg-step="1"],
