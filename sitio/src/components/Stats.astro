---
import { stats as defaultStats } from '../data/home';

interface Stat {
  number: string;
  label: string;
}

interface Props {
  stats?: Stat[];
}

const { stats = defaultStats } = Astro.props;
---

<section class="stats section" id="stats">
  <div class="container">
    <dl class="stats-grid">
      {stats.map((stat) => (
        <div class="stat-item">
          <dt class="stat-label body-small">{stat.label}</dt>
          <dd class="stat-number display-l">{stat.number}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .stats {
    background: var(--color-bg-primary);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat-item {
    text-align: center;
    padding: var(--space-6) 0;
    border-top: 2px solid var(--color-primary);
  }

  .stat-number {
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .stat-label {
    color: var(--color-text-tertiary);
    order: 1;
  }

  .stat-number {
    order: 0;
  }
</style>
