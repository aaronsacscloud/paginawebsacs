    image: '/images/marketing-whatsapp-hero.webp',
    imageAlt: 'SACS Marketing por WhatsApp',
    href: '/producto/marketing-por-whatsapp',
    ctaLabel: 'Conocer marketing',
  },
];

const steps = [
  {
    title: 'Conecta tu catálogo.',
    description: 'Importa tu inventario de SACS POS o sube un CSV. Tus productos aparecen en el sitio con stock y precios al instante.',
  },
  {
    title: 'Elige un estilo.',
    description: 'Parte de una paleta y tipografía base. Después afinas — todo es editable.',
  },
  {
    title: 'Personaliza tu landing.',
    description: 'Hero, productos destacados, secciones de marca, lookbook. Edita arrastrando bloques.',
  },
  {
    title: 'Configura el cobro.',
    description: 'Conectas tu Stripe en minutos. Apple Pay, Google Pay y métodos locales activos por default.',
  },
  {
    title: 'Conecta tu dominio.',
    description: 'Apunta tu dominio (o subdominio) a SACS. Te damos los registros DNS exactos.',
  },
  {
    title: 'Publica y empieza a vender.',
    description: 'Un clic y tu tienda está en vivo. Recibes el primer pedido en tu POS y en tu correo simultáneamente.',
  },
];

const supportItems = [
  {
    eyebrow: 'Onboarding',
    title: 'Te acompañamos en el lanzamiento.',
    description: 'Un especialista te ayuda con la configuración inicial, importación de catálogo y conexión de dominio. Sin costo extra.',
    href: '/contacto',
    ctaLabel: 'Agendar onboarding',
  },
  {
    eyebrow: 'Centro de ayuda',
    title: 'Documentación clara y soporte humano.',
    description: 'Guías paso a paso, videos tutoriales y un equipo que responde en español, en horario LatAm.',
    href: '/centro-de-ayuda',
    ctaLabel: 'Ir al centro de ayuda',
  },
];
---

<ProductLayout
  title={feature.title}
  description={feature.description}
  currentSlug={slug}
  currentPillar={pillar.id}
  preloadImage="/images/cm-boutique.webp"
>
  <section class="pf-hero-centered">
    <div class="pf-hero-centered-inner container">
      <h1 class="pf-hero-title">{content.hero.title}</h1>
      <p class="pf-hero-subtitle">{content.hero.subtitle}</p>
      <div class="pf-hero-ctas">
        <a href="/prueba-gratis" class="pf-hero-btn pf-hero-btn--outline">Prueba gratis</a>
        <a href="/contacto" class="pf-hero-btn pf-hero-btn--solid">Agenda una demo</a>
      </div>
    </div>
    <div class="pf-hero-media container">
      <div class="pf-hero-media-wrap pf-hero-media-wrap--mock">
        <div class="pf-ipad-perspective" id="pf-ipad-perspective">
          <div class="pf-ipad-idle">
            <div class="pf-hero-video-frame pf-hero-video-frame--ipad">
              <span class="pf-ipad-cam" aria-hidden="true"></span>
              <div class="pf-ipad-screen">
                <div class="pf-storemock" aria-hidden="true">
                  <div class="pf-storemock-stage">

                    <div class="pf-pos">
                      <div class="pf-pos-head">
                        <div class="pf-pos-user">
                          <div class="pf-pos-avatar">L</div>
                          <div class="pf-pos-userinfo">
                            <span class="pf-pos-name">Lucía</span>
                            <span class="pf-pos-caja">Caja Mara CDMX <span class="pf-pos-conn"><i class="pf-pos-conn-dot"></i> Conexión estable</span></span>
                          </div>
                        </div>
                        <button class="pf-pos-actions">▦ Más acciones ▾</button>
                      </div>

                      <div class="pf-pos-body">
                        <div class="pf-pos-left">
                          <div class="pf-pos-search">
                            <span class="pf-pos-search-icon">⌕</span>
                            <span class="pf-pos-search-ph">Busca el nombre del producto, sku o código de barras</span>
                          </div>
                          <div class="pf-pos-tiles">
                            <div class="pf-pos-tile pf-pos-tile--quick">
                              <svg viewBox="0 0 24 24" fill="none" stroke="#5DA866" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 5h2l2.4 11.2a2 2 0 0 0 2 1.6h7.6a2 2 0 0 0 2-1.6L21 8H6"/><circle cx="9" cy="20" r="1"/><circle cx="17" cy="20" r="1"/></svg>
                              <span class="pf-pos-tile-name">Venta rápida</span>
                            </div>
                            <div class="pf-pos-tile" style="background:#9DC881"><span class="pf-pos-tile-name">NOVEDADES</span><span class="pf-pos-tile-tag">Carpeta</span></div>
                            <div class="pf-pos-tile" style="background:#C9A4DD"><span class="pf-pos-tile-name">ROPA</span><span class="pf-pos-tile-tag">Carpeta</span></div>
                            <div class="pf-pos-tile" style="background:#9CCDD2"><span class="pf-pos-tile-name">CALZADO</span><span class="pf-pos-tile-tag">Carpeta</span></div>
                            <div class="pf-pos-tile pf-pos-tile--product">
                              <div class="pf-pos-tile-img">
                                <img src="/images/cm-boutique.webp" alt="" width="160" height="160" loading="eager" fetchpriority="high" />
                              </div>
                              <span class="pf-pos-tile-name">Blusa Sole</span>
                              <span class="pf-pos-tile-price">$1,290</span>
                            </div>
                            <div class="pf-pos-tile" style="background:#D480D2"><span class="pf-pos-tile-name">BELLEZA</span><span class="pf-pos-tile-tag">Carpeta</span></div>
                            <div class="pf-pos-tile" style="background:#BCD0EE"><span class="pf-pos-tile-name">VESTIDOS</span><span class="pf-pos-tile-tag">Carpeta</span></div>
                            <div class="pf-pos-tile" style="background:#4F837E"><span class="pf-pos-tile-name">PROMOCIONES</span><span class="pf-pos-tile-tag">Carpeta</span></div>
                          </div>
                        </div>

                        <div class="pf-pos-right">
                          <div class="pf-pos-tabs">
                            <span>Guardar</span>
                            <span>Ventas</span>
                            <span>Pedidos</span>
                            <span class="pf-pos-tab-clear">Limpiar</span>
                          </div>
                          <div class="pf-pos-customer">
                            <span class="pf-pos-customer-tag">EN PISO</span>
                            <span class="pf-pos-customer-id">Sofía R. · pago directo</span>
                          </div>
                          <div class="pf-pos-cart">
                            <div class="pf-pos-cart-row">
                              <div class="pf-pos-cart-thumb"><img src="/images/cm-boutique.webp" alt="" width="40" height="50" loading="lazy" /></div>
                              <div class="pf-pos-cart-info">
                                <span class="pf-pos-cart-name">Blusa Sole</span>
                                <span class="pf-pos-cart-variant">Talla M · Crema · 1 pieza</span>
                              </div>
                              <span class="pf-pos-cart-price">1,290.00</span>
                            </div>
                            <div class="pf-pos-stockpill">
                              <span class="pf-pos-stockpill-label">Stock Blusa Sole · sincronizando</span>
                              <span class="pf-pos-stockpill-num">
                                <span class="pf-pos-stock-from">12</span>
                                <span class="pf-pos-stock-arrow">→</span>
                                <span class="pf-pos-stock-to">11</span>
                              </span>
                              <span class="pf-pos-stockpill-sync"><i class="pf-pos-syncdot"></i> POS y tienda online en línea</span>
                            </div>
                          </div>
                          <div class="pf-pos-totals">
                            <div class="pf-pos-totals-row"><span>Subtotal</span><span class="pf-pos-totals-amt">$1,112.07</span></div>
                            <div class="pf-pos-totals-row pf-pos-totals-row--muted"><span>IVA 16%</span><span>$177.93</span></div>
                          </div>
                          <button type="button" class="pf-pos-pay">
                            <span class="pf-pos-pay-label pf-pos-pay-label--idle">
                              <span class="pf-pos-pay-text">COBRAR EN PISO</span>
                              <span class="pf-pos-pay-amt">$1,290.00 <small>MXN</small></span>
                            </span>
                            <span class="pf-pos-pay-label pf-pos-pay-label--done">
                              <span class="pf-pos-pay-text">✓ COBRADO</span>
                              <span class="pf-pos-pay-amt-done">Sincronizando con mara.shop…</span>
                            </span>
                          </button>
                        </div>
                      </div>
                    </div>

                    <div class="pf-online">
                      <div class="pf-online-bar">
                        <span class="pf-online-dots"><i></i><i></i><i></i></span>
                        <span class="pf-online-urls">
                          <span class="pf-online-url pf-online-url--catalog">mara.shop / tienda</span>
                          <span class="pf-online-url pf-online-url--pdp">mara.shop / blusa-sole</span>
                          <span class="pf-online-url pf-online-url--cart">mara.shop / bolsa</span>
                          <span class="pf-online-url pf-online-url--confirm">mara.shop / pedido / m-1042</span>
                        </span>
                        <span class="pf-online-bag">
                          <span class="pf-online-bag-icon" aria-hidden="true">⌒</span>
                          Bolsa ·
                          <span class="pf-online-bag-count">
                            <span class="pf-online-bag-count--zero">0</span>
                            <span class="pf-online-bag-count--one">1</span>
                          </span>
                        </span>
                      </div>
                      <div class="pf-online-site">
                        <header class="pf-online-nav">
                          <span class="pf-online-logo">Mara</span>
                          <nav class="pf-online-links">
                            <span>Tienda</span>
                            <span>Lookbook</span>
                            <span>Atelier</span>
                            <span>Diario</span>
                          </nav>
                          <span class="pf-online-search">⌕</span>
                        </header>

                        <div class="pf-online-stage">

                          <section class="pf-scene pf-scene--catalog">
                            <div class="pf-cat-head">
                              <span class="pf-cat-eyebrow">Edición Otoño · 26</span>
                              <span class="pf-cat-meta">12 piezas · stock real desde POS</span>
                            </div>
                            <div class="pf-cat-grid">
                              <article class="pf-cat-tile">
                                <div class="pf-cat-tile-img"><img src="/images/reco-blazer.webp" alt="" width="220" height="280" loading="lazy" /></div>
                                <span class="pf-cat-tile-name">Saco Liana</span>
                                <span class="pf-cat-tile-price">$2,490</span>
                              </article>
                              <article class="pf-cat-tile pf-cat-tile--featured">
                                <div class="pf-cat-tile-img">
                                  <img src="/images/cm-boutique.webp" alt="" width="220" height="280" loading="eager" fetchpriority="high" />
                                  <span class="pf-cat-tile-stockbadge">
                                    <span class="pf-cat-tile-stockbadge-dot"></span>
                                    <span class="pf-cat-tile-stockbadge-text">Quedan <b>11</b> · stock real</span>
                                  </span>
                                </div>
                                <span class="pf-cat-tile-name">Blusa Sole</span>
                                <span class="pf-cat-tile-price">$1,290</span>
                                <div class="pf-cat-tile-cursor" aria-hidden="true"></div>
                              </article>
                              <article class="pf-cat-tile">
                                <div class="pf-cat-tile-img"><img src="/images/reco-falda.webp" alt="" width="220" height="280" loading="lazy" /></div>
                                <span class="pf-cat-tile-name">Falda Otoño</span>
                                <span class="pf-cat-tile-price">$1,790</span>
                              </article>
                              <article class="pf-cat-tile">
                                <div class="pf-cat-tile-img"><img src="/images/reco-blusa.webp" alt="" width="220" height="280" loading="lazy" /></div>
                                <span class="pf-cat-tile-name">Top Marina</span>
                                <span class="pf-cat-tile-price">$1,490</span>
                              </article>
                            </div>
                          </section>

                          <section class="pf-scene pf-scene--pdp">
                            <span class="pf-pdp-back">← Tienda</span>
                            <div class="pf-pdp-grid">
                              <div class="pf-pdp-img">
                                <img src="/images/cm-boutique.webp" alt="" width="320" height="400" loading="lazy" />
                              </div>
                              <div class="pf-pdp-info">
                                <span class="pf-pdp-eyebrow">Edición Otoño</span>
                                <h3 class="pf-pdp-title">Blusa Sole</h3>
                                <span class="pf-pdp-price">$1,290.00 <small>MXN</small></span>
                                <p class="pf-pdp-desc">Algodón orgánico bordado a mano. Cuello redondo, mangas globo.</p>
                                <div class="pf-pdp-section">
                                  <span class="pf-pdp-label">Talla</span>
                                  <div class="pf-pdp-sizes">
                                    <span>XS</span><span>S</span><span class="pf-pdp-size--active">M</span><span>L</span>
                                  </div>
                                </div>
                                <div class="pf-pdp-stock">
                                  <span class="pf-pdp-stock-dot"></span>
                                  <span>11 en inventario · listo en 24h</span>
                                </div>
                                <button class="pf-pdp-add" type="button">
                                  <span class="pf-pdp-add-label pf-pdp-add-label--idle">AGREGAR A BOLSA</span>
                                  <span class="pf-pdp-add-label pf-pdp-add-label--done">✓ AGREGADO</span>
                                </button>
                              </div>
                            </div>
                          </section>

                          <section class="pf-scene pf-scene--cart">
                            <div class="pf-cart-overlay"></div>
                            <aside class="pf-cart-drawer">
                              <header class="pf-cart-head">
                                <span>Tu bolsa · 1 pieza</span>
                                <span class="pf-cart-close">×</span>
                              </header>
                              <div class="pf-cart-row">
                                <div class="pf-cart-row-img"><img src="/images/cm-boutique.webp" alt="" width="64" height="80" loading="lazy" /></div>
                                <div class="pf-cart-row-info">
                                  <span class="pf-cart-row-name">Blusa Sole</span>
                                  <span class="pf-cart-row-meta">Talla M · Crema</span>
                                  <span class="pf-cart-row-qty">Cantidad: 1</span>
                                </div>
                                <span class="pf-cart-row-price">$1,290</span>
                              </div>
                              <div class="pf-cart-totals">
                                <div class="pf-cart-totals-row"><span>Subtotal</span><span>$1,112.07</span></div>
                                <div class="pf-cart-totals-row pf-cart-totals-row--muted"><span>IVA 16%</span><span>$177.93</span></div>
                                <div class="pf-cart-totals-row pf-cart-totals-row--total"><span>Total</span><span>$1,290.00 MXN</span></div>
                              </div>
                              <button class="pf-cart-pay" type="button">
                                <span class="pf-cart-pay-label pf-cart-pay-label--idle">PAGAR · $1,290 MXN →</span>
                                <span class="pf-cart-pay-label pf-cart-pay-label--processing">PROCESANDO PAGO…</span>
                              </button>
                              <span class="pf-cart-trust">Envío seguro · 24h en CDMX</span>
                            </aside>
                          </section>

                          <section class="pf-scene pf-scene--confirm">
                            <div class="pf-confirm-card">
                              <div class="pf-confirm-check">
                                <svg viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 7"/></svg>
                              </div>
                              <h3 class="pf-confirm-title">Pedido confirmado</h3>
                              <p class="pf-confirm-id">#M-1042 · Blusa Sole · Talla M</p>
                              <div class="pf-confirm-amount">$1,290.00 MXN</div>
