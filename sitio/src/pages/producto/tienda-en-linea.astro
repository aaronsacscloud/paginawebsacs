---

<ProductLayout
  title={feature.title}
  description={feature.description}
  currentSlug={slug}
  currentPillar={pillar.id}
  preloadImage={content?.hero?.image}
>
  <section class="pf-hero-centered">
    <div class="pf-hero-centered-inner container">
      <h1 class="pf-hero-title">{content.hero.title}</h1>
      <p class="pf-hero-subtitle">{content.hero.subtitle}</p>
      <div class="pf-hero-ctas">
        <a href="/prueba-gratis" class="pf-hero-btn pf-hero-btn--outline">Prueba gratis</a>
        <a href="/contacto" class="pf-hero-btn pf-hero-btn--solid">Agenda una demo</a>
      </div>
    </div>
    <div class="pf-hero-media container">
      <div class="pf-hero-media-wrap pf-hero-media-wrap--mock">
        <div class="pf-ipad-perspective" id="pf-ipad-perspective">
          <div class="pf-ipad-idle">
            <div class="pf-hero-video-frame pf-hero-video-frame--ipad">
              <span class="pf-ipad-cam" aria-hidden="true"></span>
              <div class="pf-ipad-screen">
                {content.hero.image ? (
                  <img src={content.hero.image} alt={content.hero.imageAlt} width="1200" height="675" loading="eager" fetchpriority="high" />
                ) : (
                  <div class="pf-ipad-placeholder" aria-hidden="true"></div>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <StoresShowcase
    eyebrow="Tiendas reales hechas con SACS"
    title="Catálogos físicos que ya viven en línea."
    subtitle="Cada una empezó como POS y conectó su tienda online en SACS. Mismo stock, misma caja, misma marca."
    stores={stores}
    ctaLabel="Ver casos de éxito"
    ctaHref="/blog"
  />

  <BentoGrid
    eyebrow="Diseño inteligente"
    title="Crea una tienda en línea hecha a tu marca."
    subtitle="No es una plantilla con tu logo pegado. Editor visual, IA que redacta y un sistema que se adapta a tu catálogo."
    items={bentoItems}
  />

  <CreativeToolsGrid
    eyebrow="Herramientas creativas"
    title="Las herramientas que tu sitio necesita para destacar."
    subtitle="Diseño responsive, contenido multimedia y micro-animaciones — sin sumar peso ni complicar el editor."
