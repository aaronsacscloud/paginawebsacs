  },
  {
    title: 'Capta el interés con movimiento.',
    description: 'Animaciones sutiles en el hero, en cards de producto y en CTAs. Sin ralentizar el sitio.',
    visual: 'motion' as const,
  },
  {
    title: 'Potencia el atractivo visual.',
    description: 'Filtros, transiciones suaves y efectos hover que dan personalidad sin sentirse genéricos.',
    visual: 'effects' as const,
  },
];

const discoveryItems = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>',
    title: 'SEO integrado',
    description: 'Metadatos, sitemap, Open Graph y schema.org se generan solos por producto. Apuntas tu dominio y empiezas a indexar.',
    bullets: [
      'Sitemap.xml y robots.txt automáticos',
      'Schema product, breadcrumb y review',
      'Open Graph y Twitter Cards por SKU',
    ],
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>',
    title: 'Integraciones y extensiones',
    description: 'Conecta con los pixels y APIs que ya usas. Sin instalar plugins, sin duplicar configuración.',
    bullets: [
      'Meta Pixel y Conversions API',
      'Google Analytics 4 y Tag Manager',
