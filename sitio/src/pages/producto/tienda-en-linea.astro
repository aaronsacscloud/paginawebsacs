    bullets: [
      'Conversión por canal y dispositivo',
      'Embudo de checkout en vivo',
      'SKU más vistos vs. más comprados',
    ],
  },
];

const relatedProducts = [
  {
    eyebrow: 'Punto de Venta',
    title: 'Conecta tu tienda online con tu POS.',
    description: 'Mismo catálogo, mismo cliente, misma caja. La caja física y el e-commerce dejan de ser sistemas distintos.',
    image: '/images/pos-control-central.webp',
    imageAlt: 'SACS Punto de Venta — pantalla principal',
    href: '/producto/punto-de-venta',
    ctaLabel: 'Conocer POS',
  },
  {
    eyebrow: 'Programa de Lealtad',
