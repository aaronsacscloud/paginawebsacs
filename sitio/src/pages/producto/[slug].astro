    font-weight: 700;
    color: var(--color-text-primary, #1a1a2e);
    text-decoration: none;
    margin-top: var(--space-5, 20px);
    transition: gap 0.2s ease;
  }

  .sq-block-link:hover {
    gap: 10px;
    text-decoration: none;
  }

  .sq-block-media {
    border-radius: 12px;
    overflow: hidden;
    background: var(--color-bg-secondary, #F5F3EE);
  }

  .sq-block-media img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 12px;
  }

  /* ═══ Featured block (photo + floating POS card) ═══ */
  .sq-block--featured .sq-block-media {
    background: transparent;
    overflow: visible;
  }

  .sq-featured {
    position: relative;
    isolation: isolate;
  }

  .sq-featured > img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12), 0 4px 12px rgba(0, 0, 0, 0.06);
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  /* Floating POS card */
  .sq-featured-card {
    position: absolute;
    bottom: -28px;
    left: -24px;
    width: min(300px, 72%);
    background: #fff;
    border-radius: 14px;
    padding: 14px 14px 12px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.18), 0 6px 16px rgba(0, 0, 0, 0.08);
    font-family: var(--font-body, 'Plus Jakarta Sans', sans-serif);
    z-index: 2;
    animation: sqFeaturedFloat 6s ease-in-out infinite;
  }

  /* Size modifiers (applied on .sq-featured wrapper, cascade to inner card) */
  .sq-featured--size-sm .sq-featured-card {
    width: min(240px, 62%);
    padding: 11px 12px 10px;
    font-size: 0.75rem;
  }

  .sq-featured--size-lg .sq-featured-card {
    width: min(380px, 88%);
    padding: 16px 16px 14px;
  }

  /* Position modifiers */
  .sq-featured--pos-top-right .sq-featured-card {
    top: -28px;
    right: -24px;
    bottom: auto;
    left: auto;
  }

  .sq-featured--pos-top-left .sq-featured-card {
    top: -28px;
    left: -24px;
    bottom: auto;
    right: auto;
  }

  .sq-featured--pos-bottom-right .sq-featured-card {
    bottom: -28px;
    right: -24px;
    top: auto;
    left: auto;
  }

  .sq-featured--pos-center-bottom .sq-featured-card {
    bottom: -36px;
    left: 50%;
    right: auto;
    top: auto;
    transform: translateX(-50%);
    animation: sqFeaturedFloatCenter 6s ease-in-out infinite;
  }

  @keyframes sqFeaturedFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @keyframes sqFeaturedFloatCenter {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(-6px); }
  }

  .sq-fc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 10px;
    margin-bottom: 10px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .sq-fc-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-text-primary, #1a1a2e);
  }

  .sq-fc-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #2AB5A0;
    box-shadow: 0 0 0 3px rgba(42, 181, 160, 0.18);
    animation: sqFcPulse 2s ease-in-out infinite;
  }

  @keyframes sqFcPulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(42, 181, 160, 0.18); }
    50% { box-shadow: 0 0 0 5px rgba(42, 181, 160, 0.08); }
  }

  .sq-fc-time {
    font-size: 0.625rem;
    font-weight: 500;
    color: var(--color-text-tertiary, #8c8c8c);
    letter-spacing: 0.02em;
  }

  .sq-fc-line {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    padding: 6px 0;
  }

  .sq-fc-line-main {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .sq-fc-prod {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-primary, #1a1a2e);
    line-height: 1.2;
  }

  .sq-fc-qty {
    font-size: 0.625rem;
    color: var(--color-text-tertiary, #8c8c8c);
    line-height: 1.2;
  }

  .sq-fc-price {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-primary, #1a1a2e);
    flex-shrink: 0;
  }

  .sq-fc-total {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 0 12px;
    margin-top: 6px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-secondary, #4A4A4A);
  }

  .sq-fc-total-val {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 1.125rem;
    font-weight: 800;
    color: var(--color-text-primary, #1a1a2e);
    letter-spacing: -0.02em;
  }

  .sq-fc-cobrar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    width: 100%;
    padding: 10px 14px;
    background: #2563EB;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    cursor: default;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.28);
  }

  /* Device pills */
  .sq-featured-pill {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: #fff;
    border-radius: 50px;
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-primary, #1a1a2e);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12), 0 2px 6px rgba(0, 0, 0, 0.04);
    z-index: 3;
    white-space: nowrap;
  }

  .sq-featured-pill svg {
    color: #2563EB;
  }

  .sq-featured-pill--a {
    top: 8%;
    right: -10px;
    animation: sqPillFloat 5s ease-in-out infinite;
  }

  .sq-featured-pill--b {
    top: 40%;
    right: -18px;
    animation: sqPillFloat 5s ease-in-out infinite 1.2s;
  }

  .sq-featured-pill--c {
    top: 72%;
    right: -6px;
    animation: sqPillFloat 5s ease-in-out infinite 2.4s;
  }

  /* Flip pills to left side on pickup variant to avoid covering customer's phone/QR */
  .sq-featured--pickup .sq-featured-pill--a,
  .sq-featured--pickup .sq-featured-pill--b,
  .sq-featured--pickup .sq-featured-pill--c {
    right: auto;
  }

  .sq-featured--pickup .sq-featured-pill--a {
    top: 6%;
    left: -12px;
  }

  .sq-featured--pickup .sq-featured-pill--b {
    top: 38%;
    left: -20px;
  }

  .sq-featured--pickup .sq-featured-pill--c {
    top: 70%;
    left: -8px;
  }

  /* Pickup variant: card sits bottom-right instead of bottom-left */
  .sq-featured--pickup .sq-featured-card {
    left: auto;
    right: -24px;
  }

  /* Customer row (pickup) */
  .sq-fc-customer {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 4px 0 8px;
    border-bottom: 1px dashed rgba(0, 0, 0, 0.08);
    margin-bottom: 6px;
  }

  .sq-fc-cust-name {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-text-primary, #1a1a2e);
    letter-spacing: -0.01em;
  }

  .sq-fc-cust-meta {
    font-size: 0.625rem;
    color: var(--color-text-tertiary, #8c8c8c);
    line-height: 1.2;
  }

  /* QR row (pickup) */
  .sq-fc-qrrow {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px;
    margin-top: 8px;
    background: rgba(42, 181, 160, 0.08);
    border-radius: 10px;
  }

  .sq-fc-qr {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border-radius: 8px;
    color: #1a1a2e;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.06);
  }

  .sq-fc-qr-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .sq-fc-qr-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-primary, #1a1a2e);
    line-height: 1.2;
  }

  .sq-fc-qr-meta {
    font-size: 0.625rem;
    color: #2AB5A0;
    font-weight: 600;
    line-height: 1.2;
  }

  /* Pickup button — green instead of blue */
  .sq-fc-cobrar--pickup {
    background: #2AB5A0;
    box-shadow: 0 4px 12px rgba(42, 181, 160, 0.32);
    margin-top: 10px;
  }

  /* Blue variant of pulsing dot (endless-aisle) */
  .sq-fc-dot--blue {
    background: #2563EB;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.18);
    animation: sqFcPulseBlue 2s ease-in-out infinite;
  }

  @keyframes sqFcPulseBlue {
    0%, 100% { box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.18); }
    50% { box-shadow: 0 0 0 5px rgba(37, 99, 235, 0.08); }
  }

  /* ═══ Endless aisle variant — stock list ═══ */
  .sq-featured--endless-aisle .sq-featured-card {
    left: auto;
    right: -24px;
  }

  .sq-featured--endless-aisle .sq-featured-pill--a,
  .sq-featured--endless-aisle .sq-featured-pill--b,
  .sq-featured--endless-aisle .sq-featured-pill--c {
    right: auto;
  }

  .sq-featured--endless-aisle .sq-featured-pill--a {
    top: 6%;
    left: -12px;
  }

  .sq-featured--endless-aisle .sq-featured-pill--b {
    top: 38%;
    left: -20px;
  }

  .sq-featured--endless-aisle .sq-featured-pill--c {
    top: 70%;
    left: -8px;
  }

  .sq-fc-stock {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 4px 0 2px;
  }

  .sq-fc-stock-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 6px 10px;
    background: rgba(42, 181, 160, 0.08);
    border-radius: 8px;
  }

  .sq-fc-stock-row--out {
    background: rgba(0, 0, 0, 0.04);
  }

  .sq-fc-stock-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .sq-fc-stock-check {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6875rem;
    font-weight: 800;
    line-height: 1;
    flex-shrink: 0;
  }

  .sq-fc-stock-check--ok {
    background: #2AB5A0;
    color: #fff;
  }

  .sq-fc-stock-check--out {
    background: rgba(0, 0, 0, 0.15);
    color: #fff;
  }

  .sq-fc-stock-name {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-primary, #1a1a2e);
  }

  .sq-fc-stock-qty {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #2AB5A0;
  }

  .sq-fc-stock-row--out .sq-fc-stock-qty {
    color: var(--color-text-tertiary, #8c8c8c);
  }

  .sq-fc-cobrar--aisle {
    background: #2563EB;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.32);
    margin-top: 12px;
  }

  /* ═══ Control central variant — dashboard ═══ */
  .sq-featured--control-central .sq-featured-card {
    /* default: bottom-left (existing) */
  }

  .sq-fc-metric {
    padding: 10px 12px 12px;
    margin-top: 4px;
    background: linear-gradient(135deg, rgba(42, 181, 160, 0.08), rgba(37, 99, 235, 0.06));
    border-radius: 10px;
    position: relative;
    overflow: hidden;
  }

  .sq-fc-metric-label {
    display: block;
    font-size: 0.625rem;
    font-weight: 600;
    color: var(--color-text-tertiary, #8c8c8c);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 2px;
  }

  .sq-fc-metric-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }

  .sq-fc-metric-val {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-text-primary, #1a1a2e);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .sq-fc-metric-delta {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #2AB5A0;
  }

  .sq-fc-metric-spark {
    display: block;
    width: 100%;
    height: 28px;
    margin-top: 8px;
  }

  .sq-fc-ranking {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 10px;
  }

  .sq-fc-ranking-title {
    font-size: 0.625rem;
    font-weight: 700;
    color: var(--color-text-tertiary, #8c8c8c);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 2px;
  }

  .sq-fc-rank-row {
    display: grid;
    grid-template-columns: 18px 1fr auto;
    align-items: center;
    gap: 8px;
    padding: 4px 0;
  }

  .sq-fc-rank-pos {
    font-size: 0.625rem;
    font-weight: 800;
    color: #2563EB;
    background: rgba(37, 99, 235, 0.1);
    border-radius: 4px;
    text-align: center;
    line-height: 18px;
    height: 18px;
  }

  .sq-fc-rank-name {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-primary, #1a1a2e);
  }

  .sq-fc-rank-val {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-primary, #1a1a2e);
    font-variant-numeric: tabular-nums;
  }

  .sq-fc-cobrar--dash {
    background: #1a1a2e;
    box-shadow: 0 4px 12px rgba(26, 26, 46, 0.32);
    margin-top: 12px;
  }

  /* ─── Promo variant styles ─── */
  .sq-fc-badge--promo,
  .sq-fc-badge--schedule,
  .sq-fc-badge--code,
  .sq-fc-badge--loyalty {
    padding: 4px 10px;
    border-radius: 50px;
  }

  .sq-fc-badge--promo {
    background: #fef1e7;
    color: #c2490b;
  }
  .sq-fc-badge--promo .sq-fc-dot {
    background: #ea7b24;
    box-shadow: 0 0 0 3px rgba(234, 123, 36, 0.18);
    animation-name: sqFcPulseOrange;
  }

  .sq-fc-badge--schedule {
    background: #eef4ff;
    color: #2753b8;
  }
  .sq-fc-badge--schedule .sq-fc-dot {
    background: #3467db;
    box-shadow: 0 0 0 3px rgba(52, 103, 219, 0.18);
    animation-name: sqFcPulseBlue;
  }

  .sq-fc-badge--code {
    background: #f1ecff;
    color: #5735c2;
  }
  .sq-fc-badge--code .sq-fc-dot {
    background: #7a4ae0;
    box-shadow: 0 0 0 3px rgba(122, 74, 224, 0.18);
    animation-name: sqFcPulsePurple;
  }

  .sq-fc-badge--loyalty {
    background: #fff1c8;
    color: #6b4b00;
  }
  .sq-fc-badge--loyalty .sq-fc-dot {
    background: #b88900;
    box-shadow: 0 0 0 3px rgba(184, 137, 0, 0.22);
    animation-name: sqFcPulseGold;
  }

  @keyframes sqFcPulseOrange {
    0%, 100% { box-shadow: 0 0 0 3px rgba(234, 123, 36, 0.18); }
    50% { box-shadow: 0 0 0 5px rgba(234, 123, 36, 0.08); }
  }
  @keyframes sqFcPulseBlue {
    0%, 100% { box-shadow: 0 0 0 3px rgba(52, 103, 219, 0.18); }
    50% { box-shadow: 0 0 0 5px rgba(52, 103, 219, 0.08); }
  }
  @keyframes sqFcPulsePurple {
    0%, 100% { box-shadow: 0 0 0 3px rgba(122, 74, 224, 0.18); }
    50% { box-shadow: 0 0 0 5px rgba(122, 74, 224, 0.08); }
  }
  @keyframes sqFcPulseGold {
    0%, 100% { box-shadow: 0 0 0 3px rgba(212, 163, 0, 0.2); }
    50% { box-shadow: 0 0 0 5px rgba(212, 163, 0, 0.08); }
  }

  /* Promo row (discount applied line) */
  .sq-fc-promo-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 8px 10px;
    margin: 6px -4px 0;
    background: #fef4eb;
    border-radius: 8px;
    font-size: 0.6875rem;
  }

  .sq-fc-promo-label {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-weight: 600;
    color: #c2490b;
  }

  .sq-fc-promo-val {
    font-weight: 700;
    color: #c2490b;
    font-variant-numeric: tabular-nums;
  }

  /* Schedule variant */
  .sq-fc-sched-title {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-text-primary, #1a1a2e);
    margin-top: 4px;
    letter-spacing: -0.01em;
  }

  .sq-fc-sched-days {
    display: flex;
    gap: 5px;
    margin-top: 2px;
  }

  .sq-fc-day {
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #f1f1f5;
    font-size: 0.625rem;
    font-weight: 700;
    color: #8c8c8c;
  }

  .sq-fc-day--active {
    background: #3467db;
    color: #fff;
    box-shadow: 0 2px 6px rgba(52, 103, 219, 0.3);
  }

  .sq-fc-sched-branches {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 4px;
  }

  .sq-fc-sched-branch-label {
    font-size: 0.625rem;
    color: #8c8c8c;
    margin-right: 2px;
  }

  .sq-fc-branch-chip {
    padding: 2px 8px;
    background: #eef4ff;
    color: #2753b8;
    border-radius: 50px;
    font-size: 0.625rem;
    font-weight: 600;
  }

  .sq-fc-branch-chip--more {
    background: #f1f1f5;
    color: #4a4a4a;
  }

  .sq-fc-sched-timer {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 10px;
    background: #eef4ff;
    color: #2753b8;
    border-radius: 8px;
    font-size: 0.6875rem;
    font-weight: 600;
    margin-top: 2px;
    align-self: flex-start;
  }

  /* Code variant */
  .sq-fc-code-tile {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 10px;
    background: #faf7ff;
    border: 1px dashed #c8b6f0;
    border-radius: 10px;
  }

  .sq-fc-code-chip {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.9375rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: #5735c2;
  }

  .sq-fc-code-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 0.625rem;
    color: #6b6b75;
  }

  .sq-fc-code-stat {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .sq-fc-code-stat svg {
    color: #5735c2;
  }

  /* Loyalty variant */
  .sq-fc-customer {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 8px 10px;
    background: #fff4d0;
    border-left: 3px solid #b88900;
    border-radius: 6px;
    margin-top: 2px;
  }

  .sq-fc-cust-name {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-primary, #1a1a2e);
  }

  .sq-fc-cust-meta {
    font-size: 0.625rem;
    color: #6b4b00;
    font-weight: 600;
  }

  .sq-fc-loyalty-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    font-size: 0.6875rem;
    padding: 6px 0 2px;
  }

  .sq-fc-loyalty-label {
    font-weight: 600;
    color: var(--color-text-secondary, #4A4A4A);
  }

  .sq-fc-loyalty-pts {
    font-weight: 800;
    color: #6b4b00;
  }

  .sq-fc-loyalty-bar {
    width: 100%;
