    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    revealSections.forEach((section) => revealObserver.observe(section));
  } else {
    document.querySelectorAll('.reveal-section').forEach((s) => s.classList.add('visible'));
  }

  // ═══ Testimonial Carousel ═══
  const tSlides = document.querySelectorAll<HTMLElement>('[data-testimonial]');
  const tDots = document.querySelectorAll<HTMLButtonElement>('[data-dot]');
  const tPrev = document.getElementById('pf-prev');
  const tNext = document.getElementById('pf-next');
  let tCurrent = 0;
  let tTimer: ReturnType<typeof setInterval> | null = null;

  function resetTimer() {
    if (tTimer) clearInterval(tTimer);
    tTimer = setInterval(nextTestimonial, 6000);
  }

  const tSection = document.getElementById('pf-testimonials');

  function setTestimonial(idx: number) {
    tSlides.forEach((s) => s.classList.remove('active'));
    tDots.forEach((d) => d.classList.remove('active'));
    tSlides[idx]?.classList.add('active');
    tDots[idx]?.classList.add('active');
    const bg = tSlides[idx]?.dataset.bg;
    const accent = tSlides[idx]?.dataset.accent;
    if (tSection) {
      if (bg) tSection.style.setProperty('--tbg', bg);
      if (accent) tSection.style.setProperty('--taccent', accent);
    }
    tCurrent = idx;
  }

  function nextTestimonial() {
    setTestimonial((tCurrent + 1) % tSlides.length);
  }

  function prevTestimonial() {
    setTestimonial((tCurrent - 1 + tSlides.length) % tSlides.length);
  }

  if (tSlides.length > 1) {
    tTimer = setInterval(nextTestimonial, 6000);

    tPrev?.addEventListener('click', () => { prevTestimonial(); resetTimer(); });
    tNext?.addEventListener('click', () => { nextTestimonial(); resetTimer(); });

    tDots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const idx = parseInt(dot.dataset.dot || '0', 10);
        setTestimonial(idx);
        resetTimer();
      });
    });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        if (tTimer) clearInterval(tTimer);
      } else {
        resetTimer();
      }
    });
  }
</script>
