              <div class="pf-hero-video-frame pf-hero-video-frame--ipad">
                <span class="pf-ipad-cam" aria-hidden="true"></span>
                <div class="pf-ipad-screen">
                  <video
                    class="pf-hero-media-video"
                    autoplay
                    muted
                    loop
                    playsinline
                    preload="metadata"
                    poster={content.hero.videoPoster || content.hero.image}
                    width="1200"
                    height="1200"
                    aria-label={content.hero.imageAlt}
