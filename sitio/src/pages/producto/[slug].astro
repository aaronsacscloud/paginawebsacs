    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    cursor: default;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.28);
  }

  /* Device pills */
  .sq-featured-pill {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: #fff;
    border-radius: 50px;
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-primary, #1a1a2e);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12), 0 2px 6px rgba(0, 0, 0, 0.04);
    z-index: 3;
    white-space: nowrap;
  }

  .sq-featured-pill svg {
    color: #2563EB;
  }

  .sq-featured-pill--a {
    top: 8%;
    right: -10px;
    animation: sqPillFloat 5s ease-in-out infinite;
  }

  .sq-featured-pill--b {
    top: 40%;
    right: -18px;
    animation: sqPillFloat 5s ease-in-out infinite 1.2s;
  }

  .sq-featured-pill--c {
    top: 72%;
    right: -6px;
    animation: sqPillFloat 5s ease-in-out infinite 2.4s;
  }

  /* Flip pills to left side on pickup variant to avoid covering customer's phone/QR */
  .sq-featured--pickup .sq-featured-pill--a,
  .sq-featured--pickup .sq-featured-pill--b,
  .sq-featured--pickup .sq-featured-pill--c {
    right: auto;
  }

  .sq-featured--pickup .sq-featured-pill--a {
    top: 6%;
    left: -12px;
  }

  .sq-featured--pickup .sq-featured-pill--b {
    top: 38%;
    left: -20px;
  }

  .sq-featured--pickup .sq-featured-pill--c {
    top: 70%;
    left: -8px;
  }

  /* Pickup variant: card sits bottom-right instead of bottom-left */
  .sq-featured--pickup .sq-featured-card {
    left: auto;
    right: -24px;
  }

  /* Customer row (pickup) */
  .sq-fc-customer {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 4px 0 8px;
    border-bottom: 1px dashed rgba(0, 0, 0, 0.08);
