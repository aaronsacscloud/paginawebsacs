    position: absolute;
    inset: 1px 1px auto 1px;
    height: 40%;
    border-radius: 26px 26px 0 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0) 70%);
