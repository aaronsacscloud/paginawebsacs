  /* Hero media */
  .pf-hero-media {
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.45s both;
  }

  .pf-hero-media-wrap {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .pf-hero-media-wrap img,
  .pf-hero-media-wrap .pf-hero-media-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Square-style ambient hero: centered device with blurred warm backdrop */
  .pf-hero-media-wrap--has-video {
    display: grid;
    place-items: center;
    padding: clamp(24px, 5vw, 72px);
    background-color: #EFE4D4;
    isolation: isolate;
  }

  .pf-hero-media-wrap--has-video::before {
    content: '';
    position: absolute;
    inset: -8%;
    background-image: url('/images/pos-boutique-atencion.webp');
    background-size: cover;
    background-position: center;
    filter: blur(28px) saturate(0.9) brightness(1.02);
    transform: scale(1.08);
    z-index: -2;
  }

