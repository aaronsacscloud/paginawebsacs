  }

  /* Blue variant of pulsing dot (endless-aisle) */
  .sq-fc-dot--blue {
    background: #2563EB;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.18);
    animation: sqFcPulseBlue 2s ease-in-out infinite;
  }

  @keyframes sqFcPulseBlue {
    0%, 100% { box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.18); }
    50% { box-shadow: 0 0 0 5px rgba(37, 99, 235, 0.08); }
  }

  /* ═══ Endless aisle variant — stock list ═══ */
  .sq-featured--endless-aisle .sq-featured-card {
    left: auto;
    right: -24px;
  }

  .sq-featured--endless-aisle .sq-featured-pill--a,
  .sq-featured--endless-aisle .sq-featured-pill--b,
  .sq-featured--endless-aisle .sq-featured-pill--c {
    right: auto;
  }

  .sq-featured--endless-aisle .sq-featured-pill--a {
    top: 6%;
    left: -12px;
  }

  .sq-featured--endless-aisle .sq-featured-pill--b {
    top: 38%;
    left: -20px;
  }

  .sq-featured--endless-aisle .sq-featured-pill--c {
    top: 70%;
    left: -8px;
