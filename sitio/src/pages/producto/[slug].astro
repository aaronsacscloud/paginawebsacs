    font-weight: 800;
    color: var(--color-text-primary, #1a1a2e);
    letter-spacing: -0.02em;
  }

  .sq-fc-cobrar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    width: 100%;
    padding: 10px 14px;
