  .sq-fc-zone-fill,
  .sq-fc-bar-fill,
  .sq-fc-rec-fill {
    height: 100%;
    background: linear-gradient(90deg, #b28a36, #c2a053);
    border-radius: 50px;
  }
  .sq-fc-bar-fill { background: linear-gradient(90deg, #5a8a5f, #7aaa7f); }
  .sq-fc-rec-fill { background: linear-gradient(90deg, #2a8a5f, #3bb583); }
  .sq-fc-zone-meta,
  .sq-fc-bar-val {
    color: #6b6b75;
    font-weight: 600;
    white-space: nowrap;
  }

  /* count-variance-report */
  .sq-fc-var-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 4px;
  }
  .sq-fc-var-row {
    display: flex;
    justify-content: space-between;
    padding: 6px 8px;
    background: #f7e8e6;
    border-radius: 6px;
    font-size: 0.6875rem;
  }
  .sq-fc-var-sku {
    font-weight: 700;
    color: #1a1a2e;
  }
  .sq-fc-var-nums {
    color: #6b6b75;
    font-variant-numeric: tabular-nums;
  }
  .sq-fc-var-plus { color: #2a8a5f; font-weight: 800; }
  .sq-fc-var-minus { color: #c25a4a; font-weight: 800; }
  .sq-fc-var-zero { color: #6b6b75; font-weight: 800; }
  .sq-fc-total-val--neg { color: #8a3a2a; }

  /* oc-receive-scan */
  .sq-fc-rec-progress { margin-top: 4px; }
  .sq-fc-rec-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 8px;
  }
  .sq-fc-rec-row {
    display: flex;
    justify-content: space-between;
    padding: 6px 8px;
    background: #e7f2ec;
    border-radius: 6px;
    font-size: 0.6875rem;
  }
  .sq-fc-rec-row--warn { background: #fdeceb; }
  .sq-fc-rec-name { font-weight: 700; color: #1a1a2e; }
  .sq-fc-rec-status { color: #1f5c3c; font-weight: 700; font-variant-numeric: tabular-nums; }
  .sq-fc-rec-row--warn .sq-fc-rec-status { color: #a82419; }

  /* oc-reconcile-3way */
  .sq-fc-3way {
    margin-top: 4px;
    padding: 8px;
    background: #f7e8e6;
    border-radius: 8px;
  }
  .sq-fc-3way-head,
  .sq-fc-3way-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 6px;
    font-size: 0.625rem;
    padding: 4px 0;
  }
  .sq-fc-3way-head {
    color: #6b6b75;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .sq-fc-3way-row {
    color: #1a1a2e;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .sq-fc-3way-row--warn { background: rgba(194, 90, 74, 0.08); border-radius: 4px; padding: 6px; }
  .sq-fc-3way-warn { color: #8a3a2a; font-weight: 800; }

  /* expense-capture */
  .sq-fc-exp-top {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 10px;
    margin-top: 4px;
    padding: 8px;
    background: #f5f5f8;
    border-radius: 8px;
  }
  .sq-fc-exp-thumb {
    width: 48px;
    height: 60px;
    background: #fff;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #b28a36;
    border: 1px dashed #d9d4c5;
  }
  .sq-fc-exp-fields {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .sq-fc-exp-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.625rem;
  }
  .sq-fc-exp-label { color: #6b6b75; }
  .sq-fc-exp-amount {
    font-weight: 800;
    color: #1f5c3c;
    font-variant-numeric: tabular-nums;
  }

  /* expense-categories-tree */
  .sq-fc-tree {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 4px;
  }
  .sq-fc-tree-row {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 5px 8px;
    border-radius: 6px;
    font-size: 0.6875rem;
  }
  .sq-fc-tree-row--l1 {
    font-weight: 800;
    color: #7a5a1c;
    background: #f2ede2;
  }
  .sq-fc-tree-row--l2 {
    font-weight: 700;
    color: #7a5a1c;
    padding-left: 18px;
    background: #faf5e8;
  }
  .sq-fc-tree-row--l3 {
    justify-content: space-between;
    color: #1a1a2e;
    font-weight: 600;
    padding-left: 32px;
  }
  .sq-fc-tree-amt {
    font-weight: 800;
    color: #7a5a1c;
    font-variant-numeric: tabular-nums;
  }

  /* expense-filters-report */
  .sq-fc-pills-row {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 4px;
  }
  .sq-fc-pill-tag {
    padding: 3px 8px;
    background: #eef3ee;
    color: #3a6a48;
    border-radius: 50px;
    font-size: 0.625rem;
    font-weight: 700;
  }

  /* expense-approval-pin */
  .sq-fc-approval-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
    margin-top: 4px;
    padding: 8px 10px;
    background: #f7e8e6;
    border-radius: 8px;
  }
  .sq-fc-approval-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.625rem;
  }
  .sq-fc-approval-label { color: #6b6b75; }
  .sq-fc-approval-amt {
    font-weight: 800;
    color: #8a3a2a;
    font-variant-numeric: tabular-nums;
  }
  .sq-fc-pinpad {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 10px;
  }
  .sq-fc-pinpad-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #e6dad7;
  }
  .sq-fc-pinpad-dot--filled { background: #8a3a2a; }

  /* ap-payment-split */
  .sq-fc-split-head {
    margin-top: 4px;
    padding: 8px 10px;
    background: #e2f1f4;
    border-radius: 8px;
    font-size: 0.75rem;
    color: #0f4a58;
  }
  .sq-fc-split-head strong {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-weight: 800;
    color: #0a3742;
  }

  /* ap-due-calendar */
  .sq-fc-due-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
    margin-top: 4px;
  }
  .sq-fc-due-chip {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 8px 6px;
    background: #eceff3;
    border-radius: 8px;
    text-align: center;
  }
  .sq-fc-due-date {
    font-size: 0.625rem;
    color: #4d5a6b;
    font-weight: 700;
    text-transform: uppercase;
  }
  .sq-fc-due-amt {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-weight: 800;
    color: #1a1a2e;
    font-size: 0.8125rem;
  }
  .sq-fc-due-sup {
    font-size: 0.5625rem;
    color: #6b6b75;
  }
  .sq-fc-due-banner {
    margin-top: 8px;
    padding: 8px 10px;
    background: #fef1e7;
    border-radius: 8px;
    font-size: 0.6875rem;
    color: #7a3e0b;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .sq-fc-due-banner strong { font-weight: 800; color: #a52d0b; }

  /* report-filter-cross */
  .sq-fc-cross-filters {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 4px;
  }
  .sq-fc-cross-pill {
    padding: 5px 10px;
    background: #eaeef7;
    color: #2a4a9a;
    border-radius: 6px;
    font-size: 0.6875rem;
    font-weight: 700;
    text-align: left;
  }
  .sq-fc-cross-result {
    margin-top: 8px;
    padding: 10px 12px;
    background: linear-gradient(135deg, rgba(42, 181, 160, 0.08), rgba(37, 99, 235, 0.06));
    border-radius: 10px;
  }
  .sq-fc-cross-kpi {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sq-fc-cross-big {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 1.375rem;
    font-weight: 800;
    color: #1a1a2e;
    line-height: 1;
  }
  .sq-fc-cross-meta {
    font-size: 0.625rem;
    color: #6b6b75;
    font-weight: 600;
  }

  /* report-modules-grid */
  .sq-fc-mods {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
    margin-top: 4px;
  }
  .sq-fc-mod {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 8px 6px;
    background: #eaeef7;
    border-radius: 8px;
  }
  .sq-fc-mod-name {
    font-size: 0.625rem;
    font-weight: 700;
    color: #2a4a9a;
  }
  .sq-fc-mod-spark {
    width: 100%;
    height: 12px;
  }

  /* report-export-preview */
  .sq-fc-export-card {
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 10px;
    margin-top: 4px;
    padding: 10px;
    background: #e7f2ec;
    border-radius: 10px;
  }
  .sq-fc-export-icon {
    width: 44px;
    height: 44px;
    background: #fff;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1f5c3c;
  }
  .sq-fc-export-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sq-fc-export-file {
    font-size: 0.75rem;
    font-weight: 800;
    color: #1f5c3c;
    font-family: ui-monospace, SF Mono, Menlo, monospace;
  }
  .sq-fc-export-line {
    font-size: 0.5625rem;
    color: #4a6a5a;
  }

  /* ═══ Fideliza variants ═══ */

  /* Badge color schemes */
  .sq-fc-badge--segment { background: #ede8f7; color: #4a3a8a; }
  .sq-fc-badge--segment .sq-fc-dot { background: #7558c2; box-shadow: 0 0 0 3px rgba(117, 88, 194, 0.22); animation-name: sqFcPulsePurple; }
  .sq-fc-badge--gold { background: #faf0d8; color: #7a5a1c; }
  .sq-fc-badge--gold .sq-fc-dot { background: #c89b3f; box-shadow: 0 0 0 3px rgba(200, 155, 63, 0.22); animation-name: sqFcPulseAmber; }
  .sq-fc-badge--email { background: #e8ecf8; color: #2e3f85; }
  .sq-fc-badge--email .sq-fc-dot { background: #4a5ab8; box-shadow: 0 0 0 3px rgba(74, 90, 184, 0.22); animation-name: sqFcPulseSteelblue; }
  .sq-fc-badge--coral { background: #fde9e4; color: #9a3a2a; }
  .sq-fc-badge--coral .sq-fc-dot { background: #d56450; box-shadow: 0 0 0 3px rgba(213, 100, 80, 0.22); animation-name: sqFcPulseCoral; }
  .sq-fc-badge--sea { background: #dff1ec; color: #155a4a; }
  .sq-fc-badge--sea .sq-fc-dot { background: #2a8a72; box-shadow: 0 0 0 3px rgba(42, 138, 114, 0.22); animation-name: sqFcPulseSea; }
  .sq-fc-badge--rose { background: #fbe4ea; color: #8a2e4a; }
  .sq-fc-badge--rose .sq-fc-dot { background: #c24a73; box-shadow: 0 0 0 3px rgba(194, 74, 115, 0.22); animation-name: sqFcPulseRose; }
  .sq-fc-badge--deep { background: #e4e6f5; color: #2a2a6b; }
  .sq-fc-badge--deep .sq-fc-dot { background: #4040a0; box-shadow: 0 0 0 3px rgba(64, 64, 160, 0.22); animation-name: sqFcPulseDeep; }
  .sq-fc-badge--silver { background: #edeff3; color: #3a4656; }
  .sq-fc-badge--silver .sq-fc-dot { background: #6a7787; box-shadow: 0 0 0 3px rgba(106, 119, 135, 0.22); animation-name: sqFcPulseSlate; }
  .sq-fc-badge--violet { background: #ebe6f7; color: #3f2a7d; }
  .sq-fc-badge--violet .sq-fc-dot { background: #7048c0; box-shadow: 0 0 0 3px rgba(112, 72, 192, 0.22); animation-name: sqFcPulsePurple; }

  /* WA palette reuses existing .sq-fc-badge--wa (green) */

  /* Badge padding (join existing list) */
  .sq-fc-badge--segment,
  .sq-fc-badge--gold,
  .sq-fc-badge--email,
  .sq-fc-badge--coral,
  .sq-fc-badge--sea,
  .sq-fc-badge--rose,
  .sq-fc-badge--deep,
  .sq-fc-badge--silver,
  .sq-fc-badge--violet {
    padding: 4px 10px;
    border-radius: 50px;
  }

  @keyframes sqFcPulsePurple {
    0%, 100% { box-shadow: 0 0 0 3px rgba(117, 88, 194, 0.22); }
    50% { box-shadow: 0 0 0 5px rgba(117, 88, 194, 0.08); }
  }
  @keyframes sqFcPulseCoral {
    0%, 100% { box-shadow: 0 0 0 3px rgba(213, 100, 80, 0.22); }
    50% { box-shadow: 0 0 0 5px rgba(213, 100, 80, 0.08); }
  }
  @keyframes sqFcPulseSea {
    0%, 100% { box-shadow: 0 0 0 3px rgba(42, 138, 114, 0.22); }
    50% { box-shadow: 0 0 0 5px rgba(42, 138, 114, 0.08); }
  }
  @keyframes sqFcPulseRose {
    0%, 100% { box-shadow: 0 0 0 3px rgba(194, 74, 115, 0.22); }
    50% { box-shadow: 0 0 0 5px rgba(194, 74, 115, 0.08); }
  }
  @keyframes sqFcPulseDeep {
    0%, 100% { box-shadow: 0 0 0 3px rgba(64, 64, 160, 0.22); }
    50% { box-shadow: 0 0 0 5px rgba(64, 64, 160, 0.08); }
  }

  /* ── crm-segment-builder ── */
  .sq-fc-chip-stack {
    display: flex;
    flex-direction: column;
    gap: 5px;
    margin-top: 4px;
  }
  .sq-fc-chip-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .sq-fc-chip-op {
    font-size: 0.5625rem;
    font-weight: 700;
    color: #7558c2;
    background: #ede8f7;
    padding: 2px 6px;
    border-radius: 4px;
    letter-spacing: 0.06em;
  }
  .sq-fc-chip {
    flex: 1;
    font-size: 0.6875rem;
    color: #1a1a2e;
    background: #f5f3fa;
    padding: 5px 9px;
    border-radius: 6px;
    border: 1px dashed rgba(117, 88, 194, 0.35);
  }
  .sq-fc-segment-count {
    margin-top: 8px;
    padding: 8px 10px;
    background: #f3eefa;
    border-radius: 8px;
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .sq-fc-segment-num {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 1.125rem;
    font-weight: 800;
    color: #4a3a8a;
    line-height: 1;
  }
  .sq-fc-segment-desc {
    font-size: 0.6875rem;
    color: #6a5a8a;
  }
  .sq-fc-cobrar--segment {
    background: #7558c2;
    box-shadow: 0 4px 12px rgba(117, 88, 194, 0.32);
    margin-top: 10px;
  }

  /* ── loyalty-tiers ── */
  .sq-fc-tier-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    margin-top: 4px;
  }
  .sq-fc-tier {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 8px 4px;
    background: #f7f5f0;
    border-radius: 8px;
    border: 1px solid rgba(0, 0, 0, 0.04);
  }
  .sq-fc-tier--active {
    background: #faf0d8;
    border-color: #c89b3f;
    box-shadow: 0 2px 8px rgba(200, 155, 63, 0.22);
  }
  .sq-fc-tier-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .sq-fc-tier-name {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.625rem;
    font-weight: 700;
    color: #1a1a2e;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .sq-fc-tier-meta {
    font-size: 0.5625rem;
    color: #6b6b75;
  }
  .sq-fc-tier-progress {
    margin-top: 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .sq-fc-tier-bar {
    height: 6px;
    background: #efe6cf;
    border-radius: 3px;
    overflow: hidden;
  }
  .sq-fc-tier-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #c89b3f, #e8c475);
    border-radius: 3px;
  }
  .sq-fc-tier-progress-label {
    font-size: 0.625rem;
    color: #7a5a1c;
    font-weight: 600;
  }
  .sq-fc-tier-benefits {
    display: flex;
    gap: 5px;
    margin-top: 6px;
    flex-wrap: wrap;
  }
  .sq-fc-tier-ben {
    font-size: 0.5625rem;
    color: #7a5a1c;
    background: #faf0d8;
    padding: 3px 7px;
    border-radius: 50px;
    font-weight: 600;
  }

  /* ── crm-profile-360 ── */
  .sq-fc-profile-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 4px;
  }
  .sq-fc-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #c89b3f, #7a5a1c);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }
  .sq-fc-profile-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }
  .sq-fc-profile-name {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.8125rem;
    font-weight: 800;
    color: #1a1a2e;
  }
  .sq-fc-profile-sub {
    font-size: 0.6875rem;
    color: #6b6b75;
  }
  .sq-fc-profile-sub strong { color: #7a5a1c; }
  .sq-fc-tag-row {
    display: flex;
    gap: 5px;
    margin-top: 7px;
    flex-wrap: wrap;
  }
  .sq-fc-tag {
    font-size: 0.5625rem;
    color: #7a5a1c;
    background: #faf0d8;
    padding: 3px 7px;
    border-radius: 50px;
    font-weight: 600;
  }
  .sq-fc-tx-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 8px;
  }
  .sq-fc-tx-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.6875rem;
    padding: 5px 8px;
    background: #f7f5f0;
    border-radius: 6px;
  }
  .sq-fc-tx-item { color: #1a1a2e; }
  .sq-fc-tx-amt {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-weight: 700;
    color: #7a5a1c;
  }
  .sq-fc-seller-note {
    margin-top: 8px;
    padding: 6px 9px;
    background: #fef8e6;
    border-left: 2px solid #c89b3f;
    border-radius: 4px;
    font-size: 0.625rem;
    color: #7a5a1c;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  /* ── email-template-preview ── */
  .sq-fc-email-frame {
    margin-top: 6px;
    background: #fff;
    border: 1px solid #e4e7ec;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }
  .sq-fc-email-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 7px 10px;
    border-bottom: 1px solid #f0f2f5;
  }
  .sq-fc-email-sender {
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .sq-fc-email-logo {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: linear-gradient(135deg, #b47a3a, #7a5a1c);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.5625rem;
    font-weight: 800;
  }
  .sq-fc-email-sender-meta {
    display: flex;
    flex-direction: column;
  }
  .sq-fc-email-from {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #1a1a2e;
  }
  .sq-fc-email-to {
    font-size: 0.5625rem;
    color: #8c8c8c;
  }
  .sq-fc-email-time {
    font-size: 0.5625rem;
    color: #8c8c8c;
  }
  .sq-fc-email-subject {
    padding: 8px 10px 4px;
    font-family: var(--font-display, 'Sora', sans-serif);
