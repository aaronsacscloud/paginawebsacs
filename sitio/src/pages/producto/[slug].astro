  .pf-hero-media {
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.45s both;
  }

  .pf-hero-media-wrap {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .pf-hero-media-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

