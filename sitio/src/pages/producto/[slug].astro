  /* count-scan-live */
  .sq-fc-scan-frame {
    position: relative;
    aspect-ratio: 4 / 3;
    margin-top: 4px;
    background: #101016;
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sq-fc-scan-viewport {
    position: absolute;
    inset: 12px;
    border: 1px dashed rgba(255, 255, 255, 0.2);
    border-radius: 6px;
  }
  .sq-fc-scan-corner {
    position: absolute;
    width: 12px;
    height: 12px;
    border: 2px solid #2AB5A0;
  }
  .sq-fc-scan-corner--tl { top: -1px; left: -1px; border-right: none; border-bottom: none; }
  .sq-fc-scan-corner--tr { top: -1px; right: -1px; border-left: none; border-bottom: none; }
  .sq-fc-scan-corner--bl { bottom: -1px; left: -1px; border-right: none; border-top: none; }
  .sq-fc-scan-corner--br { bottom: -1px; right: -1px; border-left: none; border-top: none; }
  .sq-fc-scan-laser {
    position: absolute;
    left: 8%;
    right: 8%;
    top: 50%;
    height: 2px;
    background: linear-gradient(90deg, transparent, #2AB5A0, transparent);
    box-shadow: 0 0 12px rgba(42, 181, 160, 0.6);
  }
  .sq-fc-scan-count {
