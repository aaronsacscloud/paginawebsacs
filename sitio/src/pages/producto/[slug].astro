    color: var(--color-text-primary, #1a1a2e);
    line-height: 1.2;
  }

  .sq-fc-qty {
    font-size: 0.625rem;
    color: var(--color-text-tertiary, #8c8c8c);
    line-height: 1.2;
  }

  .sq-fc-price {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-primary, #1a1a2e);
    flex-shrink: 0;
  }

  .sq-fc-total {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 0 12px;
    margin-top: 6px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
