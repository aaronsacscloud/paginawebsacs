    50% { box-shadow: 0 0 0 5px rgba(234, 123, 36, 0.08); }
  }
  @keyframes sqFcPulseBlue {
    0%, 100% { box-shadow: 0 0 0 3px rgba(52, 103, 219, 0.18); }
    50% { box-shadow: 0 0 0 5px rgba(52, 103, 219, 0.08); }
