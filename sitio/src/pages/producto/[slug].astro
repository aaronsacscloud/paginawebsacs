  .sq-fc-badge--teal .sq-fc-dot,
  .sq-fc-badge--split .sq-fc-dot { background: #1c6b7d; box-shadow: 0 0 0 3px rgba(28, 107, 125, 0.22); animation-name: sqFcPulseTeal; }

  .sq-fc-badge--slate,
  .sq-fc-badge--due { background: #eceff3; color: #33404f; }
  .sq-fc-badge--slate .sq-fc-dot,
  .sq-fc-badge--due .sq-fc-dot { background: #4d5a6b; box-shadow: 0 0 0 3px rgba(77, 90, 107, 0.2); animation-name: sqFcPulseSlate; }

  .sq-fc-badge--indigo,
  .sq-fc-badge--states,
  .sq-fc-badge--cross,
  .sq-fc-badge--modules { background: #eaeef7; color: #2a4a9a; }
  .sq-fc-badge--indigo .sq-fc-dot,
  .sq-fc-badge--states .sq-fc-dot,
  .sq-fc-badge--cross .sq-fc-dot,
  .sq-fc-badge--modules .sq-fc-dot { background: #4a6ab8; box-shadow: 0 0 0 3px rgba(74, 106, 184, 0.2); animation-name: sqFcPulseSteelblue; }

  .sq-fc-badge--scan,
  .sq-fc-badge--receive { background: #e7f2ec; color: #1f5c3c; }
  .sq-fc-badge--scan .sq-fc-dot,
  .sq-fc-badge--receive .sq-fc-dot { background: #2a8a5f; box-shadow: 0 0 0 3px rgba(42, 138, 95, 0.22); animation-name: sqFcPulseEmerald; }

  .sq-fc-badge--zones,
  .sq-fc-badge--tree,
  .sq-fc-badge--expense { background: #f2ede2; color: #7a5a1c; }
  .sq-fc-badge--zones .sq-fc-dot,
  .sq-fc-badge--tree .sq-fc-dot,
  .sq-fc-badge--expense .sq-fc-dot { background: #b28a36; box-shadow: 0 0 0 3px rgba(178, 138, 54, 0.2); animation-name: sqFcPulseBronze; }

  .sq-fc-badge--variance,
  .sq-fc-badge--reconcile,
  .sq-fc-badge--approval { background: #f7e8e6; color: #8a3a2a; }
  .sq-fc-badge--variance .sq-fc-dot,
  .sq-fc-badge--reconcile .sq-fc-dot,
  .sq-fc-badge--approval .sq-fc-dot { background: #c25a4a; box-shadow: 0 0 0 3px rgba(194, 90, 74, 0.22); animation-name: sqFcPulseBrick; }

  .sq-fc-badge--filter { background: #eef3ee; color: #3a6a48; }
  .sq-fc-badge--filter .sq-fc-dot { background: #5a8a5f; box-shadow: 0 0 0 3px rgba(90, 138, 95, 0.2); animation-name: sqFcPulseEmerald; }

  .sq-fc-badge--export { background: #e7f2ec; color: #1f5c3c; }
