---
import ProductLayout from '../../layouts/ProductLayout.astro';
import GiroHero from '../../components/giros/GiroHero.astro';
import ZoomTypo from '../../components/ZoomTypo.astro';
import ProductFeatureShowcase from '../../components/ProductFeatureShowcase.astro';
import GiroFeatures from '../../components/giros/GiroFeatures.astro';
import GiroSplitSection from '../../components/giros/GiroSplitSection.astro';
import GiroStats from '../../components/giros/GiroStats.astro';
import GiroTestimonial from '../../components/giros/GiroTestimonial.astro';
import GiroFAQ from '../../components/giros/GiroFAQ.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import { pillars, getFeatureBySlug, getPillarForFeature, getAllSlugs } from '../../data/product';
import { plans } from '../../data/plans';
import { pageContent } from '../../data/product-pages';

export function getStaticPaths() {
  return getAllSlugs().map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const feature = getFeatureBySlug(slug!)!;
const pillar = getPillarForFeature(slug!)!;


const content = pageContent[slug!];
const isLive = feature.status === 'live' && content;
---

<ProductLayout
  title={feature.title}
  description={feature.description}
  currentSlug={slug!}
  currentPillar={pillar.id}
  noindex={feature.status === 'coming-soon'}
  preloadImage={content?.hero?.image}
>
  {isLive && (
    <Fragment>
      <section class="pf-hero-centered">
        <div class="pf-hero-centered-inner container">
          <span class="pf-hero-eyebrow">{content.hero.eyebrow}</span>
          <h1 class="pf-hero-title">{content.hero.title}</h1>
          <div class="pf-hero-ctas">
            <a href="/prueba-gratis" class="pf-hero-btn pf-hero-btn--outline">Prueba gratis</a>
            <a href="/contacto" class="pf-hero-btn pf-hero-btn--solid">Agenda una demo</a>
          </div>
        </div>
        <div class="pf-hero-media container">
          <div class="pf-hero-media-wrap">
            <img src={content.hero.image} alt={content.hero.imageAlt} width="1200" height="675" loading="eager" fetchpriority="high" />
            <div class="pf-hero-media-overlay">
              <p class="pf-hero-media-text">{content.hero.subtitle}</p>
            </div>
          </div>
        </div>
      </section>

      <div class="sq-showcase-wrap">
      <section class="sq-showcase reveal-section">
        <div class="sq-showcase-inner container">
          <h2 class="sq-showcase-heading reveal-item">{content.showcaseTitle}</h2>
        </div>

        {content.blocks.map((block: any, i: number) => (
          <div class={`sq-block reveal-section${i % 2 === 0 ? '' : ' sq-block--flip'}${block.featured ? ' sq-block--featured' : ''}`}>
            <div class="sq-block-inner container">
              <div class="sq-block-text reveal-item" style="--reveal-delay: 0ms">
                <h3 class="sq-block-title">{block.title}</h3>
                <p class="sq-block-desc">{block.description}</p>
                {block.link && (
                  <a href={block.link.href} class="sq-block-link">
                    {block.link.label}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M7 7h10v10"/></svg>
                  </a>
                )}
              </div>
              <div class="sq-block-media reveal-item" style="--reveal-delay: 150ms">
                {block.featured ? (
                  <div class={`sq-featured sq-featured--${block.variant || 'checkout'}`}>
                    <img src={block.image} alt={block.imageAlt} width="1024" height="1024" loading="lazy" />

                    {(!block.variant || block.variant === 'checkout') && (
                      <div class="sq-featured-card" aria-hidden="true">
                        <div class="sq-fc-header">
                          <span class="sq-fc-badge">
                            <span class="sq-fc-dot"></span>
                            Caja Chapalita
                          </span>
                          <span class="sq-fc-time">POS · iPad</span>
                        </div>
                        <div class="sq-fc-line">
                          <div class="sq-fc-line-main">
                            <span class="sq-fc-prod">Playera Blanca · M</span>
                            <span class="sq-fc-qty">1 × $450.00</span>
                          </div>
                          <span class="sq-fc-price">$450.00</span>
                        </div>
                        <div class="sq-fc-line">
                          <div class="sq-fc-line-main">
                            <span class="sq-fc-prod">Jeans Wide Leg</span>
                            <span class="sq-fc-qty">1 × $890.00</span>
                          </div>
                          <span class="sq-fc-price">$890.00</span>
                        </div>
                        <div class="sq-fc-total">
                          <span>Total</span>
                          <span class="sq-fc-total-val">$1,340.00</span>
                        </div>
                        <button class="sq-fc-cobrar" tabindex="-1">
                          COBRAR
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </button>
                      </div>
                    )}

                    {block.variant === 'pickup' && (
                      <div class="sq-featured-card" aria-hidden="true">
                        <div class="sq-fc-header">
                          <span class="sq-fc-badge">
                            <span class="sq-fc-dot"></span>
                            Listo para pickup
                          </span>
                          <span class="sq-fc-time">#4291</span>
                        </div>
                        <div class="sq-fc-customer">
                          <span class="sq-fc-cust-name">María Fernández</span>
                          <span class="sq-fc-cust-meta">Sucursal Chapalita · Tienda en línea</span>
                        </div>
                        <div class="sq-fc-line">
                          <div class="sq-fc-line-main">
                            <span class="sq-fc-prod">Vestido Verano · S</span>
                            <span class="sq-fc-qty">1 × $1,290.00</span>
                          </div>
                          <span class="sq-fc-price">$1,290.00</span>
                        </div>
                        <div class="sq-fc-line">
                          <div class="sq-fc-line-main">
                            <span class="sq-fc-prod">Sandalia Kira · 24</span>
                            <span class="sq-fc-qty">1 × $890.00</span>
                          </div>
                          <span class="sq-fc-price">$890.00</span>
                        </div>
                        <div class="sq-fc-qrrow">
                          <div class="sq-fc-qr" aria-hidden="true">
                            <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor"><path d="M3 3h7v7H3V3zm2 2v3h3V5H5zm9-2h7v7h-7V3zm2 2v3h3V5h-3zM3 14h7v7H3v-7zm2 2v3h3v-3H5zm11-2h2v2h-2v-2zm2 2h2v2h-2v-2zm-4 0h2v2h-2v-2zm4 2h2v2h-2v-2zm-2 2h2v2h-2v-2zm-2-2h2v2h-2v-2zm4-6h2v2h-2v-2z"/></svg>
                          </div>
                          <div class="sq-fc-qr-text">
                            <span class="sq-fc-qr-title">Escanea el QR del cliente</span>
                            <span class="sq-fc-qr-meta">Entrega verificada · sin copiar datos</span>
                          </div>
                        </div>
                        <button class="sq-fc-cobrar sq-fc-cobrar--pickup" tabindex="-1">
                          ENTREGAR PEDIDO
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                        </button>
                      </div>
                    )}

                    {block.variant === 'endless-aisle' && (
                      <div class="sq-featured-card" aria-hidden="true">
                        <div class="sq-fc-header">
                          <span class="sq-fc-badge">
                            <span class="sq-fc-dot sq-fc-dot--blue"></span>
                            Disponibilidad global
                          </span>
                          <span class="sq-fc-time">SKU #INX-RG18</span>
                        </div>
                        <div class="sq-fc-customer">
                          <span class="sq-fc-cust-name">Inox Rose Gold · 18 oz</span>
                          <span class="sq-fc-cust-meta">Consultado desde Sucursal Chapalita</span>
                        </div>
                        <div class="sq-fc-stock">
                          <div class="sq-fc-stock-row">
                            <div class="sq-fc-stock-left">
                              <span class="sq-fc-stock-check sq-fc-stock-check--ok">✓</span>
                              <span class="sq-fc-stock-name">Polanco</span>
                            </div>
                            <span class="sq-fc-stock-qty">2 en stock</span>
                          </div>
                          <div class="sq-fc-stock-row">
                            <div class="sq-fc-stock-left">
                              <span class="sq-fc-stock-check sq-fc-stock-check--ok">✓</span>
                              <span class="sq-fc-stock-name">Santa Fe</span>
                            </div>
                            <span class="sq-fc-stock-qty">4 en stock</span>
                          </div>
                          <div class="sq-fc-stock-row sq-fc-stock-row--out">
                            <div class="sq-fc-stock-left">
                              <span class="sq-fc-stock-check sq-fc-stock-check--out">–</span>
                              <span class="sq-fc-stock-name">Chapalita</span>
                            </div>
                            <span class="sq-fc-stock-qty">Agotado</span>
                          </div>
                        </div>
                        <button class="sq-fc-cobrar sq-fc-cobrar--aisle" tabindex="-1">
                          APARTAR Y TRASPASAR
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </button>
                      </div>
                    )}

                    {block.variant === 'control-central' && (
                      <div class="sq-featured-card" aria-hidden="true">
                        <div class="sq-fc-header">
                          <span class="sq-fc-badge">
                            <span class="sq-fc-dot"></span>
                            En vivo · Dashboard
                          </span>
                          <span class="sq-fc-time">12 sucursales</span>
                        </div>
                        <div class="sq-fc-metric">
                          <span class="sq-fc-metric-label">Ventas hoy</span>
                          <div class="sq-fc-metric-row">
                            <span class="sq-fc-metric-val">$184,320</span>
                            <span class="sq-fc-metric-delta">↑ 12% vs ayer</span>
                          </div>
                          <svg class="sq-fc-metric-spark" viewBox="0 0 120 28" preserveAspectRatio="none" aria-hidden="true">
                            <path d="M0 22 L12 18 L24 20 L36 14 L48 16 L60 10 L72 12 L84 6 L96 8 L108 4 L120 2" fill="none" stroke="#2AB5A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        </div>
                        <div class="sq-fc-ranking">
                          <span class="sq-fc-ranking-title">Top sucursales</span>
                          <div class="sq-fc-rank-row">
                            <span class="sq-fc-rank-pos">1</span>
                            <span class="sq-fc-rank-name">Polanco</span>
                            <span class="sq-fc-rank-val">$42,180</span>
                          </div>
                          <div class="sq-fc-rank-row">
                            <span class="sq-fc-rank-pos">2</span>
                            <span class="sq-fc-rank-name">Santa Fe</span>
                            <span class="sq-fc-rank-val">$38,910</span>
                          </div>
                          <div class="sq-fc-rank-row">
                            <span class="sq-fc-rank-pos">3</span>
                            <span class="sq-fc-rank-name">Chapalita</span>
                            <span class="sq-fc-rank-val">$31,240</span>
                          </div>
                        </div>
                        <button class="sq-fc-cobrar sq-fc-cobrar--dash" tabindex="-1">
                          VER DASHBOARD
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </button>
                      </div>
                    )}

                    {block.variant === 'promo-auto' && (
                      <div class="sq-featured-card" aria-hidden="true">
                        <div class="sq-fc-header">
                          <span class="sq-fc-badge sq-fc-badge--promo">
                            <span class="sq-fc-dot"></span>
                            Promo detectada
                          </span>
                          <span class="sq-fc-time">POS · Auto</span>
                        </div>
                        <div class="sq-fc-line">
                          <div class="sq-fc-line-main">
                            <span class="sq-fc-prod">Blusa Lino · M</span>
                            <span class="sq-fc-qty">1 × $790.00</span>
                          </div>
                          <span class="sq-fc-price">$790.00</span>
                        </div>
                        <div class="sq-fc-line">
                          <div class="sq-fc-line-main">
                            <span class="sq-fc-prod">Falda Plisada · 28</span>
                            <span class="sq-fc-qty">1 × $690.00</span>
                          </div>
                          <span class="sq-fc-price">$690.00</span>
                        </div>
                        <div class="sq-fc-promo-row">
                          <span class="sq-fc-promo-label">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                            Promo Verano · 15% off
                          </span>
                          <span class="sq-fc-promo-val">−$222.00</span>
                        </div>
                        <div class="sq-fc-total">
                          <span>Total</span>
                          <span class="sq-fc-total-val">$1,258.00</span>
                        </div>
                        <button class="sq-fc-cobrar" tabindex="-1">
                          COBRAR
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </button>
                      </div>
                    )}

                    {block.variant === 'promo-schedule' && (
                      <div class="sq-featured-card" aria-hidden="true">
                        <div class="sq-fc-header">
                          <span class="sq-fc-badge sq-fc-badge--schedule">
                            <span class="sq-fc-dot"></span>
                            Happy hour · Activa
                          </span>
                          <span class="sq-fc-time">Martes</span>
                        </div>
                        <div class="sq-fc-sched-title">2x1 en bebidas · 15:00 – 18:00</div>
                        <div class="sq-fc-sched-days">
                          <span class="sq-fc-day">L</span>
                          <span class="sq-fc-day sq-fc-day--active">M</span>
                          <span class="sq-fc-day">M</span>
                          <span class="sq-fc-day">J</span>
                          <span class="sq-fc-day">V</span>
                          <span class="sq-fc-day">S</span>
                          <span class="sq-fc-day">D</span>
                        </div>
                        <div class="sq-fc-sched-branches">
                          <span class="sq-fc-sched-branch-label">Sucursales:</span>
                          <span class="sq-fc-branch-chip">Norte</span>
                          <span class="sq-fc-branch-chip">Polanco</span>
                          <span class="sq-fc-branch-chip sq-fc-branch-chip--more">+3</span>
                        </div>
                        <div class="sq-fc-sched-timer">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                          Termina en 1h 42m
                        </div>
                      </div>
                    )}

                    {block.variant === 'promo-code' && (
                      <div class="sq-featured-card" aria-hidden="true">
                        <div class="sq-fc-header">
                          <span class="sq-fc-badge sq-fc-badge--code">
                            <span class="sq-fc-dot"></span>
                            Código aplicado
                          </span>
                          <span class="sq-fc-time">#7812</span>
                        </div>
                        <div class="sq-fc-code-tile">
                          <div class="sq-fc-code-chip">BIENVENIDA20</div>
                          <div class="sq-fc-code-meta">
                            <span class="sq-fc-code-stat">
                              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                              Uso único por cliente
                            </span>
                            <span class="sq-fc-code-stat">Vigente hasta 31 mar</span>
                          </div>
                        </div>
                        <div class="sq-fc-line">
                          <div class="sq-fc-line-main">
                            <span class="sq-fc-prod">Subtotal</span>
                          </div>
                          <span class="sq-fc-price">$1,450.00</span>
                        </div>
                        <div class="sq-fc-promo-row">
                          <span class="sq-fc-promo-label">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12V8a2 2 0 00-2-2H6a2 2 0 00-2 2v4a2 2 0 012 2 2 2 0 00-2 2v4a2 2 0 002 2h12a2 2 0 002-2v-4a2 2 0 01-2-2 2 2 0 002-2z"/></svg>
                            Descuento BIENVENIDA20
                          </span>
                          <span class="sq-fc-promo-val">−$290.00</span>
                        </div>
                        <div class="sq-fc-total">
                          <span>Total</span>
                          <span class="sq-fc-total-val">$1,160.00</span>
                        </div>
                      </div>
                    )}

                    {block.variant === 'promo-loyalty' && (
                      <div class="sq-featured-card" aria-hidden="true">
                        <div class="sq-fc-header">
                          <span class="sq-fc-badge sq-fc-badge--loyalty">
                            <span class="sq-fc-dot"></span>
                            Lealtad · Cliente VIP
                          </span>
                          <span class="sq-fc-time">+300 pts</span>
                        </div>
                        <div class="sq-fc-customer">
                          <span class="sq-fc-cust-name">Lucía Herrera</span>
                          <span class="sq-fc-cust-meta">4,820 pts · equivale a $482</span>
                        </div>
                        <div class="sq-fc-loyalty-row">
                          <span class="sq-fc-loyalty-label">Promo: Gasta $500, gana 300 pts</span>
                          <span class="sq-fc-loyalty-pts">+300 pts</span>
                        </div>
                        <div class="sq-fc-loyalty-bar" aria-hidden="true">
                          <div class="sq-fc-loyalty-bar-fill" style="width:72%"></div>
                        </div>
                        <div class="sq-fc-loyalty-meta">
                          <span>Próxima recompensa en 1,180 pts</span>
                        </div>
                        <div class="sq-fc-total">
                          <span>Total</span>
                          <span class="sq-fc-total-val">$1,240.00</span>
                        </div>
                      </div>
                    )}

                    {block.variant === 'apartado-reserva' && (
                      <div class="sq-featured-card" aria-hidden="true">
                        <div class="sq-fc-header">
                          <span class="sq-fc-badge sq-fc-badge--reserva">
                            <span class="sq-fc-dot"></span>
                            Apartado confirmado
                          </span>
                          <span class="sq-fc-time">#3812</span>
                        </div>
                        <div class="sq-fc-customer sq-fc-customer--reserva">
                          <span class="sq-fc-cust-name">Valentina Nogueira</span>
                          <span class="sq-fc-cust-meta">Vence en 15 días · 4 may</span>
                        </div>
                        <div class="sq-fc-line">
                          <div class="sq-fc-line-main">
                            <span class="sq-fc-prod">Vestido Zafiro · S</span>
                            <span class="sq-fc-qty">1 × $2,460.00</span>
                          </div>
                          <span class="sq-fc-price">$2,460.00</span>
                        </div>
                        <div class="sq-fc-reserva-row">
                          <span class="sq-fc-reserva-label">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                            Anticipo recibido · 25%
                          </span>
                          <span class="sq-fc-reserva-val">$615.00</span>
                        </div>
                        <div class="sq-fc-total">
                          <span>Saldo pendiente</span>
                          <span class="sq-fc-total-val sq-fc-total-val--reserva">$1,845.00</span>
                        </div>
                        <button class="sq-fc-cobrar sq-fc-cobrar--reserva" tabindex="-1">
                          IMPRIMIR APARTADO
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </button>
                      </div>
                    )}

                    {block.variant === 'apartado-payment' && (
                      <div class="sq-featured-card" aria-hidden="true">
                        <div class="sq-fc-header">
                          <span class="sq-fc-badge sq-fc-badge--payment">
                            <span class="sq-fc-dot"></span>
                            Abono #3 de 4
                          </span>
                          <span class="sq-fc-time">#3812</span>
                        </div>
                        <div class="sq-fc-customer sq-fc-customer--payment">
                          <span class="sq-fc-cust-name">Valentina Nogueira</span>
                          <span class="sq-fc-cust-meta">Saldo $615 · Vence en 5 días</span>
                        </div>
                        <div class="sq-fc-payment-list">
                          <div class="sq-fc-payment-row">
                            <span class="sq-fc-payment-date">21 abr</span>
                            <span class="sq-fc-payment-method">Tarjeta</span>
                            <span class="sq-fc-payment-val">$615</span>
                          </div>
                          <div class="sq-fc-payment-row">
                            <span class="sq-fc-payment-date">27 abr</span>
                            <span class="sq-fc-payment-method">Efectivo</span>
                            <span class="sq-fc-payment-val">$615</span>
                          </div>
                          <div class="sq-fc-payment-row sq-fc-payment-row--active">
                            <span class="sq-fc-payment-date">Hoy</span>
                            <span class="sq-fc-payment-method">Transferencia</span>
                            <span class="sq-fc-payment-val">$615</span>
                          </div>
                        </div>
                        <div class="sq-fc-loyalty-bar" aria-hidden="true">
                          <div class="sq-fc-payment-bar-fill" style="width:75%"></div>
                        </div>
                        <div class="sq-fc-payment-meta">
                          <span>$1,845 pagados · $615 restantes</span>
                        </div>
                      </div>
                    )}

                    {block.variant === 'apartado-transfer' && (
                      <div class="sq-featured-card" aria-hidden="true">
                        <div class="sq-fc-header">
                          <span class="sq-fc-badge sq-fc-badge--transfer">
                            <span class="sq-fc-dot"></span>
                            Apartado con traspaso
                          </span>
                          <span class="sq-fc-time">SKU #BOT-08</span>
                        </div>
                        <div class="sq-fc-customer sq-fc-customer--transfer">
                          <span class="sq-fc-cust-name">Bota Cognac · 38</span>
                          <span class="sq-fc-cust-meta">Apartado desde Sucursal Chapalita</span>
                        </div>
                        <div class="sq-fc-stock">
                          <div class="sq-fc-stock-row">
                            <div class="sq-fc-stock-left">
                              <span class="sq-fc-stock-check sq-fc-stock-check--transfer">→</span>
