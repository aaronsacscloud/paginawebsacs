    position: relative;
  }
  .sq-fc-notes::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: #faf0d8;
    border-radius: 2px;
  }
  .sq-fc-note {
    position: relative;
    padding: 7px 9px 7px 18px;
    background: #f7f5f0;
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sq-fc-note::before {
    content: '';
    position: absolute;
    left: 3px;
    top: 12px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #c89b3f;
    box-shadow: 0 0 0 2px #faf0d8;
  }
  .sq-fc-note-head {
    display: flex;
    justify-content: space-between;
    gap: 6px;
  }
  .sq-fc-note-author {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #7a5a1c;
  }
  .sq-fc-note-time {
    font-size: 0.5625rem;
    color: #8c8c8c;
  }
  .sq-fc-note-body {
    font-size: 0.625rem;
    color: #1a1a2e;
    line-height: 1.4;
  }

  /* ── loyalty-rules ── */
  .sq-fc-toggle-list {
    margin-top: 4px;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .sq-fc-toggle-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 7px 10px;
    background: #faf7ee;
    border-radius: 6px;
    font-size: 0.6875rem;
    color: #1a1a2e;
    font-weight: 600;
  }
  .sq-fc-toggle {
    width: 26px;
    height: 14px;
    background: #d8d8de;
    border-radius: 50px;
    position: relative;
    flex-shrink: 0;
  }
  .sq-fc-toggle-dot {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 10px;
    height: 10px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.12);
    transition: left 0.15s ease;
  }
  .sq-fc-toggle--on {
    background: #c89b3f;
  }
  .sq-fc-toggle--on .sq-fc-toggle-dot {
    left: 14px;
  }
  .sq-fc-rule-foot {
    margin-top: 8px;
    padding: 6px 9px;
    background: #faf0d8;
    border-radius: 6px;
    font-size: 0.625rem;
    color: #7a5a1c;
  }

  /* ── email-provider-connect ── */
  .sq-fc-prov {
    margin-top: 4px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 10px;
    background: #f5f7fc;
    border-radius: 8px;
  }
  .sq-fc-prov-logo {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: #ffe01b;
    color: #1a1a2e;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 1rem;
    font-weight: 800;
  }
  .sq-fc-prov-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }
  .sq-fc-prov-name {
    font-size: 0.75rem;
    font-weight: 700;
    color: #1a1a2e;
  }
  .sq-fc-prov-ok {
    font-size: 0.625rem;
    color: #2a8a5f;
    font-weight: 600;
  }
  .sq-fc-prov-stats {
    margin-top: 8px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
  }
  .sq-fc-prov-stat {
    padding: 6px 9px;
    background: #f5f7fc;
    border-radius: 6px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .sq-fc-prov-stat-k {
    font-size: 0.5625rem;
    color: #4a5ab8;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
  }
  .sq-fc-prov-stat-v {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.8125rem;
    font-weight: 800;
    color: #2e3f85;
  }

  /* ── gift-sell ── */
  .sq-fc-pos-ticket {
    margin-top: 4px;
    padding: 9px 11px;
    background: #dff1ec;
    border-radius: 8px;
    border-left: 3px solid #2a8a72;
  }
  .sq-fc-pos-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: #1a1a2e;
  }
  .sq-fc-pos-amt {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-weight: 800;
    color: #155a4a;
  }
  .sq-fc-pos-sub {
    margin-top: 3px;
    font-size: 0.625rem;
    color: #155a4a;
  }
  .sq-fc-cobrar--sea {
    background: #2a8a72;
    box-shadow: 0 4px 12px rgba(42, 138, 114, 0.32);
    margin-top: 10px;
  }

  /* ── membership-tiers-pricing ── */
  .sq-fc-plans-row {
    margin-top: 4px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }
  .sq-fc-plan {
    padding: 9px 7px;
    background: #f5f3fa;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 3px;
    position: relative;
    border: 1px solid transparent;
  }
  .sq-fc-plan--highlight {
    background: #ebe6f7;
    border-color: #7048c0;
    box-shadow: 0 4px 12px rgba(112, 72, 192, 0.15);
  }
  .sq-fc-plan-tag {
    position: absolute;
    top: -6px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.5rem;
    font-weight: 800;
    background: #7048c0;
    color: #fff;
    padding: 2px 7px;
    border-radius: 50px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .sq-fc-plan-name {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.625rem;
    font-weight: 800;
    color: #3f2a7d;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: center;
  }
  .sq-fc-plan-price {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.9375rem;
    font-weight: 800;
    color: #2a1a6b;
    line-height: 1;
    text-align: center;
    margin: 2px 0 4px;
  }
  .sq-fc-plan-per {
    font-size: 0.5rem;
    font-weight: 600;
    color: #6b5a8a;
  }
  .sq-fc-plan-ben {
    font-size: 0.5625rem;
    color: #3f2a7d;
    background: rgba(255, 255, 255, 0.6);
    padding: 2px 5px;
    border-radius: 4px;
    text-align: center;
  }

  @keyframes sqPillFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  /* Mobile: simplify overlays */
  @media (max-width: 640px) {
    .sq-featured-card {
      bottom: -20px;
      left: 8px;
      right: 8px;
      width: auto;
      max-width: calc(100% - 16px);
      padding: 12px;
    }

    .sq-featured-pill--a { top: 6%; right: -4px; padding: 6px 10px; font-size: 0.6875rem; }
    .sq-featured-pill--b { top: 42%; right: -8px; padding: 6px 10px; font-size: 0.6875rem; }
    .sq-featured-pill--c { top: 76%; right: -2px; padding: 6px 10px; font-size: 0.6875rem; }

    .sq-featured--pickup .sq-featured-pill--a { left: -4px; top: 6%; }
    .sq-featured--pickup .sq-featured-pill--b { left: -8px; top: 42%; }
    .sq-featured--pickup .sq-featured-pill--c { left: -2px; top: 76%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .sq-featured-card,
    .sq-featured-pill--a,
    .sq-featured-pill--b,
    .sq-featured-pill--c,
    .sq-fc-dot {
      animation: none;
    }
  }

  /* ═══ Automatiza variants ═══ */
  .sq-fc-badge--flow,
  .sq-fc-badge--clay,
  .sq-fc-badge--axo,
  .sq-fc-badge--purple,
  .sq-fc-badge--rosep,
  .sq-fc-badge--blue,
  .sq-fc-badge--logfail {
    padding: 4px 10px;
    border-radius: 50px;
  }

  .sq-fc-badge--flow { background: #e8ecfa; color: #2e3d8a; }
  .sq-fc-badge--flow .sq-fc-dot { background: #4a5ec8; box-shadow: 0 0 0 3px rgba(74, 94, 200, 0.22); animation-name: sqFcPulseViolet; }

  .sq-fc-badge--clay { background: #faeedd; color: #7a4a1c; }
  .sq-fc-badge--clay .sq-fc-dot { background: #c27a2e; box-shadow: 0 0 0 3px rgba(194, 122, 46, 0.22); animation-name: sqFcPulseAmber; }

  .sq-fc-badge--axo { background: #e6e8f7; color: #2a2a6a; }
  .sq-fc-badge--axo .sq-fc-dot { background: #4a4aa8; box-shadow: 0 0 0 3px rgba(74, 74, 168, 0.22); animation-name: sqFcPulseIndigo; }

  .sq-fc-badge--purple { background: #eee2f4; color: #5a2a7a; }
  .sq-fc-badge--purple .sq-fc-dot { background: #8a4ab8; box-shadow: 0 0 0 3px rgba(138, 74, 184, 0.22); animation-name: sqFcPulseDeepPurple; }

  .sq-fc-badge--rosep { background: #f5e2ea; color: #8a2a5a; }
  .sq-fc-badge--rosep .sq-fc-dot { background: #b84a7a; box-shadow: 0 0 0 3px rgba(184, 74, 122, 0.22); animation-name: sqFcPulseRose; }

  .sq-fc-badge--blue { background: #e2ecf5; color: #1a4a7a; }
  .sq-fc-badge--blue .sq-fc-dot { background: #2e6abf; box-shadow: 0 0 0 3px rgba(46, 106, 191, 0.22); animation-name: sqFcPulseSteelblue; }

  .sq-fc-badge--logfail { background: #f7e8e6; color: #8a3a2a; }
  .sq-fc-badge--logfail .sq-fc-dot { background: #c25a4a; box-shadow: 0 0 0 3px rgba(194, 90, 74, 0.22); animation-name: sqFcPulseBrick; }

  @keyframes sqFcPulseViolet {
    0%, 100% { box-shadow: 0 0 0 3px rgba(74, 94, 200, 0.22); }
    50% { box-shadow: 0 0 0 5px rgba(74, 94, 200, 0.08); }
  }
  @keyframes sqFcPulseIndigo {
    0%, 100% { box-shadow: 0 0 0 3px rgba(74, 74, 168, 0.22); }
    50% { box-shadow: 0 0 0 5px rgba(74, 74, 168, 0.08); }
  }
  @keyframes sqFcPulseDeepPurple {
    0%, 100% { box-shadow: 0 0 0 3px rgba(138, 74, 184, 0.22); }
    50% { box-shadow: 0 0 0 5px rgba(138, 74, 184, 0.08); }
  }
  @keyframes sqFcPulseRose {
    0%, 100% { box-shadow: 0 0 0 3px rgba(184, 74, 122, 0.22); }
    50% { box-shadow: 0 0 0 5px rgba(184, 74, 122, 0.08); }
  }

  .sq-fc-cobrar--clay {
    background: #c27a2e;
    box-shadow: 0 4px 12px rgba(194, 122, 46, 0.32);
    margin-top: 10px;
  }

  /* ── workflow-builder ── */
  .sq-fc-flow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    margin-top: 4px;
  }
  .sq-fc-flow-node {
    width: 100%;
    padding: 8px 10px;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    border: 1px solid transparent;
  }
  .sq-fc-flow-node--trigger { background: #e8ecfa; border-color: #c4cde8; }
  .sq-fc-flow-node--cond    { background: #f2e8f7; border-color: #d8c4e0; }
  .sq-fc-flow-node--action  { background: #e4f1e7; border-color: #bcd8c0; }
  .sq-fc-flow-type {
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6b6b75;
    font-weight: 700;
  }
  .sq-fc-flow-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: #1a1a2e;
  }
  .sq-fc-flow-arrow {
    font-size: 0.875rem;
    color: #8c8c8c;
    line-height: 1;
  }

  /* ── ai-diagnostico ── */
  .sq-fc-diag-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 4px;
  }
  .sq-fc-diag-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 7px 10px;
    background: #faf5ec;
    border-radius: 6px;
    font-size: 0.75rem;
  }
  .sq-fc-diag-text { color: #1a1a2e; font-weight: 600; }
  .sq-fc-diag-prio {
    font-size: 0.625rem;
    padding: 2px 7px;
    border-radius: 50px;
    font-weight: 700;
  }
  .sq-fc-diag-prio--high { background: #f7e0d8; color: #8a3a2a; }
  .sq-fc-diag-prio--med  { background: #faeed5; color: #7a5a1c; }
  .sq-fc-diag-prio--low  { background: #e4f1e7; color: #2a6a3a; }
  .sq-fc-diag-foot {
    margin-top: 8px;
    padding: 7px 10px;
    background: #f2e8f7;
    border-radius: 8px;
    font-size: 0.6875rem;
    color: #5a2a7a;
  }
  .sq-fc-diag-foot strong { font-weight: 800; }

  /* ── axo-answer / axo-source / axo-voice shared chat ── */
  .sq-fc-chat-q {
    margin-top: 4px;
    padding: 8px 11px;
    background: #ebedf8;
    border-radius: 10px 10px 10px 2px;
    font-size: 0.75rem;
    color: #2a2a6a;
    font-style: italic;
  }
  .sq-fc-chat-a {
    margin-top: 4px;
    padding: 9px 11px;
    background: #f7f5f0;
    border-radius: 10px 10px 2px 10px;
    font-size: 0.75rem;
    color: #1a1a2e;
    line-height: 1.45;
  }
  .sq-fc-chat-num {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-weight: 800;
    color: #2a2a6a;
  }
  .sq-fc-source-chip {
    margin-top: 6px;
    padding: 5px 9px;
    background: #ebedf8;
    border-radius: 50px;
    font-size: 0.625rem;
    color: #4a4aa8;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    width: fit-content;
  }
  .sq-fc-source-link {
    display: inline-block;
    margin-top: 4px;
    font-size: 0.6875rem;
    color: #4a4aa8;
    font-weight: 700;
    text-decoration: none;
    cursor: default;
  }

  /* ── alert-stock ── */
  .sq-fc-alert-meta {
    margin-top: 4px;
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .sq-fc-alert-num {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 1.1rem;
    font-weight: 800;
    color: #a82419;
    line-height: 1;
  }
  .sq-fc-alert-desc {
    font-size: 0.6875rem;
    color: #6b6b75;
  }
  .sq-fc-dos-bar {
    margin-top: 8px;
    height: 6px;
    background: #f5e2e0;
    border-radius: 3px;
    overflow: hidden;
  }
  .sq-fc-dos-fill {
    height: 100%;
    background: #d14a4a;
    border-radius: 3px;
  }

  /* ── forecast-kpi ── */
  .sq-fc-forecast-kpi {
    margin-top: 4px;
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .sq-fc-forecast-val {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 1.6rem;
    font-weight: 800;
    color: #0f4a58;
    line-height: 1;
  }
  .sq-fc-forecast-prob {
    font-size: 0.6875rem;
    color: #1c6b7d;
    font-weight: 600;
  }
  .sq-fc-cone {
    margin-top: 6px;
    width: 100%;
    height: 42px;
    display: block;
  }
  .sq-fc-kpi-row {
    margin-top: 4px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }
  .sq-fc-kpi-cell {
    padding: 6px 8px;
    background: #e2f1f4;
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sq-fc-kpi-k {
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #1c6b7d;
    font-weight: 600;
  }
  .sq-fc-kpi-v {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.75rem;
    font-weight: 800;
    color: #0f4a58;
  }

  /* ── orq-routing ── */
  .sq-fc-routing {
    margin-top: 4px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .sq-fc-routing-in {
    padding: 7px 10px;
    background: #eee2f4;
    border-radius: 50px;
    font-size: 0.6875rem;
    color: #5a2a7a;
    font-weight: 600;
    text-align: center;
  }
  .sq-fc-routing-branches {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5px;
  }
  .sq-fc-route {
    padding: 6px 8px;
    background: #f5edf8;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-left: 3px solid #8a4ab8;
  }
  .sq-fc-route-model {
    font-size: 0.6875rem;
    font-weight: 800;
    color: #5a2a7a;
  }
  .sq-fc-route-tag {
    font-size: 0.5625rem;
    color: #8a4ab8;
  }

  /* ── orq-pipeline ── */
  .sq-fc-pipe {
    margin-top: 4px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 6px;
  }
  .sq-fc-pipe-step {
    padding: 8px 9px;
    background: #f5e2ea;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sq-fc-pipe-model {
    font-size: 0.6875rem;
    font-weight: 800;
    color: #8a2a5a;
  }
  .sq-fc-pipe-task {
    font-size: 0.5625rem;
    color: #6b6b75;
  }
  .sq-fc-pipe-arrow {
    color: #b84a7a;
    font-weight: 800;
    font-size: 0.875rem;
  }
  .sq-fc-pipe-out {
    margin-top: 8px;
    padding: 7px 10px;
    background: #f0e4e8;
    border-radius: 8px;
    font-size: 0.6875rem;
    color: #8a2a5a;
    display: flex;
    align-items: center;
    gap: 6px;
    font-weight: 600;
  }

  /* ── api-integrations ── */
  .sq-fc-intg-grid {
    margin-top: 4px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 5px;
  }
  .sq-fc-intg {
    padding: 6px 7px;
    background: #eceff3;
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .sq-fc-intg-name {
    font-size: 0.625rem;
    font-weight: 700;
    color: #1a1a2e;
  }
  .sq-fc-intg-tag {
    font-size: 0.5rem;
    padding: 1px 5px;
    border-radius: 50px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    width: fit-content;
  }
  .sq-fc-intg-tag--official  { background: #e4f1e7; color: #2a6a3a; }
  .sq-fc-intg-tag--partner   { background: #e2ecf5; color: #1a4a7a; }
  .sq-fc-intg-tag--roadmap   { background: #faeed5; color: #7a5a1c; }
  .sq-fc-intg-tag--community { background: #eceff3; color: #4d5a6b; }

  /* ── api-endpoint ── */
  .sq-fc-code {
    margin: 4px 0 0;
    padding: 10px 11px;
    background: #0f1a2e;
    border-radius: 8px;
    font-family: 'SF Mono', Menlo, Consolas, monospace;
    font-size: 0.625rem;
    line-height: 1.6;
    color: #e4e8f0;
    overflow: hidden;
    white-space: pre;
  }
  .sq-fc-code-brace { color: #8cb8ff; }
  .sq-fc-code-key { color: #9ecef5; }
  .sq-fc-code-str { color: #a8e0a8; }
  .sq-fc-code-num { color: #f0c080; }
  .sq-fc-code-status {
    margin-top: 6px;
    padding: 5px 9px;
    background: #e4f1e7;
    border-radius: 50px;
    font-size: 0.625rem;
    color: #2a6a3a;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    width: fit-content;
    font-weight: 700;
  }
  .sq-fc-code-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #3a8a5a;
  }

  /* ── workflow-triggers ── */
  .sq-fc-trig-list {
    margin-top: 4px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .sq-fc-trig-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 10px;
    background: #f2f3fa;
    border-radius: 6px;
    font-size: 0.6875rem;
  }
  .sq-fc-trig-name { color: #1a1a2e; font-weight: 600; }
  .sq-fc-trig-cat {
    font-size: 0.5625rem;
    padding: 2px 7px;
    background: #e8ecfa;
    color: #2e3d8a;
    border-radius: 50px;
    font-weight: 700;
  }

  /* ── workflow-conditions ── */
  .sq-fc-cond-line {
    margin-top: 4px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 5px;
    padding: 8px 10px;
    background: #f2e8f7;
    border-radius: 8px;
    font-size: 0.6875rem;
    color: #5a2a7a;
  }
  .sq-fc-cond-word { font-weight: 500; }
  .sq-fc-cond-drop {
    padding: 2px 8px;
    background: #fff;
    border: 1px solid #d8c4e0;
    border-radius: 6px;
    font-weight: 700;
    color: #1a1a2e;
  }
  .sq-fc-cond-sep {
    margin: 2px 0;
    font-size: 0.625rem;
    font-weight: 800;
    color: #8a4ab8;
    text-align: center;
    letter-spacing: 0.1em;
  }
  .sq-fc-cond-foot {
    margin-top: 6px;
    font-size: 0.625rem;
    color: #6b6b75;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  /* ── workflow-log ── */
  .sq-fc-log-line {
    margin-top: 4px;
    display: flex;
    gap: 8px;
    padding: 6px 10px;
    background: #f5f5f8;
    border-radius: 6px;
    font-size: 0.6875rem;
    color: #1a1a2e;
  }
  .sq-fc-log-line--fail {
    background: #f7e8e6;
    color: #8a3a2a;
  }
  .sq-fc-log-icon {
    font-weight: 800;
    color: #6b6b75;
  }
  .sq-fc-log-line--fail .sq-fc-log-icon { color: #c25a4a; }
  .sq-fc-log-ok { color: #2a8a5f; font-weight: 800; }
  .sq-fc-log-text em { font-style: italic; color: #6b6b75; }
  .sq-fc-log-foot {
    margin-top: 6px;
    padding: 6px 10px;
    background: #f7e8e6;
    border-radius: 6px;
    font-size: 0.625rem;
    color: #8a3a2a;
  }

  /* ── ai-session-live ── */
  .sq-fc-vc {
    margin-top: 4px;
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 8px;
    padding: 9px;
    background: #0f1a2e;
    border-radius: 10px;
  }
  .sq-fc-vc-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, #c27a2e, #a05818);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 800;
    font-size: 0.875rem;
  }
  .sq-fc-vc-screen {
    background: #1a2a44;
    border-radius: 6px;
    padding: 7px 9px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .sq-fc-vc-screen-head {
    font-size: 0.5625rem;
    color: #a8b4c8;
    font-weight: 600;
  }
  .sq-fc-vc-screen-row {
    height: 5px;
    background: rgba(255, 255, 255, 0.18);
    border-radius: 2px;
  }
  .sq-fc-vc-screen-row--short { width: 62%; }
  .sq-fc-vc-meta {
    margin-top: 6px;
    font-size: 0.625rem;
    color: #7a4a1c;
    font-weight: 600;
  }

  /* ── ai-cohorte ── */
  .sq-fc-coh-roster {
    margin-top: 4px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3px;
  }
  .sq-fc-coh-row {
    padding: 4px 7px;
    background: #faeedd;
    border-radius: 4px;
    font-size: 0.5625rem;
    color: #7a4a1c;
    font-weight: 600;
  }
  .sq-fc-coh-bar {
    margin-top: 6px;
    height: 5px;
    background: #f0e4d5;
    border-radius: 3px;
    overflow: hidden;
  }
  .sq-fc-coh-fill {
    height: 100%;
    background: #c27a2e;
    border-radius: 3px;
  }

  /* ── ai-agenda ── */
  .sq-fc-agenda {
    margin-top: 4px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .sq-fc-agenda-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 10px;
    background: #faf5ec;
    border-radius: 6px;
    font-size: 0.6875rem;
    color: #1a1a2e;
  }
  .sq-fc-agenda-n {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #c27a2e;
    color: #fff;
    font-size: 0.625rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* ── axo-context ── */
  .sq-fc-ctx-chips {
    margin-top: 4px;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .sq-fc-ctx-chip {
    padding: 4px 9px;
    background: #ebedf8;
    border-radius: 50px;
    font-size: 0.625rem;
    color: #2a2a6a;
    font-weight: 600;
  }
  .sq-fc-ctx-status {
    margin-top: 6px;
    padding: 5px 9px;
    background: #e4f1e7;
    border-radius: 50px;
    font-size: 0.625rem;
    color: #2a6a3a;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    width: fit-content;
    font-weight: 700;
  }

  /* ── axo-voice ── */
  .sq-fc-voice-bubble {
    margin-top: 4px;
    padding: 10px 12px;
    background: #ebedf8;
    border-radius: 10px 10px 10px 2px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .sq-fc-wave {
    display: flex;
    align-items: center;
    gap: 2px;
    height: 16px;
  }
  .sq-fc-wave span {
    display: inline-block;
    width: 2px;
    background: #4a4aa8;
    border-radius: 1px;
    animation: sqFcWave 1.2s ease-in-out infinite;
  }
  .sq-fc-wave span:nth-child(1) { height: 40%; animation-delay: 0s; }
  .sq-fc-wave span:nth-child(2) { height: 70%; animation-delay: 0.1s; }
  .sq-fc-wave span:nth-child(3) { height: 90%; animation-delay: 0.2s; }
  .sq-fc-wave span:nth-child(4) { height: 60%; animation-delay: 0.3s; }
  .sq-fc-wave span:nth-child(5) { height: 85%; animation-delay: 0.4s; }
  .sq-fc-wave span:nth-child(6) { height: 45%; animation-delay: 0.5s; }
  .sq-fc-wave span:nth-child(7) { height: 70%; animation-delay: 0.6s; }
  .sq-fc-wave span:nth-child(8) { height: 50%; animation-delay: 0.7s; }
  .sq-fc-wave span:nth-child(9) { height: 35%; animation-delay: 0.8s; }
  @keyframes sqFcWave {
    0%, 100% { transform: scaleY(1); }
    50% { transform: scaleY(1.8); }
  }
  .sq-fc-voice-txt {
    font-size: 0.75rem;
    color: #2a2a6a;
    font-style: italic;
  }
  .sq-fc-voice-tx {
    margin-top: 4px;
    font-size: 0.5625rem;
    color: #6b6b75;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }

  /* ── alert-anomaly ── */
  .sq-fc-anomaly {
    margin-top: 4px;
    width: 100%;
    height: 62px;
    display: block;
  }
  .sq-fc-anomaly-tag {
    margin-top: 4px;
    padding: 6px 10px;
    background: #f7e8e6;
    border-radius: 6px;
    font-size: 0.6875rem;
    color: #8a3a2a;
  }
  .sq-fc-anomaly-tag strong {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-weight: 800;
    color: #a82419;
  }

  /* ── alert-vip-churn ── */
  .sq-fc-churn-meta {
    margin-top: 4px;
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 7px 10px;
    background: #f7e8e6;
    border-radius: 6px;
  }
  .sq-fc-churn-line {
    font-size: 0.6875rem;
    color: #8a3a2a;
  }
  .sq-fc-churn-line strong { color: #a82419; font-weight: 800; }
  .sq-fc-microchart {
    margin-top: 4px;
    width: 100%;
    height: 26px;
    display: block;
  }

  /* ── alert-action ── */
  .sq-fc-alert-head {
    margin-top: 4px;
    font-size: 0.8125rem;
    font-weight: 700;
    color: #8a3a2a;
  }
  .sq-fc-action-row {
    margin-top: 6px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5px;
  }
  .sq-fc-btn {
    padding: 7px 10px;
    border-radius: 6px;
    font-size: 0.6875rem;
    font-weight: 700;
    border: none;
    cursor: default;
    font-family: inherit;
  }
  .sq-fc-btn--primary {
    background: #d14a4a;
    color: #fff;
  }
  .sq-fc-btn--ghost {
    background: #f5f5f8;
    color: #6b6b75;
  }
  .sq-fc-action-meta {
    margin-top: 6px;
    font-size: 0.625rem;
    color: #6b6b75;
  }

  /* ── forecast-digest ── */
  .sq-fc-digest-head {
    margin-top: 4px;
    font-size: 0.75rem;
    font-weight: 700;
    color: #0f4a58;
  }
  .sq-fc-digest-list {
    margin: 4px 0 0;
    padding: 0 0 0 14px;
    list-style: disc;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .sq-fc-digest-list li {
    font-size: 0.6875rem;
    color: #1a1a2e;
    line-height: 1.45;
  }
  .sq-fc-digest-list strong {
    font-weight: 800;
    color: #0f4a58;
  }

  /* ── forecast-margin ── */
  .sq-fc-margin-stack {
    margin-top: 6px;
    display: flex;
    width: 100%;
    height: 26px;
    border-radius: 6px;
    overflow: hidden;
  }
  .sq-fc-margin-seg {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.5rem;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
    overflow: hidden;
  }
  .sq-fc-margin-seg--cost  { background: #4d5a6b; }
  .sq-fc-margin-seg--promo { background: #c28500; }
  .sq-fc-margin-seg--dev   { background: #c25a4a; }
  .sq-fc-margin-seg--merma { background: #b28a36; }
  .sq-fc-margin-seg--comi  { background: #6a4aa8; }
  .sq-fc-margin-result {
    margin-top: 6px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 7px 10px;
    background: #e2f1f4;
    border-radius: 8px;
  }
  .sq-fc-margin-label {
    font-size: 0.6875rem;
    color: #0f4a58;
    font-weight: 600;
  }
  .sq-fc-margin-val {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 1rem;
    font-weight: 800;
    color: #0f4a58;
  }

  /* ── forecast-signal ── */
  .sq-fc-semaphore {
    margin-top: 4px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 5px;
  }
  .sq-fc-sem {
    padding: 8px 6px;
    border-radius: 6px;
    text-align: center;
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    position: relative;
  }
  .sq-fc-sem::before {
    content: '';
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin: 0 auto 4px;
  }
  .sq-fc-sem--green  { background: #e4f1e7; color: #2a6a3a; }
  .sq-fc-sem--green::before { background: #3a8a5a; }
  .sq-fc-sem--yellow { background: #faeed5; color: #7a5a1c; }
  .sq-fc-sem--yellow::before { background: #c28500; }
  .sq-fc-sem--red    { background: #f7e0d8; color: #8a3a2a; }
  .sq-fc-sem--red::before { background: #d14a4a; }
  .sq-fc-sem-foot {
    margin-top: 6px;
    font-size: 0.6875rem;
    color: #0f4a58;
    padding: 6px 10px;
    background: #e2f1f4;
    border-radius: 6px;
  }
  .sq-fc-sem-foot strong { font-weight: 800; }

  /* ── orq-audit ── */
  .sq-fc-audit-resp {
    margin-top: 4px;
    padding: 8px 11px;
    background: #f5edf8;
    border-left: 3px solid #8a4ab8;
    border-radius: 4px 8px 8px 4px;
    font-size: 0.6875rem;
    color: #1a1a2e;
    font-style: italic;
    line-height: 1.45;
  }
  .sq-fc-audit-path {
    margin-top: 6px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px;
    font-size: 0.625rem;
  }
  .sq-fc-audit-step {
    padding: 3px 7px;
    background: #eee2f4;
    border-radius: 50px;
    color: #5a2a7a;
    font-weight: 700;
  }
  .sq-fc-audit-step em {
    font-style: italic;
    font-weight: 500;
    color: #8a4ab8;
  }
  .sq-fc-audit-arrow { color: #8a4ab8; font-weight: 800; }
  .sq-fc-audit-src {
    margin-top: 4px;
    font-size: 0.625rem;
    color: #6b6b75;
  }
  .sq-fc-audit-conf {
    margin-top: 6px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 6px 10px;
    background: #eee2f4;
    border-radius: 6px;
    font-size: 0.6875rem;
    color: #5a2a7a;
  }
  .sq-fc-audit-conf strong {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.875rem;
    font-weight: 800;
  }

  /* ── api-webhooks ── */
  .sq-fc-hook {
    margin-top: 4px;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 7px 10px;
    background: #0f1a2e;
    border-radius: 6px;
    font-family: 'SF Mono', Menlo, Consolas, monospace;
    font-size: 0.6875rem;
    color: #e4e8f0;
    overflow: hidden;
  }
  .sq-fc-hook-verb {
    padding: 1px 6px;
    background: #2e6abf;
    color: #fff;
    border-radius: 4px;
    font-size: 0.5625rem;
    font-weight: 800;
  }
  .sq-fc-hook-url {
    font-size: 0.625rem;
    color: #9ecef5;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sq-fc-hook-log {
    margin-top: 4px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .sq-fc-hook-row {
    display: flex;
    gap: 8px;
    padding: 5px 9px;
    background: #e4f1e7;
    border-radius: 4px;
    font-size: 0.625rem;
    color: #2a6a3a;
    font-family: 'SF Mono', Menlo, Consolas, monospace;
  }
  .sq-fc-hook-row--retry {
    background: #faeed5;
    color: #7a5a1c;
  }
  .sq-fc-hook-ok { color: #3a8a5a; font-weight: 800; }
  .sq-fc-hook-retry { color: #c28500; font-weight: 800; }
  .sq-fc-hook-sig {
    margin-top: 6px;
    padding: 4px 8px;
    background: #eceff3;
    border-radius: 50px;
    font-size: 0.5625rem;
    color: #4d5a6b;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    width: fit-content;
    font-weight: 600;
  }

  /* ── api-tokens ── */
  .sq-fc-tokens {
    margin-top: 4px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .sq-fc-tok-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 8px;
    padding: 7px 10px;
    background: #eceff3;
    border-radius: 6px;
  }
  .sq-fc-tok-main {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }
  .sq-fc-tok-name {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #1a1a2e;
  }
  .sq-fc-tok-ip {
    font-size: 0.5625rem;
    color: #6b6b75;
    font-family: 'SF Mono', Menlo, Consolas, monospace;
  }
  .sq-fc-tok-scopes {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sq-fc-tok-scope {
    font-size: 0.5rem;
    padding: 1px 5px;
    background: #e2ecf5;
    color: #1a4a7a;
    border-radius: 50px;
    font-family: 'SF Mono', Menlo, Consolas, monospace;
    font-weight: 700;
  }
  .sq-fc-tok-status {
    font-size: 0.5rem;
    padding: 2px 6px;
    border-radius: 50px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .sq-fc-tok-status--on  { background: #e4f1e7; color: #2a6a3a; }
  .sq-fc-tok-status--off { background: #f7e8e6; color: #8a3a2a; }

  /* ═══ Stats Bar ═══ */
  .pf-stats {
    background: var(--color-bg-dark-deep, #1A1A2E);
    padding: clamp(48px, 6vw, 80px) 0;
  }

  .pf-stats-inner {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8, 32px);
    text-align: center;
  }

  @media (min-width: 768px) {
    .pf-stats-inner { grid-template-columns: repeat(4, 1fr); }
  }

  .pf-stat-value {
    display: block;
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: var(--space-2, 8px);
  }

  .pf-stat-label {
    display: block;
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.3;
  }

  /* ═══ Testimonial ═══ */
  .pf-testimonial {
    padding: clamp(64px, 8vw, 100px) 0;
    background: var(--color-bg-primary, #FAFAF8);
  }

  .pf-testimonial-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .pf-testimonial-card {
    position: relative;
    padding: clamp(32px, 5vw, 48px) 0;
  }

  .pf-quote-mark {
    margin-bottom: var(--space-6, 24px);
  }

  .pf-testimonial-quote {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    font-weight: 600;
    color: var(--color-text-primary, #1a1a2e);
    letter-spacing: -0.02em;
    line-height: 1.45;
    margin: 0 0 var(--space-8, 32px);
  }

  .pf-testimonial-footer {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-6, 24px);
    padding-top: var(--space-6, 24px);
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .pf-testimonial-author {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .pf-testimonial-name {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text-primary, #1a1a2e);
  }

  .pf-testimonial-role {
    font-size: 0.8125rem;
    color: var(--color-text-tertiary, #8c8c8c);
  }

  .pf-testimonial-stat {
    text-align: right;
    flex-shrink: 0;
  }

  .pf-testimonial-stat-value {
    display: block;
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary, #4B7BE5);
    line-height: 1;
  }

  .pf-testimonial-stat-label {
    font-size: 0.75rem;
    color: var(--color-text-tertiary, #8c8c8c);
    line-height: 1.3;
  }

  /* ═══ Mini Plans ═══ */
  .pf-plans {
    padding: clamp(64px, 8vw, 100px) 0;
    background: #fff;
  }

  .pf-plans-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: clamp(32px, 4vw, 48px);
    flex-wrap: wrap;
  }

  .pf-plans-title {
    font-family: var(--font-display, 'Sora', sans-serif);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
