---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';
import { buildReferrerCookie } from '../../lib/attribution';

export const prerender = false;

const { slug } = Astro.params;

if (!slug) return Astro.redirect('/404');

// Resolver slug → invitación + partner
const { data: invitation } = await supabase
  .from('partner_invitations')
  .select('id, nombre, slug_landing, numero, tipo, estado, team_member_id, comision_pct')
  .eq('slug_landing', slug)
  .maybeSingle();

// Fallback: buscar por número (lowercase) si slug_landing no coincide
let resolved = invitation;
if (!resolved) {
  const { data: byNumero } = await supabase
    .from('partner_invitations')
    .select('id, nombre, slug_landing, numero, tipo, estado, team_member_id, comision_pct')
    .ilike('numero', slug)
    .maybeSingle();
  resolved = byNumero;
}

if (!resolved || !resolved.team_member_id || resolved.estado !== 'accepted') {
  return Astro.redirect('/404');
}

const partnerId = resolved.team_member_id as string;
const partnerName = resolved.nombre || 'tu asesor SACS';
const tipoLabels: Record<string, string> = {
  embajador: 'Embajador SACS',
  distribuidor: 'Distribuidor Autorizado',
  integrador: 'Integrador Certificado',
  reseller: 'Reseller',
  consultor: 'Consultor Partner',
};
const programaLabel = tipoLabels[resolved.tipo] || 'Partner SACS';

// Setea cookie de atribución (90 días)
Astro.response.headers.append('Set-Cookie', buildReferrerCookie(partnerId));

// ── Tracking de visita ──────────────────────────────────────────
// Visitor ID estable de 1 año en cookie sacs_pv (partner visitor).
// Distingue visitantes únicos vs recurrentes sin loggear IP cruda.
const cookieHeader = Astro.request.headers.get('cookie') || '';
const pvMatch = cookieHeader.match(/(?:^|;\s*)sacs_pv=([a-f0-9-]{36})/);
let visitorId = pvMatch?.[1] || '';
if (!visitorId) {
  visitorId = crypto.randomUUID();
  Astro.response.headers.append(
    'Set-Cookie',
    `sacs_pv=${visitorId}; Path=/; Max-Age=31536000; SameSite=Lax; HttpOnly`
  );
}

// Skip tracking si ?notrack=1 (para que el partner no infle sus stats al previsualizar).
const noTrack = Astro.url.searchParams.get('notrack') === '1';
if (!noTrack) {
  const ua = Astro.request.headers.get('user-agent') || null;
  const ref = Astro.request.headers.get('referer') || null;
  const fwd = Astro.request.headers.get('x-forwarded-for') || '';
  const ip = fwd.split(',')[0]?.trim() || '';
  let ipHash: string | null = null;
  if (ip) {
    const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(ip + ':sacs'));
    ipHash = Array.from(new Uint8Array(buf)).slice(0, 12).map(b => b.toString(16).padStart(2, '0')).join('');
  }
  // Fire-and-forget — no bloquea render
  supabase.from('partner_link_visits').insert({
    partner_id: partnerId,
    slug,
    visitor_id: visitorId,
    ip_hash: ipHash,
    user_agent: ua,
    referrer: ref,
  }).then(() => {}, () => {});
}

const trialUrl = `/prueba-gratis?ref=${encodeURIComponent(partnerId)}`;
const demoUrl  = `/agendar?ref=${encodeURIComponent(partnerId)}`;
---
<BaseLayout
  title={`${partnerName} te recomienda SACS — Sistema operativo para retailers`}
  description={`Conoce SACS por recomendación de ${partnerName}. Plataforma de retail moderna: POS, inventario multi-sucursal, e-commerce, CRM, IA.`}
  noindex={false}
  bareLayout={true}
>
  <main class="pl-page">
    <!-- Hero -->
    <section class="pl-hero">
      <div class="pl-hero-inner">
        <a href="/" class="pl-logo">Sacs</a>
        <div class="pl-eyebrow">Recomendado por {partnerName}</div>
        <h1 class="pl-title">
          El sistema operativo<br/>
          <span class="pl-title-accent">del retail moderno.</span>
        </h1>
        <p class="pl-lead">
          Punto de venta, inventario multi-sucursal, e-commerce, CRM y IA — en un solo
          sistema. Probado por más de <strong>3,000 marcas en LATAM</strong>.
        </p>

        <div class="pl-cta-row">
          <a class="pl-cta pl-cta--primary" href={trialUrl}>
            Empezar prueba gratis · 14 días
          </a>
          <a class="pl-cta pl-cta--ghost" href={demoUrl}>
            Agendar demo de 30 min →
          </a>
        </div>

        <div class="pl-attribution">
          Llegaste por el link de <strong>{partnerName}</strong> · {programaLabel} oficial.
          Tu activación queda atribuida a {partnerName.split(' ')[0]} automáticamente.
        </div>
      </div>
    </section>

    <!-- Trust signals -->
    <section class="pl-trust">
      <div class="pl-trust-inner">
        <div class="pl-trust-item">
          <div class="pl-trust-num">3,000+</div>
          <div class="pl-trust-label">Marcas activas en LATAM</div>
        </div>
        <div class="pl-trust-item">
          <div class="pl-trust-num">42M+</div>
          <div class="pl-trust-label">Transacciones procesadas</div>
        </div>
        <div class="pl-trust-item">
          <div class="pl-trust-num">14 días</div>
          <div class="pl-trust-label">Prueba gratis · sin tarjeta</div>
        </div>
        <div class="pl-trust-item">
          <div class="pl-trust-num">99.95%</div>
          <div class="pl-trust-label">Uptime de la plataforma</div>
        </div>
      </div>
    </section>

    <!-- Screenshot del producto -->
    <section class="pl-screenshot">
      <div class="pl-screenshot-inner">
        <div class="pl-screenshot-eyebrow">Así se ve SACS</div>
        <h2 class="pl-screenshot-title">Una plataforma. Todo tu retail.</h2>
        <p class="pl-screenshot-lead">
          POS, inventario multi-sucursal, e-commerce y CRM — operando sincronizados desde laptop, tablet o teléfono.
        </p>
        <div class="pl-screenshot-image-wrap">
          <img
            src="/images/screen-ecommerce.webp"
            alt="SACS — laptop, tablet y phone mostrando POS, catálogo y CRM sincronizados"
            class="pl-screenshot-image"
            width="1200"
            height="640"
            loading="lazy"
          />
        </div>
      </div>
    </section>

    <!-- Beneficios resumidos -->
    <section class="pl-bens">
      <div class="pl-bens-grid">
        <div class="pl-ben">
          <div class="pl-ben-num">1</div>
          <div class="pl-ben-title">Sin instalación</div>
          <div class="pl-ben-detail">100% en la nube. Funciona en tablet, computadora o móvil. Sin servidores, sin tickets de soporte de TI.</div>
        </div>
        <div class="pl-ben">
          <div class="pl-ben-num">2</div>
          <div class="pl-ben-title">Multi-sucursal</div>
          <div class="pl-ben-detail">Inventario, ventas y reportes en tiempo real entre todas tus tiendas. Una sola fuente de verdad.</div>
        </div>
        <div class="pl-ben">
          <div class="pl-ben-num">3</div>
          <div class="pl-ben-title">E-commerce + redes</div>
          <div class="pl-ben-detail">Tu tienda en línea sincronizada con stock físico, más venta directa por META, TikTok Shop y WhatsApp.</div>
        </div>
        <div class="pl-ben">
          <div class="pl-ben-num">4</div>
          <div class="pl-ben-title">CRM + IA</div>
          <div class="pl-ben-detail">Cada cliente con su perfil, historial de compras, recomendaciones automáticas y comunicación omnicanal.</div>
        </div>
      </div>
    </section>

    <!-- Plans recall -->
    <section class="pl-plans">
      <div class="pl-section-eyebrow">Planes</div>
      <h2 class="pl-section-title">Empieza con el plan que necesitas hoy.</h2>
      <p class="pl-section-lead">
        Cambia entre planes cuando crezcas. Sin permanencia. Cancela cuando quieras.
      </p>
      <div class="pl-plan-cards">
        <div class="pl-plan-card">
          <div class="pl-plan-name">Vende</div>
          <div class="pl-plan-price">$600 <span>/ mes</span></div>
          <div class="pl-plan-desc">Para marcas que arrancan. POS + inventario base.</div>
        </div>
        <div class="pl-plan-card">
          <div class="pl-plan-name">Controla</div>
          <div class="pl-plan-price">$900 <span>/ mes</span></div>
          <div class="pl-plan-desc">Multi-sucursal con orden, reportes profundos.</div>
        </div>
        <div class="pl-plan-card pl-plan-card--featured">
          <div class="pl-plan-pop">Más popular</div>
          <div class="pl-plan-name">Fideliza</div>
          <div class="pl-plan-price">$1,400 <span>/ mes</span></div>
          <div class="pl-plan-desc">+ CRM, lealtad, e-commerce, marketing.</div>
        </div>
        <div class="pl-plan-card">
          <div class="pl-plan-name">Automatiza</div>
          <div class="pl-plan-price">$5,900 <span>/ mes</span></div>
          <div class="pl-plan-desc">Operación con IA, workflows, integraciones.</div>
        </div>
      </div>
      <div class="pl-cta-row pl-cta-row--center">
        <a class="pl-cta pl-cta--primary" href={trialUrl}>Empezar mi prueba gratis</a>
      </div>
    </section>

    <!-- Footer simple -->
    <footer class="pl-foot">
      <div>SACS Cloud · Sistema operativo para retailers conscientes</div>
      <div class="pl-foot-links">
        <a href="/terminos">Términos</a> · <a href="/privacidad">Privacidad</a> · <a href="/contacto">Contacto</a>
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  .pl-page { font-family: var(--font-body); color: #1a1a1a; background: #fafafa; }

  /* Hero */
  .pl-hero {
    background: linear-gradient(180deg, #fff 0%, #f5f5f7 100%);
    padding: 56px 20px 72px;
    border-bottom: 1px solid #ececec;
  }
  .pl-hero-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .pl-logo {
    display: inline-block;
    font-family: 'Clash Display', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a1a;
    text-decoration: none;
    letter-spacing: -0.02em;
    margin-bottom: 28px;
  }
  .pl-eyebrow {
    display: inline-block;
    padding: 6px 12px;
    background: rgba(75,123,229,0.10);
    color: #4B7BE5;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    border-radius: 999px;
    margin-bottom: 20px;
  }
  .pl-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5.5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: #1a1a1a;
    margin: 0 0 18px;
    letter-spacing: -0.025em;
  }
  .pl-title-accent {
    color: #4B7BE5;
  }
  .pl-lead {
    font-size: clamp(1rem, 1.6vw, 1.125rem);
    color: #555;
    line-height: 1.6;
    max-width: 540px;
    margin: 0 auto 30px;
  }
  .pl-cta-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-bottom: 24px;
  }
  .pl-cta-row--center { justify-content: center; margin-top: 28px; }
  .pl-cta {
    display: inline-block;
    padding: 14px 24px;
    border-radius: 10px;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .pl-cta--primary {
    background: #1a1a1a;
    color: #fff;
  }
  .pl-cta--primary:hover { background: #4B7BE5; }
  .pl-cta--ghost {
    background: transparent;
    color: #1a1a1a;
    border: 1px solid #ddd;
  }
  .pl-cta--ghost:hover { border-color: #1a1a1a; }
  .pl-attribution {
    font-size: 0.8125rem;
    color: #888;
    line-height: 1.5;
    max-width: 460px;
    margin: 0 auto;
  }

  /* Beneficios */
  /* Trust signals row */
  .pl-trust { background: #1A1A1A; padding: 36px 20px; }
  .pl-trust-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    text-align: center;
    color: #fff;
  }
  .pl-trust-num {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.8vw, 2rem);
    font-weight: 300;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 6px;
  }
  .pl-trust-label {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.4;
  }
  @media (max-width: 720px) {
    .pl-trust-inner { grid-template-columns: 1fr 1fr; gap: 20px; }
  }

  /* Screenshot showcase */
  .pl-screenshot {
    background: #FAFAF8;
    padding: 72px 20px;
    text-align: center;
  }
  .pl-screenshot-inner { max-width: 1100px; margin: 0 auto; }
  .pl-screenshot-eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 14px;
  }
  .pl-screenshot-title {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 3.2vw, 2.375rem);
    font-weight: 300;
    color: #1A1A1A;
    margin: 0 0 14px;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .pl-screenshot-lead {
    font-size: 1rem;
    color: #6A6A6A;
    line-height: 1.6;
    margin: 0 auto 32px;
    max-width: 540px;
    font-weight: 400;
  }
  .pl-screenshot-image-wrap {
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 24px 48px -16px rgba(20,20,30,0.18), 0 4px 12px -4px rgba(20,20,30,0.06);
    background: #fff;
  }
  .pl-screenshot-image {
    display: block;
    width: 100%;
    height: auto;
  }
  @media (max-width: 640px) {
    .pl-screenshot { padding: 48px 16px; }
  }

  .pl-bens {
    padding: 56px 20px;
    background: #fff;
  }
  .pl-bens-grid {
    max-width: 980px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 18px;
  }
  .pl-ben {
    padding: 24px;
    background: #fafafa;
    border: 1px solid #ececec;
    border-radius: 14px;
  }
  .pl-ben-num {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: #1a1a1a;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.875rem;
    margin-bottom: 14px;
  }
  .pl-ben-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }
  .pl-ben-detail {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.55;
  }

  /* Planes */
  .pl-plans {
    padding: 64px 20px;
    text-align: center;
    max-width: 1100px;
    margin: 0 auto;
  }
  .pl-section-eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 12px;
  }
  .pl-section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 12px;
    letter-spacing: -0.015em;
  }
  .pl-section-lead {
    font-size: 0.9375rem;
    color: #666;
    margin: 0 auto 32px;
    max-width: 520px;
    line-height: 1.55;
  }
  .pl-plan-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
  }
  .pl-plan-card {
    position: relative;
    padding: 24px 20px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 14px;
    text-align: left;
  }
  .pl-plan-card--featured {
    border-color: #4B7BE5;
    background: linear-gradient(180deg, rgba(75,123,229,0.04), #fff);
    box-shadow: 0 8px 24px -8px rgba(75,123,229,0.18);
  }
  .pl-plan-pop {
    position: absolute;
    top: -10px; left: 16px;
    padding: 4px 10px;
    background: #4B7BE5;
    color: #fff;
    font-size: 0.625rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    border-radius: 999px;
  }
  .pl-plan-name {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 8px;
  }
  .pl-plan-price {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: #1a1a1a;
    margin-bottom: 4px;
    letter-spacing: -0.01em;
  }
  .pl-plan-price span {
    font-size: 0.8125rem;
    color: #888;
    font-weight: 500;
  }
  .pl-plan-desc {
    font-size: 0.8125rem;
    color: #666;
    line-height: 1.5;
    margin-top: 8px;
  }

  /* Footer */
  .pl-foot {
    padding: 32px 20px;
    text-align: center;
    font-size: 0.75rem;
    color: #888;
    line-height: 1.7;
    border-top: 1px solid #ececec;
    background: #fff;
  }
  .pl-foot-links a {
    color: #888;
    text-decoration: none;
  }
  .pl-foot-links a:hover {
    color: #4B7BE5;
    text-decoration: underline;
  }
</style>
