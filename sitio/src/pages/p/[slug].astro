---
// /p/[slug] · partner attribution link
//
// Comportamiento nuevo: redirect a la home con tracking + cookie de atribución.
// El partner siempre va a la página web normal de SACS — la atribución se
// mantiene por 90 días vía cookie + se refuerza con ?ref en la URL para
// asegurar attribution incluso si bloquean cookies.
//
// Crawlers de redes sociales (WhatsApp, LinkedIn, Twitter) reciben las mismas
// OG tags que la home porque siguen el redirect.

import { supabase } from '../../lib/supabase';
import { buildReferrerCookie } from '../../lib/attribution';

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return new Response(null, { status: 302, headers: { Location: '/' } });
}

// Resolver slug → invitación + partner
const { data: invitation } = await supabase
  .from('partner_invitations')
  .select('id, nombre, slug_landing, numero, tipo, estado, team_member_id, comision_pct')
  .eq('slug_landing', slug)
  .maybeSingle();

// Fallback: buscar por número (lowercase) si slug_landing no coincide
let resolved = invitation;
if (!resolved) {
  const { data: byNumero } = await supabase
    .from('partner_invitations')
    .select('id, nombre, slug_landing, numero, tipo, estado, team_member_id, comision_pct')
    .ilike('numero', slug)
    .maybeSingle();
  resolved = byNumero;
}

// Si no existe o no está aceptado, redirige a home sin cookie ni tracking
if (!resolved || !resolved.team_member_id || resolved.estado !== 'accepted') {
  return new Response(null, { status: 302, headers: { Location: '/' } });
}

const partnerId = resolved.team_member_id as string;
const partnerName = resolved.nombre || 'tu asesor';
const tipoLabels: Record<string, string> = {
  embajador: 'Embajador SACS',
  distribuidor: 'Distribuidor Autorizado',
  integrador: 'Integrador Certificado',
  reseller: 'Reseller',
  consultor: 'Consultor Partner',
};
const partnerTipo = tipoLabels[resolved.tipo] || 'Partner SACS';

// ── Construir headers de respuesta ──
const headers = new Headers();

// Cookie display (no httponly) — leíble por client-side para mostrar strip
// Formato: encoded "Andrea Araujo|Embajador SACS"
const displayValue = `${partnerName}|${partnerTipo}`;
const isProd = (import.meta.env.PROD || process.env.NODE_ENV === 'production');
const displayCookieParts = [
  `sacs_ref_name=${encodeURIComponent(displayValue)}`,
  `Path=/`,
  `Max-Age=${90 * 24 * 60 * 60}`,
  `SameSite=Lax`,
];
if (isProd) displayCookieParts.push('Secure');
headers.append('Set-Cookie', displayCookieParts.join('; '));

// Visitor ID estable de 1 año en cookie sacs_pv (partner visitor).
// Distingue únicos vs recurrentes sin loggear IP cruda.
const cookieHeader = Astro.request.headers.get('cookie') || '';
const pvMatch = cookieHeader.match(/(?:^|;\s*)sacs_pv=([a-f0-9-]{36})/);
let visitorId = pvMatch?.[1] || '';
if (!visitorId) {
  visitorId = crypto.randomUUID();
  headers.append(
    'Set-Cookie',
    `sacs_pv=${visitorId}; Path=/; Max-Age=31536000; SameSite=Lax; HttpOnly`,
  );
}

// Cookie de atribución de partner (90 días)
headers.append('Set-Cookie', buildReferrerCookie(partnerId));

// Tracking de visita — fire-and-forget, no bloquea redirect
const noTrack = Astro.url.searchParams.get('notrack') === '1';
if (!noTrack) {
  const ua = Astro.request.headers.get('user-agent') || null;
  const ref = Astro.request.headers.get('referer') || null;
  const fwd = Astro.request.headers.get('x-forwarded-for') || '';
  const ip = fwd.split(',')[0]?.trim() || '';
  let ipHash: string | null = null;
  if (ip) {
    try {
      const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(ip + ':sacs'));
      ipHash = Array.from(new Uint8Array(buf)).slice(0, 12).map(b => b.toString(16).padStart(2, '0')).join('');
    } catch { /* ignore */ }
  }
  // Background insert — no await
  supabase.from('partner_link_visits').insert({
    partner_id: partnerId,
    slug,
    visitor_id: visitorId,
    ip_hash: ipHash,
    user_agent: ua,
    referrer: ref,
  }).then(() => {}, () => {});
}

// Si el partner pasa ?to=plan o ?to=demo, redirige a esos destinos específicos
// con ref. Por default va a home.
const toParam = Astro.url.searchParams.get('to');
let destination = `/?ref=${encodeURIComponent(partnerId)}`;
if (toParam === 'plan')   destination = `/planes?ref=${encodeURIComponent(partnerId)}`;
if (toParam === 'demo')   destination = `/agendar?ref=${encodeURIComponent(partnerId)}`;
if (toParam === 'trial')  destination = `/prueba-gratis?ref=${encodeURIComponent(partnerId)}`;
if (toParam === 'planes') destination = `/planes?ref=${encodeURIComponent(partnerId)}`;

headers.set('Location', destination);
headers.set('Cache-Control', 'no-cache, no-store');

return new Response(null, { status: 302, headers });
---
