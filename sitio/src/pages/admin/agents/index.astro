---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { supabase } from '../../../lib/supabase';

export const prerender = false;

const { data: configs } = await supabase.from('agent_configs').select('*').order('agent_name');
const { data: recentRuns } = await supabase
  .from('agent_runs')
  .select('id, created_at, agent_name, status, cost_usd, latency_ms, owner_id, deal_id')
  .order('created_at', { ascending: false })
  .limit(50);

const awaitingCount = (recentRuns || []).filter(r => r.status === 'awaiting_approval').length;
const failedLast24h = (recentRuns || []).filter(r => {
  if (r.status !== 'failed' && r.status !== 'timeout') return false;
  const age = Date.now() - new Date(r.created_at).getTime();
  return age < 86400000;
}).length;
---

<BaseLayout title="Agentes IA — SACS Admin">
  <div style="max-width:1200px;margin:0 auto;padding:32px 24px;font-family:-apple-system,Segoe UI,Helvetica,sans-serif">
    <h1 style="font-size:1.5rem;font-weight:800;margin:0 0 8px">Agentes IA</h1>
    <p style="color:#666;margin:0 0 24px">Estado + kill switches + últimos runs</p>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:32px">
      <div style="background:#fff;border:1px solid #e5e5e5;padding:16px;border-radius:8px">
        <div style="font-size:0.625rem;font-weight:700;color:#999;text-transform:uppercase;letter-spacing:0.08em">Agentes activos</div>
        <div style="font-size:1.5rem;font-weight:700;margin-top:4px">{(configs || []).filter(c => c.enabled).length} / {(configs || []).length}</div>
      </div>
      <div style="background:#fff;border:1px solid #e5e5e5;padding:16px;border-radius:8px">
        <div style="font-size:0.625rem;font-weight:700;color:#999;text-transform:uppercase;letter-spacing:0.08em">Esperando aprobación</div>
        <div style={`font-size:1.5rem;font-weight:700;margin-top:4px;color:${awaitingCount > 0 ? '#e65100' : '#1a1a1a'}`}>{awaitingCount}</div>
      </div>
      <div style="background:#fff;border:1px solid #e5e5e5;padding:16px;border-radius:8px">
        <div style="font-size:0.625rem;font-weight:700;color:#999;text-transform:uppercase;letter-spacing:0.08em">Fallas últimas 24h</div>
        <div style={`font-size:1.5rem;font-weight:700;margin-top:4px;color:${failedLast24h > 0 ? '#c62828' : '#1a1a1a'}`}>{failedLast24h}</div>
      </div>
    </div>

    <h2 style="font-size:1rem;font-weight:700;margin:0 0 12px">Configuración</h2>
    <div style="background:#fff;border:1px solid #e5e5e5;border-radius:8px;padding:12px 16px;margin-bottom:32px">
      <table style="width:100%;border-collapse:collapse;font-size:0.8125rem">
        <thead>
          <tr style="color:#999;font-size:0.6875rem;text-transform:uppercase;letter-spacing:0.06em">
            <th style="padding:8px 0;text-align:left">Agente</th>
            <th style="padding:8px 0;text-align:left">Estado</th>
            <th style="padding:8px 0;text-align:left">Auto-approve</th>
            <th style="padding:8px 0;text-align:left">Modelo</th>
            <th style="padding:8px 0;text-align:right">Cost/run max</th>
          </tr>
        </thead>
        <tbody>
          {(configs || []).map(c => (
            <tr style="border-top:1px solid #f0f0f0">
              <td style="padding:10px 0;font-weight:600">{c.agent_name}</td>
              <td style="padding:10px 0">
                <span style={`font-size:0.625rem;font-weight:700;padding:2px 8px;border-radius:12px;background:${c.enabled ? '#e8f5e9' : '#ffebee'};color:${c.enabled ? '#1b5e20' : '#b71c1c'}`}>
                  {c.enabled ? 'ON' : 'OFF'}
                </span>
              </td>
              <td style="padding:10px 0">{c.auto_approve ? '✓' : '—'}</td>
              <td style="padding:10px 0;color:#666;font-family:monospace;font-size:0.75rem">{c.current_model}</td>
              <td style="padding:10px 0;text-align:right;color:#666">${c.max_cost_per_run_usd}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h2 style="font-size:1rem;font-weight:700;margin:0 0 12px">Últimos runs</h2>
    <div style="background:#fff;border:1px solid #e5e5e5;border-radius:8px;padding:12px 16px">
      <table style="width:100%;border-collapse:collapse;font-size:0.8125rem">
        <thead>
          <tr style="color:#999;font-size:0.6875rem;text-transform:uppercase;letter-spacing:0.06em">
            <th style="padding:8px 0;text-align:left">Fecha</th>
            <th style="padding:8px 0;text-align:left">Agente</th>
            <th style="padding:8px 0;text-align:left">Estado</th>
            <th style="padding:8px 0;text-align:right">Latencia</th>
            <th style="padding:8px 0;text-align:right">Costo</th>
            <th style="padding:8px 0;text-align:right">Detalle</th>
          </tr>
        </thead>
        <tbody>
          {(recentRuns || []).slice(0, 30).map(r => {
            const dt = new Date(r.created_at);
            return (
              <tr style="border-top:1px solid #f0f0f0">
                <td style="padding:8px 0;color:#666;font-size:0.75rem">{dt.toLocaleDateString('es-MX')} {dt.toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' })}</td>
                <td style="padding:8px 0">{r.agent_name}</td>
                <td style="padding:8px 0">
                  <span style={`font-size:0.625rem;font-weight:700;padding:2px 8px;border-radius:12px;background:${
                    r.status === 'completed' || r.status === 'approved' ? '#e8f5e9' :
                    r.status === 'awaiting_approval' ? '#fff3e0' :
                    r.status === 'failed' || r.status === 'timeout' ? '#ffebee' :
                    r.status === 'rejected' ? '#fce4ec' : '#f5f5f5'
                  };color:${
                    r.status === 'completed' || r.status === 'approved' ? '#1b5e20' :
                    r.status === 'awaiting_approval' ? '#b35500' :
                    r.status === 'failed' || r.status === 'timeout' ? '#b71c1c' :
                    r.status === 'rejected' ? '#880e4f' : '#666'
                  }`}>
                    {r.status}
                  </span>
                </td>
                <td style="padding:8px 0;text-align:right;color:#666;font-size:0.75rem">{r.latency_ms ? `${r.latency_ms}ms` : '—'}</td>
                <td style="padding:8px 0;text-align:right;color:#666;font-size:0.75rem">{r.cost_usd ? `$${Number(r.cost_usd).toFixed(4)}` : '—'}</td>
                <td style="padding:8px 0;text-align:right"><a href={`/admin/agents/${r.id}`} style="color:#1a56db;text-decoration:none;font-size:0.75rem">Ver →</a></td>
              </tr>
            );
          })}
          {(recentRuns || []).length === 0 && (
            <tr><td colSpan="6" style="padding:40px 0;text-align:center;color:#aaa">Sin runs todavía. Corre <code>hello_agent</code> para empezar.</td></tr>
          )}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>
