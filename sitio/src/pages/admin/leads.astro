---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="CRM — Leads" description="Panel de leads de Sacs">

<section class="crm">
  <div class="crm-wrap">
    <!-- Top bar -->
    <div class="crm-topbar">
      <div class="crm-topbar-left">
        <span class="crm-logo">Sacs</span>
        <span class="crm-logo-tag">CRM</span>
      </div>
      <button id="crm-refresh" class="crm-refresh-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/></svg>
        Actualizar
      </button>
    </div>

    <!-- Stats row -->
    <div class="crm-stats">
      <div class="crm-stat crm-stat--primary">
        <div class="crm-stat-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4-4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <span class="crm-stat-num" id="stat-total">0</span>
        <span class="crm-stat-label">Total</span>
      </div>
      <div class="crm-stat crm-stat--warning">
        <div class="crm-stat-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <span class="crm-stat-num" id="stat-paso1">0</span>
        <span class="crm-stat-label">Esperando pago</span>
      </div>
      <div class="crm-stat crm-stat--success">
        <div class="crm-stat-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
        </div>
        <span class="crm-stat-num" id="stat-completado">0</span>
        <span class="crm-stat-label">Registrados</span>
      </div>
      <div class="crm-stat crm-stat--info">
        <div class="crm-stat-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <span class="crm-stat-num" id="stat-hoy">0</span>
        <span class="crm-stat-label">Hoy</span>
      </div>
    </div>

    <!-- Table card -->
    <div class="crm-card">
      <div class="crm-card-header">
        <h2 class="crm-card-title">Leads recientes</h2>
        <span class="crm-card-count" id="crm-total">0 leads</span>
      </div>
      <div class="crm-table-wrap">
        <table class="crm-table">
          <thead>
            <tr>
              <th>Fecha</th>
              <th>Contacto</th>
              <th>Empresa</th>
              <th>Detalle</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody id="crm-tbody">
            <tr><td colspan="6" class="crm-empty">Cargando leads...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
:global(nav), :global(.nav), :global(header), :global(footer), :global(.whatsapp-float) {
  display: none !important;
}

.crm {
  min-height: 100vh;
  background: #f8f9fb;
  padding: 0;
}

.crm-wrap {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px 48px;
}

/* Top bar */
.crm-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 0;
  border-bottom: 1px solid #e8eaed;
  margin-bottom: 32px;
}

.crm-topbar-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.crm-logo {
  font-family: var(--font-logo);
  font-size: 1.5rem;
  font-weight: 700;
  color: #1a1a1a;
}

.crm-logo-tag {
  font-size: 0.6875rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-primary);
  background: rgba(75, 123, 229, 0.08);
  padding: 3px 8px;
  border-radius: 4px;
}

.crm-refresh-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-body);
  font-size: 0.8125rem;
  font-weight: 600;
  color: #666;
  background: #fff;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 8px 16px;
  cursor: pointer;
  transition: all 0.15s ease;
}

.crm-refresh-btn:hover {
  background: #f5f5f5;
  color: #333;
}

/* Stats */
.crm-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 28px;
}

.crm-stat {
  background: #fff;
  border-radius: 14px;
  padding: 20px 24px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  border: 1px solid #f0f0f0;
  transition: box-shadow 0.2s ease;
}

.crm-stat:hover {
  box-shadow: 0 4px 16px rgba(0,0,0,0.06);
}

.crm-stat-icon {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
}

.crm-stat--primary .crm-stat-icon { background: rgba(75, 123, 229, 0.1); color: #4B7BE5; }
.crm-stat--warning .crm-stat-icon { background: rgba(232, 168, 56, 0.1); color: #E8A838; }
.crm-stat--success .crm-stat-icon { background: rgba(42, 181, 160, 0.1); color: #2AB5A0; }
.crm-stat--info .crm-stat-icon { background: rgba(108, 92, 231, 0.1); color: #6C5CE7; }

.crm-stat-num {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 800;
  color: #1a1a1a;
  line-height: 1;
}

.crm-stat-label {
  font-size: 0.75rem;
  font-weight: 500;
  color: #999;
  margin-top: 4px;
}

/* Table card */
.crm-card {
  background: #fff;
  border-radius: 16px;
  border: 1px solid #f0f0f0;
  overflow: hidden;
}

.crm-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 24px;
  border-bottom: 1px solid #f5f5f5;
}

.crm-card-title {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  color: #1a1a1a;
  margin: 0;
}

.crm-card-count {
  font-size: 0.8125rem;
  font-weight: 500;
  color: #999;
}

.crm-table-wrap {
  overflow-x: auto;
}

.crm-table {
  width: 100%;
  border-collapse: collapse;
}

.crm-table th {
  font-size: 0.6875rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: #aaa;
  padding: 14px 20px;
  text-align: left;
  background: #fafafa;
  white-space: nowrap;
}

.crm-table td {
  padding: 16px 20px;
  font-size: 0.8125rem;
  color: #555;
  border-bottom: 1px solid #f5f5f5;
  vertical-align: top;
}

.crm-table tbody tr:hover {
  background: #fafbfd;
}

.crm-table tbody tr:last-child td {
  border-bottom: none;
}

/* Contact cell */
.crm-contact-name {
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 2px;
}

.crm-contact-email {
  font-size: 0.75rem;
  color: #999;
}

/* Detail cell */
.crm-detail-row {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.crm-tag {
  display: inline-block;
  font-size: 0.6875rem;
  font-weight: 600;
  padding: 3px 8px;
  border-radius: 5px;
  background: #f5f5f5;
  color: #666;
}

/* Status badge */
.crm-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 0.6875rem;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 20px;
}

.crm-badge--paso1 {
  background: #fff3e0;
  color: #e65100;
}

.crm-badge--completado {
  background: #e8f5e9;
  color: #2e7d32;
}

.crm-badge-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

.crm-badge--paso1 .crm-badge-dot { background: #e65100; }
.crm-badge--completado .crm-badge-dot { background: #2e7d32; }

/* Action buttons */
.crm-action {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 0.75rem;
  font-weight: 600;
  text-decoration: none;
  padding: 6px 12px;
  border-radius: 6px;
  transition: all 0.15s ease;
}

.crm-action--wa {
  background: #e8f5e9;
  color: #2e7d32;
}

.crm-action--wa:hover {
  background: #c8e6c9;
}

.crm-action--email {
  background: #e3f2fd;
  color: #1565c0;
}

.crm-action--email:hover {
  background: #bbdefb;
}

.crm-actions {
  display: flex;
  gap: 6px;
}

/* Empty state */
.crm-empty {
  text-align: center;
  padding: 64px 20px !important;
  color: #bbb;
  font-size: 0.875rem;
}

/* Mobile */
@media (max-width: 767px) {
  .crm-stats { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .crm-wrap { padding: 0 16px 32px; }
  .crm-stat { padding: 16px 18px; }
  .crm-stat-num { font-size: 1.5rem; }
}
</style>

<script>
  const refreshBtn = document.getElementById('crm-refresh')!;
  const tbody = document.getElementById('crm-tbody')!;

  refreshBtn.addEventListener('click', loadLeads);
  loadLeads();

  async function loadLeads() {
    try {
      tbody.innerHTML = '<tr><td colspan="6" class="crm-empty">Cargando...</td></tr>';
      const res = await fetch('/api/get-leads');
      const data = await res.json();

      if (data.error) {
        tbody.innerHTML = `<tr><td colspan="6" class="crm-empty">Error: ${data.error}</td></tr>`;
        return;
      }

      const leads = data.leads || [];
      const today = new Date().toISOString().slice(0, 10);

      // Stats
      (document.getElementById('stat-total') as HTMLElement).textContent = String(leads.length);
      (document.getElementById('crm-total') as HTMLElement).textContent = `${leads.length} leads`;
      (document.getElementById('stat-paso1') as HTMLElement).textContent = String(leads.filter((l: any) => l.paso?.includes('Paso 1')).length);
      (document.getElementById('stat-completado') as HTMLElement).textContent = String(leads.filter((l: any) => l.paso?.includes('Registro')).length);
      (document.getElementById('stat-hoy') as HTMLElement).textContent = String(leads.filter((l: any) => l.timestamp?.startsWith(today)).length);

      if (leads.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="crm-empty">No hay leads aun. Registrate en /prueba-gratis para probarlo.</td></tr>';
        return;
      }

      tbody.innerHTML = leads.map((lead: any) => {
        const d = new Date(lead.timestamp);
        const date = d.toLocaleDateString('es-MX', { day: '2-digit', month: 'short', year: '2-digit' });
        const time = d.toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' });
        const isCompleted = lead.paso?.includes('Registro');
        const badgeClass = isCompleted ? 'crm-badge--completado' : 'crm-badge--paso1';
        const badgeText = isCompleted ? 'Registrado' : 'Pendiente';
        const waNum = lead.whatsapp?.replace(/\D/g, '') || '';
        const waLink = waNum ? `https://wa.me/52${waNum}` : '';

        return `<tr>
          <td>
            <div style="font-weight:600;color:#1a1a1a">${date}</div>
            <div style="font-size:0.6875rem;color:#aaa">${time}</div>
          </td>
          <td>
            <span class="crm-contact-name">${lead.nombre || '-'}</span>
            <span class="crm-contact-email">${lead.email || '-'}</span>
          </td>
          <td style="font-weight:600;color:#333">${lead.empresa || '-'}</td>
          <td>
            <div class="crm-detail-row">
              ${lead.giro ? `<span class="crm-tag">${lead.giro}</span>` : ''}
              ${lead.sucursales ? `<span class="crm-tag">${lead.sucursales} suc.</span>` : ''}
              ${lead.plan ? `<span class="crm-tag">${lead.plan}</span>` : ''}
            </div>
          </td>
          <td>
            <span class="crm-badge ${badgeClass}">
              <span class="crm-badge-dot"></span>
              ${badgeText}
            </span>
          </td>
          <td>
            <div class="crm-actions">
              ${waLink ? `<a href="${waLink}" target="_blank" class="crm-action crm-action--wa">WhatsApp</a>` : ''}
              ${lead.email ? `<a href="mailto:${lead.email}" class="crm-action crm-action--email">Email</a>` : ''}
            </div>
          </td>
        </tr>`;
      }).join('');

    } catch {
      tbody.innerHTML = '<tr><td colspan="6" class="crm-empty">Error de conexion</td></tr>';
    }
  }
</script>
