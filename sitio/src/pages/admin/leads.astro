---
// Redirect to unified CRM — pero primero el gate de admin (si no, un no-admin
// vería el meta-refresh y rebotaría hacia /admin/crm que ya lo bloquea; mejor
// cortar aquí directo).
import { requireFounder } from '../../lib/auth/requireFounder';
export const prerender = false;
const gate = await requireFounder(Astro);
if (gate) return gate;
---
<html>
<head>
  <meta http-equiv="refresh" content="0;url=/admin/crm?tab=pipeline" />
  <title>Redirecting...</title>
</head>
<body>
  <script is:inline>window.location.replace('/admin/crm?tab=pipeline');</script>
  <p>Redirigiendo a <a href="/admin/crm?tab=pipeline">CRM SACS</a>...</p>
</body>
</html>
