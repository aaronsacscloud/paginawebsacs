---
// Cambiar contraseña del admin logueado. Gated: solo equipo interno.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { requireFounder } from '../../lib/auth/requireFounder';
import { getSessionFromRequest } from '../../lib/auth/session';

export const prerender = false;

const gate = await requireFounder(Astro);
if (gate) return gate;
const user = await getSessionFromRequest(Astro.request);
---
<BaseLayout title="Cambiar contraseña — Admin SACS" description="Panel interno" noindex={true} bareLayout={true}>
  <div class="auth-wrap">
    <form id="pw-form" class="auth-card">
      <div class="auth-eyebrow">Panel interno</div>
      <h1 class="auth-title">Cambiar contraseña</h1>
      <p class="auth-sub">Sesión: <strong>{user?.email}</strong>. Al guardar se cerrarán todas tus sesiones y entrarás de nuevo con la contraseña nueva.</p>

      <label class="auth-label" for="current">Contraseña actual</label>
      <input id="current" type="password" autocomplete="current-password" class="auth-input" placeholder="••••••••" />

      <label class="auth-label" for="nueva">Contraseña nueva</label>
      <input id="nueva" type="password" autocomplete="new-password" required minlength="8" class="auth-input" placeholder="Mínimo 8 caracteres" />

      <label class="auth-label" for="confirmar">Confirmar nueva</label>
      <input id="confirmar" type="password" autocomplete="new-password" required minlength="8" class="auth-input" placeholder="Repite la nueva" />

      <div id="msg" class="auth-error" role="alert" hidden></div>

      <button id="submit-btn" type="submit" class="auth-btn">Guardar contraseña</button>
      <div class="auth-foot"><a href="/admin/crm">← Volver al CRM</a></div>
    </form>
  </div>

  <style>
    .auth-wrap { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #0f1115; padding: 24px; }
    .auth-card { width: 100%; max-width: 400px; background: #fff; border-radius: 16px; padding: 32px 30px; box-shadow: 0 24px 60px rgba(0,0,0,.35); font-family: 'DM Sans', system-ui, sans-serif; }
    .auth-eyebrow { font-size: 11px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; color: #2563EB; }
    .auth-title { font-size: 24px; font-weight: 800; letter-spacing: -.02em; margin: 6px 0 4px; color: #0F172A; }
    .auth-sub { font-size: 13px; color: #64748B; margin: 0 0 20px; line-height: 1.5; }
    .auth-label { display: block; font-size: 12px; font-weight: 700; color: #374151; margin: 14px 0 6px; }
    .auth-input { width: 100%; box-sizing: border-box; padding: 11px 13px; font-size: 14px; border: 1px solid #E2E5EA; border-radius: 10px; background: #fafafa; outline: none; font-family: inherit; }
    .auth-input:focus { border-color: #2563EB; background: #fff; }
    .auth-error { margin-top: 14px; padding: 10px 13px; border-radius: 8px; font-size: 13px; }
    .auth-error.err { background: #FEF2F2; border: 1px solid #FECACA; color: #B91C1C; }
    .auth-error.ok { background: #ECFDF5; border: 1px solid #A7F3D0; color: #047857; }
    .auth-btn { width: 100%; margin-top: 20px; padding: 12px; font-size: 14px; font-weight: 700; color: #fff; background: #0F172A; border: none; border-radius: 10px; cursor: pointer; font-family: inherit; }
    .auth-btn:disabled { opacity: .6; cursor: default; }
    .auth-foot { text-align: center; margin-top: 16px; font-size: 13px; }
    .auth-foot a { color: #64748B; text-decoration: none; }
  </style>

  <script>
    const form = document.getElementById('pw-form');
    const btn = document.getElementById('submit-btn');
    const msg = document.getElementById('msg');
    function show(text, ok) { msg.textContent = text; msg.className = 'auth-error ' + (ok ? 'ok' : 'err'); msg.hidden = false; }
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.hidden = true;
      const current = document.getElementById('current').value;
      const nueva = document.getElementById('nueva').value;
      const confirmar = document.getElementById('confirmar').value;
      if (nueva.length < 8) { show('La nueva contraseña debe tener al menos 8 caracteres.', false); return; }
      if (nueva !== confirmar) { show('La confirmación no coincide.', false); return; }
      btn.disabled = true; btn.textContent = 'Guardando…';
      try {
        const res = await fetch('/api/auth/change-password', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ current_password: current, new_password: nueva }) });
        const data = await res.json();
        if (!res.ok) { show(data.error || 'No se pudo cambiar la contraseña', false); btn.disabled = false; btn.textContent = 'Guardar contraseña'; return; }
        show('Contraseña actualizada. Redirigiendo al login…', true);
        setTimeout(() => { window.location.href = '/admin/login'; }, 1400);
      } catch (e) {
        show('Error de conexión. Intenta de nuevo.', false);
        btn.disabled = false; btn.textContent = 'Guardar contraseña';
      }
    });
  </script>
</BaseLayout>
