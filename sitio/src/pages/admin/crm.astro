---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CrmDashboard from '../../components/admin/CrmDashboard';
import { requireFounder } from '../../lib/auth/requireFounder';

export const prerender = false;

// Solo equipo interno (founder/cs). Partner o anónimo → login/portal.
const gate = await requireFounder(Astro);
if (gate) return gate;
---

<BaseLayout title="CRM — Sacs" description="CRM interno de Sacs" noindex={true}>
<CrmDashboard client:only="react" />
</BaseLayout>

<style is:global>
nav, .nav, header, footer, .wa-bar, .final-cta {
  display: none !important;
}
main { padding: 0 !important; margin: 0 !important; }
</style>
