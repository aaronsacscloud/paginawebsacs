---
import BaseLayout from '../../layouts/BaseLayout.astro';
export const prerender = false;
---
<BaseLayout
  title="Recuperar contraseña — Partners SACS"
  description="Recibe un link para restablecer tu contraseña de partner SACS"
  noindex={true}
  bareLayout={true}
>
  <main class="auth-page">
    <div class="auth-card">
      <a href="/" class="auth-logo">Sacs</a>
      <h1 class="auth-title">¿Olvidaste tu contraseña?</h1>
      <p class="auth-sub">Ingresa tu email y te enviaremos un link para crear una nueva.</p>

      <form id="forgot-form" class="auth-form" novalidate>
        <label class="auth-field">
          <span>Email</span>
          <input type="email" id="email" name="email" autocomplete="email" required placeholder="tu@correo.com" />
        </label>
        <button type="submit" class="auth-btn" id="submit-btn">Enviar link</button>
        <div id="success-msg" class="auth-success" hidden>
          Si tu email está registrado, recibirás un correo en los próximos minutos.
          Revisa también tu carpeta de spam.
        </div>
      </form>

      <div class="auth-foot">
        <a href="/partner/login">← Volver a inicio de sesión</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .auth-page { min-height: 100vh; background: #fafafa; display: flex; align-items: center; justify-content: center; padding: 24px 16px; font-family: var(--font-body); }
  .auth-card { width: 100%; max-width: 420px; background: #fff; border-radius: 18px; padding: 40px 32px; box-shadow: 0 20px 60px -20px rgba(0,0,0,0.10), 0 4px 16px -4px rgba(0,0,0,0.05); text-align: center; }
  .auth-logo { display: inline-block; font-family: 'Clash Display', sans-serif; font-size: 1.75rem; font-weight: 700; color: #1a1a1a; text-decoration: none; letter-spacing: -0.02em; margin-bottom: 18px; }
  .auth-title { font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; color: #1a1a1a; margin: 0 0 8px; letter-spacing: -0.015em; }
  .auth-sub { font-size: 0.875rem; color: #666; margin: 0 0 28px; line-height: 1.5; }
  .auth-form { display: flex; flex-direction: column; gap: 14px; text-align: left; }
  .auth-field { display: flex; flex-direction: column; gap: 6px; }
  .auth-field > span { font-size: 0.6875rem; font-weight: 700; color: #999; letter-spacing: 0.08em; text-transform: uppercase; }
  .auth-field input { width: 100%; box-sizing: border-box; padding: 13px 14px; font-family: inherit; font-size: 0.9375rem; color: #1a1a1a; border: 1px solid #e5e5e5; border-radius: 10px; background: #fff; outline: none; transition: border-color 0.15s, box-shadow 0.15s; }
  .auth-field input:focus { border-color: #4B7BE5; box-shadow: 0 0 0 3px rgba(75,123,229,0.10); }
  .auth-btn { margin-top: 6px; padding: 13px 20px; background: #1a1a1a; color: #fff; font-family: inherit; font-size: 0.9375rem; font-weight: 600; border: none; border-radius: 10px; cursor: pointer; transition: background 0.15s ease; }
  .auth-btn:hover { background: #4B7BE5; }
  .auth-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .auth-success { padding: 14px 16px; background: rgba(42,181,160,0.08); border-left: 3px solid #2AB5A0; color: #1a5a4f; font-size: 0.8125rem; line-height: 1.5; border-radius: 4px; }
  .auth-foot { margin-top: 24px; font-size: 0.8125rem; color: #888; text-align: center; }
  .auth-foot a { color: #4B7BE5; text-decoration: none; }
  .auth-foot a:hover { text-decoration: underline; }
</style>

<script>
  const form = document.getElementById('forgot-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const ok = document.getElementById('success-msg') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    btn.disabled = true;
    btn.textContent = 'Enviando…';
    try {
      await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
    } catch {/* swallow */}
    ok.hidden = false;
    btn.textContent = 'Link enviado';
  });
</script>
