---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSessionFromRequest } from '../../lib/auth/session';
import PortalShell from '../../components/partner-portal/PortalShell.tsx';

export const prerender = false;

// Demo mode bypass: ?demo=1 muestra el portal con datos mock sin requerir
// sesión. Útil para QA, preview a partners potenciales, screenshots.
const isDemo = Astro.url.searchParams.get('demo') === '1';

let user: any = null;
if (isDemo) {
  user = { id: 'demo-partner-id', nombre: 'Andrea Araujo', email: 'andrea@ejemplo.mx', role: 'partner' };
} else {
  user = await getSessionFromRequest(Astro.request);
  if (!user) {
    return Astro.redirect('/partner/login');
  }
  if (user.role !== 'partner' && user.role !== 'founder') {
    return Astro.redirect('/');
  }
}
---
<BaseLayout
  title={`Portal · ${user.nombre || 'Partner'} — SACS`}
  description="Tu panel de partner SACS: comisiones, pagos, prospectos y métricas en tiempo real."
  noindex={true}
  bareLayout={true}
>
  <PortalShell
    client:only="react"
    initialUser={{ id: user.id, nombre: user.nombre || '', email: user.email || '' }}
  />
</BaseLayout>
