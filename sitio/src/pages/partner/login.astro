---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSessionFromRequest } from '../../lib/auth/session';

export const prerender = false;

// If already logged in, redirect
const user = await getSessionFromRequest(Astro.request);
if (user) {
  return Astro.redirect(user.role === 'partner' ? '/partner/portal' : '/admin/crm');
}
---
<BaseLayout
  title="Iniciar sesión — Partners SACS"
  description="Accede a tu portal de partner SACS"
  noindex={true}
  bareLayout={true}
>
  <main class="auth-page">
    <div class="auth-card">
      <a href="/" class="auth-logo">Sacs</a>
      <h1 class="auth-title">Portal de Partner</h1>
      <p class="auth-sub">Inicia sesión para ver tus comisiones, prospectos y pagos.</p>

      <form id="login-form" class="auth-form" novalidate>
        <label class="auth-field">
          <span>Email</span>
          <input type="email" id="email" name="email" autocomplete="email" required placeholder="tu@correo.com" />
        </label>
        <label class="auth-field">
          <span>Contraseña</span>
          <input type="password" id="password" name="password" autocomplete="current-password" required minlength="8" />
        </label>
        <button type="submit" class="auth-btn" id="submit-btn">Entrar</button>
        <div id="error-msg" class="auth-error" role="alert" hidden></div>
      </form>

      <div class="auth-foot">
        <a href="/partner/forgot-password">¿Olvidaste tu contraseña?</a>
        <span class="auth-foot-sep">·</span>
        <span>¿No tienes cuenta? <a href="/partners">Conoce el programa</a></span>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .auth-page {
    min-height: 100vh;
    background: #fafafa;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
    font-family: var(--font-body);
  }
  .auth-card {
    width: 100%;
    max-width: 420px;
    background: #fff;
    border-radius: 18px;
    padding: 40px 32px;
    box-shadow: 0 20px 60px -20px rgba(0,0,0,0.10), 0 4px 16px -4px rgba(0,0,0,0.05);
    text-align: center;
  }
  .auth-logo {
    display: inline-block;
    font-family: 'Clash Display', sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: #1a1a1a;
    text-decoration: none;
    letter-spacing: -0.02em;
    margin-bottom: 18px;
  }
  .auth-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 8px;
    letter-spacing: -0.015em;
  }
  .auth-sub {
    font-size: 0.875rem;
    color: #666;
    margin: 0 0 28px;
    line-height: 1.5;
  }
  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-align: left;
  }
  .auth-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .auth-field > span {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #999;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .auth-field input {
    width: 100%;
    box-sizing: border-box;
    padding: 13px 14px;
    font-family: inherit;
    font-size: 0.9375rem;
    color: #1a1a1a;
    border: 1px solid #e5e5e5;
    border-radius: 10px;
    background: #fff;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .auth-field input:focus {
    border-color: #4B7BE5;
    box-shadow: 0 0 0 3px rgba(75,123,229,0.10);
  }
  .auth-btn {
    margin-top: 6px;
    padding: 13px 20px;
    background: #1a1a1a;
    color: #fff;
    font-family: inherit;
    font-size: 0.9375rem;
    font-weight: 600;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .auth-btn:hover { background: #4B7BE5; }
  .auth-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .auth-error {
    padding: 10px 12px;
    background: rgba(229,75,75,0.08);
    border-left: 3px solid #E54B4B;
    color: #b93333;
    font-size: 0.8125rem;
    border-radius: 4px;
  }
  .auth-foot {
    margin-top: 24px;
    font-size: 0.8125rem;
    color: #888;
    text-align: center;
    line-height: 1.6;
  }
  .auth-foot a {
    color: #4B7BE5;
    text-decoration: none;
  }
  .auth-foot a:hover { text-decoration: underline; }
  .auth-foot-sep { margin: 0 8px; color: #ddd; }
</style>

<script>
  const form = document.getElementById('login-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const err = document.getElementById('error-msg') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    err.hidden = true;
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const password = (document.getElementById('password') as HTMLInputElement).value;

    btn.disabled = true;
    btn.textContent = 'Verificando…';

    try {
      const res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });
      const data = await res.json();
      if (!res.ok) {
        err.textContent = data.error || 'No se pudo iniciar sesión';
        err.hidden = false;
        btn.disabled = false;
        btn.textContent = 'Entrar';
        return;
      }
      window.location.href = data.redirect || '/partner/portal';
    } catch (e: any) {
      err.textContent = 'Error de conexión. Intenta de nuevo.';
      err.hidden = false;
      btn.disabled = false;
      btn.textContent = 'Entrar';
    }
  });
</script>
