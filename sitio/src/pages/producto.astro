---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABanner from '../components/CTABanner.astro';
import { productSections } from '../data/product';

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'SACS',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  description: 'Plataforma de gestión de retail todo-en-uno con punto de venta, inventario, CRM, reportes y asistente de IA.',
  featureList: productSections.flatMap((s) => s.features),
};
---

<BaseLayout
  title="Producto"
  description="Conoce todas las funcionalidades de SACS: punto de venta, inventario multi-sucursal, CRM, reportes avanzados y AXO, tu asistente de IA para retail."
  structuredData={productSchema}
>
  <section class="producto-hero section">
    <div class="container">
      <div class="producto-header">
        <span class="eyebrow badge badge-blue">Plataforma</span>
        <h1 class="display-l">Todo lo que tu retail necesita, en un solo lugar</h1>
        <p class="body-large">
          SACS integra las herramientas que antes requerían 5 apps diferentes.
          Diseñado para retailers mexicanos que quieren crecer sin caos.
        </p>
      </div>
    </div>
  </section>

  {productSections.map((s, i) => (
    <section class:list={['feature-detail', 'section', { alt: i % 2 === 1 }]} id={s.id}>
      <div class="container feature-grid">
        <div class="feature-text">
          <span class="eyebrow" style="color: var(--color-primary);">{s.eyebrow}</span>
          <h2>{s.title}</h2>
          <p class="body-large">{s.description}</p>
          <ul class="feature-list">
            {s.features.map((f) => (
              <li>{f}</li>
            ))}
          </ul>
        </div>
        <div class="feature-visual">
          <div class="feature-placeholder">
            <p class="body-small" style="color: var(--color-text-tertiary);">
              {s.eyebrow}
            </p>
          </div>
        </div>
      </div>
    </section>
  ))}

  <CTABanner
    title="¿Listo para simplificar tu operación?"
    subtitle="Prueba SACS gratis y descubre por qué cientos de retailers ya lo usan."
  />
</BaseLayout>

<style>
  .producto-hero {
    padding-top: calc(72px + var(--space-16));
    padding-bottom: var(--space-8);
  }

  .producto-header {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
  }

  .producto-header .badge {
    margin-bottom: var(--space-5);
  }

  .producto-header h1 {
    margin-bottom: var(--space-4);
  }

  .producto-header .body-large {
    color: var(--color-text-secondary);
  }

  .feature-detail.alt {
    background: var(--color-bg-secondary);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .feature-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
    }

    .feature-detail:nth-child(even) .feature-grid {
      direction: rtl;
    }

    .feature-detail:nth-child(even) .feature-grid > * {
      direction: ltr;
    }
  }

  .feature-text .eyebrow {
    display: block;
    margin-bottom: var(--space-4);
  }

  .feature-text h2 {
    margin-bottom: var(--space-4);
  }

  .feature-text .body-large {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .feature-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .feature-list li {
    position: relative;
    padding-left: var(--space-6);
    color: var(--color-text-secondary);
  }

  .feature-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-secondary);
    font-weight: 700;
  }

  .feature-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    background: var(--color-bg-card);
    border-radius: var(--radius-2xl);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border-light);
  }
</style>
