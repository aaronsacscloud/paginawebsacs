---
export const prerender = false;
import CancelPage from '../../components/scheduling/CancelPage';

const token = Astro.url.searchParams.get('token') || '';

if (!token) {
  return new Response('<html><body style="font-family:sans-serif;display:flex;align-items:center;justify-content:center;min-height:100vh;"><p>Token de cancelacion requerido.</p></body></html>', { status: 400, headers: { 'Content-Type': 'text/html' } });
}
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cancelar reunion — Sacs</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Sora:wght@600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #FAFAF8; -webkit-font-smoothing: antialiased; }
  </style>
</head>
<body>
  <CancelPage client:only="react" token={token} />
</body>
</html>
