---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingLoader from '../../components/scheduling/BookingLoader';
import { supabase } from '../../lib/supabase';

const slug = Astro.params.slug || 'demo';

let eventType: any = null;
let questions: any[] = [];

try {
  const { data } = await supabase
    .from('event_types')
    .select('*')
    .eq('slug', slug)
    .eq('activo', true)
    .single();
  eventType = data;

  if (eventType?.owner_id) {
    const { data: host } = await supabase.from('team_members').select('nombre, email').eq('id', eventType.owner_id).single();
    if (host) eventType.team_members = host;
  }

  if (eventType) {
    const { data: q } = await supabase.from('booking_questions').select('*').eq('event_type_id', eventType.id).eq('activo', true).order('orden');
    questions = q || [];
  }
} catch {}

if (!eventType) {
  return new Response('<html><body style="font-family:sans-serif;display:flex;align-items:center;justify-content:center;min-height:100vh;"><p>Evento no encontrado</p></body></html>', { status: 404, headers: { 'Content-Type': 'text/html' } });
}
---

<BaseLayout title={`Agendar ${eventType.nombre} — Sacs`} description={eventType.descripcion || 'Agenda tu sesión con SACS'} noindex={true}>
  <BookingLoader client:only="react" eventType={eventType} questions={questions} />
</BaseLayout>

<style is:global>
  .nav, .wa-bar, footer { display: none !important; }
  main { padding: 0 !important; margin: 0 !important; }
</style>
