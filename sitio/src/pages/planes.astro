---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABanner from '../components/CTABanner.astro';

const plans = [
  {
    name: 'Semilla',
    price: 'Gratis',
    period: '',
    description: 'Para emprendedores que inician su camino en retail.',
    features: [
      '1 sucursal',
      'Punto de venta básico',
      'Inventario simple',
      'Reportes esenciales',
      'Soporte por email',
    ],
    cta: 'Empezar gratis',
    highlighted: false,
  },
  {
    name: 'Crecimiento',
    price: '$799',
    period: '/mes por sucursal',
    description: 'Para negocios que necesitan escalar sin fricciones.',
    features: [
      'Hasta 5 sucursales',
      'POS completo + CFDI',
      'Inventario multi-sucursal',
      'CRM con segmentación',
      'AXO — Asistente de IA',
      'Reportes avanzados',
      'Soporte prioritario',
    ],
    cta: 'Comenzar prueba',
    highlighted: true,
  },
  {
    name: 'Empresa',
    price: 'Personalizado',
    period: '',
    description: 'Para retailers con operaciones complejas y multi-ubicación.',
    features: [
      'Sucursales ilimitadas',
      'Todo de Crecimiento',
      'API e integraciones',
      'Onboarding dedicado',
      'Account manager',
      'SLA garantizado',
      'Personalización avanzada',
    ],
    cta: 'Contactar ventas',
    highlighted: false,
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Puedo probar SACS gratis?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, el plan Semilla es completamente gratuito e incluye las funcionalidades básicas para una sucursal.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué incluye el 10% de impacto social?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'El 10% de cada licencia se destina a programas de capacitación digital, apoyo a emprendedores locales y conservación de ecosistemas en México.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Puedo cambiar de plan en cualquier momento?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, puedes escalar o reducir tu plan cuando lo necesites, sin penalizaciones.',
      },
    },
  ],
};
---

<BaseLayout
  title="Planes y precios"
  description="Elige el plan SACS ideal para tu negocio. Desde gratis para emprendedores hasta planes personalizados para retailers multi-sucursal."
  structuredData={faqSchema}
>
  <section class="pricing-hero section">
    <div class="container">
      <div class="pricing-header">
        <span class="eyebrow badge badge-blue">Planes transparentes</span>
        <h1 class="display-l">Un plan para cada etapa de tu negocio</h1>
        <p class="body-large">
          Sin sorpresas, sin contratos forzados. Escala cuando estés listo.
        </p>
      </div>

      <div class="plans-grid">
        {plans.map((plan) => (
          <div class:list={['plan-card', 'card', { highlighted: plan.highlighted }]}>
            {plan.highlighted && <span class="plan-badge badge badge-teal">Más popular</span>}
            <h3>{plan.name}</h3>
            <div class="plan-price">
              <span class="price-amount">{plan.price}</span>
              {plan.period && <span class="price-period">{plan.period}</span>}
            </div>
            <p class="plan-description">{plan.description}</p>
            <ul class="plan-features">
              {plan.features.map((f) => (
                <li>{f}</li>
              ))}
            </ul>
            <a
              href="/contacto"
              class:list={['btn', plan.highlighted ? 'btn-primary' : 'btn-secondary']}
              style="width: 100%;"
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq section">
    <div class="container faq-container">
      <h2>Preguntas frecuentes</h2>
      <div class="faq-list">
        {faqSchema.mainEntity.map((q) => (
          <details class="faq-item">
            <summary>{q.name}</summary>
            <p>{q.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    title="¿No estás seguro qué plan necesitas?"
    subtitle="Agenda una llamada con nuestro equipo y te ayudamos a elegir."
    ctaLabel="Hablar con ventas"
  />
</BaseLayout>

<style>
  .pricing-hero {
    padding-top: calc(72px + var(--space-16));
  }

  .pricing-header {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: var(--space-16);
  }

  .pricing-header .badge {
    margin-bottom: var(--space-5);
  }

  .pricing-header h1 {
    margin-bottom: var(--space-4);
  }

  .pricing-header .body-large {
    color: var(--color-text-secondary);
  }

  .plans-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    max-width: 1000px;
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .plans-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .plan-card {
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .plan-card.highlighted {
    border: 2px solid var(--color-primary);
    box-shadow: var(--shadow-lg);
  }

  .plan-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
  }

  .plan-price {
    margin-block: var(--space-4);
  }

  .price-amount {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .price-period {
    font-size: 0.875rem;
    color: var(--color-text-tertiary);
  }

  .plan-description {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    margin-bottom: var(--space-6);
  }

  .plan-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
    flex-grow: 1;
  }

  .plan-features li {
    position: relative;
    padding-left: var(--space-6);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }

  .plan-features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-secondary);
    font-weight: 700;
  }

  /* FAQ */
  .faq {
    background: var(--color-bg-secondary);
  }

  .faq-container {
    max-width: 720px;
  }

  .faq h2 {
    margin-bottom: var(--space-10);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .faq-item {
    background: var(--color-bg-card);
    border-radius: var(--radius-lg);
    padding: var(--space-5) var(--space-6);
    border: 1px solid var(--color-border-light);
    cursor: pointer;
  }

  .faq-item summary {
    font-weight: 600;
    color: var(--color-text-primary);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .faq-item summary::after {
    content: '+';
    font-size: 1.5rem;
    color: var(--color-text-tertiary);
    transition: transform var(--duration-fast) ease;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-item p {
    margin-top: var(--space-4);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
</style>
