  list-style: none;
  padding: 0;
  margin: 0 0 var(--space-8);
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.enterprise-points li {
  font-size: 0.9375rem;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
  padding-left: 24px;
  position: relative;
}

.enterprise-points li::before {
  content: '✓';
  position: absolute;
  left: 0;
  color: var(--color-secondary);
  font-weight: 700;
}

.enterprise-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16px 36px;
  background: #fff;
  color: var(--color-bg-dark);
  font-family: var(--font-body);
  font-size: 1rem;
  font-weight: 600;
  border-radius: var(--radius-full);
  text-decoration: none;
  transition: all var(--duration-fast) var(--ease-default);
}

.enterprise-btn:hover {
  background: #f0f0f0;
  transform: translateY(-1px);
  box-shadow: 0 4px 20px rgba(255, 255, 255, 0.15);
}

/* Enterprise card */
.enterprise-visual {
  display: flex;
  justify-content: center;
  align-items: center;
}

.enterprise-card {
  position: relative;
  width: 100%;
  max-width: 340px;
}

.enterprise-card-glow {
  position: absolute;
  inset: -20px;
  background: radial-gradient(circle at 50% 50%, rgba(75, 123, 229, 0.2) 0%, transparent 70%);
  border-radius: 50%;
  animation: enterprise-pulse 4s ease-in-out infinite;
}

@keyframes enterprise-pulse {
  0%, 100% { transform: scale(1); opacity: 0.5; }
  50% { transform: scale(1.08); opacity: 0.8; }
}

.enterprise-card-inner {
  position: relative;
  background: linear-gradient(145deg, #2a2a3e 0%, #1a1a2e 100%);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-xl);
  padding: var(--space-8);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
}

.enterprise-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-8);
}

.enterprise-card-logo {
  font-family: var(--font-logo);
  font-size: 1.5rem;
  font-weight: 700;
  color: #fff;
}

.enterprise-card-label {
  font-size: 0.6875rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-secondary);
  background: rgba(42, 181, 160, 0.15);
  padding: 4px 12px;
  border-radius: var(--radius-full);
}

.enterprise-card-body {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-8);
  margin-bottom: var(--space-6);
}

.enterprise-card-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.enterprise-card-stat-num {
  font-family: var(--font-display);
  font-size: 3rem;
  font-weight: 800;
  color: #fff;
  line-height: 1;
}

.enterprise-card-stat-label {
  font-size: 0.6875rem;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.45);
  margin-top: 6px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.enterprise-card-divider {
  width: 1px;
  height: 48px;
  background: rgba(255, 255, 255, 0.1);
}

.enterprise-card-features {
  display: flex;
  justify-content: center;
  gap: var(--space-4);
  margin-bottom: var(--space-6);
  flex-wrap: wrap;
}

.enterprise-card-features span {
  font-size: 0.75rem;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.06);
  padding: 6px 14px;
  border-radius: var(--radius-full);
}

.enterprise-card-price {
  text-align: center;
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--color-primary);
  letter-spacing: -0.02em;
}

@media (max-width: 767px) {
  .enterprise-card { max-width: 280px; }
  .enterprise-card-stat-num { font-size: 2.25rem; }
}

@media (prefers-reduced-motion: reduce) {
  .enterprise-card-glow { animation: none; }
}

/* ═══════════════════════════════════════
   ROI CALCULATOR
   ═══════════════════════════════════════ */
.calc-section {
  padding: var(--space-16) 0;
  background: #fff;
}

@media (min-width: 768px) { .calc-section { padding: var(--space-20) 0; } }
@media (min-width: 1024px) { .calc-section { padding: var(--space-24) 0; } }

.calc-eyebrow {
  display: block;
  text-align: center;
  font-family: var(--font-body);
  font-size: clamp(0.75rem, 1vw, 0.8125rem);
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-primary);
  margin-bottom: var(--space-4);
}

.calc-title {
  font-family: var(--font-display);
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  font-weight: 800;
  color: var(--color-text-primary);
  text-align: center;
  margin: 0 0 var(--space-3);
  letter-spacing: -0.03em;
}

.calc-subtitle {
  font-size: 1rem;
  color: var(--color-text-tertiary);
  text-align: center;
  margin: 0 0 var(--space-12);
}

.calc-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-10);
}

@media (min-width: 1024px) {
  .calc-grid { grid-template-columns: 1fr 400px; gap: var(--space-12); }
}

/* Plan selector */
.calc-plan-selector {
  margin-bottom: var(--space-8);
}

.calc-plan-options {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
  margin-top: var(--space-3);
}

@media (min-width: 768px) {
  .calc-plan-options { grid-template-columns: repeat(4, 1fr); }
}

.calc-plan-opt {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  padding: 12px 8px;
  border: 2px solid var(--color-border-light);
  border-radius: var(--radius-md);
  background: #fff;
  cursor: pointer;
  font-family: var(--font-display);
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--color-text-primary);
  transition: all var(--duration-fast) var(--ease-default);
}

.calc-plan-opt span {
  font-family: var(--font-body);
  font-size: 0.6875rem;
  font-weight: 500;
  color: var(--color-text-tertiary);
}

.calc-plan-opt.active {
  border-color: var(--color-primary);
  background: rgba(75, 123, 229, 0.06);
}

.calc-plan-opt.active span {
  color: var(--color-primary);
}

.calc-plan-opt:hover:not(.active) {
  border-color: var(--color-border);
}

/* Sliders */
.calc-slider-group {
  margin-bottom: var(--space-8);
}

.calc-slider-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: var(--space-3);
}

.calc-slider-label {
  font-family: var(--font-display);
  font-size: 0.9375rem;
  font-weight: 700;
  color: var(--color-text-primary);
}

.calc-slider-value {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 800;
  color: var(--color-primary);
}

.calc-range {
  -webkit-appearance: none;
  appearance: none;
  width: 100%;
  height: 6px;
  border-radius: 3px;
  background: var(--color-bg-secondary);
  outline: none;
  cursor: pointer;
}

.calc-range::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--color-primary);
  border: 3px solid #fff;
  box-shadow: 0 2px 8px rgba(75, 123, 229, 0.3);
  cursor: pointer;
  transition: transform var(--duration-fast) var(--ease-default);
}

.calc-range::-webkit-slider-thumb:hover {
  transform: scale(1.15);
}

.calc-range::-moz-range-thumb {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--color-primary);
  border: 3px solid #fff;
  box-shadow: 0 2px 8px rgba(75, 123, 229, 0.3);
  cursor: pointer;
}

.calc-slider-ticks {
  display: flex;
  justify-content: space-between;
  margin-top: 6px;
  font-size: 0.6875rem;
  color: var(--color-text-tertiary);
}

/* Benefits */
.calc-benefits {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}

.calc-category-label {
  display: block;
  font-size: 0.6875rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-text-tertiary);
  margin-bottom: var(--space-3);
}

.calc-benefit {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 0;
  border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  cursor: pointer;
  transition: opacity var(--duration-fast) var(--ease-default);
}

.calc-benefit:has(input:not(:checked)) {
  opacity: 0.4;
}

.calc-benefit input {
  position: absolute;
  opacity: 0;
  width: 0;
  height: 0;
}

.calc-benefit-check {
  width: 20px;
  height: 20px;
  border-radius: 6px;
  border: 2px solid var(--color-border);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast) var(--ease-default);
}

.calc-benefit input:checked ~ .calc-benefit-check {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.calc-benefit input:checked ~ .calc-benefit-check::after {
  content: '✓';
  color: #fff;
  font-size: 11px;
  font-weight: 700;
}

.calc-benefit-info {
  flex: 1;
  min-width: 0;
}

.calc-benefit-text {
  display: block;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-text-primary);
}

.calc-benefit-why {
  display: block;
  font-size: 0.75rem;
  font-weight: 400;
  color: var(--color-text-tertiary);
  line-height: 1.4;
  margin-top: 2px;
}

.calc-benefit-pct {
  font-size: 0.6875rem;
  font-weight: 600;
  color: var(--color-text-tertiary);
  white-space: nowrap;
  margin-left: auto;
}

.calc-benefit-save {
  font-family: var(--font-display);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--color-secondary);
  white-space: nowrap;
  min-width: 70px;
  text-align: right;
}

/* Results */
.calc-results {
  position: sticky;
  top: 90px;
  align-self: start;
}

.calc-results-card {
  background: var(--color-bg-primary);
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-xl);
  padding: var(--space-8);
}

.calc-results-title {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin: 0 0 var(--space-6);
  text-align: center;
}

.calc-results-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-6);
  margin-bottom: var(--space-5);
}

.calc-result-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.calc-result-icon {
  font-size: 1.5rem;
  margin-bottom: 4px;
}

.calc-result-num {
  font-family: var(--font-display);
  font-size: clamp(1.75rem, 3vw, 2.25rem);
  font-weight: 800;
  color: var(--color-primary);
  letter-spacing: -0.03em;
  line-height: 1;
  transition: color 0.3s ease;
}

.calc-result-num--time {
  color: var(--color-secondary);
}

.calc-result-label {
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--color-text-tertiary);
  margin-top: 4px;
}

.calc-result-divider {
  width: 1px;
  height: 48px;
  background: var(--color-border-light);
}

.calc-results-equiv {
  text-align: center;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text-tertiary);
  margin-bottom: var(--space-6);
}

.calc-results-equiv span {
  font-weight: 800;
  color: var(--color-text-primary);
}

.calc-results-divider {
  height: 1px;
  background: var(--color-border-light);
  margin-bottom: var(--space-5);
}

.calc-results-plan {
  text-align: center;
  margin-bottom: var(--space-6);
}

.calc-results-plan-label {
  display: block;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--color-text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 4px;
}

.calc-results-plan-price {
  display: block;
  font-family: var(--font-display);
  font-size: 1.125rem;
  font-weight: 800;
  color: var(--color-text-primary);
  margin-bottom: 4px;
}

.calc-results-plan-roi {
  font-size: 0.875rem;
  color: var(--color-text-secondary);
}

.calc-results-plan-roi strong {
  color: var(--color-secondary);
  font-weight: 800;
}

.calc-results-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 16px;
  background: var(--color-primary);
  color: #fff;
  font-family: var(--font-body);
  font-size: 1rem;
  font-weight: 600;
  border-radius: var(--radius-full);
  text-decoration: none;
  transition: all var(--duration-fast) var(--ease-default);
}

.calc-results-btn:hover {
  background: var(--color-primary-hover);
  transform: scale(1.02);
}

@media (max-width: 1023px) {
  .calc-results { position: static; }
}

/* ═══════════════════════════════════════
   UNIVERSAL FEATURES
   ═══════════════════════════════════════ */
.universal-section {
  background: var(--color-bg-secondary);
  padding: var(--space-16) 0;
}

@media (min-width: 768px) {
  .universal-section { padding: var(--space-20) 0; }
}

.universal-title {
  font-family: var(--font-display);
  font-size: clamp(1.25rem, 2vw, 1.5rem);
  font-weight: 700;
  color: var(--color-text-primary);
  text-align: center;
  margin: 0 0 var(--space-10);
  letter-spacing: -0.02em;
}

.universal-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-4) var(--space-3);
  max-width: 900px;
  margin: 0 auto;
}

@media (min-width: 768px) {
  .universal-grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-5) var(--space-6); }
}

@media (min-width: 1024px) {
  .universal-grid { grid-template-columns: repeat(4, 1fr); }
}

.universal-item {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.universal-check {
  flex-shrink: 0;
  color: var(--color-secondary);
}

/* ═══════════════════════════════════════
   COMPARISON TABLE
   ═══════════════════════════════════════ */
.comparison-section {
  padding: var(--space-16) 0;
  content-visibility: auto;
  contain-intrinsic-size: 0 600px;
}

@media (min-width: 768px) {
  .comparison-section { padding: var(--space-20) 0; }
}

@media (min-width: 1024px) {
  .comparison-section { padding: var(--space-24) 0; }
}

.comparison-title {
  font-family: var(--font-display);
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  font-weight: 800;
  color: var(--color-text-primary);
  text-align: center;
  margin: 0 0 var(--space-3);
  letter-spacing: -0.03em;
}

.comparison-subtitle {
  font-size: 1rem;
  color: var(--color-text-tertiary);
  text-align: center;
  margin: 0 0 var(--space-10);
}

/* Desktop table header */
.comparison-header {
  display: none;
}

@media (min-width: 768px) {
  .comparison-header {
    display: grid;
    grid-template-columns: 2fr repeat(4, 1fr);
    gap: 0;
    padding: var(--space-4) var(--space-5);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    position: sticky;
    top: 71px;
    z-index: 10;
  }
}

.comparison-header-feature {
  font-family: var(--font-display);
  font-size: 0.8125rem;
  font-weight: 700;
  color: var(--color-text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.comparison-header-plan {
  font-family: var(--font-display);
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--color-text-primary);
  text-align: center;
}

.comparison-header-plan.highlighted {
  color: var(--color-primary);
}

/* Accordion category */
.comparison-category {
  border-top: 1px solid var(--color-border-light);
}

.comparison-category:last-child {
  border-bottom: 1px solid var(--color-border-light);
}

.comparison-category-header {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  width: 100%;
  padding: var(--space-5) 0;
  border: none;
  background: transparent;
  cursor: pointer;
  text-align: left;
}

@media (min-width: 768px) {
  .comparison-category-header {
    padding: var(--space-5);
  }
}

.comparison-category-name {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-text-primary);
  flex: 1;
}

.comparison-category-count {
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--color-text-tertiary);
}

.comparison-category-chevron {
  flex-shrink: 0;
  width: 20px;
  height: 20px;
  color: var(--color-text-tertiary);
  transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}

.comparison-category.open .comparison-category-chevron {
  transform: rotate(180deg);
}

.comparison-category.open .comparison-category-name {
  color: var(--color-primary);
}

/* Category body */
.comparison-category-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.comparison-category.open .comparison-category-body {
  max-height: 2000px;
}

/* Comparison row */
.comparison-row {
  padding: var(--space-3) 0;
  border-top: 1px solid rgba(0, 0, 0, 0.04);
}

.comparison-row.alt {
  background: var(--color-bg-primary);
}

@media (min-width: 768px) {
  .comparison-row {
    display: grid;
    grid-template-columns: 2fr repeat(4, 1fr);
    align-items: center;
    gap: 0;
    padding: var(--space-3) var(--space-5);
  }
}

.comparison-feature-name {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--space-2);
}

@media (min-width: 768px) {
  .comparison-feature-name {
    margin-bottom: 0;
    font-weight: 500;
    color: var(--color-text-secondary);
  }
}

/* Values grid (mobile: 2x2, desktop: inline) */
.comparison-values {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4px var(--space-3);
}

@media (min-width: 768px) {
  .comparison-values {
    display: contents;
  }
}

.comparison-cell {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px 0;
}

@media (min-width: 768px) {
  .comparison-cell {
    justify-content: center;
  }

  .comparison-cell-label { display: none; }
}

.comparison-cell-label {
  font-size: 0.6875rem;
  font-weight: 600;
  color: var(--color-text-tertiary);
  min-width: 55px;
}

.cell-check {
  color: var(--color-secondary);
  display: flex;
}

.cell-x {
  color: var(--color-border);
  display: flex;
}

.cell-text {
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--color-text-primary);
}

/* ═══════════════════════════════════════
   ADD-ONS
   ═══════════════════════════════════════ */
.addons-section {
  padding: var(--space-16) 0;
  background: var(--color-bg-secondary);
}

@media (min-width: 768px) {
  .addons-section { padding: var(--space-20) 0; }
}

@media (min-width: 1024px) {
  .addons-section { padding: var(--space-24) 0; }
}

.addons-eyebrow {
  display: block;
  text-align: center;
  font-family: var(--font-body);
  font-size: clamp(0.75rem, 1vw, 0.8125rem);
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-secondary);
  margin-bottom: var(--space-4);
}

.addons-title {
  font-family: var(--font-display);
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  font-weight: 800;
  color: var(--color-text-primary);
  text-align: center;
  margin: 0 0 var(--space-3);
  letter-spacing: -0.03em;
}

.addons-subtitle {
  font-size: 1rem;
  color: var(--color-text-tertiary);
  text-align: center;
  margin: 0 0 var(--space-10);
}

.addons-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-6);
}

@media (min-width: 768px) {
  .addons-grid { grid-template-columns: repeat(2, 1fr); }
}

/* Addon card — colored hero style */
.addon-card {
  border-radius: var(--radius-xl);
  overflow: hidden;
