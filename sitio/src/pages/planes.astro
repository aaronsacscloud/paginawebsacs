</style>

<script>
  // ─── Toggle state management ───
  const root = document.getElementById('pricing-root');
  const toggles = document.getElementById('pricing-toggles');

  if (toggles && root) {
    toggles.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.toggle-btn') as HTMLButtonElement;
      if (!btn) return;

      const billing = btn.dataset.billing;
      const currency = btn.dataset.currency;

      if (billing) {
        root.dataset.billing = billing;
        const group = btn.closest('.toggle-group');
        group?.querySelectorAll('.toggle-btn').forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
      }

      if (currency) {
        root.dataset.currency = currency;
        const group = btn.closest('.toggle-group');
        group?.querySelectorAll('.toggle-btn').forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
      }
    });
  }

  // ─── Comparison table accordion ───
  const compAccordion = document.getElementById('comparison-accordion');
  compAccordion?.addEventListener('click', (e) => {
    const header = (e.target as HTMLElement).closest('.comparison-category-header') as HTMLButtonElement;
    if (!header) return;

    const category = header.closest('.comparison-category');
    if (!category) return;

    const isOpen = category.classList.contains('open');
    category.classList.toggle('open');
    header.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
  });

  // ─── Pricing FAQ accordion ───
  const pricingFaqAccordion = document.getElementById('pricing-faq-accordion');
  const pricingFaqItems = pricingFaqAccordion?.querySelectorAll('.faq-item');

  pricingFaqItems?.forEach((item) => {
    item.addEventListener('click', () => {
      const isActive = item.classList.contains('active');

      pricingFaqItems.forEach((it) => {
        it.classList.remove('active');
        it.setAttribute('aria-expanded', 'false');
      });

      if (!isActive) {
        item.classList.add('active');
        item.setAttribute('aria-expanded', 'true');
      }
    });

    item.addEventListener('keydown', (e: Event) => {
      if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
        e.preventDefault();
        (item as HTMLElement).click();
      }
    });
  });

  // ─── Mobile carousel sync ───
  const cardsContainer = document.getElementById('pricing-cards');
  const dots = document.querySelectorAll('#carousel-dots .dot');
  const stripItems = document.querySelectorAll('#price-strip .price-strip-item');
  let scrollTicking = false;

  function updateCarouselState(index: number) {
    dots.forEach((dot, i) => {
      dot.classList.toggle('active', i === index);
    });
    stripItems.forEach((item, i) => {
      item.classList.toggle('active', i === index);
    });
  }

  if (cardsContainer && window.innerWidth < 768) {
    // Scroll to Fideliza (index 2) on load
    requestAnimationFrame(() => {
      const cards = cardsContainer.querySelectorAll('.plan-card');
      if (cards[2]) {
        (cards[2] as HTMLElement).scrollIntoView({ inline: 'center', block: 'nearest' });
        updateCarouselState(2);
      }
    });

    cardsContainer.addEventListener('scroll', () => {
      if (!scrollTicking) {
        requestAnimationFrame(() => {
          const cards = cardsContainer.querySelectorAll('.plan-card');
          const containerRect = cardsContainer.getBoundingClientRect();
          const containerCenter = containerRect.left + containerRect.width / 2;
          let closestIndex = 0;
          let closestDistance = Infinity;

          cards.forEach((card, i) => {
            const cardRect = card.getBoundingClientRect();
            const cardCenter = cardRect.left + cardRect.width / 2;
            const distance = Math.abs(cardCenter - containerCenter);
            if (distance < closestDistance) {
              closestDistance = distance;
              closestIndex = i;
            }
          });

          updateCarouselState(closestIndex);
          scrollTicking = false;
        });
        scrollTicking = true;
      }
    }, { passive: true });

    // Strip click → scroll to card
    stripItems.forEach((item) => {
      item.addEventListener('click', () => {
        const index = parseInt((item as HTMLElement).dataset.index || '0');
        const cards = cardsContainer.querySelectorAll('.plan-card');
        if (cards[index]) {
          (cards[index] as HTMLElement).scrollIntoView({
            behavior: 'smooth',
            inline: 'center',
            block: 'nearest',
          });
        }
      });
    });
  }

  // ─── ROI Calculator ───
  const revenueSlider = document.getElementById('calc-revenue') as HTMLInputElement;
  const branchesSlider = document.getElementById('calc-branches') as HTMLInputElement;
  const revenueDisplay = document.getElementById('calc-revenue-display');
  const branchesDisplay = document.getElementById('calc-branches-display');
  const moneyEl = document.getElementById('calc-money');
  const hoursEl = document.getElementById('calc-hours');
  const fteEl = document.getElementById('calc-fte');
  const sacsCostEl = document.getElementById('calc-sacs-cost');
  const roiEl = document.getElementById('calc-roi');
  const planNameEl = document.getElementById('calc-plan-name');
  const planOptions = document.querySelectorAll<HTMLButtonElement>('.calc-plan-opt');
  const benefitCheckboxes = document.querySelectorAll<HTMLInputElement>('.calc-benefit input[type="checkbox"]');
  let selectedPlanPrice = 900;
  let selectedPlanName = 'Controla';

  function formatMoney(n: number): string {
    if (n >= 1000000) return '$' + (n / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
    if (n >= 1000) return '$' + Math.round(n).toLocaleString('es-MX');
    return '$' + Math.round(n);
  }

  // Plan selector
  planOptions.forEach((btn) => {
    btn.addEventListener('click', () => {
      planOptions.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      selectedPlanPrice = parseInt(btn.dataset.price || '900');
      selectedPlanName = btn.dataset.plan || 'controla';
      selectedPlanName = selectedPlanName.charAt(0).toUpperCase() + selectedPlanName.slice(1);
      calculateROI();
    });
  });

  function calculateROI() {
    const revenue = parseInt(revenueSlider?.value || '1000000');
    const branches = parseInt(branchesSlider?.value || '3');

    if (revenueDisplay) {
      if (revenue >= 1000000) {
        revenueDisplay.textContent = '$' + (revenue / 1000000).toFixed(1).replace(/\.0$/, '') + 'M MXN';
      } else {
        revenueDisplay.textContent = '$' + (revenue / 1000).toFixed(0) + 'K MXN';
      }
    }
    if (branchesDisplay) branchesDisplay.textContent = String(branches);

    let totalPct = 0;
    let totalHrsMonth = 0;

    benefitCheckboxes.forEach((cb) => {
      const pct = parseFloat(cb.dataset.pct || '0');
      const hrs = parseFloat(cb.dataset.hrs || '0');
      const row = cb.closest('.calc-benefit');
      const pctEl = row?.querySelector('.calc-benefit-pct');
      const saveEl = row?.querySelector('.calc-benefit-save');

      if (!cb.checked) {
        if (pctEl) pctEl.textContent = '';
        if (saveEl) saveEl.textContent = '';
        return;
      }

      totalPct += pct;
      totalHrsMonth += hrs * branches;

      if (pctEl) {
        if (pct > 0) pctEl.textContent = pct + '%';
        else pctEl.textContent = '';
      }

      if (saveEl) {
        const moneySave = revenue * (pct / 100);
        const hrsSave = hrs * branches * 12;
        if (pct > 0 && hrs > 0) saveEl.textContent = formatMoney(moneySave) + ' · ' + hrsSave + 'h';
        else if (pct > 0) saveEl.textContent = formatMoney(moneySave);
        else if (hrs > 0) saveEl.textContent = hrsSave + 'h/año';
      }
    });

    const totalMoney = revenue * (totalPct / 100);
    const totalHrsYear = totalHrsMonth * 12;
    const fte = totalHrsYear / 1920;
    const sacsCost = branches * selectedPlanPrice * 10; // annual = 10 months (2 months free)
    const roi = sacsCost > 0 ? totalMoney / sacsCost : 0;

    if (moneyEl) moneyEl.textContent = formatMoney(totalMoney);
    if (hoursEl) hoursEl.textContent = totalHrsYear.toLocaleString('es-MX');
    if (fteEl) fteEl.textContent = fte.toFixed(1);
    if (planNameEl) planNameEl.textContent = selectedPlanName;
    if (sacsCostEl) sacsCostEl.textContent = formatMoney(sacsCost) + ' MXN/año';
    if (roiEl) roiEl.textContent = roi.toFixed(1) + 'x';
  }

  revenueSlider?.addEventListener('input', calculateROI);
  branchesSlider?.addEventListener('input', calculateROI);
  benefitCheckboxes.forEach((cb) => cb.addEventListener('change', calculateROI));
  calculateROI();
</script>
