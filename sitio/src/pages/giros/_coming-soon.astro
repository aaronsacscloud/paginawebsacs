---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
  title: string;
  giro: string;
  description: string;
  color?: string;
}

const { title, giro, description, color = '#4B7BE5' } = Astro.props;
---

<BaseLayout title={`${giro} — SACS`} description={description}>
  <section class="coming-soon">
    <div class="coming-soon-inner container">
      <span class="coming-soon-eyebrow" style={`color: ${color};`}>SACS para {giro}</span>
      <h1 class="coming-soon-title">Próximamente</h1>
      <p class="coming-soon-subtitle">Estamos preparando la mejor solución de punto de venta para <strong>{giro.toLowerCase()}</strong>. Muy pronto tendrás toda la información aquí.</p>
      <div class="coming-soon-ctas">
        <a href="/contacto" class="cs-btn cs-btn-primary">Agenda una demo</a>
        <a href="/giros/marcas-de-ropa" class="cs-btn cs-btn-outline">Ver ejemplo: Marcas de Ropa</a>
      </div>
      <a href="/" class="coming-soon-back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Volver al inicio
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .coming-soon {
    min-height: calc(100vh - 71px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 0 80px;
    background: var(--color-bg-primary, #FAFAF8);
  }

  .coming-soon-inner {
    max-width: 560px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .coming-soon-eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .coming-soon-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    line-height: 1;
  }

  .coming-soon-subtitle {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 420px;
  }

  .coming-soon-subtitle strong {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .coming-soon-ctas {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: var(--space-4);
    width: 100%;
    max-width: 320px;
  }

  @media (min-width: 480px) {
    .coming-soon-ctas {
      flex-direction: row;
      max-width: none;
    }
  }

  .cs-btn {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    padding: 14px 24px;
    border-radius: 12px;
    text-decoration: none;
    text-align: center;
    line-height: 1;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .cs-btn-primary {
    background: #2563EB;
    color: #fff;
  }

  .cs-btn-primary:hover {
    background: #1D4FD7;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(37, 99, 235, 0.3);
    text-decoration: none;
  }

  .cs-btn-outline {
    background: transparent;
    color: var(--color-text-primary);
    border: 1.5px solid rgba(0, 0, 0, 0.15);
  }

  .cs-btn-outline:hover {
    border-color: rgba(0, 0, 0, 0.3);
    text-decoration: none;
  }

  .coming-soon-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: var(--space-6);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .coming-soon-back:hover {
    color: var(--color-text-primary);
    text-decoration: none;
  }
</style>
