---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import { t } from '../../i18n/utils';
const locale = 'it';
---
<BaseLayout title={t('meta.siteTitle', locale)} description={t('meta.siteDescription', locale)} locale={locale}>
  <Hero
    eyebrow={t('hero.eyebrow', locale)}
    title={t('hero.title', locale)}
    subtitle={t('hero.subtitle', locale)}
    primaryCTA={{ label: t('cta.startFree', locale), href: '/it/free-trial' }}
    secondaryCTA={{ label: t('cta.bookDemo', locale), href: '/it/contact' }}
  />
  <section style="padding: 80px 24px; text-align: center; background: var(--color-bg-primary);">
    <a href="/it/contact" style="display: inline-block; font-family: var(--font-body); font-size: 1rem; font-weight: 700; color: #fff; background: var(--color-primary); padding: 14px 32px; border-radius: 8px; text-decoration: none;">{t('cta.bookDemo', locale)}</a>
  </section>
</BaseLayout>
