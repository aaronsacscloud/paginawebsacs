---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';
const locale = 'it';
---
<BaseLayout title="Prova gratuita — Sacs" description="7 giorni con tutte le funzioni. Senza carta di credito." locale={locale}>
<section style="padding: clamp(120px, 12vw, 180px) 24px 80px; text-align: center;">
  <div style="max-width: 800px; margin: 0 auto;">
    <h1 style="font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: 800; color: var(--color-text-primary); letter-spacing: -0.04em; margin: 0 0 16px;">Prova gratuita</h1>
    <p style="font-family: var(--font-body); font-size: 1.125rem; color: var(--color-text-secondary); margin: 0 0 40px;">7 giorni con tutte le funzioni. Senza carta di credito.</p>
    <a href="/it/contact" style="display: inline-block; font-family: var(--font-body); font-size: 1rem; font-weight: 700; color: #fff; background: var(--color-primary); padding: 14px 32px; border-radius: 8px; text-decoration: none;">{t('cta.bookDemo', locale)}</a>
  </div>
</section>
</BaseLayout>
