---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';
const locale = 'it';
---
<BaseLayout title={t('contact.metaTitle', locale)} description={t('contact.metaDesc', locale)} locale={locale}>
<section class="ct-hero" style="background: #fff; padding: clamp(120px, 10vw, 160px) 0 80px;">
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 clamp(24px, 4vw, 48px); display: grid; grid-template-columns: 1fr 1.15fr; gap: clamp(48px, 6vw, 80px); align-items: start;">
    <div>
      <h1 style="font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 3.75rem); font-weight: 800; color: var(--color-text-primary); letter-spacing: -0.04em; line-height: 1.05; margin: 0 0 20px;">{t('contact.heroTitle', locale)}</h1>
      <p style="font-family: var(--font-body); font-size: 1.1rem; color: var(--color-text-secondary); line-height: 1.65; margin: 0 0 32px; max-width: 440px;">{t('contact.heroLead', locale)}</p>
      <div style="display: flex; flex-direction: column; gap: 14px;">
        <div style="display: flex; gap: 12px; align-items: flex-start;">
          <span style="font-family: var(--font-display); font-size: 0.6875rem; font-weight: 700; color: var(--color-primary); width: 22px; height: 22px; border-radius: 50%; border: 1.5px solid var(--color-primary); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">1</span>
          <div><strong style="font-size: 0.875rem; color: var(--color-text-primary);">{t('contact.step1Title', locale)}</strong><p style="font-size: 0.8125rem; color: var(--color-text-tertiary); margin: 2px 0 0;">{t('contact.step1Desc', locale)}</p></div>
        </div>
        <div style="display: flex; gap: 12px; align-items: flex-start;">
          <span style="font-family: var(--font-display); font-size: 0.6875rem; font-weight: 700; color: var(--color-primary); width: 22px; height: 22px; border-radius: 50%; border: 1.5px solid var(--color-primary); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">2</span>
          <div><strong style="font-size: 0.875rem; color: var(--color-text-primary);">{t('contact.step2Title', locale)}</strong><p style="font-size: 0.8125rem; color: var(--color-text-tertiary); margin: 2px 0 0;">{t('contact.step2Desc', locale)}</p></div>
        </div>
        <div style="display: flex; gap: 12px; align-items: flex-start;">
          <span style="font-family: var(--font-display); font-size: 0.6875rem; font-weight: 700; color: var(--color-primary); width: 22px; height: 22px; border-radius: 50%; border: 1.5px solid var(--color-primary); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">3</span>
          <div><strong style="font-size: 0.875rem; color: var(--color-text-primary);">{t('contact.step3Title', locale)}</strong><p style="font-size: 0.8125rem; color: var(--color-text-tertiary); margin: 2px 0 0;">{t('contact.step3Desc', locale)}</p></div>
        </div>
      </div>
    </div>
    <div id="demo" style="background: var(--color-bg-primary); border: 1px solid rgba(0,0,0,0.08); border-radius: 20px; padding: 24px; min-height: 700px;">
      <div class="calendly-inline-widget" data-url="https://calendly.com/aaronherzberg/reuniongeneral?hide_event_type_details=1&hide_gdpr_banner=1" style="min-width:320px;height:700px;"></div>
      <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
    </div>
  </div>
</section>
</BaseLayout>
<style>
  @media (max-width: 768px) { .ct-hero div[style*="grid"] { display: flex !important; flex-direction: column !important; } }
</style>
