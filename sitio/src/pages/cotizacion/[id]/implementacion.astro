---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { supabase } from '../../../lib/supabase';
import ImplementacionContent from '../../../components/ImplementacionContent.astro';

export const prerender = false;

const { id } = Astro.params;
const { data: quote } = await supabase.from('quotes').select('*').eq('id', id).single();

if (!quote) return Astro.redirect('/404');

// Parse meta
const notasSep = '\n---META---\n';
const notasIdx = (quote.notas || '').indexOf(notasSep);
const quoteMeta = notasIdx >= 0
  ? (() => { try { return JSON.parse(quote.notas.slice(notasIdx + notasSep.length)); } catch { return {}; } })()
  : {};

const showImplementacion = quoteMeta.mostrar_implementacion !== undefined ? quoteMeta.mostrar_implementacion : true;
if (!showImplementacion) return Astro.redirect(`/cotizacion/${id}`);

const items = Array.isArray(quote.items) ? quote.items : [];
const isAnnual = items.some((i: any) => i.tipo === 'plan' && i.periodo === 'anual');
const implementacionNota = quoteMeta.implementacion_nota || '';
const quoteUrl = `/cotizacion/${id}`;
---

<BaseLayout
  title={`Tu implementación con SACS — ${quote.empresa}`}
  description={`Proceso completo de implementación para ${quote.empresa}. Migración, capacitación y puesta en marcha en días.`}
>
  <main style="background:#fafafa;min-height:100vh;padding-top:88px;padding-bottom:96px">
    <ImplementacionContent
      variant="full"
      empresa={quote.empresa}
      contacto={quote.contacto}
      nota={implementacionNota}
      isAnnual={isAnnual}
      quoteUrl={quoteUrl}
    />
  </main>
</BaseLayout>
