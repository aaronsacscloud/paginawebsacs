.quote-tl-line { width: 2px; flex: 1; background: #f0f0f0; min-height: 16px; }
.quote-tl-content { padding-bottom: 24px; flex: 1; }
.quote-tl-badge { display: inline-block; font-size: 0.5625rem; font-weight: 800; color: #fff; padding: 3px 10px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px; }
.quote-tl-heading { font-family: var(--font-display); font-size: 0.9375rem; font-weight: 800; color: #1a1a1a; margin-bottom: 10px; }
.quote-tl-items, .quote-tl-problems { display: flex; flex-direction: column; gap: 6px; }
.quote-tl-item { display: flex; align-items: flex-start; gap: 8px; font-size: 0.75rem; color: #555; line-height: 1.5; }
.quote-tl-item svg { flex-shrink: 0; margin-top: 2px; }
