.quote-dark .quote-total-final--normal { border-color: rgba(255,255,255,0.18); color: #6ee7b7; }
.quote-dark .quote-total-final--normal span:last-child { color: #6ee7b7; }

/* ─── Bank account ─── */
.quote-bank { padding: 24px 40px; border-top: 1px solid #f0f0f0; }
.quote-bank-title { font-size: 0.625rem; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 12px; }
.quote-bank-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.quote-bank-item { display: flex; flex-direction: column; }
.quote-bank-label { font-size: 0.625rem; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.06em; }
.quote-bank-value { font-size: 0.875rem; font-weight: 600; color: #1a1a1a; margin-top: 2px; }

.quote-dark .quote-bank { border-color: rgba(255,255,255,0.08); }
.quote-dark .quote-bank-value { color: #fff; }

/* ─── Pay link ─── */
