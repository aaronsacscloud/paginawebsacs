.quote-dark .quote-why-text { color: rgba(255,255,255,0.5); }
.quote-dark .quote-cases { border-color: rgba(255,255,255,0.08); }
.quote-dark .quote-cases-title { color: #fff; }
.quote-dark .quote-case-card { border-color: rgba(255,255,255,0.1); background: rgba(255,255,255,0.03); }
.quote-dark .quote-case-name { color: #fff; }
.quote-dark .quote-cases-dot { background: rgba(255,255,255,0.15); }
.quote-dark .quote-cases-dot.active { background: #fff; }

/* ─── Legal ─── */
