.quote-dark .quote-conscious-word, .quote-dark .quote-conscious-jlabel { color: #fff; }
.quote-dark .quote-conscious-impact { background: rgba(42,181,160,0.06); }
.quote-dark .quote-conscious-closing { color: #2AB5A0; }

/* ─── Implementation Timeline ─── */
.quote-timeline-section { padding: 32px 40px; border-top: 1px solid #f0f0f0; }
.quote-timeline-header { text-align: center; margin-bottom: 28px; }
.quote-timeline-title { font-family: var(--font-display); font-size: 1.125rem; font-weight: 800; color: #1a1a1a; }
.quote-timeline-subtitle { font-size: 0.8125rem; color: #999; margin-top: 4px; }
.quote-timeline-steps { position: relative; }
.quote-tl-step { display: flex; gap: 16px; position: relative; }
.quote-tl-marker { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; width: 20px; }
.quote-tl-dot { width: 12px; height: 12px; border-radius: 50%; background: #e0e0e0; border: 2px solid #fff; box-shadow: 0 0 0 2px #e0e0e0; transition: all 0.3s ease; flex-shrink: 0; }
.quote-tl-dot.active { background: #E54B4B; box-shadow: 0 0 0 2px #E54B4B; }
.quote-tl-step:nth-child(2) .quote-tl-dot { background: #4B7BE5; box-shadow: 0 0 0 2px #4B7BE5; }
.quote-tl-step:nth-child(3) .quote-tl-dot { background: #6C5CE7; box-shadow: 0 0 0 2px #6C5CE7; }
.quote-tl-step:nth-child(4) .quote-tl-dot { background: #2AB5A0; box-shadow: 0 0 0 2px #2AB5A0; }
