.quote-pay-btn { display: inline-block; padding: 16px 48px; background: #4B7BE5; color: #fff; font-size: 1.0625rem; font-weight: 700; border-radius: 8px; text-decoration: none; transition: all 0.2s ease; }
.quote-pay-btn:hover { background: #3D6BD4; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(75,123,229,0.3); }
.quote-pay-note { font-size: 0.6875rem; color: #999; margin-top: 8px; }

.quote-dark .quote-pay-link { border-color: rgba(255,255,255,0.08); }

/* ─── Summary ─── */
.quote-summary { padding: 0 40px 20px; font-size: 1rem; font-weight: 600; color: var(--color-primary); line-height: 1.5; font-style: italic; }

/* ─── Strikethrough price ─── */
.qt-strikethrough { text-decoration: line-through; color: #ccc; font-weight: 400; margin-right: 6px; font-size: 0.75rem; }

/* ─── Savings ─── */
.qt-savings { color: #2AB5A0; font-weight: 600; }

/* ─── Totals ─── */
.quote-totals { padding: 20px 40px; }
.quote-total-row { display: flex; justify-content: space-between; padding: 8px 0; font-size: 0.875rem; color: #666; }
.quote-total-row.quote-discount { color: #2AB5A0; }
.quote-total-row.quote-total-final { font-family: var(--font-display); font-size: 1.25rem; font-weight: 800; color: #1a1a1a; border-top: 2px solid #1a1a1a; padding-top: 12px; margin-top: 8px; }

/* ─── Payment breakdown ─── */
.quote-payments { padding: 32px 40px; }
.quote-payments-title { font-family: var(--font-display); font-size: 0.875rem; font-weight: 700; color: #1a1a1a; margin-bottom: 16px; }
.quote-payment-block { margin-bottom: 16px; padding: 16px; background: #fafafa; border-radius: 10px; }
.quote-payment-label { font-size: 0.6875rem; font-weight: 700; color: #666; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px; }
.quote-payment-line { display: flex; justify-content: space-between; font-size: 0.8125rem; color: #666; padding: 4px 0; }
.quote-payment-total { display: flex; justify-content: space-between; font-size: 0.9375rem; font-weight: 800; color: #1a1a1a; border-top: 1px solid #e0e0e0; padding-top: 8px; margin-top: 8px; }
.quote-payment-total--compare { display: flex; flex-direction: column; gap: 4px; border: none; padding: 0; margin: 0; }
.quote-payment-total-row { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; }
.quote-payment-total-row .quote-payment-total-label { font-size: 0.75rem; font-weight: 500; color: #b91c1c; opacity: 0.8; }
.quote-payment-total-row .quote-payment-total-label em { font-style: italic; opacity: 0.85; }
.quote-payment-total-row--now .quote-payment-total-label { font-size: 0.9375rem; font-weight: 800; color: #1a1a1a; opacity: 1; }
.quote-payment-total-row--now { padding-top: 6px; margin-top: 4px; border-top: 1px solid #e0e0e0; }
.quote-payment-total-row--now .qt-price-normal { font-size: 1rem; }
.quote-dark .quote-payment-total-row .quote-payment-total-label { color: #fca5a5; }
.quote-dark .quote-payment-total-row--now .quote-payment-total-label { color: #fff; }
.quote-dark .quote-payment-total-row--now { border-color: rgba(255,255,255,0.1); }

.quote-dark .quote-summary { color: #2AB5A0; }
.quote-dark .quote-payments { border-color: rgba(255,255,255,0.08); }
.quote-dark .quote-payment-block { background: rgba(255,255,255,0.03); }
.quote-dark .quote-payment-label { color: rgba(255,255,255,0.4); }
.quote-dark .quote-payment-line { color: rgba(255,255,255,0.5); }
.quote-dark .quote-payment-total { color: #fff; border-color: rgba(255,255,255,0.1); }

/* ─── Conditions ─── */
.quote-conditions { padding: 20px 40px; border-top: 1px solid #f0f0f0; }
.quote-conditions-title { font-size: 0.625rem; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; }
.quote-conditions-text { font-size: 0.8125rem; color: #888; line-height: 1.6; white-space: pre-line; }

/* ─── ROI ─── */
.quote-roi { padding: 24px 40px; border-top: 1px solid #f0f0f0; }
.quote-roi-title { font-family: var(--font-display); font-size: 1rem; font-weight: 800; color: #1a1a1a; margin-bottom: 8px; }
.quote-roi-problem { font-size: 0.8125rem; color: #888; margin-bottom: 16px; line-height: 1.5; }
.quote-roi-numbers { display: flex; gap: 16px; margin-bottom: 12px; }
.quote-roi-stat { flex: 1; background: #f8f9fb; border-radius: 10px; padding: 16px; text-align: center; }
.quote-roi-value { font-family: var(--font-display); font-size: 1.75rem; font-weight: 800; color: #2AB5A0; }
.quote-roi-label { font-size: 0.625rem; color: #999; margin-top: 2px; text-transform: uppercase; letter-spacing: 0.06em; }
.quote-roi-detail { font-size: 0.75rem; color: #aaa; font-style: italic; }
.quote-dark .quote-roi { border-color: rgba(255,255,255,0.08); }
.quote-dark .quote-roi-title { color: #fff; }
.quote-dark .quote-roi-stat { background: rgba(255,255,255,0.03); }

/* ─── Comparison ─── */
.quote-comparison { padding: 24px 40px; border-top: 1px solid #f0f0f0; }
.quote-comparison-title { font-family: var(--font-display); font-size: 1rem; font-weight: 800; color: #1a1a1a; margin-bottom: 12px; }
.quote-comparison-table { width: 100%; border-collapse: collapse; }
.quote-comp-th { font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; padding: 8px 12px; border-bottom: 1px solid #f0f0f0; }
.quote-comp-th.quote-comp-before { color: #ccc; text-align: center; }
.quote-comp-th.quote-comp-after { color: #2AB5A0; text-align: center; }
.quote-comp-td { padding: 10px 12px; font-size: 0.8125rem; border-bottom: 1px solid #f5f5f5; }
.quote-comp-aspect { font-weight: 700; color: #1a1a1a; }
.quote-comp-before-cell { color: #ccc; text-align: center; text-decoration: line-through; }
.quote-comp-after-cell { color: #1a1a1a; text-align: center; font-weight: 600; }
.quote-dark .quote-comparison { border-color: rgba(255,255,255,0.08); }
.quote-dark .quote-comparison-title { color: #fff; }
.quote-dark .quote-comp-aspect { color: #fff; }
.quote-dark .quote-comp-after-cell { color: #2AB5A0; }

/* ─── QR ─── */
.quote-qr { padding: 20px 40px; border-top: 1px solid #f0f0f0; display: flex; flex-direction: column; align-items: center; }
.quote-qr-img { border-radius: 6px; display: block; }
.quote-qr-text { font-size: 0.625rem; color: #ccc; margin-top: 6px; }

/* ─── Signature ─── */
.quote-signature { padding: 24px 40px; border-top: 1px solid #f0f0f0; }
.quote-signature-title { font-family: var(--font-display); font-size: 1rem; font-weight: 800; color: #1a1a1a; margin-bottom: 4px; }
.quote-signature-hint { font-size: 0.75rem; color: #999; margin-bottom: 12px; }
.quote-signature-canvas { width: 100%; height: 150px; border: 1px solid #e0e0e0; border-radius: 8px; cursor: crosshair; touch-action: none; }
.quote-signature-actions { display: flex; gap: 8px; margin-top: 8px; }
.quote-signed { padding: 24px 40px; border-top: 1px solid #f0f0f0; text-align: center; }
.quote-signed-img { max-width: 240px; height: auto; margin: 0 auto 8px; display: block; border-bottom: 1px solid #e0e0e0; padding-bottom: 8px; }
.quote-signed-label { font-size: 0.875rem; font-weight: 700; color: #2AB5A0; }
.quote-signed-date { font-size: 0.6875rem; color: #999; }

/* ─── Success overlay ─── */
.quote-success-overlay { position: fixed; inset: 0; z-index: 2000; background: rgba(255,255,255,0.95); display: flex; align-items: center; justify-content: center; }
.quote-success-content { text-align: center; animation: successFadeIn 0.5s ease; }
.quote-success-check { margin-bottom: 16px; animation: successPop 0.6s ease; }
.quote-success-title { font-family: var(--font-display); font-size: 1.75rem; font-weight: 800; color: #1a1a1a; margin-bottom: 8px; }
.quote-success-text { font-size: 0.9375rem; color: #999; }
@keyframes successFadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
@keyframes successPop { 0% { transform: scale(0); } 50% { transform: scale(1.2); } 100% { transform: scale(1); } }

/* Confetti */
.quote-confetti { position: fixed; inset: 0; pointer-events: none; overflow: hidden; z-index: 2001; }
.confetti-piece { position: absolute; width: 10px; height: 10px; top: -10px; animation: confettiFall linear forwards; }
@keyframes confettiFall {
  0% { transform: translateY(0) rotate(0deg); opacity: 1; }
  100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
}

/* ─── Why SACS ─── */
.quote-why { padding: 32px 40px; border-top: 1px solid #f0f0f0; text-align: center; }
.quote-why-title { font-family: var(--font-display); font-size: 1.125rem; font-weight: 800; color: #1a1a1a; margin-bottom: 10px; }
.quote-why-hero { font-family: var(--font-display); font-size: 1.25rem; font-weight: 800; color: #4B7BE5; margin-bottom: 8px; line-height: 1.3; }
.quote-why-text { font-size: 0.8125rem; color: #888; line-height: 1.7; max-width: 480px; margin: 0 auto 20px; }
.quote-why-stats { display: flex; justify-content: center; gap: 32px; }
.quote-why-stat { text-align: center; }
.quote-why-stat-num { font-family: var(--font-display); font-size: 1.5rem; font-weight: 800; color: #4B7BE5; }
.quote-why-stat-label { font-size: 0.625rem; color: #aaa; text-transform: uppercase; letter-spacing: 0.06em; }

/* ─── Conscious Commerce ─── */
.quote-conscious { padding: 32px 40px; border-top: 1px solid #f0f0f0; }
.quote-conscious-top { text-align: center; margin-bottom: 24px; }
.quote-conscious-video { margin-bottom: 16px; display: flex; justify-content: center; }
