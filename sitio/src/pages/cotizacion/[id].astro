/* ─── Actions ─── */
.quote-actions { display: flex; gap: 8px; justify-content: center; margin-top: 24px; flex-wrap: wrap; }
.quote-action-btn { padding: 10px 20px; border-radius: 6px; font-size: 0.8125rem; font-weight: 600; cursor: pointer; text-decoration: none; border: 1px solid #ddd; font-family: inherit; display: inline-flex; align-items: center; gap: 6px; background: #fff; color: #333; transition: background 0.15s; }
.quote-action-btn:hover { background: #f5f5f5; }
.quote-actions-row { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
.quote-accepted-badge { display: flex; align-items: center; gap: 6px; font-size: 0.8125rem; font-weight: 600; color: #2AB5A0; }
.quote-expired-notice { text-align: center; padding: 8px 0; }
.quote-expired-notice-title { font-family: var(--font-display); font-size: 1rem; font-weight: 800; color: #1a1a1a; margin-bottom: 4px; }
.quote-expired-notice-text { font-size: 0.8125rem; color: #999; margin-bottom: 16px; line-height: 1.5; }

/* ─── Modal ─── */
.quote-modal-overlay { position: fixed; inset: 0; z-index: 1000; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; padding: 24px; }
.quote-modal { background: #fff; border-radius: 16px; width: 100%; max-width: 480px; max-height: 90vh; display: flex; flex-direction: column; overflow: hidden; box-shadow: 0 24px 64px rgba(0,0,0,0.15); }
.quote-modal-header { display: flex; justify-content: space-between; align-items: center; padding: 20px 24px; border-bottom: 1px solid #f0f0f0; }
.quote-modal-title { font-family: var(--font-display); font-size: 1rem; font-weight: 800; color: #1a1a1a; }
.quote-modal-close { background: none; border: none; width: 32px; height: 32px; border-radius: 8px; font-size: 1.125rem; color: #999; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.15s; }
.quote-modal-close:hover { background: #f5f5f5; }
.quote-modal-body { padding: 20px 24px; overflow-y: auto; flex: 1; }
.quote-modal-footer { padding: 16px 24px; border-top: 1px solid #f0f0f0; display: flex; flex-direction: column; gap: 8px; }
.quote-modal-input { width: 100%; padding: 10px 14px; font-size: 0.8125rem; border: 1px solid #e0e0e0; border-radius: 8px; font-family: inherit; box-sizing: border-box; outline: none; resize: none; transition: border-color 0.15s; }
.quote-modal-input:focus { border-color: #bbb; }
.quote-modal-btn { width: 100%; padding: 12px; font-size: 0.8125rem; font-weight: 600; border: none; border-radius: 8px; cursor: pointer; font-family: inherit; background: #1a1a1a; color: #fff; transition: background 0.15s; }
.quote-modal-btn:hover { background: #333; }
.quote-modal-btn--secondary { background: #f5f5f5; color: #555; }
.quote-modal-btn--secondary:hover { background: #eee; }
.quote-modal-hint { font-size: 0.8125rem; color: #999; margin: 0 0 16px; line-height: 1.5; }

/* ─── Comments thread ─── */
.quote-comments-thread { padding: 20px 24px; max-height: 300px; overflow-y: auto; flex: 1; }
.quote-comments-empty { font-size: 0.8125rem; color: #ccc; text-align: center; padding: 32px 0; }
.quote-comment { margin-bottom: 16px; }
.quote-comment:last-child { margin-bottom: 0; }
.quote-comment-bubble { padding: 10px 14px; border-radius: 12px; font-size: 0.8125rem; line-height: 1.5; color: #333; }
.quote-comment--prospect .quote-comment-bubble { background: #f5f5f5; border-bottom-left-radius: 4px; }
.quote-comment--admin .quote-comment-bubble { background: #f0f0f0; border-bottom-right-radius: 4px; }
.quote-comment-meta { display: flex; justify-content: space-between; align-items: center; margin-top: 4px; padding: 0 4px; }
.quote-comment-name { font-size: 0.5625rem; font-weight: 700; color: #bbb; text-transform: uppercase; letter-spacing: 0.04em; }
.quote-comment--admin .quote-comment-name { color: #999; }
.quote-comment-time { font-size: 0.5rem; color: #ddd; }

/* ─── Share form ─── */
.quote-share-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.quote-share-label { display: block; font-size: 0.5625rem; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px; }

/* ─── Dark template ─── */
.quote-dark .quote-container { background: #1a1a1a; color: #fff; }
.quote-dark .quote-logo-text { color: #fff; }
.quote-dark .quote-logo-tag { background: rgba(42,181,160,0.15); color: #2AB5A0; }
.quote-dark .quote-number { color: #fff; }
.quote-dark .quote-date { color: rgba(255,255,255,0.45); }
.quote-dark .quote-client-name { color: #fff; }
.quote-dark .quote-client-detail { color: rgba(255,255,255,0.55); }
.quote-dark .quote-header { border-color: rgba(255,255,255,0.1); }
.quote-dark .quote-table th { background: rgba(255,255,255,0.03); color: rgba(255,255,255,0.4); border-color: rgba(255,255,255,0.08); }
.quote-dark .quote-table td { color: rgba(255,255,255,0.7); border-color: rgba(255,255,255,0.06); }
.quote-dark .quote-table td strong { color: #fff; }
.quote-dark .quote-total-row { color: rgba(255,255,255,0.5); }
.quote-dark .quote-total-row.quote-total-final { color: #fff; border-color: #fff; }
.quote-dark .quote-conditions { border-color: rgba(255,255,255,0.08); }
.quote-dark .quote-conditions-text { color: rgba(255,255,255,0.4); }
.quote-dark .quote-footer { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.08); }
.quote-dark .quote-footer-logo { color: #fff; }
.quote-dark .qt-desc { color: rgba(255,255,255,0.35); }
.quote-dark .qt-nota { color: rgba(42,181,160,0.8); }

/* ─── Classic template ─── */
.quote-classic .quote-container { border-radius: 0; box-shadow: none; border: 2px solid #1a1a1a; }
.quote-classic .quote-header { border-bottom: 2px solid #1a1a1a; }
.quote-classic .quote-logo-tag { background: #1a1a1a; color: #fff; border-radius: 0; }
.quote-classic .quote-table th { background: #1a1a1a; color: #fff; border: 1px solid #1a1a1a; }
.quote-classic .quote-table td { border: 1px solid #ddd; }
.quote-classic .quote-footer { background: #1a1a1a; }
.quote-classic .quote-footer-logo, .quote-classic .quote-footer-tagline, .quote-classic .quote-footer-contact { color: #fff; }

/* ─── Key Points ─── */
.quote-key-points { padding: 48px 56px; max-width: 680px; margin: 0 auto; }
.quote-key-points-title { font-family: var(--font-display); font-size: 1.5rem; font-weight: 300; letter-spacing: -0.015em; color: #1a1a1a; margin-bottom: 28px; }
.quote-key-points-list { display: flex; flex-direction: column; gap: 20px; }
.quote-key-point { display: flex; gap: 14px; align-items: flex-start; padding-bottom: 18px; border-bottom: 1px solid #f0f0f0; }
.quote-key-point:last-child { border-bottom: none; padding-bottom: 0; }
.quote-key-point-icon { flex-shrink: 0; margin-top: 3px; }
.quote-key-point-content { flex: 1; min-width: 0; }
.quote-key-point-title { font-size: 0.9375rem; font-weight: 500; color: #1a1a1a; margin-bottom: 4px; letter-spacing: -0.005em; }
.quote-key-point-detail { font-size: 0.8125rem; color: #666; line-height: 1.55; }

.quote-dark .quote-key-points { border-color: rgba(255,255,255,0.08); }
.quote-dark .quote-key-points-title { color: #fff; }
.quote-dark .quote-key-point-title { color: #fff; }
.quote-dark .quote-key-point-detail { color: rgba(255,255,255,0.5); }
.quote-dark .quote-key-point-icon svg path { stroke: #2AB5A0; }

/* ─── Versions ─── */
.quote-versions { padding: 20px 40px; border-top: 1px solid #f0f0f0; }
.quote-versions-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.quote-versions-title { font-size: 0.625rem; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.08em; }
.quote-versions-current { font-size: 0.625rem; font-weight: 700; color: #4B7BE5; }
.quote-versions-list { position: relative; padding-left: 16px; }
.quote-version-item { display: flex; align-items: flex-start; gap: 10px; padding: 6px 0; position: relative; }
.quote-version-item::before { content: ''; position: absolute; left: -13px; top: 16px; bottom: -6px; width: 1px; background: #eee; }
.quote-version-item:last-child::before { display: none; }
.quote-version-dot { width: 7px; height: 7px; border-radius: 50%; background: #ddd; flex-shrink: 0; margin-top: 5px; margin-left: -20px; position: relative; z-index: 1; }
.quote-version-current .quote-version-dot { background: #4B7BE5; width: 9px; height: 9px; }
.quote-version-content { flex: 1; }
.quote-version-label { font-size: 0.75rem; font-weight: 700; color: #1a1a1a; display: flex; align-items: center; gap: 6px; }
.quote-version-badge { font-size: 0.5rem; font-weight: 700; color: #4B7BE5; background: rgba(75,123,229,0.08); padding: 1px 6px; border-radius: 3px; text-transform: uppercase; letter-spacing: 0.06em; }
.quote-version-detail { font-size: 0.6875rem; color: #999; margin-top: 1px; }
.quote-version-up { color: #E54B4B; font-weight: 600; margin-left: 4px; }
.quote-version-down { color: #2AB5A0; font-weight: 600; margin-left: 4px; }

.quote-dark .quote-versions { border-color: rgba(255,255,255,0.08); }
.quote-dark .quote-version-label { color: #fff; }
.quote-dark .quote-version-detail { color: rgba(255,255,255,0.4); }
.quote-dark .quote-version-item::before { background: rgba(255,255,255,0.08); }
.quote-dark .quote-version-dot { background: rgba(255,255,255,0.2); }
.quote-dark .quote-version-current .quote-version-dot { background: #2AB5A0; }

/* ─── Promotion ─── */
.qt-promo-row { background: rgba(42,181,160,0.03); }
.qt-promo-badge { display: inline-block; font-size: 0.5625rem; font-weight: 800; color: #fff; background: #2AB5A0; padding: 2px 8px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px; }
.qt-promo-price { color: #2AB5A0; font-weight: 800; font-size: 1rem; }

.quote-dark .qt-promo-row { background: rgba(42,181,160,0.06); }

/* ─── Plan Features ─── */
.quote-features { padding: 24px 40px; border-top: 1px solid #f0f0f0; }
.quote-features-title { font-family: var(--font-display); font-size: 1rem; font-weight: 800; color: #1a1a1a; margin-bottom: 20px; }
.quote-plan-features { margin-bottom: 20px; }
.quote-plan-name { font-size: 0.6875rem; font-weight: 700; color: var(--color-primary, #4B7BE5); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid #f0f0f0; }
.quote-features-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px 24px; }
.quote-feature-cat { margin-bottom: 8px; }
.quote-feature-cat-name { font-size: 0.6875rem; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 6px; }
.quote-feature-list { list-style: none; margin: 0; padding: 0; }
.quote-feature-item { display: flex; align-items: flex-start; gap: 6px; font-size: 0.75rem; color: #555; padding: 3px 0; line-height: 1.4; }
.quote-services { margin-top: 12px; }
.quote-services-list { display: flex; flex-wrap: wrap; gap: 6px; }
.quote-service-tag { font-size: 0.6875rem; font-weight: 600; color: #2AB5A0; background: rgba(42,181,160,0.08); padding: 4px 10px; border-radius: 20px; }

.quote-dark .quote-features { border-color: rgba(255,255,255,0.08); }
.quote-dark .quote-features-title { color: #fff; }
.quote-dark .quote-plan-name { color: #2AB5A0; border-color: rgba(255,255,255,0.08); }
.quote-dark .quote-feature-cat-name { color: rgba(255,255,255,0.4); }
.quote-dark .quote-feature-item { color: rgba(255,255,255,0.6); }
.quote-dark .quote-service-tag { background: rgba(42,181,160,0.12); }

/* ─── Pagos realizados (panel + modal) ─── */
.qph {
  margin: 16px 40px;
  padding: 28px 32px;
  background: #fff;
  border: 1px solid #ececec;
  border-radius: 10px;
}
.qph--paid { background: linear-gradient(180deg, rgba(42,181,160,0.06) 0%, #fff 80%); border-color: rgba(42,181,160,0.25); }
.qph-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; margin-bottom: 14px; }
.qph-title { font-family: var(--font-display); font-size: 0.9375rem; font-weight: 800; letter-spacing: -0.01em; color: #1a1a1a; }
.qph--paid .qph-title { color: #1a5a4f; }
.qph-sub { font-size: 0.75rem; color: #888; margin-top: 4px; }
.qph-btn-add {
  display: inline-flex; align-items: center; gap: 6px;
  background: #1a1a1a; color: #fff;
  border: 0; border-radius: 6px;
  padding: 8px 14px;
  font-family: var(--font-body); font-size: 0.75rem; font-weight: 700;
  cursor: pointer;
  transition: background 0.15s ease;
  white-space: nowrap;
}
.qph-btn-add:hover { background: #000; }
.qph-bar {
  height: 6px;
  background: #f0eee8;
  border-radius: 99px;
  overflow: hidden;
  margin: 14px 0 18px;
}
.qph-bar-fill { height: 100%; background: #2AB5A0; transition: width 0.6s cubic-bezier(.4,0,.2,1); }
.qph-empty {
  font-size: 0.8125rem;
  color: #999;
  background: #fafafa;
  border: 1px dashed #ececec;
  padding: 16px;
  border-radius: 8px;
  text-align: center;
  font-style: italic;
}
.qph-list { display: flex; flex-direction: column; gap: 8px; }
.qph-row {
  display: grid;
  grid-template-columns: 28px 1fr auto auto;
  align-items: center;
  gap: 14px;
  padding: 12px 14px;
  background: #fafafa;
  border-radius: 8px;
  border: 1px solid transparent;
  transition: border-color 0.12s ease, background 0.12s ease;
}
.qph-row:hover { border-color: #ececec; background: #fff; }
.qph-row-num { font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; color: #aaa; text-align: center; }
.qph-row-line { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.qph-row-acuse { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.75rem; font-weight: 700; color: #1a1a1a; }
.qph-row-method { font-size: 0.6875rem; color: #fff; background: #2AB5A0; padding: 2px 8px; border-radius: 99px; font-weight: 600; letter-spacing: 0.02em; }
.qph-row-meta { margin-top: 2px; font-size: 0.6875rem; color: #888; }
.qph-row-amount { font-family: var(--font-display); font-size: 0.9375rem; font-weight: 800; color: #1a1a1a; white-space: nowrap; }
.qph-row-actions { display: flex; gap: 8px; align-items: center; }
.qph-row-link { font-size: 0.6875rem; font-weight: 600; color: #4B7BE5; text-decoration: none; padding: 4px 10px; border-radius: 5px; border: 1px solid transparent; transition: border-color 0.12s ease; }
.qph-row-link:hover { border-color: #4B7BE5; text-decoration: none; }
.qph-row-resend { font-size: 0.6875rem; font-weight: 600; color: #888; background: none; border: 1px solid #ddd; padding: 4px 10px; border-radius: 5px; cursor: pointer; transition: border-color 0.12s ease, color 0.12s ease; }
.qph-row-resend:hover:not(:disabled) { border-color: #1a1a1a; color: #1a1a1a; }
.qph-row-resend:disabled { opacity: 0.6; cursor: default; }
.qph-balance {
  margin-top: 16px;
  padding: 12px 14px;
  background: #fff8e1;
  border-left: 3px solid #E8A838;
  border-radius: 4px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.8125rem;
  color: #5a4a1f;
}
.qph-balance strong { font-family: var(--font-display); font-weight: 800; font-size: 0.9375rem; color: #1a1a1a; }

/* Dark template support */
.quote-dark .qph { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.08); }
.quote-dark .qph-title { color: #fff; }
.quote-dark .qph-sub { color: rgba(255,255,255,0.5); }
.quote-dark .qph-row { background: rgba(255,255,255,0.04); }
.quote-dark .qph-row:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.1); }
.quote-dark .qph-row-acuse { color: #fff; }
.quote-dark .qph-row-amount { color: #fff; }
.quote-dark .qph-row-meta { color: rgba(255,255,255,0.4); }
.quote-dark .qph-bar { background: rgba(255,255,255,0.08); }
.quote-dark .qph-empty { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.08); color: rgba(255,255,255,0.5); }

/* Modal "Registrar pago" */
.qph-form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px 16px;
  margin-bottom: 14px;
}
.qph-field { display: flex; flex-direction: column; gap: 6px; }
.qph-field--full { grid-column: 1 / -1; }
.qph-field > span:first-child { font-size: 0.5625rem; font-weight: 700; color: #aaa; text-transform: uppercase; letter-spacing: 0.06em; }
.qph-field input,
.qph-field select,
.qph-field textarea {
  font-family: var(--font-body);
  font-size: 0.875rem;
  color: #1a1a1a;
  background: #fff;
  border: 1px solid #e5e5e5;
  border-radius: 6px;
  padding: 9px 12px;
  outline: none;
  transition: border-color 0.15s ease;
}
.qph-field input:focus,
.qph-field select:focus,
.qph-field textarea:focus { border-color: #1a1a1a; }
.qph-field textarea { resize: vertical; min-height: 60px; }
.qph-file-status { font-size: 0.6875rem; color: #2AB5A0; min-height: 14px; }
.qph-items { background: #fafafa; padding: 12px; border-radius: 6px; border: 1px solid #ececec; }
.qph-items-list { margin-top: 10px; padding-top: 10px; border-top: 1px solid #ececec; display: flex; flex-direction: column; gap: 6px; }
.qph-item-check { display: flex; align-items: center; gap: 8px; font-size: 0.8125rem; color: #555; cursor: pointer; }
.qph-item-check input { margin: 0; cursor: pointer; }
.qph-item-check em { font-style: normal; color: #999; margin-left: 6px; font-size: 0.75rem; }
.qph-toggle-row { display: flex; align-items: center; gap: 10px; padding: 12px; background: rgba(75,123,229,0.06); border-radius: 6px; font-size: 0.8125rem; color: #1a1a1a; cursor: pointer; }
.qph-toggle-row input { margin: 0; }

@media (max-width: 640px) {
  .qph { margin: 12px 16px; padding: 22px 20px; }
  .qph-row { grid-template-columns: 24px 1fr auto; grid-template-areas: "num main amount" "num actions actions"; }
  .qph-row-num { grid-area: num; }
  .qph-row-main { grid-area: main; }
  .qph-row-amount { grid-area: amount; align-self: center; }
  .qph-row-actions { grid-area: actions; justify-content: flex-start; padding-top: 4px; }
  .qph-form-grid { grid-template-columns: 1fr; }
}

/* ─── Print ─── */
@media print {
  * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; color-adjust: exact !important; }
  .no-print { display: none !important; }
  .quote-page { padding: 0; max-width: none; }
  .quote-container { box-shadow: none; border-radius: 0; }
  .quote-modal-overlay { display: none !important; }
  body { background: #fff !important; margin: 0; }
  @page { margin: 0.8cm; size: A4; }
  .quote-features-grid { grid-template-columns: 1fr 1fr; }
  .quote-header { padding: 28px 32px 18px; }
  .quote-logo-tag { background: rgba(75,123,229,0.08) !important; color: var(--color-primary) !important; }
  .quote-validity { color: #999 !important; }
  .quote-expired { color: #E54B4B !important; }
  .quote-timer { background: #1a1a1a !important; color: #fff !important; }
  .quote-timer--urgent { background: #1a1a1a !important; }
  .qt-promo-badge { background: #2AB5A0 !important; color: #fff !important; }
  .qt-promo-badge--expired { background: #b91c1c !important; }
  .quote-expired-notice { background: #fff7ed !important; border-color: #fdba74 !important; color: #7c2d12 !important; }
  .qt-price-strike { color: #b91c1c !important; }
  .qt-price-normal { color: #047857 !important; }
  .quote-timer-promo-dot { animation: none !important; }
  .qt-promo-row { background: rgba(42,181,160,0.03) !important; }
  .qt-savings { color: #2AB5A0 !important; }
  .quote-total-row.quote-discount { color: #2AB5A0 !important; }
  .quote-total-row.quote-total-final { border-top: 2px solid #1a1a1a !important; }
  .quote-table th { background: #fafafa !important; }
  .quote-payment-block { background: #fafafa !important; }
  .quote-footer { background: #fafafa !important; }
  .quote-pay-btn { background: #4B7BE5 !important; color: #fff !important; }
  .quote-service-tag { background: rgba(42,181,160,0.08) !important; color: #2AB5A0 !important; }
  .quote-paid-banner { background: #4B7BE5 !important; color: #fff !important; }
  .qt-nota { color: #4B7BE5 !important; }
  .quote-plan-name { color: #4B7BE5 !important; }
  .quote-feature-item svg path { stroke: #2AB5A0 !important; }
  .quote-key-point-icon svg path { stroke: #4B7BE5 !important; }
  .quote-roi-stat { background: #f8f9fb !important; }
  .quote-roi-value { color: #2AB5A0 !important; }
  .quote-comp-after-cell { color: #1a1a1a !important; }
  .quote-comp-before-cell { color: #ccc !important; }
  .quote-signature { display: none !important; }
  .quote-why-stat-num { color: #4B7BE5 !important; }
  .quote-case-tag { color: #fff !important; }
  .quote-cases-dots { display: none !important; }
  .quote-cases-track { overflow: visible !important; flex-wrap: wrap !important; }
  .quote-version-current .quote-version-dot { background: #4B7BE5 !important; }
  .quote-version-badge { background: rgba(75,123,229,0.08) !important; color: #4B7BE5 !important; }
}

/* ─── Mobile ─── */
/* ─── Reject button + reasons list ─── */
.quote-reject-wrap { padding: 16px 40px 24px; text-align: center; }
.quote-reject-btn {
  background: transparent; border: none; color: #999;
  font-size: 0.8125rem; font-weight: 500; font-family: inherit;
  cursor: pointer; padding: 6px 12px; border-radius: 4px;
  text-decoration: underline; text-decoration-color: #ddd;
  transition: color 0.15s ease, text-decoration-color 0.15s ease;
}
.quote-reject-btn:hover { color: #666; text-decoration-color: #666; }
.quote-reject-reasons { display: flex; flex-direction: column; gap: 8px; margin-top: 4px; }
.quote-reject-reason {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 12px; border: 1px solid #e5e5e5; border-radius: 6px;
  font-size: 0.8125rem; color: #555; cursor: pointer;
  transition: background 0.15s ease, border-color 0.15s ease;
}
.quote-reject-reason:hover { background: #fafafa; border-color: #d0d0d0; }
.quote-reject-reason input[type="radio"] { margin: 0; flex-shrink: 0; cursor: pointer; }
.quote-reject-reason input[type="radio"]:checked + span { color: #1a1a1a; font-weight: 600; }
.quote-reject-success { padding: 32px 24px; text-align: center; }
.quote-reject-success-title { font-family: var(--font-display); font-size: 1.25rem; font-weight: 500; color: #1a1a1a; margin-bottom: 10px; }
