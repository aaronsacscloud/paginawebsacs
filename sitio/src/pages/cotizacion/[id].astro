</style>

<script>
  // Countdown timer
  const countdown = document.getElementById('countdown');
  if (countdown) {
    const expires = new Date(countdown.dataset.expires + 'T23:59:59').getTime();
    function updateTimer() {
      const now = Date.now();
      const diff = expires - now;
      if (diff <= 0) return;
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const mins = Math.floor((diff % 3600000) / 60000);
      const secs = Math.floor((diff % 60000) / 1000);
      const dEl = document.getElementById('timer-days');
      const hEl = document.getElementById('timer-hours');
      const mEl = document.getElementById('timer-mins');
      const sEl = document.getElementById('timer-secs');
      if (dEl) dEl.textContent = String(days);
      if (hEl) hEl.textContent = String(hours);
      if (mEl) mEl.textContent = String(mins);
      if (sEl) sEl.textContent = String(secs);
    }
    updateTimer();
    setInterval(updateTimer, 1000);
  }

  // ─── Track view (skip if admin) ───
  const quoteId = window.location.pathname.split('/').pop();
  const isAdmin = new URLSearchParams(window.location.search).has('admin');
  if (quoteId && !isAdmin) {
    fetch('/api/revenue/quote-view', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: quoteId }),
    }).catch(() => {});
  }

  // ─── Comments ───
  const commentsSection = document.getElementById('comments-section');
  const commentsThread = document.getElementById('comments-thread');
  const commentsEmpty = document.getElementById('comments-empty');
  const btnComments = document.getElementById('btn-comments');
  const btnClose = document.getElementById('btn-close-comments');
  const btnSend = document.getElementById('btn-send-comment');

  function fmtCommentDate(d: string) {
    const date = new Date(d);
    const day = date.getDate();
    const month = date.toLocaleDateString('es-MX', { month: 'short' }).replace('.', '');
    const time = date.toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' });
    return `${day}/${month} ${time}`;
  }

  function renderComments(comments: any[]) {
    if (!commentsThread) return;
    if (comments.length === 0) {
      if (commentsEmpty) commentsEmpty.style.display = '';
      return;
    }
    if (commentsEmpty) commentsEmpty.style.display = 'none';
    // Remove old comments (keep empty placeholder)
    commentsThread.querySelectorAll('.quote-comment').forEach(el => el.remove());
    comments.forEach((c: any) => {
      const div = document.createElement('div');
      div.className = `quote-comment quote-comment--${c.from || 'prospect'}`;
      div.innerHTML = `
        <div class="quote-comment-bubble">${c.text.replace(/</g, '&lt;').replace(/\n/g, '<br>')}</div>
        <div class="quote-comment-meta">
          <span class="quote-comment-name">${c.from === 'admin' ? 'Sacs' : (c.name || 'Cliente').replace(/</g, '&lt;')}</span>
          <span class="quote-comment-time">${fmtCommentDate(c.at)}</span>
        </div>
      `;
      commentsThread.appendChild(div);
    });
    commentsThread.scrollTop = commentsThread.scrollHeight;
  }

  async function loadComments() {
    const res = await fetch(`/api/revenue/quote-comments?id=${quoteId}`);
    const data = await res.json();
    renderComments(data.comments || []);
  }

  if (btnComments && commentsSection) {
    btnComments.addEventListener('click', () => {
      commentsSection.style.display = '';
      if (shareSection) shareSection.style.display = 'none';
      loadComments();
    });
    commentsSection.addEventListener('click', (e) => { if (e.target === commentsSection) commentsSection.style.display = 'none'; });
  }
  if (btnClose && commentsSection) {
    btnClose.addEventListener('click', () => {
      commentsSection.style.display = 'none';
    });
  }
  if (btnSend) {
    btnSend.addEventListener('click', async () => {
      const nameEl = document.getElementById('comment-name') as HTMLInputElement;
      const textEl = document.getElementById('comment-text') as HTMLTextAreaElement;
      const name = nameEl?.value.trim();
      const text = textEl?.value.trim();
      if (!text) return;
      btnSend.textContent = 'Enviando...';
      const res = await fetch('/api/revenue/quote-comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: quoteId, from: 'prospect', name: name || 'Cliente', text }),
      });
      const data = await res.json();
      renderComments(data.comments || []);
      if (textEl) textEl.value = '';
      btnSend.textContent = 'Enviar comentario';
    });
  }

  // ─── Share by email ───
  const shareSection = document.getElementById('share-section');
  const btnShare = document.getElementById('btn-share');
  const btnCloseShare = document.getElementById('btn-close-share');
  const btnSendShare = document.getElementById('btn-send-share');

  if (btnShare && shareSection) {
    btnShare.addEventListener('click', () => {
      shareSection.style.display = '';
      if (commentsSection) commentsSection.style.display = 'none';
    });
    shareSection.addEventListener('click', (e) => { if (e.target === shareSection) shareSection.style.display = 'none'; });
  }
  if (btnCloseShare && shareSection) {
    btnCloseShare.addEventListener('click', () => { shareSection.style.display = 'none'; });
  }
  if (btnSendShare) {
    btnSendShare.addEventListener('click', () => {
      const to = (document.getElementById('share-to') as HTMLInputElement)?.value.trim();
      const from = (document.getElementById('share-from') as HTMLInputElement)?.value.trim();
      const subject = (document.getElementById('share-subject') as HTMLInputElement)?.value.trim();
      const body = (document.getElementById('share-body') as HTMLTextAreaElement)?.value.trim();
      if (!to) { alert('Ingresa el correo del destinatario'); return; }
      const finalBody = (from ? `De: ${from}\n\n` : '') + body;
      window.location.href = `mailto:${encodeURIComponent(to)}?subject=${encodeURIComponent(subject || 'Cotización')}&body=${encodeURIComponent(finalBody)}`;
    });
  }
</script>
