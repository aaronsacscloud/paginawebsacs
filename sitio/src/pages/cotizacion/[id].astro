---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';

export const prerender = false;

const { id } = Astro.params;
const { data: quote } = await supabase.from('quotes').select('*').eq('id', id).single();

if (!quote) return Astro.redirect('/404');

// Fetch bank account if linked
let bankAccount: any = null;
if (quote.bank_account_id) {
  const { data: ba } = await supabase.from('bank_accounts').select('*').eq('id', quote.bank_account_id).single();
  bankAccount = ba;
}

const items = Array.isArray(quote.items) ? quote.items : [];
const template = quote.template || 'modern';
const isExpired = quote.vigencia && new Date(quote.vigencia) < new Date();
const daysLeft = quote.vigencia ? Math.ceil((new Date(quote.vigencia).getTime() - Date.now()) / 86400000) : 0;
const fmt = (n: number) => '$' + Math.round(n).toLocaleString('es-MX');
const fecha = new Date(quote.created_at).toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' });
const vigenciaFecha = quote.vigencia ? new Date(quote.vigencia).toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' }) : '';

// Classify items
const planItems = items.filter((i: any) => i.tipo === 'plan');
const uniqueItems = items.filter((i: any) => i.tipo === 'extra' && !i.recurrente);
const recurringItems = items.filter((i: any) => i.tipo === 'extra' && i.recurrente);

// Calculate payment breakdown
const annualPlanTotal = planItems.filter((i: any) => i.periodo === 'anual').reduce((s: number, i: any) => s + (i.subtotal || 0), 0);
const monthlyPlanTotal = planItems.filter((i: any) => i.periodo === 'mensual').reduce((s: number, i: any) => s + (i.subtotal || 0), 0);
const uniqueTotal = uniqueItems.reduce((s: number, i: any) => s + (i.monto || i.subtotal || 0), 0);
const recurringTotal = recurringItems.reduce((s: number, i: any) => s + (i.monto || i.subtotal || 0), 0);
const firstPayment = annualPlanTotal + monthlyPlanTotal + uniqueTotal + recurringTotal;
const monthlyRecurring = monthlyPlanTotal + recurringTotal;

// Auto-generate summary
const planNames = planItems.map((i: any) => `Plan ${i.nombre}`).join(' + ');
const sucTotal = planItems.reduce((s: number, i: any) => s + (parseInt(i.sucursales) || 1), 0);
const extraNames = [...uniqueItems, ...recurringItems].map((i: any) => i.nombre).filter(Boolean);
const summary = planNames ? `${planNames} para ${sucTotal} sucursal${sucTotal > 1 ? 'es' : ''}${extraNames.length ? ' con ' + extraNames.join(' y ') : ''}` : quote.empresa;

// Next annual renewal date
const nextAnnualDate = new Date();
nextAnnualDate.setFullYear(nextAnnualDate.getFullYear() + 1);
const nextAnnualStr = nextAnnualDate.toLocaleDateString('es-MX', { month: 'long', year: 'numeric' });
---

<BaseLayout title={`Cotización ${quote.numero} — Sacs`} description={`Cotización para ${quote.empresa}`}>

<div class:list={['quote-page', `quote-${template}`]} id="quote-doc">
  <div class="quote-container">
    <!-- Header -->
    <div class="quote-header">
      <div class="quote-logo">
        <span class="quote-logo-text">Sacs</span>
        <span class="quote-logo-tag">Cotización</span>
      </div>
      <div class="quote-meta">
        <div class="quote-number">{quote.numero}</div>
        <div class="quote-date">Fecha: {fecha}</div>
        <div class="quote-date">Vigencia: {quote.vigencia}</div>
        {!isExpired && daysLeft > 0 && <div class="quote-validity">Válida hasta {vigenciaFecha}</div>}
        {isExpired && <div class="quote-expired">Cotización vencida</div>}
      </div>
    </div>

    <!-- Client info -->
    <div class="quote-client">
      <div class="quote-client-label">Cotización para:</div>
      <div class="quote-client-name">{quote.empresa}</div>
      {quote.contacto && <div class="quote-client-detail">{quote.contacto}</div>}
      {quote.email && <div class="quote-client-detail">{quote.email}</div>}
      {quote.whatsapp && <div class="quote-client-detail">{quote.whatsapp}</div>}
    </div>

    <!-- Urgency timer -->
    {!isExpired && daysLeft > 0 && daysLeft <= 15 && (
      <div class:list={['quote-timer', { 'quote-timer--urgent': daysLeft <= 5 }]}>
        <div class="quote-timer-label">{quote.urgencia === 'oferta' ? 'Oferta especial' : 'Esta cotización'} vence en</div>
        <div class="quote-timer-countdown" id="countdown" data-expires={quote.vigencia}>
          <span class="quote-timer-num" id="timer-days">{daysLeft}</span>
          <span class="quote-timer-unit">días</span>
          <span class="quote-timer-num" id="timer-hours">0</span>
          <span class="quote-timer-unit">horas</span>
          <span class="quote-timer-num" id="timer-mins">0</span>
          <span class="quote-timer-unit">min</span>
        </div>
        {quote.descuento_global > 0 && (
          <div class="quote-timer-savings">Los descuentos de esta cotización representan un ahorro de {fmt(quote.subtotal * quote.descuento_global / 100)} {quote.moneda}</div>
        )}
      </div>
    )}

    <!-- Executive summary -->
    <div class="quote-summary">
      {summary}
    </div>

    <!-- Items table -->
    <table class="quote-table">
      <thead>
        <tr>
          <th class="qt-concept">Concepto</th>
          <th class="qt-detail">Detalle</th>
          <th class="qt-qty">Cant.</th>
          <th class="qt-price">Precio unit.</th>
          <th class="qt-subtotal">Subtotal</th>
        </tr>
      </thead>
      <tbody>
        {items.map((item: any) => {
          const isAnnual = item.periodo === 'anual';
          const suc = parseInt(item.sucursales) || 1;
          const monthlyFull = (item.precio_unitario || 0) * suc * 12;
          const annualPrice = (item.precio_unitario || 0) * suc * 10;
          const savings = isAnnual ? monthlyFull - annualPrice : 0;
          const hasDiscount = item.tipo === 'plan' && parseFloat(item.descuento_pct || 0) > 0;
          const beforeDiscount = (item.precio_unitario || 0) * suc * (isAnnual ? 10 : 1);

          return (
            <tr>
              <td class="qt-concept">
                <strong>{item.tipo === 'plan' ? `Plan ${item.nombre}` : item.nombre}</strong>
                {item.tipo === 'plan' && (
                  <div class="qt-desc">
                    {fmt(item.precio_unitario || 0)}/suc × {suc} suc. × {isAnnual ? '10 meses' : '1 mes'}
                    {isAnnual && <span class="qt-savings"> · Ahorro: {fmt(savings)} (2 meses gratis)</span>}
                  </div>
                )}
                {item.descripcion && <div class="qt-desc">{item.descripcion}</div>}
              </td>
              <td class="qt-detail">
                {item.tipo === 'plan' ? (isAnnual ? 'Anual' : 'Mensual') : item.recurrente ? 'Recurrente' : 'Único'}
              </td>
              <td class="qt-qty">{item.tipo === 'plan' ? `${suc} suc.` : '1'}</td>
              <td class="qt-price">{fmt(item.precio_unitario || item.monto || 0)}</td>
              <td class="qt-subtotal">
                {hasDiscount && <span class="qt-strikethrough">{fmt(beforeDiscount)}</span>}
                {fmt(item.subtotal || item.monto || 0)} {quote.moneda}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>

    <!-- Totals -->
    <div class="quote-totals">
      <div class="quote-total-row">
        <span>Subtotal</span>
        <span>{fmt(quote.subtotal || 0)} {quote.moneda}</span>
      </div>
      {quote.descuento_global > 0 && (
        <div class="quote-total-row quote-discount">
          <span>Descuento {quote.descuento_tipo === 'pct' ? `(${quote.descuento_global}%)` : ''}</span>
          <span>-{fmt(quote.descuento_tipo === 'pct' ? (quote.subtotal || 0) * quote.descuento_global / 100 : quote.descuento_global)} {quote.moneda}</span>
        </div>
      )}
      {quote.iva_incluido && (
        <div class="quote-total-row">
          <span>IVA (16%)</span>
          <span>{fmt(quote.iva_monto || 0)} {quote.moneda}</span>
        </div>
      )}
      <div class="quote-total-row quote-total-final">
        <span>Total</span>
        <span>{fmt(quote.total || 0)} {quote.moneda}</span>
      </div>
    </div>

    <!-- Payment breakdown -->
    {(annualPlanTotal > 0 || uniqueTotal > 0 || monthlyRecurring > 0) && (
      <div class="quote-payments">
        <div class="quote-payments-title">Resumen de pagos</div>

        <div class="quote-payment-block">
          <div class="quote-payment-label">Primer pago</div>
          {planItems.map((i: any) => (
            <div class="quote-payment-line">
              <span>Plan {i.nombre} ({i.periodo}) · {i.sucursales} suc.</span>
              <span>{fmt(i.subtotal || 0)}</span>
            </div>
          ))}
          {uniqueItems.map((i: any) => (
            <div class="quote-payment-line">
              <span>{i.nombre} (único)</span>
              <span>{fmt(i.monto || i.subtotal || 0)}</span>
            </div>
          ))}
          {recurringItems.map((i: any) => (
            <div class="quote-payment-line">
              <span>{i.nombre}</span>
              <span>{fmt(i.monto || i.subtotal || 0)}</span>
            </div>
          ))}
          <div class="quote-payment-total">
            <span>Total primer pago {quote.iva_incluido ? '(con IVA)' : ''}</span>
            <span>{fmt(quote.total || 0)} {quote.moneda}</span>
          </div>
        </div>

        {monthlyRecurring > 0 && (
          <div class="quote-payment-block">
            <div class="quote-payment-label">Pago mensual recurrente</div>
            {planItems.filter((i: any) => i.periodo === 'mensual').map((i: any) => (
              <div class="quote-payment-line"><span>Plan {i.nombre} · {i.sucursales} suc.</span><span>{fmt(i.subtotal || 0)}</span></div>
            ))}
            {recurringItems.map((i: any) => (
              <div class="quote-payment-line"><span>{i.nombre}</span><span>{fmt(i.monto || 0)}</span></div>
            ))}
            <div class="quote-payment-total">
              <span>Total mensual {quote.iva_incluido ? '(+IVA)' : ''}</span>
              <span>{fmt(monthlyRecurring)} {quote.moneda}/mes</span>
            </div>
          </div>
        )}

        {annualPlanTotal > 0 && (
          <div class="quote-payment-block">
            <div class="quote-payment-label">Próxima renovación anual: {nextAnnualStr}</div>
            {planItems.filter((i: any) => i.periodo === 'anual').map((i: any) => (
              <div class="quote-payment-line"><span>Renovación Plan {i.nombre} · {i.sucursales} suc.</span><span>{fmt(i.subtotal || 0)}</span></div>
            ))}
          </div>
        )}
      </div>
    )}

    <!-- Conditions -->
    {quote.condiciones && (
      <div class="quote-conditions">
        <div class="quote-conditions-title">Condiciones</div>
        <div class="quote-conditions-text">{quote.condiciones}</div>
      </div>
    )}

    <!-- Bank account -->
    {bankAccount && quote.mostrar_banco && (
      <div class="quote-bank">
        <div class="quote-bank-title">Datos para transferencia</div>
        <div class="quote-bank-grid">
          <div class="quote-bank-item"><span class="quote-bank-label">Banco</span><span class="quote-bank-value">{bankAccount.banco}</span></div>
          <div class="quote-bank-item"><span class="quote-bank-label">Titular</span><span class="quote-bank-value">{bankAccount.titular}</span></div>
          <div class="quote-bank-item"><span class="quote-bank-label">Cuenta</span><span class="quote-bank-value">{bankAccount.cuenta}</span></div>
          <div class="quote-bank-item"><span class="quote-bank-label">CLABE</span><span class="quote-bank-value" style="font-family:monospace;letter-spacing:0.05em">{bankAccount.clabe}</span></div>
          {bankAccount.rfc && <div class="quote-bank-item"><span class="quote-bank-label">RFC</span><span class="quote-bank-value">{bankAccount.rfc}</span></div>}
        </div>
      </div>
    )}

    <!-- Payment link -->
    {quote.link_pago && (
      <div class="quote-pay-link">
        <a href={quote.link_pago} target="_blank" rel="noopener" class="quote-pay-btn">Pagar ahora</a>
        <div class="quote-pay-note">Pago seguro. Al completar el pago, tu servicio se activa de inmediato.</div>
      </div>
    )}

    <!-- Footer -->
    <div class="quote-footer">
      <div class="quote-footer-brand">
        <span class="quote-footer-logo">Sacs</span>
        <span class="quote-footer-tagline">Sistema operativo para retailers</span>
      </div>
      <div class="quote-footer-contact">
        www.sacscloud.com · administracion@sacscloud.com
      </div>
    </div>
  </div>

  <!-- Actions (hidden in print) -->
  <div class="quote-actions no-print">
    {quote.estado !== 'accepted' && !isExpired && (
      <button class="quote-action-btn quote-action-accept" id="btn-accept">Aceptar cotización</button>
    )}
    {quote.estado === 'accepted' && (
      <div class="quote-accepted-badge">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" stroke="currentColor" stroke-width="2"/><path d="M22 4L12 14.01l-3-3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        Cotización aceptada {quote.aceptado_por ? `por ${quote.aceptado_por}` : ''}
      </div>
    )}
    <button class="quote-action-btn quote-action-pdf" onclick="window.print()">Descargar PDF</button>
    <a class="quote-action-btn quote-action-wa" href={`https://wa.me/?text=${encodeURIComponent(`Hola, te comparto la cotización ${quote.numero} de Sacs: https://www.sacscloud.com/cotizacion/${quote.id}`)}`} target="_blank">Compartir por WhatsApp</a>
  </div>
</div>

</BaseLayout>

<style>
:global(nav), :global(.nav), :global(header), :global(footer), :global(.whatsapp-float) { display: none !important; }

.quote-page { max-width: 800px; margin: 0 auto; padding: 40px 24px 80px; }
.quote-container { background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }

/* ─── Header ─── */
.quote-header { display: flex; justify-content: space-between; align-items: flex-start; padding: 40px 40px 24px; border-bottom: 1px solid #f0f0f0; }
.quote-logo { display: flex; align-items: center; gap: 10px; }
.quote-logo-text { font-family: var(--font-logo); font-size: 2rem; font-weight: 700; color: #1a1a1a; }
.quote-logo-tag { font-size: 0.6875rem; font-weight: 700; color: var(--color-primary); background: rgba(75,123,229,0.08); padding: 3px 10px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.08em; }
.quote-meta { text-align: right; }
.quote-number { font-family: var(--font-display); font-size: 1.25rem; font-weight: 800; color: #1a1a1a; }
.quote-date { font-size: 0.8125rem; color: #999; margin-top: 2px; }
.quote-validity { font-size: 0.6875rem; font-weight: 700; color: var(--color-secondary); background: rgba(42,181,160,0.08); padding: 3px 10px; border-radius: 20px; display: inline-block; margin-top: 8px; }
.quote-expired { font-size: 0.6875rem; font-weight: 700; color: #E54B4B; background: rgba(229,75,75,0.08); padding: 3px 10px; border-radius: 20px; display: inline-block; margin-top: 8px; }

/* ─── Client ─── */
.quote-client { padding: 24px 40px; }
.quote-client-label { font-size: 0.625rem; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px; }
.quote-client-name { font-family: var(--font-display); font-size: 1.125rem; font-weight: 700; color: #1a1a1a; }
.quote-client-detail { font-size: 0.8125rem; color: #666; margin-top: 2px; }

/* ─── Table ─── */
.quote-table { width: 100%; border-collapse: collapse; }
.quote-table th { font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: #aaa; padding: 12px 16px; text-align: left; background: #fafafa; border-top: 1px solid #f0f0f0; border-bottom: 1px solid #f0f0f0; }
.quote-table td { padding: 16px; font-size: 0.875rem; color: #555; border-bottom: 1px solid #f5f5f5; }
.quote-table td strong { color: #1a1a1a; }
.qt-desc { font-size: 0.75rem; color: #999; margin-top: 2px; }
.qt-detail, .qt-qty { white-space: nowrap; }
.qt-price, .qt-subtotal { text-align: right; white-space: nowrap; font-weight: 600; }
.quote-table th.qt-price, .quote-table th.qt-subtotal { text-align: right; }

/* ─── Timer ─── */
.quote-timer { padding: 24px 40px; background: linear-gradient(135deg, #4B7BE5, #3D6BD4); text-align: center; color: #fff; }
.quote-timer--urgent { background: linear-gradient(135deg, #E54B4B, #c62828); }
.quote-timer-label { font-size: 0.8125rem; font-weight: 500; opacity: 0.8; margin-bottom: 8px; }
.quote-timer-countdown { display: flex; justify-content: center; align-items: baseline; gap: 4px; }
.quote-timer-num { font-family: var(--font-display); font-size: 2.5rem; font-weight: 800; line-height: 1; }
.quote-timer-unit { font-size: 0.75rem; font-weight: 500; opacity: 0.7; margin-right: 12px; }
.quote-timer-savings { font-size: 0.8125rem; font-weight: 600; margin-top: 12px; opacity: 0.9; }

.quote-dark .quote-timer { background: linear-gradient(135deg, #2AB5A0, #1a8a76); }
.quote-dark .quote-timer--urgent { background: linear-gradient(135deg, #E54B4B, #c62828); }

/* ─── Bank account ─── */
.quote-bank { padding: 24px 40px; border-top: 1px solid #f0f0f0; }
.quote-bank-title { font-size: 0.625rem; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 12px; }
.quote-bank-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.quote-bank-item { display: flex; flex-direction: column; }
.quote-bank-label { font-size: 0.625rem; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.06em; }
.quote-bank-value { font-size: 0.875rem; font-weight: 600; color: #1a1a1a; margin-top: 2px; }

.quote-dark .quote-bank { border-color: rgba(255,255,255,0.08); }
.quote-dark .quote-bank-value { color: #fff; }

/* ─── Pay link ─── */
.quote-pay-link { padding: 24px 40px; text-align: center; border-top: 1px solid #f0f0f0; }
.quote-pay-btn { display: inline-block; padding: 16px 48px; background: #2AB5A0; color: #fff; font-size: 1.0625rem; font-weight: 700; border-radius: 50px; text-decoration: none; transition: all 0.2s ease; }
.quote-pay-btn:hover { background: #239688; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(42,181,160,0.3); }
.quote-pay-note { font-size: 0.6875rem; color: #999; margin-top: 8px; }

.quote-dark .quote-pay-link { border-color: rgba(255,255,255,0.08); }

/* ─── Summary ─── */
.quote-summary { padding: 0 40px 20px; font-size: 1rem; font-weight: 600; color: var(--color-primary); line-height: 1.5; font-style: italic; }

/* ─── Strikethrough price ─── */
.qt-strikethrough { text-decoration: line-through; color: #ccc; font-weight: 400; margin-right: 6px; font-size: 0.75rem; }

/* ─── Savings ─── */
.qt-savings { color: #2AB5A0; font-weight: 600; }

/* ─── Totals ─── */
.quote-totals { padding: 20px 40px; }
.quote-total-row { display: flex; justify-content: space-between; padding: 8px 0; font-size: 0.875rem; color: #666; }
.quote-total-row.quote-discount { color: #2AB5A0; }
.quote-total-row.quote-total-final { font-family: var(--font-display); font-size: 1.25rem; font-weight: 800; color: #1a1a1a; border-top: 2px solid #1a1a1a; padding-top: 12px; margin-top: 8px; }

/* ─── Payment breakdown ─── */
.quote-payments { padding: 20px 40px; border-top: 1px solid #f0f0f0; }
.quote-payments-title { font-family: var(--font-display); font-size: 0.875rem; font-weight: 700; color: #1a1a1a; margin-bottom: 16px; }
.quote-payment-block { margin-bottom: 16px; padding: 16px; background: #fafafa; border-radius: 10px; }
.quote-payment-label { font-size: 0.6875rem; font-weight: 700; color: #666; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px; }
.quote-payment-line { display: flex; justify-content: space-between; font-size: 0.8125rem; color: #666; padding: 4px 0; }
.quote-payment-total { display: flex; justify-content: space-between; font-size: 0.9375rem; font-weight: 800; color: #1a1a1a; border-top: 1px solid #e0e0e0; padding-top: 8px; margin-top: 8px; }

.quote-dark .quote-summary { color: #2AB5A0; }
.quote-dark .quote-payments { border-color: rgba(255,255,255,0.08); }
.quote-dark .quote-payment-block { background: rgba(255,255,255,0.03); }
.quote-dark .quote-payment-label { color: rgba(255,255,255,0.4); }
.quote-dark .quote-payment-line { color: rgba(255,255,255,0.5); }
.quote-dark .quote-payment-total { color: #fff; border-color: rgba(255,255,255,0.1); }

/* ─── Conditions ─── */
.quote-conditions { padding: 20px 40px; border-top: 1px solid #f0f0f0; }
.quote-conditions-title { font-size: 0.625rem; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; }
.quote-conditions-text { font-size: 0.8125rem; color: #888; line-height: 1.6; white-space: pre-line; }

/* ─── Footer ─── */
.quote-footer { padding: 24px 40px; background: #fafafa; border-top: 1px solid #f0f0f0; display: flex; justify-content: space-between; align-items: center; }
.quote-footer-logo { font-family: var(--font-logo); font-size: 1rem; font-weight: 700; color: #1a1a1a; }
.quote-footer-tagline { font-size: 0.6875rem; color: #aaa; margin-left: 8px; }
.quote-footer-contact { font-size: 0.6875rem; color: #aaa; }

/* ─── Actions ─── */
.quote-actions { display: flex; gap: 10px; justify-content: center; margin-top: 24px; flex-wrap: wrap; }
.quote-action-btn { padding: 12px 24px; border-radius: 50px; font-size: 0.875rem; font-weight: 600; cursor: pointer; text-decoration: none; border: none; font-family: inherit; display: inline-flex; align-items: center; gap: 6px; }
.quote-action-accept { background: #1a1a1a; color: #fff; }
.quote-action-accept:hover { background: #333; }
.quote-action-pdf { background: #f0f0f0; color: #555; }
.quote-action-pdf:hover { background: #e0e0e0; }
.quote-action-wa { background: #e8f5e9; color: #2e7d32; }
.quote-action-wa:hover { background: #c8e6c9; }
.quote-accepted-badge { display: flex; align-items: center; gap: 6px; font-size: 0.875rem; font-weight: 700; color: #2AB5A0; }

/* ─── Dark template ─── */
.quote-dark .quote-container { background: #1a1a1a; color: #fff; }
.quote-dark .quote-logo-text { color: #fff; }
