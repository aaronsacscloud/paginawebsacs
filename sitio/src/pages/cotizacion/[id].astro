.quote-conscious-label { font-size: 0.5625rem; font-weight: 700; color: #2AB5A0; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 8px; }
.quote-conscious-heading { font-family: var(--font-display); font-size: 1.25rem; font-weight: 800; color: #1a1a1a; margin-bottom: 10px; line-height: 1.3; }
