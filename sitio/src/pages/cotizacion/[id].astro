@media (max-width: 640px) {
  .quote-header { flex-direction: column; gap: 8px; padding: 16px 20px 12px; }
  .quote-meta { text-align: left; }
  .quote-client { padding: 14px 20px; }
  .quote-status { margin-bottom: 6px; }
  .quote-expired-note { padding: 10px 20px; flex-wrap: wrap; }
  /* Tab intro — compact on mobile so timer/vigencia is visible above the fold */
  .quote-tab-intro { padding: 18px 20px 16px; }
  .quote-tab-intro-eyebrow { margin-bottom: 6px; }
  .quote-tab-intro-heading { font-size: 1.125rem; line-height: 1.3; margin-bottom: 0; }
  .quote-tab-intro-total-value { font-size: 2rem; }
  /* Key points */
  .quote-key-points { padding: 32px 24px; }
  .quote-key-points-title { font-size: 1.25rem; margin-bottom: 20px; }
  /* Table */
  .quote-table { font-size: 0.75rem; }
  .quote-table th, .quote-table td { padding: 10px 12px; }
  .qt-detail, .qt-qty { display: none; }
  .qt-price { font-size: 0.6875rem; }
  .qt-subtotal { font-size: 0.75rem; }
  .qt-concept strong { font-size: 0.8125rem; }
  .qt-desc { font-size: 0.6875rem; }
  .qt-nota { font-size: 0.6875rem; }
  .qt-strikethrough { font-size: 0.625rem; }
  .quote-total-row { font-size: 0.8125rem; }
  .quote-total-row.quote-total-final { font-size: 1.125rem; }
  .quote-totals { padding: 20px 24px; }
  /* Timer — compact en mobile y prominente para verse arriba del fold */
  .quote-timer { padding: 14px 18px 16px; margin-top: 4px; }
  .quote-timer-num { font-size: 1.5rem; }
  .quote-timer-savings { font-size: 0.6875rem; margin-top: 6px; }
  .quote-timer-extended { font-size: 0.625rem; padding: 3px 10px; margin-bottom: 6px; gap: 5px; }
  .quote-timer-promo { font-size: 0.625rem; padding: 4px 10px 4px 8px; gap: 6px; margin-bottom: 8px; }
  .quote-timer-promo-name { font-size: 0.6875rem; }
  .quote-timer-label { font-size: 0.625rem; }
  .quote-timer-deadline { font-size: 0.75rem; margin-top: 8px; }
  .quote-timer-warning { font-size: 0.625rem; margin-top: 4px; }
  /* Expired notice */
  .quote-expired-notice { margin: 0 24px 12px; padding: 12px 14px; font-size: 0.75rem; }
  /* Compare prices stack on mobile */
  .qt-compare { align-items: flex-end; }
  .qt-price-strike, .qt-price-normal { font-size: 0.75rem; }
  /* Payments */
  .quote-payments { padding: 24px; }
  .quote-payment-block { padding: 14px; }
  .quote-payment-line { font-size: 0.75rem; }
  .quote-payment-total { font-size: 0.875rem; }
  /* Conditions */
  .quote-conditions { padding: 20px 24px; }
  /* Features */
  .quote-features { padding: 24px; }
  .quote-features-grid { grid-template-columns: 1fr; }
  /* Cross-tab link */
  .quote-tab-cross { padding: 0 24px 20px; }
  /* Signed closed */
  .quote-signed { padding: 32px 24px; }
  .quote-signed--closed { padding: 40px 24px; }
  .quote-signed-title { font-size: 1.375rem; }
  .quote-signed-sub { font-size: 0.8125rem; }
  /* Conscious Commerce */
  .quote-conscious { padding: 32px 24px; }
  .quote-conscious-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .quote-conscious-char { font-size: 1.25rem; }
  .quote-conscious-journey-steps { flex-direction: column; gap: 14px; }
  .quote-conscious-jarrow { display: none; }
  .quote-conscious-jstep { text-align: left; display: flex; gap: 12px; align-items: flex-start; }
  .quote-conscious-jnum { font-size: 1.25rem; flex-shrink: 0; }
  .quote-conscious-video video { width: 140px; height: 140px; }
  /* ROI */
  .quote-roi { padding: 24px; }
  .quote-roi-numbers { flex-direction: column; gap: 10px; }
  /* Comparison */
  .quote-comparison { padding: 24px; }
  .quote-comp-td, .quote-comp-th { padding: 8px 6px; font-size: 0.75rem; }
  /* Timeline */
  .quote-timeline-section { padding: 32px 24px; }
  /* Why SACS */
  .quote-why { padding: 32px 24px; }
  .quote-why-stats { gap: 20px; }
  .quote-why-stat-num { font-size: 1.25rem; }
  /* Cases */
  .quote-case-card { min-width: 260px; }
  .quote-cases-title { padding: 0 24px; }
  .quote-cases-track { padding: 0 24px; }
  /* Bank */
  .quote-bank { padding: 20px 24px; }
  .quote-bank-grid { grid-template-columns: 1fr; }
  /* Legal */
  .quote-legal { padding: 16px 24px; }
  /* Versions */
  .quote-versions { padding: 20px 24px; }
  /* Signature */
  .quote-signature { padding: 24px; }
  /* QR */
  .quote-qr { padding: 20px 24px; }
  /* Footer */
  .quote-footer { flex-direction: column; gap: 10px; padding: 20px 24px; text-align: center; }
}
</style>

<script>
  // Countdown timer — DOM-cached, visibility-aware, self-stops at zero
  const countdown = document.getElementById('countdown');
  if (countdown) {
    const expiresRaw = countdown.dataset.expires || '';
    const expires = new Date(expiresRaw + 'T23:59:59').getTime();
    const dEl = document.getElementById('timer-days');
    const hEl = document.getElementById('timer-hours');
    const mEl = document.getElementById('timer-mins');
    const sEl = document.getElementById('timer-secs');
    let intervalId: ReturnType<typeof setInterval> | null = null;

    function tick() {
      const diff = expires - Date.now();
      if (diff <= 0) {
        if (dEl) dEl.textContent = '0';
        if (hEl) hEl.textContent = '0';
        if (mEl) mEl.textContent = '0';
        if (sEl) sEl.textContent = '0';
        if (intervalId !== null) { clearInterval(intervalId); intervalId = null; }
        return;
      }
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const mins = Math.floor((diff % 3600000) / 60000);
      const secs = Math.floor((diff % 60000) / 1000);
      if (dEl) dEl.textContent = String(days);
      if (hEl) hEl.textContent = String(hours);
      if (mEl) mEl.textContent = String(mins);
      if (sEl) sEl.textContent = String(secs);
    }

    function start() {
      if (intervalId !== null) return;
      tick();
      intervalId = setInterval(tick, 1000);
    }
    function stop() {
      if (intervalId !== null) { clearInterval(intervalId); intervalId = null; }
    }

    if (!isNaN(expires)) {
      start();
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stop();
        else { tick(); start(); }
      }, { passive: true });
    }
  }

  // ─── Track view (skip if admin) ───
  const quoteId = window.location.pathname.split('/').pop();
  const isAdmin = new URLSearchParams(window.location.search).has('admin');
  if (quoteId && !isAdmin) {
    fetch('/api/revenue/quote-view', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: quoteId }),
    }).catch(() => {});
  }

  // ─── Comments ───
  const commentsSection = document.getElementById('comments-section');
  const commentsThread = document.getElementById('comments-thread');
  const commentsEmpty = document.getElementById('comments-empty');
  const btnComments = document.getElementById('btn-comments');
  const btnClose = document.getElementById('btn-close-comments');
  const btnSend = document.getElementById('btn-send-comment');

  function fmtCommentDate(d: string) {
    const date = new Date(d);
    const day = date.getDate();
    const month = date.toLocaleDateString('es-MX', { month: 'short' }).replace('.', '');
    const time = date.toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' });
    return `${day}/${month} ${time}`;
  }

  function renderComments(comments: any[]) {
    if (!commentsThread) return;
    if (comments.length === 0) {
      if (commentsEmpty) commentsEmpty.style.display = '';
      return;
    }
    if (commentsEmpty) commentsEmpty.style.display = 'none';
    // Remove old comments (keep empty placeholder)
    commentsThread.querySelectorAll('.quote-comment').forEach(el => el.remove());
    comments.forEach((c: any) => {
      const div = document.createElement('div');
      div.className = `quote-comment quote-comment--${c.from || 'prospect'}`;
      div.innerHTML = `
        <div class="quote-comment-bubble">${c.text.replace(/</g, '&lt;').replace(/\n/g, '<br>')}</div>
        <div class="quote-comment-meta">
          <span class="quote-comment-name">${c.from === 'admin' ? 'Sacs' : (c.name || 'Cliente').replace(/</g, '&lt;')}</span>
          <span class="quote-comment-time">${fmtCommentDate(c.at)}</span>
        </div>
      `;
      commentsThread.appendChild(div);
    });
    commentsThread.scrollTop = commentsThread.scrollHeight;
  }

  async function loadComments() {
    const res = await fetch(`/api/revenue/quote-comments?id=${quoteId}`);
    const data = await res.json();
    renderComments(data.comments || []);
  }

  if (btnComments && commentsSection) {
    btnComments.addEventListener('click', () => {
      commentsSection.style.display = '';
      if (shareSection) shareSection.style.display = 'none';
      loadComments();
    });
    commentsSection.addEventListener('click', (e) => { if (e.target === commentsSection) commentsSection.style.display = 'none'; });
  }
  if (btnClose && commentsSection) {
    btnClose.addEventListener('click', () => {
      commentsSection.style.display = 'none';
    });
  }
  if (btnSend) {
    btnSend.addEventListener('click', async () => {
      const nameEl = document.getElementById('comment-name') as HTMLInputElement;
      const textEl = document.getElementById('comment-text') as HTMLTextAreaElement;
      const name = nameEl?.value.trim();
      const text = textEl?.value.trim();
      if (!text) return;
      btnSend.textContent = 'Enviando...';
      const res = await fetch('/api/revenue/quote-comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: quoteId, from: 'prospect', name: name || 'Cliente', text }),
      });
      const data = await res.json();
      renderComments(data.comments || []);
      if (textEl) textEl.value = '';
      btnSend.textContent = 'Enviar comentario';
    });
  }

  // ─── Share by email ───
  const shareSection = document.getElementById('share-section');
  const btnShare = document.getElementById('btn-share');
  const btnCloseShare = document.getElementById('btn-close-share');
  const btnSendShare = document.getElementById('btn-send-share');

  if (btnShare && shareSection) {
    btnShare.addEventListener('click', () => {
      shareSection.style.display = '';
      if (commentsSection) commentsSection.style.display = 'none';
    });
    shareSection.addEventListener('click', (e) => { if (e.target === shareSection) shareSection.style.display = 'none'; });
  }
  if (btnCloseShare && shareSection) {
    btnCloseShare.addEventListener('click', () => { shareSection.style.display = 'none'; });
  }
  if (btnSendShare) {
    btnSendShare.addEventListener('click', () => {
      const to = (document.getElementById('share-to') as HTMLInputElement)?.value.trim();
      const from = (document.getElementById('share-from') as HTMLInputElement)?.value.trim();
      const subject = (document.getElementById('share-subject') as HTMLInputElement)?.value.trim();
      const body = (document.getElementById('share-body') as HTMLTextAreaElement)?.value.trim();
      if (!to) { alert('Ingresa el correo del destinatario'); return; }
      const finalBody = (from ? `De: ${from}\n\n` : '') + body;
      window.location.href = `mailto:${encodeURIComponent(to)}?subject=${encodeURIComponent(subject || 'Cotización')}&body=${encodeURIComponent(finalBody)}`;
    });
  }

  // ─── Timeline scroll animation ───
  const tlSteps = document.querySelectorAll('.quote-tl-step');
  if (tlSteps.length) {
    tlSteps.forEach(step => { (step as HTMLElement).style.opacity = '0'; (step as HTMLElement).style.transform = 'translateY(20px)'; (step as HTMLElement).style.transition = 'opacity 0.5s ease, transform 0.5s ease'; });
    const revealSteps = () => {
      tlSteps.forEach((step, i) => {
        const rect = step.getBoundingClientRect();
        if (rect.top < window.innerHeight - 60) {
          setTimeout(() => { (step as HTMLElement).style.opacity = '1'; (step as HTMLElement).style.transform = 'translateY(0)'; }, i * 120);
        }
      });
    };
    revealSteps();
    window.addEventListener('scroll', revealSteps, { passive: true });
  }

  // ─── Cases carousel ───
  const casesTrack = document.getElementById('cases-track');
  const casesDots = document.querySelectorAll('.quote-cases-dot');
  if (casesTrack && casesDots.length) {
    casesDots.forEach(dot => {
      dot.addEventListener('click', () => {
        const idx = parseInt((dot as HTMLElement).dataset.idx || '0');
        const card = casesTrack.children[idx] as HTMLElement;
        if (card) casesTrack.scrollTo({ left: card.offsetLeft - 40, behavior: 'smooth' });
      });
    });
    casesTrack.addEventListener('scroll', () => {
      const scrollLeft = casesTrack.scrollLeft;
      let activeIdx = 0;
      for (let i = 0; i < casesTrack.children.length; i++) {
        const child = casesTrack.children[i] as HTMLElement;
        if (child.offsetLeft - 40 <= scrollLeft + 20) activeIdx = i;
      }
      casesDots.forEach((d, i) => d.classList.toggle('active', i === activeIdx));
    }, { passive: true });
    // Auto-scroll every 4s
    let autoIdx = 0;
    setInterval(() => {
      autoIdx = (autoIdx + 1) % casesTrack.children.length;
      const card = casesTrack.children[autoIdx] as HTMLElement;
      if (card) casesTrack.scrollTo({ left: card.offsetLeft - 40, behavior: 'smooth' });
    }, 4000);
  }

  // ─── Animated numbers (count-up) ───
  const animationsEnabled = !document.querySelector('[data-no-animations]');
  if (animationsEnabled) {
    document.querySelectorAll('[data-count]').forEach(el => {
      const target = parseInt((el as HTMLElement).dataset.count || '0');
      if (!target) return;
      const suffix = (el as HTMLElement).dataset.suffix || '';
      let current = 0;
      const duration = 1200;
      const steps = 50;
      const stepValue = target / steps;
      const stepTime = duration / steps;
      const interval = setInterval(() => {
        current += stepValue;
        if (current >= target) { current = target; clearInterval(interval); }
        (el as HTMLElement).textContent = '$' + Math.round(current).toLocaleString('es-MX') + suffix;
      }, stepTime);
    });
  }


  // ─── Signature canvas ───
  const sigCanvas = document.getElementById('signature-canvas') as HTMLCanvasElement;
  if (sigCanvas) {
    const ctx = sigCanvas.getContext('2d');
    let drawing = false;
    let hasDrawn = false;

    // Set canvas resolution
    const rect = sigCanvas.getBoundingClientRect();
    sigCanvas.width = rect.width * 2;
    sigCanvas.height = rect.height * 2;
    if (ctx) {
      ctx.scale(2, 2);
      ctx.strokeStyle = '#1a1a1a';
      ctx.lineWidth = 2;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
    }

    function getPos(e: MouseEvent | TouchEvent) {
      const r = sigCanvas.getBoundingClientRect();
      const t = 'touches' in e ? e.touches[0] : e;
      return { x: t.clientX - r.left, y: t.clientY - r.top };
    }

    sigCanvas.addEventListener('mousedown', (e) => { drawing = true; const p = getPos(e); ctx?.beginPath(); ctx?.moveTo(p.x, p.y); });
    sigCanvas.addEventListener('mousemove', (e) => { if (!drawing || !ctx) return; hasDrawn = true; const p = getPos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); });
    sigCanvas.addEventListener('mouseup', () => { drawing = false; });
    sigCanvas.addEventListener('mouseleave', () => { drawing = false; });
    sigCanvas.addEventListener('touchstart', (e) => { e.preventDefault(); drawing = true; const p = getPos(e); ctx?.beginPath(); ctx?.moveTo(p.x, p.y); }, { passive: false });
    sigCanvas.addEventListener('touchmove', (e) => { e.preventDefault(); if (!drawing || !ctx) return; hasDrawn = true; const p = getPos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); }, { passive: false });
    sigCanvas.addEventListener('touchend', () => { drawing = false; });

    document.getElementById('btn-clear-sig')?.addEventListener('click', () => {
      ctx?.clearRect(0, 0, sigCanvas.width, sigCanvas.height);
      hasDrawn = false;
    });

    const acceptModal = document.getElementById('accept-modal');
    const acceptInput = document.getElementById('accept-name-input') as HTMLInputElement;

    document.getElementById('btn-accept-sig')?.addEventListener('click', () => {
      if (!hasDrawn) { alert('Dibuja tu firma primero'); return; }
      if (acceptModal) { acceptModal.style.display = ''; acceptInput?.focus(); }
    });

    document.getElementById('btn-close-accept')?.addEventListener('click', () => { if (acceptModal) acceptModal.style.display = 'none'; });
    document.getElementById('btn-cancel-accept')?.addEventListener('click', () => { if (acceptModal) acceptModal.style.display = 'none'; });
    acceptModal?.addEventListener('click', (e) => { if (e.target === acceptModal) acceptModal.style.display = 'none'; });

    document.getElementById('btn-confirm-accept')?.addEventListener('click', async () => {
      const name = acceptInput?.value.trim();
      if (!name) { acceptInput?.focus(); return; }
      const btn = document.getElementById('btn-confirm-accept') as HTMLButtonElement;
      btn.textContent = 'Procesando...';
      btn.disabled = true;

      // Capture signature as base64
      const firmaBase64 = sigCanvas ? sigCanvas.toDataURL('image/png') : '';

      // Save firma in meta via notas field
      const notasRes = await fetch(`/api/revenue/quote-view?id=${quoteId}`);
      const notasData = await notasRes.json();
      // Read current notas to preserve meta
      const quoteRes = await fetch(`/api/revenue/quotes?id=${quoteId}`);
      const quoteData = await quoteRes.json();
      let notas = quoteData.notas || '';
      const sep = '\n---META---\n';
      const sepIdx = notas.indexOf(sep);
      let metaText = sepIdx >= 0 ? notas.slice(0, sepIdx) : notas;
      let metaObj: any = {};
      if (sepIdx >= 0) { try { metaObj = JSON.parse(notas.slice(sepIdx + sep.length)); } catch {} }
      metaObj.firma_base64 = firmaBase64;
      if (!metaObj.timeline) metaObj.timeline = [];
      metaObj.timeline.push({ event: 'accepted', at: new Date().toISOString() });
      notas = metaText + sep + JSON.stringify(metaObj);

      await fetch('/api/revenue/quotes', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: quoteId, estado: 'accepted', aceptado_por: name, aceptado_fecha: new Date().toISOString(), notas }),
      });

      // Close modal, show success + confetti
      if (acceptModal) acceptModal.style.display = 'none';
      const successOverlay = document.getElementById('success-overlay');
      if (successOverlay) {
        successOverlay.style.display = '';
        // Generate confetti
        const container = document.getElementById('confetti-container');
        if (container) {
          const colors = ['#4B7BE5', '#2AB5A0', '#E8A838', '#6C5CE7', '#E54B4B', '#1a1a1a'];
          for (let i = 0; i < 80; i++) {
            const piece = document.createElement('div');
            piece.className = 'confetti-piece';
            piece.style.left = Math.random() * 100 + '%';
            piece.style.background = colors[Math.floor(Math.random() * colors.length)];
            piece.style.width = (Math.random() * 8 + 6) + 'px';
            piece.style.height = (Math.random() * 8 + 6) + 'px';
            piece.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
            piece.style.animationDuration = (Math.random() * 2 + 1.5) + 's';
            piece.style.animationDelay = (Math.random() * 1) + 's';
            container.appendChild(piece);
          }
        }
      }
      setTimeout(() => { window.location.reload(); }, 3000);
    });

    acceptInput?.addEventListener('keydown', (e) => { if (e.key === 'Enter') document.getElementById('btn-confirm-accept')?.click(); });
  }

  // ─── Reject flow ───
  const rejectModal = document.getElementById('reject-modal');
  const btnOpenReject = document.getElementById('btn-open-reject');
  const btnCloseReject = document.getElementById('btn-close-reject');
  const btnCancelReject = document.getElementById('btn-cancel-reject');
  const btnConfirmReject = document.getElementById('btn-confirm-reject');

  if (btnOpenReject && rejectModal) {
    btnOpenReject.addEventListener('click', () => { rejectModal.style.display = ''; });
  }
  if (btnCloseReject && rejectModal) {
    btnCloseReject.addEventListener('click', () => { rejectModal.style.display = 'none'; });
  }
  if (btnCancelReject && rejectModal) {
    btnCancelReject.addEventListener('click', () => { rejectModal.style.display = 'none'; });
  }
  rejectModal?.addEventListener('click', (e) => { if (e.target === rejectModal) rejectModal.style.display = 'none'; });

  if (btnConfirmReject) {
    btnConfirmReject.addEventListener('click', async () => {
      const motivoEl = document.querySelector('input[name="reject-motivo"]:checked') as HTMLInputElement | null;
      const detalleEl = document.getElementById('reject-detalle') as HTMLTextAreaElement | null;
      if (!motivoEl) { alert('Selecciona un motivo'); return; }
      const btn = btnConfirmReject as HTMLButtonElement;
      btn.textContent = 'Enviando...';
      btn.disabled = true;
      try {
        const res = await fetch('/api/revenue/mark-rejected', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            quoteId,
            motivo: motivoEl.value,
            detalle: detalleEl?.value?.trim() || '',
            from: 'client',
          }),
        });
        const data = await res.json();
        if (!res.ok) {
          alert(data?.error || 'No pudimos registrar tu respuesta. Intenta de nuevo.');
          btn.textContent = 'Enviar respuesta';
          btn.disabled = false;
          return;
        }
        // Replace modal body with thank-you
        const modal = rejectModal?.querySelector('.quote-modal');
        if (modal) {
          modal.innerHTML = '<div class="quote-reject-success"><div class="quote-reject-success-title">Gracias por tu respuesta</div><div class="quote-reject-success-text">Quedamos al pendiente. Si en el futuro la situación cambia, con gusto retomamos la conversación.</div></div>';
        }
        setTimeout(() => { window.location.reload(); }, 2500);
      } catch (err) {
        alert('Error de conexión. Intenta de nuevo.');
        btn.textContent = 'Enviar respuesta';
        btn.disabled = false;
      }
    });
  }

  // ═══════════════════════════════════════════════════════════════
  //  PAGOS REALIZADOS — modal admin "Registrar pago" + reenvío de acuse
  // ═══════════════════════════════════════════════════════════════
  {
    const quoteIdForPay = window.location.pathname.split('/').filter(Boolean).pop() || '';
    const modal = document.getElementById('qph-modal') as HTMLElement | null;
    const btnAdd = document.getElementById('qph-btn-add');
    const btnClose = document.getElementById('qph-close');
    const btnCancel = document.getElementById('qph-cancel');
    const btnSubmit = document.getElementById('qph-submit') as HTMLButtonElement | null;
    const itemsAll = document.getElementById('qph-items-all') as HTMLInputElement | null;
    const itemsList = document.getElementById('qph-items-list') as HTMLElement | null;
    const fileInput = document.getElementById('qph-file') as HTMLInputElement | null;
    const fileStatus = document.getElementById('qph-file-status');
    let comprobanteUrl: string | null = null;

    function openModal() {
      if (!modal) return;
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
    function closeModal() {
      if (!modal) return;
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }

    if (btnAdd) btnAdd.addEventListener('click', openModal);
    if (btnClose) btnClose.addEventListener('click', closeModal);
    if (btnCancel) btnCancel.addEventListener('click', closeModal);
    if (modal) modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

    if (itemsAll && itemsList) {
      itemsAll.addEventListener('change', () => {
        itemsList.style.display = itemsAll.checked ? 'none' : 'flex';
      });
    }

    if (fileInput) {
      fileInput.addEventListener('change', async () => {
        const file = fileInput.files?.[0];
        if (!file) return;
        if (fileStatus) fileStatus.textContent = 'Subiendo...';
        const fd = new FormData();
        fd.append('file', file);
        try {
          const res = await fetch('/api/revenue/payment-comprobante', { method: 'POST', body: fd });
          const data = await res.json();
          if (data.url) {
            comprobanteUrl = data.url;
            if (fileStatus) fileStatus.textContent = '✓ Subido';
          } else {
            if (fileStatus) fileStatus.textContent = data.error || 'Error al subir';
          }
        } catch (err) {
          if (fileStatus) fileStatus.textContent = 'Error de red';
        }
      });
    }

    if (btnSubmit) {
      btnSubmit.addEventListener('click', async () => {
        const monto = Number((document.getElementById('qph-monto') as HTMLInputElement)?.value || 0);
        const fecha = (document.getElementById('qph-fecha') as HTMLInputElement)?.value;
        const metodo = (document.getElementById('qph-metodo') as HTMLSelectElement)?.value;
        const referencia = (document.getElementById('qph-referencia') as HTMLInputElement)?.value;
        const notas = (document.getElementById('qph-notas') as HTMLTextAreaElement)?.value;
        const enviarAcuse = (document.getElementById('qph-enviar-email') as HTMLInputElement)?.checked;
        const usarTodos = itemsAll?.checked !== false;

        if (!monto || monto <= 0) { alert('Captura un monto válido.'); return; }
        if (!fecha) { alert('Captura la fecha.'); return; }

        let itemsCubiertos: number[] | null = null;
        if (!usarTodos) {
          itemsCubiertos = Array.from(document.querySelectorAll<HTMLInputElement>('.qph-item-cb'))
            .filter(cb => cb.checked)
            .map(cb => Number(cb.dataset.idx));
          if (itemsCubiertos.length === 0) {
            alert('Selecciona al menos un concepto o marca "Todos".');
            return;
          }
        }

        btnSubmit.disabled = true;
        btnSubmit.textContent = 'Guardando...';

        try {
          const res = await fetch('/api/revenue/payments', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              quote_id: quoteIdForPay,
              fecha,
              monto,
              metodo,
              referencia: referencia || null,
              comprobante_url: comprobanteUrl,
              notas: notas || null,
              items_cubiertos: itemsCubiertos,
              enviar_acuse: !!enviarAcuse,
            }),
          });
          const data = await res.json();
          if (!res.ok || data.error) {
            alert(data.error || 'No se pudo registrar el pago.');
            btnSubmit.disabled = false;
            btnSubmit.textContent = 'Guardar y generar acuse';
            return;
          }
          // Éxito → ir al acuse
          if (data.id) {
            window.location.href = `/acuse/${data.id}?admin`;
          } else {
            window.location.reload();
          }
        } catch (err) {
          alert('Error de red. Intenta de nuevo.');
          btnSubmit.disabled = false;
          btnSubmit.textContent = 'Guardar y generar acuse';
        }
      });
    }

    // Reenviar acuse desde botones inline
    document.querySelectorAll<HTMLButtonElement>('.qph-row-resend').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const pid = btn.dataset.pid;
        if (!pid) return;
        const original = btn.textContent || 'Reenviar';
        btn.disabled = true;
        btn.textContent = 'Enviando...';
        try {
          const res = await fetch(`/api/revenue/payments/${pid}/send-acuse`, { method: 'POST' });
          const data = await res.json();
          btn.textContent = data.ok ? '✓ Enviado' : (data.reason || 'Error');
          setTimeout(() => { btn.textContent = original; btn.disabled = false; }, 2400);
        } catch (err) {
          btn.textContent = 'Error';
          setTimeout(() => { btn.textContent = original; btn.disabled = false; }, 2400);
        }
      });
    });
  }
</script>

<!-- Tab switcher: show only one panel at a time, URL-hash-synced -->
<script is:inline>
  (() => {
    const doc = document.getElementById('quote-doc');
    if (!doc) return;
    const defaultTab = doc.getAttribute('data-initial-tab') || 'resumen';
    const panels = Array.from(document.querySelectorAll('.quote-tab-panel'));
    const links = Array.from(document.querySelectorAll('[data-tab-link]'));
    if (!panels.length) return;

    // Collect tab ids that have at least one panel
    const tabIdsWithPanels = new Set();
    panels.forEach(p => {
      const id = p.getAttribute('data-tab');
      if (id) tabIdsWithPanels.add(id);
    });

    const visited = new Set();

    const setActive = (id, pushHash) => {
      if (!tabIdsWithPanels.has(id)) id = defaultTab;
      if (!tabIdsWithPanels.has(id)) {
        // fallback: first panel's tab
        const firstPanel = panels[0];
        id = firstPanel ? (firstPanel.getAttribute('data-tab') || 'resumen') : 'resumen';
      }
      panels.forEach(p => p.classList.toggle('is-active', p.getAttribute('data-tab') === id));
      visited.add(id);
      links.forEach(link => {
        const target = link.getAttribute('data-tab-link');
        if (!target) return;
        const isActive = target === id;
        const isVisited = visited.has(target) && !isActive;
        link.classList.toggle('qsb-tab--active', isActive && link.classList.contains('qsb-tab'));
        link.classList.toggle('qsb-tab--visited', isVisited && link.classList.contains('qsb-tab'));
        link.classList.toggle('qmp-pill--active', isActive && link.classList.contains('qmp-pill'));
        link.classList.toggle('qmp-pill--visited', isVisited && link.classList.contains('qmp-pill'));
        if (link.setAttribute) {
          link.setAttribute('aria-selected', isActive ? 'true' : 'false');
        }
      });
      if (pushHash) {
        const url = id === defaultTab ? window.location.pathname + window.location.search : '#' + id;
        try { history.replaceState(null, '', url); } catch (_) {}
      }
      // Scroll matching mobile pill into view
      const pill = document.querySelector('.qmp-pill[data-tab-link="' + id + '"]');
      pill?.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' });
      // Scroll to top of content container for comfortable reading
      const container = document.querySelector('.quote-container');
      if (container) {
        const rect = container.getBoundingClientRect();
        if (rect.top < -40) {
          window.scrollTo({ top: window.scrollY + rect.top - 16, behavior: 'smooth' });
        }
      }
    };

    links.forEach(link => {
      const target = link.getAttribute('data-tab-link');
      if (!target || !tabIdsWithPanels.has(target)) return;
      link.addEventListener('click', (e) => {
        e.preventDefault();
        setActive(target, true);
      });
    });

    // Initial tab: from URL hash or default
    const initialFromHash = window.location.hash ? window.location.hash.slice(1) : '';
    const initial = (initialFromHash && tabIdsWithPanels.has(initialFromHash)) ? initialFromHash : defaultTab;
    setActive(initial, false);

    // React to hash changes (back/forward, manual edit)
    window.addEventListener('hashchange', () => {
      const id = window.location.hash ? window.location.hash.slice(1) : defaultTab;
      setActive(id, false);
    });
  })();
</script>
