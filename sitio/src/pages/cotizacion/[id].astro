  border-radius: 999px;
  font-size: 0.6875rem; letter-spacing: 0.04em;
}
.quote-timer-promo-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: #2AB5A0;
  box-shadow: 0 0 0 0 rgba(42,181,160,0.6);
  animation: quote-promo-pulse 2s infinite;
}
@keyframes quote-promo-pulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(42,181,160,0.6); }
  50%     { box-shadow: 0 0 0 6px rgba(42,181,160,0); }
}
.quote-timer-promo-label { font-weight: 500; opacity: 0.7; text-transform: uppercase; }
.quote-timer-promo-name {
  font-weight: 800; letter-spacing: 0.06em;
  font-family: var(--font-display);
  color: #2AB5A0;
}
.quote-timer-deadline {
  margin-top: 14px;
  font-size: 0.9375rem; font-weight: 600; opacity: 0.95;
  font-family: var(--font-display);
  letter-spacing: 0.005em;
}
.quote-timer-warning {
  margin-top: 6px;
  font-size: 0.75rem; opacity: 0.55; font-style: italic;
}

.quote-dark .quote-timer { background: rgba(255,255,255,0.05); }
.quote-dark .quote-timer--urgent { background: rgba(255,255,255,0.05); }

/* ─── Expired notice + price comparison ─── */
.quote-expired-notice {
  margin: 0 40px 16px; padding: 14px 18px;
  background: #fff7ed; border: 1px solid #fdba74; color: #7c2d12;
  border-radius: 10px; font-size: 0.8125rem; line-height: 1.55;
}
.quote-expired-notice strong { display: block; margin-bottom: 4px; color: #9a3412; font-weight: 700; }
.quote-expired-notice em { font-style: normal; font-weight: 700; }
.quote-dark .quote-expired-notice { background: rgba(253,186,116,0.08); border-color: rgba(253,186,116,0.3); color: #fed7aa; }
.quote-dark .quote-expired-notice strong { color: #fdba74; }

.qt-compare { display: inline-flex; flex-direction: column; align-items: flex-end; gap: 1px; line-height: 1.25; }
.qt-price-strike { text-decoration: line-through; color: #b91c1c; opacity: 0.7; font-weight: 500; }
.qt-price-normal { color: #047857; font-weight: 700; }
.quote-dark .qt-price-strike { color: #fca5a5; }
