.quote-conscious-impact { display: flex; align-items: flex-start; gap: 12px; background: rgba(42,181,160,0.04); border-radius: 10px; padding: 16px; margin-bottom: 16px; }
.quote-conscious-impact-icon { flex-shrink: 0; margin-top: 1px; }
