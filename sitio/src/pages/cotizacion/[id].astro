<script>
  // Countdown timer
  const countdown = document.getElementById('countdown');
  if (countdown) {
    const expires = new Date(countdown.dataset.expires + 'T23:59:59').getTime();
    function updateTimer() {
      const now = Date.now();
      const diff = expires - now;
      if (diff <= 0) return;
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const mins = Math.floor((diff % 3600000) / 60000);
      const secs = Math.floor((diff % 60000) / 1000);
      const dEl = document.getElementById('timer-days');
      const hEl = document.getElementById('timer-hours');
      const mEl = document.getElementById('timer-mins');
      const sEl = document.getElementById('timer-secs');
      if (dEl) dEl.textContent = String(days);
      if (hEl) hEl.textContent = String(hours);
      if (mEl) mEl.textContent = String(mins);
      if (sEl) sEl.textContent = String(secs);
    }
    updateTimer();
    setInterval(updateTimer, 1000);
  }

  // ─── Track view (skip if admin) ───
  const quoteId = window.location.pathname.split('/').pop();
  const isAdmin = new URLSearchParams(window.location.search).has('admin');
  if (quoteId && !isAdmin) {
    fetch('/api/revenue/quote-view', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: quoteId }),
    }).catch(() => {});
  }

  // ─── Comments ───
  const commentsSection = document.getElementById('comments-section');
  const commentsThread = document.getElementById('comments-thread');
  const commentsEmpty = document.getElementById('comments-empty');
  const btnComments = document.getElementById('btn-comments');
  const btnClose = document.getElementById('btn-close-comments');
  const btnSend = document.getElementById('btn-send-comment');

  function fmtCommentDate(d: string) {
    const date = new Date(d);
    const day = date.getDate();
    const month = date.toLocaleDateString('es-MX', { month: 'short' }).replace('.', '');
    const time = date.toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' });
    return `${day}/${month} ${time}`;
  }

  function renderComments(comments: any[]) {
    if (!commentsThread) return;
    if (comments.length === 0) {
      if (commentsEmpty) commentsEmpty.style.display = '';
      return;
    }
    if (commentsEmpty) commentsEmpty.style.display = 'none';
    // Remove old comments (keep empty placeholder)
    commentsThread.querySelectorAll('.quote-comment').forEach(el => el.remove());
    comments.forEach((c: any) => {
      const div = document.createElement('div');
      div.className = `quote-comment quote-comment--${c.from || 'prospect'}`;
      div.innerHTML = `
        <div class="quote-comment-bubble">${c.text.replace(/</g, '&lt;').replace(/\n/g, '<br>')}</div>
        <div class="quote-comment-meta">
          <span class="quote-comment-name">${c.from === 'admin' ? 'Sacs' : (c.name || 'Cliente').replace(/</g, '&lt;')}</span>
          <span class="quote-comment-time">${fmtCommentDate(c.at)}</span>
        </div>
      `;
      commentsThread.appendChild(div);
    });
    commentsThread.scrollTop = commentsThread.scrollHeight;
  }

  async function loadComments() {
    const res = await fetch(`/api/revenue/quote-comments?id=${quoteId}`);
    const data = await res.json();
    renderComments(data.comments || []);
  }

  if (btnComments && commentsSection) {
    btnComments.addEventListener('click', () => {
      commentsSection.style.display = '';
      if (shareSection) shareSection.style.display = 'none';
      loadComments();
    });
    commentsSection.addEventListener('click', (e) => { if (e.target === commentsSection) commentsSection.style.display = 'none'; });
  }
  if (btnClose && commentsSection) {
    btnClose.addEventListener('click', () => {
      commentsSection.style.display = 'none';
    });
  }
  if (btnSend) {
    btnSend.addEventListener('click', async () => {
      const nameEl = document.getElementById('comment-name') as HTMLInputElement;
      const textEl = document.getElementById('comment-text') as HTMLTextAreaElement;
      const name = nameEl?.value.trim();
      const text = textEl?.value.trim();
      if (!text) return;
      btnSend.textContent = 'Enviando...';
      const res = await fetch('/api/revenue/quote-comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: quoteId, from: 'prospect', name: name || 'Cliente', text }),
      });
      const data = await res.json();
      renderComments(data.comments || []);
      if (textEl) textEl.value = '';
      btnSend.textContent = 'Enviar comentario';
    });
  }

  // ─── Share by email ───
  const shareSection = document.getElementById('share-section');
  const btnShare = document.getElementById('btn-share');
  const btnCloseShare = document.getElementById('btn-close-share');
  const btnSendShare = document.getElementById('btn-send-share');

  if (btnShare && shareSection) {
    btnShare.addEventListener('click', () => {
      shareSection.style.display = '';
      if (commentsSection) commentsSection.style.display = 'none';
    });
    shareSection.addEventListener('click', (e) => { if (e.target === shareSection) shareSection.style.display = 'none'; });
  }
  if (btnCloseShare && shareSection) {
    btnCloseShare.addEventListener('click', () => { shareSection.style.display = 'none'; });
  }
  if (btnSendShare) {
    btnSendShare.addEventListener('click', () => {
      const to = (document.getElementById('share-to') as HTMLInputElement)?.value.trim();
      const from = (document.getElementById('share-from') as HTMLInputElement)?.value.trim();
      const subject = (document.getElementById('share-subject') as HTMLInputElement)?.value.trim();
      const body = (document.getElementById('share-body') as HTMLTextAreaElement)?.value.trim();
      if (!to) { alert('Ingresa el correo del destinatario'); return; }
      const finalBody = (from ? `De: ${from}\n\n` : '') + body;
      window.location.href = `mailto:${encodeURIComponent(to)}?subject=${encodeURIComponent(subject || 'Cotización')}&body=${encodeURIComponent(finalBody)}`;
    });
  }

  // ─── Timeline scroll animation ───
  const tlSteps = document.querySelectorAll('.quote-tl-step');
  if (tlSteps.length) {
    tlSteps.forEach(step => { (step as HTMLElement).style.opacity = '0'; (step as HTMLElement).style.transform = 'translateY(20px)'; (step as HTMLElement).style.transition = 'opacity 0.5s ease, transform 0.5s ease'; });
    const revealSteps = () => {
      tlSteps.forEach((step, i) => {
        const rect = step.getBoundingClientRect();
        if (rect.top < window.innerHeight - 60) {
          setTimeout(() => { (step as HTMLElement).style.opacity = '1'; (step as HTMLElement).style.transform = 'translateY(0)'; }, i * 120);
        }
      });
    };
    revealSteps();
    window.addEventListener('scroll', revealSteps, { passive: true });
  }

  // ─── Cases carousel ───
  const casesTrack = document.getElementById('cases-track');
  const casesDots = document.querySelectorAll('.quote-cases-dot');
  if (casesTrack && casesDots.length) {
    casesDots.forEach(dot => {
      dot.addEventListener('click', () => {
        const idx = parseInt((dot as HTMLElement).dataset.idx || '0');
        const card = casesTrack.children[idx] as HTMLElement;
        if (card) casesTrack.scrollTo({ left: card.offsetLeft - 40, behavior: 'smooth' });
      });
    });
    casesTrack.addEventListener('scroll', () => {
      const scrollLeft = casesTrack.scrollLeft;
      let activeIdx = 0;
      for (let i = 0; i < casesTrack.children.length; i++) {
        const child = casesTrack.children[i] as HTMLElement;
        if (child.offsetLeft - 40 <= scrollLeft + 20) activeIdx = i;
      }
      casesDots.forEach((d, i) => d.classList.toggle('active', i === activeIdx));
    }, { passive: true });
    // Auto-scroll every 4s
    let autoIdx = 0;
    setInterval(() => {
      autoIdx = (autoIdx + 1) % casesTrack.children.length;
      const card = casesTrack.children[autoIdx] as HTMLElement;
      if (card) casesTrack.scrollTo({ left: card.offsetLeft - 40, behavior: 'smooth' });
    }, 4000);
  }

  // ─── Animated numbers (count-up) ───
  const animationsEnabled = !document.querySelector('[data-no-animations]');
  if (animationsEnabled) {
    document.querySelectorAll('[data-count]').forEach(el => {
      const target = parseInt((el as HTMLElement).dataset.count || '0');
      if (!target) return;
      const suffix = (el as HTMLElement).dataset.suffix || '';
      let current = 0;
      const duration = 1200;
      const steps = 50;
      const stepValue = target / steps;
      const stepTime = duration / steps;
      const interval = setInterval(() => {
        current += stepValue;
        if (current >= target) { current = target; clearInterval(interval); }
        (el as HTMLElement).textContent = '$' + Math.round(current).toLocaleString('es-MX') + suffix;
      }, stepTime);
    });
  }


  // ─── Signature canvas ───
  const sigCanvas = document.getElementById('signature-canvas') as HTMLCanvasElement;
  if (sigCanvas) {
    const ctx = sigCanvas.getContext('2d');
    let drawing = false;
    let hasDrawn = false;

    // Set canvas resolution
    const rect = sigCanvas.getBoundingClientRect();
    sigCanvas.width = rect.width * 2;
    sigCanvas.height = rect.height * 2;
    if (ctx) {
      ctx.scale(2, 2);
      ctx.strokeStyle = '#1a1a1a';
      ctx.lineWidth = 2;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
    }

    function getPos(e: MouseEvent | TouchEvent) {
      const r = sigCanvas.getBoundingClientRect();
      const t = 'touches' in e ? e.touches[0] : e;
      return { x: t.clientX - r.left, y: t.clientY - r.top };
    }

    sigCanvas.addEventListener('mousedown', (e) => { drawing = true; const p = getPos(e); ctx?.beginPath(); ctx?.moveTo(p.x, p.y); });
    sigCanvas.addEventListener('mousemove', (e) => { if (!drawing || !ctx) return; hasDrawn = true; const p = getPos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); });
    sigCanvas.addEventListener('mouseup', () => { drawing = false; });
    sigCanvas.addEventListener('mouseleave', () => { drawing = false; });
    sigCanvas.addEventListener('touchstart', (e) => { e.preventDefault(); drawing = true; const p = getPos(e); ctx?.beginPath(); ctx?.moveTo(p.x, p.y); }, { passive: false });
    sigCanvas.addEventListener('touchmove', (e) => { e.preventDefault(); if (!drawing || !ctx) return; hasDrawn = true; const p = getPos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); }, { passive: false });
    sigCanvas.addEventListener('touchend', () => { drawing = false; });

    document.getElementById('btn-clear-sig')?.addEventListener('click', () => {
      ctx?.clearRect(0, 0, sigCanvas.width, sigCanvas.height);
      hasDrawn = false;
    });

    const acceptModal = document.getElementById('accept-modal');
    const acceptInput = document.getElementById('accept-name-input') as HTMLInputElement;

    document.getElementById('btn-accept-sig')?.addEventListener('click', () => {
      if (!hasDrawn) { alert('Dibuja tu firma primero'); return; }
      if (acceptModal) { acceptModal.style.display = ''; acceptInput?.focus(); }
    });

    document.getElementById('btn-close-accept')?.addEventListener('click', () => { if (acceptModal) acceptModal.style.display = 'none'; });
    document.getElementById('btn-cancel-accept')?.addEventListener('click', () => { if (acceptModal) acceptModal.style.display = 'none'; });
    acceptModal?.addEventListener('click', (e) => { if (e.target === acceptModal) acceptModal.style.display = 'none'; });

    document.getElementById('btn-confirm-accept')?.addEventListener('click', async () => {
      const name = acceptInput?.value.trim();
      if (!name) { acceptInput?.focus(); return; }
      const btn = document.getElementById('btn-confirm-accept') as HTMLButtonElement;
      btn.textContent = 'Procesando...';
      btn.disabled = true;

      // Capture signature as base64
      const firmaBase64 = sigCanvas ? sigCanvas.toDataURL('image/png') : '';

      // Save firma in meta via notas field
      const notasRes = await fetch(`/api/revenue/quote-view?id=${quoteId}`);
      const notasData = await notasRes.json();
      // Read current notas to preserve meta
      const quoteRes = await fetch(`/api/revenue/quotes?id=${quoteId}`);
      const quoteData = await quoteRes.json();
      let notas = quoteData.notas || '';
      const sep = '\n---META---\n';
      const sepIdx = notas.indexOf(sep);
      let metaText = sepIdx >= 0 ? notas.slice(0, sepIdx) : notas;
      let metaObj: any = {};
      if (sepIdx >= 0) { try { metaObj = JSON.parse(notas.slice(sepIdx + sep.length)); } catch {} }
      metaObj.firma_base64 = firmaBase64;
      if (!metaObj.timeline) metaObj.timeline = [];
      metaObj.timeline.push({ event: 'accepted', at: new Date().toISOString() });
      notas = metaText + sep + JSON.stringify(metaObj);

      await fetch('/api/revenue/quotes', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: quoteId, estado: 'accepted', aceptado_por: name, aceptado_fecha: new Date().toISOString(), notas }),
      });

      // Close modal, show success + confetti
      if (acceptModal) acceptModal.style.display = 'none';
      const successOverlay = document.getElementById('success-overlay');
      if (successOverlay) {
        successOverlay.style.display = '';
        // Generate confetti
        const container = document.getElementById('confetti-container');
        if (container) {
          const colors = ['#4B7BE5', '#2AB5A0', '#E8A838', '#6C5CE7', '#E54B4B', '#1a1a1a'];
          for (let i = 0; i < 80; i++) {
            const piece = document.createElement('div');
            piece.className = 'confetti-piece';
            piece.style.left = Math.random() * 100 + '%';
            piece.style.background = colors[Math.floor(Math.random() * colors.length)];
            piece.style.width = (Math.random() * 8 + 6) + 'px';
            piece.style.height = (Math.random() * 8 + 6) + 'px';
            piece.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
            piece.style.animationDuration = (Math.random() * 2 + 1.5) + 's';
            piece.style.animationDelay = (Math.random() * 1) + 's';
            container.appendChild(piece);
          }
        }
      }
      setTimeout(() => { window.location.reload(); }, 3000);
    });

    acceptInput?.addEventListener('keydown', (e) => { if (e.key === 'Enter') document.getElementById('btn-confirm-accept')?.click(); });
  }
</script>
