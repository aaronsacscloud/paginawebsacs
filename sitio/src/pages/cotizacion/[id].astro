---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';
import { plans } from '../../data/plans';
import ImplementacionContent from '../../components/ImplementacionContent.astro';
import QuoteSidebar from '../../components/quote/QuoteSidebar.astro';
import QuoteMobilePills from '../../components/quote/QuoteMobilePills.astro';

export const prerender = false;

const { id } = Astro.params;
const isPaidReturn = Astro.url.searchParams.get('paid') === '1';
const { data: quote } = await supabase.from('quotes').select('*').eq('id', id).single();

if (!quote) return Astro.redirect('/404');

// Auto-expire: if vigencia passed and status is still sent/draft, mark as expired
const isExpired = quote.vigencia && new Date(quote.vigencia) < new Date();
if (isExpired && quote.estado !== 'expired' && quote.estado !== 'accepted' && quote.estado !== 'paid') {
  await supabase.from('quotes').update({ estado: 'expired' }).eq('id', id);
  quote.estado = 'expired';
}

// Fetch bank account if linked
let bankAccount: any = null;
if (quote.bank_account_id) {
  const { data: ba } = await supabase.from('bank_accounts').select('*').eq('id', quote.bank_account_id).single();
  bankAccount = ba;
}

// Fetch pagos asociados a esta cotización (para panel "Pagos realizados")
const { data: paymentsListRaw } = await supabase
  .from('payments')
  .select('id, fecha, monto, metodo, referencia, numero_acuse, comprobante_url, estado, notas, items_cubiertos')
  .eq('quote_id', id)
  .order('fecha', { ascending: true });
const paymentsList = paymentsListRaw || [];
const totalPagado = paymentsList.reduce((s: number, p: any) => s + Number(p.monto || 0), 0);
const saldoRestante = Math.max(0, Number(quote.total || 0) - totalPagado);
const porcentajePagado = (quote.total || 0) > 0 ? Math.min(100, Math.round((totalPagado / quote.total) * 100)) : 0;
const isAdminMode = Astro.url.searchParams.has('admin');

// Fetch partner/owner if deal has one assigned — for voice-per-partner in public quote
let partnerAssigned: any = null;
if (quote.deal_id) {
  const { data: dealData } = await supabase.from('deals').select('owner_id').eq('id', quote.deal_id).maybeSingle();
  if (dealData?.owner_id) {
    const { data: partnerData } = await supabase
      .from('team_members')
      .select('id, nombre, email, rol')
      .eq('id', dealData.owner_id)
      .maybeSingle();
    if (partnerData && (partnerData as any).rol === 'partner') {
      partnerAssigned = partnerData;
    }
  }
}

const items = Array.isArray(quote.items) ? quote.items : [];
const template = quote.template || 'modern';

// Parse meta from notas for logo_url
const notasSep = '\n---META---\n';
const notasIdx = (quote.notas || '').indexOf(notasSep);
const quoteMeta = notasIdx >= 0 ? (() => { try { return JSON.parse(quote.notas.slice(notasIdx + notasSep.length)); } catch { return {}; } })() : {};
const logoUrl = quoteMeta.logo_url || '';
const ivaMode = quoteMeta.iva_mode || (quote.iva_incluido ? 'suma' : 'sin');
const showTimer = quoteMeta.mostrar_timer !== undefined ? quoteMeta.mostrar_timer : true;
const showFeatures = quoteMeta.mostrar_features !== undefined ? quoteMeta.mostrar_features : true;
const showDesglose = quoteMeta.mostrar_desglose !== undefined ? quoteMeta.mostrar_desglose : true;
const showCondiciones = quoteMeta.mostrar_condiciones !== undefined ? quoteMeta.mostrar_condiciones : true;
const showKeyPoints = quoteMeta.mostrar_key_points !== undefined ? quoteMeta.mostrar_key_points : true;
const keyPoints = quoteMeta.key_points || [];
const hasKeyPoints = showKeyPoints && Array.isArray(keyPoints) && keyPoints.length > 0;
const showRoi = quoteMeta.mostrar_roi || false;
const roi = quoteMeta.roi || null;
const hasRoi = showRoi && roi && roi.ahorro_mensual > 0;
const showAntesDesp = quoteMeta.mostrar_antes_despues || false;
const antesDesp = quoteMeta.antes_despues || [];
const hasAntesDesp = showAntesDesp && Array.isArray(antesDesp) && antesDesp.length > 0;
const showFirma = quoteMeta.mostrar_firma !== undefined ? quoteMeta.mostrar_firma : true;
const showQr = quoteMeta.mostrar_qr !== undefined ? quoteMeta.mostrar_qr : true;
const showAnimaciones = quoteMeta.mostrar_animaciones !== undefined ? quoteMeta.mostrar_animaciones : true;
const showTimeline = quoteMeta.mostrar_timeline !== undefined ? quoteMeta.mostrar_timeline : true;
const showPorqueSacs = quoteMeta.mostrar_porque_sacs !== undefined ? quoteMeta.mostrar_porque_sacs : true;
const timelineTipo = quoteMeta.timeline_tipo || '1suc';
const showImplementacion = quoteMeta.mostrar_implementacion !== undefined ? quoteMeta.mostrar_implementacion : true;
const implementacionNota = quoteMeta.implementacion_nota || '';
const promoLabel = (quoteMeta.promo_label || '').trim();
const extensions = Array.isArray(quoteMeta.extensions) ? quoteMeta.extensions : [];
const totalExtensionDays = extensions.reduce((s: number, ext: any) => s + (Number(ext.days) || 0), 0);
const wasExtended = extensions.length > 0;
const isAnnualQuote = (Array.isArray(quote.items) ? quote.items : []).some((i: any) => i.tipo === 'plan' && i.periodo === 'anual');

// Quote state flags (shared with sidebar + pills)
const isAccepted = quote.estado === 'accepted';
const isPaid = quote.estado === 'paid';
const isClosed = isAccepted || isPaid; // either accepted or paid → no more "urgency"
const hasFeatures = showFeatures; // computed later after planFeatures
const hasCondiciones = showCondiciones && !!quote.condiciones && quote.condiciones.trim().length > 0;

// Dynamic tabs — compute after planFeatures/payments info below
// (Declared here so we can reuse flags; final array built after those computations.)
const quoteUrl = `https://www.sacscloud.com/cotizacion/${id}`;
const daysLeft = quote.vigencia ? Math.ceil((new Date(quote.vigencia).getTime() - Date.now()) / 86400000) : 0;
const fmt = (n: number) => '$' + Math.round(n).toLocaleString('es-MX');
const fmtDate = (d: string | null) => {
  if (!d) return '';
  const date = new Date(d.length === 10 ? d + 'T12:00:00' : d);
  if (isNaN(date.getTime())) return '';
  const day = date.getDate();
  const month = date.toLocaleDateString('es-MX', { month: 'short' }).replace('.', '');
  const year = date.getFullYear();
  return `${day}/${month}/${year}`;
};
const fmtDateLong = (d: string | null) => {
  if (!d) return '';
  const date = new Date(d.length === 10 ? d + 'T12:00:00' : d);
  if (isNaN(date.getTime())) return '';
  const wd = date.toLocaleDateString('es-MX', { weekday: 'long' });
  const day = date.getDate();
  const month = date.toLocaleDateString('es-MX', { month: 'long' });
  return `${wd[0].toUpperCase() + wd.slice(1)} ${day} de ${month}`;
};
const fecha = fmtDate(quote.created_at);
const vigenciaFecha = fmtDate(quote.vigencia);
const vigenciaFechaLarga = fmtDateLong(quote.vigencia);

// Classify items
const planItems = items.filter((i: any) => i.tipo === 'plan');
const uniqueItems = items.filter((i: any) => i.tipo === 'extra' && !i.recurrente && !i.es_promocion);
const recurringMonthlyItems = items.filter((i: any) => i.tipo === 'extra' && i.recurrente && i.periodo_extra !== 'anual');
const recurringAnnualItems = items.filter((i: any) => i.tipo === 'extra' && i.recurrente && i.periodo_extra === 'anual');
const recurringItems = [...recurringMonthlyItems, ...recurringAnnualItems];
const promoItems = items.filter((i: any) => i.es_promocion);

// Build plan features for "Qué incluye tu plan" section
const planFeatures = planItems.map((pi: any) => {
  const planData = plans.find(p => p.id === pi.nombre?.toLowerCase());
  if (!planData) return null;
  // Collect features from this plan + all inherited plans
  const allFeatures: { category: string; items: string[] }[] = [];
  let current: typeof planData | undefined = planData;
  const visited = new Set<string>();
  while (current && !visited.has(current.id)) {
    visited.add(current.id);
    for (const f of current.features) {
      if (typeof f === 'object' && 'category' in f) {
        allFeatures.push(f);
      }
    }
    current = current.inheritsFrom ? plans.find(p => p.name === current!.inheritsFrom) : undefined;
  }
  return { planName: planData.name, features: allFeatures.reverse(), services: planData.services };
}).filter(Boolean);

// Calculate payment breakdown
const annualPlanTotal = planItems.filter((i: any) => i.periodo === 'anual').reduce((s: number, i: any) => s + (i.subtotal || 0), 0);
const monthlyPlanTotal = planItems.filter((i: any) => i.periodo === 'mensual').reduce((s: number, i: any) => s + (i.subtotal || 0), 0);
const uniqueTotal = uniqueItems.reduce((s: number, i: any) => s + (i.monto || i.subtotal || 0), 0);
const recurringTotal = recurringItems.reduce((s: number, i: any) => s + (i.monto || i.subtotal || 0), 0);
const firstPayment = annualPlanTotal + monthlyPlanTotal + uniqueTotal + recurringTotal;
const monthlyRecurring = monthlyPlanTotal + recurringTotal;

// Total sin promoción — usado cuando isExpired para mostrar precio comparado
const totalSinPromo = items.reduce((s: number, i: any) => {
  if (i.es_promocion && i.precio_original) return s + i.precio_original;
  return s + (i.subtotal || i.monto || 0);
}, 0);
const totalSinPromoConIva = ivaMode === 'suma' ? totalSinPromo * 1.16 : totalSinPromo;
// Renewal discount ratio — el cliente paga discount cuando hay descuento; al expirar la promo, vuelve al precio sin descuento
const _rawSubtotal = quote.subtotal || 1;
const _totalBeforeIva = ivaMode === 'suma' ? (quote.total || 0) / 1.16 : (quote.total || 0);
const renewalDiscountRatio = _rawSubtotal > 0 ? _totalBeforeIva / _rawSubtotal : 1;
const hasRenewalDiscount = renewalDiscountRatio < 0.999;

// Auto-generate summary
const planNames = planItems.map((i: any) => `Plan ${i.nombre}`).join(' + ');
const sucTotal = planItems.reduce((s: number, i: any) => s + (parseInt(i.sucursales) || 1), 0);
const extraNames = [...uniqueItems, ...recurringItems].map((i: any) => i.nombre).filter(Boolean);
const summary = planNames ? `${planNames} para ${sucTotal} sucursal${sucTotal > 1 ? 'es' : ''}${extraNames.length ? ' con ' + extraNames.join(' y ') : ''}` : quote.empresa;

// Next annual renewal date
const nextAnnualDate = new Date();
nextAnnualDate.setFullYear(nextAnnualDate.getFullYear() + 1);
const nextAnnualStr = fmtDate(nextAnnualDate.toISOString());

// Dynamic tabs — only include tabs whose underlying content exists
const hasFeaturesReal = showFeatures && planFeatures.length > 0;
const hasPagosContent = showDesglose && (annualPlanTotal > 0 || uniqueTotal > 0 || monthlyRecurring > 0);
const hasTimelineReal = showTimeline && !!timelineTipo;
const hasImplementacionReal = showImplementacion;

// Tab "Pagos": visible cuando hay pagos registrados, esta aceptada/pagada, o estamos en modo admin
const showPagosTab = paymentsList.length > 0 || isAccepted || isPaid || isAdminMode;

const tabsDef = [
  { id: 'minuta', label: 'Minuta', show: hasKeyPoints },
  { id: 'inversion', label: 'Inversión', show: items.length > 0 || hasPagosContent || hasFeaturesReal || hasTimelineReal },
  { id: 'pagos', label: isPaid ? 'Pagos ✓' : (paymentsList.length > 0 ? `Pagos (${paymentsList.length})` : 'Pagos'), show: showPagosTab },
  { id: 'roi', label: 'ROI', show: hasRoi },
  { id: 'comparativa', label: 'Comparativa', show: hasAntesDesp },
  { id: 'proceso', label: 'Proceso', show: hasImplementacionReal },
  { id: 'condiciones', label: 'Condiciones', show: hasCondiciones },
  { id: 'porque', label: '¿Por qué SACS?', show: showPorqueSacs && (showFirma || isClosed) },
  { id: 'firma', label: isPaid ? 'Pagada' : (isAccepted ? 'Confirmación' : 'Firmar y aceptar'), show: showFirma || isClosed },
];
const visibleTabs = tabsDef.filter(t => t.show).map(({ id, label }) => ({ id, label }));
const initialTab = isClosed ? 'firma' : (visibleTabs[0]?.id || 'inversion');
---

<BaseLayout title={`Cotización ${quote.numero} — Sacs`} description={`Cotización para ${quote.empresa}`}>

<QuoteMobilePills
  template={template}
  total={quote.total || 0}
  totalSinPromo={totalSinPromoConIva}
  isExpired={isExpired && !isClosed}
  vigenciaFecha={vigenciaFecha}
  daysLeft={daysLeft}
  moneda={quote.moneda || 'MXN'}
  tabs={visibleTabs}
  initialTab={initialTab}
/>

<div class:list={['quote-layout', `quote-layout--${template}`]}>
  <aside class="quote-layout-sidebar no-print">
    <QuoteSidebar
      total={quote.total || 0}
      totalSinPromo={totalSinPromoConIva}
      moneda={quote.moneda || 'MXN'}
      empresa={quote.empresa}
      numero={quote.numero}
      logoUrl={logoUrl}
      template={template}
      isAccepted={isAccepted}
      isPaid={isPaid}
      isExpired={isExpired}
      paymentLink={quote.link_pago}
      vigenciaFecha={vigenciaFecha}
      tabs={visibleTabs}
      initialTab={initialTab}
    />
  </aside>

<div class:list={['quote-page', `quote-${template}`, { 'quote-expired-page': isExpired && !isClosed }]} id="quote-doc" data-no-animations={showAnimaciones ? undefined : true} data-initial-tab={initialTab}>
  <div class="quote-container" style="position:relative">
    {isPaidReturn && (
      <div class="quote-paid-banner">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" stroke="#fff" stroke-width="2.5"/><path d="M22 4L12 14.01l-3-3" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/></svg>
        <span>Pago recibido. Tu servicio se activa de inmediato.</span>
      </div>
    )}

    <!-- Header (always visible) -->
    <div class="quote-header">
      <div class="quote-logo">
        {logoUrl ? (
          <img src={logoUrl} alt={quote.empresa} class="quote-client-logo" width="120" height="48" loading="eager" />
        ) : (
          <span class="quote-logo-text">Sacs</span>
        )}
        <span class="quote-logo-tag">Cotización</span>
      </div>
      <div class="quote-meta">
        {isPaid && (
          <span class="quote-status quote-status--paid"><span class="quote-status-dot"></span>Pagada</span>
        )}
        {isAccepted && !isPaid && (
          <span class="quote-status quote-status--accepted"><span class="quote-status-dot"></span>Aceptada</span>
        )}
        {isExpired && !isClosed && (
          <span class="quote-status quote-status--expired"><span class="quote-status-dot"></span>Vencida</span>
        )}
        {!isExpired && !isClosed && !isAccepted && !isPaid && daysLeft > 0 && (
          <span class="quote-status quote-status--active"><span class="quote-status-dot"></span>Activa</span>
        )}
        <div class="quote-number">{quote.numero}</div>
        <div class="quote-date">Emitida {fecha}</div>
        {!isExpired && !isClosed && daysLeft > 0 && (
          <div class="quote-date">
            Válida hasta {vigenciaFecha} · {daysLeft}d restantes
            {wasExtended && <span style="color:#1d4ed8;font-weight:600;"> · Extendida +{totalExtensionDays}d</span>}
          </div>
        )}
        {isExpired && !isClosed && <div class="quote-date">Venció el {vigenciaFecha}{wasExtended ? ` · Extendida +${totalExtensionDays}d` : ''}</div>}
        {isAccepted && !isPaid && quote.aceptado_fecha && <div class="quote-date" style="color:#1e8471;font-weight:600">Aceptada el {fmtDate(quote.aceptado_fecha)}</div>}
        {isPaid && quote.aceptado_fecha && <div class="quote-date" style="color:#3764c4;font-weight:600">Pagada · Aceptada el {fmtDate(quote.aceptado_fecha)}</div>}
      </div>
    </div>

    <!-- Client info (always visible) -->
    <div class="quote-client">
      <div class="quote-client-label">Cotización para:</div>
      <div class="quote-client-name">{quote.empresa}</div>
      {quote.contacto && <div class="quote-client-detail">{quote.contacto}</div>}
      {quote.email && <div class="quote-client-detail">{quote.email}</div>}
      {quote.whatsapp && <div class="quote-client-detail">{quote.whatsapp}</div>}
    </div>

    {partnerAssigned && (
      <div class="quote-asesor">
        <div class="quote-asesor-label">Tu asesor SACS</div>
        <div class="quote-asesor-name">{partnerAssigned.nombre}</div>
        {partnerAssigned.email && <a href={`mailto:${partnerAssigned.email}`} class="quote-asesor-contact">{partnerAssigned.email}</a>}
      </div>
    )}

    <style>
      .quote-asesor {
        padding: 16px 40px;
        border-top: 1px solid #e5e5e5;
        background: #fafafa;
      }
      .quote-asesor-label {
        font-size: 0.625rem;
        font-weight: 700;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 6px;
      }
      .quote-asesor-name {
        font-family: var(--font-display, inherit);
        font-size: 1.0625rem;
        font-weight: 500;
        color: #1a1a1a;
        letter-spacing: -0.005em;
      }
      .quote-asesor-contact {
        display: inline-block;
        margin-top: 4px;
        font-size: 0.8125rem;
        color: #2AB5A0;
        text-decoration: none;
      }
      .quote-asesor-contact:hover { text-decoration: underline; }
      @media (max-width: 640px) {
        .quote-asesor { padding: 10px 20px; }
        .quote-asesor-label { font-size: 0.5625rem; margin-bottom: 4px; }
        .quote-asesor-name { font-size: 0.9375rem; }
        .quote-asesor-contact { font-size: 0.75rem; margin-top: 2px; }
      }
    </style>

    {/* ═══════════════════════════════════════════════
         HERO DE BIENVENIDA (vive dentro del tab Inversión)
         ═══════════════════════════════════════════════ */}
    <section class="quote-tab-panel" data-tab="inversion">
      <div class="quote-tab-intro">
        <div class="quote-tab-intro-eyebrow">Bienvenido</div>
        <div class="quote-tab-intro-heading">{summary}</div>
      </div>
    </section>

    {/* ═══════════════════════════════════════════════
         TAB: MINUTA
         ═══════════════════════════════════════════════ */}
    {hasKeyPoints && (
    <section class="quote-tab-panel" data-tab="minuta">
      <div class="quote-key-points">
        <div class="quote-key-points-title">Minuta de la reunión</div>
        <div class="quote-key-points-list">
          {keyPoints.map((kp: any) => (
            <div class="quote-key-point">
              <div class="quote-key-point-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div class="quote-key-point-content">
                <div class="quote-key-point-title">{kp.title}</div>
                <div class="quote-key-point-detail">{kp.detail}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
    )}

    {/* ═══════════════════════════════════════════════
         TAB: INVERSIÓN — timer (if not closed) + items + totals
         ═══════════════════════════════════════════════ */}
    <section class="quote-tab-panel" data-tab="inversion">
    <!-- Urgency timer -->
    {showTimer && !isExpired && !isClosed && daysLeft > 0 && daysLeft <= 15 && (
      <div class:list={['quote-timer', { 'quote-timer--urgent': daysLeft <= 5 }]}>
        {wasExtended && (
          <div class="quote-timer-extended">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/>
            </svg>
            <span>Vigencia extendida +{totalExtensionDays} {totalExtensionDays === 1 ? 'día' : 'días'}</span>
          </div>
        )}
        {promoLabel && (
          <div class="quote-timer-promo">
            <span class="quote-timer-promo-dot"></span>
            <span class="quote-timer-promo-label">Promoción aplicada</span>
            <span class="quote-timer-promo-name">{promoLabel}</span>
          </div>
        )}
        <div class="quote-timer-label">{quote.urgencia === 'oferta' ? 'Oferta especial' : 'Esta cotización'} vence en</div>
        <div class="quote-timer-countdown" id="countdown" data-expires={quote.vigencia}>
          <span class="quote-timer-num" id="timer-days">{daysLeft}</span>
          <span class="quote-timer-unit">días</span>
          <span class="quote-timer-num" id="timer-hours">0</span>
          <span class="quote-timer-unit">horas</span>
          <span class="quote-timer-num" id="timer-mins">0</span>
          <span class="quote-timer-unit">min</span>
          <span class="quote-timer-num" id="timer-secs">0</span>
          <span class="quote-timer-unit">seg</span>
        </div>
        {vigenciaFechaLarga && (
          <div class="quote-timer-deadline">{vigenciaFechaLarga} vence tu cotización</div>
        )}
        <div class="quote-timer-warning">Después de esa fecha los precios vuelven al valor normal sin promoción.</div>
        {(() => {
          const globalSaving = quote.descuento_global > 0 ? (quote.descuento_tipo === 'pct' ? (quote.subtotal || 0) * quote.descuento_global / 100 : quote.descuento_global) : 0;
          const promoSaving = promoItems.reduce((s: number, i: any) => s + (i.precio_original || 0), 0);
          const annualSaving = planItems.filter((i: any) => i.periodo === 'anual').reduce((s: number, i: any) => {
            const suc = parseInt(i.sucursales) || 1;
            return s + (i.precio_unitario || 0) * suc * 2;
          }, 0);
          const totalSaving = globalSaving + promoSaving + annualSaving;
          return totalSaving > 0 ? (
            <div class="quote-timer-savings">Los descuentos de esta cotización representan un ahorro de {fmt(totalSaving)} {quote.moneda}</div>
          ) : null;
        })()}
      </div>
    )}

    {isExpired && !isClosed && (
      <div class="quote-expired-notice">
        <strong>Esta cotización venció el {vigenciaFechaLarga || vigenciaFecha}{wasExtended ? ` (incluyendo extensión de +${totalExtensionDays} ${totalExtensionDays === 1 ? 'día' : 'días'})` : ''}.</strong>
        {promoLabel ? <>La promoción <em>{promoLabel}</em> ya no aplica</> : <>La promoción ya no aplica</>}
        {' '}— los precios tachados son los que tenías; los precios en verde son los actuales. Si quieres reactivarla, contáctanos.
      </div>
    )}

    <!-- Items table -->
    <table class="quote-table">
      <thead>
        <tr>
          <th class="qt-concept">Concepto</th>
          <th class="qt-detail">Detalle</th>
          <th class="qt-qty">Cant.</th>
          <th class="qt-price">Precio unit.</th>
          <th class="qt-subtotal">Subtotal</th>
        </tr>
      </thead>
      <tbody>
        {items.map((item: any) => {
          const isAnnual = item.periodo === 'anual';
          const suc = parseInt(item.sucursales) || 1;
          const monthlyFull = (item.precio_unitario || 0) * suc * 12;
          const annualPrice = (item.precio_unitario || 0) * suc * 10;
          const savings = isAnnual ? monthlyFull - annualPrice : 0;
          const hasDiscount = item.tipo === 'plan' && parseFloat(item.descuento_pct || 0) > 0;
          const beforeDiscount = (item.precio_unitario || 0) * suc * (isAnnual ? 10 : 1);
          const isPromo = item.es_promocion;
          const promoUnit = item.precio_unitario || item.monto || 0;
          const normalUnit = item.precio_original || 0;
          const promoSubtotal = item.subtotal || item.monto || 0;
          const normalSubtotalExtra = normalUnit; // extras: precio_original ya es el monto único
          const showExpiredCompare = isExpired && isPromo && normalUnit > 0;

          return (
            <tr class:list={[{ 'qt-promo-row': isPromo, 'qt-expired-row': showExpiredCompare }]}>
              <td class="qt-concept">
                {isPromo && <span class:list={['qt-promo-badge', { 'qt-promo-badge--expired': showExpiredCompare }]}>{showExpiredCompare ? 'PROMO VENCIDA' : 'PROMOCION'}</span>}
                <strong>{item.tipo === 'plan' ? `Plan ${item.nombre}` : item.nombre}</strong>
                {item.tipo === 'plan' && (
                  <div class="qt-desc">
                    {fmt(item.precio_unitario || 0)}/suc × {suc} suc. × {isAnnual ? '10 meses' : '1 mes'}
                    {isAnnual && <span class="qt-savings"> · Ahorro: {fmt(savings)} (2 meses gratis)</span>}
                  </div>
                )}
                {item.descripcion && <div class="qt-desc">{item.descripcion}</div>}
                {item.nota && <div class="qt-nota">{item.nota}</div>}
              </td>
              <td class="qt-detail">
                {isPromo ? 'Promoción' : item.tipo === 'plan' ? (isAnnual ? 'Anual' : 'Mensual') : item.periodo_extra === 'anual' ? 'Anual' : item.recurrente ? 'Mensual' : 'Único'}
              </td>
              <td class="qt-qty">{item.tipo === 'plan' ? `${suc} suc.` : '1'}</td>
              <td class="qt-price">
                {showExpiredCompare ? (
                  <span class="qt-compare">
                    <span class="qt-price-strike">{fmt(promoUnit)}</span>
                    <span class="qt-price-normal">{fmt(normalUnit)}</span>
                  </span>
                ) : (
                  <>
                    {isPromo && item.precio_original ? <span class="qt-strikethrough">{fmt(item.precio_original)}</span> : ''}
                    {fmt(promoUnit)}
                  </>
                )}
              </td>
              <td class="qt-subtotal">
                {showExpiredCompare ? (
                  <span class="qt-compare">
                    <span class="qt-price-strike">{fmt(promoSubtotal)}</span>
                    <span class="qt-price-normal">{fmt(normalSubtotalExtra)} {quote.moneda}</span>
                  </span>
                ) : (
                  <>
                    {hasDiscount && <span class="qt-strikethrough">{fmt(beforeDiscount)}</span>}
                    {isPromo && item.precio_original ? (
                      <span><span class="qt-strikethrough">{fmt(item.precio_original)}</span> <span class="qt-promo-price">{fmt(0)}</span></span>
                    ) : (
                      <span>{fmt(promoSubtotal)} {quote.moneda}</span>
                    )}
                  </>
                )}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>

    <!-- Totals -->
    {(() => {
      const globalDiscAmt = quote.descuento_global > 0 ? (quote.descuento_tipo === 'pct' ? (quote.subtotal || 0) * quote.descuento_global / 100 : quote.descuento_global) : 0;
      const promoSavingsAmt = promoItems.reduce((s: number, i: any) => s + (i.precio_original || 0), 0);
      // Total sin promoción = subtotal de items SIN tomar promo (precio_original cuando aplica) y sin descuento_global
      const totalSinPromo = items.reduce((s: number, i: any) => {
        if (i.es_promocion && i.precio_original) return s + i.precio_original;
        return s + (i.subtotal || i.monto || 0);
      }, 0);
      const totalSinPromoConIva = ivaMode === 'suma' ? totalSinPromo * 1.16 : totalSinPromo;
      return (
        <div class="quote-totals">
          <div class="quote-total-row">
            <span>Subtotal</span>
            <span>{fmt(quote.subtotal || 0)} {quote.moneda}</span>
          </div>
          {quote.descuento_global > 0 && (
            isExpired ? (
              <div class="quote-total-row quote-total-row--strike">
                <span>Descuento promoción <em>(ya no aplica)</em></span>
                <span class="qt-price-strike">-{fmt(globalDiscAmt)} {quote.moneda}</span>
              </div>
            ) : (
              <div class="quote-total-row quote-discount">
                <span>Descuento {quote.descuento_tipo === 'pct' ? `(${quote.descuento_global}%)` : ''}</span>
                <span>-{fmt(globalDiscAmt)} {quote.moneda}</span>
              </div>
            )
          )}
          {promoItems.length > 0 && promoSavingsAmt > 0 && (
            isExpired ? (
              <div class="quote-total-row quote-total-row--strike">
                <span>Ahorro por promociones <em>(ya no aplica)</em></span>
                <span class="qt-price-strike">-{fmt(promoSavingsAmt)} {quote.moneda}</span>
              </div>
            ) : (
              <div class="quote-total-row quote-discount">
                <span>Ahorro por promociones ({promoItems.length})</span>
                <span>-{fmt(promoSavingsAmt)} {quote.moneda}</span>
              </div>
            )
          )}
          {ivaMode === 'suma' && (
            <div class="quote-total-row">
              <span>IVA (16%)</span>
              <span>+{fmt(quote.iva_monto || 0)} {quote.moneda}</span>
            </div>
          )}
          {ivaMode === 'incluido' && (
            <div class="quote-total-row" style="font-size:0.75rem;color:#999">
              <span>IVA incluido en precios</span>
              <span>{fmt(quote.iva_monto || 0)} {quote.moneda}</span>
            </div>
          )}
          {isExpired ? (
            <>
              <div class="quote-total-row quote-total-row--strike">
                <span>Total con promoción <em>(ya no aplica)</em></span>
                <span class="qt-price-strike">{fmt(quote.total || 0)} {quote.moneda}</span>
              </div>
              <div class="quote-total-row quote-total-final quote-total-final--normal">
                <span>Total sin promoción</span>
                <span>{fmt(totalSinPromoConIva)} {quote.moneda}</span>
              </div>
            </>
          ) : (
            <div class="quote-total-row quote-total-final">
              <span>Total {ivaMode === 'incluido' ? '(IVA incluido)' : ''}</span>
              <span class="count-up" data-count={quote.total || 0} data-suffix={` ${quote.moneda}`}>{fmt(quote.total || 0)} {quote.moneda}</span>
            </div>
          )}
        </div>
      );
    })()}

    </section>

    {/* ═══════════════════════════════════════════════
         PAGOS (ahora vive dentro del tab Inversión)
         ═══════════════════════════════════════════════ */}
    {hasPagosContent && (
    <section class="quote-tab-panel" data-tab="inversion">
    <!-- Payment breakdown -->
    {showDesglose && (annualPlanTotal > 0 || uniqueTotal > 0 || monthlyRecurring > 0) && (
      <div class="quote-payments">
        <div class="quote-payments-title">Resumen de pagos</div>

        <div class="quote-payment-block">
          {isExpired && !isClosed && totalSinPromoConIva > (quote.total || 0) ? (
            <div class="quote-payment-total quote-payment-total--compare" style="border:none;margin:0;padding:0">
              <div class="quote-payment-total-row">
                <span class="quote-payment-total-label">Total con promoción <em>(ya no aplica)</em></span>
                <span class="qt-price-strike">{fmt(quote.total || 0)} {quote.moneda}</span>
              </div>
              <div class="quote-payment-total-row quote-payment-total-row--now">
                <span class="quote-payment-total-label">Total primer pago {quote.iva_incluido ? '(con IVA)' : ''}</span>
                <span class="qt-price-normal">{fmt(totalSinPromoConIva)} {quote.moneda}</span>
              </div>
            </div>
          ) : (
            <div class="quote-payment-total" style="border:none;margin:0;padding:0">
              <span>Total primer pago {quote.iva_incluido ? '(con IVA)' : ''}</span>
              <span class="count-up" data-count={quote.total || 0} data-suffix={` ${quote.moneda}`}>{fmt(quote.total || 0)} {quote.moneda}</span>
            </div>
          )}
        </div>

        {(monthlyPlanTotal > 0 || recurringMonthlyItems.length > 0) && (
          <div class="quote-payment-block">
            <div class="quote-payment-label">Pago mensual recurrente</div>
            {planItems.filter((i: any) => i.periodo === 'mensual').map((i: any) => (
              <div class="quote-payment-line"><span>Plan {i.nombre} · {i.sucursales} suc.</span><span>{fmt(i.subtotal || 0)}</span></div>
            ))}
            {recurringMonthlyItems.map((i: any) => (
              <div class="quote-payment-line"><span>{i.nombre}</span><span>{fmt(i.monto || 0)}</span></div>
            ))}
            <div class="quote-payment-total">
              <span>Total mensual {quote.iva_incluido ? '(+IVA)' : ''}</span>
              <span>{fmt(monthlyPlanTotal + recurringMonthlyItems.reduce((s: number, i: any) => s + (parseFloat(i.monto) || 0), 0))} {quote.moneda}/mes</span>
            </div>
          </div>
        )}

        {(annualPlanTotal > 0 || recurringAnnualItems.length > 0) && (() => {
          const discountRatio = renewalDiscountRatio;
          const hasDiscount = hasRenewalDiscount;
          // Per-item discount info for renewal compare
          const planRenewalLines = planItems.filter((i: any) => i.periodo === 'anual').map((i: any) => {
            const suc = parseInt(i.sucursales) || 1;
            const promoRenewal = Math.round((i.subtotal || 0) * discountRatio);
            const planDiscPct = parseFloat(i.descuento_pct || 0);
            // Full anual sin descuento_pct ni descuento_global
            const fullAnnual = (i.precio_unitario || 0) * suc * 10;
            const hasAnyDiscount = planDiscPct > 0 || hasDiscount;
            const fullPrice = hasAnyDiscount ? fullAnnual : (i.subtotal || 0);
            return { i, suc, promoRenewal, fullPrice, hasAnyDiscount };
          });
          const extraRenewalLines = recurringAnnualItems.map((i: any) => {
            const promoRenewal = Math.round((i.subtotal || 0) * discountRatio);
            const fullPrice = (i.precio_original && i.precio_original > 0) ? i.precio_original : (i.subtotal || 0);
            const hasAnyDiscount = (i.precio_original && i.precio_original > i.subtotal) || hasDiscount;
            return { i, promoRenewal, fullPrice, hasAnyDiscount };
          });
          const anyLineHasDiscount = planRenewalLines.some(l => l.hasAnyDiscount) || extraRenewalLines.some(l => l.hasAnyDiscount);
          const showRenewalCompare = isExpired && !isClosed && anyLineHasDiscount;
          return (
            <div class="quote-payment-block">
              <div class="quote-payment-label">Próxima renovación anual: {nextAnnualStr}</div>
              {planRenewalLines.map(({ i, suc, promoRenewal, fullPrice, hasAnyDiscount }) => (
                showRenewalCompare && hasAnyDiscount ? (
                  <div class="quote-payment-line"><span>Renovación Plan {i.nombre} · {suc} suc.</span><span class="qt-compare"><span class="qt-price-strike">{fmt(promoRenewal)}</span><span class="qt-price-normal">{fmt(fullPrice)}</span></span></div>
                ) : (
                  <div class="quote-payment-line"><span>Renovación Plan {i.nombre} · {suc} suc.</span><span>{fmt(promoRenewal)}</span></div>
                )
              ))}
              {extraRenewalLines.map(({ i, promoRenewal, fullPrice, hasAnyDiscount }) => (
                showRenewalCompare && hasAnyDiscount ? (
                  <div class="quote-payment-line"><span>{i.nombre} (anual)</span><span class="qt-compare"><span class="qt-price-strike">{fmt(promoRenewal)}</span><span class="qt-price-normal">{fmt(fullPrice)}</span></span></div>
                ) : (
                  <div class="quote-payment-line"><span>{i.nombre} (anual)</span><span>{fmt(promoRenewal)}</span></div>
                )
              ))}
              {anyLineHasDiscount && !showRenewalCompare && (
                <div class="quote-payment-line" style="font-size:0.6875rem;color:#2AB5A0;font-style:italic">
                  <span>El precio con descuento se mantiene en renovaciones futuras</span>
                </div>
              )}
              {showRenewalCompare && (
                <div class="quote-payment-line" style="font-size:0.6875rem;color:#b91c1c;font-style:italic">
                  <span>La promoción venció — la renovación vuelve al precio sin descuento</span>
                </div>
              )}
            </div>
          );
        })()}
      </div>
    )}
    </section>
    )}

    {/* ═══════════════════════════════════════════════
         TAB: PAGOS — historial completo + registrar pago (admin)
         ═══════════════════════════════════════════════ */}
    <section class="quote-tab-panel" data-tab="pagos">
      <div class={`qph${isPaid ? ' qph--paid' : ''}`}>
        <div class="qph-head">
          <div>
            <div class="qph-title">{isPaid ? '✓ Pagada en su totalidad' : 'Pagos realizados'}</div>
            <div class="qph-sub">
              {paymentsList.length === 0
                ? 'Sin pagos registrados todavía.'
                : `${fmt(totalPagado)} de ${fmt(quote.total || 0)} ${quote.moneda || 'MXN'} · ${porcentajePagado}%`}
            </div>
          </div>
          {isAdminMode && (
            <button type="button" class="qph-btn-add" id="qph-btn-add">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
              <span>Registrar pago</span>
            </button>
          )}
        </div>

        {(quote.total || 0) > 0 && paymentsList.length > 0 && (
          <div class="qph-bar"><div class="qph-bar-fill" style={`width:${porcentajePagado}%`}></div></div>
        )}

        {paymentsList.length === 0 ? (
          <div class="qph-empty">
            {isAdminMode
              ? 'Cuando registres un pago, aparecerá aquí y se generará el acuse correspondiente para tu cliente.'
              : 'Aún no hay pagos confirmados en esta cotización.'}
          </div>
        ) : (
          <div class="qph-list">
            {paymentsList.map((p: any, i: number) => {
              const metodoDisplay = {
                transferencia: 'Transferencia',
                tarjeta: 'Tarjeta',
                stripe: 'Tarjeta (Stripe)',
                stripe_subscription: 'Suscripción',
                efectivo: 'Efectivo',
                oxxo: 'OXXO',
                otro: 'Otro',
              } as any;
              return (
                <div class="qph-row">
                  <div class="qph-row-num">{i + 1}</div>
                  <div class="qph-row-main">
                    <div class="qph-row-line">
                      <span class="qph-row-acuse">{p.numero_acuse || '—'}</span>
                      <span class="qph-row-method">{metodoDisplay[p.metodo] || p.metodo}</span>
                    </div>
                    <div class="qph-row-meta">
                      {fmtDate(p.fecha)}{p.referencia ? ` · ref. ${p.referencia}` : ''}
                    </div>
                  </div>
                  <div class="qph-row-amount">{fmt(p.monto)}</div>
                  <div class="qph-row-actions no-print">
                    <a href={`/acuse/${p.id}${isAdminMode ? '?admin' : ''}`} class="qph-row-link">Ver acuse</a>
                    {isAdminMode && (
                      <button type="button" class="qph-row-resend" data-pid={p.id} data-email={quote.email || ''}>Reenviar</button>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        )}

        {!isPaid && saldoRestante > 0 && paymentsList.length > 0 && (
          <div class="qph-balance">
            <span>Saldo restante</span>
            <strong>{fmt(saldoRestante)} {quote.moneda || 'MXN'}</strong>
          </div>
        )}
      </div>
    </section>

    {/* ─── Admin modal: registrar pago ─── */}
    {isAdminMode && (
    <div class="quote-modal-overlay no-print" id="qph-modal" style="display:none">
      <div class="quote-modal" style="max-width:520px">
        <div class="quote-modal-header">
          <span class="quote-modal-title">Registrar pago</span>
          <button class="quote-modal-close" id="qph-close" type="button">✕</button>
        </div>
        <div class="quote-modal-body">
          <div class="qph-form-grid">
            <label class="qph-field">
              <span>Monto ({quote.moneda || 'MXN'})</span>
              <input type="number" id="qph-monto" step="0.01" min="0" value={saldoRestante > 0 ? saldoRestante : (quote.total || 0)} />
            </label>
            <label class="qph-field">
              <span>Fecha del pago</span>
              <input type="date" id="qph-fecha" value={new Date().toISOString().slice(0, 10)} />
            </label>
            <label class="qph-field">
              <span>Método de pago</span>
              <select id="qph-metodo">
                <option value="transferencia">Transferencia bancaria</option>
                <option value="tarjeta">Tarjeta de crédito o débito</option>
                <option value="efectivo">Efectivo</option>
                <option value="oxxo">OXXO</option>
                <option value="otro">Otro</option>
              </select>
            </label>
            <label class="qph-field">
              <span>Referencia / # de operación</span>
              <input type="text" id="qph-referencia" placeholder="Ej. SPEI-1234567" />
            </label>
          </div>

          <label class="qph-field qph-field--full">
            <span>Comprobante (foto del bauche, recibo OXXO, captura)</span>
            <input type="file" id="qph-file" accept="image/*,application/pdf" />
            <span class="qph-file-status" id="qph-file-status"></span>
          </label>

          {items.length > 0 && (
            <div class="qph-field qph-field--full">
              <span>¿Qué items cubre este pago?</span>
              <div class="qph-items">
                <label class="qph-item-check"><input type="checkbox" id="qph-items-all" checked /> Todos los conceptos de la cotización</label>
                <div class="qph-items-list" id="qph-items-list" style="display:none">
                  {items.map((it: any, i: number) => {
                    const lbl = it.tipo === 'plan'
                      ? `Plan ${it.nombre}${it.sucursales ? ` · ${it.sucursales} suc.` : ''}`
                      : it.nombre || 'Concepto';
                    return (
                      <label class="qph-item-check">
                        <input type="checkbox" data-idx={i} class="qph-item-cb" />
                        <span>{lbl} <em>{fmt(it.subtotal || it.monto || 0)}</em></span>
                      </label>
                    );
                  })}
                </div>
              </div>
            </div>
          )}

          <label class="qph-field qph-field--full">
            <span>Notas internas (opcional)</span>
            <textarea id="qph-notas" rows="2" placeholder="Ej. Anticipo del 50% acordado en demo del 15-abr"></textarea>
          </label>

          <label class="qph-toggle-row">
            <input type="checkbox" id="qph-enviar-email" checked />
            <span>Enviar acuse por email a <strong>{quote.email || 'cliente'}</strong></span>
          </label>
        </div>
        <div class="quote-modal-footer" style="flex-direction:row;gap:8px">
          <button class="quote-modal-btn quote-modal-btn--secondary" id="qph-cancel" type="button">Cancelar</button>
          <button class="quote-modal-btn" id="qph-submit" type="button">Guardar y generar acuse</button>
        </div>
      </div>
    </div>
    )}

    {/* ═══════════════════════════════════════════════
         TAB: ROI
         ═══════════════════════════════════════════════ */}
    {hasRoi && (
    <section class="quote-tab-panel" data-tab="roi">
    <!-- ROI -->
    {showRoi && roi && roi.ahorro_mensual > 0 && (
      <div class="quote-roi">
        <div class="quote-roi-title">Retorno de inversión estimado</div>
        <div class="quote-roi-problem">{roi.problema}</div>
        <div class="quote-roi-numbers">
          <div class="quote-roi-stat">
            <div class="quote-roi-value" data-count={roi.ahorro_mensual}>{fmt(roi.ahorro_mensual)}</div>
            <div class="quote-roi-label">Ahorro mensual estimado</div>
          </div>
          <div class="quote-roi-stat">
            <div class="quote-roi-value" data-count={roi.ahorro_mensual * 12}>{fmt(roi.ahorro_mensual * 12)}</div>
            <div class="quote-roi-label">Ahorro anual proyectado</div>
          </div>
        </div>
        <div class="quote-roi-detail">{roi.detalle}</div>
      </div>
    )}
    </section>
    )}

    {/* ═══════════════════════════════════════════════
         TAB: COMPARATIVA
         ═══════════════════════════════════════════════ */}
    {hasAntesDesp && (
    <section class="quote-tab-panel" data-tab="comparativa">
    <!-- Antes vs Después -->
    {showAntesDesp && antesDesp.length > 0 && (
      <div class="quote-comparison">
        <div class="quote-comparison-title">Antes vs Después</div>
        <table class="quote-comparison-table">
          <thead>
            <tr>
              <th class="quote-comp-th">Aspecto</th>
              <th class="quote-comp-th quote-comp-before">Hoy</th>
              <th class="quote-comp-th quote-comp-after">Con SACS</th>
            </tr>
          </thead>
          <tbody>
            {antesDesp.map((row: any) => (
              <tr>
                <td class="quote-comp-td quote-comp-aspect">{row.aspecto}</td>
                <td class="quote-comp-td quote-comp-before-cell">{row.antes}</td>
                <td class="quote-comp-td quote-comp-after-cell">{row.despues}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
    </section>
    )}

    {/* ═══════════════════════════════════════════════
         INCLUYE (ahora vive dentro del tab Inversión)
         ═══════════════════════════════════════════════ */}
    {hasFeaturesReal && (
    <section class="quote-tab-panel" data-tab="inversion">
    <!-- Plan features -->
    {showFeatures && planFeatures.length > 0 && (
      <div class="quote-features">
        <div class="quote-features-title">Que incluye tu plan</div>
        {planFeatures.map((pf: any) => (
          <div class="quote-plan-features">
            <div class="quote-plan-name">Plan {pf.planName}</div>
            <div class="quote-features-grid">
              {pf.features.map((cat: any) => (
                <div class="quote-feature-cat">
                  <div class="quote-feature-cat-name">{cat.category}</div>
                  <ul class="quote-feature-list">
                    {cat.items.map((item: string) => (
                      <li class="quote-feature-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" style="flex-shrink:0;margin-top:2px"><path d="M20 6L9 17l-5-5" stroke="#2AB5A0" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
            {pf.services.length > 0 && (
              <div class="quote-services">
                <div class="quote-feature-cat-name">Servicios incluidos</div>
                <div class="quote-services-list">
                  {pf.services.map((s: string) => (
                    <span class="quote-service-tag">{s}</span>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    )}
    </section>
    )}

    {/* ═══════════════════════════════════════════════
         TAB: CONDICIONES
         ═══════════════════════════════════════════════ */}
    {hasCondiciones && (
    <section class="quote-tab-panel" data-tab="condiciones">
    <!-- Conditions -->
    {showCondiciones && quote.condiciones && (
      <div class="quote-conditions">
        <div class="quote-conditions-title">Condiciones</div>
        <div class="quote-conditions-text">{quote.condiciones}</div>
      </div>
    )}
