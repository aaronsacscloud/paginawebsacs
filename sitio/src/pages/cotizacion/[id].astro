.qt-promo-badge--expired { background: #b91c1c !important; }
.quote-dark .qt-promo-badge--expired { background: #b91c1c !important; color: #fff !important; }

.quote-total-row--strike { color: #b91c1c; opacity: 0.75; font-size: 0.75rem; }
