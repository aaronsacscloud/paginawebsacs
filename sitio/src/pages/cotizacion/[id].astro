---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';
import { plans } from '../../data/plans';

export const prerender = false;

const { id } = Astro.params;
const isPaidReturn = Astro.url.searchParams.get('paid') === '1';
const { data: quote } = await supabase.from('quotes').select('*').eq('id', id).single();

if (!quote) return Astro.redirect('/404');

// Auto-expire: if vigencia passed and status is still sent/draft, mark as expired
const isExpired = quote.vigencia && new Date(quote.vigencia) < new Date();
if (isExpired && quote.estado !== 'expired' && quote.estado !== 'accepted' && quote.estado !== 'paid') {
  await supabase.from('quotes').update({ estado: 'expired' }).eq('id', id);
  quote.estado = 'expired';
}

// Fetch bank account if linked
let bankAccount: any = null;
if (quote.bank_account_id) {
  const { data: ba } = await supabase.from('bank_accounts').select('*').eq('id', quote.bank_account_id).single();
  bankAccount = ba;
}

const items = Array.isArray(quote.items) ? quote.items : [];
const template = quote.template || 'modern';

// Parse meta from notas for logo_url
const notasSep = '\n---META---\n';
const notasIdx = (quote.notas || '').indexOf(notasSep);
const quoteMeta = notasIdx >= 0 ? (() => { try { return JSON.parse(quote.notas.slice(notasIdx + notasSep.length)); } catch { return {}; } })() : {};
const logoUrl = quoteMeta.logo_url || '';
const ivaMode = quoteMeta.iva_mode || (quote.iva_incluido ? 'suma' : 'sin');
const showTimer = quoteMeta.mostrar_timer !== undefined ? quoteMeta.mostrar_timer : true;
const showFeatures = quoteMeta.mostrar_features !== undefined ? quoteMeta.mostrar_features : true;
const showDesglose = quoteMeta.mostrar_desglose !== undefined ? quoteMeta.mostrar_desglose : true;
const showCondiciones = quoteMeta.mostrar_condiciones !== undefined ? quoteMeta.mostrar_condiciones : true;
const showKeyPoints = quoteMeta.mostrar_key_points !== undefined ? quoteMeta.mostrar_key_points : true;
const keyPoints = quoteMeta.key_points || [];
const daysLeft = quote.vigencia ? Math.ceil((new Date(quote.vigencia).getTime() - Date.now()) / 86400000) : 0;
const fmt = (n: number) => '$' + Math.round(n).toLocaleString('es-MX');
const fmtDate = (d: string | null) => {
  if (!d) return '';
  const date = new Date(d.length === 10 ? d + 'T12:00:00' : d);
  if (isNaN(date.getTime())) return '';
  const day = date.getDate();
  const month = date.toLocaleDateString('es-MX', { month: 'short' }).replace('.', '');
  const year = date.getFullYear();
  return `${day}/${month}/${year}`;
};
const fecha = fmtDate(quote.created_at);
const vigenciaFecha = fmtDate(quote.vigencia);

// Classify items
const planItems = items.filter((i: any) => i.tipo === 'plan');
const uniqueItems = items.filter((i: any) => i.tipo === 'extra' && !i.recurrente && !i.es_promocion);
const recurringMonthlyItems = items.filter((i: any) => i.tipo === 'extra' && i.recurrente && i.periodo_extra !== 'anual');
const recurringAnnualItems = items.filter((i: any) => i.tipo === 'extra' && i.recurrente && i.periodo_extra === 'anual');
const recurringItems = [...recurringMonthlyItems, ...recurringAnnualItems];
const promoItems = items.filter((i: any) => i.es_promocion);

// Build plan features for "Qué incluye tu plan" section
const planFeatures = planItems.map((pi: any) => {
  const planData = plans.find(p => p.id === pi.nombre?.toLowerCase());
  if (!planData) return null;
  // Collect features from this plan + all inherited plans
  const allFeatures: { category: string; items: string[] }[] = [];
  let current: typeof planData | undefined = planData;
  const visited = new Set<string>();
  while (current && !visited.has(current.id)) {
    visited.add(current.id);
    for (const f of current.features) {
      if (typeof f === 'object' && 'category' in f) {
        allFeatures.push(f);
      }
    }
    current = current.inheritsFrom ? plans.find(p => p.name === current!.inheritsFrom) : undefined;
  }
  return { planName: planData.name, features: allFeatures.reverse(), services: planData.services };
}).filter(Boolean);

// Calculate payment breakdown
const annualPlanTotal = planItems.filter((i: any) => i.periodo === 'anual').reduce((s: number, i: any) => s + (i.subtotal || 0), 0);
const monthlyPlanTotal = planItems.filter((i: any) => i.periodo === 'mensual').reduce((s: number, i: any) => s + (i.subtotal || 0), 0);
const uniqueTotal = uniqueItems.reduce((s: number, i: any) => s + (i.monto || i.subtotal || 0), 0);
const recurringTotal = recurringItems.reduce((s: number, i: any) => s + (i.monto || i.subtotal || 0), 0);
const firstPayment = annualPlanTotal + monthlyPlanTotal + uniqueTotal + recurringTotal;
const monthlyRecurring = monthlyPlanTotal + recurringTotal;

// Auto-generate summary
const planNames = planItems.map((i: any) => `Plan ${i.nombre}`).join(' + ');
const sucTotal = planItems.reduce((s: number, i: any) => s + (parseInt(i.sucursales) || 1), 0);
const extraNames = [...uniqueItems, ...recurringItems].map((i: any) => i.nombre).filter(Boolean);
const summary = planNames ? `${planNames} para ${sucTotal} sucursal${sucTotal > 1 ? 'es' : ''}${extraNames.length ? ' con ' + extraNames.join(' y ') : ''}` : quote.empresa;

// Next annual renewal date
const nextAnnualDate = new Date();
nextAnnualDate.setFullYear(nextAnnualDate.getFullYear() + 1);
const nextAnnualStr = fmtDate(nextAnnualDate.toISOString());
---

<BaseLayout title={`Cotización ${quote.numero} — Sacs`} description={`Cotización para ${quote.empresa}`}>

<div class:list={['quote-page', `quote-${template}`, { 'quote-expired-page': isExpired }]} id="quote-doc">
  <div class="quote-container" style="position:relative">
    {isExpired && (
      <div class="quote-stamp">
        <div class="quote-stamp-text">VENCIDA</div>
      </div>
    )}

    {isPaidReturn && (
      <div class="quote-paid-banner">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" stroke="#fff" stroke-width="2.5"/><path d="M22 4L12 14.01l-3-3" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/></svg>
        <span>Pago recibido. Tu servicio se activa de inmediato.</span>
      </div>
    )}

    <!-- Header -->
    <div class="quote-header">
      <div class="quote-logo">
        {logoUrl ? (
          <img src={logoUrl} alt={quote.empresa} class="quote-client-logo" width="120" height="48" loading="eager" />
        ) : (
          <span class="quote-logo-text">Sacs</span>
        )}
        <span class="quote-logo-tag">Cotización</span>
      </div>
      <div class="quote-meta">
        <div class="quote-number">{quote.numero}</div>
        <div class="quote-date">Fecha: {fecha}</div>
        <div class="quote-date">Vigencia: {vigenciaFecha}</div>
        {!isExpired && daysLeft > 0 && <div class="quote-validity">Válida hasta {vigenciaFecha}</div>}
        {isExpired && <div class="quote-expired">Cotización vencida</div>}
      </div>
    </div>

    <!-- Client info -->
    <div class="quote-client">
      <div class="quote-client-label">Cotización para:</div>
      <div class="quote-client-name">{quote.empresa}</div>
      {quote.contacto && <div class="quote-client-detail">{quote.contacto}</div>}
      {quote.email && <div class="quote-client-detail">{quote.email}</div>}
      {quote.whatsapp && <div class="quote-client-detail">{quote.whatsapp}</div>}
    </div>

    <!-- Key points -->
    {showKeyPoints && keyPoints.length > 0 && (
      <div class="quote-key-points">
        <div class="quote-key-points-title">Minuta de la reunión</div>
        <div class="quote-key-points-list">
          {keyPoints.map((kp: any) => (
            <div class="quote-key-point">
              <div class="quote-key-point-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#4B7BE5" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div class="quote-key-point-content">
                <div class="quote-key-point-title">{kp.title}</div>
                <div class="quote-key-point-detail">{kp.detail}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Urgency timer -->
    {showTimer && !isExpired && daysLeft > 0 && daysLeft <= 15 && (
      <div class:list={['quote-timer', { 'quote-timer--urgent': daysLeft <= 5 }]}>
        <div class="quote-timer-label">{quote.urgencia === 'oferta' ? 'Oferta especial' : 'Esta cotización'} vence en</div>
        <div class="quote-timer-countdown" id="countdown" data-expires={quote.vigencia}>
          <span class="quote-timer-num" id="timer-days">{daysLeft}</span>
          <span class="quote-timer-unit">días</span>
          <span class="quote-timer-num" id="timer-hours">0</span>
          <span class="quote-timer-unit">horas</span>
          <span class="quote-timer-num" id="timer-mins">0</span>
          <span class="quote-timer-unit">min</span>
          <span class="quote-timer-num" id="timer-secs">0</span>
          <span class="quote-timer-unit">seg</span>
        </div>
        {quote.descuento_global > 0 && (
          <div class="quote-timer-savings">Los descuentos de esta cotización representan un ahorro de {fmt(quote.subtotal * quote.descuento_global / 100)} {quote.moneda}</div>
        )}
      </div>
    )}

    <!-- Items table -->
    <table class="quote-table">
      <thead>
        <tr>
          <th class="qt-concept">Concepto</th>
          <th class="qt-detail">Detalle</th>
          <th class="qt-qty">Cant.</th>
          <th class="qt-price">Precio unit.</th>
          <th class="qt-subtotal">Subtotal</th>
        </tr>
      </thead>
      <tbody>
        {items.map((item: any) => {
          const isAnnual = item.periodo === 'anual';
          const suc = parseInt(item.sucursales) || 1;
          const monthlyFull = (item.precio_unitario || 0) * suc * 12;
          const annualPrice = (item.precio_unitario || 0) * suc * 10;
          const savings = isAnnual ? monthlyFull - annualPrice : 0;
          const hasDiscount = item.tipo === 'plan' && parseFloat(item.descuento_pct || 0) > 0;
          const beforeDiscount = (item.precio_unitario || 0) * suc * (isAnnual ? 10 : 1);
          const isPromo = item.es_promocion;

          return (
            <tr class:list={[{ 'qt-promo-row': isPromo }]}>
              <td class="qt-concept">
                {isPromo && <span class="qt-promo-badge">PROMOCION</span>}
                <strong>{item.tipo === 'plan' ? `Plan ${item.nombre}` : item.nombre}</strong>
                {item.tipo === 'plan' && (
                  <div class="qt-desc">
                    {fmt(item.precio_unitario || 0)}/suc × {suc} suc. × {isAnnual ? '10 meses' : '1 mes'}
                    {isAnnual && <span class="qt-savings"> · Ahorro: {fmt(savings)} (2 meses gratis)</span>}
                  </div>
                )}
                {item.descripcion && <div class="qt-desc">{item.descripcion}</div>}
                {item.nota && <div class="qt-nota">{item.nota}</div>}
              </td>
              <td class="qt-detail">
                {isPromo ? 'Promoción' : item.tipo === 'plan' ? (isAnnual ? 'Anual' : 'Mensual') : item.periodo_extra === 'anual' ? 'Anual' : item.recurrente ? 'Mensual' : 'Único'}
              </td>
              <td class="qt-qty">{item.tipo === 'plan' ? `${suc} suc.` : '1'}</td>
              <td class="qt-price">
                {isPromo && item.precio_original ? <span class="qt-strikethrough">{fmt(item.precio_original)}</span> : ''}
                {fmt(item.precio_unitario || item.monto || 0)}
              </td>
              <td class="qt-subtotal">
                {hasDiscount && <span class="qt-strikethrough">{fmt(beforeDiscount)}</span>}
                {isPromo && item.precio_original ? (
                  <span><span class="qt-strikethrough">{fmt(item.precio_original)}</span> <span class="qt-promo-price">{fmt(0)}</span></span>
                ) : (
                  <span>{fmt(item.subtotal || item.monto || 0)} {quote.moneda}</span>
                )}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>

    <!-- Totals -->
    <div class="quote-totals">
      <div class="quote-total-row">
        <span>Subtotal</span>
        <span>{fmt(quote.subtotal || 0)} {quote.moneda}</span>
      </div>
      {quote.descuento_global > 0 && (
        <div class="quote-total-row quote-discount">
          <span>Descuento {quote.descuento_tipo === 'pct' ? `(${quote.descuento_global}%)` : ''}</span>
          <span>-{fmt(quote.descuento_tipo === 'pct' ? (quote.subtotal || 0) * quote.descuento_global / 100 : quote.descuento_global)} {quote.moneda}</span>
        </div>
      )}
      {ivaMode === 'suma' && (
        <div class="quote-total-row">
          <span>IVA (16%)</span>
          <span>+{fmt(quote.iva_monto || 0)} {quote.moneda}</span>
        </div>
      )}
      {ivaMode === 'incluido' && (
        <div class="quote-total-row" style="font-size:0.75rem;color:#999">
          <span>IVA incluido en precios</span>
          <span>{fmt(quote.iva_monto || 0)} {quote.moneda}</span>
        </div>
      )}
      <div class="quote-total-row quote-total-final">
        <span>Total {ivaMode === 'incluido' ? '(IVA incluido)' : ''}</span>
        <span>{fmt(quote.total || 0)} {quote.moneda}</span>
      </div>
    </div>

    <!-- Payment breakdown -->
    {showDesglose && (annualPlanTotal > 0 || uniqueTotal > 0 || monthlyRecurring > 0) && (
      <div class="quote-payments">
        <div class="quote-payments-title">Resumen de pagos</div>

        <div class="quote-payment-block">
          <div class="quote-payment-label">Primer pago</div>
          {planItems.map((i: any) => (
            <div class="quote-payment-line">
              <span>Plan {i.nombre} ({i.periodo}) · {i.sucursales} suc.</span>
              <span>{fmt(i.subtotal || 0)}</span>
            </div>
          ))}
          {uniqueItems.map((i: any) => (
            <div class="quote-payment-line">
              <span>{i.nombre} (único)</span>
              <span>{fmt(i.monto || i.subtotal || 0)}</span>
            </div>
          ))}
          {recurringItems.map((i: any) => (
            <div class="quote-payment-line">
              <span>{i.nombre}</span>
              <span>{fmt(i.monto || i.subtotal || 0)}</span>
            </div>
          ))}
          <div class="quote-payment-total">
            <span>Total primer pago {quote.iva_incluido ? '(con IVA)' : ''}</span>
            <span>{fmt(quote.total || 0)} {quote.moneda}</span>
          </div>
        </div>

        {(monthlyPlanTotal > 0 || recurringMonthlyItems.length > 0) && (
          <div class="quote-payment-block">
            <div class="quote-payment-label">Pago mensual recurrente</div>
            {planItems.filter((i: any) => i.periodo === 'mensual').map((i: any) => (
              <div class="quote-payment-line"><span>Plan {i.nombre} · {i.sucursales} suc.</span><span>{fmt(i.subtotal || 0)}</span></div>
            ))}
            {recurringMonthlyItems.map((i: any) => (
              <div class="quote-payment-line"><span>{i.nombre}</span><span>{fmt(i.monto || 0)}</span></div>
            ))}
            <div class="quote-payment-total">
              <span>Total mensual {quote.iva_incluido ? '(+IVA)' : ''}</span>
              <span>{fmt(monthlyPlanTotal + recurringMonthlyItems.reduce((s: number, i: any) => s + (parseFloat(i.monto) || 0), 0))} {quote.moneda}/mes</span>
            </div>
          </div>
        )}

        {(annualPlanTotal > 0 || recurringAnnualItems.length > 0) && (
          <div class="quote-payment-block">
            <div class="quote-payment-label">Próxima renovación anual: {nextAnnualStr}</div>
            {planItems.filter((i: any) => i.periodo === 'anual').map((i: any) => (
              <div class="quote-payment-line"><span>Renovación Plan {i.nombre} · {i.sucursales} suc.</span><span>{fmt(i.subtotal || 0)}</span></div>
            ))}
            {recurringAnnualItems.map((i: any) => (
              <div class="quote-payment-line"><span>{i.nombre} (anual)</span><span>{fmt(i.subtotal || 0)}</span></div>
            ))}
          </div>
        )}
      </div>
    )}

    <!-- Plan features -->
    {showFeatures && planFeatures.length > 0 && (
      <div class="quote-features">
        <div class="quote-features-title">Que incluye tu plan</div>
        {planFeatures.map((pf: any) => (
          <div class="quote-plan-features">
            <div class="quote-plan-name">Plan {pf.planName}</div>
            <div class="quote-features-grid">
              {pf.features.map((cat: any) => (
                <div class="quote-feature-cat">
                  <div class="quote-feature-cat-name">{cat.category}</div>
                  <ul class="quote-feature-list">
                    {cat.items.map((item: string) => (
                      <li class="quote-feature-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" style="flex-shrink:0;margin-top:2px"><path d="M20 6L9 17l-5-5" stroke="#2AB5A0" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
            {pf.services.length > 0 && (
              <div class="quote-services">
                <div class="quote-feature-cat-name">Servicios incluidos</div>
                <div class="quote-services-list">
                  {pf.services.map((s: string) => (
                    <span class="quote-service-tag">{s}</span>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    )}

    <!-- Conditions -->
    {showCondiciones && quote.condiciones && (
      <div class="quote-conditions">
        <div class="quote-conditions-title">Condiciones</div>
        <div class="quote-conditions-text">{quote.condiciones}</div>
      </div>
    )}

    <!-- Bank account -->
    {bankAccount && quote.mostrar_banco && (
      <div class="quote-bank">
        <div class="quote-bank-title">Datos para transferencia</div>
        <div class="quote-bank-grid">
          <div class="quote-bank-item"><span class="quote-bank-label">Banco</span><span class="quote-bank-value">{bankAccount.banco}</span></div>
          <div class="quote-bank-item"><span class="quote-bank-label">Titular</span><span class="quote-bank-value">{bankAccount.titular}</span></div>
          <div class="quote-bank-item"><span class="quote-bank-label">Cuenta</span><span class="quote-bank-value">{bankAccount.cuenta}</span></div>
          <div class="quote-bank-item"><span class="quote-bank-label">CLABE</span><span class="quote-bank-value" style="font-family:monospace;letter-spacing:0.05em">{bankAccount.clabe}</span></div>
          {bankAccount.rfc && <div class="quote-bank-item"><span class="quote-bank-label">RFC</span><span class="quote-bank-value">{bankAccount.rfc}</span></div>}
        </div>
      </div>
    )}

    <!-- Payment link -->
    {quote.link_pago && (
      <div class="quote-pay-link">
        <a href={quote.link_pago} target="_blank" rel="noopener" class="quote-pay-btn">Pagar ahora</a>
        <div class="quote-pay-note">Pago seguro. Al completar el pago, tu servicio se activa de inmediato.</div>
      </div>
    )}

    <!-- Version history -->
    {(quoteMeta.versions || []).length > 1 && (
      <div class="quote-versions">
        <div class="quote-versions-header">
          <span class="quote-versions-title">Historial de versiones</span>
          <span class="quote-versions-current">Version actual: v{(quoteMeta.versions || []).length}</span>
        </div>
        <div class="quote-versions-list">
          {(quoteMeta.versions || []).slice().reverse().map((ver: any, i: number) => {
            const isCurrent = i === 0;
            const prev = i < (quoteMeta.versions || []).length - 1 ? (quoteMeta.versions || []).slice().reverse()[i + 1] : null;
            const diff = prev ? ver.total - prev.total : 0;
            return (
              <div class:list={['quote-version-item', { 'quote-version-current': isCurrent }]}>
                <div class="quote-version-dot" />
                <div class="quote-version-content">
                  <div class="quote-version-label">
                    <strong>v{ver.v}</strong>
                    {isCurrent && <span class="quote-version-badge">Actual</span>}
                  </div>
                  <div class="quote-version-detail">
                    {fmtDate(ver.at)} · {ver.items_count} concepto{ver.items_count !== 1 ? 's' : ''} · {fmt(ver.total)} {ver.moneda || 'MXN'}
                    {diff !== 0 && !isCurrent && (
                      <span class={diff > 0 ? 'quote-version-up' : 'quote-version-down'}>
                        {diff > 0 ? '+' : ''}{fmt(diff)}
                      </span>
                    )}
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}

    <!-- Legal -->
    <div class="quote-legal">
      Al aceptar esta cotización, confirmas que has leído y aceptas nuestros <a href="https://www.sacscloud.com/terminos" target="_blank" rel="noopener">Términos y condiciones</a> y nuestro <a href="https://www.sacscloud.com/privacidad" target="_blank" rel="noopener">Aviso de privacidad</a>.
    </div>

    <!-- Footer -->
    <div class="quote-footer">
      <div class="quote-footer-brand">
        <span class="quote-footer-logo">Sacs</span>
        <span class="quote-footer-tagline">Sistema operativo para retailers</span>
      </div>
      <div class="quote-footer-contact">
        www.sacscloud.com · administracion@sacscloud.com
      </div>
    </div>
  </div>

  <!-- Actions (hidden in print) -->
  <div class="quote-actions no-print">
    {quote.estado === 'accepted' && (
      <div class="quote-accepted-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" stroke="currentColor" stroke-width="2"/><path d="M22 4L12 14.01l-3-3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        Cotización aceptada {quote.aceptado_por ? `por ${quote.aceptado_por}` : ''}
      </div>
    )}
    {isExpired ? (
      <div class="quote-expired-notice">
        <div class="quote-expired-notice-title">Esta cotización ha vencido</div>
        <div class="quote-expired-notice-text">Los precios y condiciones ya no son vigentes. Contactanos para recibir una cotización actualizada.</div>
        <a class="quote-action-btn" href={`https://wa.me/5215512345678?text=${encodeURIComponent(`Hola, la cotización ${quote.numero} venció. Me gustaría recibir una cotización actualizada.`)}`} target="_blank" rel="noopener">Solicitar recotización</a>
      </div>
    ) : (
      <div class="quote-actions-row">
        <button class="quote-action-btn" id="btn-comments">Realizar comentarios</button>
        <button class="quote-action-btn" id="btn-share">Compartir por correo</button>
        <button class="quote-action-btn" onclick="window.print()">Descargar PDF</button>
      </div>
    )}
  </div>

  <!-- Comments modal -->
  <div class="quote-modal-overlay no-print" id="comments-section" style="display:none">
    <div class="quote-modal">
      <div class="quote-modal-header">
        <span class="quote-modal-title">Comentarios</span>
        <button class="quote-modal-close" id="btn-close-comments">✕</button>
      </div>
      <div class="quote-comments-thread" id="comments-thread">
        <div class="quote-comments-empty" id="comments-empty">Sin comentarios aun. Escribe tu primera pregunta o solicitud.</div>
      </div>
      <div class="quote-modal-footer">
        <input type="text" id="comment-name" placeholder="Tu nombre" class="quote-modal-input" />
        <textarea id="comment-text" placeholder="Escribe tu comentario, pregunta o solicitud..." class="quote-modal-input" rows="3"></textarea>
        <button class="quote-modal-btn" id="btn-send-comment">Enviar comentario</button>
      </div>
    </div>
  </div>

  <!-- Share modal -->
  <div class="quote-modal-overlay no-print" id="share-section" style="display:none">
    <div class="quote-modal">
      <div class="quote-modal-header">
        <span class="quote-modal-title">Compartir por correo</span>
        <button class="quote-modal-close" id="btn-close-share">✕</button>
      </div>
      <div class="quote-modal-body">
        <p class="quote-modal-hint">Envia esta cotización a alguien mas. Se abrira tu cliente de correo con el link incluido.</p>
        <div class="quote-share-grid">
          <div>
            <label class="quote-share-label">Para</label>
            <input type="email" id="share-to" placeholder="correo@ejemplo.com" class="quote-modal-input" />
          </div>
          <div>
            <label class="quote-share-label">Tu nombre</label>
            <input type="text" id="share-from" placeholder="Tu nombre" class="quote-modal-input" value={quote.contacto || ''} />
          </div>
          <div style="grid-column:1/-1">
            <label class="quote-share-label">Asunto</label>
            <input type="text" id="share-subject" class="quote-modal-input" value={`Cotización ${quote.numero} — ${quote.empresa}`} />
          </div>
          <div style="grid-column:1/-1">
            <label class="quote-share-label">Mensaje</label>
            <textarea id="share-body" class="quote-modal-input" rows="4">{`Hola,\n\nTe comparto esta cotización para tu revision:\n\nhttps://www.sacscloud.com/cotizacion/${quote.id}\n\nSaludos`}</textarea>
          </div>
        </div>
      </div>
      <div class="quote-modal-footer" style="flex-direction:row">
        <button class="quote-modal-btn" id="btn-send-share">Abrir correo</button>
        <button class="quote-modal-btn quote-modal-btn--secondary" onclick="window.print()">Descargar PDF</button>
      </div>
    </div>
  </div>
</div>

</BaseLayout>

<style>
