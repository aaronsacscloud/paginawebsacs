.quote-tl-result { margin-top: 12px; font-size: 0.8125rem; font-weight: 700; color: #2AB5A0; font-style: italic; }

.quote-dark .quote-timeline-section { border-color: rgba(255,255,255,0.08); }
.quote-dark .quote-timeline-title { color: #fff; }
.quote-dark .quote-tl-heading { color: #fff; }
.quote-dark .quote-tl-item { color: rgba(255,255,255,0.6); }
.quote-dark .quote-tl-line { background: rgba(255,255,255,0.08); }
.quote-dark .quote-tl-dot { border-color: #1a1a1a; }

/* ─── Cases carousel ─── */
.quote-cases { padding: 24px 0 32px; border-top: 1px solid #f0f0f0; overflow: hidden; }
.quote-cases-title { font-family: var(--font-display); font-size: 1rem; font-weight: 800; color: #1a1a1a; margin-bottom: 16px; padding: 0 40px; }
.quote-cases-track { display: flex; gap: 16px; padding: 0 40px; overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; -webkit-overflow-scrolling: touch; scroll-behavior: smooth; }
.quote-cases-track::-webkit-scrollbar { display: none; }
.quote-case-card { min-width: 280px; max-width: 300px; flex-shrink: 0; border-radius: 12px; overflow: hidden; border: 1px solid #f0f0f0; scroll-snap-align: start; transition: transform 0.3s ease, box-shadow 0.3s ease; }
.quote-case-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
