---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t } from '../../../i18n/utils';
const locale = 'fr';
---
<BaseLayout title="Cas clients — Sacs" description="Des histoires reelles de marques qui grandissent avec Sacs." locale={locale}>
<section style="padding: clamp(120px, 12vw, 180px) 24px 80px; text-align: center;">
  <div style="max-width: 800px; margin: 0 auto;">
    <h1 style="font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: 800; color: var(--color-text-primary); letter-spacing: -0.04em; margin: 0 0 16px;">{t('nav.caseStudies', locale)}</h1>
    <p style="font-family: var(--font-body); font-size: 1.125rem; color: var(--color-text-secondary); margin: 0 0 40px;">Des histoires reelles de marques qui grandissent avec Sacs.</p>
    <a href="/casos-de-exito" style="display: inline-block; font-family: var(--font-body); font-size: 0.875rem; color: var(--color-primary); text-decoration: none;">View in Spanish →</a>
  </div>
</section>
</BaseLayout>
