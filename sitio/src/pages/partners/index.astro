---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;

const title = 'Partners SACS · Próximamente';
const description = 'El programa de partners SACS estará disponible pronto.';
---

<BaseLayout title={title} description={description}>
  <main class="soon">
    <section class="soon-inner">
      <span class="soon-eyebrow">Programa de Partners SACS</span>
      <h1 class="soon-title">Próximamente.</h1>
      <p class="soon-lead">
        Estamos preparando todos los detalles del programa de partners.
        Vuelve pronto para conocer cómo puedes ser parte de la red SACS.
      </p>
      <a href="/" class="soon-link">← Volver a sacscloud.com</a>
    </section>
  </main>
</BaseLayout>

<style>
  .soon {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
    background: #fafaf8;
  }
  .soon-inner {
    max-width: 560px;
    text-align: center;
  }
  .soon-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #4b7be5;
    margin-bottom: 28px;
  }
  .soon-title {
    font-family: var(--font-display, 'Inter', system-ui, sans-serif);
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #1a1a1a;
    margin: 0 0 24px;
  }
  .soon-lead {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: #555;
    margin: 0 0 40px;
  }
  .soon-link {
    display: inline-block;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #4b7be5;
    text-decoration: none;
    padding: 12px 4px;
    transition: color 0.15s;
  }
  .soon-link:hover { color: #2f5fcc; }
  @media (max-width: 640px) {
    .soon { padding: 60px 20px; min-height: 72vh; }
    .soon-eyebrow { margin-bottom: 20px; font-size: 0.6875rem; }
    .soon-lead { font-size: 0.9375rem; margin-bottom: 32px; }
  }
</style>
