---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;

// Stats hero
const STATS = [
  { num: '50%', label: 'Comisión por venta directa', sub: 'sobre el monto cobrado' },
  { num: '$250', label: 'Por prueba gratis activada', sub: 'cada nuevo trial' },
  { num: '$250', label: 'Por demo completada', sub: 'cuando el prospecto asiste' },
  { num: '3K+', label: 'Marcas en la red SACS', sub: 'red activa LATAM' },
];

const TIPOS = [
  {
    icon: '📣',
    nombre: 'Embajador',
    tagline: 'Para creadores con audiencia retail',
    bullets: [
      'Free + 50% comisión + bonos',
      '4 videos al mes con la plataforma',
      'Reuniones trimestrales con producto',
      'Plan Fideliza gratis ($14k/año valor)',
    ],
    cta: 'Postularse',
    featured: true,
  },
  {
    icon: '🏢',
    nombre: 'Distribuidor',
    tagline: 'Vende SACS a tu propia red',
    bullets: [
      'Comisión recurrente sobre MRR',
      'Leads asignados por zona',
      'Certificación oficial',
      'Manejo de relación comercial',
    ],
    cta: 'Postularse',
  },
  {
    icon: '⚙️',
    nombre: 'Integrador',
    tagline: 'B2B · implementación técnica',
    bullets: [
      '25% sobre fees de implementación',
      'Sandbox + soporte L2',
      'Documentación API completa',
      'Certificación SACS Integrator',
    ],
    cta: 'Postularse',
  },
];

// JSON-LD structured data for SEO
const programSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Programa Partners SACS',
  serviceType: 'Programa de afiliados',
  provider: {
    '@type': 'Organization',
    name: 'SACS Cloud',
    url: 'https://www.sacscloud.com',
  },
  areaServed: { '@type': 'Country', name: 'Mexico' },
  description: '50% de comisión por venta directa, $250 por prueba gratis activada, $250 por demo completada. Para creadores con audiencia retail, distribuidores, integradores y consultores.',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'MXN',
    description: 'Programa gratuito para partners aprobados',
  },
};

const FAQ_DATA = [
  {
    q: '¿Cuánto cuesta entrar al programa?',
    a: '$0. El programa es gratis para embajadores aprobados. No hay cuota mensual ni de inscripción. SACS gana cuando tú generas ventas — el incentivo está alineado.',
  },
  {
    q: '¿Cuándo y cómo me pagan?',
    a: 'Cada 30 días por transferencia bancaria, PayPal o Mercado Pago. Tu portal de partner muestra desglose por concepto, cliente y referido — completamente transparente.',
  },
  {
    q: '¿Qué cuento como "venta atribuida"?',
    a: 'Cualquier prospecto que llegue por tu link único (sacscloud.com/p/tu-nombre), se registre, agende demo o cierre venta queda atribuido a ti automáticamente vía cookie de 90 días.',
  },
  {
    q: '¿Qué pasa si no llego al mínimo de cuota?',
    a: 'Para embajadores la cuota mínima es 10 sucursales activas en 12 meses. Si no la alcanzas, SACS y tú acordamos un plan de recuperación de 90 días — no es despido automático.',
  },
  {
    q: '¿Necesito tener una marca personal grande?',
    a: 'No necesariamente. Lo que vale es la calidad de tu red y tu seriedad para representar la marca. Tenemos embajadores con 5K seguidores que cierran más que algunos con 100K.',
  },
  {
    q: '¿En cuánto tiempo me aprueban?',
    a: '3 a 5 días hábiles. Validamos tu información, tu fit con la marca y tus datos de cobro. Te avisamos por correo y WhatsApp.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_DATA.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<BaseLayout
  title="Programa Partners SACS — gana 50% recomendando el sistema operativo del retail"
  description="Únete al programa de partners SACS. 50% de comisión por venta directa, $250 por prueba gratis activada, $250 por demo completada. Plan Fideliza gratis para tu negocio."
  noindex={false}
  structuredData={[programSchema, faqSchema]}
>
  <main class="pt-page">

    <!-- HERO -->
    <section class="pt-hero">
      <div class="pt-container">
        <div class="pt-hero-eyebrow">Programa Partners SACS</div>
        <h1 class="pt-hero-title">
          Recomienda SACS.<br/>
          <span class="pt-hero-title-accent">Cobra cada activación.</span>
        </h1>
        <p class="pt-hero-lead">
          Únete a la red de partners de la plataforma de retail más usada en
          México. SACS opera todo el embudo — tú solo compartes tu link único.
        </p>
        <div class="pt-hero-cta-row">
          <a href="#aplicar" class="pt-btn pt-btn--primary">Postularme ahora</a>
          <a href="#como-funciona" class="pt-btn pt-btn--ghost">Cómo funciona →</a>
        </div>
      </div>
    </section>

    <!-- STATS -->
    <section class="pt-section pt-section--stats">
      <div class="pt-container">
        <div class="pt-stats-grid">
          {STATS.map(s => (
            <div class="pt-stat">
              <div class="pt-stat-num">{s.num}</div>
              <div class="pt-stat-label">{s.label}</div>
              <div class="pt-stat-sub">{s.sub}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CÓMO FUNCIONA -->
    <section class="pt-section" id="como-funciona">
      <div class="pt-container">
        <div class="pt-head">
          <div class="pt-eyebrow">El proceso</div>
          <h2 class="pt-title">Cómo funciona</h2>
          <p class="pt-lead">
            Sin sorpresas. Desde que aplicas hasta tu primera comisión, te explicamos cada paso.
          </p>
        </div>

        <ol class="pt-steps">
          <li class="pt-step">
            <div class="pt-step-num">1</div>
            <div>
              <h3 class="pt-step-title">Aplicas en este sitio</h3>
              <p class="pt-step-detail">Llenas un formulario de 3 minutos. Datos básicos, tu audiencia, tipo de partnership.</p>
            </div>
          </li>
          <li class="pt-step">
            <div class="pt-step-num">2</div>
            <div>
              <h3 class="pt-step-title">SACS revisa tu solicitud</h3>
              <p class="pt-step-detail">Validamos fit con la marca, audiencia y datos de cobro. <strong>Respuesta en 3-5 días hábiles.</strong></p>
            </div>
          </li>
          <li class="pt-step">
            <div class="pt-step-num">3</div>
            <div>
              <h3 class="pt-step-title">Te activamos</h3>
              <p class="pt-step-detail">Recibes tu link único, acceso al portal, brand kit y tu cuenta SACS Plan Fideliza gratis para usar en tu negocio.</p>
            </div>
          </li>
          <li class="pt-step">
            <div class="pt-step-num">4</div>
            <div>
              <h3 class="pt-step-title">Compartes y cobras</h3>
              <p class="pt-step-detail">Cada activación que llega por tu link genera bonos automáticos. SACS opera el cierre. Tú ves todo en tu portal en tiempo real.</p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <!-- TIPOS DE PARTNER -->
    <section class="pt-section pt-section--alt" id="tipos">
      <div class="pt-container">
        <div class="pt-head">
          <div class="pt-eyebrow">Tipos de partnership</div>
          <h2 class="pt-title">Hay un programa para cada perfil</h2>
          <p class="pt-lead">Elige el que mejor se ajusta a tu modelo. Los tres son compatibles — algunos partners son embajador + integrador a la vez.</p>
        </div>

        <div class="pt-tipos-grid">
          {TIPOS.map(t => (
            <div class={`pt-tipo-card ${t.featured ? 'pt-tipo-card--featured' : ''}`}>
              {t.featured && <div class="pt-tipo-pop">Más popular</div>}
              <div class="pt-tipo-icon">{t.icon}</div>
              <h3 class="pt-tipo-nombre">{t.nombre}</h3>
              <p class="pt-tipo-tagline">{t.tagline}</p>
              <ul class="pt-tipo-bullets">
                {t.bullets.map(b => <li>{b}</li>)}
              </ul>
              <a href={`#aplicar?tipo=${t.nombre.toLowerCase()}`} class="pt-tipo-cta">{t.cta} →</a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- LO QUE GANAS -->
    <section class="pt-section" id="ganas">
      <div class="pt-container">
        <div class="pt-head">
          <div class="pt-eyebrow">Lo que ganas</div>
          <h2 class="pt-title">Te pagamos por cada paso del proceso</h2>
          <p class="pt-lead">No solo por la venta final. Cada activación cuenta.</p>
        </div>

        <div class="pt-rewards-grid">
          <div class="pt-reward">
            <div class="pt-reward-num">$250</div>
            <div class="pt-reward-name">Prueba gratis activada</div>
            <p class="pt-reward-detail">Cada usuario que llega por tu link y se registra para la prueba gratis. Pago al confirmar el alta.</p>
          </div>
          <div class="pt-reward">
            <div class="pt-reward-num">$250</div>
            <div class="pt-reward-name">Demo completada</div>
            <p class="pt-reward-detail">Cuando el prospecto asiste y completa el demo válido (mín. 25 min con tomador de decisión).</p>
          </div>
          <div class="pt-reward pt-reward--featured">
            <div class="pt-reward-num">50%</div>
            <div class="pt-reward-name">Venta directa</div>
            <p class="pt-reward-detail">Comisión sobre el cobro de la primera factura del cliente cerrado a través de tu link.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- LO QUE SACS TE DA -->
    <section class="pt-section pt-section--alt">
      <div class="pt-container">
        <div class="pt-head">
          <div class="pt-eyebrow">Lo que SACS te entrega</div>
          <h2 class="pt-title">Todo lo que necesitas, listo el día 1</h2>
        </div>

        <div class="pt-deliverables-grid">
          <div class="pt-deliverable">
            <div class="pt-deliverable-icon">🔗</div>
            <h3 class="pt-deliverable-title">Tu link único</h3>
            <p class="pt-deliverable-detail">URL personalizada (sacscloud.com/p/tu-nombre) que atribuye automáticamente cualquier prospecto que llegue por ahí.</p>
          </div>
          <div class="pt-deliverable">
            <div class="pt-deliverable-icon">📊</div>
            <h3 class="pt-deliverable-title">Portal con métricas en vivo</h3>
            <p class="pt-deliverable-detail">Visitas, registros, demos, comisiones, pagos — todo en tiempo real desde laptop, tablet o teléfono.</p>
          </div>
          <div class="pt-deliverable">
            <div class="pt-deliverable-icon">🛍️</div>
            <h3 class="pt-deliverable-title">Plan Fideliza gratis</h3>
            <p class="pt-deliverable-detail">Cuenta SACS completa para tu propio negocio. Valor real $14,000 MXN/año — gratis durante el programa.</p>
          </div>
          <div class="pt-deliverable">
            <div class="pt-deliverable-icon">📘</div>
            <h3 class="pt-deliverable-title">Brand kit completo</h3>
            <p class="pt-deliverable-detail">Logos, colores, tipografías, captions listos, hashtags y plan mensual de contenido.</p>
          </div>
          <div class="pt-deliverable">
            <div class="pt-deliverable-icon">🎓</div>
            <h3 class="pt-deliverable-title">Onboarding 1-on-1</h3>
            <p class="pt-deliverable-detail">Sesión privada de 45 min para conocer la plataforma, resolver dudas y empezar a vender con confianza.</p>
          </div>
          <div class="pt-deliverable">
            <div class="pt-deliverable-icon">🤝</div>
            <h3 class="pt-deliverable-title">Reuniones trimestrales</h3>
            <p class="pt-deliverable-detail">Cada 3 meses revisamos juntos cómo va, mejores prácticas, nuevos materiales, feedback al producto.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- APPLY FORM (multi-step + contrato + firma) -->
    <section class="pt-section pt-section--apply" id="aplicar">
      <div class="pt-container pt-container--narrow">
        <div class="pt-head pt-head--center">
          <div class="pt-eyebrow">Postularte</div>
          <h2 class="pt-title">Empieza tu aplicación</h2>
          <p class="pt-lead">3 pasos. Firma digital. Respuesta en 3-5 días hábiles.</p>
          <div class="pt-social-badge">
            <span class="pt-social-dot"></span>
            <strong>577 partners</strong> ya están activos en LATAM
          </div>
        </div>

        <!-- Stepper -->
        <div class="pt-stepper" id="apply-stepper">
          <div class="pt-stepper-item is-active" data-step="1"><span>1</span> Datos</div>
          <div class="pt-stepper-line"></div>
          <div class="pt-stepper-item" data-step="2"><span>2</span> Audiencia</div>
          <div class="pt-stepper-line"></div>
          <div class="pt-stepper-item" data-step="3"><span>3</span> Contrato y firma</div>
        </div>

        <div id="apply-draft-prompt" class="pt-draft-prompt" hidden>
          <div>📝 Tienes una solicitud guardada sin terminar.</div>
          <div class="pt-draft-actions">
            <button type="button" id="apply-draft-restore" class="pt-btn pt-btn--ghost" style="padding:8px 14px;font-size:0.8125rem">Continuar donde quedé</button>
            <button type="button" id="apply-draft-discard" class="pt-btn pt-btn--ghost" style="padding:8px 14px;font-size:0.8125rem;border-color:transparent;color:#888">Empezar de cero</button>
          </div>
        </div>

        <form id="apply-form" class="pt-form" novalidate>

          <!-- ── STEP 1: Datos básicos ── -->
          <fieldset class="pt-step is-active" data-step="1">
            <div class="pt-step-head">
              <div class="pt-step-num">01</div>
              <div>
                <h3 class="pt-step-title">Tus datos</h3>
                <p class="pt-step-sub">Cómo te contactamos cuando tengamos respuesta.</p>
              </div>
            </div>
            <div class="pt-form-row">
              <label class="pt-field">
                <span>Nombre completo *</span>
                <input type="text" id="apply-nombre" required placeholder="Mariana López" autocomplete="name" />
              </label>
              <label class="pt-field">
                <span>Email *</span>
                <input type="email" id="apply-email" required placeholder="tu@correo.com" autocomplete="email" />
              </label>
            </div>
            <div class="pt-form-row">
              <label class="pt-field">
                <span>WhatsApp *</span>
                <input type="tel" id="apply-whatsapp" required placeholder="55 1234 5678" autocomplete="tel" inputmode="numeric" />
              </label>
              <label class="pt-field">
                <span>Empresa o marca personal</span>
                <input type="text" id="apply-empresa" placeholder="Tu marca / proyecto" />
              </label>
            </div>
            <div class="pt-form-row">
              <label class="pt-field">
                <span>Tipo de partnership *</span>
                <select id="apply-tipo" required>
                  <option value="embajador">Embajador (creador con audiencia)</option>
                  <option value="distribuidor">Distribuidor (red comercial propia)</option>
                  <option value="integrador">Integrador (B2B / técnico)</option>
                  <option value="reseller">Reseller (white-label)</option>
                  <option value="consultor">Consultor</option>
                </select>
              </label>
              <label class="pt-field">
                <span>Ciudad / Estado</span>
                <input type="text" id="apply-ciudad" placeholder="CDMX, Guadalajara, MTY..." />
              </label>
            </div>

            {/* Honeypot — invisible para humanos, bots lo llenan */}
            <input type="text" id="apply-bot" name="company" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;pointer-events:none" />

            <div class="pt-step-nav">
              <div></div>
              <button type="button" class="pt-btn pt-btn--primary" data-go-step="2">Siguiente · Audiencia →</button>
            </div>
          </fieldset>

          <!-- ── STEP 2: Audiencia ── -->
          <fieldset class="pt-step" data-step="2">
            <div class="pt-step-head">
              <div class="pt-step-num">02</div>
              <div>
                <h3 class="pt-step-title">Tu audiencia y experiencia</h3>
                <p class="pt-step-sub">Para entender tu alcance y cómo podemos amplificarte.</p>
              </div>
            </div>

            <label class="pt-field pt-field--full">
              <span>Sitio web o portafolio</span>
              <input type="text" id="apply-website" placeholder="https://tumarca.com (opcional)" />
            </label>

            <div class="pt-field pt-field--full">
              <span>Tus redes sociales y seguidores</span>
              <p class="pt-field-hint">Solo las que uses. Pon @handle y aproximado de seguidores.</p>
              <div class="pt-socials">
                {['Instagram', 'TikTok', 'YouTube', 'LinkedIn', 'X / Twitter'].map(p => (
                  <div class="pt-social-row" data-platform={p}>
                    <span class="pt-social-platform">{p}</span>
                    <input type="text" class="pt-social-handle" placeholder="@usuario" data-field="handle" />
                    <input type="number" class="pt-social-followers" placeholder="seguidores" min="0" inputmode="numeric" data-field="followers" />
                  </div>
                ))}
              </div>
              <div class="pt-followers-summary" id="apply-followers-summary">
                <span>Alcance total: <strong id="apply-followers-total">0</strong> seguidores</span>
                <span class="pt-earnings-est" id="apply-earnings-est"></span>
              </div>
            </div>

            <div class="pt-form-row">
              <label class="pt-field">
                <span>Experiencia con retail</span>
                <select id="apply-experiencia">
                  <option value="">Elige una opción…</option>
                  <option value="ninguna">Ninguna formal</option>
                  <option value="1-3">1–3 años</option>
                  <option value="3-5">3–5 años</option>
                  <option value="5+">5+ años</option>
                  <option value="dueño">Soy dueño/a de un retail</option>
                </select>
              </label>
              <label class="pt-field">
                <span>¿Cómo nos conociste?</span>
                <select id="apply-como">
                  <option value="">Elige una opción…</option>
                  <option value="redes">Redes sociales</option>
                  <option value="google">Google / búsqueda</option>
                  <option value="recomendacion">Me recomendaron</option>
                  <option value="evento">Evento o conferencia</option>
                  <option value="cliente">Soy cliente SACS</option>
                  <option value="otro">Otro</option>
                </select>
              </label>
            </div>

            <div class="pt-step-nav">
              <button type="button" class="pt-btn pt-btn--ghost" data-go-step="1">← Atrás</button>
              <button type="button" class="pt-btn pt-btn--primary" data-go-step="3">Siguiente · Contrato y firma →</button>
            </div>
          </fieldset>

          <!-- ── STEP 3: Contrato + firma ── -->
          <fieldset class="pt-step" data-step="3">
            <div class="pt-step-head">
              <div class="pt-step-num">03</div>
              <div>
                <h3 class="pt-step-title">Contrato y firma</h3>
                <p class="pt-step-sub">Cuéntanos por qué quieres unirte, lee el contrato y firma.</p>
              </div>
            </div>

            <label class="pt-field pt-field--full">
              <span>¿Por qué te interesa ser partner SACS? *</span>
              <p class="pt-field-hint">Mínimo 30 caracteres. Sé específico — esto nos ayuda a evaluar fit.</p>
              <textarea id="apply-motivo" required minlength="30" rows="5" placeholder="Cuéntanos sobre tu audiencia, qué tipo de contenido haces, tu visión del retail mexicano, qué te entusiasma de SACS, etc."></textarea>
              <div class="pt-char-count" id="apply-motivo-count">0 / 1500</div>
            </label>

            <!-- Contrato -->
            <div class="pt-contract">
              <div class="pt-contract-head">
                <div class="pt-contract-eyebrow">Acuerdo de Partner</div>
                <div class="pt-contract-title">Lee y firma para enviar tu solicitud</div>
              </div>
              <div class="pt-contract-body">
                <p><strong>Por la presente declaro que:</strong></p>
                <ol>
                  <li><strong>Datos verídicos.</strong> La información que proporciono es verdadera, actualizada y representa fielmente mi audiencia y experiencia.</li>
                  <li><strong>Acepto las condiciones económicas:</strong>
                    <ul>
                      <li>50% de comisión sobre venta directa atribuida a mi link único</li>
                      <li>$250 MXN por cada prueba gratis activada por mi referido</li>
                      <li>$250 MXN por cada demo completada con prospecto válido (mín. 25 min, decisor presente)</li>
                      <li>Acceso al plan SACS Fideliza ($14,000 MXN/año) gratis durante el programa</li>
                    </ul>
                  </li>
                  <li><strong>Compromisos como partner:</strong>
                    <ul>
                      <li>Cuidar la marca SACS y representarla profesionalmente</li>
                      <li>Atender leads asignados en menos de 24 horas hábiles</li>
                      <li>Asistir a sesión mensual de actualizaciones (30-60 min)</li>
                      <li>Cumplir compromisos de contenido según mi tipo de partnership</li>
                    </ul>
                  </li>
                  <li><strong>Revisión SACS.</strong> Entiendo que SACS revisará mi solicitud en 3-5 días hábiles y se reserva el derecho de aprobar o rechazar.</li>
                  <li><strong>Pagos.</strong> Las comisiones se liquidan cada 30 días vía transferencia bancaria, PayPal o Mercado Pago a la cuenta que registre.</li>
                  <li><strong>Vigencia y terminación.</strong> El acuerdo es por 12 meses, renovable. Cualquiera de las partes puede terminar con 30 días de aviso.</li>
                </ol>
                <p class="pt-contract-fine">
                  Términos completos: <a href="/terminos" target="_blank">sacscloud.com/terminos</a> · Aviso de privacidad: <a href="/privacidad" target="_blank">sacscloud.com/privacidad</a>
                </p>
              </div>

              <label class="pt-contract-accept">
                <input type="checkbox" id="apply-acepta" required />
                <span>He leído el contrato y acepto los términos del programa.</span>
              </label>

              <div class="pt-signature-wrap">
                <div class="pt-signature-label">Firma con tu dedo o el mouse *</div>
                <canvas id="apply-canvas" class="pt-signature-canvas"></canvas>
                <button type="button" class="pt-btn pt-btn--ghost" id="apply-canvas-clear" style="padding:8px 14px;font-size:0.8125rem;margin-top:8px">Limpiar firma</button>
              </div>
            </div>

            <div class="pt-step-nav">
              <button type="button" class="pt-btn pt-btn--ghost" data-go-step="2">← Atrás</button>
              <button type="submit" class="pt-btn pt-btn--primary" id="apply-submit">Firmar y enviar solicitud</button>
            </div>

            <div class="pt-form-msg" id="apply-msg" hidden></div>
            <div class="pt-form-legal">
              Al firmar aceptas el contrato y autorizas a SACS a procesar tus datos para evaluar tu solicitud.
            </div>
