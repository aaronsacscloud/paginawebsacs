  .pt-faq-icon { font-size: 1.5rem; color: #4B7BE5; transition: transform 0.2s; line-height: 1; flex-shrink: 0; margin-left: 16px; }
  details[open] .pt-faq-icon { transform: rotate(45deg); }
  .pt-faq-a { font-size: 0.9375rem; color: #555; line-height: 1.65; margin: 0 0 22px; padding-right: 32px; }
  .pt-faq-cta { text-align: center; margin-top: 48px; padding-top: 32px; border-top: 1px solid #ececec; }
  .pt-faq-cta p { font-size: 0.9375rem; color: #888; margin: 0 0 16px; }
</style>

<script>
  (function() {
    const DRAFT_KEY = 'sacs_partner_apply_draft_v2';
    const PLATFORMS = ['Instagram', 'TikTok', 'YouTube', 'LinkedIn', 'X / Twitter'];

    const form = document.getElementById('apply-form') as HTMLFormElement | null;
    const submit = document.getElementById('apply-submit') as HTMLButtonElement | null;
    const msg = document.getElementById('apply-msg') as HTMLDivElement | null;
    const success = document.getElementById('apply-success') as HTMLDivElement | null;
    const stepper = document.getElementById('apply-stepper') as HTMLDivElement | null;
    if (!form || !submit || !msg) return;

    // ─── Step navigation ───
    let currentStep = 1;
    function showStep(n: number) {
      currentStep = n;
      document.querySelectorAll('.pt-step').forEach(s => s.classList.toggle('is-active', Number((s as HTMLElement).dataset.step) === n));
      stepper?.querySelectorAll('.pt-stepper-item').forEach(it => {
        const sn = Number((it as HTMLElement).dataset.step);
        it.classList.toggle('is-active', sn === n);
        it.classList.toggle('is-done', sn < n);
      });
      if (n === 3) initSignature();
      const sec = document.getElementById('aplicar');
      if (sec) sec.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    document.querySelectorAll('[data-go-step]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const target = Number((btn as HTMLElement).dataset.goStep);
        // Validate forward navigation
        if (target > currentStep) {
          if (currentStep === 1 && !validateStep1()) return;
          if (currentStep === 2 && !validateStep2()) return;
        }
        showStep(target);
        saveDraft();
      });
    });

    function val(id: string) { const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null; return el ? el.value.trim() : ''; }
    function setError(id: string, isErr: boolean) {
      const el = document.getElementById(id);
      if (el) el.classList.toggle('is-error', isErr);
    }
    function showMsg(text: string, isErr = false) {
      msg.innerHTML = text;
      msg.className = isErr ? 'pt-form-msg is-error' : 'pt-form-msg';
      msg.hidden = false;
    }

    function isValidEmail(s: string) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(s); }
    function isValidWhats(s: string) { const d = s.replace(/\D/g, ''); return d.length >= 10 && d.length <= 13; }

    function validateStep1(): boolean {
      const nombre = val('apply-nombre'); const email = val('apply-email'); const wa = val('apply-whatsapp');
      let ok = true;
      setError('apply-nombre', !nombre); if (!nombre) ok = false;
      setError('apply-email', !isValidEmail(email)); if (!isValidEmail(email)) ok = false;
      setError('apply-whatsapp', !isValidWhats(wa)); if (!isValidWhats(wa)) ok = false;
      if (!ok) showMsg('Llena los campos requeridos correctamente. WhatsApp debe tener 10 dígitos.', true);
      else { msg.hidden = true; }
      return ok;
    }

    function validateStep2(): boolean {
      // No fields are required in step 2 — but URL must be valid if present
      const w = val('apply-website');
      if (w && !/^(https?:\/\/)?[\w.-]+\.[a-z]{2,}(\S*)?$/i.test(w)) {
        setError('apply-website', true);
        showMsg('La URL del sitio web no parece válida.', true);
        return false;
      }
      setError('apply-website', false);
      msg.hidden = true;
      return true;
    }

    // ─── Social handles + live earnings calc ───
    function getSocials() {
      const rows: any[] = [];
      document.querySelectorAll('.pt-social-row').forEach(row => {
        const platform = (row as HTMLElement).dataset.platform || '';
        const handleEl = row.querySelector('[data-field="handle"]') as HTMLInputElement;
        const followersEl = row.querySelector('[data-field="followers"]') as HTMLInputElement;
        const handle = handleEl?.value.trim() || '';
        const followers = Number(followersEl?.value) || 0;
        if (handle || followers) rows.push({ platform, handle, followers });
      });
      return rows;
    }

    function updateFollowersUI() {
      const socials = getSocials();
      const total = socials.reduce((s, r) => s + (r.followers || 0), 0);
      const totalEl = document.getElementById('apply-followers-total');
      if (totalEl) totalEl.textContent = total.toLocaleString('es-MX');
      // Live earnings estimate: assume 0.5% conversion to prueba_gratis = $250 each
      const est = document.getElementById('apply-earnings-est');
      if (est && total > 0) {
        const trials = Math.round(total * 0.005);
        const earningsLow = trials * 250;
        const earningsHigh = trials * 250 * 3; // also includes some demos + 1 venta
        est.textContent = trials > 0 ? `≈ $${earningsLow.toLocaleString('es-MX')}–$${earningsHigh.toLocaleString('es-MX')} MXN/mes potencial` : '';
      } else if (est) {
        est.textContent = '';
      }
    }
    document.querySelectorAll('.pt-social-followers, .pt-social-handle').forEach(el => {
      el.addEventListener('input', () => { updateFollowersUI(); saveDraft(); });
    });

    // ─── Motivo char count ───
    const motivoEl = document.getElementById('apply-motivo') as HTMLTextAreaElement | null;
    const motivoCount = document.getElementById('apply-motivo-count');
    motivoEl?.addEventListener('input', () => {
      if (motivoCount) motivoCount.textContent = `${motivoEl.value.length} / 1500`;
      saveDraft();
    });

    // ─── Signature canvas ───
    let canvas: HTMLCanvasElement | null = null;
    let ctx: CanvasRenderingContext2D | null = null;
    let signatureInited = false;
    let hasDrawn = false;
    function initSignature() {
      canvas = document.getElementById('apply-canvas') as HTMLCanvasElement | null;
      if (!canvas) return;
      const rect = canvas.getBoundingClientRect();
      if (rect.width === 0) return;
      const dpr = window.devicePixelRatio || 1;
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      ctx = canvas.getContext('2d');
      if (!ctx) return;
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.scale(dpr, dpr);
      ctx.lineWidth = 2.2;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.strokeStyle = '#1a1a1a';
      if (signatureInited) return;
      signatureInited = true;

      let drawing = false;
      function getPos(e: MouseEvent | TouchEvent) {
        const r = canvas!.getBoundingClientRect();
        const t = (e as TouchEvent).touches ? (e as TouchEvent).touches[0] : (e as MouseEvent);
        return { x: t.clientX - r.left, y: t.clientY - r.top };
      }
      function start(e: MouseEvent | TouchEvent) { drawing = true; const p = getPos(e); ctx!.beginPath(); ctx!.moveTo(p.x, p.y); if (e.cancelable) e.preventDefault(); }
      function move(e: MouseEvent | TouchEvent) { if (!drawing) return; const p = getPos(e); ctx!.lineTo(p.x, p.y); ctx!.stroke(); hasDrawn = true; if (e.cancelable) e.preventDefault(); }
      function end() { drawing = false; }
      canvas.addEventListener('mousedown', start);
      canvas.addEventListener('mousemove', move);
      canvas.addEventListener('mouseup', end);
      canvas.addEventListener('mouseleave', end);
      canvas.addEventListener('touchstart', start, { passive: false });
      canvas.addEventListener('touchmove', move, { passive: false });
      canvas.addEventListener('touchend', end);

      document.getElementById('apply-canvas-clear')?.addEventListener('click', () => {
        if (canvas && ctx) { ctx.clearRect(0, 0, canvas.width, canvas.height); hasDrawn = false; }
      });
    }

    // ─── Auto-save draft to localStorage ───
    function saveDraft() {
      const draft: any = {
        step: currentStep,
        nombre: val('apply-nombre'),
        email: val('apply-email'),
        whatsapp: val('apply-whatsapp'),
        empresa: val('apply-empresa'),
        tipo: val('apply-tipo'),
        ciudad: val('apply-ciudad'),
        website: val('apply-website'),
        social: getSocials(),
        experiencia: val('apply-experiencia'),
        como: val('apply-como'),
        motivo: val('apply-motivo'),
        savedAt: Date.now(),
      };
      try { localStorage.setItem(DRAFT_KEY, JSON.stringify(draft)); } catch {}
    }
    function clearDraft() { try { localStorage.removeItem(DRAFT_KEY); } catch {} }
    function restoreDraft(d: any) {
      if (d.nombre) (document.getElementById('apply-nombre') as HTMLInputElement).value = d.nombre;
      if (d.email) (document.getElementById('apply-email') as HTMLInputElement).value = d.email;
      if (d.whatsapp) (document.getElementById('apply-whatsapp') as HTMLInputElement).value = d.whatsapp;
      if (d.empresa) (document.getElementById('apply-empresa') as HTMLInputElement).value = d.empresa;
      if (d.tipo) (document.getElementById('apply-tipo') as HTMLSelectElement).value = d.tipo;
      if (d.ciudad) (document.getElementById('apply-ciudad') as HTMLInputElement).value = d.ciudad;
      if (d.website) (document.getElementById('apply-website') as HTMLInputElement).value = d.website;
      if (d.experiencia) (document.getElementById('apply-experiencia') as HTMLSelectElement).value = d.experiencia;
      if (d.como) (document.getElementById('apply-como') as HTMLSelectElement).value = d.como;
      if (d.motivo) {
        (document.getElementById('apply-motivo') as HTMLTextAreaElement).value = d.motivo;
        if (motivoCount) motivoCount.textContent = `${d.motivo.length} / 1500`;
      }
      if (Array.isArray(d.social)) {
        document.querySelectorAll('.pt-social-row').forEach(row => {
          const platform = (row as HTMLElement).dataset.platform;
          const found = d.social.find((s: any) => s.platform === platform);
          if (found) {
            const h = row.querySelector('[data-field="handle"]') as HTMLInputElement;
            const f = row.querySelector('[data-field="followers"]') as HTMLInputElement;
            if (h && found.handle) h.value = found.handle;
            if (f && found.followers) f.value = String(found.followers);
          }
        });
      }
      updateFollowersUI();
      // Don't auto-jump to step beyond 1 (privacy: motivo + signature need active intent)
      showStep(Math.min(d.step || 1, 2));
    }

    // Inputs save on change (debounced)
    let saveTimer: any;
    document.querySelectorAll('#apply-form input, #apply-form select, #apply-form textarea').forEach(el => {
      el.addEventListener('input', () => {
        clearTimeout(saveTimer);
        saveTimer = setTimeout(saveDraft, 600);
      });
    });

    // Pre-fill tipo from hash
    (function() {
      const m = (window.location.hash || '').match(/tipo=([a-z]+)/i);
      if (m) {
        const select = document.getElementById('apply-tipo') as HTMLSelectElement;
        if (select) select.value = m[1].toLowerCase();
      }
    })();

    // Check for existing draft
    try {
      const raw = localStorage.getItem(DRAFT_KEY);
      if (raw) {
        const d = JSON.parse(raw);
        const ageHours = (Date.now() - (d.savedAt || 0)) / 36e5;
        if (d.nombre && ageHours < 168) { // 7 días
          const prompt = document.getElementById('apply-draft-prompt');
          if (prompt) prompt.hidden = false;
          document.getElementById('apply-draft-restore')?.addEventListener('click', () => {
            restoreDraft(d);
            if (prompt) prompt.hidden = true;
          });
          document.getElementById('apply-draft-discard')?.addEventListener('click', () => {
            clearDraft();
            if (prompt) prompt.hidden = true;
          });
        }
      }
    } catch {}

    // ─── Submit ───
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Final validation
      if (!validateStep1()) { showStep(1); return; }
      const motivo = val('apply-motivo');
      if (motivo.length < 30) {
        showMsg('Cuéntanos por qué te interesa SACS (mínimo 30 caracteres)', true);
        setError('apply-motivo', true);
        return;
      }
      const acepta = (document.getElementById('apply-acepta') as HTMLInputElement)?.checked;
      if (!acepta) {
        showMsg('Debes aceptar los términos del programa para enviar tu solicitud.', true);
        return;
      }
      if (!hasDrawn || !canvas) {
        showMsg('Firma con tu dedo o mouse antes de enviar.', true);
        return;
      }

      const firma_base64 = canvas.toDataURL('image/png');

      const payload = {
        nombre: val('apply-nombre'),
        email: val('apply-email'),
        whatsapp: val('apply-whatsapp'),
        empresa: val('apply-empresa'),
        tipo: val('apply-tipo'),
        ciudad: val('apply-ciudad'),
        website: val('apply-website'),
        social: getSocials(),
        audiencia_total: getSocials().reduce((s, r) => s + (r.followers || 0), 0),
        experiencia_retail: val('apply-experiencia'),
        como_supo: val('apply-como'),
        motivo,
        acepta_terminos: true,
        firma_base64,
        _bot_field: (document.getElementById('apply-bot') as HTMLInputElement)?.value || '',
      };

      submit.disabled = true;
      submit.textContent = 'Enviando…';
      msg.hidden = true;

      try {
        const res = await fetch('/api/partners/apply', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Error');

        clearDraft();
        // Show success state, hide form
        if (success) {
          (document.getElementById('apply-success-name')!).textContent = (val('apply-nombre').split(' ')[0]) || '';
          (document.getElementById('apply-success-folio')!).textContent = data.numero || 'PA-XXX';
          form.style.display = 'none';
          stepper && (stepper.style.display = 'none');
          success.hidden = false;
          success.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      } catch (err: any) {
        showMsg(`No se pudo enviar: ${err.message || err}. Intenta de nuevo o escríbenos a partners@sacscloud.com.`, true);
        submit.disabled = false;
        submit.textContent = 'Reintentar firma y envío';
      }
    });

    // Auto-format WhatsApp as user types (MX format: 55 1234 5678)
    const waEl = document.getElementById('apply-whatsapp') as HTMLInputElement | null;
    waEl?.addEventListener('input', () => {
      const d = waEl.value.replace(/\D/g, '').slice(0, 13);
      let formatted = d;
      if (d.length > 6) formatted = `${d.slice(0, 2)} ${d.slice(2, 6)} ${d.slice(6)}`;
      else if (d.length > 2) formatted = `${d.slice(0, 2)} ${d.slice(2)}`;
      if (waEl.value !== formatted) waEl.value = formatted;
    });

    // Re-init signature on resize
    window.addEventListener('resize', () => {
      if (currentStep === 3) requestAnimationFrame(initSignature);
    });
  })();
</script>
