---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;

// ─── Brand kit data ───
const COLORS = [
  { name: 'Azul SACS',      hex: '#4B7BE5', usage: 'Primario · CTAs, links, acento principal' },
  { name: 'Verde Consciente', hex: '#2AB5A0', usage: 'Acento · checks, éxito, comercio consciente' },
  { name: 'Tinta',          hex: '#1A1A1A', usage: 'Tipografía y backgrounds dark' },
  { name: 'Papel',          hex: '#FAFAF8', usage: 'Fondo principal claro' },
  { name: 'Morado AXO',     hex: '#6C5CE7', usage: 'AXO copiloto IA · features de inteligencia' },
  { name: 'Mostaza',        hex: '#E8A838', usage: 'Acento secundario · realce, badges' },
  { name: 'Rojo Alerta',    hex: '#E54B4B', usage: 'Solo errores, alertas, problemas' },
  { name: 'Gris UI',        hex: '#999999', usage: 'Textos secundarios, labels, hints' },
];

const FONTS = [
  {
    name: 'Clash Display',
    use: 'Display · headlines · números grandes',
    weights: '300 · 400 · 500 · 600 · 700',
    download: 'https://www.fontshare.com/fonts/clash-display',
    sample: 'Vende bien, hace el bien.',
    family: "'Clash Display', 'Plus Jakarta Sans', system-ui, sans-serif",
    isDisplay: true,
  },
  {
    name: 'Plus Jakarta Sans',
    use: 'Body · párrafos · UI · captions',
    weights: '300 · 400 · 500 · 600 · 700 · 800',
    download: 'https://fonts.google.com/specimen/Plus+Jakarta+Sans',
    sample: 'Sistema operativo para retailers que creen que vender bien y hacer el bien pueden ir de la mano.',
    family: "'Plus Jakarta Sans', system-ui, sans-serif",
    isDisplay: false,
  },
];

const VOICE_DOS = [
  { title: 'Directos y cálidos', detail: 'Habla como hablarías con un amigo dueño de tienda. Sin jerga corporativa.' },
  { title: 'Optimistas pero realistas', detail: 'Mostramos resultados con contexto. Si algo cuesta, lo decimos.' },
  { title: 'Específicos', detail: 'Menciona números, marcas, casos. "+45% en lifetime value" mejor que "más ventas".' },
  { title: 'Comercio consciente', detail: 'Vender bien y hacer el bien sí pueden ir de la mano. Es nuestro norte.' },
];

const VOICE_DONTS = [
  { title: 'Pegarle a competidores', detail: 'Nunca menciones marcas competidoras de forma despectiva.' },
  { title: 'Promesas exageradas', detail: 'Nada de "el mejor", "100% garantizado", "el único". Resultados con números reales.' },
  { title: 'Tono corporativo', detail: 'Evita "soluciones de clase mundial", "líderes de la industria", "ecosistema integral".' },
  { title: 'Lenguaje agresivo', detail: 'Vendemos por valor, no por miedo. Cero "no te quedes atrás" o similar.' },
];

const CAPTIONS = [
  {
    platform: 'Instagram / Reels',
    text: `Llevo X meses operando mi tienda con SACS y esto cambió 👇

Antes: ventas en cuadernos, inventario por WhatsApp, reportes que no cuadraban.

Ahora: punto de venta + inventario + facturación + tienda en línea, todo en un solo sistema.

¿Lo mejor? Lo construyeron en México pensando en negocios como el mío.

Link en mi bio para que lo pruebes 🇲🇽

#SACScloud #ComercioConsciente #RetailMexicano`,
  },
  {
    platform: 'TikTok',
    text: `POV: por fin encontraste el sistema para tu tienda 🛍️

✅ Punto de venta
✅ Inventario en tiempo real
✅ Facturación
✅ Tienda en línea sincronizada

Todo en uno · hecho en México · sin complicaciones.

Link en mi bio · soy embajador @sacscloud

#RetailTok #SACScloud #PymeMexicana`,
  },
  {
    platform: 'LinkedIn',
    text: `Si manejas un retail en México y todavía operas con Excel + un POS genérico, esto te interesa.

Llevo X tiempo trabajando con SACS — el sistema operativo para retailers mexicanos. Lo que más me ha convencido:

→ Construido para México (no es traducción)
→ Multi-sucursal de verdad (no parches)
→ El 10% de cada licencia financia programas de comercio consciente

Si te interesa platicar cómo lo estoy implementando, escríbeme. Soy embajador SACS.

#SACScloud #ComercioConsciente`,
  },
];

const HASHTAGS = [
  '#SACScloud',
  '#ComercioConsciente',
  '#RetailMexicano',
  '#PymeMexicana',
  '#SistemaOperativoRetail',
];

const DISCLOSURE = `Soy embajador SACS · sacscloud.com/p/<tu-slug>`;

const CONTENT_PLAN = {
  mes: 'Mayo 2026',
  tema: 'Inventario en tiempo real entre sucursales',
  palabrasClave: [
    'inventario multi-sucursal',
    'traspasos entre tiendas',
    'kardex digital',
    'mermas y trazabilidad',
    'reabasto inteligente',
  ],
  videos: [
    {
      titulo: 'El traspaso que se perdió',
      angulo: 'Storytelling: cuenta una vez que perdiste mercancía por un traspaso por WhatsApp y cómo ahora lo evitas con SACS.',
      duracion: '60-90 seg',
    },
    {
      titulo: 'Tour del inventario en SACS',
      angulo: 'Pantalla compartida: muestra el panel de inventario multi-sucursal en vivo. Enseña cómo ves stock por tienda.',
      duracion: '90-120 seg',
    },
    {
      titulo: 'Antes vs Ahora · conteo físico',
      angulo: 'Comparativa: antes contabas con papel y tomaba 3 días. Ahora con el celular y SACS termina en horas.',
      duracion: '45-60 seg',
    },
    {
      titulo: 'Una pregunta que te van a hacer',
      angulo: '“¿Por qué SACS y no otro?” — responde en 60 segundos con tu razón personal + 1 dato concreto.',
      duracion: '60 seg',
    },
  ],
};

const VERTICALS = [
  {
    id: 'moda',
    nombre: 'Moda y boutiques',
    icon: '👗',
    pains: ['Stock entre talla / color', 'Devoluciones', 'Temporada que cambia', 'Influencer marketing'],
    angulos: [
      'Tour de cómo SACS maneja variantes (talla×color×material) sin caos',
      '"Devolución sin drama": muestra el flujo de cambio en 30 segundos',
      'Comparativa: tu sistema viejo vs SACS para cierre de mes',
      'Cómo mides ROI de campaña con influencer (link unique → ventas)',
    ],
    hashtags: ['#ModaMexicana', '#BoutiqueMx', '#RetailFashion'],
  },
  {
    id: 'farmacia',
    nombre: 'Farmacias',
    icon: '💊',
    pains: ['Caducidades', 'Recetas', 'Medicamento controlado', 'Precios IEPS'],
    angulos: [
      'Alerta de caducidad antes que CONAMED te alcance',
      'Cómo SACS automatiza el reporte de medicamento controlado',
      'Receta digital + historial del paciente en 1 pantalla',
      'Reabasto predictivo: SACS te dice qué pedir',
    ],
    hashtags: ['#FarmaciasMx', '#PymeFarmaceutica'],
  },
  {
    id: 'restaurantes',
    nombre: 'Restaurantes',
    icon: '🍽️',
    pains: ['Mesa abierta', 'Cocina vs caja', 'Mermas', 'Comandas confusas'],
    angulos: [
      'Comanda de cocina sin papel: muestra el flujo end-to-end',
      'Cierre de turno en 5 min vs 1 hora con caja a mano',
      'Receta + costo + merma: el cálculo que te ahorra el mes',
      'POS + delivery (Rappi/Uber) en una sola pantalla',
    ],
    hashtags: ['#RestaurantesMx', '#FoodservMx', '#GastronomiaMx'],
  },
  {
    id: 'ferreteria',
    nombre: 'Ferreterías',
    icon: '🔧',
    pains: ['Catálogo enorme', 'Ventas a contratistas', 'Crédito', 'Multimarca'],
    angulos: [
      'Buscar tornillos por código en 2 segundos, no 5 minutos',
      'Línea de crédito por cliente: cómo lo manejas sin perderte',
      'Proveedor te subió 8% — cómo actualizas 2,000 SKUs sin volverte loco',
      'Mostrador físico + e-commerce mostrando el mismo stock',
    ],
    hashtags: ['#FerreteriasMx', '#PymeMexicana'],
  },
  {
    id: 'belleza',
    nombre: 'Salones y barberías',
    icon: '💇',
    pains: ['Citas', 'Servicios + retail', 'Comisiones a estilistas', 'Programa de lealtad'],
    angulos: [
      'Agenda + venta de productos + comisiones en una app',
      'Cliente que recomienda → puntos automáticos. Programa que vende',
      'Reporte por estilista: quién factura más, qué servicios',
      'Recordatorio de cita por WhatsApp = -40% no-shows',
    ],
    hashtags: ['#SalonesMx', '#BarberiaMx'],
  },
  {
    id: 'abarrotes',
    nombre: 'Abarrotes y minisúper',
    icon: '🛒',
    pains: ['Margen apretado', 'Robos / mermas', 'Proveedores múltiples', 'Báscula + caja'],
    angulos: [
      'Margen real por producto: cuál te da $ y cuál no',
      'Conteo físico nocturno: detecta merma antes que tú',
      'Recibo CFDI 4.0 sin tener que aprender de fiscal',
      'Crédito a vecinos sin libreta: SACS lleva la cuenta',
    ],
    hashtags: ['#AbarrotesMx', '#MinisúperMx'],
  },
];

const SECTIONS = [
  { id: 'logos', label: 'Logos' },
  { id: 'tipografia', label: 'Tipografía' },
  { id: 'colores', label: 'Colores' },
  { id: 'voz', label: 'Voz y tono' },
  { id: 'captions', label: 'Captions' },
  { id: 'verticales', label: 'Ideas por vertical' },
  { id: 'plan', label: 'Plan del mes' },
  { id: 'reglas', label: 'Reglas' },
];
---

<BaseLayout
  title="Brand Kit Embajadores · SACS"
  description="Manual de marca, logos, tipografías, voz, captions y plan de contenido para embajadores SACS."
  noindex={true}
>

<div class="bk-page" id="brand-kit">

  <!-- Hero -->
  <section class="bk-hero">
    <div class="bk-container">
      <div class="bk-hero-eyebrow">Programa Embajador SACS</div>
      <h1 class="bk-hero-title">Brand kit para representar SACS<br/><span class="bk-hero-title-soft">con coherencia</span>.</h1>
      <p class="bk-hero-sub">
        Todo lo que necesitas: logos, tipografías, paleta, voz, captions listos para usar y el plan de contenido del mes. Cumplir el manual no es burocracia — es lo que hace que tu contenido se vea profesional y la marca crezca contigo.
      </p>
      <div class="bk-hero-cta-row">
        <a href="/brand/sacs-logo-full-dark.svg" download class="bk-btn bk-btn--primary">Descargar logo principal</a>
        <a href="#logos" class="bk-btn bk-btn--ghost">Ver brand kit completo ↓</a>
      </div>
    </div>
  </section>

  <!-- Sticky anchor nav -->
  <nav class="bk-sticky-nav" aria-label="Secciones">
    <div class="bk-container bk-sticky-inner">
      <div class="bk-sticky-brand">Brand kit · Embajadores</div>
      <div class="bk-sticky-links">
        {SECTIONS.map(s => (
          <a href={`#${s.id}`} class="bk-sticky-link">{s.label}</a>
        ))}
      </div>
    </div>
  </nav>

  <!-- ════════════════════════════════════════
       LOGOS
       ════════════════════════════════════════ -->
  <section class="bk-section" id="logos">
    <div class="bk-container">
      <div class="bk-section-head">
        <div class="bk-section-eyebrow">01 · Logos</div>
        <h2 class="bk-section-title">El logo de SACS</h2>
        <p class="bk-section-lead">
          Tres versiones para cubrir cualquier soporte. Descarga la que mejor contraste tenga con tu fondo. Nunca lo deformes, recolorees ni le agregues efectos.
        </p>
      </div>

      <div class="bk-logo-grid">
        <div class="bk-logo-card bk-logo-card--light">
          <div class="bk-logo-preview">
            <svg width="120" height="120" viewBox="0 0 56 56" fill="none">
              <rect width="56" height="56" rx="12" fill="#1a1a1a"/>
              <circle cx="21" cy="28" r="8" fill="#4B7BE5" opacity="0.9"/>
              <circle cx="32" cy="23" r="8" fill="#E8A838" opacity="0.85"/>
              <circle cx="34" cy="30" r="8" fill="#2AB5A0" opacity="0.85"/>
            </svg>
          </div>
          <div class="bk-logo-meta">
            <div class="bk-logo-name">Isotipo · oscuro</div>
            <div class="bk-logo-detail">Para fondos claros. Tres círculos representando producto + datos + comunidad.</div>
            <a href="/brand/sacs-icon-dark.svg" download class="bk-logo-dl">Descargar SVG</a>
          </div>
        </div>

        <div class="bk-logo-card bk-logo-card--dark">
          <div class="bk-logo-preview">
            <svg width="120" height="120" viewBox="0 0 56 56" fill="none">
              <rect width="56" height="56" rx="12" fill="#FAFAF8" stroke="#e5e5e5" stroke-width="1"/>
              <circle cx="21" cy="28" r="8" fill="#4B7BE5" opacity="0.9"/>
              <circle cx="32" cy="23" r="8" fill="#E8A838" opacity="0.85"/>
              <circle cx="34" cy="30" r="8" fill="#2AB5A0" opacity="0.85"/>
            </svg>
          </div>
          <div class="bk-logo-meta">
            <div class="bk-logo-name">Isotipo · claro</div>
            <div class="bk-logo-detail">Para fondos oscuros. Misma composición con base papel.</div>
            <a href="/brand/sacs-icon-light.svg" download class="bk-logo-dl">Descargar SVG</a>
          </div>
        </div>

        <div class="bk-logo-card bk-logo-card--light">
          <div class="bk-logo-preview">
            <span class="bk-wordmark bk-wordmark--dark">Sacs</span>
          </div>
          <div class="bk-logo-meta">
            <div class="bk-logo-name">Wordmark · oscuro</div>
            <div class="bk-logo-detail">El nombre completo. Úsalo cuando el isotipo no se entienda solo.</div>
            <a href="/brand/sacs-wordmark-dark.svg" download class="bk-logo-dl">Descargar SVG</a>
          </div>
        </div>

        <div class="bk-logo-card bk-logo-card--dark">
          <div class="bk-logo-preview">
            <span class="bk-wordmark bk-wordmark--light">Sacs</span>
          </div>
          <div class="bk-logo-meta">
            <div class="bk-logo-name">Wordmark · claro</div>
            <div class="bk-logo-detail">Para fondos oscuros, video y press kit en negro.</div>
            <a href="/brand/sacs-wordmark-light.svg" download class="bk-logo-dl">Descargar SVG</a>
          </div>
        </div>

        <div class="bk-logo-card bk-logo-card--light bk-logo-card--full">
          <div class="bk-logo-preview">
            <div class="bk-logo-full-row">
              <svg width="64" height="64" viewBox="0 0 56 56" fill="none">
                <rect width="56" height="56" rx="14" fill="#1a1a1a"/>
                <circle cx="21" cy="28" r="8" fill="#4B7BE5" opacity="0.9"/>
                <circle cx="32" cy="23" r="8" fill="#E8A838" opacity="0.85"/>
                <circle cx="34" cy="30" r="8" fill="#2AB5A0" opacity="0.85"/>
              </svg>
              <span class="bk-wordmark bk-wordmark--dark" style="font-size:3rem">Sacs</span>
            </div>
          </div>
          <div class="bk-logo-meta">
            <div class="bk-logo-name">Logo completo · isotipo + wordmark</div>
            <div class="bk-logo-detail">Cuando tienes espacio y necesitas la versión más reconocible.</div>
            <a href="/brand/sacs-logo-full-dark.svg" download class="bk-logo-dl">Descargar SVG</a>
          </div>
        </div>
      </div>

      <div class="bk-rules-grid">
        <div class="bk-rule">
          <div class="bk-rule-eyebrow">Tamaño mínimo</div>
          <div class="bk-rule-detail">Isotipo nunca menor a <strong>32px</strong> de altura. Wordmark nunca menor a <strong>24px</strong>.</div>
        </div>
        <div class="bk-rule">
          <div class="bk-rule-eyebrow">Área de protección</div>
          <div class="bk-rule-detail">Deja al menos la altura de la "S" como margen libre alrededor del logo.</div>
        </div>
        <div class="bk-rule">
          <div class="bk-rule-eyebrow">Color y contraste</div>
          <div class="bk-rule-detail">Usa la versión oscura sobre claros y la clara sobre oscuros. Nunca apliques sombras o gradientes al logo.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       TIPOGRAFÍA
       ════════════════════════════════════════ -->
  <section class="bk-section bk-section--alt" id="tipografia">
    <div class="bk-container">
      <div class="bk-section-head">
        <div class="bk-section-eyebrow">02 · Tipografía</div>
        <h2 class="bk-section-title">Dos familias, jerarquía clara</h2>
        <p class="bk-section-lead">
          Clash Display da la voz a los headlines y números. Plus Jakarta Sans hace el trabajo silencioso del cuerpo y la UI. Combinarlas correctamente es 80% del look.
        </p>
      </div>

      <div class="bk-fonts-grid">
        {FONTS.map(f => (
          <div class="bk-font-card">
            <div class="bk-font-meta">
              <div class="bk-font-name">{f.name}</div>
              <div class="bk-font-use">{f.use}</div>
              <div class="bk-font-weights"><span>Pesos</span> {f.weights}</div>
              <a href={f.download} target="_blank" rel="noopener" class="bk-font-dl">Descargar →</a>
            </div>
            <div class={`bk-font-sample ${f.isDisplay ? 'bk-font-sample--display' : ''}`} style={`font-family:${f.family}`}>
              {f.sample}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       COLORES
       ════════════════════════════════════════ -->
  <section class="bk-section" id="colores">
    <div class="bk-container">
      <div class="bk-section-head">
        <div class="bk-section-eyebrow">03 · Colores</div>
        <h2 class="bk-section-title">Paleta oficial</h2>
        <p class="bk-section-lead">
          Click en cualquier color para copiar el HEX. Usa azul SACS y verde consciente como acentos principales; el resto solo cuando aplique.
        </p>
      </div>

      <div class="bk-colors-grid">
        {COLORS.map(c => (
          <button type="button" class="bk-color-tile" data-hex={c.hex} aria-label={`Copiar ${c.hex}`}>
            <div class="bk-color-swatch" style={`background:${c.hex}`}></div>
            <div class="bk-color-meta">
              <div class="bk-color-name">{c.name}</div>
              <div class="bk-color-hex">{c.hex}</div>
              <div class="bk-color-usage">{c.usage}</div>
            </div>
            <span class="bk-color-copy">Copiar</span>
            <span class="bk-color-copied">¡Copiado!</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       VOZ Y TONO
       ════════════════════════════════════════ -->
  <section class="bk-section bk-section--alt" id="voz">
    <div class="bk-container">
      <div class="bk-section-head">
        <div class="bk-section-eyebrow">04 · Voz y tono</div>
        <h2 class="bk-section-title">Cómo hablamos de SACS</h2>
        <p class="bk-section-lead">
          La forma en que escribes importa tanto como qué escribes. Esta es la voz de SACS: directa, cálida, mexicana, optimista pero realista.
        </p>
      </div>

      <div class="bk-voice-grid">
        <div class="bk-voice-col">
          <div class="bk-voice-col-head bk-voice-col-head--do">
            <span class="bk-voice-col-icon">✓</span>
            <span class="bk-voice-col-title">Hazlo así</span>
          </div>
          {VOICE_DOS.map(item => (
            <div class="bk-voice-item">
              <div class="bk-voice-item-title">{item.title}</div>
              <div class="bk-voice-item-detail">{item.detail}</div>
            </div>
          ))}
        </div>
        <div class="bk-voice-col">
          <div class="bk-voice-col-head bk-voice-col-head--dont">
            <span class="bk-voice-col-icon">✕</span>
            <span class="bk-voice-col-title">Evita esto</span>
          </div>
          {VOICE_DONTS.map(item => (
            <div class="bk-voice-item">
              <div class="bk-voice-item-title">{item.title}</div>
              <div class="bk-voice-item-detail">{item.detail}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       CAPTIONS
       ════════════════════════════════════════ -->
  <section class="bk-section" id="captions">
    <div class="bk-container">
      <div class="bk-section-head">
        <div class="bk-section-eyebrow">05 · Captions y hashtags</div>
        <h2 class="bk-section-title">Plantillas listas para usar</h2>
        <p class="bk-section-lead">
          Adapta estas captions con tu experiencia personal. Reemplaza los placeholders y publica. Usa los hashtags oficiales y siempre incluye el disclosure.
        </p>
      </div>

      <div class="bk-captions">
        {CAPTIONS.map(c => (
          <div class="bk-caption-card">
            <div class="bk-caption-head">
              <div class="bk-caption-platform">{c.platform}</div>
              <button type="button" class="bk-copy-btn" data-target="caption">Copiar</button>
            </div>
            <pre class="bk-caption-text bk-copy-text">{c.text}</pre>
          </div>
        ))}
      </div>

      <div class="bk-tags-row">
        <div class="bk-tags-block">
          <div class="bk-tags-label">Hashtags oficiales</div>
          <div class="bk-tags-list">
            {HASHTAGS.map(h => (
              <button type="button" class="bk-tag" data-hex={h}>{h}</button>
            ))}
          </div>
        </div>
        <div class="bk-tags-block">
          <div class="bk-tags-label">Disclosure obligatorio</div>
          <div class="bk-disclosure">
            <code>{DISCLOSURE}</code>
            <button type="button" class="bk-tag" data-hex={DISCLOSURE}>Copiar</button>
          </div>
          <div class="bk-tags-hint">Reemplaza <code>&lt;tu-slug&gt;</code> con el slug de tu landing personalizada.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       IDEAS POR VERTICAL
       ════════════════════════════════════════ -->
  <section class="bk-section bk-section--alt" id="verticales">
    <div class="bk-container">
      <div class="bk-section-head">
        <div class="bk-section-eyebrow">06 · Ideas por vertical</div>
        <h2 class="bk-section-title">Contenido específico por giro</h2>
        <p class="bk-section-lead">
          Cada vertical tiene sus propios pains. Habla de lo que le duele a tu audiencia.
          Estos son ángulos probados que conectan rápido por giro.
        </p>
      </div>

      <div class="bk-vert-grid">
        {VERTICALS.map(v => (
          <div class="bk-vert-card">
            <div class="bk-vert-head">
              <span class="bk-vert-icon" aria-hidden="true">{v.icon}</span>
