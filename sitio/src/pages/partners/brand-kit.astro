<script is:inline>
(function() {
  // ─── Click-to-copy: color tiles ───
  document.querySelectorAll('.bk-color-tile').forEach(tile => {
    tile.addEventListener('click', () => {
      const hex = tile.dataset.hex || '';
      navigator.clipboard.writeText(hex).then(() => {
        tile.classList.add('is-copied');
        setTimeout(() => tile.classList.remove('is-copied'), 1400);
      });
    });
  });

  // ─── Click-to-copy: tags / disclosure ───
  document.querySelectorAll('.bk-tag').forEach(tag => {
    tag.addEventListener('click', () => {
      const text = tag.dataset.hex || tag.textContent;
      navigator.clipboard.writeText(text).then(() => {
        const orig = tag.textContent;
        tag.classList.add('is-copied');
        tag.textContent = '¡Copiado!';
        setTimeout(() => {
          tag.classList.remove('is-copied');
          tag.textContent = orig;
        }, 1200);
      });
    });
  });

  // ─── Click-to-copy: caption text ───
  document.querySelectorAll('.bk-copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.bk-caption-card');
      if (!card) return;
      const text = card.querySelector('.bk-copy-text')?.textContent || '';
      navigator.clipboard.writeText(text).then(() => {
        const orig = btn.textContent;
        btn.classList.add('is-copied');
        btn.textContent = '¡Copiado!';
        setTimeout(() => {
          btn.classList.remove('is-copied');
          btn.textContent = orig;
        }, 1200);
      });
    });
  });
})();
</script>

</BaseLayout>
