  }
  .p-contract-head {
    border-bottom: 1px solid #f0f0ee;
    padding-bottom: 20px;
    margin-bottom: 24px;
  }
  .p-contract-eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 10px;
  }
  .p-contract-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: #1a1a1a;
