  .p-wall-foot {
    font-size: 0.875rem;
    color: #666;
    text-align: center;
    margin-top: 10px;
  }

  /* ─── Calculadora interactiva ───────────────────────── */
  .p-calc {
    margin: 28px 0;
    padding: 36px;
    background: linear-gradient(135deg, #1a1a1a 0%, #232337 100%);
    border-radius: 18px;
