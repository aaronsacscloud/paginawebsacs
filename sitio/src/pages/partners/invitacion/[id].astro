  'scen.cons':   { es: 'Conservador', en: 'Conservative', fr: 'Conservateur', it: 'Conservativo', pt: 'Conservador' },
  'scen.real':   { es: 'Realista',    en: 'Realistic',    fr: 'Réaliste',     it: 'Realistico',   pt: 'Realista' },
  'scen.amb':    { es: 'Ambicioso',   en: 'Ambitious',    fr: 'Ambitieux',    it: 'Ambizioso',    pt: 'Ambicioso' },
  'scen.cons.h': { es: '~5 horas/mes de difusión', en: '~5 hours/month of outreach', fr: '~5 heures/mois de diffusion', it: '~5 ore/mese di diffusione', pt: '~5 horas/mês de difusão' },
  'scen.real.h': { es: '~10 horas/mes de difusión', en: '~10 hours/month of outreach', fr: '~10 heures/mois de diffusion', it: '~10 ore/mese di diffusione', pt: '~10 horas/mês de difusão' },
  'scen.amb.h':  { es: 'Tiempo completo', en: 'Full time', fr: 'Temps plein', it: 'Tempo pieno', pt: 'Tempo integral' },

  // Process steps (6)
  'proc.s1.t': { es: 'Llena el formulario y firma', en: 'Fill out the form and sign', fr: 'Remplissez le formulaire et signez', it: 'Compila il modulo e firma', pt: 'Preencha o formulário e assine' },
  'proc.s1.d': { es: 'Datos personales, dirección del negocio, datos de cobro (CLABE, PayPal o Mercado Pago) y firma digital. Te toma <strong>~5 minutos</strong>. Una vez enviado, queda en revisión.', en: 'Personal info, business address, payment details (CLABE, PayPal or Mercado Pago) and digital signature. Takes <strong>~5 minutes</strong>. Once submitted, it goes to review.', fr: 'Données personnelles, adresse de l\'activité, infos de paiement (CLABE, PayPal ou Mercado Pago) et signature numérique. <strong>~5 minutes</strong>. Une fois soumis, c\'est en examen.', it: 'Dati personali, indirizzo dell\'attività, dati di pagamento (CLABE, PayPal o Mercado Pago) e firma digitale. Ci vogliono <strong>~5 minuti</strong>. Una volta inviato, va in revisione.', pt: 'Dados pessoais, endereço do negócio, dados de cobrança (CLABE, PayPal ou Mercado Pago) e assinatura digital. Leva <strong>~5 minutos</strong>. Após enviar, fica em revisão.' },
  'proc.s1.tag': { es: '~5 min', en: '~5 min', fr: '~5 min', it: '~5 min', pt: '~5 min' },
  'proc.s2.t': { es: 'Revisión por el equipo SACS', en: 'Review by the SACS team', fr: 'Examen par l\'équipe SACS', it: 'Revisione dal team SACS', pt: 'Revisão pela equipe SACS' },
  'proc.s2.d': { es: 'Validamos tus datos, confirmamos vigencia y comisión, y revisamos tu información de cobro. Si falta algo, te escribimos por correo. Tiempo de respuesta: <strong>3 a 5 días hábiles</strong>.', en: 'We validate your data, confirm validity and commission, and review your payment info. If something\'s missing, we email you. Response time: <strong>3 to 5 business days</strong>.', fr: 'Nous validons vos données, confirmons la validité et la commission, et examinons vos infos de paiement. S\'il manque quelque chose, nous vous écrivons. Délai : <strong>3 à 5 jours ouvrés</strong>.', it: 'Validiamo i tuoi dati, confermiamo validità e commissione, e revisioniamo i tuoi dati di pagamento. Se manca qualcosa, ti scriviamo. Tempo di risposta: <strong>3-5 giorni lavorativi</strong>.', pt: 'Validamos seus dados, confirmamos vigência e comissão, e revisamos seus dados de cobrança. Se faltar algo, te escrevemos por e-mail. Tempo de resposta: <strong>3 a 5 dias úteis</strong>.' },
  'proc.s2.tag': { es: '3–5 días hábiles', en: '3–5 business days', fr: '3–5 jours ouvrés', it: '3–5 giorni lavorativi', pt: '3–5 dias úteis' },
  'proc.s3.t': { es: 'Aprobación + tu link único', en: 'Approval + your unique link', fr: 'Approbation + votre lien unique', it: 'Approvazione + il tuo link unico', pt: 'Aprovação + seu link único' },
  'proc.s3.d': { es: 'Te enviamos por <strong>correo y WhatsApp</strong> tu código de partner, tu link único (ej. <code>sacscloud.com/p/tu-nombre</code>) y un link para crear tu contraseña del portal. Cualquier prospecto que llegue por tu link queda atribuido a ti automáticamente.', en: 'We send by <strong>email and WhatsApp</strong> your partner code, your unique link (e.g. <code>sacscloud.com/p/your-name</code>) and a link to create your portal password. Any prospect arriving via your link is attributed to you automatically.', fr: 'Nous envoyons par <strong>email et WhatsApp</strong> votre code partenaire, votre lien unique (ex. <code>sacscloud.com/p/votre-nom</code>) et un lien pour créer votre mot de passe portail. Tout prospect arrivant par votre lien vous est attribué automatiquement.', it: 'Ti inviamo via <strong>email e WhatsApp</strong> il tuo codice partner, il tuo link unico (es. <code>sacscloud.com/p/tuo-nome</code>) e un link per creare la password del portale. Ogni prospect che arriva dal tuo link viene attribuito a te automaticamente.', pt: 'Enviamos por <strong>e-mail e WhatsApp</strong> seu código de parceiro, seu link único (ex. <code>sacscloud.com/p/seu-nome</code>) e um link para criar sua senha do portal. Qualquer prospecto que chegar pelo seu link fica atribuído a você automaticamente.' },
  'proc.s3.tag': { es: 'Email + WhatsApp', en: 'Email + WhatsApp', fr: 'Email + WhatsApp', it: 'Email + WhatsApp', pt: 'E-mail + WhatsApp' },
  'proc.s4.t': { es: 'Tu panel personal de partner', en: 'Your personal partner panel', fr: 'Votre tableau de bord partenaire', it: 'Il tuo pannello partner personale', pt: 'Seu painel pessoal de parceiro' },
  'proc.s4.d': { es: 'Entras a tu portal con tu correo y contraseña — desde laptop, tablet o teléfono. Ves todo lo que está pasando con tu link en tiempo real: comisiones, pagos, prospectos, brand kit.', en: 'Sign into your portal with your email and password — from laptop, tablet or phone. See everything happening with your link in real time: commissions, payments, prospects, brand kit.', fr: 'Connectez-vous à votre portail avec email et mot de passe — depuis ordi, tablette ou téléphone. Voyez tout ce qui se passe avec votre lien en temps réel : commissions, paiements, prospects, kit de marque.', it: 'Accedi al tuo portale con email e password — da laptop, tablet o telefono. Vedi tutto ciò che succede con il tuo link in tempo reale: commissioni, pagamenti, prospect, brand kit.', pt: 'Entre no seu portal com seu e-mail e senha — do laptop, tablet ou celular. Veja tudo o que acontece com seu link em tempo real: comissões, pagamentos, prospectos, brand kit.' },
  'proc.s4.btn': { es: 'Ver preview del panel →', en: 'See panel preview →', fr: 'Voir l\'aperçu du tableau →', it: 'Vedi anteprima pannello →', pt: 'Ver preview do painel →' },
  'proc.s5.t': { es: 'Reunión de onboarding 1-on-1', en: '1-on-1 onboarding meeting', fr: 'Réunion d\'onboarding 1-on-1', it: 'Riunione di onboarding 1-on-1', pt: 'Reunião de onboarding 1-on-1' },
  'proc.s5.d': { es: 'Sesión privada de <strong>45 minutos</strong> donde te enseñamos la plataforma SACS, dónde encontrar cada cosa, cómo aprenderla, y resolvemos cualquier duda. Activamos tu cuenta SACS en plan Fideliza para tu propio negocio (valor $14,000 MXN/año).', en: 'Private <strong>45-minute</strong> session where we walk you through SACS, where to find everything, how to learn it, and resolve any questions. We activate your SACS Fideliza account for your own business ($14,000 MXN/year value).', fr: 'Session privée de <strong>45 minutes</strong> où nous vous présentons la plateforme SACS, où trouver chaque chose, comment l\'apprendre, et répondons à toute question. Nous activons votre compte SACS plan Fideliza pour votre activité (valeur 14 000 MXN/an).', it: 'Sessione privata di <strong>45 minuti</strong> dove ti mostriamo la piattaforma SACS, dove trovare ogni cosa, come impararla, e risolviamo ogni dubbio. Attiviamo il tuo account SACS in piano Fideliza per la tua attività (valore $14.000 MXN/anno).', pt: 'Sessão privada de <strong>45 minutos</strong> onde te mostramos a plataforma SACS, onde encontrar cada coisa, como aprender, e resolvemos qualquer dúvida. Ativamos sua conta SACS no plano Fideliza para seu próprio negócio (valor $14.000 MXN/ano).' },
  'proc.s5.tag': { es: '45 min · 1-on-1', en: '45 min · 1-on-1', fr: '45 min · 1-on-1', it: '45 min · 1-on-1', pt: '45 min · 1-on-1' },
  'proc.s6.t': { es: 'Reuniones trimestrales', en: 'Quarterly meetings', fr: 'Réunions trimestrielles', it: 'Riunioni trimestrali', pt: 'Reuniões trimestrais' },
  'proc.s6.d': { es: 'Cada 3 meses revisamos juntos cómo va tu programa: mejores prácticas, contenido que funcionó, nuevos materiales, feedback directo al equipo de producto. Es donde el modelo se mejora — con tu voz incluida.', en: 'Every 3 months we review together how your program is going: best practices, what content worked, new materials, direct feedback to the product team. That\'s where the model improves — with your voice included.', fr: 'Tous les 3 mois nous examinons ensemble comment va votre programme : meilleures pratiques, contenu qui a marché, nouveaux supports, feedback direct à l\'équipe produit. C\'est là que le modèle s\'améliore — avec votre voix incluse.', it: 'Ogni 3 mesi rivediamo insieme come va il tuo programma: best practice, contenuti che hanno funzionato, nuovi materiali, feedback diretto al team prodotto. È dove il modello migliora — con la tua voce inclusa.', pt: 'A cada 3 meses revisamos juntos como vai seu programa: melhores práticas, conteúdo que funcionou, novos materiais, feedback direto à equipe de produto. É onde o modelo melhora — com sua voz incluída.' },
  'proc.s6.tag': { es: 'Cada 3 meses', en: 'Every 3 months', fr: 'Tous les 3 mois', it: 'Ogni 3 mesi', pt: 'A cada 3 meses' },
  'proc.cta':    { es: 'Estoy listo · ir a firmar', en: 'I\'m ready · go sign', fr: 'Je suis prêt · aller signer', it: 'Sono pronto · vai a firmare', pt: 'Estou pronto · ir assinar' },

