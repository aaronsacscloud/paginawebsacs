  'sign.declined.sub':   { es: 'Tu feedback nos ayuda a mejorar el programa. Si cambias de opinión, escríbenos a partners@sacscloud.com y reactivamos tu invitación.', en: 'Your feedback helps us improve the program. If you change your mind, email partners@sacscloud.com and we\'ll reactivate your invitation.', fr: 'Vos retours nous aident à améliorer le programme. Si vous changez d\'avis, écrivez à partners@sacscloud.com et nous réactivons votre invitation.', it: 'Il tuo feedback ci aiuta a migliorare il programma. Se cambi idea, scrivi a partners@sacscloud.com e riattiviamo il tuo invito.', pt: 'Seu feedback nos ajuda a melhorar o programa. Se mudar de ideia, escreva para partners@sacscloud.com e reativamos seu convite.' },
  'sign.expired.eyebrow':{ es: 'Vencida', en: 'Expired', fr: 'Expirée', it: 'Scaduta', pt: 'Vencida' },
  'sign.expired.sub':    { es: 'Si todavía te interesa el programa, contáctanos y te enviamos una invitación renovada.', en: 'If you\'re still interested, contact us and we\'ll send you a renewed invitation.', fr: 'Si le programme vous intéresse toujours, contactez-nous et nous vous envoyons une invitation renouvelée.', it: 'Se il programma ti interessa ancora, contattaci e ti inviamo un invito rinnovato.', pt: 'Se ainda tiver interesse, entre em contato e te enviamos um convite renovado.' },

