        <div class="p-proc-steps">
          <!-- Step 1 -->
          <div class="p-proc-step">
            <div class="p-proc-step-num">1</div>
            <div class="p-proc-step-body">
              <div class="p-proc-step-title">Llena el formulario y firma</div>
              <p class="p-proc-step-detail">
