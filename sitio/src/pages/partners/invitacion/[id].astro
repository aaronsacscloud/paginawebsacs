};
const cancelT = CANCEL_T[lang] || CANCEL_T.es;
const isSubmitted = invitation.estado === 'submitted_for_review';
const isClosed = isAccepted || isDeclined || isSubmitted;

const fmt = (n: number) => n === 0 ? 'Gratis' : '$' + Math.round(n).toLocaleString('es-MX');
const fmtMoney = (n: number) => fmtLocalMoney(n);
const fmtDate = (d: string | null) => {
  if (!d) return '';
  const date = new Date(d.length === 10 ? d + 'T12:00:00' : d);
  if (isNaN(date.getTime())) return '';
  const day = date.getDate();
  const month = date.toLocaleDateString('es-MX', { month: 'short' }).replace('.', '');
  const year = date.getFullYear();
  return `${day}/${month}/${year}`;
};
const fmtDateLong = (d: string | null) => {
  if (!d) return '';
  const date = new Date(d.length === 10 ? d + 'T12:00:00' : d);
  if (isNaN(date.getTime())) return '';
  const day = date.getDate();
  const month = date.toLocaleDateString('es-MX', { month: 'long' });
  const year = date.getFullYear();
  return `${day} de ${month} de ${year}`;
};

const fechaCreado = fmtDate(invitation.created_at);
const fechaCreadoLargo = fmtDateLong(invitation.created_at);
const vigenciaFecha = fmtDate(invitation.vigencia);
const vigenciaLarga = fmtDateLong(invitation.vigencia);

const tipoLabel: Record<string, string> = {
  embajador: 'Embajador SACS',
  distribuidor: 'Distribuidor Autorizado',
  integrador: 'Integrador Certificado',
  reseller: 'Reseller',
  consultor: 'Consultor Partner',
};
const tipoTagline: Record<string, string> = {
  embajador: 'Difunde, recomienda y crece con SACS. Tu voz mueve marcas.',
  distribuidor: 'Vende SACS a tu red. Comisiones recurrentes mientras estén activos.',
  integrador: 'Implementa SACS en clientes B2B. Soporte técnico y handoff cualificado.',
  reseller: 'Modelo white-label para vender SACS bajo tu marca o canal.',
  consultor: 'Asesora a clientes en su transformación digital con SACS.',
};

const heroEyebrow = esp ? esp.badge : tt('hero.eyebrow');
const heroTitle = invitation.nombre;
const heroSubtitle = esp ? esp.heroPitch : (tipoTagline[tipo] || '');

const SIGN_LABELS: Record<Lang, { firmada: string; rechazada: string; revision: string; firmar: string }> = {
  es: { firmada: 'Firmada', rechazada: 'Rechazada', revision: 'En revisión', firmar: 'Aceptar y firmar' },
  en: { firmada: 'Signed', rechazada: 'Declined', revision: 'In review', firmar: 'Accept & sign' },
  fr: { firmada: 'Signée', rechazada: 'Refusée', revision: 'En examen', firmar: 'Accepter & signer' },
  it: { firmada: 'Firmata', rechazada: 'Rifiutata', revision: 'In revisione', firmar: 'Accetta e firma' },
  pt: { firmada: 'Assinada', rechazada: 'Recusada', revision: 'Em revisão', firmar: 'Aceitar e assinar' },
};
const sl = SIGN_LABELS[lang];
const tabsDef = [
  { id: 'bienvenida',   label: tt('tab.bienvenida'),    show: true, minutes: 2 },
  { id: 'terminos',     label: tt('tab.terminos'),      show: true, minutes: 5 },
  { id: 'embudo',       label: tt('tab.embudo'),        show: true, minutes: 6 },
  { id: 'compromisos',  label: tt('tab.compromisos'),   show: compromisos.length > 0, minutes: 3 },
  { id: 'contenido',    label: tt('tab.contenido'),     show: tipo === 'embajador', minutes: 4 },
  { id: 'compensacion', label: tt('tab.compensacion'),  show: comisionPct > 0 || Object.keys(tabulador).length > 0, minutes: 6 },
  { id: 'canales',      label: tt('tab.canales'),       show: true, minutes: 3 },
  { id: 'red',          label: tt('tab.red'),           show: true, minutes: 3 },
  { id: 'crecimiento',  label: tt('tab.crecimiento'),   show: true, minutes: 3 },
  { id: 'proceso',      label: tt('tab.proceso'),       show: true, minutes: 4 },
  { id: 'firma',        label: isAccepted ? sl.firmada : (isDeclined ? sl.rechazada : (isSubmitted ? sl.revision : sl.firmar)), show: true, minutes: 2 },
];
const visibleTabs = tabsDef.filter(t => t.show).map(({ id, label, minutes }) => ({ id, label, minutes }));
const initialTab = isClosed ? 'firma' : 'bienvenida';

// ─── Projection data: SACS plan pricing (MXN) y escenarios ───
// monthly = precio público mensual del plan
// annualTotal = precio público anual del plan (con descuento de 2 meses)
const SACS_PLANS = [
  { id: 'vende',      name: 'Vende',      monthly: 600,  annualTotal: 6000,  accent: '#94A3B8', tagline: 'Para marcas que arrancan' },
  { id: 'controla',   name: 'Controla',   monthly: 900,  annualTotal: 9000,  accent: '#4B7BE5', tagline: 'Multi-sucursal con orden' },
  { id: 'fideliza',   name: 'Fideliza',   monthly: 1400, annualTotal: 14000, accent: '#6C5CE7', tagline: 'Más popular',   highlighted: true },
  { id: 'automatiza', name: 'Automatiza', monthly: 5900, annualTotal: 59000, accent: '#1a1a1a', tagline: 'Operación con IA' },
];
const CLIENT_TIERS = [10, 20, 50, 100, 200, 500];

// Escenarios de actividad mensual: usuarios que se registran a prueba gratis
// (entran por tu link único) y demos completadas (asisten al demo válido).
const DEMO_SCENARIOS = [
  { id: 'cons', label: tt('scen.cons'), pruebas_gratis: 4,  completadas: 2,  hint: tt('scen.cons.h') },
  { id: 'real', label: tt('scen.real'), pruebas_gratis: 10, completadas: 6,  hint: tt('scen.real.h') },
  { id: 'amb',  label: tt('scen.amb'),  pruebas_gratis: 25, completadas: 15, hint: tt('scen.amb.h') },
];

const ratePartner = comisionPct / 100;
// Bonos por prueba gratis y demo completada DESCONTINUADOS — solo se paga el
// 50% de comisión directa sobre la venta. El partner ve la actividad de cada
// lead (clicks, demos, registros) en su portal, pero no monetiza esos eventos.
// Hardcoded a 0 (ignoramos el tabulador de la DB) para que NUNCA aparezcan
// los bloques de bono, sin importar lo que diga la invitación específica.
const bonusPruebaGratis = 0;
const bonusCompletada   = 0;

// Per-cell calculation: clientes × precio_plan × comision%
function calcSale(planPrice: number, clients: number) {
  return Math.round(planPrice * clients * ratePartner);
}
function calcDemoMonthly(s: typeof DEMO_SCENARIOS[0]) {
  return s.pruebas_gratis * bonusPruebaGratis + s.completadas * bonusCompletada;
}

// Big closing number — best case fideliza × 100 (realista) y automatiza × 500 (techo)
const realisticClosingMonthly = calcSale(SACS_PLANS[2].monthly,     100); // Fideliza × 100 mensual
const realisticClosingAnnual  = calcSale(SACS_PLANS[2].annualTotal, 100); // Fideliza × 100 anual
const ceilingClosingMonthly   = calcSale(SACS_PLANS[3].monthly,     500); // Automatiza × 500 mensual
const ceilingClosingAnnual    = calcSale(SACS_PLANS[3].annualTotal, 500); // Automatiza × 500 anual

// Cuota mínima anual: 10 sucursales — usado en la sección "¿Por qué te conviene cumplir?"
const minQuotaFidelizaAnnual   = calcSale(SACS_PLANS[2].annualTotal, 10); // 10 × Fideliza anual
const minQuotaAutomatizaAnnual = calcSale(SACS_PLANS[3].annualTotal, 10); // 10 × Automatiza anual

// Pre-compute contract template strings (avoid IIFE inside JSX)
const tipoStr   = tipoLabel[tipo] || tipo;
const numeroStr = invitation.numero || '—';
const nombreStr = invitation.nombre || '—';
const pctStr    = String(comisionPct);
const ctTitleHtml = tt('ct.title').split('{tipo}').join(tipoStr);
const ctIntroHtml = tt('ct.intro').split('{nombre}').join(nombreStr);
const ctP1Html    = tt('ct.p1').split('{tipo}').join(tipoStr).split('{numero}').join(numeroStr).split('{vigencia}').join(vigenciaLarga);
const ctP21Html   = tt('ct.p2.1').split('{pct}').join(pctStr);
const ctP24Html   = tt('ct.p2.4').split('{pct}').join(pctStr);

// ─── Override 10% sobre la red · ejemplos por hito ───
// Asume plan promedio Fideliza ($14,000 MXN/año) y promedios conservadores
// de venta por partner. El override se calcula sobre el cobro al cliente,
// pagado por SACS (no descuenta del 50% directo del partner invitado).
const PLAN_PROM_MXN = 14000;
const OVERRIDE_PCT  = 10;
const overrideExamples = [
  { tier: 1, partners: 5,   storesPerPartner: 5,  totalStores: 25,   suffix: 'Master Partner Nv 1' },
  { tier: 2, partners: 10,  storesPerPartner: 8,  totalStores: 80,   suffix: 'Master Partner Nv 2' },
  { tier: 3, partners: 20,  storesPerPartner: 10, totalStores: 200,  suffix: 'Master Partner Nv 3' },
  { tier: 4, partners: 100, storesPerPartner: 12, totalStores: 1200, suffix: 'Master Partner Nv 4' },
].map(e => {
  const grossMxn   = e.totalStores * PLAN_PROM_MXN;
  const overrideMxn = Math.round(grossMxn * OVERRIDE_PCT / 100);
  return {
    ...e,
    grossStr:   fmtMoney(grossMxn),
    annualStr:  fmtMoney(overrideMxn),
    monthlyStr: fmtMoney(Math.round(overrideMxn / 12)),
  };
});

const beneficioIcons: Record<string, string> = {
  gift: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>',
  percent: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>',
  academy: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>',
  community: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>',
  reward: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>',
  leads: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>',
  broadcast: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 11-5.8-1.6"/></svg>',
  calendar: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
  link: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>',
  dashboard: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>',
  wallet: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 010-4h14v4"/><path d="M3 5v14a2 2 0 002 2h16v-5"/><path d="M18 12a2 2 0 000 4h4v-4z"/></svg>',
  default: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>',
};

const partnerLandingUrl = invitation.slug_landing
  ? `https://www.sacscloud.com/p/${invitation.slug_landing}`
  : `https://www.sacscloud.com/p/${(invitation.numero || '').toLowerCase()}`;
---

<BaseLayout
  title={`Invitación Partner ${invitation.numero || ''} — SACS`}
  description={`Programa de partners SACS para ${invitation.nombre}`}
  noindex={true}
  bareLayout={true}
>

<div class:list={['p-layout', `p-layout--${template}`]}>
  <aside class="p-layout-sidebar no-print">
    <PartnerSidebar
      tabs={visibleTabs}
      initialTab={initialTab}
      numero={invitation.numero}
      nombre={invitation.nombre}
      tipo={tipo}
      comisionPct={comisionPct}
      template={template}
      isAccepted={isAccepted}
      isDeclined={isDeclined}
      isExpired={!!isExpired}
      vigenciaFecha={vigenciaFecha}
      glossaryLabel={tt('glos.eyebrow')}
    />
  </aside>

  <div class:list={['p-page', `p-${template}`]} id="partner-doc" data-initial-tab={initialTab}>

    <!-- Language switcher · select dropdown con bandera default -->
    <div class="p-langswitch no-print" role="group" aria-label={tt('lang.label')}>
      {(() => {
        const names = { es: 'Español', en: 'English', fr: 'Français', it: 'Italiano', pt: 'Português' } as const;
        const flags = { es: '🇲🇽', en: '🇺🇸', fr: '🇫🇷', it: '🇮🇹', pt: '🇧🇷' } as const;
        const optionData = SUPPORTED_LANGS.map((l) => {
          const url = new URL(Astro.url);
          if (l === 'es') url.searchParams.delete('lang'); else url.searchParams.set('lang', l);
          return { code: l, href: url.pathname + (url.search || '') + url.hash };
        });
        return (
          <div class="p-langswitch-wrap">
            <span class="p-langswitch-current" aria-hidden="true">
              <span class="p-langswitch-flag">{flags[lang]}</span>
              <span class="p-langswitch-code">{lang.toUpperCase()}</span>
              <svg class="p-langswitch-caret" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </span>
            <select
              class="p-langswitch-select"
              id="p-langswitch-select"
              aria-label={tt('lang.label')}
              data-current={lang}
            >
              {optionData.map((o) => (
                <option value={o.href} selected={o.code === lang}>
                  {flags[o.code]} {names[o.code]} ({o.code.toUpperCase()})
                </option>
              ))}
            </select>
          </div>
        );
      })()}
    </div>

    <!-- Mobile sticky nav (oculta en desktop) -->
    <nav class="p-mobnav no-print" aria-label="Secciones (móvil)">
      <div class="p-mobnav-inner" id="p-mobnav-inner">
        {visibleTabs.map((t, i) => (
          <a
            href={`#${t.id}`}
            class={`p-mobnav-tab ${t.id === initialTab ? 'p-mobnav-tab--active' : ''}`}
            data-tab-link={t.id}
          >
            <span class="p-mobnav-tab-num">{(i + 1).toString().padStart(2, '0')}</span>
            <span class="p-mobnav-tab-label">{t.label}</span>
          </a>
        ))}
      </div>
    </nav>

    <!-- Mobile header (visible solo cuando hay sección activa en mobile) -->
    <header class="p-mh no-print" id="p-mh" role="navigation" aria-label="Navegación de sección">
      <button class="p-mh-back" id="p-mh-back" type="button" aria-label="Volver al índice">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
        <span>Inicio</span>
      </button>
      <select class="p-mh-select" id="p-mh-select" aria-label="Ir a sección">
        {visibleTabs.map((t, i) => (
          <option value={t.id}>{(i + 1).toString().padStart(2, '0')} · {t.label}</option>
        ))}
      </select>
    </header>

    <!-- Mobile index · pantalla inicial con cards de las secciones -->
    <div class="p-mi no-print" id="p-mi" role="navigation" aria-label="Índice de secciones">
      <div class="p-mi-hero">
        <div class="p-mi-eyebrow">Programa Partners SACS</div>
        <h1 class="p-mi-title">Hola, <span>{invitation.nombre?.split(' ')[0] || 'partner'}</span></h1>
        <p class="p-mi-sub" set:html={escalonadoOn ? tt('mi.sub.esc') : tt('mi.sub.std').split('{pct}').join(String(comisionPct))}></p>
        <div class="p-mi-meta">
          {!isExpired && !isClosed && <span class="p-mi-badge p-mi-badge--active"><span class="p-mi-dot"></span>Activa</span>}
          {isAccepted && <span class="p-mi-badge p-mi-badge--accepted"><span class="p-mi-dot"></span>Firmada</span>}
          {isDeclined && <span class="p-mi-badge p-mi-badge--declined"><span class="p-mi-dot"></span>Rechazada</span>}
          {isExpired && !isClosed && <span class="p-mi-badge p-mi-badge--expired"><span class="p-mi-dot"></span>Vencida</span>}
          <span class="p-mi-numero">{invitation.numero}</span>
        </div>
      </div>

      <!-- Cover ilustrada · comunidad de partners SACS -->
      <div class="p-mi-cover">
        <img src="/img/partner-invitation/cover.webp" alt="" loading="eager" fetchpriority="high" width="1024" height="683" />
      </div>

      <div class="p-mi-listtitle">
        <span class="p-mi-listtitle-num">{visibleTabs.length}</span>
        <span class="p-mi-listtitle-text">secciones para conocer el programa</span>
      </div>

      <div class="p-mi-list">
        {visibleTabs.map((t, i) => (
          <button
            type="button"
            class="p-mi-card"
            data-tab-link={t.id}
            style={`--i:${i}`}
            aria-label={`Ir a sección ${t.label}`}
          >
            <span class="p-mi-card-img">
              <img src={`/img/partner-invitation/${t.id}.webp`} alt="" loading="lazy" width="80" height="80" />
              <span class="p-mi-card-check" aria-label="Visto">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </span>
            </span>
            <span class="p-mi-card-body">
              <span class="p-mi-card-meta">
                <span class="p-mi-card-num">{(i + 1).toString().padStart(2, '0')}</span>
                <span class="p-mi-card-sep">·</span>
                <span class="p-mi-card-time">{t.minutes} min</span>
              </span>
              <span class="p-mi-card-title">{t.label}</span>
            </span>
            <svg class="p-mi-card-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </button>
        ))}
      </div>

      <!-- Banner CTA "Firmar" al final del index -->
      {!isClosed && (
        <button type="button" class="p-mi-cta" data-tab-link="firma" aria-label="Ir a firmar">
          <span class="p-mi-cta-eyebrow">¿Listo para empezar?</span>
          <span class="p-mi-cta-title">Firmar y aceptar</span>
          <span class="p-mi-cta-sub">Tu portal queda activo al instante</span>
          <span class="p-mi-cta-arrow" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </span>
        </button>
      )}

      <div class="p-mi-footer">
        <p>Tómate tu tiempo · puedes volver al índice en cualquier momento desde el header.</p>
      </div>
    </div>

    <div class="p-container">

      <!-- Header -->
      <div class="p-header">
        <div class="p-header-brand">
          <span class="p-logo-text">Sacs</span>
          <span class="p-logo-tag">Partners</span>
        </div>
        <div class="p-header-meta">
          {isAccepted && <span class="p-status p-status--accepted"><span class="p-status-dot"></span>Firmada</span>}
          {isDeclined && <span class="p-status p-status--declined"><span class="p-status-dot"></span>Rechazada</span>}
          {isExpired && !isClosed && <span class="p-status p-status--expired"><span class="p-status-dot"></span>Vencida</span>}
          {!isExpired && !isClosed && <span class="p-status p-status--active"><span class="p-status-dot"></span>Activa</span>}
          <div class="p-numero">{invitation.numero}</div>
          <div class="p-fecha">Emitida {fechaCreado}</div>
          {!isClosed && !isExpired && vigenciaFecha && (
            <div class="p-fecha">Vigente hasta {vigenciaFecha}</div>
          )}
        </div>
      </div>

      <!-- TAB: BIENVENIDA -->
      <section id="bienvenida" class={`p-tab-panel${initialTab === 'bienvenida' ? ' is-active' : ''}`} data-tab="bienvenida">
        {isLocalized && (
          <div class="p-localized-banner no-print">
            <span class="p-localized-icon" aria-hidden="true">🌐</span>
            <span class="p-localized-text">{tt('banner.localized')}</span>
          </div>
        )}

        <!-- Hero -->
        <div class="p-hero">
          <div class="p-hero-eyebrow">{heroEyebrow}</div>
          <h1 class="p-hero-title">
            {invitation.nombre},<br/>
            <span class="p-hero-title-soft">{tt('hero.want')}</span><br/>
            <span class="p-hero-title-strong">{tipoLabel[tipo] || tipo}</span>{esp && (<><br/><span class="p-hero-title-strong" style={`color:${esp.color};`}>especialista en {esp.label}</span></>)}.
          </h1>
          <p class="p-hero-sub">{heroSubtitle}</p>

          <div class="p-hero-stats">
            {escalonadoOn && escBest ? (
              <>
                <div class="p-hero-stat">
                  <div class="p-hero-stat-num">{fmtMoney(escBest.netProfit)}</div>
                  <div class="p-hero-stat-label">{tt('esc.hero.profit')}</div>
                </div>
                <div class="p-hero-stat">
                  <div class="p-hero-stat-num">{fmtMoney(escTiers[0].price)}</div>
                  <div class="p-hero-stat-label">{tt('esc.hero.invest')}</div>
                </div>
              </>
            ) : (
