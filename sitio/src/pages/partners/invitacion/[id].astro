  'proj.bonos.eyebrow': { es: '1 · Bonos por activaciones (mensual recurrente)', en: '1 · Activation bonuses (monthly recurring)', fr: '1 · Bonus d\'activation (mensuel récurrent)', it: '1 · Bonus per attivazioni (mensile ricorrente)', pt: '1 · Bônus por ativações (mensal recorrente)' },
  'proj.bonos.title':   { es: 'Por traer pruebas gratis y completar demos', en: 'For bringing free trials and completing demos', fr: 'Pour amener des essais gratuits et compléter des démos', it: 'Per portare prove gratuite e completare demo', pt: 'Por trazer testes grátis e concluir demos' },
  'proj.com.eyebrow':   { es: '2 · Comisiones por ventas (acumulado)', en: '2 · Sales commissions (cumulative)', fr: '2 · Commissions de vente (cumulé)', it: '2 · Commissioni di vendita (cumulato)', pt: '2 · Comissões por vendas (acumulado)' },
  'proj.com.title':     { es: 'Por cerrar clientes con tu link', en: 'For closing clients via your link', fr: 'Pour conclure des clients via votre lien', it: 'Per chiudere clienti con il tuo link', pt: 'Por fechar clientes com seu link' },

  // Closing scenarios
  'proj.real.lbl':   { es: 'Escenario realista', en: 'Realistic scenario', fr: 'Scénario réaliste', it: 'Scenario realistico', pt: 'Cenário realista' },
  'proj.real.det':   { es: '100 clientes en plan Fideliza con tu {pct}% de comisión.', en: '100 clients on Fideliza Plan with your {pct}% commission.', fr: '100 clients sur le plan Fideliza avec votre {pct}% de commission.', it: '100 clienti sul piano Fideliza con la tua commissione del {pct}%.', pt: '100 clientes no plano Fideliza com sua comissão de {pct}%.' },
  'proj.ceil.lbl':   { es: 'Tu techo', en: 'Your ceiling', fr: 'Votre plafond', it: 'Il tuo tetto', pt: 'Seu teto' },
  'proj.ceil.det':   { es: '500 clientes en plan Automatiza. Una red enterprise de retailers usándote como su embajador SACS.', en: '500 clients on the Automatiza plan. An enterprise network of retailers using you as their SACS ambassador.', fr: '500 clients sur le plan Automatiza. Un réseau enterprise de retailers vous utilisant comme leur ambassadeur SACS.', it: '500 clienti sul piano Automatiza. Una rete enterprise di retailer che ti usano come ambasciatore SACS.', pt: '500 clientes no plano Automatiza. Uma rede enterprise de varejistas usando você como seu embaixador SACS.' },
  'proj.bottom':     { es: 'Y todo esto sin contar el <strong>10% adicional sobre tu red</strong> sobre lo que venda tu red cuando llegues a Master Partner.', en: 'And all this without counting the <strong>10% adicional sobre tu red</strong> on what your network sells once you reach Master Partner.', fr: 'Et tout cela sans compter le <strong>10% adicional sobre tu red</strong> sur ce que vend votre réseau quand vous atteignez Master Partner.', it: 'E tutto questo senza contare il <strong>10% adicional sobre tu red</strong> su quello che vende la tua rete quando raggiungi Master Partner.', pt: 'E tudo isso sem contar o <strong>10% adicional sobre tu red</strong> sobre o que sua rede vende quando chegar a Master Partner.' },

  // Sign form (Phase K)
  'sign.eyebrow':  { es: 'Aceptación formal', en: 'Formal acceptance', fr: 'Acceptation formelle', it: 'Accettazione formale', pt: 'Aceitação formal' },
  'sign.title':    { es: 'Acepta y firma tu invitación', en: 'Accept and sign your invitation', fr: 'Acceptez et signez votre invitation', it: 'Accetta e firma il tuo invito', pt: 'Aceite e assine seu convite' },
  'sign.lead.auto':   { es: 'Al firmar tu cuenta queda <strong>aprobada al instante</strong> y recibirás tus credenciales por correo.', en: 'When you sign your account is <strong>approved instantly</strong> and you\'ll get your credentials by email.', fr: 'En signant, votre compte est <strong>approuvé instantanément</strong> et vous recevrez vos identifiants par email.', it: 'Firmando il tuo account viene <strong>approvato all\'istante</strong> e riceverai le credenziali via email.', pt: 'Ao assinar sua conta fica <strong>aprovada na hora</strong> e você recebe suas credenciais por e-mail.' },
  'sign.lead.manual': { es: 'Tres pasos: tus datos, contrato, firma. Al firmar enviamos tu solicitud al equipo SACS para revisión y te avisamos por correo cuando esté lista tu cuenta.', en: 'Three steps: your data, contract, signature. Once signed we send your request to the SACS team for review and email you when your account is ready.', fr: 'Trois étapes : vos données, contrat, signature. Une fois signé, nous envoyons votre demande à l\'équipe SACS pour examen et vous prévenons par email lorsque votre compte est prêt.', it: 'Tre passi: i tuoi dati, contratto, firma. Una volta firmato inviamo la tua richiesta al team SACS per la revisione e ti avvisiamo via email quando il tuo account è pronto.', pt: 'Três passos: seus dados, contrato, assinatura. Ao assinar enviamos sua solicitação à equipe SACS para revisão e te avisamos por e-mail quando sua conta estiver pronta.' },

