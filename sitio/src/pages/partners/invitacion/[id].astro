  I18N['ct.p5.6'] = {
    es: `<strong>Costo de participación:</strong> el Partner paga una inversión única de ${m} para inscribirse en el programa. No hay cuotas mensuales ni anuales adicionales. Además de esta inversión, el Partner aporta actividad — los compromisos descritos en esta cláusula forman parte de la contraprestación por los beneficios incluidos.`,
    en: `<strong>Participation cost:</strong> the Partner pays a one-time investment of ${m} to enroll in the program. There are no additional monthly or annual fees. Beyond this investment, the Partner contributes activity — the commitments described in this clause are part of the consideration for the included benefits.`,
