const bonusPruebaGratis = Number(tabulador.prueba_gratis ?? 250);
const bonusCompletada   = Number(tabulador.demo_completada ?? 300);

// Per-cell calculation: clientes × precio_plan × comision%
function calcSale(planPrice: number, clients: number) {
  return Math.round(planPrice * clients * ratePartner);
}
function calcDemoMonthly(s: typeof DEMO_SCENARIOS[0]) {
  return s.pruebas_gratis * bonusPruebaGratis + s.completadas * bonusCompletada;
}

// Big closing number — best case fideliza × 100 (realista) y automatiza × 500 (techo)
const realisticClosingMonthly = calcSale(SACS_PLANS[2].monthly,     100); // Fideliza × 100 mensual
const realisticClosingAnnual  = calcSale(SACS_PLANS[2].annualTotal, 100); // Fideliza × 100 anual
const ceilingClosingMonthly   = calcSale(SACS_PLANS[3].monthly,     500); // Automatiza × 500 mensual
const ceilingClosingAnnual    = calcSale(SACS_PLANS[3].annualTotal, 500); // Automatiza × 500 anual

// Cuota mínima anual: 10 sucursales — usado en la sección "¿Por qué te conviene cumplir?"
const minQuotaFidelizaAnnual   = calcSale(SACS_PLANS[2].annualTotal, 10); // 10 × Fideliza anual
const minQuotaAutomatizaAnnual = calcSale(SACS_PLANS[3].annualTotal, 10); // 10 × Automatiza anual

const beneficioIcons: Record<string, string> = {
  gift: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>',
  percent: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>',
  academy: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>',
  community: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>',
  reward: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>',
  leads: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>',
  broadcast: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 11-5.8-1.6"/></svg>',
  calendar: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
  link: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>',
  dashboard: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>',
  wallet: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 010-4h14v4"/><path d="M3 5v14a2 2 0 002 2h16v-5"/><path d="M18 12a2 2 0 000 4h4v-4z"/></svg>',
  default: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>',
};

const partnerLandingUrl = invitation.slug_landing
  ? `https://www.sacscloud.com/p/${invitation.slug_landing}`
  : `https://www.sacscloud.com/p/${(invitation.numero || '').toLowerCase()}`;
---

<BaseLayout
  title={`Invitación Partner ${invitation.numero || ''} — SACS`}
  description={`Programa de partners SACS para ${invitation.nombre}`}
  noindex={true}
  bareLayout={true}
>

<div class:list={['p-layout', `p-layout--${template}`]}>
  <aside class="p-layout-sidebar no-print">
    <PartnerSidebar
      tabs={visibleTabs}
      initialTab={initialTab}
      numero={invitation.numero}
      nombre={invitation.nombre}
      tipo={tipo}
      comisionPct={comisionPct}
      template={template}
      isAccepted={isAccepted}
      isDeclined={isDeclined}
      isExpired={!!isExpired}
      vigenciaFecha={vigenciaFecha}
    />
  </aside>

  <div class:list={['p-page', `p-${template}`]} id="partner-doc" data-initial-tab={initialTab}>

    <!-- Language switcher (sticky top-right, hidden on print) -->
    <div class="p-langswitch no-print" role="group" aria-label={tt('lang.label')}>
      {SUPPORTED_LANGS.map((l) => {
        const url = new URL(Astro.url);
        if (l === 'es') url.searchParams.delete('lang'); else url.searchParams.set('lang', l);
        const href = url.pathname + (url.search || '') + url.hash;
        return (
          <a href={href} class={`p-langswitch-btn${l === lang ? ' is-active' : ''}`} hreflang={l} title={l.toUpperCase()}>{l.toUpperCase()}</a>
        );
      })}
    </div>

    <!-- Mobile sticky nav (oculta en desktop) -->
    <nav class="p-mobnav no-print" aria-label="Secciones (móvil)">
      <div class="p-mobnav-inner" id="p-mobnav-inner">
        {visibleTabs.map((t, i) => (
          <a
            href={`#${t.id}`}
            class={`p-mobnav-tab ${t.id === initialTab ? 'p-mobnav-tab--active' : ''}`}
            data-tab-link={t.id}
          >
            <span class="p-mobnav-tab-num">{(i + 1).toString().padStart(2, '0')}</span>
            <span class="p-mobnav-tab-label">{t.label}</span>
          </a>
        ))}
      </div>
    </nav>

    <div class="p-container">

      <!-- Header -->
      <div class="p-header">
        <div class="p-header-brand">
          <span class="p-logo-text">Sacs</span>
          <span class="p-logo-tag">Partners</span>
        </div>
        <div class="p-header-meta">
          {isAccepted && <span class="p-status p-status--accepted"><span class="p-status-dot"></span>Firmada</span>}
          {isDeclined && <span class="p-status p-status--declined"><span class="p-status-dot"></span>Rechazada</span>}
          {isExpired && !isClosed && <span class="p-status p-status--expired"><span class="p-status-dot"></span>Vencida</span>}
          {!isExpired && !isClosed && <span class="p-status p-status--active"><span class="p-status-dot"></span>Activa</span>}
          <div class="p-numero">{invitation.numero}</div>
          <div class="p-fecha">Emitida {fechaCreado}</div>
          {!isClosed && !isExpired && vigenciaFecha && (
            <div class="p-fecha">Vigente hasta {vigenciaFecha}</div>
          )}
        </div>
      </div>

      <!-- TAB: BIENVENIDA -->
      <section class="p-tab-panel" data-tab="bienvenida">
        {isLocalized && (
          <div class="p-localized-banner no-print">
            <span class="p-localized-icon" aria-hidden="true">🌐</span>
            <span class="p-localized-text">{tt('banner.localized')}</span>
          </div>
        )}

        <!-- Hero -->
        <div class="p-hero">
          <div class="p-hero-eyebrow">{heroEyebrow}</div>
          <h1 class="p-hero-title">
            {invitation.nombre},<br/>
            <span class="p-hero-title-soft">{tt('hero.want')}</span><br/>
            <span class="p-hero-title-strong">{tipoLabel[tipo] || tipo}</span>.
          </h1>
          <p class="p-hero-sub">{heroSubtitle}</p>

          <div class="p-hero-stats">
            <div class="p-hero-stat">
              <div class="p-hero-stat-num">{comisionPct}<span class="p-hero-stat-pct">%</span></div>
              <div class="p-hero-stat-label">{tt('hero.commission')}</div>
            </div>
            {(bonusPruebaGratis > 0 || bonusCompletada > 0) ? (
              <div class="p-hero-stat">
                <div class="p-hero-stat-num">{bonusPruebaGratis > 0 ? fmtMoney(bonusPruebaGratis) : fmtMoney(bonusCompletada)}</div>
                <div class="p-hero-stat-label">{bonusPruebaGratis > 0 ? tt('hero.bonus.test') : tt('hero.bonus.demo')}</div>
              </div>
            ) : (costoMensual > 0 || costoUnico > 0) ? (
              <div class="p-hero-stat">
                <div class="p-hero-stat-num">{costoMensual > 0 ? fmtMoney(costoMensual) : fmtMoney(costoUnico)}</div>
                <div class="p-hero-stat-label">{costoMensual > 0 ? 'Cuota mensual' : 'Cuota única'}</div>
              </div>
            ) : (
              <div class="p-hero-stat">
                <div class="p-hero-stat-num">Sin costo</div>
                <div class="p-hero-stat-label">Acceso al programa</div>
              </div>
            )}
            <div class="p-hero-stat">
              <div class="p-hero-stat-num">3K+</div>
              <div class="p-hero-stat-label">{tt('hero.brands')}</div>
            </div>
          </div>
        </div>

        <!-- ── TL;DR · resumen rápido ── -->
        <div class="p-tldr">
          <div class="p-tldr-head">
            <span class="p-tldr-eyebrow">{tt('tldr.eyebrow')}</span>
            <h2 class="p-tldr-title">{tt('tldr.title')}</h2>
          </div>
          <ol class="p-tldr-list">
            <li>{tt('tldr.l1')}</li>
            <li><strong>{comisionPct}% {tt('tldr.l2.commission')}</strong> {tt('tldr.l2')}</li>
            <li>{tt('tldr.l3')}</li>
            <li>{tt('tldr.l4')}</li>
            <li>{tt('tldr.l5')}</li>
          </ol>
        </div>

        <!-- ── Carta del founder ── -->
        <div class="p-letter">
          <div class="p-letter-eyebrow">Carta del founder</div>
          <div class="p-letter-body">
            <p class="p-letter-greeting">{invitation.nombre},</p>
            <p>
              Llevo más de 13 años construyendo SACS y, en todo ese tiempo,
              la decisión más difícil ha sido <strong>quién entra al programa
              de partners</strong>. No es un programa de afiliados — es una
              extensión de la empresa. Tú representas a SACS frente a tu
              comunidad y nosotros, a cambio, te damos la plataforma, el
              equipo y el respaldo para que cada cliente que tú traes tenga
              una experiencia que <strong>te haga ver bien</strong>.
            </p>
            <p>
              Hoy somos 100 partners en LATAM. Mi meta es que para el cierre
              de 2026 seamos 1,000 — pero solo personas en las que confíe
              que van a representar la marca con cuidado. Si estás leyendo
              esto es porque ya estás en esa lista corta. Espero que firmes,
              y si tienes cualquier duda, escríbeme directo: ya tienes mi
              correo en este documento.
            </p>
            <p class="p-letter-cierre">Gracias por considerar ser parte de esto.</p>
          </div>
          <div class="p-letter-sig">
            <div class="p-letter-sig-mark">A</div>
            <div class="p-letter-sig-info">
              <div class="p-letter-sig-name">Aaron Rodríguez</div>
              <div class="p-letter-sig-role">Founder & CEO · SACS</div>
            </div>
          </div>
        </div>

        <!-- Hero photo anchor -->
        <div class="p-tab-hero" style="margin-top: 32px;">
          <img src="/images/partner-tabs/bienvenida.webp" alt="Una emprendedora frente a su tienda" loading="eager" fetchpriority="high" width="1600" height="900" class="p-tab-hero-img" />
          <div class="p-tab-hero-overlay">
            <div class="p-tab-hero-eyebrow">Bienvenida</div>
            <h2 class="p-tab-hero-title">Construimos para la gente que vende.</h2>
          </div>
        </div>

        <!-- ── 1. Para quién es: 5 perfiles, mismo programa ── -->
        <div class="p-bw-section">
          <div class="p-bw-eyebrow">{tt('who.eyebrow')}</div>
          <h2 class="p-bw-title">{tt('who.title')}</h2>
          <p class="p-bw-lead">
            Diseñamos el programa para cinco perfiles distintos — sin preferencia
            entre uno y otro. Puedes empezar desde tu casa, desde tu empresa o
            desde tu tienda; el programa crece contigo y <strong>no hay límite</strong>.
            Todos cumplen los mismos compromisos, todos cobran las mismas comisiones.
          </p>

          <div class="p-perfil-rows">
            {[
              { id: 'influencer',  tag: 'Influencer',           title: 'Influencers y creadores',                 desc: 'Tienes audiencia que confía en tus recomendaciones. Aprovechas tu alcance — cada pieza de contenido suma puntos y tu link cierra ventas en piloto automático.', from: 'Desde tu casa' },
              { id: 'nomada',      tag: 'Nómada digital',       title: 'Nómadas digitales',                       desc: 'Trabajas desde donde quieras: cafés, coworkings, Airbnbs, ciudades distintas cada mes. SACS te paga vía CLABE/PayPal/Mercado Pago — la geografía no te limita.', from: 'Desde donde estés' },
              { id: 'consultor',   tag: 'Consultor',            title: 'Consultores y asesores',                  desc: 'Asesoras a negocios y SACS es una herramienta más en tu kit. Recomiendas, certificas, cobras implementación — y el 100% del cobro al cliente es tuyo.', from: 'Desde tu oficina o tu casa' },
              { id: 'contador',    tag: 'Contador',             title: 'Contadores y asesores fiscales',          desc: 'Tu cartera ya confía en ti para sus finanzas. Recomendar SACS resuelve un dolor real (CFDI, IEPS, conciliación) y abres una nueva línea de ingresos.', from: 'Desde tu despacho' },
              { id: 'tecnologia',  tag: 'Distribuidor tech',    title: 'Distribuidores de tecnología B2B',        desc: 'Vendes software, SaaS y soluciones tech a empresas. SACS encaja en tu portafolio como solución end-to-end de retail con margen recurrente real.', from: 'Desde tu empresa' },
              { id: 'hardware',    tag: 'Hardware',             title: 'Vendedores de hardware POS',              desc: 'Vendes terminales, lectores, scanners e impresoras. Sumas SACS y vendes la operación completa — hardware + software como un solo paquete.', from: 'Desde tu showroom o ruta' },
              { id: 'distribuidor', tag: 'Distribuidor',        title: 'Distribuidores de tiendas',               desc: 'Vendes a una red de tiendas o llevas un canal completo. Tu red ya conoce tu marca; sumar SACS es darles más valor con la misma relación.', from: 'Desde tu empresa o almacén' },
              { id: 'tienda',      tag: 'Dueño de tienda',      title: 'Dueños de tienda o negocio',              desc: 'Ya operas un negocio. Tu credibilidad operacional pesa más que cualquier audiencia: recomiendas SACS a colegas de tu giro y a tu cámara local.', from: 'Desde tu tienda o local' },
              { id: 'emprendedor', tag: 'Emprendedor',          title: 'Emprendedores arrancando',                desc: 'No tienes audiencia ni cartera todavía — y eso no te frena. Sumas puntos con acciones de promoción y filantropía mientras construyes tu negocio.', from: 'Desde tu casa' },
            ].map((p, i) => (
              <article class={`p-perfil-row ${i % 2 === 1 ? 'p-perfil-row--reverse' : ''}`}>
                <div class="p-perfil-row-media">
                  <img src={`/images/partner-perfiles/perfil-${p.id}.webp`} alt={p.title} loading="lazy" width="1200" height="900" class="p-perfil-row-img" />
                  <span class="p-perfil-row-tag">{p.tag}</span>
                </div>
                <div class="p-perfil-row-body">
                  <div class="p-perfil-row-num">{String(i + 1).padStart(2, '0')}</div>
                  <h3 class="p-perfil-row-title">{p.title}</h3>
                  <p class="p-perfil-row-desc">{p.desc}</p>
                  <div class="p-perfil-row-from">{p.from}</div>
                </div>
              </article>
            ))}
          </div>

          <div class="p-paths-note">
            <strong>Mismo programa, mismas oportunidades, sin límite de crecimiento.</strong>
            Buscamos abrir puertas — no filtrar a quien ya tenía éxito. Donde sea que arranques,
            el programa es gratis mientras lo cumplas, y cualquier camino te lleva a pagos cada
            30 días, comisiones reales y la red de partners SACS detrás tuyo.
          </div>

          <div class="p-bw-bullets">
            <div class="p-bw-bullet"><span class="p-bw-bullet-mark">·</span><span><strong>Comisiones que sí valen el esfuerzo.</strong> 50% sobre venta directa, $250 por cada activación, bonos por demo.</span></div>
            <div class="p-bw-bullet"><span class="p-bw-bullet-mark">·</span><span><strong>Tres formas de sumar puntos.</strong> Contenido publicado, acciones de promoción o actividades filantrópicas.</span></div>
            <div class="p-bw-bullet"><span class="p-bw-bullet-mark">·</span><span><strong>Plan Fideliza gratis ($14k/año).</strong> Para que uses SACS en tu propio negocio o como demo en vivo.</span></div>
            <div class="p-bw-bullet"><span class="p-bw-bullet-mark">·</span><span><strong>Pagos puntuales cada 30 días.</strong> Transparente. Sin letras chicas. Sin "depende de…".</span></div>
          </div>
        </div>

        <!-- ── 2. Por qué SACS · El SER ── -->
        <div class="p-bw-section p-bw-section--alt">
          <div class="p-bw-grid">
            <div>
              <div class="p-bw-eyebrow">Por qué SACS · el origen</div>
              <h2 class="p-bw-title">No vendemos software — construimos un sistema operativo para retailers conscientes.</h2>
            </div>
            <div>
              <p class="p-bw-lead">
                SACS no nació para venderle POS a quien lo pidiera. Nació para construir el
                <strong>sistema operativo del retail mexicano moderno</strong>: una plataforma
                única donde POS, inventario multi-sucursal, e-commerce, CRM, lealtad y
                marketing operen como un solo organismo.
              </p>
            </div>
          </div>

          <div class="p-bw-pillars">
            <div class="p-bw-pillar">
              <div class="p-bw-pillar-num">01</div>
              <div class="p-bw-pillar-title">Para el retailer</div>
              <div class="p-bw-pillar-detail">Una plataforma. Cero islas de información. Decisiones más rápidas. Menos errores. Más tiempo para crecer.</div>
            </div>
            <div class="p-bw-pillar">
              <div class="p-bw-pillar-num">02</div>
              <div class="p-bw-pillar-title">Para el cliente final</div>
              <div class="p-bw-pillar-detail">Experiencia consistente entre tienda física, online y WhatsApp. Recomendaciones relevantes. Lealtad que se siente.</div>
            </div>
            <div class="p-bw-pillar">
              <div class="p-bw-pillar-num">03</div>
              <div class="p-bw-pillar-title">Para la comunidad</div>
              <div class="p-bw-pillar-detail">Embajadores que cobran justo. Proveedores que cobran a tiempo. Equipos que aprenden con la herramienta. Crecimiento compartido.</div>
            </div>
          </div>
        </div>

        <!-- ── 3. Qué nos hace diferentes ── -->
        <div class="p-bw-section">
          <div class="p-bw-eyebrow">En qué nos diferenciamos</div>
          <h2 class="p-bw-title">Cualquiera vende un POS. Pocos resuelven la operación completa.</h2>
          <p class="p-bw-lead">
            El mercado de retail tech mexicano está saturado de plataformas que prometen
            todo y entregan piezas sueltas. Conocemos a los competidores — los respetamos.
            Pero nuestra fundación es distinta:
          </p>

          <div class="p-bw-diff-grid">
            <div class="p-bw-diff">
              <div class="p-bw-diff-head">No somos un parche</div>
              <p>Nacimos integrados de origen. POS, inventario, e-commerce, CRM, marketing — todo desde la misma base de datos, no APIs pegadas con goma.</p>
            </div>
            <div class="p-bw-diff">
              <div class="p-bw-diff-head">Multi-sucursal de verdad</div>
              <p>Funcionamos igual con 1 tienda que con 1,500 (Liveshow lo prueba). El sistema escala sin que tengas que migrar a una versión "enterprise".</p>
            </div>
            <div class="p-bw-diff">
              <div class="p-bw-diff-head">Pensado en LATAM</div>
              <p>CFDI 4.0, IEPS, SAT, RFC, métodos de pago locales, WhatsApp, MercadoPago. No es una traducción de un producto gringo.</p>
            </div>
            <div class="p-bw-diff">
              <div class="p-bw-diff-head">Casos de uso completos</div>
              <p>Resolvemos el caso completo — desde que el producto llega al almacén hasta que el cliente vuelve por segunda vez. No solo "cobrar".</p>
            </div>
          </div>
        </div>

        <!-- ── 4. Verticales en orden de prioridad ── -->
        <div class="p-bw-section p-bw-section--alt">
          <div class="p-bw-eyebrow">Quién usa SACS</div>
          <h2 class="p-bw-title">16 verticales con módulos hechos a la medida.</h2>
          <p class="p-bw-lead">
            No es un POS genérico. Cada vertical tiene los módulos exactos que
            necesita — variantes, certificados, reabastos, permisos. Esto te da
            argumentos reales con cada prospecto.
          </p>

          <div class="p-bw-verticals">
            {PRIORITY_SECTORS.map((sector, i) => (
              <article class="p-bw-vertical" style={`--accent: ${sector.color}; --accent-bg: ${sector.bgColor};`}>
                {sector.image && (
                  <div class="p-bw-vertical-media">
                    <img
                      src={sector.image}
                      alt={sector.label}
                      width="800"
                      height="533"
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="p-bw-vertical-rank">{String(i + 1).padStart(2, '0')}</div>
                  </div>
                )}
                <div class="p-bw-vertical-body">
                  <div class="p-bw-vertical-eyebrow">
                    <span class="p-bw-vertical-dot" aria-hidden="true"></span>
                    {sector.description}
                  </div>
                  <h3 class="p-bw-vertical-name">{sector.label}</h3>
