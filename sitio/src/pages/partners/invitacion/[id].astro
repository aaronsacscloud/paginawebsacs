// ── i18n + Currency conversion para la invitación ──────────────
// Detectamos lang vía ?lang=en (default es). Las cifras se convierten
// de MXN a la moneda del idioma. El acuerdo legal sigue siendo MXN.
type Lang = 'es' | 'en' | 'fr' | 'it' | 'pt';
const SUPPORTED_LANGS: Lang[] = ['es', 'en', 'fr', 'it', 'pt'];
const langParam = (Astro.url.searchParams.get('lang') || 'es').toLowerCase();
const lang: Lang = (SUPPORTED_LANGS.includes(langParam as Lang) ? langParam : 'es') as Lang;
const isLocalized = lang !== 'es';

// Tasas de cambio aprox (MXN base). Refresh manual cada cierto tiempo.
const FX: Record<Lang, { code: string; symbol: string; rate: number; locale: string }> = {
  es: { code: 'MXN', symbol: '$',  rate: 1,       locale: 'es-MX' },
  en: { code: 'USD', symbol: '$',  rate: 1 / 18,  locale: 'en-US' },
  fr: { code: 'EUR', symbol: '€',  rate: 1 / 19.5, locale: 'fr-FR' },
  it: { code: 'EUR', symbol: '€',  rate: 1 / 19.5, locale: 'it-IT' },
  pt: { code: 'BRL', symbol: 'R$', rate: 1 / 3.6,  locale: 'pt-BR' },
};
function fmtLocalMoney(mxn: number): string {
  if (!Number.isFinite(mxn)) return '';
  const fx = FX[lang];
  const converted = mxn * fx.rate;
  // Redondeamos sensatamente: <100 → enteros, >=100 → enteros sin decimales
  const rounded = converted < 1 ? Math.round(converted * 100) / 100 : Math.round(converted);
  try {
    return new Intl.NumberFormat(fx.locale, {
      style: 'currency',
      currency: fx.code,
      minimumFractionDigits: 0,
      maximumFractionDigits: converted < 1 ? 2 : 0,
    }).format(rounded);
  } catch {
    return `${fx.symbol}${rounded.toLocaleString('es-MX')} ${fx.code}`;
  }
}

