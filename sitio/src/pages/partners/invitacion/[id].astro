---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { supabase } from '../../../lib/supabase';
import PartnerSidebar from '../../../components/partner/PartnerSidebar.astro';

export const prerender = false;

const { id } = Astro.params;
const isAdminMode = Astro.url.searchParams.has('admin');

const { data: invitation } = await supabase
  .from('partner_invitations')
  .select('*')
  .eq('id', id)
  .maybeSingle();

if (!invitation) return Astro.redirect('/404');

// Auto-expire if vigencia passed
const isExpired = invitation.vigencia && new Date(invitation.vigencia) < new Date();
if (isExpired && invitation.estado === 'sent') {
  await supabase.from('partner_invitations').update({ estado: 'expired' }).eq('id', id);
  invitation.estado = 'expired';
}

// Mark as viewed (first opening, not by admin)
if (invitation.estado === 'draft' || invitation.estado === 'sent') {
  if (!isAdminMode && invitation.estado === 'sent') {
    // Track view via activity (non-blocking)
    try {
      await supabase.from('activities').insert({
        tipo: 'sistema',
        titulo: `Invitación de partner vista por prospecto`,
        metadata: { partner_invitation_id: id, partner_invitation_numero: invitation.numero },
        automatico: true,
      });
    } catch {}
  }
}

// Parse meta from notas (firma_base64 etc.)
const NOTAS_SEP = '\n---META---\n';
const notasIdx = (invitation.notas || '').indexOf(NOTAS_SEP);
const meta = notasIdx >= 0 ? (() => {
  try { return JSON.parse(invitation.notas.slice(notasIdx + NOTAS_SEP.length)); } catch { return {}; }
})() : {};

const template = invitation.template || 'modern';
const tipo = invitation.tipo || 'embajador';
const moneda = invitation.moneda || 'MXN';
const comisionPct = Number(invitation.comision_pct ?? 50);
const costoUnico = Number(invitation.costo_unico ?? 0);
const costoMensual = Number(invitation.costo_mensual ?? 0);

const beneficios: any[] = Array.isArray(invitation.beneficios) ? invitation.beneficios : [];
const compromisos: any[] = Array.isArray(invitation.compromisos) ? invitation.compromisos : [];
const tabulador: any = invitation.tabulador && typeof invitation.tabulador === 'object' ? invitation.tabulador : {};

const isAccepted = invitation.estado === 'accepted';
const isDeclined = invitation.estado === 'declined';
const isClosed = isAccepted || isDeclined;

const fmt = (n: number) => n === 0 ? 'Gratis' : '$' + Math.round(n).toLocaleString('es-MX');
const fmtMoney = (n: number) => '$' + Math.round(n).toLocaleString('es-MX');
const fmtDate = (d: string | null) => {
  if (!d) return '';
  const date = new Date(d.length === 10 ? d + 'T12:00:00' : d);
  if (isNaN(date.getTime())) return '';
  const day = date.getDate();
  const month = date.toLocaleDateString('es-MX', { month: 'short' }).replace('.', '');
  const year = date.getFullYear();
  return `${day}/${month}/${year}`;
};
const fmtDateLong = (d: string | null) => {
  if (!d) return '';
  const date = new Date(d.length === 10 ? d + 'T12:00:00' : d);
  if (isNaN(date.getTime())) return '';
  const day = date.getDate();
  const month = date.toLocaleDateString('es-MX', { month: 'long' });
  const year = date.getFullYear();
  return `${day} de ${month} de ${year}`;
};

const fechaCreado = fmtDate(invitation.created_at);
const vigenciaFecha = fmtDate(invitation.vigencia);
const vigenciaLarga = fmtDateLong(invitation.vigencia);

const tipoLabel: Record<string, string> = {
  embajador: 'Embajador SACS',
  distribuidor: 'Distribuidor Autorizado',
  integrador: 'Integrador Certificado',
  reseller: 'Reseller',
  consultor: 'Consultor Partner',
};
const tipoTagline: Record<string, string> = {
  embajador: 'Difunde, recomienda y crece con SACS. Tu voz mueve marcas.',
  distribuidor: 'Vende SACS a tu red. Comisiones recurrentes mientras estén activos.',
  integrador: 'Implementa SACS en clientes B2B. Soporte técnico y handoff cualificado.',
  reseller: 'Modelo white-label para vender SACS bajo tu marca o canal.',
  consultor: 'Asesora a clientes en su transformación digital con SACS.',
};

const heroEyebrow = `Invitación · Programa Partners`;
const heroTitle = invitation.nombre;
const heroSubtitle = tipoTagline[tipo] || '';

const tabsDef = [
  { id: 'bienvenida', label: 'Bienvenida', show: true },
  { id: 'beneficios', label: 'Beneficios', show: beneficios.length > 0 },
  { id: 'terminos', label: 'Términos', show: true },
  { id: 'compromisos', label: 'Compromisos', show: compromisos.length > 0 },
  { id: 'tabulador', label: 'Tabulador', show: Object.keys(tabulador).length > 0 },
  { id: 'porque', label: '¿Por qué SACS?', show: true },
  { id: 'firma', label: isAccepted ? 'Firmada' : (isDeclined ? 'Rechazada' : 'Aceptar y firmar'), show: true },
];
const visibleTabs = tabsDef.filter(t => t.show).map(({ id, label }) => ({ id, label }));
const initialTab = isClosed ? 'firma' : 'bienvenida';

const beneficioIcons: Record<string, string> = {
  gift: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>',
  percent: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>',
  academy: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>',
  community: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>',
  reward: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>',
  leads: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>',
  default: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>',
};

const partnerLandingUrl = invitation.slug_landing
  ? `https://www.sacscloud.com/p/${invitation.slug_landing}`
  : `https://www.sacscloud.com/p/${(invitation.numero || '').toLowerCase()}`;
---

<BaseLayout
  title={`Invitación Partner ${invitation.numero || ''} — SACS`}
  description={`Programa de partners SACS para ${invitation.nombre}`}
  noindex={true}
>

<div class:list={['p-layout', `p-layout--${template}`]}>
  <aside class="p-layout-sidebar no-print">
    <PartnerSidebar
      tabs={visibleTabs}
      initialTab={initialTab}
      numero={invitation.numero}
      nombre={invitation.nombre}
      tipo={tipo}
      comisionPct={comisionPct}
      template={template}
      isAccepted={isAccepted}
      isDeclined={isDeclined}
      isExpired={!!isExpired}
      vigenciaFecha={vigenciaFecha}
    />
  </aside>

  <div class:list={['p-page', `p-${template}`]} id="partner-doc" data-initial-tab={initialTab}>
    <div class="p-container">

      <!-- Header -->
      <div class="p-header">
        <div class="p-header-brand">
          <span class="p-logo-text">Sacs</span>
          <span class="p-logo-tag">Partners</span>
        </div>
        <div class="p-header-meta">
          {isAccepted && <span class="p-status p-status--accepted"><span class="p-status-dot"></span>Firmada</span>}
          {isDeclined && <span class="p-status p-status--declined"><span class="p-status-dot"></span>Rechazada</span>}
          {isExpired && !isClosed && <span class="p-status p-status--expired"><span class="p-status-dot"></span>Vencida</span>}
          {!isExpired && !isClosed && <span class="p-status p-status--active"><span class="p-status-dot"></span>Activa</span>}
          <div class="p-numero">{invitation.numero}</div>
          <div class="p-fecha">Emitida {fechaCreado}</div>
          {!isClosed && !isExpired && vigenciaFecha && (
            <div class="p-fecha">Vigente hasta {vigenciaFecha}</div>
          )}
        </div>
      </div>

      <!-- TAB: BIENVENIDA -->
      <section class="p-tab-panel" data-tab="bienvenida">
        <div class="p-hero">
          <div class="p-hero-eyebrow">{heroEyebrow}</div>
          <h1 class="p-hero-title">
            {invitation.nombre},<br/>
            <span class="p-hero-title-soft">queremos que seas</span><br/>
            <span class="p-hero-title-strong">{tipoLabel[tipo] || tipo}</span>.
          </h1>
          <p class="p-hero-sub">{heroSubtitle}</p>

          <div class="p-hero-stats">
            <div class="p-hero-stat">
              <div class="p-hero-stat-num">{comisionPct}<span class="p-hero-stat-pct">%</span></div>
              <div class="p-hero-stat-label">Comisión por venta</div>
            </div>
            <div class="p-hero-stat">
              <div class="p-hero-stat-num">{costoMensual === 0 && costoUnico === 0 ? 'Gratis' : (costoMensual > 0 ? fmtMoney(costoMensual) : fmtMoney(costoUnico))}</div>
              <div class="p-hero-stat-label">{costoMensual === 0 && costoUnico === 0 ? 'Acceso al sistema' : (costoMensual > 0 ? 'Cuota mensual' : 'Cuota única')}</div>
            </div>
            <div class="p-hero-stat">
              <div class="p-hero-stat-num">3K+</div>
              <div class="p-hero-stat-label">Marcas en la red SACS</div>
            </div>
          </div>

          <div class="p-hero-quick">
            <div class="p-hero-quick-row">
              <span class="p-hero-quick-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span>Lo que sigue: revisa beneficios, términos y firma cuando estés listo.</span>
            </div>
          </div>
        </div>

        <!-- Index -->
        <div class="p-tab-intro-nav">
          {visibleTabs.filter(t => t.id !== 'bienvenida' && t.id !== 'firma').map(t => (
            <a href={`#${t.id}`} class="p-tab-intro-link" data-tab-link={t.id}>
              <span class="p-tab-intro-link-label">{t.label}</span>
              <span class="p-tab-intro-link-arrow">→</span>
            </a>
          ))}
        </div>
      </section>

      <!-- TAB: BENEFICIOS -->
      {beneficios.length > 0 && (
      <section class="p-tab-panel" data-tab="beneficios">
        <div class="p-section-head">
          <div class="p-section-eyebrow">Lo que recibes</div>
          <h2 class="p-section-title">Beneficios de ser partner</h2>
          <p class="p-section-lead">
            Todo lo que necesitas para representar SACS, vender con confianza y crecer junto con nosotros.
          </p>
        </div>

        <div class="p-benefits-grid">
          {beneficios.map((b: any) => (
            <div class="p-benefit-card">
              <div class="p-benefit-icon" set:html={beneficioIcons[b.icon] || beneficioIcons.default}></div>
              <div class="p-benefit-title">{b.title}</div>
              <div class="p-benefit-detail">{b.detail}</div>
            </div>
          ))}
        </div>
      </section>
      )}

      <!-- TAB: TÉRMINOS -->
      <section class="p-tab-panel" data-tab="terminos">
        <div class="p-section-head">
          <div class="p-section-eyebrow">Las reglas claras</div>
          <h2 class="p-section-title">Términos económicos</h2>
          <p class="p-section-lead">
            Sin letras chicas. Esto es lo que ganas y lo que cuesta participar.
          </p>
        </div>

        <div class="p-terms">
          <div class="p-term-row p-term-row--big">
            <div class="p-term-info">
              <div class="p-term-label">Comisión por venta directa</div>
              <div class="p-term-detail">Sobre el monto cobrado al cliente cuando facturamos vía tu link único.</div>
            </div>
            <div class="p-term-value p-term-value--accent">{comisionPct}%</div>
          </div>

          <div class="p-term-row">
            <div class="p-term-info">
              <div class="p-term-label">Cuota única de inscripción</div>
              <div class="p-term-detail">{costoUnico === 0 ? 'No aplica para este programa.' : 'Pago único al activar tu programa.'}</div>
            </div>
            <div class="p-term-value">{costoUnico === 0 ? 'Sin costo' : fmtMoney(costoUnico) + ' ' + moneda}</div>
          </div>

          <div class="p-term-row">
            <div class="p-term-info">
              <div class="p-term-label">Cuota mensual del sistema SACS</div>
              <div class="p-term-detail">{costoMensual === 0 ? 'Acceso completo gratis mientras cumplas los compromisos del programa.' : 'Suscripción mensual al sistema SACS para uso interno y demos.'}</div>
            </div>
            <div class="p-term-value">{costoMensual === 0 ? 'Gratis' : fmtMoney(costoMensual) + ' / mes'}</div>
          </div>

          <div class="p-term-row">
            <div class="p-term-info">
              <div class="p-term-label">Vigencia de la invitación</div>
              <div class="p-term-detail">Después de esta fecha la invitación se cierra y deberá renegociarse.</div>
            </div>
            <div class="p-term-value">{vigenciaLarga || 'Sin vencimiento'}</div>
          </div>
        </div>

        {invitation.terminos && (
          <div class="p-terms-extra">
            <div class="p-terms-extra-title">Condiciones generales</div>
            <p class="p-terms-extra-text">{invitation.terminos}</p>
          </div>
        )}
      </section>

      <!-- TAB: COMPROMISOS -->
      {compromisos.length > 0 && (
      <section class="p-tab-panel" data-tab="compromisos">
        <div class="p-section-head">
          <div class="p-section-eyebrow">Lo que esperamos de ti</div>
          <h2 class="p-section-title">Tus compromisos como partner</h2>
          <p class="p-section-lead">
            Para mantener tus beneficios activos, esto es lo que necesitamos de tu lado.
          </p>
        </div>

        <div class="p-commits">
          {compromisos.map((c: any, i: number) => (
            <div class="p-commit-row">
              <div class="p-commit-num">{String(i + 1).padStart(2, '0')}</div>
              <div class="p-commit-content">
                <div class="p-commit-title">{c.title}</div>
                <div class="p-commit-detail">{c.detail}</div>
                {c.frequency && <div class="p-commit-frequency">{c.frequency}</div>}
              </div>
            </div>
          ))}
        </div>

        <div class="p-commit-note">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          <span>Si dejas de cumplir los compromisos, te avisaremos y tendrás 30 días para regularizar antes de pausar tus beneficios.</span>
        </div>
      </section>
      )}

      <!-- TAB: TABULADOR -->
      {Object.keys(tabulador).length > 0 && (
      <section class="p-tab-panel" data-tab="tabulador">
        <div class="p-section-head">
          <div class="p-section-eyebrow">Cómo cobras</div>
          <h2 class="p-section-title">Tabulador de recompensas</h2>
          <p class="p-section-lead">
            Te pagamos por cada paso del proceso, no sólo por la venta final.
          </p>
        </div>

        <div class="p-payout-grid">
          {tabulador.demo_agendada !== undefined && (
            <div class="p-payout-card">
              <div class="p-payout-step">Paso 1</div>
              <div class="p-payout-amount">{tabulador.demo_agendada > 0 ? fmtMoney(tabulador.demo_agendada) : '—'}</div>
              <div class="p-payout-name">Demo agendada</div>
              <div class="p-payout-detail">Por cada demo confirmada con un prospecto calificado que tú agendas.</div>
            </div>
          )}
          {tabulador.demo_completada !== undefined && (
            <div class="p-payout-card">
              <div class="p-payout-step">Paso 2</div>
              <div class="p-payout-amount">{tabulador.demo_completada > 0 ? fmtMoney(tabulador.demo_completada) : '—'}</div>
              <div class="p-payout-name">Demo completada</div>
              <div class="p-payout-detail">Cuando el prospecto asiste y completa el demo válido.</div>
            </div>
          )}
          {tabulador.venta_directa_pct !== undefined && (
            <div class="p-payout-card p-payout-card--featured">
              <div class="p-payout-step">Paso 3</div>
              <div class="p-payout-amount">{tabulador.venta_directa_pct}%</div>
              <div class="p-payout-name">Venta directa</div>
              <div class="p-payout-detail">Comisión sobre el cobro de la primera factura del cliente cerrado.</div>
            </div>
          )}
        </div>

        {tabulador.notas && (
          <div class="p-payout-notes">
            <div class="p-payout-notes-title">Cómo se calculan los pagos</div>
            <p>{tabulador.notas}</p>
          </div>
        )}

        <!-- Tu link / landing -->
        <div class="p-landing">
          <div class="p-landing-eyebrow">Tu landing personalizada</div>
          <div class="p-landing-url">{partnerLandingUrl}</div>
          <p class="p-landing-detail">
            Al firmar tu invitación se activa un link y landing con tu nombre. Cualquier prospecto que llegue por este link se atribuye a ti automáticamente.
          </p>
        </div>
      </section>
      )}

      <!-- TAB: ¿POR QUÉ SACS? -->
      <section class="p-tab-panel" data-tab="porque">
        <div class="p-section-head">
          <div class="p-section-eyebrow">Por qué SACS</div>
          <h2 class="p-section-title">El sistema operativo del retail mexicano</h2>
          <p class="p-section-lead">
            Más de 3,000 marcas en LATAM operan con SACS. Recomendar SACS no es vender software — es recomendar la mejor versión de su negocio.
          </p>
        </div>

        <div class="p-why-stats">
          <div class="p-why-stat">
            <div class="p-why-stat-num">3,000+</div>
            <div class="p-why-stat-label">Marcas activas</div>
          </div>
          <div class="p-why-stat">
            <div class="p-why-stat-num">42M+</div>
            <div class="p-why-stat-label">Transacciones procesadas</div>
          </div>
          <div class="p-why-stat">
            <div class="p-why-stat-num">8</div>
            <div class="p-why-stat-label">Países en LATAM</div>
          </div>
          <div class="p-why-stat">
            <div class="p-why-stat-num">96%</div>
            <div class="p-why-stat-label">Retención anual</div>
          </div>
        </div>

        <div class="p-why-pillars">
          <div class="p-why-pillar">
            <div class="p-why-pillar-letter">S</div>
            <div class="p-why-pillar-word">Ser</div>
            <p>Ser auténticos. Tu marca tiene una identidad — nuestro trabajo es potenciarla, no reemplazarla.</p>
          </div>
          <div class="p-why-pillar">
            <div class="p-why-pillar-letter">A</div>
            <div class="p-why-pillar-word">Avanzar</div>
            <p>Avanzar con tecnología que resuelve problemas reales, no los de alguien más.</p>
          </div>
          <div class="p-why-pillar">
            <div class="p-why-pillar-letter">C</div>
            <div class="p-why-pillar-word">Crear</div>
            <p>Crear experiencias que inspiran — para tus clientes, tu equipo y tu comunidad.</p>
          </div>
          <div class="p-why-pillar">
            <div class="p-why-pillar-letter">S</div>
            <div class="p-why-pillar-word">Sembrar</div>
            <p>Sembrar para el futuro. Tu éxito impulsa programas de impacto en comunidades mexicanas.</p>
          </div>
        </div>

        <div class="p-why-closing">
          <strong>El 10% de cada licencia genera cambio real.</strong>
          <span>Capacitación digital, apoyo a emprendedores locales y conservación de ecosistemas en México. Comercio consciente significa que cada transacción tiene propósito — y como partner, tú eres parte del impacto.</span>
        </div>
      </section>

      <!-- TAB: FIRMA -->
      <section class="p-tab-panel" data-tab="firma">
        {isAccepted ? (
          <div class="p-signed">
            <div class="p-signed-eyebrow">Firmada</div>
            <div class="p-signed-title">Bienvenido al equipo, {invitation.aceptado_por || invitation.nombre}.</div>
            <div class="p-signed-sub">
              Tu programa <strong>{tipoLabel[tipo] || tipo}</strong> está activo. En breve recibirás un correo con las credenciales del sistema, acceso a la academia y tu link de partner.
            </div>
            {meta.firma_base64 && (
              <img src={meta.firma_base64} alt="Firma" class="p-signed-img" />
            )}
            {invitation.aceptado_por && (
              <div class="p-signed-label">Firmada por {invitation.aceptado_por}</div>
            )}
            {invitation.aceptado_fecha && (
              <div class="p-signed-date">{fmtDate(invitation.aceptado_fecha)}</div>
            )}
            <div class="p-signed-cta-row">
              <a href="https://www.sacscloud.com/admin/crm" class="p-signed-cta">Ir al panel SACS</a>
            </div>
          </div>
        ) : isDeclined ? (
          <div class="p-signed p-signed--declined">
            <div class="p-signed-eyebrow">Rechazada</div>
            <div class="p-signed-title">Gracias por tu respuesta.</div>
            <div class="p-signed-sub">Tu feedback nos ayuda a mejorar el programa. Si cambias de opinión, escríbenos a partners@sacscloud.com y reactivamos tu invitación.</div>
            {invitation.decline_motivo && (
              <div class="p-signed-meta">Motivo: <strong>{invitation.decline_motivo}</strong>{invitation.decline_detalle ? ` · ${invitation.decline_detalle}` : ''}</div>
            )}
          </div>
        ) : isExpired ? (
          <div class="p-signed p-signed--expired">
            <div class="p-signed-eyebrow">Vencida</div>
            <div class="p-signed-title">Esta invitación venció el {vigenciaLarga}.</div>
            <div class="p-signed-sub">Si todavía te interesa el programa, contáctanos y te enviamos una invitación renovada.</div>
            <div class="p-signed-cta-row">
              <a class="p-signed-cta" href={`https://wa.me/5215512345678?text=${encodeURIComponent(`Hola, mi invitación de partner ${invitation.numero || ''} venció. Me gustaría renovarla.`)}`} target="_blank" rel="noopener">Renovar invitación</a>
            </div>
          </div>
        ) : (
          <div class="p-sign-form">
            <div class="p-section-head p-section-head--center">
              <div class="p-section-eyebrow">Último paso</div>
              <h2 class="p-section-title">Acepta y firma tu invitación</h2>
              <p class="p-section-lead">
                Al firmar, activamos tu programa <strong>{tipoLabel[tipo] || tipo}</strong>, te creamos tu cuenta SACS y enviamos las credenciales a tu correo.
              </p>
            </div>

            <div class="p-sign-fields">
              <label class="p-sign-field">
                <span>Nombre completo</span>
                <input type="text" id="sign-nombre" class="p-input" placeholder="Ej. Mariana López" value={invitation.nombre || ''} />
              </label>
              <label class="p-sign-field">
                <span>Email</span>
                <input type="email" id="sign-email" class="p-input" placeholder="tu@correo.com" value={invitation.email || ''} />
              </label>
              <label class="p-sign-field">
                <span>WhatsApp</span>
                <input type="tel" id="sign-whatsapp" class="p-input" placeholder="55 1234 5678" value={invitation.whatsapp || ''} />
              </label>
            </div>

            <div class="p-sign-canvas-wrap">
              <div class="p-sign-canvas-label">Firma con el dedo o el mouse</div>
              <canvas id="signature-canvas" class="p-sign-canvas" width="600" height="180"></canvas>
              <div class="p-sign-canvas-actions">
                <button type="button" class="p-btn p-btn--ghost" id="btn-clear-sig">Limpiar firma</button>
              </div>
            </div>

            <div class="p-sign-legal">
              Al aceptar y firmar confirmas que has leído y aceptas los
              <a href="/terminos" target="_blank" rel="noopener">Términos y condiciones</a> y el
              <a href="/privacidad" target="_blank" rel="noopener">Aviso de privacidad</a>.
            </div>

            <div class="p-sign-actions">
              <button type="button" class="p-btn p-btn--primary" id="btn-accept">Aceptar y activar mi programa</button>
              <button type="button" class="p-btn p-btn--ghost" id="btn-decline">No me interesa por ahora</button>
            </div>
          </div>
        )}
      </section>

      <!-- Footer -->
      <div class="p-footer">
        <div class="p-footer-brand">
          <span class="p-footer-logo">Sacs</span>
          <span class="p-footer-tagline">Sistema operativo para retailers</span>
        </div>
        <div class="p-footer-contact">www.sacscloud.com · partners@sacscloud.com</div>
      </div>
    </div>
  </div>
</div>

<!-- Decline modal -->
{!isClosed && !isExpired && (
<div class="p-modal-overlay no-print" id="decline-modal" style="display:none">
  <div class="p-modal">
    <div class="p-modal-header">
      <span class="p-modal-title">¿Por qué no es para ti?</span>
      <button type="button" class="p-modal-close" id="btn-close-decline">✕</button>
    </div>
    <div class="p-modal-body">
      <p class="p-modal-text">Tu respuesta nos ayuda a mejorar el programa. Selecciona el motivo principal:</p>
      <div class="p-decline-reasons">
        <label class="p-decline-reason"><input type="radio" name="decline-motivo" value="no_tengo_audiencia" /> <span>No tengo audiencia o red para recomendar SACS</span></label>
        <label class="p-decline-reason"><input type="radio" name="decline-motivo" value="comision_baja" /> <span>La comisión no me parece atractiva</span></label>
        <label class="p-decline-reason"><input type="radio" name="decline-motivo" value="compromiso_alto" /> <span>El compromiso de contenido es muy alto</span></label>
        <label class="p-decline-reason"><input type="radio" name="decline-motivo" value="timing" /> <span>No es buen momento, lo veo más adelante</span></label>
        <label class="p-decline-reason"><input type="radio" name="decline-motivo" value="otro" /> <span>Otro motivo</span></label>
      </div>
      <label class="p-sign-field" style="margin-top:14px">
        <span>Detalle (opcional)</span>
        <textarea id="decline-detalle" class="p-input" rows="3" placeholder="Cuéntanos más..."></textarea>
      </label>
    </div>
    <div class="p-modal-footer">
      <button class="p-btn p-btn--ghost" id="btn-cancel-decline" type="button">Cancelar</button>
      <button class="p-btn p-btn--primary" id="btn-confirm-decline" type="button">Enviar respuesta</button>
    </div>
  </div>
</div>
)}

</BaseLayout>

<style is:global>
