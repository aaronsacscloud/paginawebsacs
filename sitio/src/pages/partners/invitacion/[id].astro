  /* ─── Tu potencial — proyección de ganancias ─── */
  .p-projection-block { margin: 8px 0 56px; }

  /* Toggle Mensual / Anual */
  .p-projection-toggle {
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    background: #fafafa;
    border: 1px solid #e5e5e5;
    border-radius: 14px;
