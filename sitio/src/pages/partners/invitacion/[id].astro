  'sign.s.payment':  { es: 'Cómo recibes tus comisiones', en: 'How you receive commissions', fr: 'Comment vous recevez vos commissions', it: 'Come ricevi le commissioni', pt: 'Como você recebe suas comissões' },
  'sign.s.signature':{ es: 'Firma de aceptación', en: 'Acceptance signature', fr: 'Signature d\'acceptation', it: 'Firma di accettazione', pt: 'Assinatura de aceitação' },
  // Designación de beneficiarios (cláusula 6-bis c5): opcional, hasta 3.
  'sign.s.beneficiarios': { es: 'Beneficiarios de tus comisiones', en: 'Beneficiaries of your commissions', fr: 'Bénéficiaires de vos commissions', it: 'Beneficiari delle tue commissioni', pt: 'Beneficiários das suas comissões' },
  'sign.benef.help': { es: 'Opcional. Conforme a la cláusula 6-bis, si algún día faltas o quedas incapacitado, tus comisiones recurrentes pasan a quien designes aquí durante 24 o 36 meses. Puedes registrar hasta 3 personas con el porcentaje de cada una — o dejarlo en blanco y decidirlo después (puedes cambiarlo cuando quieras; prevalece la última que reciba SACS). Si registras, los porcentajes deben sumar 100%.', en: 'Optional. Under clause 6-bis, if you ever pass away or become incapacitated, your recurring commissions go to whoever you designate here for 24 or 36 months. You may list up to 3 people with each one\'s percentage — or leave it blank and decide later (you can change it anytime; the last one SACS receives prevails). If you list any, the percentages must add up to 100%.', fr: 'Facultatif. Selon la clause 6-bis, si un jour vous décédez ou devenez incapable, vos commissions récurrentes reviennent à qui vous désignez ici pendant 24 ou 36 mois. Vous pouvez inscrire jusqu\'à 3 personnes avec le pourcentage de chacune — ou laisser vide et décider plus tard (modifiable à tout moment ; la dernière reçue par SACS prévaut). Si vous en inscrivez, les pourcentages doivent totaliser 100 %.', it: 'Facoltativo. Ai sensi della clausola 6-bis, se un giorno venissi a mancare o diventassi incapace, le tue commissioni ricorrenti passano a chi designi qui per 24 o 36 mesi. Puoi indicare fino a 3 persone con la percentuale di ciascuna — oppure lasciare vuoto e decidere dopo (modificabile in qualsiasi momento; prevale l\'ultima ricevuta da SACS). Se ne indichi, le percentuali devono sommare 100%.', pt: 'Opcional. Conforme a cláusula 6-bis, se um dia você falecer ou ficar incapacitado, suas comissões recorrentes passam a quem você designar aqui por 24 ou 36 meses. Você pode registrar até 3 pessoas com o percentual de cada uma — ou deixar em branco e decidir depois (pode alterar quando quiser; prevalece a última recebida pela SACS). Se registrar, os percentuais devem somar 100%.' },
  'f.benef.nombre': { es: 'Nombre completo del beneficiario', en: 'Beneficiary full name', fr: 'Nom complet du bénéficiaire', it: 'Nome completo del beneficiario', pt: 'Nome completo do beneficiário' },
  'f.benef.parentesco': { es: 'Parentesco o relación', en: 'Relationship', fr: 'Lien de parenté', it: 'Parentela o relazione', pt: 'Parentesco ou relação' },
  'f.benef.pct': { es: '% que le corresponde', en: '% share', fr: '% attribué', it: '% spettante', pt: '% correspondente' },
  'sign.benef.add': { es: '＋ Agregar otro beneficiario', en: '＋ Add another beneficiary', fr: '＋ Ajouter un bénéficiaire', it: '＋ Aggiungi un beneficiario', pt: '＋ Adicionar outro beneficiário' },
  'sign.benef.remove': { es: 'Quitar', en: 'Remove', fr: 'Retirer', it: 'Rimuovi', pt: 'Remover' },
