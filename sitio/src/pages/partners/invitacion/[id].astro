  /* ── Override 10% — hero + ejemplos por hito ── */
  .p-network-ben-lead {
    font-size: 1rem;
    color: #555;
    line-height: 1.65;
    margin: 0 0 28px;
    max-width: 760px;
  }
  .p-network-ben-lead strong { color: #1a1a1a; font-weight: 600; }

  .p-network-ex-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  @media (max-width: 920px) {
    .p-network-ex-grid { grid-template-columns: 1fr; }
  }

  .p-network-ex-card {
    padding: 28px 28px 26px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 14px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
  }
  .p-network-ex-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.06);
    border-color: #d9d9d9;
  }
  .p-network-ex-card--builder {
    background: linear-gradient(180deg, #14141a 0%, #0f0f12 100%);
    border-color: #14141a;
    color: #f5efe6;
  }
  .p-network-ex-card--builder:hover { border-color: #c9a96b; }

  .p-network-ex-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  .p-network-ex-num {
    font-family: Georgia, "Times New Roman", serif;
    font-style: italic;
    font-size: 1.125rem;
    color: #999;
    letter-spacing: -0.02em;
  }
  .p-network-ex-tier {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .p-network-ex-card--builder .p-network-ex-num { color: rgba(245, 239, 230, 0.5); }
  .p-network-ex-card--builder .p-network-ex-tier { color: #c9a96b; }

  .p-network-ex-partners {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .p-network-ex-partners-num {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1a1a1a;
    letter-spacing: -0.01em;
  }
  .p-network-ex-partners-lbl {
    font-size: 0.8125rem;
    color: #777;
  }
  .p-network-ex-card--builder .p-network-ex-partners-num { color: #f5efe6; }
  .p-network-ex-card--builder .p-network-ex-partners-lbl { color: rgba(245, 239, 230, 0.6); }

  .p-network-ex-amount {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-top: 4px;
  }
  .p-network-ex-amount-num {
    font-size: 2.25rem;
    font-weight: 500;
    color: #1a1a1a;
    letter-spacing: -0.025em;
    line-height: 1;
  }
  .p-network-ex-amount-period {
    font-size: 0.875rem;
    color: #888;
  }
  .p-network-ex-card--builder .p-network-ex-amount-num { color: #c9a96b; }
  .p-network-ex-card--builder .p-network-ex-amount-period { color: rgba(201, 169, 107, 0.7); }

  .p-network-ex-monthly {
    font-size: 0.8125rem;
    color: #888;
    letter-spacing: 0.005em;
  }
  .p-network-ex-card--builder .p-network-ex-monthly { color: rgba(245, 239, 230, 0.55); }

  .p-network-ex-detail {
    margin: 8px 0 0;
    padding-top: 14px;
    border-top: 1px solid #ececec;
    font-size: 0.8125rem;
    color: #777;
    line-height: 1.55;
  }
  .p-network-ex-card--builder .p-network-ex-detail {
    color: rgba(245, 239, 230, 0.55);
    border-top-color: rgba(245, 239, 230, 0.12);
  }

  .p-network-ex-legal {
    margin: 18px 0 0;
    font-size: 0.75rem;
    color: #999;
    line-height: 1.5;
  }

  /* ── #10 Storyboard de invitación ── */
  .p-network-story {
    margin: 56px 0;
  }
  .p-network-story-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .p-network-story-fig {
    margin: 0;
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
    border: 1px solid #ececec;
  }
  .p-network-story-fig img {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
  }
  .p-network-story-fig figcaption {
    padding: 16px 20px 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .p-network-story-lbl {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .p-network-story-cap {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.55;
  }
  @media (max-width: 720px) {
    .p-network-story-grid { grid-template-columns: 1fr; }
  }

  /* ── #8 Wall de Network Builders ── */
  .p-network-wall {
    margin: 56px 0;
    padding: 36px 32px;
    background: linear-gradient(180deg, #fafaf7 0%, #f5f0e6 100%);
    border-radius: 16px;
  }
  .p-network-wall-lead {
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.6;
    margin: 8px 0 24px;
    max-width: 720px;
  }
  .p-network-wall-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
  }
  .p-network-wall-cell {
    border-radius: 10px;
    overflow: hidden;
    background: #eee;
    aspect-ratio: 1 / 1;
    transition: transform 200ms ease;
  }
  .p-network-wall-cell:hover { transform: scale(1.02); }
  .p-network-wall-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (max-width: 920px) {
    .p-network-wall-grid { grid-template-columns: repeat(4, 1fr); }
  }
  @media (max-width: 560px) {
    .p-network-wall { padding: 24px 18px; }
    .p-network-wall-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── #4 Closing wide ── */
  .p-network-closing {
    margin: 32px 0 0;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.06);
  }
  .p-network-closing img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .p-payout-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-top: 8px;
  }
  @media (max-width: 720px) { .p-payout-grid { grid-template-columns: 1fr; } }

  .p-payout-card {
    padding: 28px 22px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    display: flex; flex-direction: column; gap: 8px;
  }
  .p-payout-card--featured {
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d3f 100%);
    color: #fff;
    border: none;
  }
  .p-payout-step {
    font-size: 0.625rem; font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  .p-payout-card--featured .p-payout-step { color: #93b4ff; }
  .p-payout-amount {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 300;
    color: #1a1a1a;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .p-payout-card--featured .p-payout-amount { color: #fff; }
  .p-payout-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: #1a1a1a;
    letter-spacing: -0.005em;
  }
  .p-payout-card--featured .p-payout-name { color: #fff; }
  .p-payout-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.6);
    line-height: 1.5;
    margin-top: 4px;
  }
  .p-payout-card--featured .p-payout-detail { color: rgba(255,255,255,0.65); }
  .p-payout-card--featured .p-payout-detail strong { color: #fff; }

  /* Layout 2-col (Venta directa + Override) */
  .p-payout-grid--2col {
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }
  @media (max-width: 720px) { .p-payout-grid--2col { grid-template-columns: 1fr; } }

  /* Card de Override 10% (paso 2) — beige/cream con accent dorado */
  .p-payout-card--override {
    background: linear-gradient(135deg, #fafaf7 0%, #f5f0e6 100%);
    border: 1px solid rgba(201, 169, 107, 0.25);
  }
  .p-payout-card--override .p-payout-step {
    color: #c9a96b;
  }
  .p-payout-card--override .p-payout-amount {
    color: #1a1a1a;
    background: linear-gradient(135deg, #1a1a1a 0%, #b8965a 80%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .p-payout-card-cta {
    margin-top: 14px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #4B7BE5;
    text-decoration: none;
    letter-spacing: 0.005em;
    transition: color 160ms ease, transform 160ms ease;
    align-self: flex-start;
  }
  .p-payout-card-cta:hover { color: #1a1a1a; transform: translateX(2px); }
  .p-payout-card--override .p-payout-card-cta { color: #8a7240; }
  .p-payout-card--override .p-payout-card-cta:hover { color: #1a1a1a; }

  .p-payout-notes {
    margin-top: 28px;
    padding: 22px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
  }
  .p-payout-notes-title {
    font-size: 0.625rem; font-weight: 700; color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
    margin-bottom: 10px;
  }
  .p-payout-notes p {
    margin: 0;
    font-size: 0.875rem;
    color: rgba(26,26,46,0.7);
    line-height: 1.6;
  }

  /* Landing card */
  .p-landing {
    margin-top: 32px;
    padding: 28px;
    background: linear-gradient(120deg, rgba(75,123,229,0.06), rgba(108,92,231,0.04));
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 16px;
    text-align: center;
  }
  .p-landing-eyebrow {
    font-size: 0.6875rem; font-weight: 700; color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
    margin-bottom: 12px;
  }
  .p-landing-url {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 500;
    color: #1a1a1a;
    word-break: break-all;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .p-landing-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    margin: 0 auto;
    max-width: 460px;
  }

  /* ─── Portal de partner — qué ve el partner y desde dónde ─── */
  .p-portal {
    margin-top: 40px;
    padding: 32px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 16px;
  }
  .p-portal-eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .p-portal-title {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.6vw, 1.75rem);
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 14px;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .p-portal-lead {
    font-size: 0.9375rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.6;
    margin: 0 0 28px;
    max-width: 640px;
  }
  .p-portal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px;
    margin-bottom: 22px;
  }
  .p-portal-card {
    background: #fafafa;
    border: 1px solid #f0f0f0;
    border-radius: 12px;
    padding: 18px;
  }
  .p-portal-card-ic {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(75,123,229,0.10);
    color: #4B7BE5;
    border-radius: 9px;
    margin-bottom: 12px;
  }
  .p-portal-card-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .p-portal-card-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.6);
    line-height: 1.55;
  }
  .p-portal-note {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 14px 16px;
    background: rgba(42,181,160,0.08);
    border-left: 3px solid #2AB5A0;
    border-radius: 6px;
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.75);
    line-height: 1.55;
  }
  .p-portal-note svg {
    flex-shrink: 0;
    color: #1A8F7A;
    margin-top: 2px;
  }
  @media (max-width: 640px) {
    .p-portal { padding: 22px; }
    .p-portal-grid { grid-template-columns: 1fr; }
  }

  /* ─── Tu potencial — proyección de ganancias ─── */
  .p-projection-block { margin: 8px 0 56px; }

  /* Toggle Mensual / Anual */
  .p-projection-toggle {
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    background: #fafafa;
    border: 1px solid #e5e5e5;
    border-radius: 14px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .p-toggle-btn {
    display: flex; flex-direction: column; gap: 1px;
    padding: 10px 18px;
    background: transparent;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    color: rgba(26,26,46,0.6);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .p-toggle-btn:hover { color: #1a1a1a; }
  .p-toggle-btn.is-active {
    background: #1a1a1a;
    color: #fff;
  }
  .p-toggle-btn-label {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: -0.005em;
  }
  .p-toggle-btn-hint {
    font-size: 0.625rem;
    font-weight: 500;
    opacity: 0.75;
    letter-spacing: 0.02em;
  }

  /* Show/hide based on data-projection-scope view state */
  [data-projection-scope] .p-view-anual { display: none; }
  [data-projection-scope][data-projection-view="anual"] .p-view-mensual { display: none; }
  [data-projection-scope][data-projection-view="anual"] .p-view-anual { display: block; }

  .p-projection-eyebrow {
    font-size: 0.625rem; font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 12px;
  }
  .p-projection-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 300;
    color: #1a1a1a;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 12px;
  }
  .p-projection-lead {
    font-size: 0.9375rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    margin: 0 0 28px;
    max-width: 600px;
  }
  .p-projection-lead strong { color: #1a1a1a; font-weight: 600; }

  /* Demo cards row */
  .p-demo-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 720px) { .p-demo-cards { grid-template-columns: 1fr; } }
  .p-demo-card {
    padding: 24px 22px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    display: flex; flex-direction: column; gap: 4px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .p-demo-card:hover { border-color: #4B7BE5; transform: translateY(-2px); }
  .p-demo-card--featured {
    background: linear-gradient(135deg, rgba(75,123,229,0.10), rgba(108,92,231,0.06));
    border-color: rgba(75,123,229,0.35);
  }
  .p-demo-card-label {
    font-size: 0.6875rem; font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.12em; text-transform: uppercase;
  }
  .p-demo-card-meta {
    font-size: 0.75rem;
    color: rgba(26,26,46,0.6);
    margin-bottom: 14px;
  }
  .p-demo-card-amount {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 300;
    color: #1a1a1a;
    line-height: 1;
    letter-spacing: -0.025em;
  }
  .p-demo-card-period {
    font-size: 0.75rem;
    color: rgba(26,26,46,0.55);
    margin-top: 2px;
  }
  .p-demo-card-annual {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid #e5e5e5;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #1a1a1a;
  }
  .p-demo-card-hint {
    font-size: 0.6875rem;
    color: rgba(26,26,46,0.5);
    font-style: italic;
    margin-top: 4px;
  }
  .p-demo-card--featured .p-demo-card-annual { border-color: rgba(75,123,229,0.25); }

  /* Sales matrix */
  .p-matrix-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 0 -8px;
    padding: 0 8px;
    scrollbar-width: thin;
  }
  .p-matrix-wrap::-webkit-scrollbar { height: 6px; }
  .p-matrix-wrap::-webkit-scrollbar-thumb { background: #e0e0e0; border-radius: 3px; }
  .p-matrix {
    width: 100%; min-width: 560px;
    border-collapse: collapse;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    overflow: hidden;
  }
  .p-matrix-th, .p-matrix-td {
    padding: 14px 12px;
    text-align: center;
    font-size: 0.875rem;
    border-bottom: 1px solid #f0f0f0;
    border-right: 1px solid #f0f0f0;
  }
  .p-matrix-th:last-child, .p-matrix-td:last-child { border-right: none; }
  .p-matrix-th {
    background: #fafafa;
    font-weight: 500;
    color: rgba(26,26,46,0.7);
    border-bottom: 1px solid #e5e5e5;
    padding: 18px 12px;
  }
  .p-matrix-th--clients {
    text-align: left;
    padding-left: 22px;
    font-size: 0.625rem;
    font-weight: 700;
    color: #999;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .p-matrix-plan-name {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 2px;
    letter-spacing: -0.005em;
  }
  .p-matrix-plan-price {
    font-size: 0.6875rem;
    color: #999;
    font-weight: 500;
  }
  .p-matrix-th--featured {
    background: linear-gradient(180deg, rgba(108,92,231,0.10), rgba(108,92,231,0.04));
  }
  .p-matrix-th--featured .p-matrix-plan-name { color: #6C5CE7; }
  .p-matrix-td--clients {
    text-align: left;
    padding-left: 22px;
    font-size: 0.875rem;
    color: rgba(26,26,46,0.7);
    background: #fafafa;
  }
  .p-matrix-td--clients strong {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: #1a1a1a;
    margin-right: 6px;
    letter-spacing: -0.01em;
  }
  .p-matrix-amount {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 1.1;
    letter-spacing: -0.005em;
  }
  .p-matrix-sub {
    font-size: 0.625rem;
    color: rgba(26,26,46,0.45);
    margin-top: 1px;
    letter-spacing: 0.05em;
  }
  .p-matrix-row--big .p-matrix-amount { font-size: 1.25rem; font-weight: 500; }
  .p-matrix-row--big .p-matrix-td--clients strong { font-size: 1.5rem; color: #4B7BE5; }
  .p-matrix-td--featured {
    background: rgba(108,92,231,0.04);
  }
  .p-matrix-td--featured .p-matrix-amount {
    color: #6C5CE7;
    font-weight: 600;
  }
  .p-matrix tbody tr:last-child .p-matrix-th, .p-matrix tbody tr:last-child .p-matrix-td { border-bottom: none; }
  .p-matrix tbody tr:hover { background: rgba(75,123,229,0.02); }

  .p-matrix-note {
