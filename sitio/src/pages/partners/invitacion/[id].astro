  .p-dark .p-input:focus { border-color: #93b4ff; box-shadow: 0 0 0 3px rgba(147,180,255,0.15); }
  .p-dark .p-sign-canvas-wrap { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.08); }
  .p-dark .p-sign-canvas { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.15); }
  .p-dark .p-btn--primary { background: #fff; color: #1a1a1a; }
  .p-dark .p-btn--primary:hover { background: #4B7BE5; color: #fff; }
