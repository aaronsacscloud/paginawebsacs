  'flow.get.std':  { es: 'Plan Fideliza, portal, academia y brand kit', en: 'Fideliza Plan, portal, academy and brand kit', fr: 'Plan Fideliza, portail, académie et kit de marque', it: 'Piano Fideliza, portale, academy e brand kit', pt: 'Plano Fideliza, portal, academia e brand kit' },
  'flow.get.esc':  { es: 'Un paquete de licencias Fideliza al mayoreo', en: 'A wholesale package of Fideliza licenses', fr: 'Un pack de licences Fideliza en gros', it: 'Un pacchetto di licenze Fideliza all\'ingrosso', pt: 'Um pacote de licenças Fideliza no atacado' },
  'flow.earn.std': { es: '{pct}% por cada venta que cierras', en: '{pct}% on every sale you close', fr: '{pct}% sur chaque vente conclue', it: '{pct}% su ogni vendita che chiudi', pt: '{pct}% sobre cada venda que fecha' },
  'flow.earn.esc': { es: 'Hasta {m} revendiendo a precio público', en: 'Up to {m} reselling at public price', fr: 'Jusqu\'à {m} en revendant au prix public', it: 'Fino a {m} rivendendo a prezzo pubblico', pt: 'Até {m} revendendo a preço público' },
