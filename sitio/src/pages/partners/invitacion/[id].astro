    .pp-link-block, .pp-template { padding: 22px 22px; }
    .pp-payout-meta-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
    .pp-bk-templates, .pp-bk-colors { grid-template-columns: 1fr 1fr; }
