  @media (max-width: 720px) { .p-calc-out { grid-template-columns: 1fr; } }
  .p-calc-out-card {
    padding: 18px 20px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
