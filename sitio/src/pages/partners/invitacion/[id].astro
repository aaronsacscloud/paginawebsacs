  @media (max-width: 640px) {
    .p-contract { padding: 24px 22px; }
    .p-contract-doc { max-height: 360px; }
  }

  /* ─── Certificate (post-approval) ─── */
  .p-cert-wrap { padding: 40px 0 60px; max-width: 920px; margin: 0 auto; }
  .p-cert-actions {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .p-cert-btn {
    padding: 12px 22px;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
  }
  .p-cert-btn--primary { background: #1a1a1a; color: #fff; }
  .p-cert-btn--primary:hover { background: #000; }
  .p-cert-btn--secondary { background: #fff; color: #1a1a1a; border: 1px solid #ececec; }
  .p-cert-btn--secondary:hover { border-color: #1a1a1a; }

  .p-cert {
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 24px 48px -16px rgba(0,0,0,0.18), 0 8px 16px -8px rgba(0,0,0,0.08);
    overflow: hidden;
  }
  .p-cert-border {
    margin: 14px;
    border: 2px solid #1a1a1a;
    border-radius: 6px;
    padding: 50px 60px 40px;
    background:
      radial-gradient(circle at top right, rgba(75,123,229,0.04), transparent 60%),
      radial-gradient(circle at bottom left, rgba(108,92,231,0.04), transparent 60%),
      #fff;
    position: relative;
  }
  .p-cert-border::before, .p-cert-border::after {
    content: '';
    position: absolute;
    width: 36px; height: 36px;
    border: 2px solid #4B7BE5;
  }
  .p-cert-border::before {
    top: 8px; left: 8px;
    border-right: none;
    border-bottom: none;
  }
  .p-cert-border::after {
    bottom: 8px; right: 8px;
    border-left: none;
    border-top: none;
  }

  .p-cert-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 36px;
    padding-bottom: 18px;
    border-bottom: 1px solid #ececec;
  }
  .p-cert-brand {
    font-family: 'Clash Display', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: #1a1a1a;
    letter-spacing: -0.025em;
  }
  .p-cert-program {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .p-cert-body { text-align: center; padding: 32px 0; }
  .p-cert-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    color: #888;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .p-cert-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 500;
    color: #1a1a1a;
    margin: 0 0 28px;
    letter-spacing: -0.035em;
    line-height: 1.05;
  }
  .p-cert-divider {
    width: 60px;
    height: 2px;
    background: #4B7BE5;
    margin: 0 auto 32px;
  }
  .p-cert-otorgado {
    font-size: 0.875rem;
    color: #888;
    font-style: italic;
    margin-bottom: 16px;
  }
  .p-cert-name {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 500;
    color: #1a1a1a;
    margin-bottom: 28px;
    letter-spacing: -0.025em;
    line-height: 1.1;
  }
  .p-cert-statement {
    font-size: 1rem;
    color: #555;
    line-height: 1.7;
    max-width: 580px;
    margin: 0 auto;
  }
  .p-cert-statement strong { color: #1a1a1a; font-weight: 600; }

  .p-cert-footer { padding-top: 32px; border-top: 1px solid #ececec; margin-top: 32px; }
  .p-cert-meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 1px dashed #ececec;
  }
  .p-cert-meta-block { text-align: center; }
  .p-cert-meta-lbl {
    font-size: 0.625rem;
    font-weight: 700;
    color: #999;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .p-cert-meta-val {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    letter-spacing: -0.005em;
  }
  .p-cert-signatures {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
  }
  .p-cert-sig { text-align: center; }
  .p-cert-sig-img {
    height: 56px;
    object-fit: contain;
    margin: 0 auto 6px;
    display: block;
  }
  .p-cert-sig-mark {
    font-family: 'Clash Display', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #4B7BE5;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .p-cert-sig-line {
    width: 80%;
    height: 1px;
    background: #1a1a1a;
    margin: 6px auto 8px;
  }
  .p-cert-sig-name {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: #1a1a1a;
  }
  .p-cert-sig-role { font-size: 0.75rem; color: #888; margin-top: 2px; }

  @media (max-width: 720px) {
    .p-cert-border { padding: 32px 24px 28px; }
    .p-cert-meta { grid-template-columns: 1fr; gap: 14px; }
    .p-cert-signatures { grid-template-columns: 1fr; gap: 32px; }
  }

  .p-cert-next {
    margin-top: 40px;
    padding: 32px 36px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 14px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
    text-align: center;
  }
  .p-cert-next-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: #1a1a1a;
    margin: 0 0 12px;
    letter-spacing: -0.015em;
  }
  .p-cert-next-lead { font-size: 0.9375rem; color: #555; line-height: 1.6; margin: 0 0 12px; }
  .p-cert-next-creds { font-size: 0.875rem; color: #666; margin: 0 0 24px; }
  .p-cert-next-creds strong { color: #1a1a1a; }
  .p-cert-cta {
    display: inline-block;
    padding: 14px 26px;
    background: #4B7BE5;
    color: #fff;
    border-radius: 10px;
    font-weight: 600;
    text-decoration: none;
    font-size: 0.9375rem;
  }
  .p-cert-cta:hover { background: #3764c4; }

  /* Print modo certificado (solo el cert): activado al hacer click en "Descargar certificado" */
  @media print {
    body.print-mode-cert * { visibility: hidden; }
    body.print-mode-cert #partner-certificate, body.print-mode-cert #partner-certificate * { visibility: visible; }
    body.print-mode-cert #partner-certificate {
      position: absolute;
      top: 0; left: 0;
      width: 100%;
      box-shadow: none !important;
    }
  }
  /* Print modo documento (descarga completa): oculta UI fluff y deja todo el contenido */
  @media print {
    body.print-mode-doc .no-print,
    body.print-mode-doc .p-fab,
    body.print-mode-doc .p-mobnav,
    body.print-mode-doc .p-layout-sidebar { display: none !important; }
    body.print-mode-doc .p-layout { grid-template-columns: 1fr !important; }
    body.print-mode-doc .p-tab-panel { display: block !important; page-break-after: always; }
    body.print-mode-doc .p-page { padding: 0 !important; }
    body.print-mode-doc .p-tab-hero,
    body.print-mode-doc .p-cert-hero { max-height: 280px; }
    body.print-mode-doc { background: #fff !important; }
  }

  /* Sección numerada (Tus datos / Dirección / Cobro / Firma) */
  .p-sign-section {
    margin-top: 36px;
    padding: 24px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 14px;
  }
  .p-sign-section-head {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid #f1f1f1;
  }
  .p-sign-section-num {
    width: 26px; height: 26px;
    border-radius: 50%;
    background: #1a1a1a; color: #fff;
    display: inline-flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-size: 0.8125rem; font-weight: 800;
  }
  .p-sign-section-title {
    font-family: var(--font-display);
    font-size: 1.05rem; font-weight: 700;
    color: #1a1a1a;
    letter-spacing: -0.01em;
  }
  .p-sign-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-top: 0;
  }
  .p-sign-section .p-sign-fields { margin-top: 0; }
  .p-sign-field--full { grid-column: 1 / -1; }
  .p-sign-optional {
    font-size: 0.6875rem; color: #bbb;
    text-transform: none; letter-spacing: 0; font-weight: 500;
    margin-left: 4px;
  }
  .benef-row { position: relative; padding-top: 4px; }
  .benef-row + .benef-row { margin-top: 6px; border-top: 1px dashed rgba(255,255,255,0.12); padding-top: 14px; }
  .benef-remove {
    position: absolute; top: 0; right: 0; background: none; border: none;
    color: #f0a0a0; font-size: 0.75rem; font-weight: 600; cursor: pointer; padding: 2px 6px;
  }
  .benef-remove:hover { text-decoration: underline; }
  .benef-foot { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-top: 12px; flex-wrap: wrap; }
  .benef-add {
    background: none; border: 1px dashed rgba(255,255,255,0.3); border-radius: 10px;
    color: #cbd5e1; font-size: 0.8125rem; font-weight: 600; cursor: pointer; padding: 8px 14px;
  }
  .benef-add:hover { border-color: rgba(255,255,255,0.55); color: #fff; }
  .benef-add[disabled] { opacity: 0.4; cursor: not-allowed; }
  .benef-sum { font-size: 0.8125rem; color: #94a3b8; font-variant-numeric: tabular-nums; }
  .benef-sum.is-bad strong { color: #f0a0a0; }
  .benef-sum.is-ok strong { color: #34d399; }
  @media (max-width: 640px) {
    .p-sign-fields { grid-template-columns: 1fr; }
    .p-sign-section { padding: 18px; }
  }

  /* Payout method radios */
  .p-payout-methods {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
    margin-bottom: 18px;
  }
  @media (max-width: 640px) {
    .p-payout-methods { grid-template-columns: 1fr; }
  }
  .p-payout-opt {
    position: relative;
    display: flex; align-items: flex-start; gap: 10px;
    padding: 14px;
    background: #fafafa;
    border: 1.5px solid #ececec;
    border-radius: 10px;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .p-payout-opt:hover { border-color: #d0d0d0; }
  .p-payout-opt input[type="radio"] {
    margin: 2px 0 0;
    accent-color: #1a1a1a;
    flex-shrink: 0;
  }
  .p-payout-opt:has(input:checked) {
    border-color: #1a1a1a;
    background: #fff;
  }
  .p-payout-opt-body { display: flex; flex-direction: column; gap: 2px; }
  .p-payout-opt-title {
    font-size: 0.875rem; font-weight: 700;
    color: #1a1a1a;
  }
  .p-payout-opt-sub {
    font-size: 0.75rem; color: #888;
  }
  .p-payout-detail[hidden] { display: none !important; }

  .p-sign-field { display: flex; flex-direction: column; gap: 6px; }
  .p-sign-field > span {
    font-size: 0.6875rem; font-weight: 600;
    color: #999;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .p-input {
    width: 100%; box-sizing: border-box;
    padding: 14px 16px;
    font-family: inherit;
    font-size: 0.9375rem;
    color: #1a1a1a;
    border: 1px solid #e5e5e5;
    border-radius: 10px;
    background: #fff;
    outline: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
