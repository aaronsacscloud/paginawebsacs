    font-size: 0.875rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
  }
  .p-commit-frequency {
    display: inline-block; margin-top: 10px;
    padding: 3px 9px;
    font-size: 0.625rem; font-weight: 600;
    color: #4B7BE5;
    background: rgba(75,123,229,0.10);
    border-radius: 999px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .p-commit-note {
    display: flex; align-items: flex-start; gap: 10px;
    margin-top: 28px;
    padding: 16px 18px;
    background: rgba(75,123,229,0.05);
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 10px;
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.75);
    line-height: 1.55;
  }
  .p-commit-note svg { flex-shrink: 0; color: #4B7BE5; margin-top: 1px; }

  /* ─── ¿Por qué te conviene cumplir? — rationale block ─── */
  .p-commit-rationale {
    margin-top: 32px;
    padding: 36px 32px;
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d3f 100%);
    color: #fff;
    border-radius: 20px;
  }
  .p-commit-rationale-eyebrow {
    font-size: 0.6875rem; font-weight: 700;
    color: #93b4ff;
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 14px;
  }
  .p-commit-rationale-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 300;
    color: #fff;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0 0 16px;
  }
  .p-commit-rationale-text {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    margin: 0 0 14px;
    max-width: 620px;
  }
  .p-commit-rationale-text strong { color: #fff; font-weight: 600; }
  .p-commit-rationale-stack {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin: 22px 0 24px;
  }
  @media (max-width: 720px) { .p-commit-rationale-stack { grid-template-columns: 1fr; } }

  .p-commit-rationale-card {
    padding: 20px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    display: flex; flex-direction: column; gap: 6px;
  }
  .p-commit-rationale-card--ceiling {
    background: linear-gradient(135deg, rgba(75,123,229,0.18), rgba(108,92,231,0.12));
    border-color: rgba(108,92,231,0.30);
  }
  .p-commit-rationale-card-label {
    font-size: 0.625rem; font-weight: 700;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.12em; text-transform: uppercase;
    line-height: 1.4;
  }
  .p-commit-rationale-card--ceiling .p-commit-rationale-card-label { color: #93b4ff; }
  .p-commit-rationale-card-amount {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4.5vw, 2.5rem);
    font-weight: 200;
    color: #fff;
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 4px 0 4px;
  }
  .p-commit-rationale-card--ceiling .p-commit-rationale-card-amount {
    background: linear-gradient(120deg, #93b4ff 0%, #c4b5fd 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .p-commit-rationale-card-detail {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.5;
  }
  .p-commit-rationale-cta {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 6px;
    padding: 12px 20px;
    background: #fff;
    color: #1a1a1a;
    text-decoration: none;
    border-radius: 10px;
    font-size: 0.875rem;
    font-weight: 600;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .p-commit-rationale-cta:hover {
    background: #93b4ff;
    color: #1a1a1a;
    text-decoration: none;
    transform: translateY(-1px);
  }
  .p-commit-rationale-cta-arrow { transition: transform 0.15s ease; }
  .p-commit-rationale-cta:hover .p-commit-rationale-cta-arrow { transform: translateX(4px); }


  /* Tabulador / Payouts */
  .p-payout-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-top: 8px;
  }
  @media (max-width: 720px) { .p-payout-grid { grid-template-columns: 1fr; } }

  .p-payout-card {
    padding: 28px 22px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    display: flex; flex-direction: column; gap: 8px;
  }
  .p-payout-card--featured {
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d3f 100%);
    color: #fff;
    border: none;
  }
  .p-payout-step {
    font-size: 0.625rem; font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  .p-payout-card--featured .p-payout-step { color: #93b4ff; }
  .p-payout-amount {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 300;
    color: #1a1a1a;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .p-payout-card--featured .p-payout-amount { color: #fff; }
  .p-payout-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: #1a1a1a;
    letter-spacing: -0.005em;
  }
  .p-payout-card--featured .p-payout-name { color: #fff; }
  .p-payout-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.6);
    line-height: 1.5;
    margin-top: 4px;
  }
  .p-payout-card--featured .p-payout-detail { color: rgba(255,255,255,0.65); }

  .p-payout-notes {
    margin-top: 28px;
    padding: 22px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
  }
  .p-payout-notes-title {
    font-size: 0.625rem; font-weight: 700; color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
    margin-bottom: 10px;
  }
  .p-payout-notes p {
    margin: 0;
    font-size: 0.875rem;
    color: rgba(26,26,46,0.7);
    line-height: 1.6;
  }

  /* Landing card */
  .p-landing {
    margin-top: 32px;
    padding: 28px;
    background: linear-gradient(120deg, rgba(75,123,229,0.06), rgba(108,92,231,0.04));
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 16px;
    text-align: center;
  }
  .p-landing-eyebrow {
    font-size: 0.6875rem; font-weight: 700; color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
    margin-bottom: 12px;
  }
  .p-landing-url {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 500;
    color: #1a1a1a;
    word-break: break-all;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .p-landing-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    margin: 0 auto;
    max-width: 460px;
  }

  /* ─── Portal de partner — qué ve el partner y desde dónde ─── */
  .p-portal {
    margin-top: 40px;
    padding: 32px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 16px;
  }
  .p-portal-eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .p-portal-title {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.6vw, 1.75rem);
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 14px;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .p-portal-lead {
    font-size: 0.9375rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.6;
    margin: 0 0 28px;
    max-width: 640px;
  }
  .p-portal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px;
    margin-bottom: 22px;
  }
  .p-portal-card {
    background: #fafafa;
    border: 1px solid #f0f0f0;
    border-radius: 12px;
    padding: 18px;
  }
  .p-portal-card-ic {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(75,123,229,0.10);
    color: #4B7BE5;
    border-radius: 9px;
    margin-bottom: 12px;
  }
  .p-portal-card-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .p-portal-card-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.6);
    line-height: 1.55;
  }
  .p-portal-note {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 14px 16px;
    background: rgba(42,181,160,0.08);
    border-left: 3px solid #2AB5A0;
    border-radius: 6px;
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.75);
    line-height: 1.55;
  }
  .p-portal-note svg {
    flex-shrink: 0;
    color: #1A8F7A;
    margin-top: 2px;
  }
  @media (max-width: 640px) {
    .p-portal { padding: 22px; }
    .p-portal-grid { grid-template-columns: 1fr; }
  }

  /* ─── Tu potencial — proyección de ganancias ─── */
  .p-projection-block { margin: 8px 0 56px; }

  /* Toggle Mensual / Anual */
  .p-projection-toggle {
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    background: #fafafa;
    border: 1px solid #e5e5e5;
    border-radius: 14px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .p-toggle-btn {
    display: flex; flex-direction: column; gap: 1px;
    padding: 10px 18px;
    background: transparent;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    color: rgba(26,26,46,0.6);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .p-toggle-btn:hover { color: #1a1a1a; }
  .p-toggle-btn.is-active {
    background: #1a1a1a;
    color: #fff;
  }
  .p-toggle-btn-label {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: -0.005em;
  }
  .p-toggle-btn-hint {
    font-size: 0.625rem;
    font-weight: 500;
    opacity: 0.75;
    letter-spacing: 0.02em;
  }

  /* Show/hide based on data-projection-scope view state */
  [data-projection-scope] .p-view-anual { display: none; }
  [data-projection-scope][data-projection-view="anual"] .p-view-mensual { display: none; }
  [data-projection-scope][data-projection-view="anual"] .p-view-anual { display: block; }

  .p-projection-eyebrow {
    font-size: 0.625rem; font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 12px;
  }
  .p-projection-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 300;
    color: #1a1a1a;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 12px;
  }
  .p-projection-lead {
    font-size: 0.9375rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    margin: 0 0 28px;
    max-width: 600px;
  }
  .p-projection-lead strong { color: #1a1a1a; font-weight: 600; }

  /* Demo cards row */
  .p-demo-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 720px) { .p-demo-cards { grid-template-columns: 1fr; } }
  .p-demo-card {
    padding: 24px 22px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    display: flex; flex-direction: column; gap: 4px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .p-demo-card:hover { border-color: #4B7BE5; transform: translateY(-2px); }
  .p-demo-card--featured {
    background: linear-gradient(135deg, rgba(75,123,229,0.10), rgba(108,92,231,0.06));
    border-color: rgba(75,123,229,0.35);
  }
  .p-demo-card-label {
    font-size: 0.6875rem; font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.12em; text-transform: uppercase;
  }
  .p-demo-card-meta {
    font-size: 0.75rem;
    color: rgba(26,26,46,0.6);
    margin-bottom: 14px;
  }
  .p-demo-card-amount {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 300;
    color: #1a1a1a;
    line-height: 1;
    letter-spacing: -0.025em;
  }
  .p-demo-card-period {
    font-size: 0.75rem;
    color: rgba(26,26,46,0.55);
    margin-top: 2px;
  }
  .p-demo-card-annual {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid #e5e5e5;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #1a1a1a;
  }
  .p-demo-card-hint {
    font-size: 0.6875rem;
    color: rgba(26,26,46,0.5);
    font-style: italic;
    margin-top: 4px;
  }
  .p-demo-card--featured .p-demo-card-annual { border-color: rgba(75,123,229,0.25); }

  /* Sales matrix */
  .p-matrix-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 0 -8px;
    padding: 0 8px;
    scrollbar-width: thin;
  }
  .p-matrix-wrap::-webkit-scrollbar { height: 6px; }
  .p-matrix-wrap::-webkit-scrollbar-thumb { background: #e0e0e0; border-radius: 3px; }
  .p-matrix {
    width: 100%; min-width: 560px;
    border-collapse: collapse;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    overflow: hidden;
  }
  .p-matrix-th, .p-matrix-td {
    padding: 14px 12px;
    text-align: center;
    font-size: 0.875rem;
    border-bottom: 1px solid #f0f0f0;
    border-right: 1px solid #f0f0f0;
  }
  .p-matrix-th:last-child, .p-matrix-td:last-child { border-right: none; }
  .p-matrix-th {
    background: #fafafa;
    font-weight: 500;
    color: rgba(26,26,46,0.7);
    border-bottom: 1px solid #e5e5e5;
    padding: 18px 12px;
  }
  .p-matrix-th--clients {
    text-align: left;
    padding-left: 22px;
    font-size: 0.625rem;
    font-weight: 700;
    color: #999;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .p-matrix-plan-name {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 2px;
    letter-spacing: -0.005em;
  }
  .p-matrix-plan-price {
    font-size: 0.6875rem;
    color: #999;
    font-weight: 500;
  }
  .p-matrix-th--featured {
    background: linear-gradient(180deg, rgba(108,92,231,0.10), rgba(108,92,231,0.04));
  }
  .p-matrix-th--featured .p-matrix-plan-name { color: #6C5CE7; }
  .p-matrix-td--clients {
    text-align: left;
    padding-left: 22px;
    font-size: 0.875rem;
    color: rgba(26,26,46,0.7);
    background: #fafafa;
  }
  .p-matrix-td--clients strong {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: #1a1a1a;
    margin-right: 6px;
    letter-spacing: -0.01em;
  }
  .p-matrix-amount {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 1.1;
    letter-spacing: -0.005em;
  }
  .p-matrix-sub {
    font-size: 0.625rem;
    color: rgba(26,26,46,0.45);
    margin-top: 1px;
    letter-spacing: 0.05em;
  }
  .p-matrix-row--big .p-matrix-amount { font-size: 1.25rem; font-weight: 500; }
  .p-matrix-row--big .p-matrix-td--clients strong { font-size: 1.5rem; color: #4B7BE5; }
  .p-matrix-td--featured {
    background: rgba(108,92,231,0.04);
  }
  .p-matrix-td--featured .p-matrix-amount {
    color: #6C5CE7;
    font-weight: 600;
  }
  .p-matrix tbody tr:last-child .p-matrix-th, .p-matrix tbody tr:last-child .p-matrix-td { border-bottom: none; }
  .p-matrix tbody tr:hover { background: rgba(75,123,229,0.02); }

  .p-matrix-note {
    display: flex; align-items: flex-start; gap: 10px;
    margin-top: 18px;
    padding: 14px 16px;
    background: #fafafa;
    border-radius: 10px;
    font-size: 0.75rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
  }
  .p-matrix-note svg { flex-shrink: 0; color: #4B7BE5; margin-top: 2px; }

  /* Closing big number */
  .p-projection-closing {
    margin-top: 24px;
    padding: 36px 32px;
    background: #1a1a1a;
    color: #fff;
    border-radius: 20px;
  }
  .p-projection-closing-eyebrow {
    font-size: 0.6875rem; font-weight: 700;
    color: #93b4ff;
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 24px;
  }
  .p-projection-closing-stack {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }
  @media (max-width: 720px) { .p-projection-closing-stack { grid-template-columns: 1fr; gap: 24px; } }

  .p-projection-closing-card {
    display: flex; flex-direction: column; gap: 6px;
    padding: 22px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
  }
  .p-projection-closing-card--ceiling {
    background: linear-gradient(135deg, rgba(75,123,229,0.18), rgba(108,92,231,0.12));
    border-color: rgba(108,92,231,0.30);
  }
  .p-projection-closing-label {
    font-size: 0.625rem; font-weight: 700;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  .p-projection-closing-card--ceiling .p-projection-closing-label { color: #93b4ff; }
  .p-projection-closing-amount {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3.25rem);
    font-weight: 200;
    color: #fff;
    letter-spacing: -0.035em;
    line-height: 1;
    margin: 6px 0 4px;
  }
  .p-projection-closing-card--ceiling .p-projection-closing-amount {
    background: linear-gradient(120deg, #93b4ff 0%, #c4b5fd 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .p-projection-closing-detail {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.5;
    margin-top: 6px;
  }
  .p-projection-closing-bottom {
    margin: 0;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.55;
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 20px;
  }
  .p-projection-closing-bottom strong { color: #fff; font-weight: 600; }

  /* Dark template overrides for projection */
  .p-dark .p-demo-card { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.08); }
  .p-dark .p-demo-card-amount, .p-dark .p-demo-card-annual { color: #fff; }
  .p-dark .p-demo-card-meta, .p-dark .p-demo-card-period, .p-dark .p-demo-card-hint { color: rgba(255,255,255,0.55); }
  .p-dark .p-demo-card-annual { border-color: rgba(255,255,255,0.1); }
  .p-dark .p-matrix { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.08); }
  .p-dark .p-matrix-th, .p-dark .p-matrix-td { border-color: rgba(255,255,255,0.06); }
  .p-dark .p-matrix-th { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.7); }
  .p-dark .p-matrix-td--clients { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.7); }
  .p-dark .p-matrix-td--clients strong, .p-dark .p-matrix-amount, .p-dark .p-matrix-plan-name { color: #fff; }
  .p-dark .p-matrix-sub, .p-dark .p-matrix-plan-price { color: rgba(255,255,255,0.45); }
  .p-dark .p-matrix-note { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.65); }

  /* ¿Por qué SACS? */
  .p-why-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
    margin: 8px 0 36px;
  }
  @media (max-width: 720px) { .p-why-stats { grid-template-columns: repeat(2, 1fr); } }
  .p-why-stat {
    padding: 24px 16px;
    border-right: 1px solid #e5e5e5;
    text-align: left;
  }
  .p-why-stat:last-child { border-right: none; }
  @media (max-width: 720px) {
    .p-why-stat:nth-child(2) { border-right: none; }
    .p-why-stat:nth-child(1), .p-why-stat:nth-child(2) { border-bottom: 1px solid #e5e5e5; }
  }
  .p-why-stat-num {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 300;
    color: #1a1a1a;
    line-height: 1;
    letter-spacing: -0.025em;
    margin-bottom: 6px;
  }
  .p-why-stat-label {
    font-size: 0.6875rem; font-weight: 600;
    color: #999;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .p-why-pillars {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px 24px;
    margin-bottom: 40px;
  }
  @media (max-width: 720px) { .p-why-pillars { grid-template-columns: 1fr; } }

  .p-why-pillar { display: flex; flex-direction: column; gap: 4px; }
  .p-why-pillar-letter {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 200;
    color: #4B7BE5;
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .p-why-pillar-word {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-top: 4px;
    letter-spacing: -0.005em;
  }
  .p-why-pillar p {
    font-size: 0.875rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    margin: 6px 0 0;
  }

  .p-why-closing {
    display: flex; flex-direction: column; gap: 10px;
    padding: 28px;
    background: #1a1a1a;
    color: #fff;
    border-radius: 16px;
  }
  .p-why-closing strong {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: -0.01em;
  }
  .p-why-closing span {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
  }

  /* ─── Proceso (Cómo funciona) ─────────────────────── */
  .p-proc-steps {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 32px;
  }
  .p-proc-step {
    display: flex;
    gap: 18px;
    padding: 22px 24px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 14px;
    transition: border-color 0.18s, transform 0.18s;
  }
  .p-proc-step:hover {
    border-color: #cfd6e2;
    transform: translateY(-1px);
  }
  .p-proc-step-num {
    flex-shrink: 0;
    width: 38px; height: 38px;
    border-radius: 50%;
    background: #1a1a1a;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1rem;
  }
  .p-proc-step-body {
    flex: 1;
    min-width: 0;
  }
  .p-proc-step-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .p-proc-step-detail {
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.6;
    margin: 0 0 10px;
  }
  .p-proc-step-detail strong { color: #1a1a1a; font-weight: 700; }
  .p-proc-step-detail code {
    background: #f5f5f7;
    padding: 1px 6px;
    border-radius: 4px;
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 0.8125rem;
    color: #4B7BE5;
  }
  .p-proc-step-meta {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .p-proc-meta-pill {
    display: inline-block;
    padding: 4px 10px;
    background: rgba(75,123,229,0.10);
    color: #3764c4;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: 999px;
  }
  .p-proc-meta-pill--alt {
    background: rgba(42,181,160,0.10);
    color: #1A8F7A;
  }
  .p-proc-preview-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 6px;
    padding: 10px 16px;
    background: #1a1a1a;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .p-proc-preview-btn:hover { background: #4B7BE5; }

  .p-proc-cta {
    margin-top: 36px;
    text-align: center;
    padding: 28px;
    background: linear-gradient(120deg, rgba(75,123,229,0.06), rgba(108,92,231,0.04));
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 16px;
  }
  .p-proc-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 26px;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9375rem;
    transition: background 0.15s;
  }
  .p-proc-cta-btn:hover { background: #4B7BE5; }
  .p-proc-cta-arrow { font-size: 1.125rem; }

  @media (max-width: 640px) {
    .p-proc-step { padding: 18px 16px; gap: 14px; }
    .p-proc-step-num { width: 32px; height: 32px; font-size: 0.875rem; }
    .p-proc-step-title { font-size: 1rem; }
    .p-proc-step-detail { font-size: 0.875rem; }
  }

  /* ─── Preview modal del panel de partner ─────────────── */
  .p-preview-overlay {
    position: fixed;
    inset: 0;
    background: rgba(20,20,30,0.65);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    overflow-y: auto;
  }
  .p-preview-modal {
    width: 100%;
    max-width: 980px;
    max-height: 92vh;
    overflow-y: auto;
    background: #fff;
    border-radius: 18px;
    box-shadow: 0 30px 80px -20px rgba(0,0,0,0.30);
    display: flex;
    flex-direction: column;
  }
  .p-preview-header {
    position: sticky;
    top: 0;
    background: #fff;
    padding: 20px 24px;
    border-bottom: 1px solid #ececec;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    border-radius: 18px 18px 0 0;
    z-index: 1;
  }
  .p-preview-eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 6px;
  }
  .p-preview-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a1a;
    letter-spacing: -0.01em;
  }
  .p-preview-close {
    background: transparent;
    border: 1px solid #ddd;
    border-radius: 50%;
    width: 36px; height: 36px;
    cursor: pointer;
    font-size: 1.125rem;
    color: #666;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .p-preview-close:hover { border-color: #1a1a1a; color: #1a1a1a; }

  .p-preview-body {
    padding: 22px;
  }
  .p-preview-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
    margin-top: 22px;
  }
  .p-preview-feat {
    padding: 14px 16px;
    background: #fafafa;
    border: 1px solid #ececec;
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .p-preview-feat strong {
    font-family: var(--font-display);
    font-size: 0.875rem;
    color: #1a1a1a;
  }
  .p-preview-feat span {
    font-size: 0.8125rem;
    color: #666;
    line-height: 1.5;
  }

  /* ── Portal mockup (visual) ── */
  .pp-mock {
    background: #f5f6f8;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid #e5e7eb;
    box-shadow: 0 12px 32px -12px rgba(0,0,0,0.12);
    font-family: var(--font-body);
    color: #1a1a1a;
  }
  .pp-mock-topbar {
    background: #fff;
    padding: 10px 18px;
    border-bottom: 1px solid #ececec;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.8125rem;
  }
  .pp-mock-brand {
    font-family: 'Clash Display', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: #1a1a1a;
    letter-spacing: -0.02em;
  }
  .pp-mock-sep { color: #ccc; }
  .pp-mock-subtitle { color: #888; font-size: 0.75rem; font-weight: 500; }
  .pp-mock-username { color: #444; font-size: 0.75rem; font-weight: 600; }

  .pp-mock-body { display: flex; }
  .pp-mock-sidebar {
    width: 180px;
    background: #fff;
    border-right: 1px solid #ececec;
    padding: 14px 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-height: 360px;
  }
  .pp-mock-side-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    border-radius: 7px;
    font-size: 0.8125rem;
    color: #555;
    font-weight: 500;
  }
  .pp-mock-side-item--active {
    background: #1a1a1a;
    color: #fff;
  }
  .pp-mock-side-item--accent { color: #4B7BE5; }

  .pp-mock-main {
    flex: 1;
    padding: 22px 24px;
    background: #f5f6f8;
    overflow: hidden;
  }
  .pp-mock-h1 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 4px;
    letter-spacing: -0.015em;
  }
  .pp-mock-lead { font-size: 0.8125rem; color: #666; margin-bottom: 18px; }
  .pp-mock-h2 {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 22px 0 10px;
  }

  .pp-mock-kpi-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 10px;
  }
  .pp-mock-kpi {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 10px;
    padding: 14px;
  }
  .pp-mock-kpi-lbl {
    font-size: 0.625rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
    margin-bottom: 6px;
  }
  .pp-mock-kpi-val {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 800;
    color: #1a1a1a;
    line-height: 1.1;
    letter-spacing: -0.015em;
  }
  .pp-mock-kpi-hint {
    font-size: 0.6875rem;
    color: #999;
    margin-top: 4px;
  }

  .pp-mock-table {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 10px;
    overflow: hidden;
    font-size: 0.8125rem;
  }
  .pp-mock-trow {
    display: grid;
    grid-template-columns: 1.4fr 1fr 0.8fr;
    gap: 10px;
    padding: 10px 14px;
    border-bottom: 1px solid #f5f5f5;
    align-items: center;
  }
  .pp-mock-trow:last-child { border-bottom: none; }
  .pp-mock-trow--head {
    font-size: 0.625rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
    background: #fafafa;
  }
  .pp-mock-tag {
    display: inline-block;
    padding: 3px 8px;
    background: #f5f5f7;
    color: #666;
    border-radius: 999px;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-style: normal;
  }
  .pp-mock-tag--ok    { background: rgba(42,181,160,0.12); color: #1A8F7A; }
  .pp-mock-tag--blue  { background: rgba(75,123,229,0.12); color: #3764c4; }

  /* Mobile mockup: ocultar sidebar para que entre todo */
  @media (max-width: 640px) {
    .pp-mock-sidebar { display: none; }
    .pp-mock-main { padding: 16px; }
    .pp-mock-kpi-row { grid-template-columns: 1fr 1fr; }
    .pp-mock-trow { grid-template-columns: 1fr 1fr; }
    .pp-mock-trow > span:nth-child(3) { display: none; }
    .p-preview-modal { max-height: 96vh; border-radius: 14px; }
    .p-preview-body { padding: 14px; }
  }

  /* Sign form */
  .p-sign-form { padding: 56px 0 24px; max-width: 720px; margin: 0 auto; }

  /* Sección numerada (Tus datos / Dirección / Cobro / Firma) */
  .p-sign-section {
    margin-top: 36px;
    padding: 24px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 14px;
  }
  .p-sign-section-head {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid #f1f1f1;
  }
  .p-sign-section-num {
    width: 26px; height: 26px;
    border-radius: 50%;
    background: #1a1a1a; color: #fff;
    display: inline-flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-size: 0.8125rem; font-weight: 800;
  }
  .p-sign-section-title {
    font-family: var(--font-display);
    font-size: 1.05rem; font-weight: 700;
    color: #1a1a1a;
    letter-spacing: -0.01em;
  }
  .p-sign-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-top: 0;
  }
  .p-sign-section .p-sign-fields { margin-top: 0; }
  .p-sign-field--full { grid-column: 1 / -1; }
  .p-sign-optional {
    font-size: 0.6875rem; color: #bbb;
    text-transform: none; letter-spacing: 0; font-weight: 500;
    margin-left: 4px;
  }
  @media (max-width: 640px) {
    .p-sign-fields { grid-template-columns: 1fr; }
    .p-sign-section { padding: 18px; }
  }

  /* Payout method radios */
  .p-payout-methods {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
    margin-bottom: 18px;
  }
  @media (max-width: 640px) {
    .p-payout-methods { grid-template-columns: 1fr; }
  }
  .p-payout-opt {
    position: relative;
    display: flex; align-items: flex-start; gap: 10px;
    padding: 14px;
    background: #fafafa;
    border: 1.5px solid #ececec;
    border-radius: 10px;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .p-payout-opt:hover { border-color: #d0d0d0; }
  .p-payout-opt input[type="radio"] {
    margin: 2px 0 0;
    accent-color: #1a1a1a;
    flex-shrink: 0;
  }
  .p-payout-opt:has(input:checked) {
    border-color: #1a1a1a;
    background: #fff;
  }
  .p-payout-opt-body { display: flex; flex-direction: column; gap: 2px; }
  .p-payout-opt-title {
    font-size: 0.875rem; font-weight: 700;
    color: #1a1a1a;
  }
  .p-payout-opt-sub {
    font-size: 0.75rem; color: #888;
  }
  .p-payout-detail[hidden] { display: none !important; }

  .p-sign-field { display: flex; flex-direction: column; gap: 6px; }
  .p-sign-field > span {
    font-size: 0.6875rem; font-weight: 600;
    color: #999;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .p-input {
    width: 100%; box-sizing: border-box;
    padding: 14px 16px;
    font-family: inherit;
    font-size: 0.9375rem;
    color: #1a1a1a;
    border: 1px solid #e5e5e5;
    border-radius: 10px;
    background: #fff;
    outline: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .p-input:focus { border-color: #4B7BE5; box-shadow: 0 0 0 3px rgba(75,123,229,0.10); }
  textarea.p-input { resize: vertical; min-height: 80px; }

  .p-sign-canvas-wrap {
    padding: 18px;
    background: #fafafa;
    border: 1px solid #ececec;
    border-radius: 12px;
  }
  .p-sign-canvas-label {
    font-size: 0.6875rem; font-weight: 600;
    color: #999;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .p-sign-canvas {
    width: 100%; height: 180px;
    background: #fafaf8;
    border: 1px dashed #d0d0d0;
    border-radius: 8px;
    cursor: crosshair;
    touch-action: none;
    display: block;
  }
  .p-sign-canvas-actions {
    display: flex; justify-content: flex-end;
    margin-top: 10px;
  }

  .p-sign-legal {
    margin-top: 18px;
    font-size: 0.75rem;
    color: rgba(26,26,46,0.55);
    line-height: 1.55;
  }
  .p-sign-legal a { color: #4B7BE5; text-decoration: none; }
  .p-sign-legal a:hover { text-decoration: underline; }

  .p-sign-actions {
    display: flex; flex-direction: column; gap: 10px;
    margin-top: 24px;
  }

  /* Buttons */
  .p-btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 14px 22px;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 10px;
    border: 1px solid transparent;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }
  .p-btn--primary {
    background: #1a1a1a;
    color: #fff;
    padding: 16px 24px;
    font-size: 0.9375rem;
  }
  .p-btn--primary:hover { background: #4B7BE5; color: #fff; transform: translateY(-1px); }
  .p-btn--ghost {
    background: transparent;
    color: rgba(26,26,46,0.65);
    border-color: #e5e5e5;
  }
  .p-btn--ghost:hover { color: #1a1a1a; border-color: #1a1a1a; }

  /* Signed state */
  .p-signed {
    padding: 56px 0;
    text-align: center;
    max-width: 540px;
    margin: 0 auto;
  }
  .p-signed-eyebrow {
    font-size: 0.6875rem; font-weight: 700; color: #2AB5A0;
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 18px;
  }
  .p-signed--declined .p-signed-eyebrow { color: #b93333; }
  .p-signed--expired .p-signed-eyebrow { color: #888; }
  .p-signed-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 300;
    color: #1a1a1a;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 16px;
  }
  .p-signed-sub {
    font-size: 1rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    margin-bottom: 28px;
  }
  .p-signed-img {
    max-width: 240px; height: auto;
    margin: 0 auto 12px;
    display: block;
  }
  .p-signed-label { font-size: 0.875rem; font-weight: 600; color: #1a1a1a; }
  .p-signed-date { font-size: 0.75rem; color: #999; margin-top: 2px; }
  .p-signed-meta {
    margin-top: 16px;
    font-size: 0.875rem;
    color: rgba(26,26,46,0.65);
  }
  .p-signed-cta-row {
    margin-top: 24px;
    display: inline-flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .p-signed-cta {
    display: inline-block;
    padding: 14px 28px;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9375rem;
    transition: background 0.15s ease;
  }
  .p-signed-cta:hover { background: #4B7BE5; color: #fff; }
  .p-signed-cta-secondary {
    display: inline-block;
    padding: 14px 28px;
    background: transparent;
    color: #1a1a1a;
    text-decoration: none;
    border: 1px solid #e5e5e5;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9375rem;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .p-signed-cta-secondary:hover { border-color: #1a1a1a; color: #1a1a1a; text-decoration: none; }

  /* Footer */
  .p-footer {
    display: flex; justify-content: space-between; align-items: center;
    padding: 32px 0;
    border-top: 1px solid #e5e5e5;
    margin-top: 48px;
    flex-wrap: wrap; gap: 12px;
  }
  .p-footer-brand { display: flex; align-items: baseline; gap: 10px; }
  .p-footer-logo { font-family: var(--font-logo, var(--font-display)); font-size: 1.125rem; font-weight: 700; color: #1a1a1a; }
  .p-footer-tagline { font-size: 0.75rem; color: #999; }
  .p-footer-contact { font-size: 0.75rem; color: #999; letter-spacing: 0.01em; }

  /* Modal */
  .p-modal-overlay {
    position: fixed; inset: 0; z-index: 1000;
    background: rgba(0,0,0,0.5);
    display: flex; align-items: center; justify-content: center;
    padding: 24px;
  }
  .p-modal {
    background: #fff;
    width: 100%; max-width: 500px;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.2);
    display: flex; flex-direction: column;
  }
  .p-modal-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 20px 24px;
    border-bottom: 1px solid #f0f0f0;
  }
  .p-modal-title { font-family: var(--font-display); font-size: 1rem; font-weight: 600; color: #1a1a1a; }
  .p-modal-close {
    background: transparent; border: none; cursor: pointer;
    font-size: 1rem; color: #999;
    padding: 4px 8px;
  }
  .p-modal-body { padding: 24px; }
  .p-modal-text { margin: 0 0 16px; font-size: 0.875rem; color: rgba(26,26,46,0.65); line-height: 1.55; }
  .p-decline-reasons { display: flex; flex-direction: column; gap: 8px; }
  .p-decline-reason {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 12px 14px;
    background: #fafafa;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    font-size: 0.875rem;
    color: rgba(26,26,46,0.75);
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .p-decline-reason:hover { border-color: #4B7BE5; background: rgba(75,123,229,0.04); }
  .p-decline-reason input { margin-top: 2px; }
  .p-modal-footer {
    display: flex; gap: 10px; justify-content: flex-end;
    padding: 16px 24px;
    border-top: 1px solid #f0f0f0;
    background: #fafafa;
  }

  /* Dark template overrides */
  .p-dark, .p-dark .p-container { background: #0f1115; color: #fff; }
  .p-dark .p-header { border-color: rgba(255,255,255,0.08); }
  .p-dark .p-logo-text, .p-dark .p-numero, .p-dark .p-section-title,
  .p-dark .p-hero-title, .p-dark .p-benefit-title, .p-dark .p-term-label,
  .p-dark .p-term-value, .p-dark .p-commit-title, .p-dark .p-payout-amount,
  .p-dark .p-payout-name, .p-dark .p-why-stat-num, .p-dark .p-why-pillar-word,
  .p-dark .p-signed-title, .p-dark .p-signed-label, .p-dark .p-landing-url,
  .p-dark .p-footer-logo { color: #fff; }
  .p-dark .p-section-lead, .p-dark .p-hero-sub, .p-dark .p-benefit-detail,
  .p-dark .p-term-detail, .p-dark .p-commit-detail, .p-dark .p-payout-detail,
  .p-dark .p-why-pillar p, .p-dark .p-signed-sub, .p-dark .p-landing-detail,
  .p-dark .p-payout-notes p, .p-dark .p-terms-extra-text { color: rgba(255,255,255,0.65); }
  .p-dark .p-fecha, .p-dark .p-hero-stat-label, .p-dark .p-why-stat-label,
  .p-dark .p-tab-intro-link-arrow, .p-dark .p-footer-tagline, .p-dark .p-footer-contact,
  .p-dark .p-sign-canvas-label, .p-dark .p-sign-field > span,
  .p-dark .p-signed-date { color: rgba(255,255,255,0.45); }
  .p-dark .p-terms, .p-dark .p-term-row, .p-dark .p-commits, .p-dark .p-commit-row,
  .p-dark .p-tab-intro-nav, .p-dark .p-tab-intro-link, .p-dark .p-hero-stats,
  .p-dark .p-why-stats, .p-dark .p-why-stat, .p-dark .p-footer { border-color: rgba(255,255,255,0.08); }
  .p-dark .p-benefit-card, .p-dark .p-payout-card:not(.p-payout-card--featured),
  .p-dark .p-payout-notes, .p-dark .p-terms-extra { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.08); }
  .p-dark .p-tab-intro-link { color: #fff; }
  .p-dark .p-tab-intro-link:hover { color: #93b4ff; }
  .p-dark .p-input { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.1); color: #fff; }
  .p-dark .p-input:focus { border-color: #93b4ff; box-shadow: 0 0 0 3px rgba(147,180,255,0.15); }
  .p-dark .p-sign-canvas-wrap { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.08); }
  .p-dark .p-sign-canvas { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.15); }
  .p-dark .p-btn--primary { background: #fff; color: #1a1a1a; }
  .p-dark .p-btn--primary:hover { background: #4B7BE5; color: #fff; }
  .p-dark .p-btn--ghost { color: rgba(255,255,255,0.7); border-color: rgba(255,255,255,0.15); }
  .p-dark .p-btn--ghost:hover { color: #fff; border-color: #fff; }
</style>

<script is:inline define:vars={{ invitationId: id, isClosed }}>
(function() {
  // ─── Tab switcher ───
  const doc = document.getElementById('partner-doc');
  if (!doc) return;
  const initialTab = doc.dataset.initialTab || 'bienvenida';

  function showTab(tabId) {
    document.querySelectorAll('.p-tab-panel').forEach(p => {
      p.classList.toggle('is-active', p.dataset.tab === tabId);
    });
    document.querySelectorAll('[data-tab-link]').forEach(link => {
      const id = link.dataset.tabLink;
      if (id === tabId) link.classList.add('psb-tab--active');
      else if (link.classList.contains('psb-tab--active')) link.classList.remove('psb-tab--active');
    });
    if (history.replaceState) {
      history.replaceState(null, '', '#' + tabId);
    }
    // Init signature canvas la primera vez que el tab firma se hace visible
    if (tabId === 'firma') {
      requestAnimationFrame(() => {
        if (typeof initSignature === 'function') initSignature();
      });
    }
  }

  // Wire links
  document.addEventListener('click', e => {
    const link = e.target.closest('[data-tab-link]');
    if (!link) return;
    const tabId = link.dataset.tabLink;
    if (!tabId) return;
    e.preventDefault();
    showTab(tabId);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Initial tab from hash or initialTab
  const hash = (location.hash || '').replace('#', '');
  showTab(hash || initialTab);

  // ─── Preview del panel modal (siempre disponible) ───
  const previewOverlay = document.getElementById('preview-overlay');
  const btnOpenPreview = document.getElementById('btn-open-preview');
  const btnClosePreview = document.getElementById('btn-close-preview');
  function openPreview() {
    if (previewOverlay) {
      previewOverlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
  }
  function closePreview() {
    if (previewOverlay) {
      previewOverlay.style.display = 'none';
      document.body.style.overflow = '';
    }
  }
  btnOpenPreview && btnOpenPreview.addEventListener('click', openPreview);
  btnClosePreview && btnClosePreview.addEventListener('click', closePreview);
  // Close on overlay backdrop click
  previewOverlay && previewOverlay.addEventListener('click', (e) => {
    if (e.target === previewOverlay) closePreview();
  });
  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && previewOverlay && previewOverlay.style.display === 'flex') {
      closePreview();
    }
  });

  if (isClosed) return;

  // ─── Signature canvas ───
  // CRITICAL: el canvas vive dentro del tab 'firma' que está display:none
  // al cargar. getBoundingClientRect() retorna 0×0 en ese estado, así que
  // el resize inicial dejaba el canvas a 0×0 y los pointer events no
  // dibujaban nada. Solución: inicializar lazy cuando el tab se activa,
  // re-init en cada apertura del tab para manejar rotación / resize.
  const canvas = document.getElementById('signature-canvas');
  let hasDrawn = false;
  let signatureInitialized = false;

  function initSignature() {
    if (!canvas) return;
    const rect = canvas.getBoundingClientRect();
    if (rect.width === 0 || rect.height === 0) return; // todavía oculto
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const dpr = window.devicePixelRatio || 1;

    // Si ya tiene contenido y mismo size, no rehacer
    const targetW = Math.round(rect.width * dpr);
    const targetH = Math.round(rect.height * dpr);
    if (signatureInitialized && canvas.width === targetW && canvas.height === targetH) return;

    // Si re-init con dibujo previo: preservar imagen redibujándola
    let prevImage = null;
    if (hasDrawn && canvas.width > 0 && canvas.height > 0) {
      prevImage = canvas.toDataURL('image/png');
    }
    canvas.width = targetW;
    canvas.height = targetH;
    ctx.setTransform(1, 0, 0, 1, 0, 0); // reset matrix antes de scale
    ctx.scale(dpr, dpr);
    ctx.lineWidth = 2.2;
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
    ctx.strokeStyle = '#1a1a1a';
    if (prevImage) {
      const img = new Image();
      img.onload = () => ctx.drawImage(img, 0, 0, rect.width, rect.height);
      img.src = prevImage;
    }
    signatureInitialized = true;
  }

  if (canvas) {
    const ctx = canvas.getContext('2d');
    let drawing = false;
    function getPos(e) {
      const rect = canvas.getBoundingClientRect();
      const t = e.touches ? e.touches[0] : e;
      return { x: t.clientX - rect.left, y: t.clientY - rect.top };
    }
    function start(e) {
      // Lazy init si todavía no está listo
      if (!signatureInitialized) initSignature();
      if (!signatureInitialized) return;
      drawing = true;
      const p = getPos(e);
      ctx.beginPath();
      ctx.moveTo(p.x, p.y);
      if (e.cancelable) e.preventDefault();
    }
    function move(e) {
      if (!drawing) return;
      const p = getPos(e);
      ctx.lineTo(p.x, p.y);
      ctx.stroke();
      hasDrawn = true;
      if (e.cancelable) e.preventDefault();
    }
    function end() { drawing = false; }

    canvas.addEventListener('mousedown', start);
    canvas.addEventListener('mousemove', move);
    canvas.addEventListener('mouseup', end);
    canvas.addEventListener('mouseleave', end);
    canvas.addEventListener('touchstart', start, { passive: false });
    canvas.addEventListener('touchmove', move, { passive: false });
    canvas.addEventListener('touchend', end);

    // Re-init cuando cambia el viewport (rotación, resize)
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(initSignature, 120);
    });

    const btnClear = document.getElementById('btn-clear-sig');
    if (btnClear) btnClear.addEventListener('click', () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      hasDrawn = false;
    });
  }

  // ─── Payout method toggle ───
  const payoutRadios = document.querySelectorAll('input[name="payout-method"]');
  const payoutSections = document.querySelectorAll('.p-payout-detail[data-payout-section]');
  function syncPayoutSections() {
    let active = 'clabe';
    payoutRadios.forEach(r => { if (r.checked) active = r.value; });
    payoutSections.forEach(s => {
      s.hidden = s.dataset.payoutSection !== active;
    });
  }
  payoutRadios.forEach(r => r.addEventListener('change', syncPayoutSections));
  syncPayoutSections();

  function val(id) {
    const el = document.getElementById(id);
    return el ? (el.value || '').trim() : '';
  }

  // ─── Accept (submit for review) ───
  const btnAccept = document.getElementById('btn-accept');
  if (btnAccept) btnAccept.addEventListener('click', async () => {
    const nombre = val('sign-nombre');
    const email = val('sign-email');
    const whatsapp = val('sign-whatsapp');
    const empresa = val('sign-empresa');

    const direccion = {
      calle: val('addr-calle'),
      colonia: val('addr-colonia'),
      cp: val('addr-cp'),
      ciudad: val('addr-ciudad'),
      estado: val('addr-estado'),
    };

    let payoutMethod = 'clabe';
    payoutRadios.forEach(r => { if (r.checked) payoutMethod = r.value; });
    let payout = { method: payoutMethod };
    if (payoutMethod === 'clabe') {
      payout = {
        method: 'clabe',
        clabe: val('payout-clabe'),
        banco: val('payout-banco'),
        titular: val('payout-titular'),
        rfc: val('payout-rfc'),
      };
    } else if (payoutMethod === 'paypal') {
      payout = { method: 'paypal', email: val('payout-paypal') };
    } else if (payoutMethod === 'mercadopago') {
      payout = {
        method: 'mercadopago',
        mp_id: val('payout-mp-id'),
        titular: val('payout-mp-titular'),
      };
    }

    // Validation
    if (!nombre) { alert('Ingresa tu nombre completo'); document.getElementById('sign-nombre')?.focus(); return; }
    if (!email) { alert('Ingresa tu email para enviarte la confirmación'); document.getElementById('sign-email')?.focus(); return; }
    if (!direccion.calle || !direccion.cp || !direccion.ciudad || !direccion.estado) {
      alert('Completa la dirección del negocio (calle, CP, ciudad y estado son requeridos)');
      document.getElementById('addr-calle')?.focus();
      return;
    }
    if (payoutMethod === 'clabe') {
      if (!payout.clabe || payout.clabe.length !== 18 || !/^\d{18}$/.test(payout.clabe)) {
        alert('La CLABE debe tener exactamente 18 dígitos');
        document.getElementById('payout-clabe')?.focus();
        return;
      }
      if (!payout.banco || !payout.titular) {
        alert('Completa banco y titular de la cuenta');
        return;
      }
    } else if (payoutMethod === 'paypal') {
      if (!payout.email || !payout.email.includes('@')) {
        alert('Ingresa un email PayPal válido');
        document.getElementById('payout-paypal')?.focus();
        return;
      }
    } else if (payoutMethod === 'mercadopago') {
      if (!payout.mp_id) {
        alert('Ingresa tu email o alias de Mercado Pago');
        document.getElementById('payout-mp-id')?.focus();
        return;
      }
    }
    if (!hasDrawn) { alert('Firma con tu dedo o mouse antes de enviar'); return; }

    btnAccept.disabled = true;
    btnAccept.textContent = 'Enviando solicitud...';

    const firma_base64 = canvas ? canvas.toDataURL('image/png') : '';
    try {
      const res = await fetch('/api/partners/accept-invitation', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: invitationId,
          nombre,
          email,
          whatsapp,
          empresa,
          direccion,
          payout,
          firma_base64,
        }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'No se pudo enviar');
      window.location.reload();
    } catch (err) {
      alert('Hubo un error: ' + (err.message || err));
      btnAccept.disabled = false;
      btnAccept.textContent = 'Enviar solicitud al equipo SACS';
    }
  });

  // ─── Decline ───
  const declineModal = document.getElementById('decline-modal');
  const btnDecline = document.getElementById('btn-decline');
  const btnCloseDecline = document.getElementById('btn-close-decline');
  const btnCancelDecline = document.getElementById('btn-cancel-decline');
  const btnConfirmDecline = document.getElementById('btn-confirm-decline');

  function openDecline() { if (declineModal) declineModal.style.display = 'flex'; }
  function closeDecline() { if (declineModal) declineModal.style.display = 'none'; }

  btnDecline && btnDecline.addEventListener('click', openDecline);
  btnCloseDecline && btnCloseDecline.addEventListener('click', closeDecline);
  btnCancelDecline && btnCancelDecline.addEventListener('click', closeDecline);

  btnConfirmDecline && btnConfirmDecline.addEventListener('click', async () => {
    const motivoInput = document.querySelector('input[name="decline-motivo"]:checked');
    const detalleInput = document.getElementById('decline-detalle');
    const motivo = motivoInput ? motivoInput.value : '';
    const detalle = detalleInput ? detalleInput.value.trim() : '';
    if (!motivo) { alert('Selecciona un motivo'); return; }

    btnConfirmDecline.disabled = true;
    btnConfirmDecline.textContent = 'Enviando...';
    try {
      const res = await fetch('/api/partners/decline-invitation', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: invitationId, motivo, detalle }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'No se pudo enviar');
      window.location.reload();
    } catch (err) {
      alert('Error: ' + (err.message || err));
      btnConfirmDecline.disabled = false;
      btnConfirmDecline.textContent = 'Enviar respuesta';
    }
  });

  // ─── Mensual / Anual toggle (proyección de ganancias) ───
  document.querySelectorAll('.p-toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const view = btn.dataset.projectionView;
      if (!view) return;
      // Update all scopes (matrix + closing cards)
      document.querySelectorAll('[data-projection-scope]').forEach(scope => {
        scope.dataset.projectionView = view;
      });
      // Sync the active state on all toggle buttons
      document.querySelectorAll('.p-toggle-btn').forEach(b => {
        const isActive = b.dataset.projectionView === view;
        b.classList.toggle('is-active', isActive);
        b.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
    });
  });
})();
</script>
