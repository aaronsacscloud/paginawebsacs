    .p-sign-actions {
      position: sticky !important;
      bottom: 0 !important;
      background: #fff !important;
      padding: 16px 20px calc(16px + env(safe-area-inset-bottom)) !important;
      margin: 24px -20px 0 !important;
      border-top: 1px solid #ececec !important;
      box-shadow: 0 -8px 24px -8px rgba(0, 0, 0, 0.08) !important;
      z-index: 20;
    }
    .p-sign-actions .p-btn--primary,
    .p-sign-actions .p-btn { width: 100% !important; }
  }

  /* ===================================================================
     CRITICAL · Prevent horizontal overflow en mobile
     Usar overflow-x: clip en lugar de hidden — clip NO rompe sticky en
     descendientes. hidden creaba un scroll container que rompía el
     header sticky (.p-mh) que se comportaba como relative.
     =================================================================== */
  @media (max-width: 1023px) {
    html, body { overflow-x: clip; max-width: 100vw; }
    .p-page { max-width: 100vw; overflow-x: clip; }
    .p-layout { max-width: 100vw; overflow-x: clip; }
    .p-langswitch { max-width: 100%; flex-wrap: wrap; }
    .p-container { max-width: 100% !important; }
  }

  /* ===================================================================
     MOBILE NAV REWRITE · index + sections (< 1024px)
     Comportamiento estilo iOS Settings:
     1. Al cargar → vista index con cards bonitas de cada sección
     2. Click en card → muestra solo esa sección + header sticky con
        ← back y select para saltar entre secciones
     3. Click back → vuelve al index
     =================================================================== */
  .p-mh, .p-mi { display: none; }

  @media (max-width: 1023px) {
    /* Ocultar el header desktop y la mobnav antigua */
    .p-header { display: none; }
    .p-mobnav { display: none !important; }

    /* Por default body está en mode 'index': muestra index, oculta paneles y mobile header */
    body:not(.is-mb-section) .p-mi { display: block; }
    body:not(.is-mb-section) .p-tab-panel { display: none !important; }
    body:not(.is-mb-section) .p-mh { display: none; }
    body:not(.is-mb-section) .p-langswitch { padding: 14px 16px 4px; }

    /* Mode 'section': header sticky visible, solo panel activo visible */
    body.is-mb-section .p-mh { display: flex; }
    body.is-mb-section .p-mi { display: none; }
    body.is-mb-section .p-tab-panel { display: none; }
    body.is-mb-section .p-tab-panel.is-active { display: block !important; }
    body.is-mb-section .p-langswitch { display: none; }

    /* Mobile header sticky · back + select */
    .p-mh {
      position: sticky;
      top: 0;
      z-index: 60;
      background: #fafaf8;
      border-bottom: 1px solid #ececec;
      padding: 10px 16px;
      align-items: center;
      gap: 12px;
      min-height: 56px;
    }
    .p-mh-back {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: transparent;
      border: none;
      color: #1a1a1a;
      font-family: inherit;
      font-size: 0.9375rem;
      font-weight: 500;
      cursor: pointer;
      padding: 8px 10px 8px 6px;
      margin-left: -6px;
      border-radius: 8px;
      min-height: 44px;
    }
    .p-mh-back:active { background: rgba(0,0,0,0.05); }
    .p-mh-select {
      flex: 1;
      min-width: 0;
      appearance: none;
      -webkit-appearance: none;
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 10px;
      padding: 10px 36px 10px 14px;
      font-family: inherit;
      font-size: 0.875rem;
      font-weight: 500;
      color: #1a1a1a;
      letter-spacing: -0.005em;
      min-height: 44px;
      cursor: pointer;
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%23555' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>");
      background-repeat: no-repeat;
      background-position: right 12px center;
      background-size: 16px;
    }
    .p-mh-select:focus {
      outline: none;
      border-color: #4B7BE5;
      box-shadow: 0 0 0 3px rgba(75,123,229,0.15);
    }

    /* Mobile index · pantalla inicial */
    .p-mi {
      padding: 24px 20px 80px;
      max-width: 100%;
      box-sizing: border-box;
    }
    .p-mi-hero { margin-bottom: 32px; }
    .p-mi-eyebrow {
      font-size: 0.6875rem;
      font-weight: 700;
      color: #4B7BE5;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      margin-bottom: 14px;
    }
    .p-mi-title {
      font-family: var(--font-display, 'Inter', system-ui, sans-serif);
      font-size: clamp(1.875rem, 8vw, 2.5rem);
      font-weight: 500;
      letter-spacing: -0.028em;
      line-height: 1.1;
      color: #1a1a1a;
      margin: 0 0 14px;
      word-break: break-word;
    }
    .p-mi-title span { color: #4B7BE5; }
    .p-mi-sub {
      font-size: 0.9375rem;
      line-height: 1.55;
      color: #555;
      margin: 0 0 20px;
    }
    .p-mi-sub strong { color: #1a1a1a; font-weight: 600; }
    .p-mi-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 10px;
      font-size: 0.75rem;
    }
    .p-mi-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 10px;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.6875rem;
      letter-spacing: 0.02em;
      text-transform: uppercase;
    }
    .p-mi-badge--active { background: rgba(75,123,229,0.10); color: #4B7BE5; }
    .p-mi-badge--accepted { background: rgba(42,181,160,0.12); color: #2AB5A0; }
    .p-mi-badge--declined { background: rgba(229,75,75,0.12); color: #C03E3E; }
    .p-mi-badge--expired { background: rgba(120,120,120,0.12); color: #555; }
    .p-mi-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: currentColor;
    }
    .p-mi-numero {
      font-family: 'SF Mono', Menlo, monospace;
      font-size: 0.6875rem;
      color: #777;
      letter-spacing: 0.02em;
    }

    /* Cover ilustrada del programa */
    .p-mi-cover {
      margin: 0 -4px 32px;
      border-radius: 20px;
      overflow: hidden;
      background: #faf7f2;
      aspect-ratio: 3 / 2;
      box-shadow: 0 8px 24px -10px rgba(75,123,229,0.18);
    }
    .p-mi-cover img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* Título de la lista de secciones */
    .p-mi-listtitle {
      display: flex;
      align-items: baseline;
      gap: 10px;
      margin: 0 4px 14px;
    }
    .p-mi-listtitle-num {
      font-family: var(--font-display, 'Inter', system-ui, sans-serif);
      font-size: 1.625rem;
      font-weight: 500;
      color: #4B7BE5;
      letter-spacing: -0.02em;
      line-height: 1;
    }
    .p-mi-listtitle-text {
      font-size: 0.875rem;
      color: #666;
      line-height: 1.4;
    }

    /* Cards de secciones */
    .p-mi-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      background: #fff;
      border: 1px solid #ececec;
      border-radius: 16px;
      padding: 4px;
      box-shadow: 0 1px 2px rgba(0,0,0,0.02);
    }
    .p-mi-card {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 14px 12px 12px;
      background: transparent;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      text-align: left;
      font-family: inherit;
      width: 100%;
      min-height: 80px;
      transition: background 0.15s;
    }
    .p-mi-card:hover { background: #fafaf8; }
    .p-mi-card:active { background: #f0f0ed; }
    .p-mi-card + .p-mi-card { border-top: 1px solid #f4f4f1; }
    .p-mi-card-img {
      position: relative;
      flex-shrink: 0;
      width: 56px; height: 56px;
      border-radius: 12px;
      overflow: hidden;
      background: #faf7f2;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
    }
    .p-mi-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      pointer-events: none;
      user-select: none;
      -webkit-user-select: none;
      -webkit-user-drag: none;
    }
    /* Checkmark overlay · solo visible cuando card está marcada como visitada */
    .p-mi-card-check {
      position: absolute;
      bottom: -4px;
      right: -4px;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: #2AB5A0;
      color: #fff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 0 2px #fff, 0 2px 6px rgba(42,181,160,0.35);
      opacity: 0;
      transform: scale(0.5);
      transition: opacity 0.2s, transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .p-mi-card.is-visited .p-mi-card-check {
      opacity: 1;
      transform: scale(1);
    }
    .p-mi-card.is-visited .p-mi-card-img img {
      opacity: 0.78;
      transition: opacity 0.2s;
    }
    .p-mi-card.is-visited .p-mi-card-title {
      color: #777;
    }

    /* Meta línea: num · tiempo */
    .p-mi-card-meta {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: 'SF Mono', Menlo, monospace;
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      color: #4B7BE5;
      text-transform: uppercase;
    }
    .p-mi-card-sep { color: #c5cad3; font-weight: 400; }
    .p-mi-card-time { color: #999; font-weight: 600; }

    /* Asegurar que TODO el contenido interno de la card no captura touch */
    .p-mi-card > * { pointer-events: none; }
    .p-mi-card {
      -webkit-tap-highlight-color: rgba(75,123,229,0.10);
      touch-action: manipulation;
      animation: pmiCardIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
      animation-delay: calc(var(--i, 0) * 55ms + 80ms);
      opacity: 0;
    }
    @keyframes pmiCardIn {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @media (prefers-reduced-motion: reduce) {
      .p-mi-card { animation: none !important; opacity: 1; }
    }

    /* Banner CTA "Firmar" al final del index */
    .p-mi-cta {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
      margin: 28px 0 8px;
      padding: 22px 64px 22px 22px;
      background: linear-gradient(135deg, #4B7BE5 0%, #3866d0 100%);
      color: #fff;
      border: none;
      border-radius: 18px;
      cursor: pointer;
      text-align: left;
      font-family: inherit;
      width: 100%;
      box-shadow: 0 12px 32px -10px rgba(75,123,229,0.45);
      -webkit-tap-highlight-color: rgba(255,255,255,0.10);
      touch-action: manipulation;
      animation: pmiCardIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
      animation-delay: calc(var(--total, 11) * 55ms + 200ms);
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .p-mi-cta > * { pointer-events: none; }
    .p-mi-cta:active { transform: scale(0.985); box-shadow: 0 8px 20px -10px rgba(75,123,229,0.55); }
    .p-mi-cta-eyebrow {
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.78);
    }
    .p-mi-cta-title {
      font-family: var(--font-display, 'Inter', system-ui, sans-serif);
      font-size: 1.375rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      line-height: 1.2;
      color: #fff;
    }
    .p-mi-cta-sub {
      font-size: 0.8125rem;
      color: rgba(255,255,255,0.82);
      margin-top: 2px;
      line-height: 1.4;
    }
    .p-mi-cta-arrow {
      position: absolute;
      right: 18px;
      top: 50%;
      transform: translateY(-50%);
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: rgba(255,255,255,0.16);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: #fff;
    }
    .p-mi-card-body {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 3px;
    }
    .p-mi-card-num {
      font-family: 'SF Mono', Menlo, monospace;
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      color: #4B7BE5;
      text-transform: uppercase;
    }
    .p-mi-card-title {
      font-size: 1rem;
      font-weight: 500;
      color: #1a1a1a;
      letter-spacing: -0.005em;
      line-height: 1.3;
    }
    .p-mi-card-arrow {
      flex-shrink: 0;
      color: #999;
    }

    /* Footer del index */
    .p-mi-footer {
      margin-top: 24px;
      padding: 16px 4px;
      font-size: 0.8125rem;
      color: #777;
      line-height: 1.55;
      text-align: center;
    }
    .p-mi-footer strong { color: #4B7BE5; font-weight: 600; }

    /* Scroll suave a top cuando cambia de sección */
    body.is-mb-section .p-tab-panel.is-active {
      padding-top: 8px !important;
      padding-bottom: 80px !important;
    }
  }
</style>

<script is:inline define:vars={{ invitationId: id, isClosed, isAdminMode, benefMsg: { errSum: tt('sign.benef.err_sum'), errNombre: tt('sign.benef.err_nombre') } }}>
(function() {
  // ─── Tab switcher ───
  const doc = document.getElementById('partner-doc');
  if (!doc) return;
  const initialTab = doc.dataset.initialTab || 'bienvenida';

  function showTab(tabId) {
    document.querySelectorAll('.p-tab-panel').forEach(p => {
      p.classList.toggle('is-active', p.dataset.tab === tabId);
    });
    // Desktop sidebar tabs
    document.querySelectorAll('[data-tab-link]').forEach(link => {
      const id = link.dataset.tabLink;
      if (id === tabId) link.classList.add('psb-tab--active');
      else if (link.classList.contains('psb-tab--active')) link.classList.remove('psb-tab--active');
    });
    // Mobile pill nav: active state + scroll into view
    document.querySelectorAll('.p-mobnav-tab').forEach(link => {
      const id = link.dataset.tabLink;
      if (id === tabId) {
        link.classList.add('p-mobnav-tab--active');
        // Centrar pill activo en el scroll horizontal
        try {
          link.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        } catch {}
      } else {
        link.classList.remove('p-mobnav-tab--active');
      }
    });
    if (history.replaceState) {
      history.replaceState(null, '', '#' + tabId);
    }
    // Init signature canvas la primera vez que el tab firma se hace visible
    if (tabId === 'firma') {
      requestAnimationFrame(() => {
        if (typeof initSignature === 'function') initSignature();
      });
    }
    // Scroll al inicio del contenido al cambiar tab (aria-current page anchor)
    requestAnimationFrame(() => {
      const target = document.querySelector('.p-tab-panel.is-active');
      if (target) {
        const rect = target.getBoundingClientRect();
        if (rect.top < 0 || rect.top > window.innerHeight * 0.5) {
          window.scrollTo({ top: window.scrollY + rect.top - 90, behavior: 'smooth' });
        }
      }
    });
  }

  // Wire links · en mobile scroll a sección, en desktop toggle tab
  const isMobileLayout = () => window.matchMedia('(max-width: 900px)').matches;
  document.addEventListener('click', e => {
    const link = e.target.closest('[data-tab-link]');
    if (!link) return;
    const tabId = link.dataset.tabLink;
    if (!tabId) return;
    e.preventDefault();
    if (isMobileLayout()) {
      // Mobile: todos los paneles están visibles, scroll al target
      const target = document.getElementById(tabId);
      if (target) {
        const rect = target.getBoundingClientRect();
        const navH = document.querySelector('.p-mobnav')?.getBoundingClientRect().height || 70;
        window.scrollTo({ top: window.scrollY + rect.top - navH - 8, behavior: 'smooth' });
      }
      // Marcar pill activo
      document.querySelectorAll('.p-mobnav-tab').forEach(l => {
        l.classList.toggle('p-mobnav-tab--active', l.dataset.tabLink === tabId);
      });
      if (history.replaceState) history.replaceState(null, '', '#' + tabId);
    } else {
      showTab(tabId);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  // ─── FAQ accordion (objeciones) ───
  document.addEventListener('click', e => {
    const btn = e.target.closest('[data-faq-toggle]');
    if (!btn) return;
    const item = btn.closest('[data-faq-item]');
    if (!item) return;
    const open = item.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
  });

  // ─── Calculadora interactiva de ingresos ───
  (function initCalc() {
    const calc = document.querySelector('[data-calc]');
    if (!calc) return;
    const PLANS = [
      { name: 'Vende',      monthly: 600,  annualTotal: 6000  },
      { name: 'Controla',   monthly: 900,  annualTotal: 9000  },
      { name: 'Fideliza',   monthly: 1400, annualTotal: 14000 },
      { name: 'Automatiza', monthly: 5900, annualTotal: 59000 },
    ];
    const RATE = parseFloat(calc.getAttribute('data-rate') || '0.5');
    const BONUS_PRUEBA = parseFloat(calc.getAttribute('data-bp') || '250');
    const BONUS_DEMO   = parseFloat(calc.getAttribute('data-bd') || '300');
    const FX_RATE = parseFloat(calc.getAttribute('data-fx') || '1');
    const FX_CUR  = calc.getAttribute('data-cur') || 'MXN';
    const FX_LOC  = calc.getAttribute('data-loc') || 'es-MX';

    function fmt(mxnAmount) {
      const local = mxnAmount * FX_RATE;
      try {
        return new Intl.NumberFormat(FX_LOC, { style: 'currency', currency: FX_CUR, minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(Math.round(local));
      } catch {
        return '$' + Math.round(local).toLocaleString(FX_LOC);
      }
    }
    function read(name) {
      const el = calc.querySelector(`[data-calc-input="${name}"]`);
      return el ? Number(el.value) : 0;
    }
    function setOut(name, value) {
      const el = calc.querySelector(`[data-calc-out="${name}"]`);
      if (el) el.textContent = value;
    }
    function recompute() {
      const pruebas  = read('pruebas');
      const demos    = read('demos');
      const clientes = read('clientes');
      const planIdx  = read('plan');
      const plan     = PLANS[planIdx] || PLANS[2];

      const bonosAnual   = (pruebas * BONUS_PRUEBA + demos * BONUS_DEMO) * 12;
      const ventasAnual  = clientes * plan.annualTotal * RATE;
      const total        = bonosAnual + ventasAnual;

      setOut('pruebas', pruebas);
      setOut('demos', demos);
      setOut('clientes', clientes);
      setOut('plan-name', plan.name);
      setOut('bonos-anual', fmt(bonosAnual));
      setOut('ventas-anual', fmt(ventasAnual));
      setOut('total-anual', fmt(total));
    }
    calc.querySelectorAll('[data-calc-input]').forEach(el => {
      el.addEventListener('input', recompute);
      el.addEventListener('change', recompute);
    });
    recompute();
  })();

  // ─── Sub-tabs por categoría (Contenido / Apoyo / Filantropía) ───
  document.addEventListener('click', e => {
    const tab = e.target.closest('[data-cat-tab]');
    if (!tab) return;
    const id = tab.dataset.catTab;
    document.querySelectorAll('[data-cat-tab]').forEach(t => {
      const active = t.dataset.catTab === id;
      t.classList.toggle('is-active', active);
      t.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    document.querySelectorAll('[data-cat-panel]').forEach(p => {
      const active = p.dataset.catPanel === id;
      p.classList.toggle('is-active', active);
      if (active) p.removeAttribute('hidden'); else p.setAttribute('hidden', '');
    });
  });

  // ─── Filtro de perfil (Influencer / Nómada / Dueño / Todos) ───
  function applyPerfilFilter(perfilId) {
    document.querySelectorAll('[data-perfil-filter]').forEach(p => {
      const active = p.dataset.perfilFilter === perfilId;
      p.classList.toggle('is-active', active);
      p.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    // Filtra cards y actualiza contadores por categoría
    const counts = { contenido: 0, apoyo: 0, filantropia: 0 };
    document.querySelectorAll('[data-cat-panel]').forEach(panel => {
      const cat = panel.dataset.catPanel;
      let visible = 0;
      panel.querySelectorAll('.p-content-type-card').forEach(card => {
        const tags = (card.dataset.perfiles || 'todos').split(',');
        const show = perfilId === 'todos' || tags.includes('todos') || tags.includes(perfilId);
        card.classList.toggle('is-hidden', !show);
        if (show) visible++;
      });
      if (cat) counts[cat] = visible;
      // Mensaje vacío
      let emptyMsg = panel.querySelector('.p-cat-panel-empty');
      if (visible === 0) {
        if (!emptyMsg) {
          emptyMsg = document.createElement('div');
          emptyMsg.className = 'p-cat-panel-empty';
          const emptyMsgText = document.querySelector('.p-perfil-filter')?.getAttribute('data-empty-msg') || 'Sin acciones específicas para este perfil.';
          emptyMsg.textContent = emptyMsgText;
          panel.querySelector('.p-content-types-grid')?.appendChild(emptyMsg);
        }
      } else if (emptyMsg) {
        emptyMsg.remove();
      }
    });
    document.querySelectorAll('[data-cat-count]').forEach(c => {
      const cat = c.dataset.catCount;
      if (counts[cat] !== undefined) c.textContent = String(counts[cat]);
    });
  }
  document.addEventListener('click', e => {
    const pill = e.target.closest('[data-perfil-filter]');
    if (!pill) return;
    applyPerfilFilter(pill.dataset.perfilFilter);
  });

  // Initial tab from hash or initialTab
  const hash = (location.hash || '').replace('#', '');
  // ─── Mobile: lógica index ↔ section + tracking de visitadas ───
  const VISITED_KEY = 'sacs_inv_visited_' + invitationId;
  function loadVisited() {
    try { return new Set(JSON.parse(localStorage.getItem(VISITED_KEY) || '[]')); }
    catch { return new Set(); }
  }
  function saveVisited(set) {
    try { localStorage.setItem(VISITED_KEY, JSON.stringify([...set])); } catch {}
  }
  function refreshVisitedUI() {
    const visited = loadVisited();
    document.querySelectorAll('.p-mi-card').forEach(card => {
      card.classList.toggle('is-visited', visited.has(card.dataset.tabLink));
    });
  }
  function markVisited(tabId) {
    const visited = loadVisited();
    if (!visited.has(tabId)) {
      visited.add(tabId);
      saveVisited(visited);
    }
  }

  function mobileShowSection(tabId) {
    document.body.classList.add('is-mb-section');
    document.querySelectorAll('.p-tab-panel').forEach(p => {
      p.classList.toggle('is-active', p.dataset.tab === tabId);
    });
    const sel = document.getElementById('p-mh-select');
    if (sel) sel.value = tabId;
    if (history.replaceState) history.replaceState(null, '', '#' + tabId);
    requestAnimationFrame(() => window.scrollTo({ top: 0, behavior: 'auto' }));
    markVisited(tabId);
    // Inicializar firma canvas si entra al tab firma
    if (tabId === 'firma') {
      requestAnimationFrame(() => {
        if (typeof initSignature === 'function') initSignature();
      });
    }
  }
  function mobileShowIndex() {
    document.body.classList.remove('is-mb-section');
    document.querySelectorAll('.p-tab-panel').forEach(p => p.classList.remove('is-active'));
    if (history.replaceState) history.replaceState(null, '', window.location.pathname);
    refreshVisitedUI();
    requestAnimationFrame(() => window.scrollTo({ top: 0, behavior: 'auto' }));
  }

  if (isMobileLayout()) {
    refreshVisitedUI();
    // Click en cards del index Y en banner CTA
    document.querySelectorAll('.p-mi-card, .p-mi-cta').forEach(btn => {
      btn.addEventListener('click', e => {
        e.preventDefault();
        const tabId = btn.dataset.tabLink;
        if (tabId) mobileShowSection(tabId);
      });
    });
    // Click en back button
    const backBtn = document.getElementById('p-mh-back');
    if (backBtn) backBtn.addEventListener('click', () => mobileShowIndex());
    // Change en select
    const sel = document.getElementById('p-mh-select');
    if (sel) sel.addEventListener('change', e => {
      const v = e.target.value;
      if (v) mobileShowSection(v);
    });
    // Estado inicial: si hay hash, abre esa sección; si está cerrado, abre firma; si no, muestra index
    if (hash) {
      mobileShowSection(hash);
    } else if (isClosed) {
      mobileShowSection('firma');
    } else {
      mobileShowIndex();
    }
  } else {
    showTab(hash || initialTab);
  }

  // ─── Preview del panel modal (siempre disponible) ───
  const previewOverlay = document.getElementById('preview-overlay');
  const btnOpenPreview = document.getElementById('btn-open-preview');
  const btnClosePreview = document.getElementById('btn-close-preview');
  function openPreview() {
    if (previewOverlay) {
      previewOverlay.style.display = 'block';
      document.body.style.overflow = 'hidden';
      // Reset to first tab
      switchPpTab('resumen');
    }
  }
  function closePreview() {
    if (previewOverlay) {
      previewOverlay.style.display = 'none';
      document.body.style.overflow = '';
    }
  }
  btnOpenPreview && btnOpenPreview.addEventListener('click', openPreview);
  btnClosePreview && btnClosePreview.addEventListener('click', closePreview);

  // ─── Preview portal: navegación entre tabs internos ───
  function switchPpTab(tabName) {
    if (!tabName) return;
    document.querySelectorAll('.pp-app-nav[data-pp-tab]').forEach(btn => {
      btn.classList.toggle('pp-app-nav--active', btn.getAttribute('data-pp-tab') === tabName);
    });
    document.querySelectorAll('.pp-app-panel[data-pp-panel]').forEach(panel => {
      panel.classList.toggle('pp-app-panel--active', panel.getAttribute('data-pp-panel') === tabName);
    });
    const main = document.querySelector('.pp-app-main');
    if (main) main.scrollTop = 0;
  }
  document.querySelectorAll('[data-pp-tab]').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const tab = el.getAttribute('data-pp-tab');
      if (tab) switchPpTab(tab);
    });
  });
  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && previewOverlay && previewOverlay.style.display !== 'none') closePreview();
  });

  // ─── Preview portal: filtros de comisiones ───
  const ppFiltersState = { estado: 'todas', tipo: 'todos' };
  function applyPpFilters() {
    const table = document.getElementById('pp-comisiones-table');
    if (!table) return;
    const rows = table.querySelectorAll('.pp-trow:not(.pp-trow--head)');
    let visibleCount = 0;
    rows.forEach((row) => {
      const estado = row.getAttribute('data-pp-estado');
      const tipo = row.getAttribute('data-pp-tipo');
      const matchEstado = ppFiltersState.estado === 'todas' || estado === ppFiltersState.estado;
      const matchTipo = ppFiltersState.tipo === 'todos' || tipo === ppFiltersState.tipo;
      const visible = matchEstado && matchTipo;
      row.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });
    // Show empty state if no rows visible
    let empty = table.querySelector('.pp-trow--empty');
    if (visibleCount === 0) {
      if (!empty) {
        empty = document.createElement('div');
        empty.className = 'pp-trow pp-trow--empty';
        empty.innerHTML = '<span style="grid-column: 1 / -1; text-align: center; color: #888; padding: 24px 0; font-size: 0.875rem">No hay comisiones que coincidan con este filtro.</span>';
        table.appendChild(empty);
      }
    } else if (empty) {
      empty.remove();
    }
  }
  document.querySelectorAll('[data-pp-filter]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const filterType = btn.getAttribute('data-pp-filter');
      const value = btn.getAttribute('data-pp-value') || '';
      if (!filterType || !value) return;
      ppFiltersState[filterType] = value;
      // Update active state within same group
      const group = btn.closest('[data-pp-filter-group]');
      if (group) {
        group.querySelectorAll('.pp-filter').forEach((f) => f.classList.remove('pp-filter--active'));
        btn.classList.add('pp-filter--active');
      }
      applyPpFilters();
    });
  });
  // Close on overlay backdrop click
  previewOverlay && previewOverlay.addEventListener('click', (e) => {
    if (e.target === previewOverlay) closePreview();
  });
  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && previewOverlay && previewOverlay.style.display === 'flex') {
      closePreview();
    }
  });

  if (isClosed) return;

  // ─── Signature canvas ───
  // CRITICAL: el canvas vive dentro del tab 'firma' que está display:none
  // al cargar. getBoundingClientRect() retorna 0×0 en ese estado, así que
  // el resize inicial dejaba el canvas a 0×0 y los pointer events no
  // dibujaban nada. Solución: inicializar lazy cuando el tab se activa,
  // re-init en cada apertura del tab para manejar rotación / resize.
  const canvas = document.getElementById('signature-canvas');
  let hasDrawn = false;
  let signatureInitialized = false;

  function initSignature() {
    if (!canvas) return;
    const rect = canvas.getBoundingClientRect();
    if (rect.width === 0 || rect.height === 0) return; // todavía oculto
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const dpr = window.devicePixelRatio || 1;

    // Si ya tiene contenido y mismo size, no rehacer
    const targetW = Math.round(rect.width * dpr);
    const targetH = Math.round(rect.height * dpr);
    if (signatureInitialized && canvas.width === targetW && canvas.height === targetH) return;

    // Si re-init con dibujo previo: preservar imagen redibujándola
    let prevImage = null;
    if (hasDrawn && canvas.width > 0 && canvas.height > 0) {
      prevImage = canvas.toDataURL('image/png');
    }
    canvas.width = targetW;
    canvas.height = targetH;
    ctx.setTransform(1, 0, 0, 1, 0, 0); // reset matrix antes de scale
    ctx.scale(dpr, dpr);
    ctx.lineWidth = 2.2;
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
    ctx.strokeStyle = '#1a1a1a';
    if (prevImage) {
      const img = new Image();
      img.onload = () => ctx.drawImage(img, 0, 0, rect.width, rect.height);
      img.src = prevImage;
    }
    signatureInitialized = true;
  }

  if (canvas) {
    const ctx = canvas.getContext('2d');
    let drawing = false;
    function getPos(e) {
      const rect = canvas.getBoundingClientRect();
      const t = e.touches ? e.touches[0] : e;
      return { x: t.clientX - rect.left, y: t.clientY - rect.top };
    }
    function start(e) {
      // Lazy init si todavía no está listo
      if (!signatureInitialized) initSignature();
      if (!signatureInitialized) return;
      drawing = true;
      const p = getPos(e);
      ctx.beginPath();
      ctx.moveTo(p.x, p.y);
      if (e.cancelable) e.preventDefault();
    }
    function move(e) {
      if (!drawing) return;
      const p = getPos(e);
      ctx.lineTo(p.x, p.y);
      ctx.stroke();
      hasDrawn = true;
      if (e.cancelable) e.preventDefault();
    }
    function end() { drawing = false; }

    canvas.addEventListener('mousedown', start);
    canvas.addEventListener('mousemove', move);
    canvas.addEventListener('mouseup', end);
    canvas.addEventListener('mouseleave', end);
    canvas.addEventListener('touchstart', start, { passive: false });
    canvas.addEventListener('touchmove', move, { passive: false });
    canvas.addEventListener('touchend', end);

    // Re-init cuando cambia el viewport (rotación, resize)
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(initSignature, 120);
    });

    const btnClear = document.getElementById('btn-clear-sig');
    if (btnClear) btnClear.addEventListener('click', () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      hasDrawn = false;
    });
  }

  // ─── Payout method toggle ───
  const payoutRadios = document.querySelectorAll('input[name="payout-method"]');
  const payoutSections = document.querySelectorAll('.p-payout-detail[data-payout-section]');
  function syncPayoutSections() {
    let active = 'clabe';
    payoutRadios.forEach(r => { if (r.checked) active = r.value; });
    payoutSections.forEach(s => {
      s.hidden = s.dataset.payoutSection !== active;
    });
  }
  payoutRadios.forEach(r => r.addEventListener('change', syncPayoutSections));
  syncPayoutSections();

  // ── Beneficiarios: agregar/quitar filas (máx 3) + suma de porcentajes en vivo ──
  (function initBeneficiarios() {
    const list = document.getElementById('benef-list');
    if (!list) return;
    const rows = Array.prototype.slice.call(list.querySelectorAll('.benef-row'));
    const addBtn = document.getElementById('benef-add');
    const sumWrap = document.getElementById('benef-sum');
    const sumVal = document.getElementById('benef-sum-val');
    function visibles() { return rows.filter(function (r) { return !r.hidden; }); }
    function recalcSuma() {
      let total = 0, hayDatos = false;
      visibles().forEach(function (r) {
        const nombre = (r.querySelector('.benef-nombre').value || '').trim();
        const pctRaw = (r.querySelector('.benef-pct').value || '').trim();
        if (nombre || pctRaw) hayDatos = true;
        const pct = pctRaw === '' ? 0 : Number(pctRaw);
        total += isFinite(pct) ? pct : 0;
      });
      total = Math.round(total * 100) / 100;
      if (sumVal) sumVal.textContent = String(total);
      if (sumWrap) {
        sumWrap.hidden = !hayDatos;
        sumWrap.classList.toggle('is-ok', hayDatos && total === 100);
        sumWrap.classList.toggle('is-bad', hayDatos && total !== 100);
      }
    }
    function syncAdd() {
      if (addBtn) addBtn.disabled = visibles().length >= rows.length;
    }
    list.addEventListener('input', function (e) {
      if (e.target && (e.target.classList.contains('benef-pct') || e.target.classList.contains('benef-nombre'))) recalcSuma();
    });
    if (addBtn) addBtn.addEventListener('click', function () {
      const oculta = rows.filter(function (r) { return r.hidden; })[0];
      if (oculta) { oculta.hidden = false; oculta.querySelector('.benef-nombre').focus(); }
      syncAdd();
    });
    list.addEventListener('click', function (e) {
      const btn = e.target.closest ? e.target.closest('.benef-remove') : null;
      if (!btn) return;
      const row = btn.closest('.benef-row');
      if (!row) return;
      row.hidden = true;
      row.querySelectorAll('input').forEach(function (inp) { inp.value = ''; });
      syncAdd(); recalcSuma();
    });
    syncAdd(); recalcSuma();
  })();

  function val(id) {
    const el = document.getElementById(id);
    return el ? (el.value || '').trim() : '';
  }

  // ─── Accept (submit for review) ───
  const btnAccept = document.getElementById('btn-accept');
  if (btnAccept) btnAccept.addEventListener('click', async () => {
    const nombre = val('sign-nombre');
    const email = val('sign-email');
    const whatsapp = val('sign-whatsapp');
    const empresa = val('sign-empresa');

    const direccion = {
      calle: val('addr-calle'),
      colonia: val('addr-colonia'),
      cp: val('addr-cp'),
      ciudad: val('addr-ciudad'),
      estado: val('addr-estado'),
    };

    let payoutMethod = 'clabe';
    payoutRadios.forEach(r => { if (r.checked) payoutMethod = r.value; });
    let payout = { method: payoutMethod };
    if (payoutMethod === 'clabe') {
      payout = {
        method: 'clabe',
        clabe: val('payout-clabe'),
        banco: val('payout-banco'),
        titular: val('payout-titular'),
        rfc: val('payout-rfc'),
      };
    } else if (payoutMethod === 'paypal') {
      payout = { method: 'paypal', email: val('payout-paypal') };
    } else if (payoutMethod === 'mercadopago') {
      payout = {
        method: 'mercadopago',
        mp_id: val('payout-mp-id'),
        titular: val('payout-mp-titular'),
      };
    }

    // Beneficiarios (opcional, hasta 3): solo filas visibles y con algún dato.
    const beneficiarios = [];
    let benefSum = 0;
    document.querySelectorAll('#benef-list .benef-row').forEach(function (row) {
      if (row.hidden) return;
      const bNombre = (row.querySelector('.benef-nombre')?.value || '').trim();
      const bParentesco = (row.querySelector('.benef-parentesco')?.value || '').trim();
      const bPctRaw = (row.querySelector('.benef-pct')?.value || '').trim();
      if (!bNombre && !bPctRaw) return; // fila totalmente vacía → se ignora
      const bPct = bPctRaw === '' ? 0 : Number(bPctRaw);
      beneficiarios.push({ nombre: bNombre, parentesco: bParentesco, porcentaje: isFinite(bPct) ? bPct : 0 });
      benefSum += isFinite(bPct) ? bPct : 0;
    });

    // Validation
    if (!nombre) { alert('Ingresa tu nombre completo'); document.getElementById('sign-nombre')?.focus(); return; }
    if (!email) { alert('Ingresa tu email para enviarte la confirmación'); document.getElementById('sign-email')?.focus(); return; }
    if (!direccion.calle || !direccion.cp || !direccion.ciudad || !direccion.estado) {
      alert('Completa la dirección del negocio (calle, CP, ciudad y estado son requeridos)');
      document.getElementById('addr-calle')?.focus();
      return;
    }
    if (payoutMethod === 'clabe') {
      if (!payout.clabe || payout.clabe.length !== 18 || !/^\d{18}$/.test(payout.clabe)) {
        alert('La CLABE debe tener exactamente 18 dígitos');
        document.getElementById('payout-clabe')?.focus();
        return;
      }
      if (!payout.banco || !payout.titular) {
        alert('Completa banco y titular de la cuenta');
        return;
      }
    } else if (payoutMethod === 'paypal') {
      if (!payout.email || !payout.email.includes('@')) {
        alert('Ingresa un email PayPal válido');
        document.getElementById('payout-paypal')?.focus();
        return;
      }
    } else if (payoutMethod === 'mercadopago') {
      if (!payout.mp_id) {
        alert('Ingresa tu email o alias de Mercado Pago');
        document.getElementById('payout-mp-id')?.focus();
        return;
      }
    }
    if (!hasDrawn) { alert('Firma con tu dedo o mouse antes de enviar'); return; }

    // Beneficiarios: si designó alguno, todos con nombre y la suma debe dar 100%.
    if (beneficiarios.length > 0) {
      if (beneficiarios.some(function (b) { return !b.nombre; })) { alert(benefMsg.errNombre); return; }
      if (Math.round(benefSum) !== 100) { alert(benefMsg.errSum); return; }
    }

    btnAccept.disabled = true;
    btnAccept.textContent = 'Enviando solicitud...';

    const firma_base64 = canvas ? canvas.toDataURL('image/png') : '';
    try {
      const res = await fetch('/api/partners/accept-invitation', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: invitationId,
          nombre,
          email,
          whatsapp,
          empresa,
          direccion,
          payout,
          beneficiarios,
          firma_base64,
        }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'No se pudo enviar');
      // If auto-approved, reload to render certificate. Otherwise advance to step 3.
      if (data.auto_approved) {
        window.location.reload();
      } else {
        if (typeof goSwStep === 'function') goSwStep(3);
        else window.location.reload();
      }
    } catch (err) {
      alert('Hubo un error: ' + (err.message || err));
      btnAccept.disabled = false;
      btnAccept.textContent = 'Firmar y enviar al equipo SACS';
    }
  });

  // ─── Sign wizard navigation ───
  function goSwStep(n) {
    const max = 3;
    const target = Math.max(1, Math.min(max, Number(n) || 1));
    document.querySelectorAll('[data-sw-step]').forEach((el) => {
      const num = Number(el.getAttribute('data-sw-step'));
      el.classList.toggle('is-active', num === target);
      el.classList.toggle('is-done', num < target);
    });
    document.querySelectorAll('[data-sw-panel]').forEach((el) => {
      const num = Number(el.getAttribute('data-sw-panel'));
      el.classList.toggle('is-active', num === target);
    });
    // Scroll to top of the wizard
    const wizard = document.getElementById('sign-wizard');
    if (wizard) {
      const rect = wizard.getBoundingClientRect();
      window.scrollTo({ top: window.scrollY + rect.top - 90, behavior: 'smooth' });
    }
  }
  document.querySelectorAll('[data-sw-go]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const target = Number(btn.getAttribute('data-sw-go'));
      // Validate when going forward to step 2
      if (target === 2) {
        const nombre = (document.getElementById('sign-nombre')||{}).value || '';
        const email = (document.getElementById('sign-email')||{}).value || '';
        if (!nombre.trim() || !email.trim()) {
          alert('Por favor completa nombre y email antes de continuar.');
          return;
        }
      }
      goSwStep(target);
    });
  });

  // Allow clicking active stepper steps to navigate
  document.querySelectorAll('[data-sw-step]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = Number(btn.getAttribute('data-sw-step'));
      // Only allow going to steps already visited (active or done)
      if (btn.classList.contains('is-done')) goSwStep(target);
    });
  });

  // Print certificate (cert-only print mode)
  const btnPrint = document.getElementById('btn-cert-print');
  if (btnPrint) btnPrint.addEventListener('click', () => {
    document.body.classList.add('print-mode-cert');
    window.print();
    setTimeout(() => document.body.classList.remove('print-mode-cert'), 1000);
  });

  // ─── FAB: print whole document as PDF ───
  const btnFabPrint = document.getElementById('p-fab-print');
  if (btnFabPrint) btnFabPrint.addEventListener('click', () => {
    document.body.classList.add('print-mode-doc');
    window.print();
    setTimeout(() => document.body.classList.remove('print-mode-doc'), 1000);
  });

  // FAB visible solo después del 25% de scroll
  const fab = document.getElementById('p-fab');
  if (fab) {
    function onScroll() {
      const pct = (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight;
      const show = window.scrollY > 240 && pct < 0.98;
      fab.classList.toggle('is-visible', show);
      fab.setAttribute('aria-hidden', show ? 'false' : 'true');
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // ─── Decline ───
  const declineModal = document.getElementById('decline-modal');
  const btnDecline = document.getElementById('btn-decline');
  const btnCloseDecline = document.getElementById('btn-close-decline');
  const btnCancelDecline = document.getElementById('btn-cancel-decline');
  const btnConfirmDecline = document.getElementById('btn-confirm-decline');

  function openDecline() { if (declineModal) declineModal.style.display = 'flex'; }
  function closeDecline() { if (declineModal) declineModal.style.display = 'none'; }

  btnDecline && btnDecline.addEventListener('click', openDecline);
  btnCloseDecline && btnCloseDecline.addEventListener('click', closeDecline);
  btnCancelDecline && btnCancelDecline.addEventListener('click', closeDecline);

  btnConfirmDecline && btnConfirmDecline.addEventListener('click', async () => {
    const motivoInput = document.querySelector('input[name="decline-motivo"]:checked');
    const detalleInput = document.getElementById('decline-detalle');
    const motivo = motivoInput ? motivoInput.value : '';
    const detalle = detalleInput ? detalleInput.value.trim() : '';
    if (!motivo) { alert('Selecciona un motivo'); return; }

    btnConfirmDecline.disabled = true;
    btnConfirmDecline.textContent = 'Enviando...';
    try {
      const res = await fetch('/api/partners/decline-invitation', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: invitationId, motivo, detalle }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'No se pudo enviar');
      window.location.reload();
    } catch (err) {
      alert('Error: ' + (err.message || err));
      btnConfirmDecline.disabled = false;
      btnConfirmDecline.textContent = 'Enviar respuesta';
    }
  });

  // ─── Mensual / Anual toggle (proyección de ganancias) ───
  document.querySelectorAll('.p-toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const view = btn.dataset.projectionView;
      if (!view) return;
      // Update all scopes (matrix + closing cards)
      document.querySelectorAll('[data-projection-scope]').forEach(scope => {
        scope.dataset.projectionView = view;
      });
      // Sync the active state on all toggle buttons
      document.querySelectorAll('.p-toggle-btn').forEach(b => {
        const isActive = b.dataset.projectionView === view;
        b.classList.toggle('is-active', isActive);
        b.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
    });
  });
})();

// ── Modal de contrato (Términos y Condiciones) ──
(function () {
  const modal = document.getElementById('contract-modal');
  if (!modal || typeof modal.showModal !== 'function') return;
  document.querySelectorAll('[data-open-contract]').forEach((btn) => {
    btn.addEventListener('click', () => {
      modal.showModal();
      // Reset scroll to top when opening
      const body = modal.querySelector('.p-contract-modal-body');
      if (body) body.scrollTop = 0;
    });
  });
  modal.querySelectorAll('[data-close-contract]').forEach((btn) => {
    btn.addEventListener('click', () => modal.close());
  });
  // Close on backdrop click (click outside the modal content)
  modal.addEventListener('click', (e) => {
    if (e.target === modal) modal.close();
  });
})();

// ── Modal de glosario de términos ──
(function () {
  const modal = document.getElementById('glossary-modal');
  if (!modal || typeof modal.showModal !== 'function') return;
  document.querySelectorAll('[data-open-glossary]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      modal.showModal();
      const body = modal.querySelector('.p-glos-modal-body');
      if (body) body.scrollTop = 0;
    });
  });
  modal.querySelectorAll('[data-close-glossary]').forEach((btn) => {
    btn.addEventListener('click', () => modal.close());
  });
  modal.addEventListener('click', (e) => {
    if (e.target === modal) modal.close();
  });
})();

// ─────────────────────────────────────────────────────────────────────────
// Interest tracking · 10 métricas de interacción
// ─────────────────────────────────────────────────────────────────────────
// Pings al server cada 15s con tiempo activo + tab actual + scroll + eventos
// pendientes. Skip si admin=1 o invitación cerrada. sendBeacon en visibilitychange
// para no perder la última sesión.
(function () {
  if (isAdminMode || isClosed) return;
  if (!invitationId) return;

  // sessionStorage para persistir el sessionId entre reloads dentro de la pestaña
  const SS_KEY = 'sacs_inv_sid_' + invitationId;
  let sessionId = sessionStorage.getItem(SS_KEY);
  if (!sessionId) {
    sessionId = (crypto.randomUUID && crypto.randomUUID()) ||
                (Date.now() + '-' + Math.random().toString(36).slice(2));
    sessionStorage.setItem(SS_KEY, sessionId);
  }

  // Buffer de eventos pendientes + estado
  const pending = {
    deltaSeconds: 0,
    events: [],
    scrollPctByTab: {},
    contractOpenTs: null,  // ts al abrir modal del contrato
    sentInitialContext: false,
  };

  let currentTab = (location.hash || '').replace('#', '') || 'bienvenida';
  let lastTick = Date.now();
  let isVisible = !document.hidden;

  function getDevice() {
    const w = window.innerWidth;
    if (w < 600) return 'mobile';
    if (w < 1024) return 'tablet';
    return 'desktop';
  }

  // Para skip de pings vacíos: el último ts en el que mandamos algo al server.
  let lastFlushAt = 0;
  const MIN_DELTA_FOR_PING = 60;   // si solo lee silencioso, esperar al menos 60s
  const KEEPALIVE_MS = 120000;     // pero forzar ping cada 2 min para mantener live

  function flush(endSession) {
    const now = Date.now();
    // Solo cuenta delta si la pestaña era visible
    if (isVisible) {
      pending.deltaSeconds += Math.floor((now - lastTick) / 1000);
    }
    lastTick = now;

    // Si no hay nada que reportar Y no es endSession, no enviar
    if (pending.deltaSeconds === 0 && pending.events.length === 0 && !endSession && pending.sentInitialContext) {
      return;
    }

    // Skip pings "vacíos de eventos" en lectura silenciosa:
    // si solo hay tiempo acumulado (sin eventos) Y aún no llegamos a MIN_DELTA Y
    // tampoco al keepalive — esperar al próximo ciclo.
    const sinceLastFlush = now - lastFlushAt;
    const isFirstPing = !pending.sentInitialContext;
    const onlyTimeNoEvents = pending.deltaSeconds > 0 && pending.events.length === 0;
    if (
      !endSession &&
      !isFirstPing &&
      onlyTimeNoEvents &&
      pending.deltaSeconds < MIN_DELTA_FOR_PING &&
      sinceLastFlush < KEEPALIVE_MS
    ) {
      // Hold — acumula hasta el siguiente ciclo o hasta que haya un evento
      return;
    }

    const scrollPct = pending.scrollPctByTab[currentTab];
    const payload = {
      invitationId,
      sessionId,
      deltaSeconds: pending.deltaSeconds,
      currentTab,
      scrollPct: typeof scrollPct === 'number' ? scrollPct : undefined,
      events: pending.events.slice(),
      endSession: !!endSession,
    };
    if (!pending.sentInitialContext) {
      payload.device = getDevice();
      payload.userAgent = navigator.userAgent.slice(0, 500);
      payload.referrer = document.referrer ? document.referrer.slice(0, 500) : undefined;
      pending.sentInitialContext = true;
    }

    pending.deltaSeconds = 0;
    pending.events = [];
    lastFlushAt = now;

    try {
      const body = JSON.stringify(payload);
      if (endSession && navigator.sendBeacon) {
        const blob = new Blob([body], { type: 'application/json' });
        navigator.sendBeacon('/api/partners/invitation-heartbeat', blob);
      } else {
        fetch('/api/partners/invitation-heartbeat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body,
          keepalive: true,
        }).catch(() => {});
      }
    } catch {}
  }

  // ── Heartbeat cada 30s (Opt A: ahorra 50% vs el 15s original) ──
  const HEARTBEAT_MS = 30000;
  setInterval(() => flush(false), HEARTBEAT_MS);

  // ── Visibility tracking (Page Visibility API) ──
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      // se va a fondo: contabiliza el delta hasta ahora
      const now = Date.now();
      if (isVisible) pending.deltaSeconds += Math.floor((now - lastTick) / 1000);
      lastTick = now;
      isVisible = false;
      flush(false);
    } else {
      // vuelve al foco
      lastTick = Date.now();
      isVisible = true;
    }
  });

  // ── sendBeacon al cerrar/navegar ──
  window.addEventListener('pagehide', () => flush(true), { capture: true });
  window.addEventListener('beforeunload', () => flush(true));

  // ── Tab tracking (hashchange y clicks en data-tab-link) ──
  function recordTab(tab) {
    if (!tab || tab === currentTab) return;
    // Flush time on old tab antes de cambiar
    flush(false);
    currentTab = tab;
    pending.events.push({ type: 'tab_view', tab, ts: new Date().toISOString() });
  }
  window.addEventListener('hashchange', () => {
    const tab = (location.hash || '').replace('#', '');
    if (tab) recordTab(tab);
  });
  document.addEventListener('click', (e) => {
    const link = e.target && (e.target.closest ? e.target.closest('[data-tab-link]') : null);
    if (link) {
      const tab = link.getAttribute('data-tab-link');
      if (tab) setTimeout(() => recordTab(tab), 50);
    }
  }, true);
  // Inicial
  pending.events.push({ type: 'tab_view', tab: currentTab, ts: new Date().toISOString() });

  // ── Scroll depth por tab (con throttle) ──
  let scrollTick = 0;
  function updateScrollPct() {
    const panel = document.querySelector('.p-tab-panel[data-tab="' + currentTab + '"]') ||
                  document.querySelector('.p-tab-panel.active') ||
                  document.documentElement;
    if (!panel) return;
    const rect = panel.getBoundingClientRect ? panel.getBoundingClientRect() : null;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const scrollTop = window.scrollY || window.pageYOffset || 0;
    const pct = docHeight > 0 ? Math.min(100, Math.round((scrollTop / docHeight) * 100)) : 0;
    const prev = pending.scrollPctByTab[currentTab] || 0;
    if (pct > prev) pending.scrollPctByTab[currentTab] = pct;
  }
  window.addEventListener('scroll', () => {
    if (scrollTick) return;
    scrollTick = requestAnimationFrame(() => {
      scrollTick = 0;
      updateScrollPct();
    });
  }, { passive: true });
  updateScrollPct();

  // ── Modal de contrato: open/close timing ──
  document.querySelectorAll('[data-open-contract]').forEach((btn) => {
    btn.addEventListener('click', () => {
      pending.events.push({ type: 'contract_modal_open' });
      pending.contractOpenTs = Date.now();
    });
  });
  const contractModal = document.getElementById('contract-modal');
  if (contractModal) {
    contractModal.addEventListener('close', () => {
      if (pending.contractOpenTs) {
        const secs = Math.floor((Date.now() - pending.contractOpenTs) / 1000);
        pending.events.push({ type: 'contract_modal_close', secondsInside: secs });
        pending.contractOpenTs = null;
      }
    });
  }

  // ── Modal de glosario: solo count ──
  document.querySelectorAll('[data-open-glossary]').forEach((btn) => {
    btn.addEventListener('click', () => pending.events.push({ type: 'glossary_open' }));
  });

  // ── Calculadora: drag/change en los sliders ──
  let calcDebounce = null;
  function onCalcInput() {
    if (calcDebounce) clearTimeout(calcDebounce);
    calcDebounce = setTimeout(() => {
      const inputs = document.querySelectorAll('[data-calc-input]');
      const finalState = {};
      inputs.forEach((el) => {
        const k = el.getAttribute('data-calc-input');
        if (k) finalState[k] = el.value;
      });
      pending.events.push({ type: 'calc_interaction', finalState });
    }, 500);
  }
  document.querySelectorAll('[data-calc-input]').forEach((el) => {
    el.addEventListener('input', onCalcInput);
    el.addEventListener('change', onCalcInput);
  });

  // ── Canvas de firma: mousedown/touchstart = señal premium ──
  const sigCanvas = document.getElementById('signature-canvas');
  if (sigCanvas) {
    let signatureSignaled = false;
    const onSig = () => {
      if (signatureSignaled) return;
      signatureSignaled = true;
      pending.events.push({ type: 'signature_attempted' });
      // flush rápido para que aparezca pronto en el admin (alerta de casi-firma)
      setTimeout(() => flush(false), 1000);
    };
    sigCanvas.addEventListener('mousedown', onSig, { passive: true });
    sigCanvas.addEventListener('touchstart', onSig, { passive: true });
  }

  // ── Checkbox de aceptación del contrato ──
  const acceptBox = document.getElementById('contract-accept');
  if (acceptBox) {
    acceptBox.addEventListener('change', () => {
      if (acceptBox.checked) pending.events.push({ type: 'contract_checkbox' });
    });
  }

  // ── FAB clicks: WhatsApp y Print ──
  document.querySelectorAll('.p-fab-btn--wa, .p-signed-cta').forEach((el) => {
    if (el.href && /wa\.me\//.test(el.href)) {
      el.addEventListener('click', () => pending.events.push({ type: 'wa_clicked' }));
    }
  });
  const printBtn = document.getElementById('p-fab-print');
  if (printBtn) {
    printBtn.addEventListener('click', () => pending.events.push({ type: 'print_clicked' }));
  }

  // ── Lang switch: select dropdown navega al idioma seleccionado ──
  const langSelect = document.getElementById('p-langswitch-select');
  if (langSelect) {
    langSelect.addEventListener('change', (e) => {
      const target = e.target;
      const href = target.value;
      const opt = target.options[target.selectedIndex];
      const lang = opt?.textContent?.match(/\(([A-Z]{2})\)/)?.[1]?.toLowerCase() || null;
      if (lang && lang !== target.dataset.current) {
        fetch('/api/partners/invitation-heartbeat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            invitationId, sessionId, langSwitchedTo: lang,
            deltaSeconds: 0, events: [],
          }),
          keepalive: true,
        }).catch(() => {});
      }
      if (href) window.location.href = href;
    });
  }

  // Ping inicial con contexto
  setTimeout(() => flush(false), 2000);
})();
</script>
