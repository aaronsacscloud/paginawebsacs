  'ct.legal_notice': { es: '', en: 'Reference translation. The binding legal contract is the Spanish version below — Mexican jurisdiction.', fr: 'Traduction de référence. Le contrat légal contraignant est la version espagnole ci-dessous — juridiction mexicaine.', it: 'Traduzione di riferimento. Il contratto legale vincolante è la versione in spagnolo qui sotto — giurisdizione messicana.', pt: 'Tradução de referência. O contrato legal vinculante é a versão em espanhol abaixo — jurisdição mexicana.' },
  'ct.eyebrow':  { es: 'Acuerdo formal de partner', en: 'Formal partner agreement', fr: 'Accord formel de partenariat', it: 'Accordo formale di partnership', pt: 'Acordo formal de parceria' },
  'ct.title':    { es: 'Contrato del Programa {tipo} SACS', en: 'SACS {tipo} Program Agreement', fr: 'Contrat du Programme {tipo} SACS', it: 'Contratto del Programma {tipo} SACS', pt: 'Contrato do Programa {tipo} SACS' },
  'ct.meta':     { es: 'Folio · Vigencia hasta', en: 'Folio · Valid until', fr: 'Folio · Valable jusqu\'au', it: 'Folio · Valido fino al', pt: 'Folio · Vigência até' },
  'ct.intro':    { es: 'Entre <strong>SACS Cloud, S.A.P.I. de C.V.</strong> ("SACS"), por una parte, y <strong>{nombre}</strong> ("el Partner"), por la otra parte, se celebra el presente <strong>Acuerdo del Programa Partners SACS</strong> bajo las siguientes condiciones:', en: 'Between <strong>SACS Cloud, S.A.P.I. de C.V.</strong> ("SACS"), on one side, and <strong>{nombre}</strong> ("the Partner"), on the other side, the following <strong>SACS Partner Program Agreement</strong> is entered into under these conditions:', fr: 'Entre <strong>SACS Cloud, S.A.P.I. de C.V.</strong> (« SACS »), d\'une part, et <strong>{nombre}</strong> (« le Partenaire »), d\'autre part, est conclu le présent <strong>Accord du Programme Partenaires SACS</strong> aux conditions suivantes :', it: 'Tra <strong>SACS Cloud, S.A.P.I. de C.V.</strong> ("SACS"), da una parte, e <strong>{nombre}</strong> ("il Partner"), dall\'altra parte, viene stipulato il presente <strong>Accordo del Programma Partner SACS</strong> alle seguenti condizioni:', pt: 'Entre <strong>SACS Cloud, S.A.P.I. de C.V.</strong> ("SACS"), de uma parte, e <strong>{nombre}</strong> ("o Parceiro"), de outra parte, celebra-se o presente <strong>Acordo do Programa de Parceiros SACS</strong> nas seguintes condições:' },

  'ct.h1': { es: '1. Programa', en: '1. Program', fr: '1. Programme', it: '1. Programma', pt: '1. Programa' },
  'ct.p1': { es: 'El Partner queda inscrito en el programa <strong>{tipo}</strong> de SACS con folio <strong>{numero}</strong>, vigente hasta <strong>{vigencia}</strong> y renovable automáticamente al cumplir las condiciones de continuidad.', en: 'The Partner is enrolled in the SACS <strong>{tipo}</strong> program with folio <strong>{numero}</strong>, valid until <strong>{vigencia}</strong> and automatically renewable upon meeting the continuity conditions.', fr: 'Le Partenaire est inscrit au programme <strong>{tipo}</strong> de SACS avec folio <strong>{numero}</strong>, valable jusqu\'au <strong>{vigencia}</strong> et renouvelable automatiquement au respect des conditions de continuité.', it: 'Il Partner è iscritto al programma <strong>{tipo}</strong> di SACS con folio <strong>{numero}</strong>, valido fino al <strong>{vigencia}</strong> e rinnovabile automaticamente al rispetto delle condizioni di continuità.', pt: 'O Parceiro fica inscrito no programa <strong>{tipo}</strong> da SACS com folio <strong>{numero}</strong>, vigente até <strong>{vigencia}</strong> e renovável automaticamente ao cumprir as condições de continuidade.' },

  'ct.h2': { es: '2. Compensación', en: '2. Compensation', fr: '2. Rémunération', it: '2. Compenso', pt: '2. Remuneração' },
  'ct.p2.1': { es: '<strong>Comisión sobre venta directa:</strong> {pct}% sobre el cobro de la primera factura de cada cliente cerrado mediante el link único del Partner.', en: '<strong>Direct sale commission:</strong> {pct}% on the first invoice charged to each client closed through the Partner\'s unique link.', fr: '<strong>Commission sur vente directe :</strong> {pct}% sur la première facture de chaque client conclu via le lien unique du Partenaire.', it: '<strong>Commissione su vendita diretta:</strong> {pct}% sull\'addebito della prima fattura di ogni cliente chiuso tramite il link unico del Partner.', pt: '<strong>Comissão sobre venda direta:</strong> {pct}% sobre a cobrança da primeira nota fiscal de cada cliente fechado pelo link único do Parceiro.' },
  'ct.p2.2': { es: '<strong>Visibilidad de seguimiento:</strong> el Partner tiene acceso a su portal con tracking completo de cada lead que llega por su link único — clicks, activación de prueba gratis, demos agendadas, contactos del equipo SACS y fase del embudo. Esta información es informativa; el pago de la comisión se devenga únicamente al cierre del cliente.', en: '<strong>Tracking visibility:</strong> the Partner has access to their portal with full tracking of every lead that arrives via their unique link — clicks, free trial activation, scheduled demos, SACS team contacts and funnel stage. This information is informational; commission accrues only upon the client closing.', fr: '<strong>Visibilité du suivi :</strong> le Partenaire a accès à son portail avec un suivi complet de chaque lead arrivant par son lien unique — clics, activation d\'essai gratuit, démos planifiées, contacts de l\'équipe SACS et étape du funnel. Cette information est informative ; la commission n\'est due qu\'à la conclusion du client.', it: '<strong>Visibilità del tracciamento:</strong> il Partner ha accesso al suo portale con tracciamento completo di ogni lead che arriva dal suo link unico — click, attivazione prova gratuita, demo prenotate, contatti del team SACS e fase del funnel. Queste informazioni sono informative; la commissione matura solo alla chiusura del cliente.', pt: '<strong>Visibilidade de acompanhamento:</strong> o Parceiro tem acesso ao seu portal com tracking completo de cada lead que chega pelo seu link único — cliques, ativação de teste grátis, demos agendadas, contatos do time SACS e fase do funil. Esta informação é informativa; a comissão se devenga somente ao fechamento do cliente.' },
  'ct.p2.3': { es: '<strong>Comisión recurrente al renovar:</strong> mientras el cliente referido permanezca activo en SACS y al corriente en sus pagos, el Partner mantiene su porcentaje de comisión sobre las renovaciones del plan vigente.', en: '<strong>Recurring commission on renewal:</strong> while the referred client remains active on SACS and current on payments, the Partner keeps their commission percentage on renewals of the active plan.', fr: '<strong>Commission récurrente au renouvellement :</strong> tant que le client référé reste actif sur SACS et à jour de ses paiements, le Partenaire conserve son pourcentage de commission sur les renouvellements du plan en vigueur.', it: '<strong>Commissione ricorrente al rinnovo:</strong> finché il cliente riferito rimane attivo su SACS e in regola con i pagamenti, il Partner mantiene la sua percentuale di commissione sui rinnovi del piano in vigore.', pt: '<strong>Comissão recorrente na renovação:</strong> enquanto o cliente referenciado permanecer ativo na SACS e em dia com os pagamentos, o Parceiro mantém seu percentual de comissão sobre as renovações do plano vigente.' },
  'ct.p2.4': { es: '<strong>Comisiones recurrentes:</strong> Mientras (i) el cliente referido permanezca activo en SACS y al corriente en sus pagos, y (ii) el Partner mantenga su estatus activo en el programa, el Partner mantiene el {pct}% sobre las renovaciones según el plan vigente. Si el Partner es dado de baja del programa por cualquier causa prevista en este contrato, las comisiones recurrentes futuras se cancelan automáticamente — el cliente continúa siendo cliente de SACS, pero deja de generar comisión al Partner. Lo anterior aplica salvo los supuestos de consolidación de cartera y protección de comisiones de la cláusula 6-bis.', en: '<strong>Recurring commissions:</strong> While (i) the referred client remains active on SACS and current on payments, and (ii) the Partner maintains active status in the program, the Partner keeps {pct}% on renewals per the active plan. If the Partner is removed from the program for any cause stated in this agreement, future recurring commissions are automatically cancelled — the client remains a SACS client but stops generating commission for the Partner. The foregoing applies except in the portfolio-consolidation and commission-protection scenarios of clause 6-bis.', fr: '<strong>Commissions récurrentes :</strong> Tant que (i) le client référé reste actif sur SACS et à jour de ses paiements, et (ii) le Partenaire conserve un statut actif dans le programme, le Partenaire conserve {pct}% sur les renouvellements selon le plan en vigueur. Si le Partenaire est exclu du programme pour toute cause prévue par cet accord, les commissions récurrentes futures sont automatiquement annulées — le client reste client de SACS mais cesse de générer une commission pour le Partenaire. Ce qui précède s\'applique sous réserve des cas de consolidation du portefeuille et de protection des commissions de la clause 6-bis.', it: '<strong>Commissioni ricorrenti:</strong> Finché (i) il cliente riferito rimane attivo su SACS e in regola con i pagamenti, e (ii) il Partner mantiene lo stato attivo nel programma, il Partner mantiene il {pct}% sui rinnovi secondo il piano in vigore. Se il Partner viene rimosso dal programma per qualsiasi causa prevista in questo contratto, le commissioni ricorrenti future vengono annullate automaticamente — il cliente continua a essere cliente di SACS ma cessa di generare commissione per il Partner. Quanto sopra si applica salvo i casi di consolidamento del portafoglio e protezione delle commissioni della clausola 6-bis.', pt: '<strong>Comissões recorrentes:</strong> Enquanto (i) o cliente referenciado permanecer ativo na SACS e em dia com os pagamentos, e (ii) o Parceiro mantiver status ativo no programa, o Parceiro mantém o {pct}% sobre as renovações conforme o plano vigente. Se o Parceiro for dado de baixa do programa por qualquer causa prevista neste contrato, as comissões recorrentes futuras são canceladas automaticamente — o cliente continua sendo cliente da SACS mas deixa de gerar comissão para o Parceiro. O disposto acima aplica-se salvo as hipóteses de consolidação de carteira e proteção de comissões da cláusula 6-bis.' },
  'ct.p2.compartida': { es: '<strong>Venta compartida (asistida por SACS):</strong> cuando el Partner tiene el prospecto pero solicita a un ejecutivo o consultor interno de SACS apoyo para una reunión, cita o presentación (física o remota) que lleve al cierre, la comisión sobre la primera factura de ese cliente es del <strong>30%</strong> (en lugar del 50% de la venta propia). La comisión recurrente por renovación se conserva según el plan vigente mientras el cliente y el Partner sigan activos.', en: '<strong>Shared sale (SACS-assisted):</strong> when the Partner has the prospect but requests a SACS executive or internal consultant to help with a meeting, appointment or presentation (in person or remote) that leads to the close, the commission on that client\'s first invoice is <strong>30%</strong> (instead of the 50% for an own sale). The recurring renewal commission is kept per the active plan while the client and the Partner remain active.', fr: '<strong>Vente partagée (assistée par SACS) :</strong> lorsque le Partenaire a le prospect mais demande à un cadre ou consultant interne de SACS de l\'aider pour une réunion, un rendez-vous ou une présentation (en personne ou à distance) menant à la conclusion, la commission sur la première facture de ce client est de <strong>30%</strong> (au lieu des 50% d\'une vente propre). La commission récurrente de renouvellement est conservée selon le plan en vigueur tant que le client et le Partenaire restent actifs.', it: '<strong>Vendita condivisa (assistita da SACS):</strong> quando il Partner ha il prospect ma richiede a un dirigente o consulente interno di SACS supporto per una riunione, un appuntamento o una presentazione (di persona o da remoto) che porti alla chiusura, la commissione sulla prima fattura di quel cliente è del <strong>30%</strong> (invece del 50% della vendita propria). La commissione ricorrente di rinnovo si mantiene secondo il piano vigente finché il cliente e il Partner restano attivi.', pt: '<strong>Venda compartilhada (assistida pela SACS):</strong> quando o Parceiro tem o prospecto mas solicita a um executivo ou consultor interno da SACS apoio para uma reunião, visita ou apresentação (presencial ou remota) que leve ao fechamento, a comissão sobre a primeira fatura desse cliente é de <strong>30%</strong> (em vez dos 50% da venda própria). A comissão recorrente de renovação mantém-se conforme o plano vigente enquanto o cliente e o Parceiro permanecerem ativos.' },
  'ct.h2b': { es: '2-bis. Tipos de venta, seguimiento y acompañamiento', en: '2-bis. Sale types, tracking and support', fr: '2-bis. Types de vente, suivi et accompagnement', it: '2-bis. Tipi di vendita, monitoraggio e supporto', pt: '2-bis. Tipos de venda, acompanhamento e suporte' },
  'ct.p2b.tipos': { es: 'El porcentaje sobre la primera factura depende de cómo se cerró la venta: <strong>(a) Venta propia (directa) — 50%:</strong> el Partner genera el prospecto y lo cierra por su cuenta con su link único, sin intervención de SACS en el cierre. <strong>(b) Venta compartida (asistida) — 30%:</strong> el Partner aporta el prospecto pero un ejecutivo o consultor de SACS participa en la reunión, cita o presentación que lleva al cierre. <strong>(c) Venta gestionada por SACS:</strong> si el prospecto fue generado y cerrado por SACS sin aportación del Partner, no genera comisión de venta directa para el Partner, salvo acuerdo por escrito. En todos los casos, la venta se atribuye al Partner solo si el prospecto llegó por su link único o la referencia se registró antes del cierre.', en: 'The percentage on the first invoice depends on how the sale was closed: <strong>(a) Own sale (direct) — 50%:</strong> the Partner generates the prospect and closes it on their own with their unique link, without SACS intervening in the close. <strong>(b) Shared sale (assisted) — 30%:</strong> the Partner brings the prospect but a SACS executive or consultant takes part in the meeting, appointment or presentation that leads to the close. <strong>(c) SACS-managed sale:</strong> if the prospect was generated and closed by SACS with no Partner contribution, it generates no direct-sale commission for the Partner, unless agreed in writing. In all cases, the sale is attributed to the Partner only if the prospect came through their unique link or the referral was registered before the close.', fr: 'Le pourcentage sur la première facture dépend de la façon dont la vente a été conclue : <strong>(a) Vente propre (directe) — 50% :</strong> le Partenaire génère le prospect et le conclut seul avec son lien unique, sans intervention de SACS dans la conclusion. <strong>(b) Vente partagée (assistée) — 30% :</strong> le Partenaire apporte le prospect mais un cadre ou consultant de SACS participe à la réunion, au rendez-vous ou à la présentation menant à la conclusion. <strong>(c) Vente gérée par SACS :</strong> si le prospect a été généré et conclu par SACS sans apport du Partenaire, il ne génère pas de commission de vente directe pour le Partenaire, sauf accord écrit. Dans tous les cas, la vente est attribuée au Partenaire uniquement si le prospect est arrivé par son lien unique ou si la référence a été enregistrée avant la conclusion.', it: 'La percentuale sulla prima fattura dipende da come è stata chiusa la vendita: <strong>(a) Vendita propria (diretta) — 50%:</strong> il Partner genera il prospect e lo chiude da solo con il suo link unico, senza intervento di SACS nella chiusura. <strong>(b) Vendita condivisa (assistita) — 30%:</strong> il Partner porta il prospect ma un dirigente o consulente di SACS partecipa alla riunione, all\'appuntamento o alla presentazione che porta alla chiusura. <strong>(c) Vendita gestita da SACS:</strong> se il prospect è stato generato e chiuso da SACS senza apporto del Partner, non genera commissione di vendita diretta per il Partner, salvo accordo scritto. In tutti i casi, la vendita è attribuita al Partner solo se il prospect è arrivato tramite il suo link unico o la referenza è stata registrata prima della chiusura.', pt: 'O percentual sobre a primeira fatura depende de como a venda foi fechada: <strong>(a) Venda própria (direta) — 50%:</strong> o Parceiro gera o prospecto e o fecha por conta própria com seu link único, sem intervenção da SACS no fechamento. <strong>(b) Venda compartilhada (assistida) — 30%:</strong> o Parceiro traz o prospecto mas um executivo ou consultor da SACS participa da reunião, visita ou apresentação que leva ao fechamento. <strong>(c) Venda gerida pela SACS:</strong> se o prospecto foi gerado e fechado pela SACS sem contribuição do Parceiro, não gera comissão de venda direta para o Parceiro, salvo acordo por escrito. Em todos os casos, a venda é atribuída ao Parceiro apenas se o prospecto chegou por seu link único ou a referência foi registrada antes do fechamento.' },
  'ct.p2b.panel': { es: '<strong>Seguimiento y panel del Partner:</strong> el Partner cuenta con un panel (portal de Partner) donde da seguimiento en tiempo real a sus <strong>prospectos y su estatus</strong> (fase del embudo), <strong>ventas cerradas</strong>, <strong>pagos recibidos</strong>, <strong>comisiones generadas</strong> y <strong>comisiones ya pagadas</strong>. La información del panel es informativa; el pago de la comisión se devenga al cierre y cobro del cliente conforme a la cláusula 2 y a los plazos de pago del programa.', en: '<strong>Tracking and Partner panel:</strong> the Partner has a panel (Partner portal) to track in real time their <strong>prospects and their status</strong> (funnel stage), <strong>closed sales</strong>, <strong>payments received</strong>, <strong>commissions generated</strong> and <strong>commissions already paid</strong>. The panel information is informational; commission payment accrues upon the client\'s close and payment per clause 2 and the program\'s payment terms.', fr: '<strong>Suivi et panneau du Partenaire :</strong> le Partenaire dispose d\'un panneau (portail Partenaire) pour suivre en temps réel ses <strong>prospects et leur statut</strong> (étape de l\'entonnoir), <strong>ventes conclues</strong>, <strong>paiements reçus</strong>, <strong>commissions générées</strong> et <strong>commissions déjà versées</strong>. Les informations du panneau sont indicatives ; le paiement de la commission est acquis à la conclusion et au paiement du client selon la clause 2 et les délais de paiement du programme.', it: '<strong>Monitoraggio e pannello del Partner:</strong> il Partner dispone di un pannello (portale Partner) per monitorare in tempo reale i suoi <strong>prospect e il loro stato</strong> (fase del funnel), <strong>vendite chiuse</strong>, <strong>pagamenti ricevuti</strong>, <strong>commissioni generate</strong> e <strong>commissioni già pagate</strong>. Le informazioni del pannello sono informative; il pagamento della commissione matura alla chiusura e al pagamento del cliente secondo la clausola 2 e i termini di pagamento del programma.', pt: '<strong>Acompanhamento e painel do Parceiro:</strong> o Parceiro conta com um painel (portal do Parceiro) para acompanhar em tempo real seus <strong>prospectos e seu status</strong> (fase do funil), <strong>vendas fechadas</strong>, <strong>pagamentos recebidos</strong>, <strong>comissões geradas</strong> e <strong>comissões já pagas</strong>. As informações do painel são informativas; o pagamento da comissão é devido no fechamento e cobrança do cliente conforme a cláusula 2 e os prazos de pagamento do programa.' },
  'ct.p2b.acomp': { es: '<strong>Capacitación y acompañamiento:</strong> al ingresar, el Partner recibe una capacitación de inicio sobre el producto, el proceso de venta y el uso de su link y su panel; las certificaciones para servicios profesionales se rigen por la cláusula 8. El acompañamiento de SACS cubre lo <strong>comercial</strong> (apoyo en reuniones, demos y venta compartida a solicitud), lo <strong>operativo</strong> (alta de clientes, facturación y cobranza) y lo <strong>técnico</strong> (soporte del producto al cliente). Son responsabilidad del Partner la prospección, el primer contacto, el seguimiento comercial de sus leads y mantener el estándar de marca; SACS atiende directamente el cierre asistido cuando se solicita, la operación de cobro y el soporte técnico del producto.', en: '<strong>Training and support:</strong> upon joining, the Partner receives onboarding training on the product, the sales process and the use of their link and panel; certifications for professional services are governed by clause 8. SACS support covers the <strong>commercial</strong> side (help with meetings, demos and shared sales on request), the <strong>operational</strong> side (client onboarding, billing and collections) and the <strong>technical</strong> side (product support to the client). The Partner is responsible for prospecting, first contact, commercial follow-up of their leads and upholding the brand standard; SACS directly handles the assisted close when requested, the collection operation and the product\'s technical support.', fr: '<strong>Formation et accompagnement :</strong> à son arrivée, le Partenaire reçoit une formation d\'intégration sur le produit, le processus de vente et l\'utilisation de son lien et de son panneau ; les certifications pour services professionnels relèvent de la clause 8. L\'accompagnement de SACS couvre le volet <strong>commercial</strong> (aide aux réunions, démos et ventes partagées sur demande), le volet <strong>opérationnel</strong> (intégration des clients, facturation et recouvrement) et le volet <strong>technique</strong> (support produit au client). Le Partenaire est responsable de la prospection, du premier contact, du suivi commercial de ses leads et du maintien du standard de marque ; SACS gère directement la conclusion assistée sur demande, l\'opération de recouvrement et le support technique du produit.', it: '<strong>Formazione e supporto:</strong> all\'ingresso, il Partner riceve una formazione iniziale sul prodotto, sul processo di vendita e sull\'uso del suo link e del suo pannello; le certificazioni per servizi professionali sono regolate dalla clausola 8. Il supporto di SACS copre l\'ambito <strong>commerciale</strong> (aiuto in riunioni, demo e vendite condivise su richiesta), quello <strong>operativo</strong> (attivazione clienti, fatturazione e incassi) e quello <strong>tecnico</strong> (supporto del prodotto al cliente). Sono responsabilità del Partner la prospezione, il primo contatto, il follow-up commerciale dei suoi lead e il mantenimento dello standard di marchio; SACS gestisce direttamente la chiusura assistita quando richiesta, l\'operazione di incasso e il supporto tecnico del prodotto.', pt: '<strong>Capacitação e acompanhamento:</strong> ao ingressar, o Parceiro recebe uma capacitação inicial sobre o produto, o processo de venda e o uso de seu link e seu painel; as certificações para serviços profissionais regem-se pela cláusula 8. O acompanhamento da SACS cobre o <strong>comercial</strong> (apoio em reuniões, demos e vendas compartilhadas a pedido), o <strong>operacional</strong> (cadastro de clientes, faturamento e cobrança) e o <strong>técnico</strong> (suporte do produto ao cliente). São responsabilidade do Parceiro a prospecção, o primeiro contato, o acompanhamento comercial de seus leads e a manutenção do padrão de marca; a SACS atende diretamente o fechamento assistido quando solicitado, a operação de cobrança e o suporte técnico do produto.' },

  'ct.h3': { es: '3. Liquidación de pagos', en: '3. Payment settlement', fr: '3. Règlement des paiements', it: '3. Liquidazione dei pagamenti', pt: '3. Liquidação de pagamentos' },
  'ct.p3': { es: 'El ciclo de pago opera por períodos de <strong>30 días naturales</strong> con <strong>corte el día 1 de cada mes</strong>. Cada corte SACS consolida en el portal del Partner todas las comisiones <em>earned</em> (confirmadas) generadas durante el mes inmediato anterior, con desglose por concepto, cliente y fecha. Para que SACS pueda emitir el pago, el Partner debe enviar su <strong>factura entre 1 y 3 días hábiles antes</strong> de la fecha programada de pago, por el monto exacto reflejado en su portal. SACS liquida al método registrado por el Partner (CLABE, PayPal o Mercado Pago) dentro de los 5 días hábiles siguientes a la recepción de la factura. El Partner es el único responsable del cumplimiento fiscal de los ingresos recibidos en su jurisdicción y de la correcta emisión del comprobante fiscal.', en: 'The payment cycle runs in <strong>30-natural-day periods</strong> with <strong>cutoff on the 1st of each month</strong>. At each cutoff SACS consolidates in the Partner portal all <em>earned</em> (confirmed) commissions generated during the immediately prior month, broken down by concept, client and date. For SACS to issue payment, the Partner must send their <strong>invoice between 1 and 3 business days before</strong> the scheduled payment date, for the exact amount reflected in their portal. SACS settles to the method registered by the Partner (CLABE, PayPal or Mercado Pago) within 5 business days of receiving the invoice. The Partner is solely responsible for tax compliance on income received in their jurisdiction and for the correct issuance of the tax receipt.', fr: 'Le cycle de paiement fonctionne par périodes de <strong>30 jours calendaires</strong> avec <strong>arrêté le 1er de chaque mois</strong>. À chaque arrêté, SACS consolide dans le portail du Partenaire toutes les commissions <em>earned</em> (confirmées) générées durant le mois immédiatement précédent, détaillées par concept, client et date. Pour que SACS puisse émettre le paiement, le Partenaire doit envoyer sa <strong>facture entre 1 et 3 jours ouvrés avant</strong> la date de paiement prévue, pour le montant exact reflété dans son portail. SACS règle au mode enregistré par le Partenaire (CLABE, PayPal ou Mercado Pago) dans les 5 jours ouvrés suivant la réception de la facture. Le Partenaire est seul responsable de la conformité fiscale des revenus reçus dans sa juridiction et de l\'émission correcte du justificatif fiscal.', it: 'Il ciclo di pagamento opera in periodi di <strong>30 giorni naturali</strong> con <strong>chiusura il 1° di ogni mese</strong>. A ogni chiusura SACS consolida nel portale del Partner tutte le commissioni <em>earned</em> (confermate) generate durante il mese immediatamente precedente, con dettaglio per concetto, cliente e data. Affinché SACS possa emettere il pagamento, il Partner deve inviare la <strong>fattura tra 1 e 3 giorni lavorativi prima</strong> della data di pagamento programmata, per l\'importo esatto riflesso nel portale. SACS liquida al metodo registrato dal Partner (CLABE, PayPal o Mercado Pago) entro 5 giorni lavorativi dalla ricezione della fattura. Il Partner è l\'unico responsabile della conformità fiscale dei ricavi ricevuti nella sua giurisdizione e della corretta emissione del documento fiscale.', pt: 'O ciclo de pagamento opera em períodos de <strong>30 dias corridos</strong> com <strong>corte no dia 1 de cada mês</strong>. A cada corte a SACS consolida no portal do Parceiro todas as comissões <em>earned</em> (confirmadas) geradas durante o mês imediatamente anterior, com desdobramento por conceito, cliente e data. Para que a SACS possa emitir o pagamento, o Parceiro deve enviar sua <strong>nota fiscal entre 1 e 3 dias úteis antes</strong> da data programada de pagamento, pelo valor exato refletido em seu portal. A SACS liquida ao método registrado pelo Parceiro (CLABE, PayPal ou Mercado Pago) em até 5 dias úteis após a recepção da nota fiscal. O Parceiro é o único responsável pela conformidade fiscal das receitas recebidas em sua jurisdição e pela correta emissão do comprovante fiscal.' },

  'ct.h4': { es: '4. Beneficios incluidos', en: '4. Included benefits', fr: '4. Avantages inclus', it: '4. Benefici inclusi', pt: '4. Benefícios incluídos' },
  'ct.p4.1': { es: 'Cuenta SACS Plan Fideliza ($14,000 MXN/año) <strong>gratis</strong> mientras el Partner esté activo.', en: 'SACS Fideliza Plan account ($14,000 MXN/year) <strong>free</strong> while the Partner is active.', fr: 'Compte SACS Plan Fideliza (14 000 MXN/an) <strong>gratuit</strong> tant que le Partenaire est actif.', it: 'Account SACS Piano Fideliza ($14.000 MXN/anno) <strong>gratis</strong> finché il Partner è attivo.', pt: 'Conta SACS Plano Fideliza ($14.000 MXN/ano) <strong>grátis</strong> enquanto o Parceiro estiver ativo.' },
  'ct.p4.2': { es: 'Acceso al portal de partner con métricas en tiempo real, pagos y prospectos.', en: 'Access to the partner portal with real-time metrics, payments and prospects.', fr: 'Accès au portail partenaire avec métriques en temps réel, paiements et prospects.', it: 'Accesso al portale partner con metriche in tempo reale, pagamenti e prospect.', pt: 'Acesso ao portal de parceiro com métricas em tempo real, pagamentos e prospectos.' },
  'ct.p4.3': { es: 'Brand kit con logos, plantillas y captions oficiales.', en: 'Brand kit with official logos, templates and captions.', fr: 'Kit de marque avec logos, modèles et légendes officiels.', it: 'Brand kit con loghi, template e caption ufficiali.', pt: 'Brand kit com logos, templates e legendas oficiais.' },
  'ct.p4.4': { es: 'Soporte prioritario, Academia SACS y workshops mensuales en vivo.', en: 'Priority support, SACS Academy and monthly live workshops.', fr: 'Support prioritaire, Académie SACS et workshops mensuels en direct.', it: 'Supporto prioritario, Academy SACS e workshop mensili dal vivo.', pt: 'Suporte prioritário, Academia SACS e workshops mensais ao vivo.' },
  'ct.p4.5': { es: 'Sesión de onboarding 1:1 y migración de datos sin costo extra para clientes referidos.', en: '1:1 onboarding session and data migration at no extra cost for referred clients.', fr: 'Session d\'onboarding 1:1 et migration de données sans frais supplémentaires pour les clients référés.', it: 'Sessione di onboarding 1:1 e migrazione dati senza costi extra per clienti riferiti.', pt: 'Sessão de onboarding 1:1 e migração de dados sem custo extra para clientes referenciados.' },

  'ct.h5': { es: '5. Compromisos del Partner', en: '5. Partner commitments', fr: '5. Engagements du Partenaire', it: '5. Impegni del Partner', pt: '5. Compromissos do Parceiro' },
  'ct.p5.1': { es: 'Representar la marca SACS de forma profesional y honesta.', en: 'Represent the SACS brand in a professional and honest manner.', fr: 'Représenter la marque SACS de manière professionnelle et honnête.', it: 'Rappresentare il marchio SACS in modo professionale e onesto.', pt: 'Representar a marca SACS de forma profissional e honesta.' },
  'ct.p5.2': { es: 'Atender los leads asignados en menos de 24 horas hábiles.', en: 'Attend assigned leads within 24 business hours.', fr: 'Répondre aux leads assignés dans les 24 heures ouvrées.', it: 'Rispondere ai lead assegnati entro 24 ore lavorative.', pt: 'Atender os leads atribuídos em menos de 24 horas úteis.' },
  'ct.p5.3': { es: 'Asistir a la sesión mensual de actualizaciones (60 min) — quedan grabadas para ver después si no puede asistir.', en: 'Attend the monthly updates session (60 min) — recordings are available to watch later if unable to attend.', fr: 'Participer à la session mensuelle de mises à jour (60 min) — enregistrées pour visionner ultérieurement en cas d\'absence.', it: 'Partecipare alla sessione mensile di aggiornamenti (60 min) — registrate per la visione successiva in caso di assenza.', pt: 'Participar da sessão mensal de atualizações (60 min) — ficam gravadas para ver depois caso não possa comparecer.' },
  'ct.p5.4': { es: 'Acumular un mínimo de <strong>100 puntos al mes</strong> mediante cualquier combinación de contenido publicado, acciones de apoyo o actividades filantrópicas, conforme al catálogo público de actividades. El reporte de cada acción se realiza desde el portal del Partner; sin reporte, no se acreditan puntos. El excedente sobre 100 se acumula al mes siguiente.', en: 'Earn a minimum of <strong>100 points per month</strong> through any combination of published content, support actions or philanthropic activities, per the public activities catalog. Each action is reported from the Partner portal; with no report, no points are credited. Surplus over 100 carries over to the next month.', fr: 'Accumuler un minimum de <strong>100 points par mois</strong> par toute combinaison de contenu publié, actions de soutien ou activités philanthropiques, selon le catalogue public d\'activités. Chaque action se rapporte depuis le portail Partenaire ; sans rapport, aucun point n\'est crédité. L\'excédent au-delà de 100 est reporté au mois suivant.', it: 'Accumulare un minimo di <strong>100 punti al mese</strong> tramite qualsiasi combinazione di contenuti pubblicati, azioni di supporto o attività filantropiche, secondo il catalogo pubblico delle attività. Ogni azione si segnala dal portale Partner; senza segnalazione, nessun punto viene accreditato. L\'eccedenza oltre 100 si riporta al mese successivo.', pt: 'Acumular um mínimo de <strong>100 pontos por mês</strong> mediante qualquer combinação de conteúdo publicado, ações de apoio ou atividades filantrópicas, conforme o catálogo público de atividades. Cada ação é reportada do portal do Parceiro; sem reporte, não há pontos creditados. O excedente sobre 100 acumula no mês seguinte.' },
  'ct.p5.5': { es: 'No realizar afirmaciones falsas, garantías de resultados o promociones engañosas sobre SACS.', en: 'Refrain from making false statements, results guarantees or misleading promotions about SACS.', fr: 'Ne pas faire de déclarations fausses, de garanties de résultats ou de promotions trompeuses sur SACS.', it: 'Non fare affermazioni false, garanzie di risultati o promozioni ingannevoli su SACS.', pt: 'Não fazer afirmações falsas, garantias de resultados ou promoções enganosas sobre a SACS.' },
  'ct.p5.6': { es: '<strong>El programa es 100% gratuito:</strong> el Partner no paga cuota mensual ni anual al programa. Lo que el Partner aporta no es dinero sino actividad — los compromisos descritos en esta cláusula son la contraprestación por los beneficios incluidos.', en: '<strong>The program is 100% free:</strong> the Partner pays no monthly or annual fee. What the Partner contributes is not money but activity — the commitments described in this clause are the consideration for the included benefits.', fr: '<strong>Le programme est 100% gratuit :</strong> le Partenaire ne paie aucune cotisation mensuelle ni annuelle. Ce que le Partenaire apporte n\'est pas de l\'argent mais de l\'activité — les engagements décrits dans cette clause constituent la contrepartie des avantages inclus.', it: '<strong>Il programma è 100% gratuito:</strong> il Partner non paga alcuna quota mensile o annuale. Ciò che il Partner apporta non è denaro ma attività — gli impegni descritti in questa clausola sono il corrispettivo per i benefici inclusi.', pt: '<strong>O programa é 100% gratuito:</strong> o Parceiro não paga cota mensal nem anual ao programa. O que o Parceiro aporta não é dinheiro mas atividade — os compromissos descritos nesta cláusula são a contraprestação pelos benefícios incluídos.' },

  'ct.h6': { es: '6. Suspensión y baja del programa', en: '6. Program suspension and removal', fr: '6. Suspension et exclusion du programme', it: '6. Sospensione e rimozione dal programma', pt: '6. Suspensão e baixa do programa' },
  'ct.p6.intro': { es: 'SACS podrá suspender o dar de baja al Partner del programa cuando se actualice cualquiera de los siguientes supuestos. La baja implica la cancelación automática de las comisiones recurrentes futuras conforme a la cláusula 2.4 y salvo lo previsto en la cláusula 6-bis; las comisiones <em>earned</em> ya pagadas o confirmadas previamente se respetan. La suspensión es un estado transitorio durante el cual los beneficios y los pagos quedan en pausa.', en: 'SACS may suspend or remove the Partner from the program upon the occurrence of any of the following events. Removal triggers the automatic cancellation of future recurring commissions per clause 2.4 and except as provided in clause 6-bis; <em>earned</em> commissions already paid or previously confirmed are respected. Suspension is a transitory state during which benefits and payments are paused.', fr: 'SACS pourra suspendre ou exclure le Partenaire du programme en cas de survenance de l\'une des situations suivantes. L\'exclusion entraîne l\'annulation automatique des commissions récurrentes futures selon la clause 2.4 et sauf ce que prévoit la clause 6-bis ; les commissions <em>earned</em> déjà versées ou confirmées sont respectées. La suspension est un état transitoire durant lequel les avantages et paiements sont mis en pause.', it: 'SACS potrà sospendere o rimuovere il Partner dal programma al verificarsi di una qualsiasi delle seguenti situazioni. La rimozione comporta la cancellazione automatica delle commissioni ricorrenti future secondo la clausola 2.4 e salvo quanto previsto dalla clausola 6-bis; le commissioni <em>earned</em> già pagate o precedentemente confermate sono rispettate. La sospensione è uno stato transitorio durante il quale benefici e pagamenti restano in pausa.', pt: 'A SACS poderá suspender ou dar de baixa do programa ao Parceiro quando se verificar qualquer uma das seguintes hipóteses. A baixa implica o cancelamento automático das comissões recorrentes futuras conforme a cláusula 2.4 e salvo o previsto na cláusula 6-bis; as comissões <em>earned</em> já pagas ou previamente confirmadas são respeitadas. A suspensão é um estado transitório durante o qual os benefícios e pagamentos ficam em pausa.' },
  'ct.p6.c1': { es: '<strong>Incumplimiento de actividad mínima:</strong> el Partner no alcanza los <strong>100 puntos mensuales</strong> durante <strong>tres meses consecutivos</strong>. SACS notificará por escrito al segundo mes y otorgará un periodo de regularización de 30 días naturales antes de la baja definitiva.', en: '<strong>Failure to meet minimum activity:</strong> the Partner does not reach <strong>100 monthly points</strong> for <strong>three consecutive months</strong>. SACS will notify in writing at the second month and grant a 30-natural-day regularization period before final removal.', fr: '<strong>Manquement à l\'activité minimale :</strong> le Partenaire n\'atteint pas les <strong>100 points mensuels</strong> pendant <strong>trois mois consécutifs</strong>. SACS notifiera par écrit au second mois et accordera une période de régularisation de 30 jours calendaires avant l\'exclusion définitive.', it: '<strong>Mancato raggiungimento dell\'attività minima:</strong> il Partner non raggiunge i <strong>100 punti mensili</strong> per <strong>tre mesi consecutivi</strong>. SACS notificherà per iscritto al secondo mese e concederà un periodo di regolarizzazione di 30 giorni naturali prima della rimozione definitiva.', pt: '<strong>Descumprimento da atividade mínima:</strong> o Parceiro não atinge os <strong>100 pontos mensais</strong> durante <strong>três meses consecutivos</strong>. A SACS notificará por escrito no segundo mês e concederá um período de regularização de 30 dias corridos antes da baixa definitiva.' },
  'ct.p6.c2': { es: '<strong>Incumplimiento de cuota anual:</strong> al cumplir 12 meses, el Partner no alcanza la cuota mínima de 10 sucursales activas vendidas. En este caso, ambas partes podrán acordar un plan de recuperación de 90 días o terminar el acuerdo conforme a la cláusula 16.', en: '<strong>Failure to meet annual quota:</strong> at 12 months, the Partner has not reached the minimum quota of 10 active stores sold. In that case, both parties may agree to a 90-day recovery plan or terminate the agreement per clause 16.', fr: '<strong>Manquement au quota annuel :</strong> à 12 mois, le Partenaire n\'atteint pas le quota minimum de 10 boutiques actives vendues. Dans ce cas, les deux parties pourront convenir d\'un plan de récupération de 90 jours ou résilier l\'accord selon la clause 16.', it: '<strong>Mancato raggiungimento della quota annuale:</strong> a 12 mesi, il Partner non ha raggiunto la quota minima di 10 negozi attivi venduti. In tal caso, entrambe le parti potranno concordare un piano di recupero di 90 giorni o terminare l\'accordo secondo la clausola 16.', pt: '<strong>Descumprimento da cota anual:</strong> ao completar 12 meses, o Parceiro não alcança a cota mínima de 10 lojas ativas vendidas. Nesse caso, ambas as partes poderão acordar um plano de recuperação de 90 dias ou terminar o acordo conforme a cláusula 16.' },
  'ct.p6.c3': { es: '<strong>Mala práctica con clientes:</strong> queja documentada, reseña pública negativa o incidencia reportada por un cliente referido en la que, tras conversación con el Partner, se demuestre mal servicio, falsa representación, engaño o cobro indebido imputable al Partner — ver cláusula 7.', en: '<strong>Bad practice with clients:</strong> documented complaint, negative public review or incident reported by a referred client in which, after a conversation with the Partner, bad service, misrepresentation, deceit or undue charging attributable to the Partner is established — see clause 7.', fr: '<strong>Mauvaise pratique avec clients :</strong> plainte documentée, avis public négatif ou incident signalé par un client référé dans lequel, après échange avec le Partenaire, sont établis un mauvais service, une fausse représentation, une tromperie ou une facturation indue imputables au Partenaire — voir clause 7.', it: '<strong>Cattiva pratica con clienti:</strong> reclamo documentato, recensione pubblica negativa o incidente riportato da un cliente riferito in cui, dopo conversazione con il Partner, si dimostri cattivo servizio, falsa rappresentazione, inganno o addebito indebito imputabili al Partner — vedi clausola 7.', pt: '<strong>Má prática com clientes:</strong> reclamação documentada, avaliação pública negativa ou incidente reportado por cliente referenciado em que, após conversa com o Parceiro, fique demonstrado mau serviço, falsa representação, engano ou cobrança indevida imputáveis ao Parceiro — ver cláusula 7.' },
  'ct.p6.c4': { es: '<strong>Servicios profesionales sin certificación:</strong> el Partner ofrece o ejecuta implementaciones, migraciones, automatizaciones o consultoría sobre el producto SACS sin contar con la certificación correspondiente vigente — ver cláusula 8.', en: '<strong>Professional services without certification:</strong> the Partner offers or executes implementations, migrations, automations or consulting on the SACS product without holding the corresponding active certification — see clause 8.', fr: '<strong>Services professionnels sans certification :</strong> le Partenaire propose ou exécute des implémentations, migrations, automatisations ou conseils sur le produit SACS sans détenir la certification correspondante en vigueur — voir clause 8.', it: '<strong>Servizi professionali senza certificazione:</strong> il Partner offre o esegue implementazioni, migrazioni, automazioni o consulenza sul prodotto SACS senza disporre della certificazione corrispondente vigente — vedi clausola 8.', pt: '<strong>Serviços profissionais sem certificação:</strong> o Parceiro oferece ou executa implementações, migrações, automações ou consultoria sobre o produto SACS sem possuir a certificação correspondente vigente — ver cláusula 8.' },
  'ct.p6.c5': { es: '<strong>Conducta dañina a la marca:</strong> mensajes ofensivos, difamatorios o denigrantes sobre SACS, su personal, otros partners o sus clientes, en redes sociales, mensajería (WhatsApp, Telegram, email), testimonios públicos o cualquier otro canal — ver cláusula 7.', en: '<strong>Conduct damaging to the brand:</strong> offensive, defamatory or denigrating messages about SACS, its staff, other partners or their clients, on social media, messaging (WhatsApp, Telegram, email), public testimonials or any other channel — see clause 7.', fr: '<strong>Conduite préjudiciable à la marque :</strong> messages offensants, diffamatoires ou dénigrants sur SACS, son personnel, d\'autres partenaires ou leurs clients, sur les réseaux sociaux, la messagerie (WhatsApp, Telegram, email), les témoignages publics ou tout autre canal — voir clause 7.', it: '<strong>Condotta dannosa al brand:</strong> messaggi offensivi, diffamatori o denigratori su SACS, il suo personale, altri partner o i loro clienti, su social media, messaggistica (WhatsApp, Telegram, email), testimonianze pubbliche o qualsiasi altro canale — vedi clausola 7.', pt: '<strong>Conduta prejudicial à marca:</strong> mensagens ofensivas, difamatórias ou denigratórias sobre a SACS, seu pessoal, outros parceiros ou seus clientes, em redes sociais, mensageria (WhatsApp, Telegram, email), testemunhos públicos ou qualquer outro canal — ver cláusula 7.' },
  'ct.p6.c6': { es: '<strong>Fraude o manipulación de atribución:</strong> leads autoreferidos, clicks artificiales, registros falsos, suplantación de identidad o cualquier otra práctica destinada a inflar la atribución del Partner — ver cláusula 9.', en: '<strong>Fraud or attribution manipulation:</strong> self-referred leads, artificial clicks, fake registrations, identity spoofing or any other practice aimed at inflating the Partner\'s attribution — see clause 9.', fr: '<strong>Fraude ou manipulation d\'attribution :</strong> leads auto-référés, clics artificiels, inscriptions fausses, usurpation d\'identité ou toute autre pratique visant à gonfler l\'attribution du Partenaire — voir clause 9.', it: '<strong>Frode o manipolazione dell\'attribuzione:</strong> lead auto-riferiti, click artificiali, registrazioni false, furto d\'identità o qualsiasi altra pratica volta a gonfiare l\'attribuzione del Partner — vedi clausola 9.', pt: '<strong>Fraude ou manipulação de atribuição:</strong> leads autorreferenciados, cliques artificiais, registros falsos, falsificação de identidade ou qualquer outra prática destinada a inflar a atribuição do Parceiro — ver cláusula 9.' },

  'ct.h6b': { es: '6-bis. Consolidación de cartera y protección de comisiones', en: '6-bis. Portfolio consolidation and commission protection', fr: '6-bis. Consolidation du portefeuille et protection des commissions', it: '6-bis. Consolidamento del portafoglio e protezione delle commissioni', pt: '6-bis. Consolidação de carteira e proteção de comissões' },
  'ct.p6b.intro': { es: 'Las comisiones recurrentes corresponden a cuentas que el Partner prospectó, trabajó y cerró con su propia inversión y gestión comercial. Por ello, la baja del programa no extingue por sí sola los derechos reconocidos en esta cláusula, que se rige por las siguientes reglas:', en: 'Recurring commissions correspond to accounts the Partner prospected, worked and closed with their own investment and commercial effort. For that reason, removal from the program does not by itself extinguish the rights recognized in this clause, which is governed by the following rules:', fr: 'Les commissions récurrentes correspondent à des comptes que le Partenaire a prospectés, travaillés et conclus avec son propre investissement et sa propre gestion commerciale. Pour cette raison, l\'exclusion du programme n\'éteint pas à elle seule les droits reconnus dans cette clause, régie par les règles suivantes :', it: 'Le commissioni ricorrenti corrispondono a conti che il Partner ha prospettato, lavorato e chiuso con il proprio investimento e la propria gestione commerciale. Per questo motivo, la rimozione dal programma non estingue di per sé i diritti riconosciuti in questa clausola, regolata dalle seguenti regole:', pt: 'As comissões recorrentes correspondem a contas que o Parceiro prospectou, trabalhou e fechou com seu próprio investimento e gestão comercial. Por isso, a baixa do programa não extingue por si só os direitos reconhecidos nesta cláusula, regida pelas seguintes regras:' },
  'ct.p6b.c1': { es: '<strong>Consolidación de cartera:</strong> al alcanzar <strong>100 cuentas activas</strong> simultáneas, la cartera del Partner se considera consolidada: la baja por incumplimiento de actividad mínima (cláusula 6) deja de aplicar sobre esa cartera y el Partner conserva sus comisiones recurrentes mientras las cuentas permanezcan activas, al corriente y sin cancelación, incorpore o no cuentas nuevas. La consolidación adquirida no se pierde si la cartera disminuye después por cancelaciones naturales.', en: '<strong>Portfolio consolidation:</strong> upon reaching <strong>100 simultaneous active accounts</strong>, the Partner\'s portfolio is deemed consolidated: removal for failure to meet minimum activity (clause 6) no longer applies to that portfolio and the Partner keeps their recurring commissions while the accounts remain active, current and not cancelled, whether or not new accounts are added. Once acquired, consolidation is not lost if the portfolio later shrinks through natural cancellations.', fr: '<strong>Consolidation du portefeuille :</strong> en atteignant <strong>100 comptes actifs</strong> simultanés, le portefeuille du Partenaire est réputé consolidé : l\'exclusion pour manquement à l\'activité minimale (clause 6) cesse de s\'appliquer à ce portefeuille et le Partenaire conserve ses commissions récurrentes tant que les comptes restent actifs, à jour et non résiliés, qu\'il ajoute ou non de nouveaux comptes. Une fois acquise, la consolidation ne se perd pas si le portefeuille diminue ensuite par résiliations naturelles.', it: '<strong>Consolidamento del portafoglio:</strong> al raggiungimento di <strong>100 conti attivi</strong> simultanei, il portafoglio del Partner si considera consolidato: la rimozione per mancato raggiungimento dell\'attività minima (clausola 6) cessa di applicarsi a quel portafoglio e il Partner conserva le proprie commissioni ricorrenti finché i conti restano attivi, in regola e non cancellati, indipendentemente dall\'aggiunta di nuovi conti. Una volta acquisito, il consolidamento non si perde se il portafoglio si riduce in seguito per cancellazioni naturali.', pt: '<strong>Consolidação de carteira:</strong> ao alcançar <strong>100 contas ativas</strong> simultâneas, a carteira do Parceiro considera-se consolidada: a baixa por descumprimento de atividade mínima (cláusula 6) deixa de aplicar-se a essa carteira e o Parceiro conserva suas comissões recorrentes enquanto as contas permanecerem ativas, em dia e sem cancelamento, incorpore ou não novas contas. A consolidação adquirida não se perde se a carteira diminuir depois por cancelamentos naturais.' },
  'ct.p6b.c2': { es: '<strong>Pausa notificada:</strong> el Partner podrá solicitar por escrito una pausa de su actividad por motivos personales, familiares, laborales o de salud, de hasta <strong>6 meses</strong>, renovable de común acuerdo en casos de salud acreditados. La pausa no computa como inactividad, el Partner conserva íntegras sus comisiones recurrentes y SACS podrá asumir temporalmente la atención de las cuentas sin que ello constituya cesión de la cartera.', en: '<strong>Notified pause:</strong> the Partner may request in writing a pause of their activity for personal, family, work or health reasons, for up to <strong>6 months</strong>, renewable by mutual agreement in duly evidenced health cases. The pause does not count as inactivity, the Partner keeps their recurring commissions in full, and SACS may temporarily take over account care without this constituting a transfer of the portfolio.', fr: '<strong>Pause notifiée :</strong> le Partenaire peut demander par écrit une pause de son activité pour des raisons personnelles, familiales, professionnelles ou de santé, d\'une durée maximale de <strong>6 mois</strong>, renouvelable d\'un commun accord dans les cas de santé dûment justifiés. La pause ne compte pas comme inactivité, le Partenaire conserve l\'intégralité de ses commissions récurrentes et SACS peut assurer temporairement le suivi des comptes sans que cela constitue une cession du portefeuille.', it: '<strong>Pausa notificata:</strong> il Partner può richiedere per iscritto una pausa della propria attività per motivi personali, familiari, lavorativi o di salute, fino a <strong>6 mesi</strong>, rinnovabile di comune accordo nei casi di salute debitamente documentati. La pausa non conta come inattività, il Partner conserva integralmente le proprie commissioni ricorrenti e SACS può assumere temporaneamente la cura dei conti senza che ciò costituisca cessione del portafoglio.', pt: '<strong>Pausa notificada:</strong> o Parceiro poderá solicitar por escrito uma pausa de sua atividade por motivos pessoais, familiares, de trabalho ou de saúde, de até <strong>6 meses</strong>, renovável de comum acordo em casos de saúde devidamente comprovados. A pausa não conta como inatividade, o Parceiro conserva integralmente suas comissões recorrentes e a SACS poderá assumir temporariamente o atendimento das contas sem que isso constitua cessão da carteira.' },
  'ct.p6b.c3': { es: '<strong>Imposibilidad definitiva o incapacidad permanente:</strong> el Partner conserva las comisiones recurrentes de su cartera durante <strong>24 meses</strong> a partir de la notificación, o <strong>36 meses</strong> si su cartera es igual o mayor a <strong>50 cuentas activas</strong>, pudiendo optar en su lugar por el mecanismo de continuidad previsto en esta misma cláusula.', en: '<strong>Definitive impossibility or permanent incapacity:</strong> the Partner keeps the recurring commissions of their portfolio for <strong>24 months</strong> from notice, or <strong>36 months</strong> if their portfolio holds <strong>50 or more active accounts</strong>, and may opt instead for the continuity mechanism set out in this same clause.', fr: '<strong>Impossibilité définitive ou incapacité permanente :</strong> le Partenaire conserve les commissions récurrentes de son portefeuille pendant <strong>24 mois</strong> à compter de la notification, ou <strong>36 mois</strong> si son portefeuille compte <strong>50 comptes actifs ou plus</strong>, et peut opter à la place pour le mécanisme de continuité prévu dans cette même clause.', it: '<strong>Impossibilità definitiva o incapacità permanente:</strong> il Partner conserva le commissioni ricorrenti del proprio portafoglio per <strong>24 mesi</strong> dalla notifica, o <strong>36 mesi</strong> se il portafoglio conta <strong>50 o più conti attivi</strong>, potendo optare in alternativa per il meccanismo di continuità previsto in questa stessa clausola.', pt: '<strong>Impossibilidade definitiva ou incapacidade permanente:</strong> o Parceiro conserva as comissões recorrentes de sua carteira durante <strong>24 meses</strong> a partir da notificação, ou <strong>36 meses</strong> se sua carteira for igual ou maior a <strong>50 contas ativas</strong>, podendo optar em vez disso pelo mecanismo de continuidade previsto nesta mesma cláusula.' },
  'ct.p6b.c4': { es: '<strong>Fallecimiento:</strong> los beneficiarios designados reciben las comisiones recurrentes de la cartera durante <strong>24 meses</strong>, o <strong>36 meses</strong> si la cartera es igual o mayor a 50 cuentas activas. El beneficio no es vitalicio: su duración es la aquí pactada y solo puede extenderse mediante el mecanismo de continuidad.', en: '<strong>Death:</strong> the designated beneficiaries receive the recurring commissions of the portfolio for <strong>24 months</strong>, or <strong>36 months</strong> if the portfolio holds 50 or more active accounts. The benefit is not lifelong: its duration is as agreed herein and can only be extended through the continuity mechanism.', fr: '<strong>Décès :</strong> les bénéficiaires désignés reçoivent les commissions récurrentes du portefeuille pendant <strong>24 mois</strong>, ou <strong>36 mois</strong> si le portefeuille compte 50 comptes actifs ou plus. L\'avantage n\'est pas viager : sa durée est celle convenue ici et ne peut être prolongée que par le mécanisme de continuité.', it: '<strong>Decesso:</strong> i beneficiari designati ricevono le commissioni ricorrenti del portafoglio per <strong>24 mesi</strong>, o <strong>36 mesi</strong> se il portafoglio conta 50 o più conti attivi. Il beneficio non è vitalizio: la sua durata è quella qui pattuita e può essere estesa solo tramite il meccanismo di continuità.', pt: '<strong>Falecimento:</strong> os beneficiários designados recebem as comissões recorrentes da carteira durante <strong>24 meses</strong>, ou <strong>36 meses</strong> se a carteira for igual ou maior a 50 contas ativas. O benefício não é vitalício: sua duração é a aqui pactuada e só pode ser estendida pelo mecanismo de continuidade.' },
  'ct.p6b.c5': { es: '<strong>Designación de beneficiarios:</strong> el Partner puede designar por escrito hasta <strong>3 beneficiarios</strong> con sus porcentajes, desde la firma o en cualquier momento posterior, y modificar la designación cuantas veces lo requiera; prevalece la última recibida por SACS. A falta de designación, el beneficio se entrega a quien acredite el carácter de heredero conforme a la legislación aplicable.', en: '<strong>Beneficiary designation:</strong> the Partner may designate in writing up to <strong>3 beneficiaries</strong> with their percentages, at signing or at any later time, and may modify the designation as often as needed; the last one received by SACS prevails. Absent a designation, the benefit is delivered to whoever proves heir status under applicable law.', fr: '<strong>Désignation de bénéficiaires :</strong> le Partenaire peut désigner par écrit jusqu\'à <strong>3 bénéficiaires</strong> avec leurs pourcentages, dès la signature ou à tout moment ultérieur, et modifier la désignation autant de fois que nécessaire ; la dernière reçue par SACS prévaut. À défaut de désignation, l\'avantage est remis à qui justifie de la qualité d\'héritier selon la loi applicable.', it: '<strong>Designazione dei beneficiari:</strong> il Partner può designare per iscritto fino a <strong>3 beneficiari</strong> con le rispettive percentuali, alla firma o in qualsiasi momento successivo, e modificare la designazione ogni volta che lo richieda; prevale l\'ultima ricevuta da SACS. In mancanza di designazione, il beneficio è consegnato a chi dimostri la qualità di erede secondo la legge applicabile.', pt: '<strong>Designação de beneficiários:</strong> o Parceiro pode designar por escrito até <strong>3 beneficiários</strong> com seus percentuais, na assinatura ou a qualquer momento posterior, e modificar a designação quantas vezes precisar; prevalece a última recebida pela SACS. Na falta de designação, o benefício é entregue a quem comprovar a condição de herdeiro conforme a legislação aplicável.' },
  'ct.p6b.c6': { es: '<strong>Requisitos de las cuentas:</strong> los beneficios de esta cláusula se calculan únicamente sobre cuentas que permanezcan <strong>activas, al corriente y sin cancelación</strong>. La cancelación o morosidad de una cuenta suspende la comisión de esa cuenta sin afectar al resto. Durante los periodos de protección, la atención operativa de las cuentas queda a cargo de SACS sin costo para el Partner o sus beneficiarios y sin que ello constituya cesión de la cartera.', en: '<strong>Account requirements:</strong> the benefits of this clause are calculated only on accounts that remain <strong>active, current and not cancelled</strong>. Cancellation or delinquency of an account suspends that account\'s commission without affecting the rest. During protection periods, operational care of the accounts is handled by SACS at no cost to the Partner or their beneficiaries and without this constituting a transfer of the portfolio.', fr: '<strong>Conditions des comptes :</strong> les avantages de cette clause ne sont calculés que sur les comptes qui restent <strong>actifs, à jour et non résiliés</strong>. La résiliation ou l\'impayé d\'un compte suspend la commission de ce compte sans affecter les autres. Pendant les périodes de protection, le suivi opérationnel des comptes est assuré par SACS sans frais pour le Partenaire ou ses bénéficiaires et sans que cela constitue une cession du portefeuille.', it: '<strong>Requisiti dei conti:</strong> i benefici di questa clausola si calcolano solo sui conti che restano <strong>attivi, in regola e non cancellati</strong>. La cancellazione o la morosità di un conto sospende la commissione di quel conto senza incidere sugli altri. Durante i periodi di protezione, la cura operativa dei conti è a carico di SACS senza costi per il Partner o i suoi beneficiari e senza che ciò costituisca cessione del portafoglio.', pt: '<strong>Requisitos das contas:</strong> os benefícios desta cláusula são calculados apenas sobre contas que permaneçam <strong>ativas, em dia e sem cancelamento</strong>. O cancelamento ou a inadimplência de uma conta suspende a comissão dessa conta sem afetar as demais. Durante os períodos de proteção, o atendimento operacional das contas fica a cargo da SACS sem custo para o Parceiro ou seus beneficiários e sem que isso constitua cessão da carteira.' },
  'ct.p6b.c7': { es: '<strong>Continuidad de la cartera:</strong> en los supuestos de imposibilidad, incapacidad o fallecimiento, un familiar o representante del Partner podrá asumir la administración de la cartera como nuevo Partner, previa aprobación de SACS — que no será negada sin causa razonable —, acreditación de la certificación vigente y firma del contrato de Partner. Aprobada la continuidad, la cartera se transfiere con todas las condiciones del programa, incluida la consolidación ya adquirida, y sustituye a los periodos de protección temporal.', en: '<strong>Portfolio continuity:</strong> in cases of impossibility, incapacity or death, a family member or representative of the Partner may take over the portfolio as a new Partner, subject to SACS approval — not to be withheld without reasonable cause —, completion of the current certification and signature of the Partner agreement. Once approved, the portfolio is transferred with all program conditions, including any consolidation already acquired, and replaces the temporary protection periods.', fr: '<strong>Continuité du portefeuille :</strong> en cas d\'impossibilité, d\'incapacité ou de décès, un membre de la famille ou un représentant du Partenaire peut reprendre la gestion du portefeuille en tant que nouveau Partenaire, sous réserve de l\'approbation de SACS — qui ne sera pas refusée sans motif raisonnable —, de l\'obtention de la certification en vigueur et de la signature du contrat de Partenaire. Une fois approuvée, le portefeuille est transféré avec toutes les conditions du programme, y compris la consolidation déjà acquise, et remplace les périodes de protection temporaire.', it: '<strong>Continuità del portafoglio:</strong> nei casi di impossibilità, incapacità o decesso, un familiare o rappresentante del Partner può assumere la gestione del portafoglio come nuovo Partner, previa approvazione di SACS — che non sarà negata senza causa ragionevole —, conseguimento della certificazione vigente e firma del contratto di Partner. Approvata la continuità, il portafoglio viene trasferito con tutte le condizioni del programma, inclusa la consolidazione già acquisita, e sostituisce i periodi di protezione temporanea.', pt: '<strong>Continuidade da carteira:</strong> nas hipóteses de impossibilidade, incapacidade ou falecimento, um familiar ou representante do Parceiro poderá assumir a administração da carteira como novo Parceiro, mediante aprovação da SACS — que não será negada sem causa razoável —, obtenção da certificação vigente e assinatura do contrato de Parceiro. Aprovada a continuidade, a carteira é transferida com todas as condições do programa, incluída a consolidação já adquirida, e substitui os períodos de proteção temporária.' },
  'ct.p6b.outro': { es: 'En lo que se opongan, las reglas de esta cláusula 6-bis prevalecen sobre las cláusulas 2.4 y 6.', en: 'To the extent of any conflict, the rules of this clause 6-bis prevail over clauses 2.4 and 6.', fr: 'En cas de contradiction, les règles de cette clause 6-bis prévalent sur les clauses 2.4 et 6.', it: 'In caso di contrasto, le regole di questa clausola 6-bis prevalgono sulle clausole 2.4 e 6.', pt: 'Em caso de conflito, as regras desta cláusula 6-bis prevalecem sobre as cláusulas 2.4 e 6.' },

  'ct.h7': { es: '7. Conducta pública y manejo de reseñas', en: '7. Public conduct and review handling', fr: '7. Conduite publique et gestion des avis', it: '7. Condotta pubblica e gestione delle recensioni', pt: '7. Conduta pública e gestão de avaliações' },
  'ct.p7': { es: 'El Partner se compromete a representar a SACS, su equipo y su comunidad de partners y clientes con respeto y honestidad en cualquier canal público o privado, incluyendo redes sociales, mensajería (WhatsApp, Telegram, email), testimonios, reseñas, podcasts y conversaciones con prospectos. Cualquier mensaje ofensivo, difamatorio, denigrante o que dañe injustificadamente la reputación de SACS detona el procedimiento de la cláusula 6 con suspensión inmediata.<br/><br/>Cuando un cliente referido emita una queja, deje una reseña pública negativa o reporte una mala experiencia, SACS abrirá una conversación con el Partner para entender el contexto antes de tomar cualquier decisión. Si tras dicha conversación se demuestra que existió mal servicio, falsa representación, engaño o cobro indebido imputables al Partner, se procederá a la suspensión automática del programa conforme a la cláusula 6, sin perjuicio de las acciones civiles o penales que correspondan.', en: 'The Partner undertakes to represent SACS, its team and its community of partners and clients with respect and honesty in any public or private channel, including social media, messaging (WhatsApp, Telegram, email), testimonials, reviews, podcasts and conversations with prospects. Any offensive, defamatory, denigrating message — or any message that unjustifiably harms SACS\'s reputation — triggers the procedure of clause 6 with immediate suspension.<br/><br/>When a referred client raises a complaint, leaves a negative public review or reports a bad experience, SACS will open a conversation with the Partner to understand the context before making any decision. If after that conversation bad service, misrepresentation, deceit or undue charging attributable to the Partner is established, automatic suspension of the program will follow per clause 6, without prejudice to applicable civil or criminal actions.', fr: 'Le Partenaire s\'engage à représenter SACS, son équipe et sa communauté de partenaires et clients avec respect et honnêteté sur tout canal public ou privé, y compris les réseaux sociaux, la messagerie (WhatsApp, Telegram, email), les témoignages, avis, podcasts et conversations avec des prospects. Tout message offensant, diffamatoire, dénigrant — ou tout message portant injustement atteinte à la réputation de SACS — déclenche la procédure de la clause 6 avec suspension immédiate.<br/><br/>Lorsqu\'un client référé formule une plainte, laisse un avis public négatif ou signale une mauvaise expérience, SACS ouvrira un échange avec le Partenaire pour comprendre le contexte avant toute décision. Si à l\'issue de cet échange un mauvais service, une fausse représentation, une tromperie ou une facturation indue imputables au Partenaire sont établis, la suspension automatique du programme s\'appliquera selon la clause 6, sans préjudice des actions civiles ou pénales applicables.', it: 'Il Partner si impegna a rappresentare SACS, il suo team e la sua comunità di partner e clienti con rispetto e onestà in qualsiasi canale pubblico o privato, inclusi social media, messaggistica (WhatsApp, Telegram, email), testimonianze, recensioni, podcast e conversazioni con prospect. Qualsiasi messaggio offensivo, diffamatorio, denigratorio — o qualsiasi messaggio che danneggi ingiustificatamente la reputazione di SACS — attiva la procedura della clausola 6 con sospensione immediata.<br/><br/>Quando un cliente riferito presenta un reclamo, lascia una recensione pubblica negativa o segnala una cattiva esperienza, SACS aprirà una conversazione con il Partner per comprendere il contesto prima di qualsiasi decisione. Se dopo tale conversazione viene dimostrato un cattivo servizio, falsa rappresentazione, inganno o addebito indebito imputabili al Partner, si procederà alla sospensione automatica del programma secondo la clausola 6, fatte salve le azioni civili o penali applicabili.', pt: 'O Parceiro se compromete a representar a SACS, sua equipe e sua comunidade de parceiros e clientes com respeito e honestidade em qualquer canal público ou privado, incluindo redes sociais, mensageria (WhatsApp, Telegram, email), testemunhos, avaliações, podcasts e conversas com prospectos. Qualquer mensagem ofensiva, difamatória, denigratória — ou qualquer mensagem que prejudique injustificadamente a reputação da SACS — aciona o procedimento da cláusula 6 com suspensão imediata.<br/><br/>Quando um cliente referenciado apresentar reclamação, deixar avaliação pública negativa ou reportar má experiência, a SACS abrirá uma conversa com o Parceiro para entender o contexto antes de qualquer decisão. Se, após essa conversa, ficar demonstrado mau serviço, falsa representação, engano ou cobrança indevida imputáveis ao Parceiro, procederá à suspensão automática do programa conforme a cláusula 6, sem prejuízo das ações cíveis ou penais aplicáveis.' },

  'ct.h8': { es: '8. Certificaciones para servicios profesionales', en: '8. Certifications for professional services', fr: '8. Certifications pour services professionnels', it: '8. Certificazioni per servizi professionali', pt: '8. Certificações para serviços profissionais' },
  'ct.p8.intro': { es: 'Sin certificación vigente, el Partner solo puede <strong>recomendar y vender SACS a través de su link único</strong>, generando las comisiones previstas en la cláusula 2. El Partner <strong>no podrá</strong> ofrecer ni ejecutar implementaciones, migraciones de datos, configuraciones avanzadas, automatizaciones, ni consultoría sobre el producto SACS — esos servicios profesionales requieren la certificación correspondiente vigente, otorgada por SACS tras una capacitación formal. Realizar cualquiera de estos servicios sin certificación constituye causal de suspensión inmediata conforme a la cláusula 6, además de la obligación del Partner de subsanar cualquier daño causado al cliente. Las certificaciones disponibles son:', en: 'Without an active certification, the Partner may only <strong>recommend and sell SACS through their unique link</strong>, generating the commissions set out in clause 2. The Partner <strong>shall not</strong> offer or execute implementations, data migrations, advanced configurations, automations or consulting on the SACS product — those professional services require the corresponding active certification, issued by SACS after formal training. Performing any of these services without certification is grounds for immediate suspension per clause 6, in addition to the Partner\'s obligation to remedy any damage caused to the client. Available certifications:', fr: 'Sans certification en vigueur, le Partenaire peut uniquement <strong>recommander et vendre SACS via son lien unique</strong>, générant les commissions prévues à la clause 2. Le Partenaire <strong>ne pourra pas</strong> proposer ni exécuter d\'implémentations, migrations de données, configurations avancées, automatisations ou conseils sur le produit SACS — ces services professionnels nécessitent la certification correspondante en vigueur, délivrée par SACS après une formation formelle. Réaliser l\'un de ces services sans certification constitue un motif de suspension immédiate selon la clause 6, en plus de l\'obligation pour le Partenaire de réparer tout dommage causé au client. Certifications disponibles :', it: 'Senza certificazione in vigore, il Partner può solo <strong>raccomandare e vendere SACS tramite il suo link unico</strong>, generando le commissioni previste dalla clausola 2. Il Partner <strong>non potrà</strong> offrire o eseguire implementazioni, migrazioni di dati, configurazioni avanzate, automazioni o consulenza sul prodotto SACS — tali servizi professionali richiedono la certificazione corrispondente in vigore, rilasciata da SACS dopo una formazione formale. Eseguire uno di questi servizi senza certificazione costituisce causa di sospensione immediata secondo la clausola 6, oltre all\'obbligo del Partner di rimediare a qualsiasi danno causato al cliente. Certificazioni disponibili:', pt: 'Sem certificação vigente, o Parceiro só pode <strong>recomendar e vender SACS através de seu link único</strong>, gerando as comissões previstas na cláusula 2. O Parceiro <strong>não poderá</strong> oferecer nem executar implementações, migrações de dados, configurações avançadas, automações ou consultoria sobre o produto SACS — esses serviços profissionais requerem a certificação correspondente vigente, outorgada pela SACS após capacitação formal. Realizar qualquer desses serviços sem certificação constitui causa de suspensão imediata conforme a cláusula 6, além da obrigação do Parceiro de sanar qualquer dano causado ao cliente. Certificações disponíveis:' },
  'ct.p8.cert1': { es: '<strong>Implementación · 1 sucursal</strong> — habilita al Partner para ejecutar la implementación completa de SACS en negocios de una sola sucursal.', en: '<strong>Implementation · 1 store</strong> — enables the Partner to execute the full SACS implementation for single-store businesses.', fr: '<strong>Implémentation · 1 boutique</strong> — autorise le Partenaire à exécuter l\'implémentation complète de SACS pour les activités mono-boutique.', it: '<strong>Implementazione · 1 negozio</strong> — abilita il Partner a eseguire l\'implementazione completa di SACS per attività con un solo negozio.', pt: '<strong>Implementação · 1 loja</strong> — habilita o Parceiro a executar a implementação completa da SACS em negócios de uma só loja.' },
  'ct.p8.cert2': { es: '<strong>Implementación · Multisucursal</strong> — habilita la implementación en negocios con múltiples sucursales: arquitectura, consolidación, transferencias y reportes HQ.', en: '<strong>Implementation · Multi-store</strong> — enables implementation for multi-store businesses: architecture, consolidation, transfers and HQ reporting.', fr: '<strong>Implémentation · Multi-boutiques</strong> — autorise l\'implémentation pour les activités multi-boutiques : architecture, consolidation, transferts et reporting HQ.', it: '<strong>Implementazione · Multi-negozio</strong> — abilita l\'implementazione per attività multi-negozio: architettura, consolidamento, trasferimenti e reporting HQ.', pt: '<strong>Implementação · Multi-loja</strong> — habilita a implementação em negócios multi-loja: arquitetura, consolidação, transferências e relatórios HQ.' },
  'ct.p8.cert3': { es: '<strong>Migración de datos</strong> — habilita la migración de datos del cliente desde Excel, Aspel, Microsip u otros sistemas hacia SACS.', en: '<strong>Data migration</strong> — enables migrating client data from Excel, Aspel, Microsip or other systems into SACS.', fr: '<strong>Migration de données</strong> — autorise la migration des données client depuis Excel, Aspel, Microsip ou d\'autres systèmes vers SACS.', it: '<strong>Migrazione dati</strong> — abilita la migrazione dei dati del cliente da Excel, Aspel, Microsip o altri sistemi verso SACS.', pt: '<strong>Migração de dados</strong> — habilita a migração de dados do cliente desde Excel, Aspel, Microsip ou outros sistemas para a SACS.' },
  'ct.p8.cert4': { es: '<strong>Automatización con IA</strong> — habilita el uso del módulo de IA de SACS (Axo Copilot y orquestador de agentes) para automatizar procesos del cliente.', en: '<strong>AI automation</strong> — enables use of the SACS AI module (Axo Copilot and agent orchestrator) to automate client processes.', fr: '<strong>Automatisation par IA</strong> — autorise l\'utilisation du module IA de SACS (Axo Copilot et orchestrateur d\'agents) pour automatiser les processus client.', it: '<strong>Automazione con IA</strong> — abilita l\'uso del modulo IA di SACS (Axo Copilot e orchestratore di agenti) per automatizzare i processi del cliente.', pt: '<strong>Automação com IA</strong> — habilita o uso do módulo de IA da SACS (Axo Copilot e orquestrador de agentes) para automatizar processos do cliente.' },
  'ct.p8.cert5': { es: '<strong>Consultor en IA</strong> — habilita el servicio recurrente de lectura e interpretación de datos del cliente con IA y entrega de reporte ejecutivo cada 30 días.', en: '<strong>AI consultant</strong> — enables the recurring service of reading and interpreting client data with AI and delivering an executive report every 30 days.', fr: '<strong>Consultant IA</strong> — autorise le service récurrent de lecture et interprétation des données client avec IA et livraison d\'un rapport exécutif tous les 30 jours.', it: '<strong>Consulente IA</strong> — abilita il servizio ricorrente di lettura e interpretazione dei dati del cliente con IA e consegna di un report esecutivo ogni 30 giorni.', pt: '<strong>Consultor em IA</strong> — habilita o serviço recorrente de leitura e interpretação de dados do cliente com IA e entrega de relatório executivo a cada 30 dias.' },
  'ct.p8.outro': { es: 'Cada certificación se obtiene mediante una capacitación con cuota de pago único; concluida y aprobada la certificación, el Partner conserva el <strong>100% de lo que cobre al cliente final</strong> por el servicio profesional, sin retención por parte de SACS.', en: 'Each certification is obtained via a one-time-fee training; once the certification is completed and passed, the Partner keeps <strong>100% of what they charge the end client</strong> for the professional service, with no withholding by SACS.', fr: 'Chaque certification s\'obtient via une formation à frais uniques ; une fois la certification terminée et validée, le Partenaire conserve <strong>100% de ce qu\'il facture au client final</strong> pour le service professionnel, sans retenue de SACS.', it: 'Ogni certificazione si ottiene tramite una formazione con quota unica; una volta completata e superata la certificazione, il Partner mantiene il <strong>100% di quanto fattura al cliente finale</strong> per il servizio professionale, senza trattenute da parte di SACS.', pt: 'Cada certificação é obtida mediante capacitação com taxa de pagamento único; concluída e aprovada a certificação, o Parceiro mantém <strong>100% do que cobrar do cliente final</strong> pelo serviço profissional, sem retenção pela SACS.' },
  'ct.h8b': { es: '8-bis. Bonificación por canalización de servicios de consultoría', en: '8-bis. Referral bonus for channeling consulting services', fr: '8-bis. Prime de canalisation de services de conseil', it: '8-bis. Bonus per la canalizzazione di servizi di consulenza', pt: '8-bis. Bonificação por canalização de serviços de consultoria' },
  'ct.p8b.intro': { es: 'Cuando el Partner no pueda o no desee ejecutar directamente un servicio profesional y <strong>canalice al cliente con un consultor autorizado de SACS</strong> para su realización, el Partner recibirá una <strong>bonificación equivalente al 15% del valor del servicio efectivamente contratado y pagado por el cliente</strong>, como reconocimiento por la referencia y canalización del trabajo al equipo de consultoría de SACS. Aplica a servicios como:', en: 'When the Partner cannot or does not wish to perform a professional service directly and <strong>channels the client to an authorized SACS consultant</strong> to carry it out, the Partner will receive a <strong>bonus equal to 15% of the value of the service actually contracted and paid by the client</strong>, in recognition of referring and channeling the work to the SACS consulting team. It applies to services such as:', fr: 'Lorsque le Partenaire ne peut pas ou ne souhaite pas exécuter directement un service professionnel et <strong>oriente le client vers un consultant autorisé de SACS</strong> pour sa réalisation, le Partenaire recevra une <strong>prime équivalente à 15% de la valeur du service effectivement contracté et payé par le client</strong>, en reconnaissance de la référence et de la canalisation du travail vers l\'équipe de conseil de SACS. Elle s\'applique à des services tels que :', it: 'Quando il Partner non può o non desidera eseguire direttamente un servizio professionale e <strong>indirizza il cliente a un consulente autorizzato di SACS</strong> per la sua realizzazione, il Partner riceverà un <strong>bonus pari al 15% del valore del servizio effettivamente contrattato e pagato dal cliente</strong>, come riconoscimento per la referenza e la canalizzazione del lavoro al team di consulenza di SACS. Si applica a servizi come:', pt: 'Quando o Parceiro não puder ou não desejar executar diretamente um serviço profissional e <strong>canalizar o cliente para um consultor autorizado da SACS</strong> para sua realização, o Parceiro receberá uma <strong>bonificação equivalente a 15% do valor do serviço efetivamente contratado e pago pelo cliente</strong>, como reconhecimento pela referência e canalização do trabalho à equipe de consultoria da SACS. Aplica-se a serviços como:' },
  'ct.p8b.s1': { es: 'Migración de artículos y datos (desde Excel, Aspel, Microsip u otros sistemas).', en: 'Migration of items and data (from Excel, Aspel, Microsip or other systems).', fr: 'Migration d\'articles et de données (depuis Excel, Aspel, Microsip ou d\'autres systèmes).', it: 'Migrazione di articoli e dati (da Excel, Aspel, Microsip o altri sistemi).', pt: 'Migração de artigos e dados (de Excel, Aspel, Microsip ou outros sistemas).' },
  'ct.p8b.s2': { es: 'Implementación en negocios de una o múltiples sucursales (arquitectura, consolidación, transferencias y reportes HQ).', en: 'Implementation in single- or multi-store businesses (architecture, consolidation, transfers and HQ reports).', fr: 'Mise en œuvre dans des entreprises mono ou multi-boutiques (architecture, consolidation, transferts et rapports HQ).', it: 'Implementazione in attività con una o più filiali (architettura, consolidamento, trasferimenti e report HQ).', pt: 'Implementação em negócios de uma ou múltiplas filiais (arquitetura, consolidação, transferências e relatórios HQ).' },
  'ct.p8b.s3': { es: 'Configuraciones avanzadas y personalizaciones del sistema.', en: 'Advanced configurations and system customizations.', fr: 'Configurations avancées et personnalisations du système.', it: 'Configurazioni avanzate e personalizzazioni del sistema.', pt: 'Configurações avançadas e personalizações do sistema.' },
  'ct.p8b.s4': { es: 'Automatizaciones con IA (Axo Copilot y orquestador de agentes).', en: 'AI automations (Axo Copilot and agent orchestrator).', fr: 'Automatisations par IA (Axo Copilot et orchestrateur d\'agents).', it: 'Automazioni con IA (Axo Copilot e orchestratore di agenti).', pt: 'Automações com IA (Axo Copilot e orquestrador de agentes).' },
  'ct.p8b.s5': { es: 'Consultoría y lectura/interpretación de datos, y cualquier otro servicio personalizado que el Partner canalice al equipo de SACS.', en: 'Consulting and data reading/interpretation, and any other custom service the Partner channels to the SACS team.', fr: 'Conseil et lecture/interprétation de données, et tout autre service personnalisé que le Partenaire oriente vers l\'équipe SACS.', it: 'Consulenza e lettura/interpretazione dei dati, e qualsiasi altro servizio personalizzato che il Partner indirizza al team SACS.', pt: 'Consultoria e leitura/interpretação de dados, e qualquer outro serviço personalizado que o Parceiro canalize à equipe da SACS.' },
  'ct.p8b.proceso': { es: '<strong>Registro y validación de la referencia:</strong> para que la bonificación proceda, el Partner debe <strong>registrar la referencia antes de canalizar al cliente</strong>, desde su portal de Partner o notificando a <a href="mailto:partners@sacscloud.com">partners@sacscloud.com</a> con el nombre del cliente, el servicio solicitado y su folio de Partner. SACS valida que el cliente proviene del Partner mediante (i) su link único de atribución, (ii) el registro previo de la referencia y/o (iii) confirmación del propio cliente. No aplica si el cliente ya era cuenta activa de SACS o ya estaba siendo atendido por el equipo de consultoría antes de la referencia.', en: '<strong>Referral registration and validation:</strong> for the bonus to apply, the Partner must <strong>register the referral before channeling the client</strong>, from their Partner portal or by notifying <a href="mailto:partners@sacscloud.com">partners@sacscloud.com</a> with the client name, the requested service and their Partner folio. SACS validates that the client comes from the Partner via (i) their unique attribution link, (ii) the prior referral registration and/or (iii) the client\'s own confirmation. It does not apply if the client was already an active SACS account or was already being served by the consulting team before the referral.', fr: '<strong>Enregistrement et validation de la référence :</strong> pour que la prime s\'applique, le Partenaire doit <strong>enregistrer la référence avant d\'orienter le client</strong>, depuis son portail Partenaire ou en notifiant <a href="mailto:partners@sacscloud.com">partners@sacscloud.com</a> avec le nom du client, le service demandé et son folio de Partenaire. SACS valide que le client provient du Partenaire via (i) son lien d\'attribution unique, (ii) l\'enregistrement préalable de la référence et/ou (iii) la confirmation du client lui-même. Ne s\'applique pas si le client était déjà un compte actif de SACS ou était déjà pris en charge par l\'équipe de conseil avant la référence.', it: '<strong>Registrazione e validazione della referenza:</strong> affinché il bonus si applichi, il Partner deve <strong>registrare la referenza prima di indirizzare il cliente</strong>, dal proprio portale Partner o notificando <a href="mailto:partners@sacscloud.com">partners@sacscloud.com</a> con il nome del cliente, il servizio richiesto e il proprio folio di Partner. SACS convalida che il cliente proviene dal Partner tramite (i) il suo link di attribuzione unico, (ii) la registrazione preventiva della referenza e/o (iii) la conferma dello stesso cliente. Non si applica se il cliente era già un account attivo di SACS o era già seguito dal team di consulenza prima della referenza.', pt: '<strong>Registro e validação da referência:</strong> para que a bonificação proceda, o Parceiro deve <strong>registrar a referência antes de canalizar o cliente</strong>, a partir de seu portal de Parceiro ou notificando <a href="mailto:partners@sacscloud.com">partners@sacscloud.com</a> com o nome do cliente, o serviço solicitado e seu folio de Parceiro. A SACS valida que o cliente provém do Parceiro mediante (i) seu link único de atribuição, (ii) o registro prévio da referência e/ou (iii) confirmação do próprio cliente. Não se aplica se o cliente já era conta ativa da SACS ou já estava sendo atendido pela equipe de consultoria antes da referência.' },
  'ct.p8b.pago': { es: '<strong>Plazo y forma de pago:</strong> la bonificación del 15% se calcula sobre el monto efectivamente cobrado al cliente por el servicio (sin impuestos) y se paga dentro de los <strong>30 días naturales</strong> siguientes a que SACS reciba el pago completo del cliente, por el mismo canal y periodicidad que las demás comisiones del programa. Si el cliente reembolsa o cancela el servicio, la bonificación no se genera o se ajusta vía clawback conforme a la cláusula 9.', en: '<strong>Term and form of payment:</strong> the 15% bonus is calculated on the amount actually charged to the client for the service (excluding taxes) and is paid within <strong>30 calendar days</strong> after SACS receives the client\'s full payment, through the same channel and frequency as the program\'s other commissions. If the client refunds or cancels the service, the bonus is not generated or is adjusted via clawback per clause 9.', fr: '<strong>Délai et modalité de paiement :</strong> la prime de 15% est calculée sur le montant effectivement facturé au client pour le service (hors taxes) et est versée dans les <strong>30 jours calendaires</strong> suivant la réception par SACS du paiement complet du client, par le même canal et la même périodicité que les autres commissions du programme. Si le client se fait rembourser ou annule le service, la prime n\'est pas générée ou est ajustée via clawback selon la clause 9.', it: '<strong>Termine e modalità di pagamento:</strong> il bonus del 15% è calcolato sull\'importo effettivamente addebitato al cliente per il servizio (imposte escluse) e viene pagato entro <strong>30 giorni naturali</strong> dalla ricezione da parte di SACS del pagamento completo del cliente, tramite lo stesso canale e periodicità delle altre commissioni del programma. Se il cliente ottiene un rimborso o annulla il servizio, il bonus non viene generato o viene rettificato tramite clawback secondo la clausola 9.', pt: '<strong>Prazo e forma de pagamento:</strong> a bonificação de 15% é calculada sobre o valor efetivamente cobrado do cliente pelo serviço (sem impostos) e é paga dentro de <strong>30 dias corridos</strong> após a SACS receber o pagamento completo do cliente, pelo mesmo canal e periodicidade das demais comissões do programa. Se o cliente reembolsar ou cancelar o serviço, a bonificação não é gerada ou é ajustada via clawback conforme a cláusula 9.' },

  'ct.h9': { es: '9. Auditoría, fraude y clawback', en: '9. Audit, fraud and clawback', fr: '9. Audit, fraude et clawback', it: '9. Audit, frode e clawback', pt: '9. Auditoria, fraude e clawback' },
  'ct.p9': { es: 'SACS se reserva el derecho de auditar trimestralmente cualquier comisión, lead o atribución asociada al Partner. Las comisiones derivadas de leads duplicados, fraudulentos, autoreferenciados o resultantes de manipulación de atribución (clicks artificiales, registros falsos, suplantación de identidad, abuso del link único) se rechazan y se marcan como <em>cancelled</em> en el portal del Partner con el motivo correspondiente. Si las comisiones fraudulentas ya fueron liquidadas, SACS podrá ejecutar <em>clawback</em> compensando el monto contra futuros pagos al Partner o solicitando el reembolso directo dentro de los 30 días naturales siguientes. La detección de fraude reiterado o de mala fe es causal de suspensión inmediata.', en: 'SACS reserves the right to audit any commission, lead or attribution associated with the Partner on a quarterly basis. Commissions arising from duplicate, fraudulent or self-referred leads, or from attribution manipulation (artificial clicks, fake registrations, identity spoofing, link abuse), are rejected and marked as <em>cancelled</em> in the Partner portal with the corresponding reason. If fraudulent commissions have already been settled, SACS may execute a <em>clawback</em> by offsetting the amount against future payments to the Partner or requesting direct reimbursement within the following 30 natural days. Detection of repeated fraud or bad faith is grounds for immediate suspension.', fr: 'SACS se réserve le droit d\'auditer trimestriellement toute commission, lead ou attribution associés au Partenaire. Les commissions issues de leads en double, frauduleux, auto-référés ou résultant d\'une manipulation d\'attribution (clics artificiels, inscriptions fausses, usurpation d\'identité, abus du lien unique) sont rejetées et marquées <em>cancelled</em> dans le portail du Partenaire avec le motif correspondant. Si des commissions frauduleuses ont déjà été versées, SACS pourra exécuter un <em>clawback</em> en compensant le montant sur les paiements futurs ou en demandant le remboursement direct dans les 30 jours calendaires suivants. La détection d\'une fraude répétée ou de mauvaise foi constitue un motif de suspension immédiate.', it: 'SACS si riserva il diritto di auditare trimestralmente qualsiasi commissione, lead o attribuzione associati al Partner. Le commissioni derivanti da lead duplicati, fraudolenti, auto-riferiti o risultanti da manipolazione dell\'attribuzione (click artificiali, registrazioni false, furto d\'identità, abuso del link unico) vengono rifiutate e marcate come <em>cancelled</em> nel portale del Partner con il motivo corrispondente. Se le commissioni fraudolente sono già state liquidate, SACS potrà eseguire <em>clawback</em> compensando l\'importo sui pagamenti futuri o richiedendo il rimborso diretto entro i successivi 30 giorni naturali. Il rilevamento di frode reiterata o malafede è causa di sospensione immediata.', pt: 'A SACS se reserva o direito de auditar trimestralmente qualquer comissão, lead ou atribuição associada ao Parceiro. As comissões derivadas de leads duplicados, fraudulentos, autorreferenciados ou resultantes de manipulação de atribuição (cliques artificiais, registros falsos, falsificação de identidade, abuso do link único) são rejeitadas e marcadas como <em>cancelled</em> no portal do Parceiro com o motivo correspondente. Se as comissões fraudulentas já foram liquidadas, a SACS poderá executar <em>clawback</em> compensando o valor contra pagamentos futuros ao Parceiro ou solicitando o reembolso direto nos 30 dias corridos seguintes. A detecção de fraude reiterada ou má-fé é causa de suspensão imediata.' },

  'ct.h10': { es: '10. Propiedad intelectual del contenido', en: '10. Intellectual property of content', fr: '10. Propriété intellectuelle du contenu', it: '10. Proprietà intellettuale dei contenuti', pt: '10. Propriedade intelectual do conteúdo' },
  'ct.p10': { es: 'El Partner conserva la titularidad del contenido que produce y publica como embajador (videos, reels, blogs, posts, fotografías, presentaciones). Al publicar contenido bajo este programa o subirlo al portal de Partner, el Partner otorga a SACS una <strong>licencia mundial, no exclusiva, libre de regalías y perpetua</strong> para reproducir, distribuir, traducir, adaptar y reutilizar dicho contenido en canales propios de SACS, materiales de marketing, redes sociales, sitio web, eventos y campañas, citando al Partner como autor cuando sea técnicamente viable. SACS no podrá modificar el contenido al punto de tergiversar el mensaje original sin autorización escrita del Partner. Esta licencia sobrevive a la terminación del acuerdo respecto del contenido producido durante la vigencia.', en: 'The Partner retains ownership of the content they produce and publish as an ambassador (videos, reels, blogs, posts, photographs, presentations). By publishing content under this program or uploading it to the Partner portal, the Partner grants SACS a <strong>worldwide, non-exclusive, royalty-free, perpetual license</strong> to reproduce, distribute, translate, adapt and reuse such content on SACS\'s own channels, marketing materials, social media, website, events and campaigns, citing the Partner as author when technically feasible. SACS may not modify the content to the point of distorting the original message without the Partner\'s written authorization. This license survives termination of the agreement with respect to content produced during its term.', fr: 'Le Partenaire conserve la propriété du contenu qu\'il produit et publie en tant qu\'ambassadeur (vidéos, reels, blogs, posts, photographies, présentations). En publiant du contenu sous ce programme ou en l\'envoyant au portail Partenaire, le Partenaire concède à SACS une <strong>licence mondiale, non exclusive, libre de redevances et perpétuelle</strong> pour reproduire, distribuer, traduire, adapter et réutiliser ce contenu sur les canaux propres de SACS, supports marketing, réseaux sociaux, site web, événements et campagnes, en citant le Partenaire comme auteur lorsque cela est techniquement faisable. SACS ne pourra modifier le contenu au point d\'en dénaturer le message d\'origine sans autorisation écrite du Partenaire. Cette licence survit à la résiliation de l\'accord pour le contenu produit pendant sa durée.', it: 'Il Partner conserva la titolarità dei contenuti che produce e pubblica come ambasciatore (video, reel, blog, post, fotografie, presentazioni). Pubblicando contenuti sotto questo programma o caricandoli nel portale Partner, il Partner concede a SACS una <strong>licenza mondiale, non esclusiva, esente da royalty e perpetua</strong> per riprodurre, distribuire, tradurre, adattare e riutilizzare tali contenuti sui canali propri di SACS, materiali di marketing, social media, sito web, eventi e campagne, citando il Partner come autore quando tecnicamente fattibile. SACS non potrà modificare il contenuto al punto di distorcerne il messaggio originale senza autorizzazione scritta del Partner. Questa licenza sopravvive alla risoluzione dell\'accordo per i contenuti prodotti durante la sua vigenza.', pt: 'O Parceiro mantém a titularidade do conteúdo que produz e publica como embaixador (vídeos, reels, blogs, posts, fotografias, apresentações). Ao publicar conteúdo sob este programa ou enviá-lo ao portal do Parceiro, o Parceiro outorga à SACS uma <strong>licença mundial, não exclusiva, livre de royalties e perpétua</strong> para reproduzir, distribuir, traduzir, adaptar e reutilizar tal conteúdo nos canais próprios da SACS, materiais de marketing, redes sociais, site, eventos e campanhas, citando o Parceiro como autor quando tecnicamente viável. A SACS não poderá modificar o conteúdo ao ponto de distorcer a mensagem original sem autorização escrita do Parceiro. Esta licença sobrevive à terminação do acordo com relação ao conteúdo produzido durante sua vigência.' },

  'ct.h11': { es: '11. Confidencialidad recíproca', en: '11. Mutual confidentiality', fr: '11. Confidentialité réciproque', it: '11. Riservatezza reciproca', pt: '11. Confidencialidade recíproca' },
  'ct.p11': { es: 'La obligación de confidencialidad es <strong>recíproca</strong>. Cada parte se obliga a mantener confidencial la información no pública de la otra a la que acceda con motivo del programa, incluyendo precios negociados, roadmap interno, métricas internas, datos personales y comerciales de clientes, listas de leads, materiales de capacitación, descuentos especiales y cualquier información comercial sensible. Esta obligación subsiste por <strong>tres (3) años</strong> contados desde la terminación del acuerdo. Quedan excluidas las informaciones que (i) sean del dominio público sin culpa de la parte receptora, (ii) hayan sido conocidas previamente sin obligación de confidencialidad, o (iii) sean reveladas por requerimiento legal con notificación previa razonable a la otra parte.', en: 'The confidentiality obligation is <strong>mutual</strong>. Each party undertakes to keep confidential the non-public information of the other accessed in connection with the program, including negotiated prices, internal roadmap, internal metrics, personal and commercial client data, lead lists, training materials, special discounts and any sensitive commercial information. This obligation survives for <strong>three (3) years</strong> from termination of the agreement. Excluded is information that (i) is in the public domain through no fault of the receiving party, (ii) was previously known without confidentiality obligation, or (iii) is disclosed by legal requirement with reasonable prior notice to the other party.', fr: 'L\'obligation de confidentialité est <strong>réciproque</strong>. Chaque partie s\'engage à garder confidentielles les informations non publiques de l\'autre auxquelles elle accède dans le cadre du programme, y compris prix négociés, roadmap interne, métriques internes, données personnelles et commerciales des clients, listes de leads, supports de formation, remises spéciales et toute information commerciale sensible. Cette obligation subsiste pendant <strong>trois (3) ans</strong> à compter de la résiliation de l\'accord. Sont exclues les informations qui (i) sont du domaine public sans faute de la partie réceptrice, (ii) étaient déjà connues sans obligation de confidentialité, ou (iii) sont divulguées sur réquisition légale avec préavis raisonnable à l\'autre partie.', it: 'L\'obbligo di riservatezza è <strong>reciproco</strong>. Ciascuna parte si impegna a mantenere riservate le informazioni non pubbliche dell\'altra a cui acceda nell\'ambito del programma, inclusi prezzi negoziati, roadmap interna, metriche interne, dati personali e commerciali dei clienti, elenchi di lead, materiali formativi, sconti speciali e qualsiasi informazione commerciale sensibile. Questo obbligo sopravvive per <strong>tre (3) anni</strong> dalla risoluzione dell\'accordo. Sono escluse le informazioni che (i) sono di dominio pubblico senza colpa della parte ricevente, (ii) erano già note senza obbligo di riservatezza, o (iii) vengono rivelate per requisito legale con preavviso ragionevole all\'altra parte.', pt: 'A obrigação de confidencialidade é <strong>recíproca</strong>. Cada parte se obriga a manter confidencial a informação não pública da outra à qual tenha acesso por ocasião do programa, incluindo preços negociados, roadmap interno, métricas internas, dados pessoais e comerciais de clientes, listas de leads, materiais de capacitação, descontos especiais e qualquer informação comercial sensível. Esta obrigação subsiste por <strong>três (3) anos</strong> contados da terminação do acordo. Ficam excluídas as informações que (i) sejam de domínio público sem culpa da parte receptora, (ii) já fossem conhecidas previamente sem obrigação de confidencialidade, ou (iii) sejam reveladas por requerimento legal com aviso prévio razoável à outra parte.' },

  'ct.h12': { es: '12. No representación legal', en: '12. No legal representation', fr: '12. Absence de représentation légale', it: '12. Assenza di rappresentanza legale', pt: '12. Não representação legal' },
  'ct.p12': { es: 'El Partner es un colaborador independiente y <strong>no es agente, empleado, socio ni representante legal de SACS</strong>. El Partner no podrá: (i) firmar contratos, cotizaciones u órdenes de compra en nombre de SACS, (ii) comprometer a SACS frente a terceros sobre precios, descuentos, plazos de entrega, roadmap, garantías o condiciones que no estén explícitamente publicadas, (iii) abrir cuentas bancarias, registrar marcas o tomar decisiones legales en nombre de SACS, ni (iv) hacer afirmaciones que sugieran que actúa con autoridad jurídica de SACS. Cualquier contratación se cierra siempre directamente entre SACS y el cliente final.', en: 'The Partner is an independent collaborator and <strong>is not an agent, employee, partner or legal representative of SACS</strong>. The Partner may not: (i) sign contracts, quotes or purchase orders on behalf of SACS, (ii) bind SACS toward third parties regarding prices, discounts, delivery terms, roadmap, warranties or conditions not explicitly published, (iii) open bank accounts, register trademarks or make legal decisions on behalf of SACS, nor (iv) make statements suggesting they act with SACS\'s legal authority. Any contracting is always closed directly between SACS and the end client.', fr: 'Le Partenaire est un collaborateur indépendant et <strong>n\'est ni agent, ni employé, ni associé, ni représentant légal de SACS</strong>. Le Partenaire ne peut pas : (i) signer de contrats, devis ou bons de commande au nom de SACS, (ii) engager SACS auprès de tiers sur des prix, remises, délais de livraison, roadmap, garanties ou conditions non explicitement publiées, (iii) ouvrir des comptes bancaires, enregistrer des marques ou prendre des décisions juridiques au nom de SACS, ni (iv) faire de déclarations suggérant qu\'il agit avec l\'autorité juridique de SACS. Toute contractualisation est toujours conclue directement entre SACS et le client final.', it: 'Il Partner è un collaboratore indipendente e <strong>non è agente, dipendente, socio né rappresentante legale di SACS</strong>. Il Partner non potrà: (i) firmare contratti, preventivi o ordini di acquisto a nome di SACS, (ii) impegnare SACS verso terzi su prezzi, sconti, tempi di consegna, roadmap, garanzie o condizioni non esplicitamente pubblicate, (iii) aprire conti bancari, registrare marchi o prendere decisioni legali a nome di SACS, né (iv) fare affermazioni che suggeriscano di agire con autorità giuridica di SACS. Qualsiasi contrattazione si chiude sempre direttamente tra SACS e il cliente finale.', pt: 'O Parceiro é um colaborador independente e <strong>não é agente, empregado, sócio nem representante legal da SACS</strong>. O Parceiro não poderá: (i) assinar contratos, orçamentos ou ordens de compra em nome da SACS, (ii) comprometer a SACS perante terceiros sobre preços, descontos, prazos de entrega, roadmap, garantias ou condições que não estejam explicitamente publicadas, (iii) abrir contas bancárias, registrar marcas ou tomar decisões legais em nome da SACS, nem (iv) fazer afirmações que sugiram que age com autoridade jurídica da SACS. Qualquer contratação se fecha sempre diretamente entre a SACS e o cliente final.' },

  'ct.h13': { es: '13. No-competencia limitada', en: '13. Limited non-compete', fr: '13. Non-concurrence limitée', it: '13. Non concorrenza limitata', pt: '13. Não-concorrência limitada' },
  'ct.p13': { es: 'Durante la vigencia del acuerdo y por un periodo de <strong>seis (6) meses</strong> posteriores a su terminación por cualquier causa, el Partner se obliga a no recomendar, promover ni canalizar activamente hacia productos competidores directos de SACS (definidos como POS o sistemas de gestión integral de retail con cobertura LATAM equivalente) a aquellos clientes que el Partner haya referido a SACS bajo este programa. Esta obligación no impide al Partner trabajar con dichas plataformas para otros clientes ni desempeñar consultoría general en su sector.', en: 'During the term of the agreement and for a period of <strong>six (6) months</strong> after its termination for any cause, the Partner undertakes not to recommend, promote or actively channel toward direct competitors of SACS (defined as POS or integrated retail management systems with equivalent LATAM coverage) those clients that the Partner referred to SACS under this program. This obligation does not prevent the Partner from working with such platforms for other clients or performing general consulting in their sector.', fr: 'Pendant la durée de l\'accord et pour une période de <strong>six (6) mois</strong> suivant sa résiliation pour quelque cause que ce soit, le Partenaire s\'engage à ne pas recommander, promouvoir ni canaliser activement vers des produits concurrents directs de SACS (définis comme POS ou systèmes de gestion intégrale de retail à couverture LATAM équivalente) les clients que le Partenaire a référés à SACS dans le cadre de ce programme. Cette obligation n\'empêche pas le Partenaire de travailler avec ces plateformes pour d\'autres clients ni d\'exercer un conseil général dans son secteur.', it: 'Durante la vigenza dell\'accordo e per un periodo di <strong>sei (6) mesi</strong> successivi alla sua risoluzione per qualsiasi causa, il Partner si obbliga a non raccomandare, promuovere né indirizzare attivamente verso prodotti concorrenti diretti di SACS (definiti come POS o sistemi di gestione integrale di retail con copertura LATAM equivalente) quei clienti che il Partner ha riferito a SACS sotto questo programma. Questo obbligo non impedisce al Partner di lavorare con tali piattaforme per altri clienti né di svolgere consulenza generale nel suo settore.', pt: 'Durante a vigência do acordo e por um período de <strong>seis (6) meses</strong> posteriores à sua terminação por qualquer causa, o Parceiro se obriga a não recomendar, promover nem canalizar ativamente para produtos concorrentes diretos da SACS (definidos como POS ou sistemas de gestão integral de varejo com cobertura LATAM equivalente) aqueles clientes que o Parceiro tenha referido à SACS sob este programa. Esta obrigação não impede o Parceiro de trabalhar com tais plataformas para outros clientes nem de prestar consultoria geral em seu setor.' },

  'ct.h14': { es: '14. Indemnización', en: '14. Indemnification', fr: '14. Indemnisation', it: '14. Manleva', pt: '14. Indenização' },
  'ct.p14': { es: 'El Partner indemnizará y mantendrá libre de daños a SACS, sus funcionarios, empleados y afiliados frente a cualquier reclamación, pérdida, gasto razonable de defensa o sanción derivados de (i) declaraciones falsas, garantías de resultados o promociones engañosas hechas por el Partner sobre SACS, (ii) servicios prestados al cliente final por el Partner que excedan el alcance de su certificación o de este acuerdo, (iii) violación por parte del Partner de las cláusulas de confidencialidad, propiedad intelectual o no representación, y (iv) incumplimiento de obligaciones fiscales o laborales del Partner en su jurisdicción.', en: 'The Partner shall indemnify and hold SACS, its officers, employees and affiliates harmless from any claim, loss, reasonable defense expense or penalty arising from (i) false statements, results guarantees or misleading promotions made by the Partner about SACS, (ii) services rendered to the end client by the Partner that exceed the scope of their certification or this agreement, (iii) breach by the Partner of the confidentiality, intellectual property or non-representation clauses, and (iv) failure to comply with the Partner\'s tax or labor obligations in their jurisdiction.', fr: 'Le Partenaire indemnisera et maintiendra SACS, ses dirigeants, employés et affiliés indemnes de toute réclamation, perte, frais raisonnables de défense ou sanction découlant de (i) déclarations fausses, garanties de résultats ou promotions trompeuses faites par le Partenaire sur SACS, (ii) services rendus au client final par le Partenaire qui dépassent le périmètre de sa certification ou du présent accord, (iii) violation par le Partenaire des clauses de confidentialité, propriété intellectuelle ou non-représentation, et (iv) manquement aux obligations fiscales ou de travail du Partenaire dans sa juridiction.', it: 'Il Partner manleverà e terrà indenni SACS, i suoi funzionari, dipendenti e affiliati da qualsiasi pretesa, perdita, spesa ragionevole di difesa o sanzione derivanti da (i) affermazioni false, garanzie di risultati o promozioni ingannevoli fatte dal Partner su SACS, (ii) servizi prestati al cliente finale dal Partner che eccedano l\'ambito della sua certificazione o del presente accordo, (iii) violazione da parte del Partner delle clausole di riservatezza, proprietà intellettuale o non rappresentanza, e (iv) inadempimento di obblighi fiscali o lavorativi del Partner nella sua giurisdizione.', pt: 'O Parceiro indenizará e manterá livres de danos a SACS, seus diretores, empregados e afiliados perante qualquer reclamação, perda, despesa razoável de defesa ou sanção derivados de (i) declarações falsas, garantias de resultados ou promoções enganosas feitas pelo Parceiro sobre a SACS, (ii) serviços prestados ao cliente final pelo Parceiro que excedam o alcance de sua certificação ou deste acordo, (iii) violação pelo Parceiro das cláusulas de confidencialidade, propriedade intelectual ou não representação, e (iv) descumprimento de obrigações fiscais ou trabalhistas do Parceiro em sua jurisdição.' },

  'ct.h15': { es: '15. Modificaciones del programa', en: '15. Program modifications', fr: '15. Modifications du programme', it: '15. Modifiche al programma', pt: '15. Modificações do programa' },
  'ct.p15': { es: 'SACS podrá ajustar el catálogo de actividades, los puntos asignados, los porcentajes de comisión, los bonos, las certificaciones disponibles y demás reglas operativas del programa, dando aviso por escrito al Partner con al menos <strong>sesenta (60) días naturales</strong> de antelación a la fecha de entrada en vigor. Durante ese periodo el Partner podrá optar por terminar el acuerdo conforme a la cláusula 16 sin penalización. Las comisiones <em>earned</em> antes de la entrada en vigor de la modificación se respetan en sus términos originales.', en: 'SACS may adjust the activities catalog, assigned points, commission percentages, bonuses, available certifications and other operational rules of the program, with written notice to the Partner at least <strong>sixty (60) natural days</strong> before the effective date. During that period the Partner may choose to terminate the agreement per clause 16 without penalty. Commissions <em>earned</em> before the modification\'s effective date are respected on their original terms.', fr: 'SACS pourra ajuster le catalogue d\'activités, les points attribués, les pourcentages de commission, les bonus, les certifications disponibles et les autres règles opérationnelles du programme, avec un préavis écrit au Partenaire d\'au moins <strong>soixante (60) jours calendaires</strong> avant la date d\'entrée en vigueur. Durant cette période, le Partenaire pourra opter pour résilier l\'accord selon la clause 16 sans pénalité. Les commissions <em>earned</em> avant la date d\'entrée en vigueur de la modification sont respectées dans leurs conditions d\'origine.', it: 'SACS potrà modificare il catalogo delle attività, i punti assegnati, le percentuali di commissione, i bonus, le certificazioni disponibili e altre regole operative del programma, con preavviso scritto al Partner di almeno <strong>sessanta (60) giorni naturali</strong> prima della data di entrata in vigore. Durante tale periodo il Partner potrà scegliere di terminare l\'accordo secondo la clausola 16 senza penalità. Le commissioni <em>earned</em> prima della data di entrata in vigore della modifica sono rispettate nelle loro condizioni originali.', pt: 'A SACS poderá ajustar o catálogo de atividades, os pontos atribuídos, os percentuais de comissão, os bônus, as certificações disponíveis e demais regras operacionais do programa, com aviso por escrito ao Parceiro de pelo menos <strong>sessenta (60) dias corridos</strong> antes da data de entrada em vigor. Durante esse período o Parceiro poderá optar por terminar o acordo conforme a cláusula 16 sem penalidade. As comissões <em>earned</em> antes da entrada em vigor da modificação são respeitadas em seus termos originais.' },

  'ct.h16': { es: '16. Vigencia y rescisión', en: '16. Term and termination', fr: '16. Durée et résiliation', it: '16. Durata e risoluzione', pt: '16. Vigência e rescisão' },
  'ct.p16': { es: 'Este acuerdo tiene una vigencia inicial de <strong>12 meses</strong> a partir de la fecha de firma, renovable automáticamente por periodos sucesivos del mismo plazo. Cualquiera de las partes puede dar por terminado el acuerdo con <strong>30 días naturales de aviso por escrito</strong>, sin necesidad de causa. SACS puede dar por terminado el acuerdo de inmediato en caso de actualización de cualquiera de las causales de la cláusula 6 (suspensión y baja).', en: 'This agreement has an initial term of <strong>12 months</strong> from the signature date, automatically renewable for successive periods of the same length. Either party may terminate the agreement with <strong>30 natural days written notice</strong>, without cause. SACS may terminate the agreement immediately upon the occurrence of any of the events in clause 6 (suspension and removal).', fr: 'Cet accord a une durée initiale de <strong>12 mois</strong> à compter de la date de signature, renouvelable automatiquement par périodes successives de même durée. Chaque partie peut mettre fin à l\'accord avec <strong>30 jours calendaires de préavis écrit</strong>, sans cause. SACS peut résilier immédiatement en cas de survenance de l\'un des motifs de la clause 6 (suspension et exclusion).', it: 'Questo accordo ha una durata iniziale di <strong>12 mesi</strong> dalla data di firma, rinnovabile automaticamente per periodi successivi di pari durata. Ciascuna parte può risolvere l\'accordo con <strong>30 giorni naturali di preavviso scritto</strong>, senza causa. SACS può risolvere immediatamente al verificarsi di una qualsiasi delle situazioni della clausola 6 (sospensione e rimozione).', pt: 'Este acordo tem vigência inicial de <strong>12 meses</strong> a partir da data de assinatura, renovável automaticamente por períodos sucessivos do mesmo prazo. Qualquer parte pode dar por encerrado o acordo com <strong>30 dias corridos de aviso por escrito</strong>, sem necessidade de causa. A SACS pode dar por encerrado o acordo imediatamente em caso de verificação de qualquer das causas da cláusula 6 (suspensão e baixa).' },

  // Cláusula 16-bis (intermedia) · Expansión de red de partner
  'ct.h16b': { es: '16-bis. Expansión de red de partner (Master Partner)', en: '16-bis. Partner network expansion (Master Partner)', fr: '16-bis. Expansion du réseau partenaire (Master Partner)', it: '16-bis. Espansione della rete partner (Master Partner)', pt: '16-bis. Expansão da rede de parceiros (Master Partner)' },
  'ct.p16b.intro': { es: 'Una vez que el Partner haya cerrado el número de sucursales activas que se indican abajo, SACS le concede el derecho de invitar nuevos partners a la red, dentro de los topes correspondientes:', en: 'Once the Partner has closed the number of active stores indicated below, SACS grants them the right to invite new partners into the network, within the corresponding caps:', fr: 'Une fois que le Partenaire aura conclu le nombre de boutiques actives indiqué ci-dessous, SACS lui accorde le droit d\'inviter de nouveaux partenaires dans le réseau, dans les limites correspondantes :', it: 'Una volta che il Partner abbia chiuso il numero di negozi attivi indicato sotto, SACS gli concede il diritto di invitare nuovi partner nella rete, entro i limiti corrispondenti:', pt: 'Uma vez que o Parceiro tenha fechado o número de lojas ativas indicado abaixo, a SACS lhe concede o direito de convidar novos parceiros à rede, dentro dos tetos correspondentes:' },
  'ct.p16b.t1': { es: '<strong>5 sucursales activas → Master Partner Nv 1</strong> (5 invitaciones)', en: '<strong>5 active stores → Master Partner Nv 1</strong> (5 invitations)', fr: '<strong>5 boutiques actives → Master Partner Nv 1</strong> (5 invitations)', it: '<strong>5 negozi attivi → Master Partner Nv 1</strong> (5 inviti)', pt: '<strong>5 lojas ativas → Master Partner Nv 1</strong> (5 convites)' },
  'ct.p16b.t2': { es: '<strong>10 sucursales activas → Master Partner Nv 2</strong> (10 invitaciones)', en: '<strong>10 active stores → Master Partner Nv 2</strong> (10 invitations)', fr: '<strong>10 boutiques actives → Master Partner Nv 2</strong> (10 invitations)', it: '<strong>10 negozi attivi → Master Partner Nv 2</strong> (10 inviti)', pt: '<strong>10 lojas ativas → Master Partner Nv 2</strong> (10 convites)' },
  'ct.p16b.t3': { es: '<strong>20 sucursales activas → Master Partner Nv 3</strong> (20 invitaciones)', en: '<strong>20 active stores → Master Partner Nv 3</strong> (20 invitations)', fr: '<strong>20 boutiques actives → Master Partner Nv 3</strong> (20 invitations)', it: '<strong>20 negozi attivi → Master Partner Nv 3</strong> (20 inviti)', pt: '<strong>20 lojas ativas → Master Partner Nv 3</strong> (20 convites)' },
  'ct.p16b.t4': { es: '<strong>50+ sucursales activas → Master Partner Nv 4</strong> (invitaciones ilimitadas; sostenido 12 meses abre Nivel 04 · Founder Circle)', en: '<strong>50+ active stores → Master Partner Nv 4</strong> (unlimited invitations; sustained 12 months unlocks Level 04 · Founder Circle)', fr: '<strong>50+ boutiques actives → Master Partner Nv 4</strong> (invitations illimitées ; maintenu 12 mois ouvre Niveau 04 · Founder Circle)', it: '<strong>50+ negozi attivi → Master Partner Nv 4</strong> (inviti illimitati; sostenuto 12 mesi apre Livello 04 · Founder Circle)', pt: '<strong>50+ lojas ativas → Master Partner Nv 4</strong> (convites ilimitados; sustentado 12 meses abre Nível 04 · Founder Circle)' },
  'ct.p16b.outro': { es: 'Cada partner invitado firma su propio acuerdo y cumple sus propios compromisos. El Partner invitado <strong>conserva íntegro el 50% de comisión directa</strong> sobre las ventas que cierra. El Partner inviter recibe adicional un <strong>comisión del 10% sobre el cobro de cada cliente que su red venda</strong> — pagado por SACS, sin descontar nada de la comisión del invitado. Este override aplica mientras (i) el Partner inviter mantenga su estatus activo en el programa, (ii) el partner invitado mantenga su estatus activo, y (iii) el cliente referido permanezca activo y al corriente. El Partner inviter es responsable del primer onboarding del invitado y de mantener el estándar de marca dentro de su red. SACS revisa y valida cada invitación antes de activarla y se reserva el derecho de rechazar invitados que no encajen con el programa o las políticas de marca.', en: 'Each invited partner signs their own agreement and meets their own commitments. The invited Partner <strong>keeps their full 50% direct commission</strong> on the sales they close. The inviting Partner additionally receives a <strong>10% override on the charge of every client their network sells</strong> — paid by SACS, with nothing deducted from the invitee\'s commission. This override applies while (i) the inviting Partner maintains active status in the program, (ii) the invited partner maintains active status, and (iii) the referred client remains active and current. The inviting Partner is responsible for the first onboarding of the invitee and for upholding the brand standard within their network. SACS reviews and validates each invitation before activation and reserves the right to decline invitees who do not fit the program or brand policies.', fr: 'Chaque partenaire invité signe son propre accord et respecte ses propres engagements. Le Partenaire invité <strong>conserve intégralement sa commission directe de 50%</strong> sur les ventes qu\'il conclut. Le Partenaire inviteur reçoit en plus un <strong>override de 10% sur la facturation de chaque client que son réseau vend</strong> — payé par SACS, sans rien déduire de la commission de l\'invité. Cet override s\'applique tant que (i) le Partenaire inviteur conserve un statut actif dans le programme, (ii) le partenaire invité conserve un statut actif, et (iii) le client référé reste actif et à jour. Le Partenaire inviteur est responsable du premier onboarding de l\'invité et du maintien du standard de marque au sein de son réseau. SACS révise et valide chaque invitation avant son activation et se réserve le droit de refuser les invités qui ne correspondent pas au programme ou aux politiques de marque.', it: 'Ogni partner invitato firma il proprio accordo e rispetta i propri impegni. Il Partner invitato <strong>mantiene integra la sua commissione diretta del 50%</strong> sulle vendite che chiude. Il Partner invitante riceve in più un <strong>comisión del 10% sull\'addebito di ogni cliente che la sua rete vende</strong> — pagato da SACS, senza scalare nulla dalla commissione dell\'invitato. Questo override si applica finché (i) il Partner invitante mantiene lo stato attivo nel programma, (ii) il partner invitato mantiene lo stato attivo, e (iii) il cliente riferito rimane attivo e in regola. Il Partner invitante è responsabile del primo onboarding dell\'invitato e del mantenimento dello standard di marchio all\'interno della sua rete. SACS revisiona e convalida ogni invito prima dell\'attivazione e si riserva il diritto di rifiutare invitati che non si adattano al programma o alle politiche di marchio.', pt: 'Cada parceiro convidado assina seu próprio acordo e cumpre seus próprios compromissos. O Parceiro convidado <strong>mantém íntegra sua comissão direta de 50%</strong> sobre as vendas que fecha. O Parceiro convidante recebe adicional um <strong>override de 10% sobre a cobrança de cada cliente que sua rede vende</strong> — pago pela SACS, sem descontar nada da comissão do convidado. Este override aplica enquanto (i) o Parceiro convidante mantiver status ativo no programa, (ii) o parceiro convidado mantiver status ativo, e (iii) o cliente referenciado permanecer ativo e em dia. O Parceiro convidante é responsável pelo primeiro onboarding do convidado e pela manutenção do padrão de marca dentro de sua rede. A SACS revisa e valida cada convite antes da ativação e se reserva o direito de rejeitar convidados que não se encaixem no programa ou nas políticas de marca.' },

  'ct.h17': { es: '17. Resolución de disputas y fuerza mayor', en: '17. Dispute resolution and force majeure', fr: '17. Résolution des litiges et force majeure', it: '17. Risoluzione delle controversie e forza maggiore', pt: '17. Resolução de disputas e força maior' },
  'ct.p17': { es: '<strong>Resolución amistosa.</strong> Las partes intentarán resolver de buena fe cualquier desacuerdo durante un periodo mínimo de <strong>treinta (30) días naturales</strong> antes de iniciar acción judicial, mediante reunión documentada del founder de SACS y el Partner. Si no se alcanza acuerdo, las partes se someten a la jurisdicción de los tribunales competentes de la <strong>Ciudad de México</strong>, renunciando a cualquier otro fuero que pudiera corresponderles.<br/><br/><strong>Fuerza mayor.</strong> Ninguna de las partes será responsable por el incumplimiento total o parcial de sus obligaciones cuando éste se deba a caso fortuito o fuerza mayor (desastres naturales, conflictos armados, decisiones gubernamentales, interrupciones generalizadas de internet o energía eléctrica), debiendo notificar a la otra parte tan pronto sea razonablemente posible y restablecer el cumplimiento al cesar la causa.', en: '<strong>Amicable resolution.</strong> The parties will attempt to resolve any disagreement in good faith for a minimum period of <strong>thirty (30) natural days</strong> before initiating legal action, through a documented meeting between SACS\'s founder and the Partner. If no agreement is reached, the parties submit to the jurisdiction of the competent courts of <strong>Mexico City</strong>, waiving any other jurisdiction that might apply.<br/><br/><strong>Force majeure.</strong> Neither party shall be liable for total or partial breach of obligations when due to act of God or force majeure (natural disasters, armed conflicts, governmental decisions, generalized internet or power outages), being required to notify the other party as soon as reasonably possible and to resume performance when the cause ceases.', fr: '<strong>Résolution amiable.</strong> Les parties tenteront de résoudre tout désaccord de bonne foi pendant une période minimale de <strong>trente (30) jours calendaires</strong> avant toute action en justice, par une réunion documentée entre le founder de SACS et le Partenaire. À défaut d\'accord, les parties se soumettent à la juridiction des tribunaux compétents de <strong>Mexico City</strong>, renonçant à tout autre for qui pourrait leur revenir.<br/><br/><strong>Force majeure.</strong> Aucune des parties ne sera responsable de l\'inexécution totale ou partielle de ses obligations en cas de force majeure (catastrophes naturelles, conflits armés, décisions gouvernementales, interruptions généralisées d\'internet ou d\'énergie), devant en notifier l\'autre partie dès que raisonnablement possible et reprendre l\'exécution dès la cessation de la cause.', it: '<strong>Risoluzione amichevole.</strong> Le parti cercheranno di risolvere in buona fede qualsiasi disaccordo per un periodo minimo di <strong>trenta (30) giorni naturali</strong> prima di intraprendere azione legale, mediante riunione documentata tra il founder di SACS e il Partner. In assenza di accordo, le parti si sottopongono alla giurisdizione dei tribunali competenti di <strong>Città del Messico</strong>, rinunciando a qualsiasi altro foro che potesse essere competente.<br/><br/><strong>Forza maggiore.</strong> Nessuna delle parti sarà responsabile per l\'inadempimento totale o parziale degli obblighi quando dovuto a caso fortuito o forza maggiore (disastri naturali, conflitti armati, decisioni governative, interruzioni generalizzate di internet o di energia elettrica), dovendo notificare all\'altra parte appena ragionevolmente possibile e ripristinare l\'adempimento al cessare della causa.', pt: '<strong>Resolução amigável.</strong> As partes tentarão resolver qualquer desacordo de boa-fé durante um período mínimo de <strong>trinta (30) dias corridos</strong> antes de iniciar ação judicial, por meio de reunião documentada entre o founder da SACS e o Parceiro. Não havendo acordo, as partes se submetem à jurisdição dos tribunais competentes da <strong>Cidade do México</strong>, renunciando a qualquer outro foro que possa lhes corresponder.<br/><br/><strong>Força maior.</strong> Nenhuma das partes será responsável pelo descumprimento total ou parcial de suas obrigações quando este se deva a caso fortuito ou força maior (desastres naturais, conflitos armados, decisões governamentais, interrupções generalizadas de internet ou energia elétrica), devendo notificar à outra parte tão logo seja razoavelmente possível e restabelecer o cumprimento ao cessar a causa.' },

  'ct.h18': { es: '18. Datos y privacidad', en: '18. Data and privacy', fr: '18. Données et confidentialité', it: '18. Dati e privacy', pt: '18. Dados e privacidade' },
  'ct.p18': { es: 'El Partner autoriza a SACS a procesar sus datos personales para los fines del programa, conforme al <a href="/privacidad" target="_blank" rel="noopener">Aviso de Privacidad</a>. Esto incluye: enviar comunicaciones del programa, mostrar el nombre/foto del Partner en su landing pública, y compartir métricas internas con el equipo SACS. SACS mantiene los datos del Partner por el tiempo necesario para los fines descritos y no los compartirá con terceros sin consentimiento expreso, salvo cuando sea legalmente exigible.', en: 'The Partner authorizes SACS to process their personal data for the program\'s purposes, in accordance with the <a href="/privacidad" target="_blank" rel="noopener">Privacy Notice</a>. This includes: sending program communications, displaying the Partner\'s name/photo on their public landing, and sharing internal metrics with the SACS team. SACS retains the Partner\'s data for the time necessary for the described purposes and will not share it with third parties without express consent, except when legally required.', fr: 'Le Partenaire autorise SACS à traiter ses données personnelles aux fins du programme, conformément à l\'<a href="/privacidad" target="_blank" rel="noopener">Avis de Confidentialité</a>. Cela inclut : envoyer les communications du programme, afficher le nom/photo du Partenaire sur sa landing publique et partager les métriques internes avec l\'équipe SACS. SACS conserve les données du Partenaire pendant la durée nécessaire aux fins décrites et ne les partagera pas avec des tiers sans consentement exprès, sauf exigence légale.', it: 'Il Partner autorizza SACS a trattare i suoi dati personali per le finalità del programma, in conformità all\'<a href="/privacidad" target="_blank" rel="noopener">Informativa Privacy</a>. Include: invio delle comunicazioni del programma, mostrare nome/foto del Partner sulla landing pubblica e condividere metriche interne con il team SACS. SACS conserva i dati del Partner per il tempo necessario alle finalità descritte e non li condividerà con terzi senza consenso espresso, salvo quando legalmente richiesto.', pt: 'O Parceiro autoriza a SACS a processar seus dados pessoais para os fins do programa, conforme o <a href="/privacidad" target="_blank" rel="noopener">Aviso de Privacidade</a>. Inclui: envio de comunicações do programa, exibição do nome/foto do Parceiro em sua landing pública e compartilhamento de métricas internas com a equipe SACS. A SACS mantém os dados do Parceiro pelo tempo necessário aos fins descritos e não os compartilhará com terceiros sem consentimento expresso, salvo quando legalmente exigido.' },

  'ct.h19': { es: '19. Aceptación', en: '19. Acceptance', fr: '19. Acceptation', it: '19. Accettazione', pt: '19. Aceitação' },
  'ct.p19': { es: 'Al firmar al final de este documento, el Partner declara que ha leído íntegramente este acuerdo, que entiende las condiciones de compensación, compromisos, suspensión, certificaciones, propiedad intelectual y demás cláusulas, y que acepta vincularse legalmente a las mismas. La firma electrónica tiene la misma validez que una firma autógrafa conforme a la NOM-151-SCFI-2016.', en: 'By signing at the end of this document, the Partner declares having fully read this agreement, understanding the conditions on compensation, commitments, suspension, certifications, intellectual property and other clauses, and accepting to be legally bound by them. The electronic signature has the same validity as a handwritten signature pursuant to NOM-151-SCFI-2016.', fr: 'En signant à la fin de ce document, le Partenaire déclare avoir lu intégralement cet accord, comprendre les conditions de rémunération, engagements, suspension, certifications, propriété intellectuelle et autres clauses, et accepter d\'y être légalement lié. La signature électronique a la même validité qu\'une signature manuscrite conformément à NOM-151-SCFI-2016.', it: 'Firmando alla fine di questo documento, il Partner dichiara di aver letto integralmente questo accordo, di comprendere le condizioni di compenso, impegni, sospensione, certificazioni, proprietà intellettuale e altre clausole, e di accettare di esserne legalmente vincolato. La firma elettronica ha la stessa validità di una firma autografa ai sensi della NOM-151-SCFI-2016.', pt: 'Ao assinar ao final deste documento, o Parceiro declara ter lido integralmente este acordo, entender as condições de remuneração, compromissos, suspensão, certificações, propriedade intelectual e demais cláusulas, e aceitar vincular-se legalmente a elas. A assinatura eletrônica tem a mesma validade de uma assinatura autógrafa conforme a NOM-151-SCFI-2016.' },
  'ct.accept': { es: 'He leído íntegramente este contrato y acepto sus términos.', en: 'I have fully read this contract and accept its terms.', fr: 'J\'ai lu intégralement ce contrat et j\'accepte ses conditions.', it: 'Ho letto integralmente questo contratto e accetto i suoi termini.', pt: 'Li integralmente este contrato e aceito seus termos.' },
  'ct.preview.eyebrow': { es: 'Condiciones generales', en: 'General conditions', fr: 'Conditions générales', it: 'Condizioni generali', pt: 'Condições gerais' },
  'ct.preview.title':   { es: 'Programa Embajador SACS — Términos y Condiciones', en: 'SACS Ambassador Program — Terms and Conditions', fr: 'Programme Ambassadeur SACS — Conditions générales', it: 'Programma Ambasciatori SACS — Termini e Condizioni', pt: 'Programa Embaixador SACS — Termos e Condições' },
  'ct.preview.note':    { es: 'El acuerdo formal completo: 19 cláusulas que cubren compensación, pagos, certificaciones, suspensión, conducta y propiedad intelectual. Lo firmas al final del proceso.', en: 'The full formal agreement: 19 clauses covering compensation, payments, certifications, suspension, conduct and intellectual property. You sign it at the end of the process.', fr: "L'accord formel complet : 19 clauses couvrant rémunération, paiements, certifications, suspension, conduite et propriété intellectuelle. Vous le signez à la fin du processus.", it: "L'accordo formale completo: 19 clausole che coprono compenso, pagamenti, certificazioni, sospensione, condotta e proprietà intellettuale. Lo firmi alla fine del processo.", pt: 'O acordo formal completo: 19 cláusulas que cobrem remuneração, pagamentos, certificações, suspensão, conduta e propriedade intelectual. Você o assina ao final do processo.' },
  'ct.preview.cta':     { es: 'Ver términos completos', en: 'View full terms', fr: 'Voir les conditions complètes', it: 'Vedi i termini completi', pt: 'Ver termos completos' },
  'ct.preview.extra':   { es: 'Cláusulas adicionales para esta invitación', en: 'Additional clauses for this invitation', fr: 'Clauses supplémentaires pour cette invitation', it: 'Clausole aggiuntive per questo invito', pt: 'Cláusulas adicionais para este convite' },
  'ct.modal.close':     { es: 'Cerrar', en: 'Close', fr: 'Fermer', it: 'Chiudi', pt: 'Fechar' },
  'ct.modal.lang':      { es: 'Versión vigente · español', en: 'Active version · {lang_label}', fr: 'Version active · {lang_label}', it: 'Versione attiva · {lang_label}', pt: 'Versão ativa · {lang_label}' },
};

function tt(key: string): string {
  return I18N[key]?.[lang] || I18N[key]?.es || key;
}

// Lista de fotos reales de partners (de /public/images/partner-wall/).
// Distribución: 50% nómadas/casa/café · 30% influencers · 10% comerciantes · 10% empresarios.
// Usamos fs.readdirSync una vez al request — es < 1ms y evita hardcoding.
let PARTNER_PHOTOS: string[] = [];
try {
  const dir = path.join(process.cwd(), 'public/images/partner-wall');
  PARTNER_PHOTOS = fs.readdirSync(dir)
    .filter(f => f.endsWith('.webp'))
    .sort();
} catch { /* en build sin acceso al fs, queda vacío */ }
import { businessSectors } from '../../../data/navigation';

const SECTOR_EMOJIS: Record<string, string> = {
  clothing: '👗',
  shoes: '👟',
  jewelry: '💎',
  entertainment: '🎮',
  stationery: '✏️',
  themepark: '🎢',
  electronics: '📱',
  phonecase: '📲',
  minisuper: '🛒',
  wine: '🍷',
  pharmacy: '💊',
  pet: '🐶',
  beauty: '💄',
  hardware: '🔧',
  toys: '🧸',
  florist: '💐',
};
const PRIORITY_SECTORS = businessSectors.slice(0, 16);

export const prerender = false;

const { id } = Astro.params;
const isAdminMode = Astro.url.searchParams.has('admin');

const { data: invitation } = await supabase
  .from('partner_invitations')
  .select('*')
  .eq('id', id)
  .maybeSingle();

if (!invitation) return Astro.redirect('/404');

// Auto-expire if vigencia passed
const isExpired = invitation.vigencia && new Date(invitation.vigencia) < new Date();
if (isExpired && invitation.estado === 'sent') {
  await supabase.from('partner_invitations').update({ estado: 'expired' }).eq('id', id);
  invitation.estado = 'expired';
}

// View tracking: incrementa view_count en cada apertura (no admin), dedup por
// cookie de sesión de 30 min para no inflar con refrescos. Captura primera
// apertura, última apertura y total de aperturas para el data table del CRM.
if (!isAdminMode) {
  const VIEW_COOKIE_KEY = `sacs_inv_seen_${id}`;
  const recentlySeen = Astro.cookies.get(VIEW_COOKIE_KEY)?.value === '1';
  if (!recentlySeen) {
    try {
      const now = new Date().toISOString();
      const isFirst = !invitation.first_viewed_at;
      await supabase
        .from('partner_invitations')
        .update({
          view_count: (Number(invitation.view_count) || 0) + 1,
          last_viewed_at: now,
          ...(isFirst ? { first_viewed_at: now } : {}),
        })
        .eq('id', id);
      // También insertamos activity solo en la PRIMERA apertura para no spammear
      if (isFirst && invitation.estado === 'sent') {
        await supabase.from('activities').insert({
          tipo: 'sistema',
          titulo: `Invitación de partner abierta por primera vez`,
          metadata: { partner_invitation_id: id, partner_invitation_numero: invitation.numero },
          automatico: true,
        });
      }
    } catch {}
    // Cookie 30 min — dedup contra refrescos pero registra revisitas reales
    Astro.cookies.set(VIEW_COOKIE_KEY, '1', { path: '/', maxAge: 60 * 30, sameSite: 'lax' });
  }
}

// Parse meta from notas (firma_base64 etc.)
const NOTAS_SEP = '\n---META---\n';
const notasIdx = (invitation.notas || '').indexOf(NOTAS_SEP);
const meta = notasIdx >= 0 ? (() => {
  try { return JSON.parse(invitation.notas.slice(notasIdx + NOTAS_SEP.length)); } catch { return {}; }
})() : {};

const template = invitation.template || 'modern';
const tipo = invitation.tipo || 'embajador';
const moneda = invitation.moneda || 'MXN';
const comisionPct = Number(invitation.comision_pct ?? 50);
const costoUnico = Number(invitation.costo_unico ?? 0);
const costoMensual = Number(invitation.costo_mensual ?? 0);

// ─── Cobro de entrada al programa (configurable por invitación) ───
// Si el admin define un costo único > 0, la invitación deja de ser "gratis"
// y pasa a ser "de cobro": las frases narrativas de COSTO DE ENTRADA se
// sustituyen por el monto, en los 5 idiomas. NO se tocan (siguen como están):
//   · el trial gratis del CLIENTE ("prueba gratis" / 14 días) y sus bonos,
//   · la cuenta Fideliza ($14k/año), que sigue siendo beneficio gratis,
//   · las herramientas/soporte incluidos.
// Los displays estructurados (hero stat "Cuota única" y la sección de costos)
// ya son condicionales sobre costoUnico, así que solo hay que reescribir el
// texto narrativo que afirma que el programa es gratis.
const esDeCobro = costoUnico > 0;
const costoEntradaStr = esDeCobro ? fmtLocalMoney(costoUnico) : '';
if (esDeCobro) {
  const m = costoEntradaStr;
  I18N['tldr.l4'] = {
    es: `Inversión única de ${m} para participar en el programa. Plan Fideliza ($14k/año) gratis para que uses SACS en tu negocio.`,
    en: `One-time investment of ${m} to join the program. Fideliza Plan ($14k/year value) free for you to use SACS in your own business.`,
    fr: `Investissement unique de ${m} pour rejoindre le programme. Plan Fideliza (14k$/an) gratuit pour utiliser SACS dans votre entreprise.`,
    it: `Investimento una tantum di ${m} per partecipare al programma. Piano Fideliza ($14k/anno) gratis per usare SACS nella tua attività.`,
    pt: `Investimento único de ${m} para participar do programa. Plano Fideliza ($14k/ano) grátis para usar SACS no seu próprio negócio.`,
  };
  I18N['who.note'] = {
    es: `<strong>Mismo programa, mismas oportunidades, sin límite de crecimiento.</strong> Buscamos abrir puertas — no filtrar a quien ya tenía éxito. Donde sea que arranques, el programa tiene una inversión única de ${m} para participar, y cualquier camino te lleva a pagos cada 30 días, comisiones reales y la red de partners SACS detrás tuyo.`,
    en: `<strong>Same program, same opportunities, no ceiling on growth.</strong> We aim to open doors — not filter out those without prior success. Wherever you start, the program has a one-time investment of ${m} to join, and any path leads to payments every 30 days, real commissions and the SACS partner network behind you.`,
    fr: `<strong>Même programme, mêmes opportunités, sans plafond de croissance.</strong> Nous cherchons à ouvrir des portes — pas à filtrer ceux qui n'ont pas encore réussi. Où que vous démarriez, le programme requiert un investissement unique de ${m} pour participer, et tout chemin mène à des paiements tous les 30 jours, des commissions réelles et le réseau partenaires SACS derrière vous.`,
    it: `<strong>Stesso programma, stesse opportunità, senza tetto di crescita.</strong> Vogliamo aprire porte — non filtrare chi non ha ancora avuto successo. Da dove inizi non importa: il programma prevede un investimento una tantum di ${m} per partecipare, e ogni percorso ti porta a pagamenti ogni 30 giorni, commissioni reali e la rete dei partner SACS dietro di te.`,
    pt: `<strong>Mesmo programa, mesmas oportunidades, sem teto de crescimento.</strong> Buscamos abrir portas — não filtrar quem ainda não teve sucesso. De onde você começar, o programa tem um investimento único de ${m} para participar, e qualquer caminho leva a pagamentos a cada 30 dias, comissões reais e a rede de parceiros SACS atrás de você.`,
  };
  I18N['terms.g3.l'] = {
    es: `Lo que cuesta participar. Tu inversión única de inscripción es ${m} — transparente, sin letras chicas y sin cuotas escondidas.`,
    en: `What it costs to participate. Your one-time enrollment investment is ${m} — transparent, no fine print and no hidden fees.`,
    fr: `Ce que coûte la participation. Votre investissement unique d'inscription est de ${m} — transparent, sans petits caractères et sans frais cachés.`,
    it: `Quanto costa partecipare. Il tuo investimento una tantum di iscrizione è ${m} — trasparente, senza clausole in piccolo e senza costi nascosti.`,
    pt: `Quanto custa participar. Seu investimento único de inscrição é ${m} — transparente, sem letras miúdas e sem taxas escondidas.`,
  };
  I18N['faq.q4.a'] = {
    es: `Una inversión única de ${m} para participar en el programa. Incluye Plan Fideliza activo en tu cuenta SACS sin costo, materiales de marca, capacitaciones y soporte sin cargo. Solo si decides certificarte (opcional) hay una cuota única adicional que va de $7,500 a $21,000 MXN. Esa cert te permite cobrar servicios profesionales con el 100% del cobro para ti.`,
    en: `A one-time investment of ${m} to join the program. It includes the Fideliza Plan active in your SACS account at no cost, brand materials, training and support free of charge. Only if you choose to get certified (optional) is there an additional one-time fee from $7,500 to $21,000 MXN. That cert lets you charge professional services with 100% of the billing for you.`,
    fr: `Un investissement unique de ${m} pour rejoindre le programme. Il inclut le Plan Fideliza actif dans votre compte SACS sans frais, supports de marque, formations et accompagnement gratuits. Uniquement si vous choisissez de vous certifier (optionnel) il y a un paiement unique supplémentaire de 7 500 à 21 000 MXN. Cette certification vous permet de facturer des services professionnels avec 100% de la facturation pour vous.`,
    it: `Un investimento una tantum di ${m} per partecipare al programma. Include il Piano Fideliza attivo nel tuo account SACS senza costi, materiali di brand, formazione e supporto gratis. Solo se scegli di certificarti (opzionale) c'è una quota unica aggiuntiva da $7.500 a $21.000 MXN. Quella certificazione ti permette di fatturare servizi professionali con il 100% della fattura per te.`,
    pt: `Um investimento único de ${m} para participar do programa. Inclui o Plano Fideliza ativo na sua conta SACS sem custo, materiais de marca, capacitação e suporte sem cobrança. Só se você escolher se certificar (opcional) há uma taxa única adicional de $7.500 a $21.000 MXN. Essa certificação te permite cobrar serviços profissionais com 100% da cobrança para você.`,
