      font-size: 0.9375rem !important;
      min-height: 44px;
      padding: 10px 16px !important;
    }
    .pp-app-sidebar {
      -webkit-mask-image: linear-gradient(to right, #000 calc(100% - 28px), transparent);
      mask-image: linear-gradient(to right, #000 calc(100% - 28px), transparent);
