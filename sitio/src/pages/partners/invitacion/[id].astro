      gap: 6px !important;
      padding: 18px 0 !important;
    }
    .p-term-value { text-align: left !important; }
    .p-term-value--range { align-items: flex-start !important; }
    .p-term-value--accent { font-size: 1.625rem !important; }
    .p-contract-doc--modal {
      font-size: 0.9375rem !important;
      line-height: 1.7 !important;
    }
    .p-terms-view-btn {
      padding: 14px 22px !important;
    }
  }

  /* ─── SECCIÓN 4 · Compromisos ─── */
  @media (max-width: 640px) {
    .p-commit-row {
      gap: 14px !important;
