  .p-faq-a p {
    margin: 0;
    padding: 0 20px 20px 50px;
    font-size: 0.875rem;
    color: #555;
    line-height: 1.65;
  }
  @media (max-width: 600px) {
    .p-faq-a p { padding-left: 20px; }
  }

  /* ===================================================================
     MOBILE-FIRST OVERRIDES · auditoría UX 2026-05
     Aplica fixes globales A-E + parches específicos por sección.
     =================================================================== */

  /* A. Section-head compactar en mobile */
  @media (max-width: 480px) {
    .p-section-head { padding: 24px 0 16px; }
    .p-section-title { font-size: 1.5rem !important; line-height: 1.18; }
    .p-section-eyebrow { font-size: 0.6875rem; }
    .p-section-lead { font-size: 0.9375rem; line-height: 1.55; }
  }

  /* C. Touch targets ≥ 44px en todos los CTAs/botones interactivos */
  @media (max-width: 768px) {
    .p-btn,
    .p-cert-btn,
    .p-fab-btn,
    .p-perfil-pill,
    .p-commit-cta,
    .p-mobnav-tab,
    .p-terms-view-btn,
    .p-faq-q {
      min-height: 44px;
    }
  }

  /* D. Remover backdrop-filter en mobile (perf standards) */
  @media (max-width: 900px) {
    .p-mobnav,
    .p-perfil-row-tag,
    .p-cert-rowcard-level,
    .p-bw-tracker,
    .p-langswitch-btn,
    .pp-app-nav {
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
    }
    .p-perfil-row-tag {
      background: rgba(26, 26, 26, 0.95) !important;
    }
  }

  /* ─── SECCIÓN 1 · Bienvenida ─── */
  @media (max-width: 640px) {
    .p-hero-title {
      font-size: clamp(1.875rem, 8vw, 2.5rem) !important;
      word-break: break-word;
      hyphens: auto;
    }
    .p-bw-vision-num { font-size: clamp(3rem, 14vw, 5rem) !important; }
  }

  /* Lang switcher compacto en mobile */
  @media (max-width: 640px) {
    .p-langswitch {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .p-langswitch-btn {
      padding: 6px 10px !important;
