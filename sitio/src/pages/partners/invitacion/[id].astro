    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    max-height: 460px;
    background: #1a1a1a;
  }
  .p-tab-hero { margin: 0 0 36px; }
  .p-cert-hero { margin-bottom: 36px; }
  .p-tab-hero-img,
  .p-cert-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .p-tab-hero-overlay,
  .p-cert-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 35%, rgba(0,0,0,0.55) 75%, rgba(0,0,0,0.78) 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 32px 36px;
    color: #fff;
  }
  .p-tab-hero-eyebrow,
  .p-cert-hero-eyebrow {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.85);
    margin-bottom: 8px;
  }
  .p-tab-hero-title,
  .p-cert-hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 3.4vw, 2.25rem);
    font-weight: 300;
    color: #fff;
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.15;
    max-width: 600px;
  }
  @media (max-width: 600px) {
    .p-tab-hero-overlay,
    .p-cert-hero-overlay { padding: 22px 22px; }
  }

  /* ─── Filas de certificaciones (foto + explicación, alternadas) ─── */
  .p-cert-rows {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 32px;
  }
  .p-cert-rowcard {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: 0;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 16px;
    overflow: hidden;
    transition: border-color 0.18s, transform 0.18s, box-shadow 0.18s;
  }
  .p-cert-rowcard:hover {
    border-color: #cfd6e2;
    transform: translateY(-2px);
    box-shadow: 0 12px 32px -16px rgba(26,26,46,0.18);
  }
  .p-cert-rowcard--reverse { grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr); }
  .p-cert-rowcard--reverse .p-cert-rowcard-media { order: 2; }
  .p-cert-rowcard--reverse .p-cert-rowcard-body  { order: 1; }

  .p-cert-rowcard-media {
    position: relative;
    overflow: hidden;
    background: #f5f5f5;
    min-height: 100%;
  }
  .p-cert-rowcard-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .p-cert-rowcard-level {
    position: absolute;
    top: 16px; left: 16px;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    background: rgba(26,26,26,0.82);
    padding: 6px 12px;
    border-radius: 999px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .p-cert-rowcard-body {
    padding: 32px 32px 30px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .p-cert-rowcard-num {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    color: #4B7BE5;
    letter-spacing: 0.10em;
    margin-bottom: -4px;
  }
  .p-cert-rowcard-name {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 600;
    color: #1a1a1a;
    margin: 0;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .p-cert-rowcard-meta {
    font-size: 0.6875rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }
  .p-cert-rowcard-desc {
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.6;
    margin: 0;
  }

  .p-cert-rowcard-prices {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 6px;
  }
  @media (max-width: 480px) { .p-cert-rowcard-prices { grid-template-columns: 1fr; } }
  .p-cert-rowcard-price {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 14px;
    background: #fafaf8;
    border: 1px solid #ececec;
    border-radius: 10px;
  }
  .p-cert-rowcard-price--earn {
    background: linear-gradient(180deg, rgba(42,140,95,0.06), rgba(42,140,95,0.02));
    border-color: rgba(42,140,95,0.20);
  }
  .p-cert-rowcard-price-lbl {
    font-size: 0.625rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    font-weight: 600;
  }
  .p-cert-rowcard-price-val {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: #1a1a1a;
    letter-spacing: -0.01em;
  }
  .p-cert-rowcard-price-val em {
    font-style: normal;
    font-family: var(--font-body, inherit);
    font-size: 0.6875rem;
    color: #888;
    font-weight: 500;
    margin-left: 4px;
    letter-spacing: 0.02em;
  }
  .p-cert-rowcard-price--earn .p-cert-rowcard-price-val { color: #2A8C5F; }

  .p-cert-rowcard-keep {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: linear-gradient(135deg, rgba(42,140,95,0.10), rgba(42,140,95,0.03));
    border: 1px solid rgba(42,140,95,0.22);
    border-radius: 12px;
  }
  .p-cert-rowcard-keep-pct {
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 300;
    color: #2A8C5F;
    letter-spacing: -0.02em;
    line-height: 1;
    flex-shrink: 0;
  }
  .p-cert-rowcard-keep-text {
    font-size: 0.8125rem;
    color: #1a4a35;
    line-height: 1.4;
    font-weight: 500;
  }

  @media (max-width: 720px) {
    .p-cert-rowcard,
    .p-cert-rowcard--reverse {
      grid-template-columns: 1fr;
    }
    .p-cert-rowcard--reverse .p-cert-rowcard-media { order: 0; }
    .p-cert-rowcard--reverse .p-cert-rowcard-body  { order: 0; }
    .p-cert-rowcard-media { aspect-ratio: 16 / 10; min-height: 0; }
    .p-cert-rowcard-body { padding: 24px 22px 24px; }
  }

  .p-cert-unlock {
    margin: 36px 0 28px;
    padding: 32px;
    background: #fafaf8;
    border: 1px solid #ececec;
    border-radius: 14px;
  }
  .p-cert-unlock-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: #4B7BE5;
    margin-bottom: 18px;
  }
  .p-cert-unlock-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 22px;
  }
  @media (max-width: 720px) { .p-cert-unlock-grid { grid-template-columns: 1fr; } }
  .p-cert-unlock-item { display: flex; flex-direction: column; gap: 4px; }
  .p-cert-unlock-num {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    color: #4B7BE5;
    letter-spacing: 0.06em;
  }
  .p-cert-unlock-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    letter-spacing: -0.005em;
    margin-top: 2px;
  }
  .p-cert-unlock-detail {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.55;
    margin-top: 6px;
  }
  @media (max-width: 720px) {
    .p-cert-unlock { padding: 24px 20px; }
  }

  .p-cert-cta {
    padding: 22px 28px;
    background: #fff;
    border: 1px solid #ececec;
    border-left: 3px solid #4B7BE5;
    border-radius: 12px;
    margin-bottom: 16px;
  }
  .p-cert-cta-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #4B7BE5;
    margin-bottom: 6px;
  }
  .p-cert-cta p {
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.6;
    margin: 0;
  }

  .p-payout-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-top: 8px;
  }
  @media (max-width: 720px) { .p-payout-grid { grid-template-columns: 1fr; } }

  .p-payout-card {
    padding: 28px 22px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    display: flex; flex-direction: column; gap: 8px;
  }
  .p-payout-card--featured {
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d3f 100%);
    color: #fff;
    border: none;
  }
  .p-payout-step {
    font-size: 0.625rem; font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  .p-payout-card--featured .p-payout-step { color: #93b4ff; }
  .p-payout-amount {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 300;
    color: #1a1a1a;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .p-payout-card--featured .p-payout-amount { color: #fff; }
  .p-payout-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: #1a1a1a;
    letter-spacing: -0.005em;
  }
  .p-payout-card--featured .p-payout-name { color: #fff; }
  .p-payout-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.6);
    line-height: 1.5;
    margin-top: 4px;
  }
  .p-payout-card--featured .p-payout-detail { color: rgba(255,255,255,0.65); }

  .p-payout-notes {
    margin-top: 28px;
    padding: 22px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
  }
  .p-payout-notes-title {
    font-size: 0.625rem; font-weight: 700; color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
    margin-bottom: 10px;
  }
  .p-payout-notes p {
    margin: 0;
    font-size: 0.875rem;
    color: rgba(26,26,46,0.7);
    line-height: 1.6;
  }

  /* Landing card */
  .p-landing {
    margin-top: 32px;
    padding: 28px;
    background: linear-gradient(120deg, rgba(75,123,229,0.06), rgba(108,92,231,0.04));
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 16px;
    text-align: center;
  }
  .p-landing-eyebrow {
    font-size: 0.6875rem; font-weight: 700; color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
    margin-bottom: 12px;
  }
  .p-landing-url {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 500;
    color: #1a1a1a;
    word-break: break-all;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .p-landing-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    margin: 0 auto;
    max-width: 460px;
  }

  /* ─── Portal de partner — qué ve el partner y desde dónde ─── */
  .p-portal {
    margin-top: 40px;
    padding: 32px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 16px;
  }
  .p-portal-eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .p-portal-title {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.6vw, 1.75rem);
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 14px;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .p-portal-lead {
    font-size: 0.9375rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.6;
    margin: 0 0 28px;
    max-width: 640px;
  }
  .p-portal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px;
    margin-bottom: 22px;
  }
  .p-portal-card {
    background: #fafafa;
    border: 1px solid #f0f0f0;
    border-radius: 12px;
    padding: 18px;
  }
  .p-portal-card-ic {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(75,123,229,0.10);
    color: #4B7BE5;
    border-radius: 9px;
    margin-bottom: 12px;
  }
  .p-portal-card-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .p-portal-card-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.6);
    line-height: 1.55;
  }
  .p-portal-note {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 14px 16px;
    background: rgba(42,181,160,0.08);
    border-left: 3px solid #2AB5A0;
    border-radius: 6px;
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.75);
    line-height: 1.55;
  }
  .p-portal-note svg {
    flex-shrink: 0;
    color: #1A8F7A;
    margin-top: 2px;
  }
  @media (max-width: 640px) {
    .p-portal { padding: 22px; }
    .p-portal-grid { grid-template-columns: 1fr; }
  }

  /* ─── Tu potencial — proyección de ganancias ─── */
  .p-projection-block { margin: 8px 0 56px; }

  /* Toggle Mensual / Anual */
  .p-projection-toggle {
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    background: #fafafa;
    border: 1px solid #e5e5e5;
    border-radius: 14px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .p-toggle-btn {
    display: flex; flex-direction: column; gap: 1px;
    padding: 10px 18px;
    background: transparent;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    color: rgba(26,26,46,0.6);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .p-toggle-btn:hover { color: #1a1a1a; }
  .p-toggle-btn.is-active {
    background: #1a1a1a;
    color: #fff;
  }
  .p-toggle-btn-label {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: -0.005em;
  }
  .p-toggle-btn-hint {
    font-size: 0.625rem;
    font-weight: 500;
    opacity: 0.75;
    letter-spacing: 0.02em;
  }

  /* Show/hide based on data-projection-scope view state */
  [data-projection-scope] .p-view-anual { display: none; }
  [data-projection-scope][data-projection-view="anual"] .p-view-mensual { display: none; }
  [data-projection-scope][data-projection-view="anual"] .p-view-anual { display: block; }

  .p-projection-eyebrow {
    font-size: 0.625rem; font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 12px;
  }
  .p-projection-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 300;
    color: #1a1a1a;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 12px;
  }
  .p-projection-lead {
    font-size: 0.9375rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    margin: 0 0 28px;
    max-width: 600px;
  }
  .p-projection-lead strong { color: #1a1a1a; font-weight: 600; }

  /* Demo cards row */
  .p-demo-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 720px) { .p-demo-cards { grid-template-columns: 1fr; } }
  .p-demo-card {
    padding: 24px 22px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    display: flex; flex-direction: column; gap: 4px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .p-demo-card:hover { border-color: #4B7BE5; transform: translateY(-2px); }
  .p-demo-card--featured {
    background: linear-gradient(135deg, rgba(75,123,229,0.10), rgba(108,92,231,0.06));
    border-color: rgba(75,123,229,0.35);
  }
  .p-demo-card-label {
    font-size: 0.6875rem; font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.12em; text-transform: uppercase;
  }
  .p-demo-card-meta {
    font-size: 0.75rem;
    color: rgba(26,26,46,0.6);
    margin-bottom: 14px;
  }
  .p-demo-card-amount {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 300;
    color: #1a1a1a;
    line-height: 1;
    letter-spacing: -0.025em;
  }
  .p-demo-card-period {
    font-size: 0.75rem;
    color: rgba(26,26,46,0.55);
    margin-top: 2px;
  }
  .p-demo-card-annual {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid #e5e5e5;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #1a1a1a;
  }
  .p-demo-card-hint {
    font-size: 0.6875rem;
    color: rgba(26,26,46,0.5);
    font-style: italic;
    margin-top: 4px;
  }
  .p-demo-card--featured .p-demo-card-annual { border-color: rgba(75,123,229,0.25); }

  /* Sales matrix */
  .p-matrix-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 0 -8px;
    padding: 0 8px;
    scrollbar-width: thin;
  }
  .p-matrix-wrap::-webkit-scrollbar { height: 6px; }
  .p-matrix-wrap::-webkit-scrollbar-thumb { background: #e0e0e0; border-radius: 3px; }
  .p-matrix {
    width: 100%; min-width: 560px;
    border-collapse: collapse;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    overflow: hidden;
  }
  .p-matrix-th, .p-matrix-td {
    padding: 14px 12px;
    text-align: center;
    font-size: 0.875rem;
    border-bottom: 1px solid #f0f0f0;
    border-right: 1px solid #f0f0f0;
  }
  .p-matrix-th:last-child, .p-matrix-td:last-child { border-right: none; }
  .p-matrix-th {
    background: #fafafa;
    font-weight: 500;
    color: rgba(26,26,46,0.7);
    border-bottom: 1px solid #e5e5e5;
    padding: 18px 12px;
  }
  .p-matrix-th--clients {
    text-align: left;
    padding-left: 22px;
    font-size: 0.625rem;
    font-weight: 700;
    color: #999;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .p-matrix-plan-name {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 2px;
    letter-spacing: -0.005em;
  }
  .p-matrix-plan-price {
    font-size: 0.6875rem;
    color: #999;
    font-weight: 500;
  }
  .p-matrix-th--featured {
    background: linear-gradient(180deg, rgba(108,92,231,0.10), rgba(108,92,231,0.04));
  }
  .p-matrix-th--featured .p-matrix-plan-name { color: #6C5CE7; }
  .p-matrix-td--clients {
    text-align: left;
    padding-left: 22px;
    font-size: 0.875rem;
    color: rgba(26,26,46,0.7);
    background: #fafafa;
  }
  .p-matrix-td--clients strong {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: #1a1a1a;
    margin-right: 6px;
    letter-spacing: -0.01em;
  }
  .p-matrix-amount {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 1.1;
    letter-spacing: -0.005em;
  }
  .p-matrix-sub {
    font-size: 0.625rem;
    color: rgba(26,26,46,0.45);
    margin-top: 1px;
    letter-spacing: 0.05em;
  }
  .p-matrix-row--big .p-matrix-amount { font-size: 1.25rem; font-weight: 500; }
  .p-matrix-row--big .p-matrix-td--clients strong { font-size: 1.5rem; color: #4B7BE5; }
  .p-matrix-td--featured {
    background: rgba(108,92,231,0.04);
  }
  .p-matrix-td--featured .p-matrix-amount {
