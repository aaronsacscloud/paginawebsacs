  'sign.benef.err_sum': { es: 'Si designas beneficiarios, los porcentajes deben sumar exactamente 100%.', en: 'If you designate beneficiaries, the percentages must add up to exactly 100%.', fr: 'Si vous désignez des bénéficiaires, les pourcentages doivent totaliser exactement 100 %.', it: 'Se designi beneficiari, le percentuali devono sommare esattamente 100%.', pt: 'Se você designar beneficiários, os percentuais devem somar exatamente 100%.' },
  'sign.benef.err_nombre': { es: 'Escribe el nombre del beneficiario o quita el porcentaje.', en: 'Enter the beneficiary\'s name or clear the percentage.', fr: 'Saisissez le nom du bénéficiaire ou effacez le pourcentage.', it: 'Inserisci il nome del beneficiario o rimuovi la percentuale.', pt: 'Escreva o nome do beneficiário ou remova o percentual.' },

