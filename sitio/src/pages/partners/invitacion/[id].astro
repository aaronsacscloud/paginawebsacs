  // 9 perfil cards · solo título corto + descripción + "desde"
  'p1.t': { es: 'Influencers y creadores', en: 'Influencers and creators', fr: 'Influenceurs et créateurs', it: 'Influencer e creator', pt: 'Influencers e criadores' },
  'p1.d': { es: 'Tienes audiencia que confía en tus recomendaciones. Aprovechas tu alcance — cada pieza de contenido suma puntos y tu link cierra ventas en piloto automático.', en: 'You have an audience that trusts your recommendations. You leverage your reach — each piece of content earns points and your link closes sales on autopilot.', fr: 'Vous avez une audience qui fait confiance à vos recommandations. Vous capitalisez sur votre portée — chaque contenu rapporte des points et votre lien conclut des ventes en pilote automatique.', it: 'Hai un pubblico che si fida dei tuoi consigli. Sfrutti la tua portata — ogni contenuto guadagna punti e il tuo link chiude vendite in automatico.', pt: 'Você tem audiência que confia nas suas recomendações. Aproveita seu alcance — cada conteúdo soma pontos e seu link fecha vendas em piloto automático.' },
  'p1.f': { es: 'Desde tu casa', en: 'From home', fr: 'Depuis chez vous', it: 'Da casa', pt: 'De casa' },

  'p2.t': { es: 'Nómadas digitales', en: 'Digital nomads', fr: 'Nomades digitaux', it: 'Nomadi digitali', pt: 'Nômades digitais' },
  'p2.d': { es: 'Trabajas desde donde quieras: cafés, coworkings, Airbnbs, ciudades distintas cada mes. SACS te paga vía CLABE/PayPal/Mercado Pago — la geografía no te limita.', en: 'You work from anywhere: cafés, coworkings, Airbnbs, different cities each month. SACS pays you via CLABE/PayPal/Mercado Pago — geography doesn\'t limit you.', fr: 'Vous travaillez d\'où vous voulez : cafés, coworkings, Airbnbs, villes différentes chaque mois. SACS vous paie via CLABE/PayPal/Mercado Pago — la géographie ne vous limite pas.', it: 'Lavori da dove vuoi: caffè, coworking, Airbnb, città diverse ogni mese. SACS ti paga via CLABE/PayPal/Mercado Pago — la geografia non ti limita.', pt: 'Você trabalha de onde quiser: cafés, coworkings, Airbnbs, cidades diferentes a cada mês. A SACS paga via CLABE/PayPal/Mercado Pago — a geografia não te limita.' },
  'p2.f': { es: 'Desde donde estés', en: 'From wherever you are', fr: 'Où que vous soyez', it: 'Da dove sei', pt: 'De onde você estiver' },

  'p3.t': { es: 'Consultores y asesores', en: 'Consultants and advisors', fr: 'Consultants et conseillers', it: 'Consulenti e advisor', pt: 'Consultores e assessores' },
  'p3.d': { es: 'Asesoras a negocios y SACS es una herramienta más en tu kit. Recomiendas, certificas, cobras implementación — y el 100% del cobro al cliente es tuyo.', en: 'You advise businesses and SACS is one more tool in your kit. You recommend, certify, charge implementation — and 100% of the client billing is yours.', fr: 'Vous conseillez des entreprises et SACS est un outil de plus dans votre kit. Vous recommandez, vous vous certifiez, vous facturez l\'implémentation — et 100% de la facturation au client est pour vous.', it: 'Consigli aziende e SACS è uno strumento in più nel tuo kit. Raccomandi, ti certifichi, fatturi l\'implementazione — e il 100% della fattura al cliente è tuo.', pt: 'Você assessora negócios e a SACS é mais uma ferramenta no seu kit. Recomenda, se certifica, cobra implementação — e 100% do que cobra do cliente é seu.' },
  'p3.f': { es: 'Desde tu oficina o tu casa', en: 'From your office or home', fr: 'Depuis votre bureau ou chez vous', it: 'Dal tuo ufficio o da casa', pt: 'Do seu escritório ou de casa' },

  'p4.t': { es: 'Contadores y asesores fiscales', en: 'Accountants and tax advisors', fr: 'Comptables et conseillers fiscaux', it: 'Commercialisti e consulenti fiscali', pt: 'Contadores e assessores fiscais' },
  'p4.d': { es: 'Tu cartera ya confía en ti para sus finanzas. Recomendar SACS resuelve un dolor real (CFDI, IEPS, conciliación) y abres una nueva línea de ingresos.', en: 'Your client base already trusts you with their finances. Recommending SACS solves real pain points (CFDI, IEPS, reconciliation) and opens a new income stream.', fr: 'Votre portefeuille vous fait déjà confiance pour ses finances. Recommander SACS résout une vraie douleur (CFDI, IEPS, rapprochement) et ouvre une nouvelle source de revenus.', it: 'I tuoi clienti già si fidano di te per le loro finanze. Raccomandare SACS risolve un dolore reale (CFDI, IEPS, riconciliazione) e apre una nuova linea di entrate.', pt: 'Sua carteira já confia em você para as finanças. Recomendar SACS resolve uma dor real (CFDI, IEPS, conciliação) e abre uma nova linha de receita.' },
  'p4.f': { es: 'Desde tu despacho', en: 'From your firm', fr: 'Depuis votre cabinet', it: 'Dal tuo studio', pt: 'Do seu escritório' },

  'p5.t': { es: 'Distribuidores de tecnología B2B', en: 'B2B technology distributors', fr: 'Distributeurs de technologie B2B', it: 'Distributori di tecnologia B2B', pt: 'Distribuidores de tecnologia B2B' },
  'p5.d': { es: 'Vendes software, SaaS y soluciones tech a empresas. SACS encaja en tu portafolio como solución end-to-end de retail con margen recurrente real.', en: 'You sell software, SaaS, and tech solutions to companies. SACS fits in your portfolio as an end-to-end retail solution with real recurring margin.', fr: 'Vous vendez des logiciels, SaaS et solutions tech aux entreprises. SACS s\'intègre dans votre portefeuille comme solution retail de bout en bout avec une marge récurrente réelle.', it: 'Vendi software, SaaS e soluzioni tech alle aziende. SACS si inserisce nel tuo portafoglio come soluzione retail end-to-end con margine ricorrente reale.', pt: 'Você vende software, SaaS e soluções tech para empresas. SACS encaixa no seu portfólio como solução end-to-end de retail com margem recorrente real.' },
  'p5.f': { es: 'Desde tu empresa', en: 'From your company', fr: 'Depuis votre entreprise', it: 'Dalla tua azienda', pt: 'Da sua empresa' },

  'p6.t': { es: 'Vendedores de hardware POS', en: 'POS hardware sellers', fr: 'Vendeurs de matériel POS', it: 'Venditori di hardware POS', pt: 'Vendedores de hardware POS' },
  'p6.d': { es: 'Vendes terminales, lectores, scanners e impresoras. Sumas SACS y vendes la operación completa — hardware + software como un solo paquete.', en: 'You sell terminals, readers, scanners, and printers. Add SACS and you sell the complete operation — hardware + software as one package.', fr: 'Vous vendez des terminaux, lecteurs, scanners et imprimantes. Ajoutez SACS et vous vendez l\'opération complète — hardware + logiciel en un seul package.', it: 'Vendi terminali, lettori, scanner e stampanti. Aggiungi SACS e vendi l\'operazione completa — hardware + software come un unico pacchetto.', pt: 'Você vende terminais, leitores, scanners e impressoras. Soma SACS e vende a operação completa — hardware + software num único pacote.' },
  'p6.f': { es: 'Desde tu showroom o ruta', en: 'From your showroom or route', fr: 'Depuis votre showroom ou tournée', it: 'Dal tuo showroom o giro', pt: 'Do seu showroom ou rota' },

  'p7.t': { es: 'Distribuidores de tiendas', en: 'Store distributors', fr: 'Distributeurs de boutiques', it: 'Distributori di negozi', pt: 'Distribuidores de lojas' },
  'p7.d': { es: 'Vendes a una red de tiendas o llevas un canal completo. Tu red ya conoce tu marca; sumar SACS es darles más valor con la misma relación.', en: 'You sell to a network of stores or run a full channel. Your network already knows your brand; adding SACS gives them more value with the same relationship.', fr: 'Vous vendez à un réseau de boutiques ou gérez un canal complet. Votre réseau connaît déjà votre marque ; ajouter SACS leur apporte plus de valeur avec la même relation.', it: 'Vendi a una rete di negozi o gestisci un canale completo. La tua rete conosce già il tuo marchio; aggiungere SACS dà loro più valore con la stessa relazione.', pt: 'Você vende para uma rede de lojas ou conduz um canal completo. Sua rede já conhece sua marca; somar SACS é dar mais valor com a mesma relação.' },
  'p7.f': { es: 'Desde tu empresa o almacén', en: 'From your company or warehouse', fr: 'Depuis votre entreprise ou entrepôt', it: 'Dalla tua azienda o magazzino', pt: 'Da sua empresa ou almoxarifado' },

  'p8.t': { es: 'Dueños de tienda o negocio', en: 'Store or business owners', fr: 'Propriétaires de boutique ou d\'entreprise', it: 'Titolari di negozio o attività', pt: 'Donos de loja ou negócio' },
  'p8.d': { es: 'Ya operas un negocio. Tu credibilidad operacional pesa más que cualquier audiencia: recomiendas SACS a colegas de tu giro y a tu cámara local.', en: 'You already run a business. Your operational credibility outweighs any audience: you recommend SACS to peers in your sector and your local chamber.', fr: 'Vous gérez déjà une entreprise. Votre crédibilité opérationnelle pèse plus que n\'importe quelle audience : vous recommandez SACS à vos pairs et à votre chambre locale.', it: 'Gestisci già un\'attività. La tua credibilità operativa conta più di qualsiasi pubblico: raccomandi SACS ai colleghi del tuo settore e alla camera di commercio locale.', pt: 'Você já opera um negócio. Sua credibilidade operacional pesa mais que qualquer audiência: recomenda SACS aos colegas do seu setor e à sua câmara local.' },
  'p8.f': { es: 'Desde tu tienda o local', en: 'From your store or location', fr: 'Depuis votre boutique ou local', it: 'Dal tuo negozio o locale', pt: 'Da sua loja ou local' },

  'p9.t': { es: 'Emprendedores arrancando', en: 'Entrepreneurs just starting', fr: 'Entrepreneurs qui démarrent', it: 'Imprenditori agli inizi', pt: 'Empreendedores começando' },
  'p9.d': { es: 'No tienes audiencia ni cartera todavía — y eso no te frena. Sumas puntos con acciones de promoción y filantropía mientras construyes tu negocio.', en: 'You don\'t have an audience or portfolio yet — and that doesn\'t stop you. You earn points with promotional actions and philanthropy while you build your business.', fr: 'Vous n\'avez pas encore d\'audience ni de portefeuille — et ça ne vous arrête pas. Vous gagnez des points par des actions de promotion et de la philanthropie pendant que vous construisez votre activité.', it: 'Non hai ancora pubblico né portafoglio — e questo non ti ferma. Guadagni punti con azioni di promozione e filantropia mentre costruisci la tua attività.', pt: 'Você ainda não tem audiência nem carteira — e isso não te trava. Soma pontos com ações de promoção e filantropia enquanto constrói seu negócio.' },
  'p9.f': { es: 'Desde tu casa', en: 'From home', fr: 'Depuis chez vous', it: 'Da casa', pt: 'De casa' },

  // ─── Tab "¿A quién le puedo vender?" · 12 canales de venta ───
  'can.eyebrow': { es: 'Cómo y a quién venderle', en: 'How and who to sell to', fr: 'Comment et à qui vendre', it: 'Come e a chi vendere', pt: 'Como e a quem vender' },
  'can.title':   { es: '12 formas reales de vender SACS.', en: '12 real ways to sell SACS.', fr: '12 vraies façons de vendre SACS.', it: '12 modi reali di vendere SACS.', pt: '12 formas reais de vender SACS.' },
  'can.lead':    { es: 'Cada partner llega con su propia red, su propio canal y su propio estilo. Aquí tienes <strong>12 vertientes</strong> probadas — escoge las 2-3 que más se acomoden a tu situación. La meta no es hacerlas todas, es elegir bien y ejecutar bien.', en: 'Each partner brings their own network, channel and style. Here are <strong>12 proven paths</strong> — pick the 2-3 that best fit your situation. The goal isn\'t to do them all, it\'s to choose well and execute well.', fr: 'Chaque partenaire arrive avec son propre réseau, son propre canal et son propre style. Voici <strong>12 voies éprouvées</strong> — choisissez les 2-3 qui correspondent le mieux à votre situation. Le but n\'est pas de toutes les faire, mais de bien choisir et bien exécuter.', it: 'Ogni partner arriva con la propria rete, canale e stile. Ecco <strong>12 strade collaudate</strong> — scegli le 2-3 che si adattano meglio alla tua situazione. L\'obiettivo non è farle tutte, è scegliere bene ed eseguire bene.', pt: 'Cada parceiro chega com sua própria rede, canal e estilo. Aqui estão <strong>12 caminhos comprovados</strong> — escolha os 2-3 que melhor se ajustam à sua situação. O objetivo não é fazer todos, é escolher bem e executar bem.' },

  // Card 1 · Visita en persona a tiendas
  'can.c1.tag':  { es: 'En la calle', en: 'On the street', fr: 'Dans la rue', it: 'In strada', pt: 'Na rua' },
  'can.c1.t':    { es: 'Visita en persona a tiendas locales', en: 'In-person visits to local stores', fr: 'Visites en personne aux commerces locaux', it: 'Visite di persona ai negozi locali', pt: 'Visita pessoal a lojas locais' },
  'can.c1.d':    { es: 'El sales call clásico. Identificas 10 tiendas en tu zona — boutiques, restaurantes, ferreterías — y entras. Observas su operación, encuentras 1 dolor real (cierre lento, inventario perdido, sin ecommerce) y le muestras SACS desde tu celular en su propia caja registradora.', en: 'The classic sales call. You identify 10 stores in your area — boutiques, restaurants, hardware stores — and walk in. Watch their operation, find one real pain (slow close, lost inventory, no e-commerce) and show them SACS from your phone right at their counter.', fr: 'Le sales call classique. Vous identifiez 10 boutiques dans votre zone — boutiques, restaurants, quincailleries — et entrez. Vous observez leur opération, trouvez une vraie douleur (clôture lente, inventaire perdu, sans e-commerce) et leur montrez SACS depuis votre téléphone à leur propre caisse.', it: 'La sales call classica. Identifichi 10 negozi nella tua zona — boutique, ristoranti, ferramenta — e entri. Osservi la loro operatività, trovi un dolore reale (chiusura lenta, inventario perso, senza ecommerce) e mostri SACS dal tuo telefono alla loro stessa cassa.', pt: 'O sales call clássico. Você identifica 10 lojas na sua zona — boutiques, restaurantes, ferragens — e entra. Observa a operação, encontra uma dor real (fechamento lento, inventário perdido, sem e-commerce) e mostra a SACS do seu celular no próprio caixa deles.' },
  'can.c1.f':    { es: '5-10 visitas/semana', en: '5-10 visits/week', fr: '5-10 visites/semaine', it: '5-10 visite/settimana', pt: '5-10 visitas/semana' },

  // Card 2 · Enterprise vía LinkedIn
  'can.c2.tag':  { es: 'B2B / Enterprise', en: 'B2B / Enterprise', fr: 'B2B / Entreprise', it: 'B2B / Enterprise', pt: 'B2B / Enterprise' },
  'can.c2.t':    { es: 'Enterprise vía LinkedIn', en: 'Enterprise via LinkedIn', fr: 'Entreprise via LinkedIn', it: 'Enterprise via LinkedIn', pt: 'Enterprise via LinkedIn' },
  'can.c2.d':    { es: 'Para cuentas grandes — cadenas con 5+ sucursales, restauranteros con varios conceptos, distribuidores nacionales. Buscas en LinkedIn al gerente de operaciones, director de TI o dueño y le mandas un mensaje específico (no plantilla) hablando de su negocio. SACS cierra contigo en la llamada.', en: 'For large accounts — chains with 5+ stores, restaurateurs with multiple concepts, national distributors. You search LinkedIn for the operations manager, IT director or owner and send a specific message (not a template) speaking about their business. SACS closes with you on the call.', fr: 'Pour les grands comptes — chaînes avec 5+ boutiques, restaurateurs avec plusieurs concepts, distributeurs nationaux. Vous cherchez sur LinkedIn le directeur des opérations, le DSI ou le propriétaire et lui envoyez un message spécifique (pas un modèle) parlant de son activité. SACS conclut avec vous lors de l\'appel.', it: 'Per grandi conti — catene con 5+ negozi, ristoratori con più concetti, distributori nazionali. Cerchi su LinkedIn il responsabile operations, il direttore IT o il titolare e gli mandi un messaggio specifico (non un template) parlando del suo business. SACS chiude con te in call.', pt: 'Para contas grandes — redes com 5+ lojas, restauranteiros com múltiplos conceitos, distribuidores nacionais. Você busca no LinkedIn o gerente de operações, diretor de TI ou dono e envia uma mensagem específica (não template) falando do negócio dele. A SACS fecha com você na chamada.' },
  'can.c2.f':    { es: '20-30 mensajes/semana', en: '20-30 messages/week', fr: '20-30 messages/semaine', it: '20-30 messaggi/settimana', pt: '20-30 mensagens/semana' },

  // Card 3 · Tu red personal
  'can.c3.tag':  { es: 'Cercanía', en: 'Inner circle', fr: 'Cercle proche', it: 'Cerchia stretta', pt: 'Círculo próximo' },
  'can.c3.t':    { es: 'Tu red personal y familiar', en: 'Your personal and family network', fr: 'Votre réseau personnel et familial', it: 'La tua rete personale e familiare', pt: 'Sua rede pessoal e familiar' },
  'can.c3.d':    { es: 'Empieza por la gente que ya conoces. Amigos con tiendas, familiares con restaurantes, vecinos con boutiques, ex-compañeros de trabajo que abrieron negocio. La confianza ya está dada — solo te queda mostrar la herramienta. Es la vía con mayor tasa de cierre.', en: 'Start with the people you already know. Friends with stores, family with restaurants, neighbors with boutiques, ex-coworkers who opened a business. Trust is already there — you just need to show the tool. Highest close rate channel.', fr: 'Commencez par les gens que vous connaissez déjà. Amis avec boutiques, famille avec restaurants, voisins avec boutiques, ex-collègues qui ont monté une activité. La confiance est déjà là — il vous reste juste à montrer l\'outil. Le canal au plus fort taux de conversion.', it: 'Inizia dalle persone che già conosci. Amici con negozi, parenti con ristoranti, vicini con boutique, ex-colleghi che hanno aperto un\'attività. La fiducia c\'è già — ti basta mostrare lo strumento. Il canale con il tasso di chiusura più alto.', pt: 'Comece pelas pessoas que você já conhece. Amigos com lojas, familiares com restaurantes, vizinhos com boutiques, ex-colegas de trabalho que abriram negócio. A confiança já está dada — só falta mostrar a ferramenta. É o canal com maior taxa de fechamento.' },
  'can.c3.f':    { es: 'Lista de 30 contactos', en: 'List of 30 contacts', fr: 'Liste de 30 contacts', it: 'Lista di 30 contatti', pt: 'Lista de 30 contatos' },

  // Card 4 · Tu propia tienda como showroom
  'can.c4.tag':  { es: 'Tu sucursal', en: 'Your store', fr: 'Votre boutique', it: 'Il tuo negozio', pt: 'Sua loja' },
  'can.c4.t':    { es: 'Tu propia tienda como showroom vivo', en: 'Your own store as a living showroom', fr: 'Votre propre boutique comme showroom vivant', it: 'Il tuo negozio come showroom vivo', pt: 'Sua própria loja como showroom vivo' },
  'can.c4.d':    { es: 'Si ya tienes negocio físico, lo conviertes en demo viviente. Invitas a 5-10 colegas del sector a ver SACS funcionando en cierres reales, devoluciones reales, picos reales de tu propia operación. Open day con café y networking — los que ven prueba real, compran rápido.', en: 'If you already have a physical business, turn it into a living demo. Invite 5-10 sector peers to see SACS working in real closes, real returns, real peaks of your own operation. An open day with coffee and networking — those who see real proof buy fast.', fr: 'Si vous avez déjà une activité physique, transformez-la en démo vivante. Invitez 5-10 confrères du secteur à voir SACS fonctionner sur de vraies clôtures, vrais retours, vrais pics de votre propre opération. Une journée portes ouvertes avec café et networking — ceux qui voient de vraies preuves achètent vite.', it: 'Se hai già un\'attività fisica, trasformala in una demo vivente. Invita 5-10 colleghi del settore a vedere SACS funzionare in chiusure reali, resi reali, picchi reali della tua operatività. Open day con caffè e networking — chi vede prove reali compra in fretta.', pt: 'Se já tem negócio físico, transforme-o em demo vivo. Convide 5-10 colegas do setor para ver a SACS funcionando em fechamentos reais, devoluções reais, picos reais da sua operação. Open day com café e networking — quem vê prova real compra rápido.' },
  'can.c4.f':    { es: '1 open day/mes', en: '1 open day/month', fr: '1 portes ouvertes/mois', it: '1 open day/mese', pt: '1 open day/mês' },

  // Card 5 · Ferias y expos
  'can.c5.tag':  { es: 'Ferias del sector', en: 'Industry fairs', fr: 'Salons du secteur', it: 'Fiere di settore', pt: 'Feiras do setor' },
  'can.c5.t':    { es: 'Ferias y expos del sector', en: 'Industry fairs and expos', fr: 'Salons et expos du secteur', it: 'Fiere ed expo di settore', pt: 'Feiras e expos do setor' },
  'can.c5.d':    { es: 'ANTAD para retail, expos restauranteras, ferias de moda, expos de ferretería. Reservas un stand pequeño compartido o vas como visitante con tarjetas y QR a tu landing. En 2 días generas más leads calificados que en 2 meses de prospección fría.', en: 'ANTAD for retail, restaurant expos, fashion fairs, hardware expos. Book a small shared booth or attend as visitor with cards and QR to your landing. In 2 days you generate more qualified leads than in 2 months of cold prospecting.', fr: 'ANTAD pour le retail, expos restauration, salons mode, expos quincaillerie. Réservez un petit stand partagé ou venez comme visiteur avec cartes et QR vers votre landing. En 2 jours vous générez plus de leads qualifiés qu\'en 2 mois de prospection froide.', it: 'ANTAD per retail, expo della ristorazione, fiere moda, expo ferramenta. Prenoti un piccolo stand condiviso o vai come visitatore con biglietti e QR alla tua landing. In 2 giorni generi più lead qualificati che in 2 mesi di prospecting a freddo.', pt: 'ANTAD para varejo, expos de restaurantes, feiras de moda, expos de ferragens. Reserve um stand pequeno compartilhado ou vá como visitante com cartões e QR para sua landing. Em 2 dias você gera mais leads qualificados do que em 2 meses de prospecção fria.' },
  'can.c5.f':    { es: '2-4 ferias/año', en: '2-4 fairs/year', fr: '2-4 salons/an', it: '2-4 fiere/anno', pt: '2-4 feiras/ano' },

  // Card 6 · Cámaras de comercio
  'can.c6.tag':  { es: 'Alianzas locales', en: 'Local alliances', fr: 'Alliances locales', it: 'Alleanze locali', pt: 'Alianças locais' },
  'can.c6.t':    { es: 'Cámaras de comercio y asociaciones', en: 'Chambers of commerce and associations', fr: 'Chambres de commerce et associations', it: 'Camere di commercio e associazioni', pt: 'Câmaras de comércio e associações' },
  'can.c6.d':    { es: 'Te acercas a la cámara de comercio de tu ciudad o a la asociación gremial de tu sector. Ofreces dar una charla gratuita sobre digitalización del negocio y, en el camino, te conviertes en proveedor recomendado para sus afiliados. Validación institucional al instante.', en: 'Approach your city\'s chamber of commerce or your sector\'s trade association. Offer a free talk on business digitalization and along the way become a recommended provider for their members. Instant institutional validation.', fr: 'Approchez la chambre de commerce de votre ville ou l\'association professionnelle de votre secteur. Proposez une conférence gratuite sur la digitalisation et, en chemin, devenez fournisseur recommandé pour leurs membres. Validation institutionnelle immédiate.', it: 'Avvicini la camera di commercio della tua città o l\'associazione di categoria del tuo settore. Offri una conferenza gratuita sulla digitalizzazione e, lungo la strada, diventi fornitore raccomandato per i loro associati. Validazione istituzionale immediata.', pt: 'Aproxime-se da câmara de comércio da sua cidade ou da associação do seu setor. Ofereça uma palestra gratuita sobre digitalização e, no caminho, torne-se fornecedor recomendado para os afiliados. Validação institucional instantânea.' },
  'can.c6.f':    { es: '1 alianza institucional', en: '1 institutional alliance', fr: '1 alliance institutionnelle', it: '1 alleanza istituzionale', pt: '1 aliança institucional' },

  // Card 7 · Grupos de WhatsApp
  'can.c7.tag':  { es: 'Comunidades digitales', en: 'Digital communities', fr: 'Communautés digitales', it: 'Comunità digitali', pt: 'Comunidades digitais' },
  'can.c7.t':    { es: 'Grupos de WhatsApp y Telegram del sector', en: 'WhatsApp and Telegram sector groups', fr: 'Groupes WhatsApp et Telegram du secteur', it: 'Gruppi WhatsApp e Telegram di settore', pt: 'Grupos de WhatsApp e Telegram do setor' },
  'can.c7.d':    { es: 'Comunidades de dueños de boutiques, restauranteros, ferreteros, salones de belleza. Te metes, aportas valor durante 30 días sin vender (responder dudas, compartir tips), y solo entonces compartes tu link cuando alguien pregunta por un sistema. La paciencia paga.', en: 'Communities of boutique owners, restaurateurs, hardware stores, beauty salons. You join, add value for 30 days without selling (answering questions, sharing tips), and only then share your link when someone asks about a system. Patience pays.', fr: 'Communautés de propriétaires de boutiques, restaurateurs, quincailleries, salons de beauté. Vous y entrez, apportez de la valeur pendant 30 jours sans vendre (répondre aux questions, partager des conseils), et seulement alors partagez votre lien quand quelqu\'un demande un système. La patience paye.', it: 'Comunità di titolari di boutique, ristoratori, ferramenta, saloni di bellezza. Entri, aggiungi valore per 30 giorni senza vendere (rispondi a dubbi, condividi tip), e solo allora condividi il tuo link quando qualcuno chiede un sistema. La pazienza paga.', pt: 'Comunidades de donos de boutiques, restauranteiros, ferragens, salões de beleza. Você entra, agrega valor por 30 dias sem vender (respondendo dúvidas, compartilhando tips), e só então compartilha seu link quando alguém pergunta por um sistema. A paciência paga.' },
  'can.c7.f':    { es: '3-5 grupos activos', en: '3-5 active groups', fr: '3-5 groupes actifs', it: '3-5 gruppi attivi', pt: '3-5 grupos ativos' },

  // Card 8 · Contenido + link en bio
  'can.c8.tag':  { es: 'Modo creator', en: 'Creator mode', fr: 'Mode créateur', it: 'Modalità creator', pt: 'Modo criador' },
  'can.c8.t':    { es: 'Contenido + link en bio', en: 'Content + link in bio', fr: 'Contenu + lien dans la bio', it: 'Contenuti + link in bio', pt: 'Conteúdo + link na bio' },
  'can.c8.d':    { es: 'El modo influencer clásico. Cada Reel, TikTok o video de YouTube educa sobre un dolor de retail concreto y deja tu link al alcance. La conversión no es inmediata — pero un solo video viral puede llenar tu pipeline por meses. Funciona muy bien combinado con otros canales.', en: 'The classic influencer mode. Each Reel, TikTok or YouTube video educates on a specific retail pain and keeps your link within reach. Conversion isn\'t immediate — but a single viral video can fill your pipeline for months. Works great combined with other channels.', fr: 'Le mode influenceur classique. Chaque Reel, TikTok ou vidéo YouTube éduque sur une douleur retail concrète et laisse votre lien à portée. La conversion n\'est pas immédiate — mais une seule vidéo virale peut remplir votre pipeline pour des mois. Fonctionne très bien combiné à d\'autres canaux.', it: 'La modalità influencer classica. Ogni Reel, TikTok o video YouTube educa su un dolore retail concreto e lascia il tuo link a portata. La conversione non è immediata — ma un solo video virale può riempire la tua pipeline per mesi. Funziona benissimo combinata con altri canali.', pt: 'O modo influenciador clássico. Cada Reel, TikTok ou vídeo do YouTube educa sobre uma dor concreta de varejo e deixa seu link ao alcance. A conversão não é imediata — mas um único vídeo viral pode encher seu pipeline por meses. Funciona muito bem combinado com outros canais.' },
  'can.c8.f':    { es: '4-8 piezas/mes', en: '4-8 pieces/month', fr: '4-8 contenus/mois', it: '4-8 contenuti/mese', pt: '4-8 peças/mês' },

  // Card 9 · Email a tu cartera B2B
  'can.c9.tag':  { es: 'Cartera existente', en: 'Existing portfolio', fr: 'Portefeuille existant', it: 'Portafoglio esistente', pt: 'Carteira existente' },
  'can.c9.t':    { es: 'Email a tu cartera B2B', en: 'Email to your B2B portfolio', fr: 'Email à votre portefeuille B2B', it: 'Email al tuo portafoglio B2B', pt: 'Email à sua carteira B2B' },
  'can.c9.d':    { es: 'Si eres consultor, contador, agencia o desarrollador con cartera de clientes empresa, ya tienes la lista. Newsletter mensual con un caso de éxito real + tu link. Sin presión, sin spam: solo contenido útil y la opción de saber más. Conversión silenciosa pero constante.', en: 'If you\'re a consultant, accountant, agency or developer with a corporate client portfolio, you already have the list. Monthly newsletter with one real case study + your link. No pressure, no spam: just useful content and the option to learn more. Silent but steady conversion.', fr: 'Si vous êtes consultant, comptable, agence ou développeur avec un portefeuille clients entreprise, vous avez déjà la liste. Newsletter mensuelle avec un cas concret + votre lien. Sans pression, sans spam : juste du contenu utile et l\'option d\'en savoir plus. Conversion silencieuse mais constante.', it: 'Se sei consulente, commercialista, agenzia o sviluppatore con un portafoglio di clienti aziendali, hai già la lista. Newsletter mensile con un caso reale + il tuo link. Senza pressione, senza spam: solo contenuto utile e l\'opzione di saperne di più. Conversione silenziosa ma costante.', pt: 'Se é consultor, contador, agência ou desenvolvedor com carteira de clientes empresariais, já tem a lista. Newsletter mensal com um caso real + seu link. Sem pressão, sem spam: só conteúdo útil e a opção de saber mais. Conversão silenciosa mas constante.' },
  'can.c9.f':    { es: '1 newsletter/mes', en: '1 newsletter/month', fr: '1 newsletter/mois', it: '1 newsletter/mese', pt: '1 newsletter/mês' },

  // Card 10 · Workshops y desayunos
  'can.c10.tag': { es: 'Eventos íntimos', en: 'Intimate events', fr: 'Événements intimes', it: 'Eventi intimi', pt: 'Eventos íntimos' },
  'can.c10.t':   { es: 'Workshops y desayunos de negocio', en: 'Workshops and business breakfasts', fr: 'Ateliers et petits-déjeuners business', it: 'Workshop e colazioni di business', pt: 'Workshops e cafés da manhã de negócios' },
  'can.c10.d':   { es: 'Reservas un coffee break o lunch en un coworking. Invitas a 8-15 dueños de negocio. 30 minutos de charla útil sobre digitalización, 30 minutos de demo en vivo de SACS, 30 minutos de networking. Cierras 2-3 leads cualificados por evento. La intimidad cierra mejor que la masa.', en: 'Book a coffee break or lunch at a coworking space. Invite 8-15 business owners. 30 minutes of useful talk on digitalization, 30 minutes of live SACS demo, 30 minutes of networking. You close 2-3 qualified leads per event. Intimacy closes better than mass.', fr: 'Réservez un petit-déjeuner ou déjeuner dans un coworking. Invitez 8-15 chefs d\'entreprise. 30 minutes de conférence utile sur la digitalisation, 30 minutes de démo SACS en direct, 30 minutes de networking. Vous concluez 2-3 leads qualifiés par événement. L\'intimité conclut mieux que la masse.', it: 'Prenoti un coffee break o pranzo in un coworking. Inviti 8-15 titolari di attività. 30 minuti di talk utile sulla digitalizzazione, 30 minuti di demo live di SACS, 30 minuti di networking. Chiudi 2-3 lead qualificati per evento. L\'intimità chiude meglio della massa.', pt: 'Reserve um coffee break ou almoço em um coworking. Convide 8-15 donos de negócio. 30 minutos de palestra útil sobre digitalização, 30 minutos de demo ao vivo da SACS, 30 minutos de networking. Você fecha 2-3 leads qualificados por evento. A intimidade fecha melhor que a massa.' },
  'can.c10.f':   { es: '1 workshop/trimestre', en: '1 workshop/quarter', fr: '1 atelier/trimestre', it: '1 workshop/trimestre', pt: '1 workshop/trimestre' },

  // Card 11 · Co-marketing con marcas aliadas
  'can.c11.tag': { es: 'Alianzas estratégicas', en: 'Strategic alliances', fr: 'Alliances stratégiques', it: 'Alleanze strategiche', pt: 'Alianças estratégicas' },
  'can.c11.t':   { es: 'Co-marketing con marcas aliadas', en: 'Co-marketing with allied brands', fr: 'Co-marketing avec marques alliées', it: 'Co-marketing con marchi alleati', pt: 'Co-marketing com marcas aliadas' },
  'can.c11.d':   { es: 'Te alías con una marca no competidora que vende a tu mismo público — proveedores de mobiliario retail, escuelas de negocio, agencias de marketing, fintechs. Cada uno recomienda al otro a sus clientes. Reels conjuntos, blog cruzado, evento doble. Multiplicas alcance sin gastar más.', en: 'Ally with a non-competing brand selling to your same audience — retail furniture suppliers, business schools, marketing agencies, fintechs. Each recommends the other to their clients. Joint Reels, cross-blog, double events. You multiply reach without spending more.', fr: 'Alliez-vous à une marque non concurrente vendant au même public — fournisseurs de mobilier retail, écoles de business, agences marketing, fintechs. Chacun recommande l\'autre à ses clients. Reels conjoints, blog croisé, événement double. Vous multipliez la portée sans dépenser plus.', it: 'Ti allei con un marchio non concorrente che vende al tuo stesso pubblico — fornitori di arredamento retail, business school, agenzie di marketing, fintech. Ciascuno raccomanda l\'altro ai propri clienti. Reel congiunti, blog incrociato, evento doppio. Moltiplichi la portata senza spendere di più.', pt: 'Alie-se com uma marca não concorrente que vende ao mesmo público — fornecedores de mobiliário de varejo, escolas de negócios, agências de marketing, fintechs. Cada um recomenda o outro aos seus clientes. Reels conjuntos, blog cruzado, evento duplo. Multiplica alcance sem gastar mais.' },
  'can.c11.f':   { es: '2-3 alianzas activas', en: '2-3 active alliances', fr: '2-3 alliances actives', it: '2-3 alleanze attive', pt: '2-3 alianças ativas' },

  // Card 12 · Speaking y paneles
  'can.c12.tag': { es: 'Posicionamiento', en: 'Positioning', fr: 'Positionnement', it: 'Posizionamento', pt: 'Posicionamento' },
  'can.c12.t':   { es: 'Speaking y paneles del sector', en: 'Speaking and sector panels', fr: 'Speaking et panels du secteur', it: 'Speaking e panel di settore', pt: 'Speaking e painéis do setor' },
  'can.c12.d':   { es: 'Te postulas como ponente en eventos del sector — congresos retail, foros de mujeres emprendedoras, conferencias de tecnología, encuentros locales. Compartes un caso real (anonimizado o con permiso) de un cliente que usa SACS. La autoridad pública genera más leads que mil cold emails.', en: 'Apply as a speaker at sector events — retail congresses, women entrepreneur forums, tech conferences, local meetings. Share a real (anonymized or with permission) case of a client using SACS. Public authority generates more leads than a thousand cold emails.', fr: 'Postulez comme intervenant dans les événements du secteur — congrès retail, forums femmes entrepreneures, conférences tech, rencontres locales. Partagez un cas réel (anonymisé ou avec permission) d\'un client qui utilise SACS. L\'autorité publique génère plus de leads que mille cold emails.', it: 'Ti candidi come speaker in eventi di settore — congressi retail, forum donne imprenditrici, conferenze tech, incontri locali. Condividi un caso reale (anonimizzato o con permesso) di un cliente che usa SACS. L\'autorità pubblica genera più lead di mille cold email.', pt: 'Candidate-se como palestrante em eventos do setor — congressos de varejo, fóruns de mulheres empreendedoras, conferências de tecnologia, encontros locais. Compartilhe um caso real (anonimizado ou com permissão) de um cliente que usa SACS. A autoridade pública gera mais leads que mil cold emails.' },
  'can.c12.f':   { es: '1-2 ponencias/trimestre', en: '1-2 talks/quarter', fr: '1-2 conférences/trimestre', it: '1-2 talk/trimestre', pt: '1-2 palestras/trimestre' },

  // Card 13 · Tu link en tus perfiles sociales (irá primero en el orden de render)
  'can.c13.tag': { es: 'Tu primera acción', en: 'Your first move', fr: 'Votre première action', it: 'La tua prima mossa', pt: 'Sua primeira ação' },
  'can.c13.t':   { es: 'Tu link en tus perfiles sociales', en: 'Your link on your social profiles', fr: 'Votre lien sur vos profils sociaux', it: 'Il tuo link sui tuoi profili social', pt: 'Seu link nos seus perfis sociais' },
  'can.c13.d':   { es: 'La acción más simple — y la primera que debes hacer. Pones tu link único en la bio de <strong>Instagram, Facebook y LinkedIn</strong>, lo compartes en una story el primer día y desde ahí cada visitante a tu perfil puede llegar a SACS. Cero costo, cero esfuerzo recurrente, máxima visibilidad pasiva.', en: 'The simplest action — and the first one to take. You put your unique link in the bio of <strong>Instagram, Facebook and LinkedIn</strong>, share it in a story on day one, and from there every profile visitor can reach SACS. Zero cost, zero recurring effort, maximum passive visibility.', fr: "L'action la plus simple — et la première à entreprendre. Vous mettez votre lien unique dans la bio d'<strong>Instagram, Facebook et LinkedIn</strong>, le partagez dans une story dès le premier jour, et chaque visiteur de votre profil peut atteindre SACS. Coût zéro, effort récurrent zéro, visibilité passive maximale.", it: "L'azione più semplice — e la prima da fare. Metti il tuo link unico nella bio di <strong>Instagram, Facebook e LinkedIn</strong>, lo condividi in una story il primo giorno e da lì ogni visitatore del tuo profilo può raggiungere SACS. Costo zero, sforzo ricorrente zero, visibilità passiva massima.", pt: 'A ação mais simples — e a primeira a fazer. Você coloca seu link único na bio do <strong>Instagram, Facebook e LinkedIn</strong>, compartilha em uma story no primeiro dia e a partir daí cada visitante do seu perfil pode chegar à SACS. Custo zero, esforço recorrente zero, visibilidade passiva máxima.' },
  'can.c13.f':   { es: '1 vez · visible siempre', en: 'Once · always visible', fr: 'Une fois · toujours visible', it: 'Una volta · sempre visibile', pt: '1 vez · sempre visível' },

  // Card 14 · Campañas publicitarias pagadas (irá segundo en el orden de render)
  'can.c14.tag': { es: 'Tráfico pagado', en: 'Paid traffic', fr: 'Trafic payant', it: 'Traffico a pagamento', pt: 'Tráfego pago' },
  'can.c14.t':   { es: 'Campañas pagadas en Meta y LinkedIn', en: 'Paid ad campaigns on Meta and LinkedIn', fr: 'Campagnes payantes sur Meta et LinkedIn', it: 'Campagne a pagamento su Meta e LinkedIn', pt: 'Campanhas pagas no Meta e LinkedIn' },
  'can.c14.d':   { es: 'Si ya manejas o quieres aprender ad spend, lanzas campañas pagadas en <strong>Meta (Facebook + Instagram)</strong>, <strong>LinkedIn Ads</strong> o TikTok Ads dirigidas a dueños de negocio. Tu link único hace la atribución automática. Es el canal que más rápido escala — pero requiere presupuesto y lectura de métricas semanal.', en: 'If you already run paid ads or want to learn, launch paid campaigns on <strong>Meta (Facebook + Instagram)</strong>, <strong>LinkedIn Ads</strong> or TikTok Ads targeting business owners. Your unique link handles attribution automatically. It\'s the fastest-scaling channel — but it needs budget and weekly metric reading.', fr: 'Si vous gérez déjà ou voulez apprendre les pubs payantes, lancez des campagnes sur <strong>Meta (Facebook + Instagram)</strong>, <strong>LinkedIn Ads</strong> ou TikTok Ads ciblant les chefs d\'entreprise. Votre lien unique gère l\'attribution automatiquement. C\'est le canal qui scale le plus vite — mais demande du budget et une lecture hebdo des métriques.', it: 'Se già gestisci o vuoi imparare ad spend, lanci campagne a pagamento su <strong>Meta (Facebook + Instagram)</strong>, <strong>LinkedIn Ads</strong> o TikTok Ads rivolte a titolari di attività. Il tuo link unico gestisce l\'attribuzione automaticamente. È il canale che scala più rapidamente — ma richiede budget e lettura settimanale delle metriche.', pt: 'Se já gerencia ou quer aprender ad spend, lança campanhas pagas no <strong>Meta (Facebook + Instagram)</strong>, <strong>LinkedIn Ads</strong> ou TikTok Ads direcionadas a donos de negócio. Seu link único faz a atribuição automaticamente. É o canal que mais rápido escala — mas requer orçamento e leitura semanal de métricas.' },
  'can.c14.f':   { es: '$200-2000/mes en ad spend', en: '$200-2000/mo in ad spend', fr: '$200-2000/mois en ad spend', it: '$200-2000/mese in ad spend', pt: '$200-2000/mês em ad spend' },

  // Card 15 · Cursos online (educadores que ya venden cursos)
  'can.c15.tag': { es: 'Educadores', en: 'Educators', fr: 'Éducateurs', it: 'Educatori', pt: 'Educadores' },
  'can.c15.t':   { es: 'Cursos online · SACS como next step', en: 'Online courses · SACS as next step', fr: 'Cours en ligne · SACS comme prochaine étape', it: 'Corsi online · SACS come next step', pt: 'Cursos online · SACS como next step' },
  'can.c15.d':   { es: 'Si ya enseñas un curso online (cómo abrir un negocio, retail moderno, e-commerce, emprendimiento gastronómico, escalar una boutique), <strong>recomiendas SACS como el sistema operativo que tus alumnos adoptan al terminar el curso</strong>. Al alumno le das estructura para aplicar lo aprendido; a SACS le llegan clientes ya pre-formados; tú ganas la comisión directa + la comisión del 10% sobre tu red si certificas a tus mejores alumnos como partners.', en: 'If you already teach an online course (how to open a business, modern retail, e-commerce, restaurant entrepreneurship, scaling a boutique), <strong>you recommend SACS as the operating system your students adopt after finishing the course</strong>. The student gets structure to apply what they learned; SACS gets pre-trained clients; you earn direct commission + your network override if you certify your best students as partners.', fr: 'Si vous enseignez déjà un cours en ligne (comment ouvrir une entreprise, retail moderne, e-commerce, entrepreneuriat gastronomique, scaler une boutique), <strong>vous recommandez SACS comme le système d\'exploitation que vos élèves adoptent à la fin du cours</strong>. L\'élève obtient une structure pour appliquer ce qu\'il a appris ; SACS reçoit des clients pré-formés ; vous gagnez la commission directe + l\'override de votre réseau si vous certifiez vos meilleurs élèves comme partenaires.', it: 'Se già insegni un corso online (come aprire un\'attività, retail moderno, e-commerce, imprenditoria gastronomica, scalare una boutique), <strong>raccomandi SACS come il sistema operativo che i tuoi studenti adottano al termine del corso</strong>. Lo studente ottiene struttura per applicare ciò che ha imparato; SACS riceve clienti già pre-formati; tu guadagni la commissione diretta + l\'override della tua rete se certifichi i tuoi migliori studenti come partner.', pt: 'Se você já ensina um curso online (como abrir um negócio, varejo moderno, e-commerce, empreendedorismo gastronômico, escalar uma boutique), <strong>recomenda a SACS como o sistema operacional que seus alunos adotam ao terminar o curso</strong>. O aluno ganha estrutura para aplicar o que aprendeu; a SACS recebe clientes já pré-formados; você ganha a comissão direta + o override da sua rede se certificar seus melhores alunos como parceiros.' },
  'can.c15.f':   { es: '1+ recomendación por cohorte', en: '1+ recommendation per cohort', fr: '1+ recommandation par cohorte', it: '1+ raccomandazione per coorte', pt: '1+ recomendação por turma' },

  // ─── Tab "Tu crecimiento" · escala de 4 niveles del partner ───
  'grw.eyebrow':   { es: 'Tu trayectoria · 4 niveles', en: 'Your trajectory · 4 levels', fr: 'Votre trajectoire · 4 niveaux', it: 'La tua traiettoria · 4 livelli', pt: 'Sua trajetória · 4 níveis' },
  'grw.title':     { es: 'De referidor a Master Partner.', en: 'From referrer to Master Partner.', fr: 'De référent à Master Partner.', it: 'Da referente a Master Partner.', pt: 'De referenciador a Master Partner.' },
  'grw.lead':      { es: 'No es un solo programa — son <strong>4 niveles</strong> que desbloqueas a tu ritmo. Empiezas como referidor (vendes via link), te certificas para cobrar servicios profesionales, construyes tu propia red de partners, y eventualmente llegas al Founder Circle. Cada nivel puede alcanzarse de forma independiente, pero el orden refleja la trayectoria natural.', en: 'It\'s not one single program — it\'s <strong>4 levels</strong> you unlock at your own pace. You start as a referrer (selling via link), get certified to charge professional services, build your own partner network, and eventually reach the Founder Circle. Each level can be reached independently, but the order reflects the natural trajectory.', fr: 'Ce n\'est pas un seul programme — ce sont <strong>4 niveaux</strong> que vous débloquez à votre rythme. Vous commencez comme référent (vente via lien), vous vous certifiez pour facturer des services pro, construisez votre propre réseau de partenaires, et finissez par rejoindre le Founder Circle. Chaque niveau peut être atteint indépendamment, mais l\'ordre reflète la trajectoire naturelle.', it: 'Non è un singolo programma — sono <strong>4 livelli</strong> che sblocchi al tuo ritmo. Inizi come referente (vendi via link), ti certifichi per fatturare servizi professionali, costruisci la tua rete di partner, e arrivi al Founder Circle. Ogni livello può essere raggiunto in modo indipendente, ma l\'ordine riflette la traiettoria naturale.', pt: 'Não é um único programa — são <strong>4 níveis</strong> que você desbloqueia no seu ritmo. Começa como referenciador (vende via link), se certifica para cobrar serviços profissionais, constrói sua própria rede de parceiros, e eventualmente chega ao Founder Circle. Cada nível pode ser alcançado de forma independente, mas a ordem reflete a trajetória natural.' },

  // Nivel 1 · Partner Referidor
  'grw.l1.lbl':    { es: 'Nivel 01', en: 'Level 01', fr: 'Niveau 01', it: 'Livello 01', pt: 'Nível 01' },
  'grw.l1.name':   { es: 'Partner Referidor', en: 'Referral Partner', fr: 'Partner Référent', it: 'Partner Referente', pt: 'Parceiro Referenciador' },
  'grw.l1.tag':    { es: 'Tu punto de partida', en: 'Your starting point', fr: 'Votre point de départ', it: 'Il tuo punto di partenza', pt: 'Seu ponto de partida' },
  'grw.l1.req':    { es: 'Automático al firmar tu acuerdo de partner.', en: 'Automatic upon signing your partner agreement.', fr: 'Automatique à la signature de votre accord de partenaire.', it: 'Automatico alla firma del tuo accordo di partner.', pt: 'Automático ao assinar seu acordo de parceiro.' },
  'grw.l1.cap':    { es: 'Recomiendas SACS a tu red usando <strong>tu link único</strong>. Cada visitante que llega por tu link queda atribuido a ti automáticamente — sin códigos, sin formularios, sin perder ventas.', en: 'You recommend SACS to your network using <strong>your unique link</strong>. Every visitor arriving via your link is automatically attributed to you — no codes, no forms, no lost sales.', fr: 'Vous recommandez SACS à votre réseau via <strong>votre lien unique</strong>. Chaque visiteur arrivant par votre lien vous est automatiquement attribué — pas de codes, pas de formulaires, pas de ventes perdues.', it: 'Raccomandi SACS alla tua rete usando <strong>il tuo link unico</strong>. Ogni visitatore che arriva dal tuo link viene attribuito a te automaticamente — niente codici, niente moduli, niente vendite perse.', pt: 'Você recomenda a SACS à sua rede usando <strong>seu link único</strong>. Cada visitante que chega pelo seu link fica atribuído a você automaticamente — sem códigos, sem formulários, sem vendas perdidas.' },
  'grw.l1.earn':   { es: '<strong>50% de comisión directa</strong> sobre la primera factura de cada cliente cerrado por tu link, más comisión recurrente mientras el cliente siga activo. En tu portal ves todo el seguimiento: clicks, pruebas gratis activadas, demos agendadas y la fase de cada lead.', en: '<strong>50% direct commission</strong> on the first invoice of every client closed via your link, plus recurring commission while the client stays active. In your portal you see all tracking: clicks, activated free trials, scheduled demos and each lead\'s funnel stage.', fr: '<strong>50% de commission directe</strong> sur la première facture de chaque client conclu via votre lien, plus commission récurrente tant que le client reste actif. Dans votre portail vous voyez tout le suivi : clics, essais gratuits activés, démos planifiées et la phase de chaque lead.', it: '<strong>50% di commissione diretta</strong> sulla prima fattura di ogni cliente chiuso tramite il tuo link, più commissione ricorrente finché il cliente resta attivo. Nel tuo portale vedi tutto il tracciamento: click, prove gratuite attivate, demo prenotate e la fase di ogni lead.', pt: '<strong>50% de comissão direta</strong> sobre a primeira nota fiscal de cada cliente fechado pelo seu link, mais comissão recorrente enquanto o cliente seguir ativo. No seu portal você vê todo o acompanhamento: cliques, testes grátis ativados, demos agendadas e a fase de cada lead.' },

  // Nivel 2 · Partner Certificado
  'grw.l2.lbl':    { es: 'Nivel 02', en: 'Level 02', fr: 'Niveau 02', it: 'Livello 02', pt: 'Nível 02' },
  'grw.l2.name':   { es: 'Partner Certificado', en: 'Certified Partner', fr: 'Partner Certifié', it: 'Partner Certificato', pt: 'Parceiro Certificado' },
  'grw.l2.tag':    { es: 'Especialización profesional', en: 'Professional specialization', fr: 'Spécialisation professionnelle', it: 'Specializzazione professionale', pt: 'Especialização profissional' },
  'grw.l2.req':    { es: 'Completa al menos <strong>1 de las 5 certificaciones SACS</strong> (Implementación · 1 sucursal, Multisucursal, Migración de datos, Automatización con IA, Consultor en IA).', en: 'Complete at least <strong>1 of the 5 SACS certifications</strong> (Implementation · 1 store, Multi-store, Data migration, AI automation, AI consultant).', fr: 'Complétez au moins <strong>1 des 5 certifications SACS</strong> (Implémentation · 1 boutique, Multi-boutiques, Migration de données, Automatisation IA, Consultant IA).', it: 'Completa almeno <strong>1 delle 5 certificazioni SACS</strong> (Implementazione · 1 negozio, Multi-negozio, Migrazione dati, Automazione IA, Consulente IA).', pt: 'Complete pelo menos <strong>1 das 5 certificações SACS</strong> (Implementação · 1 loja, Multi-loja, Migração de dados, Automação com IA, Consultor em IA).' },
  'grw.l2.cap':    { es: 'Además de recomendar via link, <strong>cobras servicios profesionales</strong> directamente a tus clientes: implementaciones, migraciones, configuraciones avanzadas, automatizaciones, consultoría. Sin certificación no se pueden ofrecer estos servicios — con ella, te conviertes en el experto local de SACS.', en: 'Beyond recommending via link, you <strong>charge professional services</strong> directly to your clients: implementations, migrations, advanced configurations, automations, consulting. Without certification these services can\'t be offered — with it, you become the local SACS expert.', fr: 'En plus de la recommandation via lien, vous <strong>facturez des services professionnels</strong> directement à vos clients : implémentations, migrations, configurations avancées, automatisations, conseil. Sans certification ces services ne peuvent être offerts — avec elle, vous devenez l\'expert SACS local.', it: 'Oltre alla raccomandazione via link, <strong>fatturi servizi professionali</strong> direttamente ai tuoi clienti: implementazioni, migrazioni, configurazioni avanzate, automazioni, consulenza. Senza certificazione questi servizi non si possono offrire — con essa, diventi l\'esperto SACS locale.', pt: 'Além de recomendar via link, você <strong>cobra serviços profissionais</strong> diretamente dos seus clientes: implementações, migrações, configurações avançadas, automações, consultoria. Sem certificação estes serviços não podem ser oferecidos — com ela, você se torna o especialista local da SACS.' },
  'grw.l2.earn':   { es: 'Todo lo del Nivel 01 · + <strong>100% del cobro al cliente final</strong> por cada servicio profesional (SACS solo cobra una vez la cuota inicial de la certificación, no comisión sobre tus servicios)', en: 'Everything from Level 01 · + <strong>100% of the end-client charge</strong> for each professional service (SACS only charges the initial certification fee once, no commission on your services)', fr: 'Tout du Niveau 01 · + <strong>100% de la facturation au client final</strong> pour chaque service professionnel (SACS ne facture qu\'une seule fois les frais initiaux de certification, aucune commission sur vos services)', it: 'Tutto del Livello 01 · + <strong>100% dell\'addebito al cliente finale</strong> per ogni servizio professionale (SACS addebita solo una volta la quota iniziale della certificazione, nessuna commissione sui tuoi servizi)', pt: 'Tudo do Nível 01 · + <strong>100% da cobrança ao cliente final</strong> por cada serviço profissional (a SACS só cobra uma vez a taxa inicial da certificação, sem comissão sobre seus serviços)' },

  // Nivel 3 · Master Partner (4 sub-niveles según tamaño de red)
  'grw.l3.lbl':    { es: 'Nivel 03', en: 'Level 03', fr: 'Niveau 03', it: 'Livello 03', pt: 'Nível 03' },
  'grw.l3.name':   { es: 'Master Partner', en: 'Master Partner', fr: 'Master Partner', it: 'Master Partner', pt: 'Master Partner' },
  'grw.l3.tag':    { es: '4 sub-niveles · escala con tu red', en: '4 sub-levels · scale with your network', fr: '4 sous-niveaux · scaler avec votre réseau', it: '4 sotto-livelli · scala con la tua rete', pt: '4 sub-níveis · escale com sua rede' },
  'grw.l3.req':    { es: 'Tu sub-nivel de Master Partner crece automáticamente con el tamaño de tu red: <strong>Nv 1</strong> a 5 sucursales activas vendidas, <strong>Nv 2</strong> a 10, <strong>Nv 3</strong> a 20, <strong>Nv 4</strong> a 50+ (ilimitado). Cada sub-nivel desbloquea más invitaciones para meter nuevos partners.', en: 'Your Master Partner sub-level grows automatically with the size of your network: <strong>Nv 1</strong> at 5 active stores sold, <strong>Nv 2</strong> at 10, <strong>Nv 3</strong> at 20, <strong>Nv 4</strong> at 50+ (unlimited). Each sub-level unlocks more invitations to bring in new partners.', fr: 'Votre sous-niveau Master Partner grandit automatiquement avec la taille de votre réseau : <strong>Nv 1</strong> à 5 boutiques actives vendues, <strong>Nv 2</strong> à 10, <strong>Nv 3</strong> à 20, <strong>Nv 4</strong> à 50+ (illimité). Chaque sous-niveau débloque plus d\'invitations pour faire entrer de nouveaux partenaires.', it: 'Il tuo sotto-livello di Master Partner cresce automaticamente con la dimensione della tua rete: <strong>Nv 1</strong> a 5 negozi attivi venduti, <strong>Nv 2</strong> a 10, <strong>Nv 3</strong> a 20, <strong>Nv 4</strong> a 50+ (illimitato). Ogni sotto-livello sblocca più inviti per portare nuovi partner.', pt: 'Seu sub-nível de Master Partner cresce automaticamente com o tamanho da sua rede: <strong>Nv 1</strong> a 5 lojas ativas vendidas, <strong>Nv 2</strong> a 10, <strong>Nv 3</strong> a 20, <strong>Nv 4</strong> a 50+ (ilimitado). Cada sub-nível desbloqueia mais convites para trazer novos parceiros.' },
  'grw.l3.cap':    { es: 'Invitas <strong>otros partners</strong> a la red SACS bajo tu mentoría como <strong>Master Partner</strong>. Tu red crece contigo — cada partner invitado firma su propio acuerdo, mantiene sus propios compromisos, y tú asumes su onboarding inicial y mantenimiento del estándar de marca dentro de tu red.', en: 'You invite <strong>other partners</strong> into the SACS network under your mentorship as a <strong>Master Partner</strong>. Your network grows with you — each invited partner signs their own agreement, meets their own commitments, and you handle their initial onboarding and uphold the brand standard within your network.', fr: 'Vous invitez <strong>d\'autres partenaires</strong> au réseau SACS sous votre mentorat en tant que <strong>Master Partner</strong>. Votre réseau grandit avec vous — chaque partenaire invité signe son propre accord, respecte ses propres engagements, et vous gérez son onboarding initial et le standard de marque dans votre réseau.', it: 'Inviti <strong>altri partner</strong> nella rete SACS sotto la tua mentorship come <strong>Master Partner</strong>. La tua rete cresce con te — ogni partner invitato firma il proprio accordo, rispetta i propri impegni, e tu gestisci il suo onboarding iniziale e lo standard di marchio nella tua rete.', pt: 'Você convida <strong>outros parceiros</strong> à rede SACS sob sua mentoria como <strong>Master Partner</strong>. Sua rede cresce com você — cada parceiro convidado assina seu próprio acordo, mantém seus próprios compromissos, e você assume seu onboarding inicial e a manutenção do padrão de marca na sua rede.' },
  'grw.l3.earn':   { es: 'Todo lo del Nivel 02 · + <strong>10% sobre todo lo que tu red venda</strong> (pagado por SACS, sin descontar nada del 50% directo de tu invitado) · ver tab "Expande tu red" para ejemplos numéricos por sub-nivel · Master Partner Nv 4 sostenido 12 meses te abre el Nivel 04', en: 'Everything from Level 02 · + <strong>10% override on everything your network sells</strong> (paid by SACS, with nothing deducted from your invitee\'s 50%) · see the "Expand your network" tab for sub-level examples · Master Partner Nv 4 sustained for 12 months unlocks Level 04', fr: 'Tout du Niveau 02 · + <strong>10% override sur tout ce que votre réseau vend</strong> (payé par SACS, sans rien déduire des 50% de votre invité) · voir l\'onglet « Étendez votre réseau » pour les exemples par sous-niveau · Master Partner Nv 4 maintenu 12 mois ouvre le Niveau 04', it: 'Tutto del Livello 02 · + <strong>10% override su tutto ciò che la tua rete vende</strong> (pagato da SACS, senza scalare nulla dal 50% del tuo invitato) · vedi la scheda "Espandi la tua rete" per esempi per sotto-livello · Master Partner Nv 4 sostenuto 12 mesi apre il Livello 04', pt: 'Tudo do Nível 02 · + <strong>10% sobre tudo o que sua rede vende</strong> (pago pela SACS, sem descontar nada dos 50% do seu convidado) · ver a aba "Expanda sua rede" para exemplos por sub-nível · Master Partner Nv 4 sustentado 12 meses abre o Nível 04' },

  // Sub-pills de Master Partner (chips dentro del card de L3)
  'grw.l3.sub.nv1.lbl':  { es: 'Nv 1', en: 'Nv 1', fr: 'Nv 1', it: 'Nv 1', pt: 'Nv 1' },
  'grw.l3.sub.nv1.meta': { es: '5 sucursales · 5 invitaciones', en: '5 stores · 5 invitations', fr: '5 boutiques · 5 invitations', it: '5 negozi · 5 inviti', pt: '5 lojas · 5 convites' },
  'grw.l3.sub.nv2.lbl':  { es: 'Nv 2', en: 'Nv 2', fr: 'Nv 2', it: 'Nv 2', pt: 'Nv 2' },
  'grw.l3.sub.nv2.meta': { es: '10 sucursales · 10 invitaciones', en: '10 stores · 10 invitations', fr: '10 boutiques · 10 invitations', it: '10 negozi · 10 inviti', pt: '10 lojas · 10 convites' },
  'grw.l3.sub.nv3.lbl':  { es: 'Nv 3', en: 'Nv 3', fr: 'Nv 3', it: 'Nv 3', pt: 'Nv 3' },
  'grw.l3.sub.nv3.meta': { es: '20 sucursales · 20 invitaciones', en: '20 stores · 20 invitations', fr: '20 boutiques · 20 invitations', it: '20 negozi · 20 inviti', pt: '20 lojas · 20 convites' },
  'grw.l3.sub.nv4.lbl':  { es: 'Nv 4', en: 'Nv 4', fr: 'Nv 4', it: 'Nv 4', pt: 'Nv 4' },
  'grw.l3.sub.nv4.meta': { es: '50+ sucursales · invitaciones ilimitadas', en: '50+ stores · unlimited invitations', fr: '50+ boutiques · invitations illimitées', it: '50+ negozi · inviti illimitati', pt: '50+ lojas · convites ilimitados' },

  // Nivel 4 · Master Partner
  'grw.l4.lbl':    { es: 'Nivel 04 · Top tier', en: 'Level 04 · Top tier', fr: 'Niveau 04 · Top tier', it: 'Livello 04 · Top tier', pt: 'Nível 04 · Top tier' },
  'grw.l4.name':   { es: 'Master Partner · Founder Circle', en: 'Master Partner · Founder Circle', fr: 'Master Partner · Founder Circle', it: 'Master Partner · Founder Circle', pt: 'Master Partner · Founder Circle' },
  'grw.l4.tag':    { es: 'El círculo del founder', en: 'The founder\'s circle', fr: 'Le cercle du founder', it: 'Il cerchio del founder', pt: 'O círculo do founder' },
  'grw.l4.req':    { es: 'Alcanzas <strong>Master Partner Nv 4</strong> (50+ sucursales activas) y sostienes ese estatus por <strong>12 meses consecutivos</strong>. El límite ya no es numérico — es excelencia operativa demostrada.', en: 'You reach <strong>Master Partner Nv 4</strong> (50+ active stores) and sustain that status for <strong>12 consecutive months</strong>. The limit is no longer numeric — it\'s proven operational excellence.', fr: 'Vous atteignez <strong>Master Partner Nv 4</strong> (50+ boutiques actives) et maintenez ce statut pendant <strong>12 mois consécutifs</strong>. La limite n\'est plus numérique — c\'est l\'excellence opérationnelle prouvée.', it: 'Raggiungi <strong>Master Partner Nv 4</strong> (50+ negozi attivi) e mantieni questo status per <strong>12 mesi consecutivi</strong>. Il limite non è più numerico — è l\'eccellenza operativa dimostrata.', pt: 'Você alcança <strong>Master Partner Nv 4</strong> (50+ lojas ativas) e sustenta esse status por <strong>12 meses consecutivos</strong>. O limite já não é numérico — é a excelência operacional comprovada.' },
  'grw.l4.cap':    { es: 'Acceso al <strong>Founder Circle</strong> de SACS: voz directa en el roadmap del producto, asistencia a eventos privados y retiros con el equipo fundador, acceso anticipado a features y módulos antes del mercado.', en: 'Access to the SACS <strong>Founder Circle</strong>: direct voice on the product roadmap, attendance at private events and retreats with the founding team, early access to features and modules before the market.', fr: 'Accès au <strong>Founder Circle</strong> de SACS : voix directe sur la roadmap produit, participation à des événements privés et retraites avec l\'équipe fondatrice, accès anticipé aux fonctionnalités et modules avant le marché.', it: 'Accesso al <strong>Founder Circle</strong> di SACS: voce diretta sulla roadmap di prodotto, partecipazione a eventi privati e retreat con il team fondatore, accesso anticipato a feature e moduli prima del mercato.', pt: 'Acesso ao <strong>Founder Circle</strong> da SACS: voz direta no roadmap do produto, presença em eventos privados e retiros com o time fundador, acesso antecipado a features e módulos antes do mercado.' },
  'grw.l4.earn':   { es: 'Todo lo del Nivel 03 con <strong>comisión sin tope</strong> sobre tu red completa.', en: 'Everything from Level 03 with <strong>unlimited override</strong> on your full network.', fr: 'Tout du Niveau 03 avec <strong>override illimité</strong> sur l\'ensemble de votre réseau.', it: 'Tutto del Livello 03 con <strong>override illimitato</strong> sull\'intera tua rete.', pt: 'Tudo do Nível 03 com <strong>comisión sin tope</strong> sobre toda sua rede.' },

  // Footer CTA
  'grw.cta.eyebrow': { es: 'Al firmar arrancas en Nivel 01', en: 'You start at Level 01 upon signing', fr: 'À la signature vous commencez au Niveau 01', it: 'Alla firma inizi al Livello 01', pt: 'Ao assinar você começa no Nível 01' },
  'grw.cta.body':    { es: 'No es un examen ni una entrevista. Firmas el acuerdo, recibes tu link único, y desde ese momento eres <strong>Partner Referidor</strong>. El resto del camino — certificaciones, red, Founder Circle — lo construyes a tu ritmo, con la profundidad y velocidad que tú decidas.', en: 'It\'s not an exam or interview. You sign the agreement, receive your unique link, and from that moment you are a <strong>Referral Partner</strong>. The rest of the path — certifications, network, Founder Circle — you build at your own pace, with the depth and speed you decide.', fr: 'Ce n\'est pas un examen ni un entretien. Vous signez l\'accord, recevez votre lien unique, et dès ce moment vous êtes <strong>Partner Référent</strong>. Le reste du parcours — certifications, réseau, Founder Circle — vous le construisez à votre rythme, avec la profondeur et la vitesse que vous décidez.', it: 'Non è un esame né un colloquio. Firmi l\'accordo, ricevi il tuo link unico, e da quel momento sei <strong>Partner Referente</strong>. Il resto del cammino — certificazioni, rete, Founder Circle — lo costruisci al tuo ritmo, con la profondità e velocità che decidi tu.', pt: 'Não é um exame nem entrevista. Você assina o acordo, recebe seu link único, e desde esse momento é <strong>Parceiro Referenciador</strong>. O resto do caminho — certificações, rede, Founder Circle — você constrói no seu ritmo, com a profundidade e velocidade que decidir.' },

  // ─── Tab "Expande tu red" · sistema de milestones de network expansion ───
  'red.eyebrow':   { es: 'Master Partner · 4 sub-niveles', en: 'Master Partner · 4 sub-levels', fr: 'Master Partner · 4 sous-niveaux', it: 'Master Partner · 4 sotto-livelli', pt: 'Master Partner · 4 sub-níveis' },
  'red.title':     { es: 'Tu red crece contigo.', en: 'Your network grows with you.', fr: 'Votre réseau grandit avec vous.', it: 'La tua rete cresce con te.', pt: 'Sua rede cresce com você.' },
  'red.lead':      { es: 'Cuando demuestres tracción real con tus propios clientes, te abrimos la puerta a <strong>invitar a otros partners</strong> a la red SACS — y a ganar el <strong>10% de todo lo que ellos vendan</strong>. Cada hito de sucursales activas desbloquea más invitaciones (5 → 10 → 20 → ilimitado), y tu comisión del 10% sobre tu red crece con cada partner que sumas.', en: 'Once you prove real traction with your own clients, we open the door for you to <strong>invite other partners</strong> into the SACS network — and to earn <strong>10% of everything they sell</strong>. Each active-store milestone unlocks more invitations (5 → 10 → 20 → unlimited), and your 10% override grows with every partner you add.', fr: 'Une fois que vous prouverez une traction réelle avec vos propres clients, nous vous ouvrons la porte pour <strong>inviter d\'autres partenaires</strong> au réseau SACS — et gagner le <strong>10% de tout ce qu\'ils vendent</strong>. Chaque palier de boutiques actives débloque plus d\'invitations (5 → 10 → 20 → illimité), et votre override de 10% grandit avec chaque partenaire que vous ajoutez.', it: 'Quando dimostri vera trazione con i tuoi clienti, ti apriamo la porta a <strong>invitare altri partner</strong> nella rete SACS — e a guadagnare il <strong>10% di tutto ciò che vendono</strong>. Ogni milestone di negozi attivi sblocca più inviti (5 → 10 → 20 → illimitato), e il tuo 10% override cresce con ogni partner che aggiungi.', pt: 'Quando demonstrar tração real com seus próprios clientes, te abrimos a porta para <strong>convidar outros parceiros</strong> à rede SACS — e ganhar <strong>10% de tudo o que eles vendem</strong>. Cada marco de lojas ativas desbloqueia mais convites (5 → 10 → 20 → ilimitado), e seu 10% override cresce com cada parceiro que adiciona.' },

  // 4 sub-niveles de Master Partner (cada uno: tag con nivel, title con identidad, desc explicación)
  'red.t1.tag':    { es: 'Master Partner Nv 1', en: 'Master Partner Nv 1', fr: 'Master Partner Nv 1', it: 'Master Partner Nv 1', pt: 'Master Partner Nv 1' },
  'red.t1.title':  { es: 'Tu primer círculo', en: 'Your inner circle', fr: 'Votre premier cercle', it: 'Il tuo primo cerchio', pt: 'Seu primeiro círculo' },
  'red.t1.desc':   { es: 'Cuando llegues a 5 sucursales activas vendidas por ti, te conviertes en <strong>Master Partner Nv 1</strong> — desbloqueas 5 invitaciones para meter a tus primeros partners — gente cercana y de confianza con potencial real.', en: 'When you hit 5 active stores sold by you, you become a <strong>Master Partner Nv 1</strong> — unlocking 5 invitations to bring in your first partners — close, trusted people with real potential.', fr: 'Lorsque vous atteignez 5 boutiques actives vendues par vous, vous devenez <strong>Master Partner Nv 1</strong> — vous débloquez 5 invitations pour faire entrer vos premiers partenaires — des proches de confiance avec un vrai potentiel.', it: 'Quando arrivi a 5 negozi attivi venduti da te, diventi <strong>Master Partner Nv 1</strong> — sblocchi 5 inviti per portare i tuoi primi partner — persone vicine e fidate con potenziale reale.', pt: 'Quando chegar a 5 lojas ativas vendidas por você, se torna <strong>Master Partner Nv 1</strong> — desbloqueia 5 convites para trazer seus primeiros parceiros — pessoas próximas e de confiança com potencial real.' },

  'red.t2.tag':    { es: 'Master Partner Nv 2', en: 'Master Partner Nv 2', fr: 'Master Partner Nv 2', it: 'Master Partner Nv 2', pt: 'Master Partner Nv 2' },
  'red.t2.title':  { es: 'Tu equipo en formación', en: 'Your team taking shape', fr: 'Votre équipe en formation', it: 'Il tuo team in formazione', pt: 'Seu time em formação' },
  'red.t2.desc':   { es: 'Con 10 sucursales activas subes a <strong>Master Partner Nv 2</strong> y tienes hasta 10 invitaciones disponibles. Tu primer círculo ya está dando frutos — ahora extiendes la red a más colegas, antiguos compañeros de trabajo, gente recomendada por tu primer círculo.', en: 'With 10 active stores you reach <strong>Master Partner Nv 2</strong> and have up to 10 invitations. Your inner circle is bearing fruit — now you extend the network to more peers, ex-coworkers, people referred by your first circle.', fr: 'Avec 10 boutiques actives vous passez à <strong>Master Partner Nv 2</strong> et disposez de 10 invitations. Votre premier cercle porte ses fruits — vous étendez maintenant le réseau à plus de collègues, anciens collaborateurs, personnes recommandées par votre premier cercle.', it: 'Con 10 negozi attivi sali a <strong>Master Partner Nv 2</strong> e hai fino a 10 inviti disponibili. Il tuo primo cerchio sta dando frutti — ora estendi la rete a più colleghi, ex collaboratori, persone raccomandate dal tuo primo cerchio.', pt: 'Com 10 lojas ativas você sobe a <strong>Master Partner Nv 2</strong> e tem até 10 convites disponíveis. Seu primeiro círculo já está dando frutos — agora estende a rede a mais colegas, ex-colaboradores, pessoas recomendadas pelo seu primeiro círculo.' },

  'red.t3.tag':    { es: 'Master Partner Nv 3', en: 'Master Partner Nv 3', fr: 'Master Partner Nv 3', it: 'Master Partner Nv 3', pt: 'Master Partner Nv 3' },
  'red.t3.title':  { es: 'Tu red establecida', en: 'Your established network', fr: 'Votre réseau établi', it: 'La tua rete affermata', pt: 'Sua rede estabelecida' },
  'red.t3.desc':   { es: 'Con 20 sucursales activas alcanzas <strong>Master Partner Nv 3</strong> y desbloqueas 20 invitaciones. Aquí ya no eres solo partner — eres referente de tu sector. Tu red empieza a tener impacto medible en el ecosistema SACS y en el mercado regional.', en: 'With 20 active stores you reach <strong>Master Partner Nv 3</strong> and unlock 20 invitations. Here you\'re no longer just a partner — you\'re a reference in your sector. Your network starts having measurable impact on the SACS ecosystem and the regional market.', fr: 'Avec 20 boutiques actives vous atteignez <strong>Master Partner Nv 3</strong> et débloquez 20 invitations. Ici, vous n\'êtes plus juste un partenaire — vous êtes une référence de votre secteur. Votre réseau commence à avoir un impact mesurable sur l\'écosystème SACS et le marché régional.', it: 'Con 20 negozi attivi raggiungi <strong>Master Partner Nv 3</strong> e sblocchi 20 inviti. Qui non sei più solo partner — sei un punto di riferimento del tuo settore. La tua rete inizia ad avere impatto misurabile sull\'ecosistema SACS e sul mercato regionale.', pt: 'Com 20 lojas ativas você alcança <strong>Master Partner Nv 3</strong> e desbloqueia 20 convites. Aqui você já não é só parceiro — é referência do seu setor. Sua rede começa a ter impacto mensurável no ecossistema SACS e no mercado regional.' },

  'red.t4.tag':    { es: 'Master Partner Nv 4', en: 'Master Partner Nv 4', fr: 'Master Partner Nv 4', it: 'Master Partner Nv 4', pt: 'Master Partner Nv 4' },
  'red.t4.title':  { es: 'Sin límite', en: 'No limit', fr: 'Sans limite', it: 'Senza limite', pt: 'Sem limite' },
  'red.t4.desc':   { es: 'Pasados los 50 sucursales activas alcanzas <strong>Master Partner Nv 4</strong> — el sub-nivel más alto, sin tope: invitas a las personas que tú decidas, sin límite numérico. Y tu 10% sobre todo lo que tu red venda escala sin techo. Sostenido por 12 meses, te abre el <strong>Nivel 04 · Founder Circle</strong>.', en: 'Past 50 active stores you reach <strong>Master Partner Nv 4</strong> — the highest sub-level, no cap: you invite whoever you choose, no numeric limit. And your 10% override on everything your network sells scales with no ceiling. Sustained for 12 months, it unlocks <strong>Level 04 · Founder Circle</strong>.', fr: 'Au-delà de 50 boutiques actives vous atteignez <strong>Master Partner Nv 4</strong> — le plus haut sous-niveau, sans plafond : vous invitez qui vous voulez, sans limite numérique. Et votre override de 10% sur tout ce que vend votre réseau grimpe sans plafond. Maintenu 12 mois, il ouvre le <strong>Niveau 04 · Founder Circle</strong>.', it: 'Oltre i 50 negozi attivi raggiungi <strong>Master Partner Nv 4</strong> — il sotto-livello più alto, senza tetto: inviti chi decidi tu, senza limite numerico. E il tuo 10% override su tutto ciò che vende la tua rete scala senza tetto. Sostenuto per 12 mesi, apre il <strong>Livello 04 · Founder Circle</strong>.', pt: 'Passados 50 lojas ativas alcança <strong>Master Partner Nv 4</strong> — o sub-nível mais alto, sem teto: você convida quem quiser, sem limite numérico. E seu 10% sobre tudo o que sua rede vende escala sem teto. Sustentado 12 meses, abre o <strong>Nível 04 · Founder Circle</strong>.' },

  // Cómo funciona
  'red.how.eyebrow': { es: 'Cómo funciona', en: 'How it works', fr: 'Comment ça marche', it: 'Come funziona', pt: 'Como funciona' },
  'red.how.title':   { es: 'Tu red, tus reglas. Pero con estándar.', en: 'Your network, your rules. With a standard.', fr: 'Votre réseau, vos règles. Avec un standard.', it: 'La tua rete, le tue regole. Con uno standard.', pt: 'Sua rede, suas regras. Com padrão.' },
  'red.how.r1':      { es: '<strong>Cada partner que invitas firma su propio acuerdo</strong> con SACS y cumple sus propios compromisos (100 puntos al mes, conducta, certificación si aplica).', en: '<strong>Each partner you invite signs their own agreement</strong> with SACS and meets their own commitments (100 points per month, conduct, certification if applicable).', fr: '<strong>Chaque partenaire que vous invitez signe son propre accord</strong> avec SACS et respecte ses propres engagements (100 points par mois, conduite, certification si applicable).', it: '<strong>Ogni partner che inviti firma il proprio accordo</strong> con SACS e rispetta i propri impegni (100 punti al mese, condotta, certificazione se applicabile).', pt: '<strong>Cada parceiro que você convida assina seu próprio acordo</strong> com a SACS e cumpre seus próprios compromissos (100 pontos por mês, conduta, certificação se aplicável).' },
  'red.how.r2':      { es: '<strong>Eres responsable del primer onboarding</strong> de cada partner que invitas: presentárselo al equipo SACS, ayudarlo a entender el programa y velar por que mantenga el estándar de marca dentro de tu red.', en: '<strong>You\'re responsible for the first onboarding</strong> of each partner you invite: introducing them to the SACS team, helping them understand the program and ensuring they hold the brand standard within your network.', fr: '<strong>Vous êtes responsable du premier onboarding</strong> de chaque partenaire que vous invitez : le présenter à l\'équipe SACS, l\'aider à comprendre le programme et veiller à ce qu\'il maintienne le standard de marque dans votre réseau.', it: '<strong>Sei responsabile del primo onboarding</strong> di ogni partner che inviti: presentarlo al team SACS, aiutarlo a comprendere il programma e vigilare che mantenga lo standard di marchio nella tua rete.', pt: '<strong>Você é responsável pelo primeiro onboarding</strong> de cada parceiro que convida: apresentá-lo ao time SACS, ajudá-lo a entender o programa e zelar para que mantenha o padrão de marca na sua rede.' },
  'red.how.r3':      { es: '<strong>Cada partner mantiene íntegro su 50% directo</strong> sobre las ventas que cierra. Tú adicional ganas un <strong>10% sobre todo lo que tu red venda</strong> — pagado por SACS, sin descontar nada del 50% de tu invitado. Es ingreso pasivo escalable que crece con tu red.', en: '<strong>Each partner keeps their full 50% direct commission</strong> on the sales they close. You additionally earn a <strong>10% override on everything your network sells</strong> — paid by SACS, with nothing deducted from your invitee\'s 50%. Scalable passive income that grows with your network.', fr: '<strong>Chaque partenaire conserve l\'intégralité de sa commission directe de 50%</strong> sur les ventes qu\'il conclut. Vous gagnez en plus un <strong>override de 10% sur tout ce que vend votre réseau</strong> — payé par SACS, sans rien déduire des 50% de votre invité. Revenu passif scalable qui grandit avec votre réseau.', it: '<strong>Ogni partner mantiene integro il suo 50% diretto</strong> sulle vendite che chiude. Tu in più guadagni un <strong>10% override su tutto ciò che vende la tua rete</strong> — pagato da SACS, senza scalare nulla dal 50% del tuo invitato. Reddito passivo scalabile che cresce con la tua rete.', pt: '<strong>Cada parceiro mantém íntegra sua comissão direta de 50%</strong> sobre as vendas que fecha. Você adicional ganha um <strong>10% sobre tudo o que sua rede vende</strong> — pago pela SACS, sem descontar nada dos 50% do seu convidado. Renda passiva escalável que cresce com sua rede.' },
  'red.how.r4':      { es: '<strong>SACS valida cada invitación.</strong> No basta con enviar el link — cada invitado pasa por el mismo proceso de revisión que tú pasaste. Si no encaja con el programa, se rechaza con respeto.', en: '<strong>SACS validates every invitation.</strong> Sending the link isn\'t enough — each invitee goes through the same review process you went through. If they don\'t fit the program, they\'re respectfully declined.', fr: '<strong>SACS valide chaque invitation.</strong> Envoyer le lien ne suffit pas — chaque invité passe par le même processus de revue que vous. S\'il ne correspond pas au programme, il est respectueusement refusé.', it: '<strong>SACS valida ogni invito.</strong> Non basta inviare il link — ogni invitato passa per lo stesso processo di revisione che hai fatto tu. Se non si adatta al programma, viene rifiutato con rispetto.', pt: '<strong>A SACS valida cada convite.</strong> Não basta enviar o link — cada convidado passa pelo mesmo processo de revisão que você passou. Se não encaixar no programa, é recusado com respeito.' },

  // Override 10% sobre la red
  'red.ben.eyebrow':   { es: 'Lo que ganas tú', en: 'What you earn', fr: 'Ce que vous gagnez', it: 'Cosa guadagni tu', pt: 'O que você ganha' },
  'red.ben.title':     { es: '10% de todo lo que tu red venda.', en: '10% of everything your network sells.', fr: '10% de tout ce que vend votre réseau.', it: '10% di tutto ciò che la tua rete vende.', pt: '10% de tudo o que sua rede vende.' },
  'red.ben.lead':      { es: 'Por cada cliente que tu red de partners cierra, recibes el <strong>10% del cobro</strong> — pagado directamente por SACS. Tu red mantiene su 50% íntegro; tu 10% es <strong>adicional, no sale de su comisión</strong>. Es ingreso pasivo escalable que crece con cada partner que invitas.', en: 'For every client your partner network closes, you receive <strong>10% of the charge</strong> — paid directly by SACS. Your network keeps their full 50%; your 10% is <strong>additional, not deducted from their commission</strong>. Scalable passive income that grows with every partner you invite.', fr: 'Pour chaque client que votre réseau de partenaires conclut, vous recevez <strong>10% de la facturation</strong> — payé directement par SACS. Votre réseau conserve l\'intégralité de ses 50% ; votre 10% est <strong>additionnel, non déduit de leur commission</strong>. Revenu passif scalable qui grandit avec chaque partenaire que vous invitez.', it: 'Per ogni cliente che la tua rete di partner chiude, ricevi il <strong>10% dell\'addebito</strong> — pagato direttamente da SACS. La tua rete mantiene il 50% integro; il tuo 10% è <strong>aggiuntivo, non scalato dalla loro commissione</strong>. Reddito passivo scalabile che cresce con ogni partner che inviti.', pt: 'Para cada cliente que sua rede de parceiros fecha, você recebe <strong>10% da cobrança</strong> — pago diretamente pela SACS. Sua rede mantém seus 50% íntegros; seu 10% é <strong>adicional, não descontado da comissão deles</strong>. Renda passiva escalável que cresce com cada parceiro que você convida.' },

  // Cards de ejemplo (usan los valores precomputados en frontmatter — overrideExamples)
  'red.ex.partners':   { es: 'partners en tu red', en: 'partners in your network', fr: 'partenaires dans votre réseau', it: 'partner nella tua rete', pt: 'parceiros na sua rede' },
  'red.ex.suffix':     { es: 'adicionales pasivos', en: 'additional passive', fr: 'additionnels passifs', it: 'aggiuntivi passivi', pt: 'adicionais passivos' },
  'red.ex.month':      { es: '/ mes', en: '/ month', fr: '/ mois', it: '/ mese', pt: '/ mês' },
  'red.ex.year':       { es: '/ año', en: '/ year', fr: '/ an', it: '/ anno', pt: '/ ano' },
  'red.ex.detail':     { es: 'Tu red vende {stores} sucursales/año (promedio {perPartner} por partner) × plan promedio = {gross} cobrado · 10% sobre tu red.', en: 'Your network sells {stores} stores/year (avg {perPartner} per partner) × average plan = {gross} charged · 10% sobre tu red.', fr: 'Votre réseau vend {stores} boutiques/an (moy. {perPartner} par partenaire) × plan moyen = {gross} facturé · 10% sobre tu red.', it: 'La tua rete vende {stores} negozi/anno (media {perPartner} per partner) × piano medio = {gross} addebitato · 10% sobre tu red.', pt: 'Sua rede vende {stores} lojas/ano (média {perPartner} por parceiro) × plano médio = {gross} cobrado · 10% sobre tu red.' },
  'red.ex.legal':      { es: '* Cifras de referencia con plan promedio Plan Fideliza ($14,000 MXN/año). Las ventas reales y los pagos se reportan en MXN; otras monedas son referenciales.', en: '* Reference figures using avg Fideliza Plan ($14,000 MXN/year). Actual sales and payments are reported in MXN; other currencies are referential.', fr: '* Chiffres de référence avec le Plan Fideliza moyen (14 000 MXN/an). Les ventes et paiements réels sont déclarés en MXN ; les autres monnaies sont indicatives.', it: '* Cifre di riferimento con il Piano Fideliza medio ($14.000 MXN/anno). Vendite e pagamenti reali sono segnalati in MXN; le altre valute sono di riferimento.', pt: '* Cifras de referência com o Plano Fideliza médio ($14.000 MXN/ano). As vendas e pagamentos reais são reportados em MXN; outras moedas são referenciais.' },

  // Footer note · cómo arrancar
  'red.cta.eyebrow': { es: 'Cuando llegues al hito 1', en: 'When you reach milestone 1', fr: 'Quand vous atteindrez le palier 1', it: 'Quando raggiungi il milestone 1', pt: 'Quando chegar ao marco 1' },
  'red.cta.body':    { es: 'Tu portal de Partner reflejará automáticamente las invitaciones desbloqueadas. Desde ahí generas el link de invitación de cada nuevo partner — SACS valida y activa.', en: 'Your Partner portal will automatically reflect the unlocked invitations. From there you generate the invitation link for each new partner — SACS validates and activates.', fr: 'Votre portail Partenaire reflétera automatiquement les invitations débloquées. De là vous générez le lien d\'invitation de chaque nouveau partenaire — SACS valide et active.', it: 'Il tuo portale Partner rifletterà automaticamente gli inviti sbloccati. Da lì generi il link d\'invito di ogni nuovo partner — SACS valida e attiva.', pt: 'Seu portal de Parceiro refletirá automaticamente os convites desbloqueados. A partir daí você gera o link de convite de cada novo parceiro — a SACS valida e ativa.' },

  // Antes / Después split
  'red.ba.eyebrow':  { es: 'Antes vs después', en: 'Before vs after', fr: 'Avant vs après', it: 'Prima vs dopo', pt: 'Antes vs depois' },
  'red.ba.title':    { es: 'De solitario a constructor de red.', en: 'From solo to network builder.', fr: 'De solo à bâtisseur de réseau.', it: 'Da solo a costruttore di rete.', pt: 'De solo a construtor de rede.' },
  'red.ba.before':   { es: 'Mes 1', en: 'Month 1', fr: 'Mois 1', it: 'Mese 1', pt: 'Mês 1' },
  'red.ba.after':    { es: 'Mes 12', en: 'Month 12', fr: 'Mois 12', it: 'Mese 12', pt: 'Mês 12' },
  'red.ba.before.cap': { es: 'Empiezas solo. Tu link, tu energía, tus primeras conversaciones.', en: 'You start alone. Your link, your energy, your first conversations.', fr: 'Vous commencez seul. Votre lien, votre énergie, vos premières conversations.', it: 'Inizi da solo. Il tuo link, la tua energia, le tue prime conversazioni.', pt: 'Você começa sozinho. Seu link, sua energia, suas primeiras conversas.' },
  'red.ba.after.cap':  { es: 'Un año después: lideras un equipo que vende contigo.', en: 'A year later: you lead a team that sells with you.', fr: 'Un an plus tard : vous menez une équipe qui vend avec vous.', it: 'Un anno dopo: guidi un team che vende con te.', pt: 'Um ano depois: você lidera um time que vende com você.' },

  // Storyboard
  'red.story.eyebrow': { es: 'Cómo se ve invitar', en: 'What inviting looks like', fr: 'À quoi ressemble une invitation', it: 'Come funziona invitare', pt: 'Como é convidar' },
  'red.story.title':   { es: 'En 3 momentos.', en: 'In 3 moments.', fr: 'En 3 moments.', it: 'In 3 momenti.', pt: 'Em 3 momentos.' },
  'red.story.s1.lbl':  { es: '01 · Identificas', en: '01 · You spot', fr: '01 · Vous repérez', it: '01 · Identifichi', pt: '01 · Identifica' },
  'red.story.s1.cap':  { es: 'Una conversación con alguien que ya tiene la energía y el contexto correcto. No fuerzas — solo escuchas.', en: 'A conversation with someone who already has the right energy and context. No forcing — just listening.', fr: 'Une conversation avec quelqu\'un qui a déjà la bonne énergie et le bon contexte. Pas de forçage — juste de l\'écoute.', it: 'Una conversazione con qualcuno che ha già l\'energia e il contesto giusti. Niente forzature — solo ascolto.', pt: 'Uma conversa com alguém que já tem a energia e o contexto certos. Sem forçar — só escutar.' },
  'red.story.s2.lbl':  { es: '02 · Presentas', en: '02 · You present', fr: '02 · Vous présentez', it: '02 · Presenti', pt: '02 · Apresenta' },
  'red.story.s2.cap':  { es: 'Le muestras el programa desde tu portal — qué se gana, qué se compromete, cómo funciona la red.', en: 'You show them the program from your portal — what you earn, what you commit to, how the network works.', fr: 'Vous lui montrez le programme depuis votre portail — ce qu\'on gagne, ce qu\'on engage, comment fonctionne le réseau.', it: 'Gli mostri il programma dal tuo portale — cosa si guadagna, a cosa ci si impegna, come funziona la rete.', pt: 'Mostra o programa do seu portal — o que se ganha, o que se compromete, como funciona a rede.' },
  'red.story.s3.lbl':  { es: '03 · Bienvenida', en: '03 · Welcome', fr: '03 · Bienvenue', it: '03 · Benvenuto', pt: '03 · Boas-vindas' },
  'red.story.s3.cap':  { es: 'Firma su propio acuerdo. SACS valida, activa, y desde ese momento son parte de tu red.', en: 'They sign their own agreement. SACS validates, activates, and from that moment they\'re part of your network.', fr: 'Il signe son propre accord. SACS valide, active, et dès ce moment il fait partie de votre réseau.', it: 'Firma il proprio accordo. SACS valida, attiva e da quel momento fa parte della tua rete.', pt: 'Assina seu próprio acordo. A SACS valida, ativa e desde esse momento faz parte da sua rede.' },

  // Wall de Network Builders
  'red.wall.eyebrow': { es: 'Network Builders en construcción', en: 'Network Builders in the making', fr: 'Network Builders en construction', it: 'Network Builders in formazione', pt: 'Network Builders em formação' },
  'red.wall.title':   { es: 'Una comunidad real, viva.', en: 'A real, living community.', fr: 'Une communauté réelle et vivante.', it: 'Una comunità reale, viva.', pt: 'Uma comunidade real, viva.' },
  'red.wall.lead':    { es: 'Estos son partners que están construyendo su red en este momento — ambassadors, founders, consultoras, dueños de negocio. Cuando llegues al tier 4, este muro suma tu cara también.', en: 'These are partners building their network right now — ambassadors, founders, consultants, business owners. When you reach tier 4, this wall adds your face too.', fr: 'Ce sont des partenaires qui construisent leur réseau en ce moment — ambassadeurs, fondateurs, consultants, propriétaires d\'entreprise. Quand vous atteindrez le palier 4, ce mur ajoutera aussi votre visage.', it: 'Questi sono partner che stanno costruendo la loro rete proprio ora — ambasciatori, founder, consulenti, titolari di attività. Quando raggiungi il tier 4, anche tu farai parte di questo muro.', pt: 'Estes são parceiros construindo sua rede neste momento — embaixadores, founders, consultores, donos de negócio. Quando chegar ao tier 4, este muro também adiciona o seu rosto.' },

  // Founder placeholder note
  'red.founder.lbl':  { es: 'Aaron Herzberg', en: 'Aaron Herzberg', fr: 'Aaron Herzberg', it: 'Aaron Herzberg', pt: 'Aaron Herzberg' },
  'red.founder.role': { es: 'Founder & CEO · SACS', en: 'Founder & CEO · SACS', fr: 'Founder & CEO · SACS', it: 'Founder & CEO · SACS', pt: 'Founder & CEO · SACS' },

  // Phase C · Bienvenida sections 2-8
  'why.eyebrow': { es: 'Por qué SACS · el origen', en: 'Why SACS · the origin', fr: 'Pourquoi SACS · l\'origine', it: 'Perché SACS · l\'origine', pt: 'Por que SACS · a origem' },
  'why.title':   { es: 'No vendemos software — construimos un sistema operativo para retailers conscientes.', en: 'We don\'t sell software — we build an operating system for conscious retailers.', fr: 'Nous ne vendons pas de logiciel — nous construisons un système d\'exploitation pour les détaillants conscients.', it: 'Non vendiamo software — costruiamo un sistema operativo per retailer consapevoli.', pt: 'Não vendemos software — construímos um sistema operacional para varejistas conscientes.' },
  'why.lead':    { es: 'SACS no nació para venderle POS a quien lo pidiera. Nació para construir el <strong>sistema operativo del retail mexicano moderno</strong>: una plataforma única donde POS, inventario multi-sucursal, e-commerce, CRM, lealtad y marketing operen como un solo organismo.', en: 'SACS was not born to sell POS to whoever asked. It was born to build the <strong>operating system of modern Mexican retail</strong>: a single platform where POS, multi-store inventory, e-commerce, CRM, loyalty and marketing operate as one organism.', fr: 'SACS n\'est pas né pour vendre des POS à qui le demandait. Il est né pour bâtir le <strong>système d\'exploitation du retail mexicain moderne</strong> : une plateforme unique où POS, inventaire multi-magasin, e-commerce, CRM, fidélité et marketing fonctionnent comme un seul organisme.', it: 'SACS non è nato per vendere POS a chi lo chiedeva. È nato per costruire il <strong>sistema operativo del retail messicano moderno</strong>: un\'unica piattaforma dove POS, inventario multi-negozio, e-commerce, CRM, fedeltà e marketing operano come un solo organismo.', pt: 'A SACS não nasceu para vender POS a quem pedisse. Nasceu para construir o <strong>sistema operacional do varejo mexicano moderno</strong>: uma plataforma única onde POS, inventário multi-loja, e-commerce, CRM, fidelidade e marketing operam como um só organismo.' },
  'why.p1.t': { es: 'Para el retailer', en: 'For the retailer', fr: 'Pour le détaillant', it: 'Per il retailer', pt: 'Para o varejista' },
  'why.p1.d': { es: 'Una plataforma. Cero islas de información. Decisiones más rápidas. Menos errores. Más tiempo para crecer.', en: 'One platform. Zero information silos. Faster decisions. Fewer errors. More time to grow.', fr: 'Une plateforme. Zéro silo d\'information. Des décisions plus rapides. Moins d\'erreurs. Plus de temps pour grandir.', it: 'Una piattaforma. Zero silos informativi. Decisioni più rapide. Meno errori. Più tempo per crescere.', pt: 'Uma plataforma. Zero ilhas de informação. Decisões mais rápidas. Menos erros. Mais tempo para crescer.' },
  'why.p2.t': { es: 'Para el cliente final', en: 'For the end customer', fr: 'Pour le client final', it: 'Per il cliente finale', pt: 'Para o cliente final' },
  'why.p2.d': { es: 'Experiencia consistente entre tienda física, online y WhatsApp. Recomendaciones relevantes. Lealtad que se siente.', en: 'Consistent experience across physical store, online and WhatsApp. Relevant recommendations. Loyalty that feels real.', fr: 'Expérience cohérente entre boutique physique, en ligne et WhatsApp. Recommandations pertinentes. Une fidélité qui se ressent.', it: 'Esperienza coerente tra negozio fisico, online e WhatsApp. Raccomandazioni rilevanti. Fedeltà che si sente.', pt: 'Experiência consistente entre loja física, online e WhatsApp. Recomendações relevantes. Fidelidade que se sente.' },
  'why.p3.t': { es: 'Para la comunidad', en: 'For the community', fr: 'Pour la communauté', it: 'Per la comunità', pt: 'Para a comunidade' },
  'why.p3.d': { es: 'Embajadores que cobran justo. Proveedores que cobran a tiempo. Equipos que aprenden con la herramienta. Crecimiento compartido.', en: 'Ambassadors who get paid fairly. Suppliers who get paid on time. Teams that learn with the tool. Shared growth.', fr: 'Des ambassadeurs payés justement. Des fournisseurs payés à temps. Des équipes qui apprennent avec l\'outil. Une croissance partagée.', it: 'Ambasciatori pagati il giusto. Fornitori pagati in tempo. Team che imparano con lo strumento. Crescita condivisa.', pt: 'Embaixadores que ganham um valor justo. Fornecedores que recebem em dia. Times que aprendem com a ferramenta. Crescimento compartilhado.' },

  'diff.eyebrow': { es: 'En qué nos diferenciamos', en: 'How we\'re different', fr: 'Ce qui nous différencie', it: 'Cosa ci differenzia', pt: 'No que nos diferenciamos' },
  'diff.title':   { es: 'Cualquiera vende un POS. Pocos resuelven la operación completa.', en: 'Anyone sells a POS. Few solve the full operation.', fr: 'Tout le monde vend un POS. Peu résolvent l\'opération complète.', it: 'Chiunque vende un POS. Pochi risolvono l\'operazione completa.', pt: 'Qualquer um vende um POS. Poucos resolvem a operação completa.' },
  'diff.lead':    { es: 'El mercado de retail tech mexicano está saturado de plataformas que prometen todo y entregan piezas sueltas. Conocemos a los competidores — los respetamos. Pero nuestra fundación es distinta:', en: 'The Mexican retail tech market is saturated with platforms that promise everything and deliver loose pieces. We know our competitors — we respect them. But our foundation is different:', fr: 'Le marché mexicain de la retail tech est saturé de plateformes qui promettent tout et livrent des pièces détachées. Nous connaissons les concurrents — nous les respectons. Mais notre fondation est différente :', it: 'Il mercato messicano del retail tech è saturo di piattaforme che promettono tutto e consegnano pezzi sfusi. Conosciamo i concorrenti — li rispettiamo. Ma la nostra base è diversa:', pt: 'O mercado mexicano de retail tech está saturado de plataformas que prometem tudo e entregam peças soltas. Conhecemos os concorrentes — os respeitamos. Mas nossa fundação é distinta:' },
  'diff.1.t': { es: 'No somos un parche', en: 'We are not a patchwork', fr: 'Nous ne sommes pas un patchwork', it: 'Non siamo una toppa', pt: 'Não somos um remendo' },
  'diff.1.d': { es: 'Nacimos integrados de origen. POS, inventario, e-commerce, CRM, marketing — todo desde la misma base de datos, no APIs pegadas con goma.', en: 'We were born integrated. POS, inventory, e-commerce, CRM, marketing — all from the same database, not APIs glued with tape.', fr: 'Nous sommes nés intégrés. POS, inventaire, e-commerce, CRM, marketing — tout depuis la même base de données, pas des API collées au scotch.', it: 'Siamo nati integrati. POS, inventario, e-commerce, CRM, marketing — tutto dallo stesso database, non API incollate.', pt: 'Nascemos integrados. POS, inventário, e-commerce, CRM, marketing — tudo a partir do mesmo banco de dados, não APIs coladas com fita.' },
  'diff.2.t': { es: 'Multi-sucursal de verdad', en: 'True multi-store', fr: 'Multi-magasin véritable', it: 'Multi-negozio vero', pt: 'Multi-loja de verdade' },
  'diff.2.d': { es: 'Funcionamos igual con 1 tienda que con 1,500 (Liveshow lo prueba). El sistema escala sin que tengas que migrar a una versión "enterprise".', en: 'We work the same with 1 store as with 1,500 (Liveshow proves it). The system scales without forcing you to migrate to an "enterprise" version.', fr: 'Nous fonctionnons de la même façon avec 1 boutique ou 1 500 (Liveshow le prouve). Le système monte en charge sans vous forcer à migrer vers une version « enterprise ».', it: 'Funzioniamo allo stesso modo con 1 negozio o con 1.500 (Liveshow lo prova). Il sistema scala senza obbligarti a migrare a una versione "enterprise".', pt: 'Funcionamos igual com 1 loja ou com 1.500 (Liveshow comprova). O sistema escala sem te forçar a migrar para uma versão "enterprise".' },
  'diff.3.t': { es: 'Pensado en LATAM', en: 'Built for LATAM', fr: 'Pensé pour l\'Amérique latine', it: 'Pensato per il LATAM', pt: 'Pensado para LATAM' },
  'diff.3.d': { es: 'CFDI 4.0, IEPS, SAT, RFC, métodos de pago locales, WhatsApp, MercadoPago. No es una traducción de un producto gringo.', en: 'CFDI 4.0, IEPS, SAT, RFC, local payment methods, WhatsApp, MercadoPago. Not a translation of a US product.', fr: 'CFDI 4.0, IEPS, SAT, RFC, moyens de paiement locaux, WhatsApp, MercadoPago. Ce n\'est pas la traduction d\'un produit américain.', it: 'CFDI 4.0, IEPS, SAT, RFC, metodi di pagamento locali, WhatsApp, MercadoPago. Non è una traduzione di un prodotto americano.', pt: 'CFDI 4.0, IEPS, SAT, RFC, métodos de pagamento locais, WhatsApp, MercadoPago. Não é uma tradução de um produto gringo.' },
  'diff.4.t': { es: 'Casos de uso completos', en: 'Complete use cases', fr: 'Cas d\'usage complets', it: 'Casi d\'uso completi', pt: 'Casos de uso completos' },
  'diff.4.d': { es: 'Resolvemos el caso completo — desde que el producto llega al almacén hasta que el cliente vuelve por segunda vez. No solo "cobrar".', en: 'We solve the complete case — from product arriving at the warehouse to the customer coming back for a second time. Not just "checkout".', fr: 'Nous résolvons le cas complet — depuis l\'arrivée du produit à l\'entrepôt jusqu\'au retour du client une deuxième fois. Pas seulement « encaisser ».', it: 'Risolviamo il caso completo — dall\'arrivo del prodotto in magazzino al cliente che torna una seconda volta. Non solo "incassare".', pt: 'Resolvemos o caso completo — da chegada do produto ao armazém até o cliente voltar pela segunda vez. Não só "cobrar".' },

  'hist.eyebrow': { es: 'Nuestra historia', en: 'Our story', fr: 'Notre histoire', it: 'La nostra storia', pt: 'Nossa história' },
  'hist.title':   { es: '13+ años construyendo categoría.', en: '13+ years building the category.', fr: '13+ ans à construire la catégorie.', it: '13+ anni a costruire la categoria.', pt: '13+ anos construindo a categoria.' },
  'hist.p1':      { es: 'Empezamos hace más de 13 años cuando "POS en la nube" todavía era una idea radical en México. Nos consolidamos como líderes del segmento mientras el mercado se llenaba de competidores que prometían lo mismo.', en: 'We started over 13 years ago when "cloud POS" was still a radical idea in Mexico. We became leaders of the segment while the market filled with competitors promising the same.', fr: 'Nous avons commencé il y a plus de 13 ans, quand le « POS dans le cloud » était encore une idée radicale au Mexique. Nous sommes devenus leaders du segment pendant que le marché se remplissait de concurrents qui promettaient la même chose.', it: 'Abbiamo iniziato oltre 13 anni fa, quando il "POS nel cloud" era ancora un\'idea radicale in Messico. Siamo diventati leader del segmento mentre il mercato si riempiva di concorrenti che promettevano lo stesso.', pt: 'Começamos há mais de 13 anos, quando "POS na nuvem" ainda era uma ideia radical no México. Nos consolidamos como líderes do segmento enquanto o mercado se enchia de concorrentes prometendo o mesmo.' },
  'hist.p2':      { es: 'La diferencia: pocos logran resolver los <strong>casos de uso completos</strong> — desde la primera venta hasta la operación enterprise. La mayoría cubre bien una pieza y deja huecos en el resto. Nosotros llevamos más de una década cerrando esos huecos uno por uno.', en: 'The difference: few solve the <strong>complete use cases</strong> — from the first sale to enterprise operation. Most cover one piece well and leave gaps in the rest. We\'ve spent over a decade closing those gaps one by one.', fr: 'La différence : peu résolvent les <strong>cas d\'usage complets</strong> — de la première vente à l\'opération enterprise. La plupart couvrent bien une pièce et laissent des trous ailleurs. Nous passons plus d\'une décennie à combler ces trous un par un.', it: 'La differenza: pochi risolvono i <strong>casi d\'uso completi</strong> — dalla prima vendita all\'operazione enterprise. La maggior parte copre bene un pezzo e lascia buchi nel resto. Noi sono oltre dieci anni che chiudiamo quei buchi uno per uno.', pt: 'A diferença: poucos resolvem os <strong>casos de uso completos</strong> — desde a primeira venda até a operação enterprise. A maioria cobre uma peça bem e deixa lacunas no resto. Nós levamos mais de uma década fechando essas lacunas uma por uma.' },

  'vis.eyebrow':  { es: 'Nuestra visión', en: 'Our vision', fr: 'Notre vision', it: 'La nostra visione', pt: 'Nossa visão' },
  'vis.suffix':   { es: 'embajadores al terminar 2026.', en: 'ambassadors by the end of 2026.', fr: 'ambassadeurs d\'ici fin 2026.', it: 'ambasciatori entro la fine del 2026.', pt: 'embaixadores até o final de 2026.' },
  'vis.lead':     { es: 'Hoy somos <strong>100</strong> partners en 12 países. La meta para diciembre 2026 son <strong>1,000</strong> — y vamos en buen ritmo.', en: 'Today we are <strong>100</strong> partners across 12 countries. The goal by December 2026 is <strong>1,000</strong> — and we\'re on track.', fr: 'Aujourd\'hui nous sommes <strong>100</strong> partenaires dans 12 pays. L\'objectif pour décembre 2026 est <strong>1 000</strong> — et nous sommes sur la bonne voie.', it: 'Oggi siamo <strong>100</strong> partner in 12 paesi. L\'obiettivo per dicembre 2026 sono <strong>1.000</strong> — e siamo in linea.', pt: 'Hoje somos <strong>100</strong> parceiros em 12 países. A meta para dezembro de 2026 são <strong>1.000</strong> — e estamos no ritmo certo.' },
  'vis.tracker.latam': { es: 'Latinoamérica · top 10', en: 'Latin America · top 10', fr: 'Amérique latine · top 10', it: 'America Latina · top 10', pt: 'América Latina · top 10' },
  'vis.tracker.intl':  { es: 'Internacional · semilla', en: 'International · seed', fr: 'International · graine', it: 'Internazionale · seme', pt: 'Internacional · semente' },
  'vis.tracker.partners': { es: 'partners', en: 'partners', fr: 'partenaires', it: 'partner', pt: 'parceiros' },
  'vis.tracker.partner':  { es: 'partner', en: 'partner', fr: 'partenaire', it: 'partner', pt: 'parceiro' },
  'vis.tracker.total': { es: 'Total hoy', en: 'Total today', fr: 'Total aujourd\'hui', it: 'Totale oggi', pt: 'Total hoje' },
  'vis.tracker.goal':  { es: '/ 1,000 al cierre 2026', en: '/ 1,000 by end of 2026', fr: '/ 1 000 d\'ici fin 2026', it: '/ 1.000 entro fine 2026', pt: '/ 1.000 até o final de 2026' },

  // Wall
  'wall.eyebrow': { es: 'La red real, hoy', en: 'The real network, today', fr: 'Le vrai réseau, aujourd\'hui', it: 'La rete reale, oggi', pt: 'A rede real, hoje' },
  'wall.title':   { es: '100 personas en LATAM ya forman parte.', en: '100 people across LATAM are already part of it.', fr: '100 personnes en LATAM en font déjà partie.', it: '100 persone in LATAM ne fanno già parte.', pt: '100 pessoas na LATAM já fazem parte.' },
  'wall.lead':    { es: 'No es un número en una landing — son personas reales con sus marcas, sus tiendas y sus comunidades. Si firmas, te unes a este grupo.', en: 'It\'s not a number on a landing page — they are real people with their brands, stores and communities. If you sign, you join this group.', fr: 'Ce n\'est pas un chiffre sur une landing — ce sont de vraies personnes avec leurs marques, leurs boutiques et leurs communautés. Si vous signez, vous rejoignez ce groupe.', it: 'Non è un numero su una landing — sono persone reali con i loro marchi, i loro negozi e le loro comunità. Se firmi, entri in questo gruppo.', pt: 'Não é um número numa landing — são pessoas reais com suas marcas, suas lojas e suas comunidades. Se você assinar, se junta a este grupo.' },
  'wall.foot':    { es: 'Y muchos más en 12 países de LATAM y Europa.', en: 'And many more across 12 countries in LATAM and Europe.', fr: 'Et bien d\'autres dans 12 pays de LATAM et d\'Europe.', it: 'E molti altri in 12 paesi tra LATAM ed Europa.', pt: 'E muitos mais em 12 países da LATAM e Europa.' },

  // SACS acronym
  'sac.eyebrow':   { es: 'SACS, lo que representamos', en: 'SACS, what we stand for', fr: 'SACS, ce que nous représentons', it: 'SACS, cosa rappresentiamo', pt: 'SACS, o que representamos' },
  'sac.title':     { es: 'Las 4 palabras que definen lo que hacemos.', en: 'The 4 words that define what we do.', fr: 'Les 4 mots qui définissent ce que nous faisons.', it: 'Le 4 parole che definiscono cosa facciamo.', pt: 'As 4 palavras que definem o que fazemos.' },
  'sac.lead':      { es: 'Nuestro nombre no es un acrónimo elegido al azar — describe el por qué del producto, de la empresa y del programa que estás considerando entrar.', en: 'Our name is not a randomly chosen acronym — it describes the why of the product, the company and the program you\'re considering joining.', fr: 'Notre nom n\'est pas un acronyme choisi au hasard — il décrit le pourquoi du produit, de l\'entreprise et du programme auquel vous envisagez de rejoindre.', it: 'Il nostro nome non è un acronimo scelto a caso — descrive il perché del prodotto, dell\'azienda e del programma a cui stai considerando di unirti.', pt: 'Nosso nome não é um acrônimo escolhido ao acaso — descreve o porquê do produto, da empresa e do programa que você está considerando entrar.' },
  'sac.s1.w': { es: 'Ser', en: 'Be', fr: 'Être', it: 'Essere', pt: 'Ser' },
  'sac.s1.d': { es: 'Ser auténticos. Tu marca tiene una identidad — el sistema la potencia, no la reemplaza.', en: 'Be authentic. Your brand has an identity — the system amplifies it, doesn\'t replace it.', fr: 'Être authentique. Votre marque a une identité — le système la potentialise, ne la remplace pas.', it: 'Essere autentici. Il tuo marchio ha un\'identità — il sistema la potenzia, non la sostituisce.', pt: 'Ser autêntico. Sua marca tem uma identidade — o sistema a potencializa, não a substitui.' },
  'sac.a.w':  { es: 'Avanzar', en: 'Advance', fr: 'Avancer', it: 'Avanzare', pt: 'Avançar' },
  'sac.a.d':  { es: 'Avanzar con tecnología que resuelve problemas reales del retail mexicano, no los de Silicon Valley.', en: 'Advance with technology that solves real problems of Mexican retail, not Silicon Valley\'s.', fr: 'Avancer avec une technologie qui résout les vrais problèmes du retail mexicain, pas ceux de la Silicon Valley.', it: 'Avanzare con tecnologia che risolve problemi reali del retail messicano, non quelli della Silicon Valley.', pt: 'Avançar com tecnologia que resolve problemas reais do varejo mexicano, não os do Vale do Silício.' },
  'sac.c.w':  { es: 'Crear', en: 'Create', fr: 'Créer', it: 'Creare', pt: 'Criar' },
  'sac.c.d':  { es: 'Crear experiencias que inspiran — para tus clientes, tu equipo y tu comunidad.', en: 'Create experiences that inspire — for your clients, your team and your community.', fr: 'Créer des expériences qui inspirent — pour vos clients, votre équipe et votre communauté.', it: 'Creare esperienze che ispirano — per i tuoi clienti, il tuo team e la tua comunità.', pt: 'Criar experiências que inspiram — para seus clientes, sua equipe e sua comunidade.' },
  'sac.s2.w': { es: 'Sembrar', en: 'Sow', fr: 'Semer', it: 'Seminare', pt: 'Semear' },
  'sac.s2.d': { es: 'Sembrar para el futuro. Tu éxito impulsa los programas de impacto a comunidades en México y LATAM.', en: 'Sow for the future. Your success drives our impact programs in Mexican and LATAM communities.', fr: 'Semer pour l\'avenir. Votre succès propulse nos programmes d\'impact dans les communautés mexicaines et latino-américaines.', it: 'Seminare per il futuro. Il tuo successo alimenta i programmi di impatto nelle comunità messicane e latinoamericane.', pt: 'Semear para o futuro. Seu sucesso impulsiona os programas de impacto em comunidades do México e da LATAM.' },
  'sac.proof.r':  { es: 'de retención anual', en: 'annual retention', fr: 'de rétention annuelle', it: 'di retention annuale', pt: 'de retenção anual' },
  'sac.proof.y':  { es: 'años en el mercado', en: 'years in the market', fr: 'ans sur le marché', it: 'anni sul mercato', pt: 'anos no mercado' },
  'sac.proof.b':  { es: 'marcas activas', en: 'active brands', fr: 'marques actives', it: 'marchi attivi', pt: 'marcas ativas' },

  // 10% impacto
  'imp.eyebrow': { es: '10% para impacto positivo', en: '10% for positive impact', fr: '10% pour l\'impact positif', it: '10% per l\'impatto positivo', pt: '10% para impacto positivo' },
  'imp.title':   { es: 'El 10% de cada comisión<br/>se dona a programas de impacto.', en: '10% of every commission<br/>is donated to impact programs.', fr: '10% de chaque commission<br/>est reversé à des programmes d\'impact.', it: 'Il 10% di ogni commissione<br/>è donato a programmi di impatto.', pt: '10% de cada comissão<br/>é doado a programas de impacto.' },
  'imp.lead':    { es: 'Apoyamos a emprendedores que están empezando, becas, y proyectos comunitarios en LATAM. Cuando seas aprobado te enviamos el reporte trimestral con cómo se distribuyó ese 10% y los assets para compartirlo en tus redes.', en: 'We support entrepreneurs just starting, scholarships, and community projects in LATAM. Once approved we send you the quarterly report with how that 10% was distributed and assets to share it on your channels.', fr: 'Nous soutenons les entrepreneurs qui démarrent, des bourses, et des projets communautaires en LATAM. Une fois approuvé, nous vous envoyons le rapport trimestriel sur la répartition des 10% et les contenus à partager sur vos réseaux.', it: 'Sosteniamo imprenditori agli inizi, borse di studio e progetti comunitari in LATAM. Una volta approvato, ti inviamo il report trimestrale su come è stato distribuito quel 10% e gli asset per condividerlo sui tuoi canali.', pt: 'Apoiamos empreendedores começando, bolsas, e projetos comunitários na LATAM. Quando você for aprovado, te enviamos o relatório trimestral de como esses 10% foram distribuídos e os assets para compartilhar nas suas redes.' },

  // Bienvenida CTA final
  'cta.title': { es: '¿Listo para revisar las reglas claras?', en: 'Ready to review the clear rules?', fr: 'Prêt à examiner les règles claires ?', it: 'Pronto a rivedere le regole chiare?', pt: 'Pronto para revisar as regras claras?' },
  'cta.lead':  { es: 'Sigue al siguiente paso para ver los términos del programa, los compromisos, lo que puedes ganar y firmar cuando estés listo.', en: 'Move to the next step to see the program terms, commitments, what you can earn and sign when you\'re ready.', fr: 'Passez à l\'étape suivante pour voir les conditions du programme, les engagements, ce que vous pouvez gagner et signer quand vous êtes prêt.', it: 'Passa al prossimo step per vedere i termini del programma, gli impegni, quanto puoi guadagnare e firmare quando sei pronto.', pt: 'Vá para o próximo passo para ver os termos do programa, os compromissos, o que você pode ganhar e assinar quando estiver pronto.' },
  'cta.btn':   { es: 'Ver términos →', en: 'See terms →', fr: 'Voir les conditions →', it: 'Vedi i termini →', pt: 'Ver termos →' },

  // Phase D · tab section heads
  // Términos
  'terms.eyebrow': { es: 'Las reglas claras', en: 'The clear rules', fr: 'Les règles claires', it: 'Le regole chiare', pt: 'As regras claras' },
  'terms.title':   { es: 'Términos del programa', en: 'Program terms', fr: 'Conditions du programme', it: 'Termini del programma', pt: 'Termos do programa' },
  'terms.lead':    { es: 'Sin letras chicas. Esto es lo que ganas, lo que SACS te entrega y lo que cuesta participar — todo en un solo lugar.', en: 'No fine print. This is what you earn, what SACS delivers and what it costs to participate — all in one place.', fr: 'Pas de petits caractères. Voici ce que vous gagnez, ce que SACS vous donne et ce que coûte la participation — tout au même endroit.', it: 'Nessuna clausola scritta in piccolo. Ecco cosa guadagni, cosa SACS ti dà e quanto costa partecipare — tutto in un solo posto.', pt: 'Sem letras miúdas. Isto é o que você ganha, o que a SACS te entrega e quanto custa participar — tudo em um só lugar.' },
  'terms.g1.t': { es: '1 · Compensación · cuánto ganas', en: '1 · Compensation · how much you earn', fr: '1 · Rémunération · combien vous gagnez', it: '1 · Compenso · quanto guadagni', pt: '1 · Remuneração · quanto você ganha' },
  'terms.g1.l': { es: 'El dinero que entra a tu cuenta. 50% de comisión directa sobre cada venta cerrada por tu link + comisión recurrente + 10% override cuando llegues a Master Partner. Pagos cada 30 días, sin "depende de…".', en: 'The money that hits your account. 50% direct commission on every sale closed via your link + recurring commission + 10% override when you reach Master Partner. Payments every 30 days, no "depends on…".', fr: 'L\'argent qui arrive sur votre compte. 50% de commission directe sur chaque vente conclue via votre lien + commission récurrente + 10% override quand vous atteignez Master Partner. Paiements tous les 30 jours, sans « ça dépend... ».', it: 'I soldi che arrivano sul tuo conto. 50% di commissione diretta su ogni vendita chiusa con il tuo link + commissione ricorrente + 10% override quando raggiungi Master Partner. Pagamenti ogni 30 giorni, senza "dipende da...".', pt: 'O dinheiro que entra na sua conta. 50% de comissão direta sobre cada venda fechada pelo seu link + comissão recorrente + 10% override quando chegar a Master Partner. Pagamentos a cada 30 dias, sem "depende de…".' },
  'terms.g2.t': { es: '2 · Activos y herramientas que recibes', en: '2 · Assets and tools you get', fr: '2 · Actifs et outils que vous recevez', it: '2 · Asset e strumenti che ricevi', pt: '2 · Ativos e ferramentas que você recebe' },
  'terms.g2.l': { es: 'Lo que SACS te da para trabajar. Software, recursos, materiales y soporte — todo sin costo mientras seas partner activo.', en: 'What SACS gives you to work with. Software, resources, materials and support — all at no cost while you\'re an active partner.', fr: 'Ce que SACS vous fournit pour travailler. Logiciels, ressources, supports et accompagnement — sans frais tant que vous êtes partenaire actif.', it: 'Cosa SACS ti dà per lavorare. Software, risorse, materiali e supporto — tutto gratis finché sei partner attivo.', pt: 'O que a SACS te dá para trabalhar. Software, recursos, materiais e suporte — sem custo enquanto você for parceiro ativo.' },
  'terms.g3.t': { es: '3 · Costos y vigencia', en: '3 · Costs and validity', fr: '3 · Coûts et validité', it: '3 · Costi e validità', pt: '3 · Custos e validade' },
  'terms.g3.l': { es: 'Lo que cuesta participar. Si dice "sin costo", es sin costo — la transparencia es parte del trato.', en: 'What it costs to participate. If it says "no cost", it\'s no cost — transparency is part of the deal.', fr: 'Ce que coûte la participation. Si c\'est marqué « sans frais », c\'est sans frais — la transparence fait partie du contrat.', it: 'Quanto costa partecipare. Se dice "nessun costo", è nessun costo — la trasparenza fa parte del patto.', pt: 'Quanto custa participar. Se diz "sem custo", é sem custo — a transparência faz parte do trato.' },

