  'cost.inscr_detail':       { es: 'Pago único al activar tu programa.', en: 'One-time payment when you activate your program.', fr: 'Paiement unique à l\'activation de votre programme.', it: 'Pagamento una tantum all\'attivazione del tuo programma.', pt: 'Pagamento único ao ativar seu programa.' },
  'cost.mensual_label':      { es: 'Cuota mensual del sistema SACS', en: 'Monthly SACS system fee', fr: 'Frais mensuel du système SACS', it: 'Quota mensile del sistema SACS', pt: 'Taxa mensal do sistema SACS' },
  'cost.mensual_detail':     { es: 'Suscripción mensual al sistema SACS para uso interno y demos.', en: 'Monthly subscription to the SACS system for internal use and demos.', fr: 'Abonnement mensuel au système SACS pour usage interne et démos.', it: 'Abbonamento mensile al sistema SACS per uso interno e demo.', pt: 'Assinatura mensal ao sistema SACS para uso interno e demos.' },
  'cost.acceso_label':       { es: 'Acceso al sistema SACS', en: 'Access to the SACS system', fr: 'Accès au système SACS', it: 'Accesso al sistema SACS', pt: 'Acesso ao sistema SACS' },
  'cost.acceso_free_detail': { es: 'Sin costo durante toda la participación, mientras cumplas los compromisos del programa.', en: 'No cost throughout your participation, as long as you meet the program commitments.', fr: 'Sans frais pendant toute votre participation, tant que vous respectez les engagements du programme.', it: 'Nessun costo per tutta la partecipazione, finché rispetti gli impegni del programma.', pt: 'Sem custo durante toda a participação, enquanto você cumprir os compromissos do programa.' },
  'cost.acceso_paid_detail': { es: 'Sujeto a la cuota indicada arriba.', en: 'Subject to the fee indicated above.', fr: 'Soumis aux frais indiqués ci-dessus.', it: 'Soggetto alla quota indicata sopra.', pt: 'Sujeito à taxa indicada acima.' },
  'cost.acceso_esc_detail': { es: 'Tu inversión es el paquete de licencias que eliges; el acceso al programa en sí no tiene cuota mensual ni anual.', en: 'Your investment is the license package you choose; access to the program itself has no monthly or annual fee.', fr: 'Votre investissement est le pack de licences que vous choisissez ; l\'accès au programme lui-même n\'a aucun frais mensuel ni annuel.', it: 'Il tuo investimento è il pacchetto di licenze che scegli; l\'accesso al programma in sé non ha quote mensili o annuali.', pt: 'Seu investimento é o pacote de licenças que você escolhe; o acesso ao programa em si não tem mensalidade nem anuidade.' },
  'cost.con_paquete':       { es: 'Con paquete', en: 'With package', fr: 'Avec pack', it: 'Con pacchetto', pt: 'Com pacote' },
  'cost.paquete_label':     { es: 'Paquete de licencias Fideliza', en: 'Fideliza license package', fr: 'Pack de licences Fideliza', it: 'Pacchetto di licenze Fideliza', pt: 'Pacote de licenças Fideliza' },
  'cost.paquete_detail':    { es: 'Compras licencias al mayoreo según el nivel que elijas y las revendes a precio público.', en: 'You buy licenses wholesale at your chosen tier and resell them at public price.', fr: 'Vous achetez des licences en gros selon le niveau choisi et les revendez au prix public.', it: 'Compri licenze all\'ingrosso secondo il livello scelto e le rivendi a prezzo pubblico.', pt: 'Você compra licenças no atacado conforme o nível escolhido e as revende a preço público.' },

  // Paquete escalonado de licencias (modo interno)
  'esc.eyebrow':   { es: 'Paquete escalonado de licencias', en: 'Tiered license package', fr: 'Pack de licences échelonné', it: 'Pacchetto di licenze a livelli', pt: 'Pacote escalonado de licenças' },
  'esc.title':     { es: 'Compra licencias al mayoreo, revéndelas a precio público', en: 'Buy licenses wholesale, resell at public price', fr: 'Achetez des licences en gros, revendez au prix public', it: 'Compra licenze all\'ingrosso, rivendile a prezzo pubblico', pt: 'Compre licenças no atacado, revenda a preço público' },
  'esc.lead':      { es: 'En vez de cobrar comisión, recibes un paquete de licencias Fideliza al mayoreo según tu inversión. Cada licencia la revendes a tus clientes al precio público y te quedas con todo el margen. Mientras más grande tu paquete, mayor tu descuento y tu ganancia.', en: 'Instead of earning commission, you get a wholesale package of Fideliza licenses based on your investment. You resell each license to your clients at the public price and keep the full margin. The bigger your package, the deeper your discount and profit.', fr: 'Au lieu de toucher une commission, vous recevez un pack de licences Fideliza en gros selon votre investissement. Vous revendez chaque licence à vos clients au prix public et gardez toute la marge. Plus votre pack est grand, plus votre remise et votre profit sont importants.', it: 'Invece di guadagnare una commissione, ricevi un pacchetto di licenze Fideliza all\'ingrosso in base al tuo investimento. Rivendi ogni licenza ai tuoi clienti al prezzo pubblico e tieni tutto il margine. Più grande è il pacchetto, maggiore lo sconto e il profitto.', pt: 'Em vez de ganhar comissão, você recebe um pacote de licenças Fideliza no atacado conforme seu investimento. Revende cada licença aos seus clientes pelo preço público e fica com toda a margem. Quanto maior o pacote, maior o desconto e o lucro.' },
  'esc.col.invest':   { es: 'Tu inversión', en: 'Your investment', fr: 'Votre investissement', it: 'Il tuo investimento', pt: 'Seu investimento' },
  'esc.col.licenses': { es: 'Licencias Fideliza', en: 'Fideliza licenses', fr: 'Licences Fideliza', it: 'Licenze Fideliza', pt: 'Licenças Fideliza' },
  'esc.col.resale':   { es: 'Valor de reventa', en: 'Resale value', fr: 'Valeur de revente', it: 'Valore di rivendita', pt: 'Valor de revenda' },
  'esc.col.profit':   { es: 'Tu ganancia neta', en: 'Your net profit', fr: 'Votre profit net', it: 'Il tuo profitto netto', pt: 'Seu lucro líquido' },
  'esc.col.vs':       { es: 'Extra vs comisión', en: 'Extra vs commission', fr: 'Extra vs commission', it: 'Extra vs commissione', pt: 'Extra vs comissão' },
  'esc.per_license':  { es: 'por licencia', en: 'per license', fr: 'par licence', it: 'per licenza', pt: 'por licença' },
  'esc.most':         { es: 'Mejor margen', en: 'Best margin', fr: 'Meilleure marge', it: 'Miglior margine', pt: 'Melhor margem' },
  'esc.compare.title':{ es: 'Tu paquete rinde más que la comisión', en: 'Your package outperforms the commission', fr: 'Votre pack rapporte plus que la commission', it: 'Il tuo pacchetto rende più della commissione', pt: 'Seu pacote rende mais que a comissão' },
  'esc.after.title':  { es: '¿Y cuando agotes tu paquete?', en: 'And once you sell out your package?', fr: 'Et quand votre pack est épuisé ?', it: 'E quando esaurisci il pacchetto?', pt: 'E quando esgotar seu pacote?' },
  'esc.after.body':   { es: 'Cuando vendas todas las licencias de tu paquete, vuelves al modelo de comisión: ganas {pct}% sobre cada nueva licencia Fideliza que cierres (≈ {comm} por licencia a precio público). Por eso conviene escalar de nivel — tu paquete al mayoreo siempre te deja más que la comisión.', en: 'Once you sell every license in your package, you return to the commission model: you earn {pct}% on each new Fideliza license you close (≈ {comm} per license at public price). That\'s why scaling up pays off — your wholesale package always nets you more than the commission.', fr: 'Quand vous avez vendu toutes les licences de votre pack, vous revenez au modèle de commission : vous gagnez {pct}% sur chaque nouvelle licence Fideliza conclue (≈ {comm} par licence au prix public). C\'est pourquoi monter de niveau est rentable — votre pack en gros rapporte toujours plus que la commission.', it: 'Quando vendi tutte le licenze del pacchetto, torni al modello a commissione: guadagni il {pct}% su ogni nuova licenza Fideliza che chiudi (≈ {comm} per licenza a prezzo pubblico). Per questo conviene salire di livello — il tuo pacchetto all\'ingrosso rende sempre più della commissione.', pt: 'Quando vender todas as licenças do seu pacote, você volta ao modelo de comissão: ganha {pct}% sobre cada nova licença Fideliza que fechar (≈ {comm} por licença a preço público). Por isso vale a pena escalar de nível — seu pacote no atacado sempre rende mais que a comissão.' },
  'esc.compare.body': { es: 'En todos los niveles ganas más que con la comisión del {pct}%: en vez de quedarte con ≈ {comm} por licencia, te llevas el margen completo de la reventa — y crece con cada nivel que subes.', en: 'At every tier you earn more than with the {pct}% commission: instead of ≈ {comm} per license, you keep the full resale margin — and it grows with every tier you climb.', fr: 'À chaque niveau, vous gagnez plus qu\'avec la commission de {pct}% : au lieu de ≈ {comm} par licence, vous gardez toute la marge de revente — et elle augmente à chaque niveau.', it: 'A ogni livello guadagni più della commissione del {pct}%: invece di ≈ {comm} per licenza, tieni tutto il margine di rivendita — e cresce a ogni livello.', pt: 'Em todos os níveis você ganha mais que com a comissão de {pct}%: em vez de ≈ {comm} por licença, você fica com toda a margem de revenda — e cresce a cada nível.' },
  'esc.hero.profit':  { es: 'Ganancia máx. con tu paquete', en: 'Max profit with your package', fr: 'Profit max avec votre pack', it: 'Profitto max col tuo pacchetto', pt: 'Lucro máx. com seu pacote' },
  'esc.hero.invest':  { es: 'Inversión desde', en: 'Investment from', fr: 'Investissement dès', it: 'Investimento da', pt: 'Investimento a partir de' },

