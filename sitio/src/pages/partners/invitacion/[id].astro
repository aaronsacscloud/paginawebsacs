</style>

<script is:inline define:vars={{ invitationId: id, isClosed }}>
(function() {
  // ─── Tab switcher ───
  const doc = document.getElementById('partner-doc');
  if (!doc) return;
  const initialTab = doc.dataset.initialTab || 'bienvenida';

  function showTab(tabId) {
    document.querySelectorAll('.p-tab-panel').forEach(p => {
      p.classList.toggle('is-active', p.dataset.tab === tabId);
    });
    // Desktop sidebar tabs
    document.querySelectorAll('[data-tab-link]').forEach(link => {
      const id = link.dataset.tabLink;
      if (id === tabId) link.classList.add('psb-tab--active');
      else if (link.classList.contains('psb-tab--active')) link.classList.remove('psb-tab--active');
    });
    // Mobile pill nav: active state + scroll into view
    document.querySelectorAll('.p-mobnav-tab').forEach(link => {
      const id = link.dataset.tabLink;
      if (id === tabId) {
        link.classList.add('p-mobnav-tab--active');
        // Centrar pill activo en el scroll horizontal
        try {
          link.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        } catch {}
      } else {
        link.classList.remove('p-mobnav-tab--active');
      }
    });
    if (history.replaceState) {
      history.replaceState(null, '', '#' + tabId);
    }
    // Init signature canvas la primera vez que el tab firma se hace visible
    if (tabId === 'firma') {
      requestAnimationFrame(() => {
        if (typeof initSignature === 'function') initSignature();
      });
    }
    // Scroll al inicio del contenido al cambiar tab (aria-current page anchor)
    requestAnimationFrame(() => {
      const target = document.querySelector('.p-tab-panel.is-active');
      if (target) {
        const rect = target.getBoundingClientRect();
        if (rect.top < 0 || rect.top > window.innerHeight * 0.5) {
          window.scrollTo({ top: window.scrollY + rect.top - 90, behavior: 'smooth' });
        }
      }
    });
  }

  // Wire links
  document.addEventListener('click', e => {
    const link = e.target.closest('[data-tab-link]');
    if (!link) return;
    const tabId = link.dataset.tabLink;
    if (!tabId) return;
    e.preventDefault();
    showTab(tabId);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // ─── FAQ accordion (objeciones) ───
  document.addEventListener('click', e => {
    const btn = e.target.closest('[data-faq-toggle]');
    if (!btn) return;
    const item = btn.closest('[data-faq-item]');
    if (!item) return;
    const open = item.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
  });

  // ─── Calculadora interactiva de ingresos ───
  (function initCalc() {
    const calc = document.querySelector('[data-calc]');
    if (!calc) return;
    const PLANS = [
      { name: 'Vende',      monthly: 600,  annualTotal: 6000  },
      { name: 'Controla',   monthly: 900,  annualTotal: 9000  },
      { name: 'Fideliza',   monthly: 1400, annualTotal: 14000 },
      { name: 'Automatiza', monthly: 5900, annualTotal: 59000 },
    ];
    const RATE = parseFloat(calc.getAttribute('data-rate') || '0.5');
    const BONUS_PRUEBA = parseFloat(calc.getAttribute('data-bp') || '250');
    const BONUS_DEMO   = parseFloat(calc.getAttribute('data-bd') || '300');
    const FX_RATE = parseFloat(calc.getAttribute('data-fx') || '1');
    const FX_CUR  = calc.getAttribute('data-cur') || 'MXN';
    const FX_LOC  = calc.getAttribute('data-loc') || 'es-MX';

    function fmt(mxnAmount) {
      const local = mxnAmount * FX_RATE;
      try {
        return new Intl.NumberFormat(FX_LOC, { style: 'currency', currency: FX_CUR, minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(Math.round(local));
      } catch {
        return '$' + Math.round(local).toLocaleString(FX_LOC);
      }
    }
    function read(name) {
      const el = calc.querySelector(`[data-calc-input="${name}"]`);
      return el ? Number(el.value) : 0;
    }
    function setOut(name, value) {
      const el = calc.querySelector(`[data-calc-out="${name}"]`);
      if (el) el.textContent = value;
    }
    function recompute() {
      const pruebas  = read('pruebas');
      const demos    = read('demos');
      const clientes = read('clientes');
      const planIdx  = read('plan');
      const plan     = PLANS[planIdx] || PLANS[2];

      const bonosAnual   = (pruebas * BONUS_PRUEBA + demos * BONUS_DEMO) * 12;
      const ventasAnual  = clientes * plan.annualTotal * RATE;
      const total        = bonosAnual + ventasAnual;

      setOut('pruebas', pruebas);
      setOut('demos', demos);
      setOut('clientes', clientes);
      setOut('plan-name', plan.name);
      setOut('bonos-anual', fmt(bonosAnual));
      setOut('ventas-anual', fmt(ventasAnual));
      setOut('total-anual', fmt(total));
    }
    calc.querySelectorAll('[data-calc-input]').forEach(el => {
      el.addEventListener('input', recompute);
      el.addEventListener('change', recompute);
    });
    recompute();
  })();

  // ─── Sub-tabs por categoría (Contenido / Apoyo / Filantropía) ───
  document.addEventListener('click', e => {
    const tab = e.target.closest('[data-cat-tab]');
    if (!tab) return;
    const id = tab.dataset.catTab;
    document.querySelectorAll('[data-cat-tab]').forEach(t => {
      const active = t.dataset.catTab === id;
      t.classList.toggle('is-active', active);
      t.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    document.querySelectorAll('[data-cat-panel]').forEach(p => {
      const active = p.dataset.catPanel === id;
      p.classList.toggle('is-active', active);
      if (active) p.removeAttribute('hidden'); else p.setAttribute('hidden', '');
    });
  });

  // ─── Filtro de perfil (Influencer / Nómada / Dueño / Todos) ───
  function applyPerfilFilter(perfilId) {
    document.querySelectorAll('[data-perfil-filter]').forEach(p => {
      const active = p.dataset.perfilFilter === perfilId;
      p.classList.toggle('is-active', active);
      p.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    // Filtra cards y actualiza contadores por categoría
    const counts = { contenido: 0, apoyo: 0, filantropia: 0 };
    document.querySelectorAll('[data-cat-panel]').forEach(panel => {
      const cat = panel.dataset.catPanel;
      let visible = 0;
      panel.querySelectorAll('.p-content-type-card').forEach(card => {
        const tags = (card.dataset.perfiles || 'todos').split(',');
        const show = perfilId === 'todos' || tags.includes('todos') || tags.includes(perfilId);
        card.classList.toggle('is-hidden', !show);
        if (show) visible++;
      });
      if (cat) counts[cat] = visible;
      // Mensaje vacío
      let emptyMsg = panel.querySelector('.p-cat-panel-empty');
      if (visible === 0) {
        if (!emptyMsg) {
          emptyMsg = document.createElement('div');
          emptyMsg.className = 'p-cat-panel-empty';
          emptyMsg.textContent = 'Sin acciones específicas para este perfil en esta categoría — cambia el perfil o explora otro tab.';
          panel.querySelector('.p-content-types-grid')?.appendChild(emptyMsg);
        }
      } else if (emptyMsg) {
        emptyMsg.remove();
      }
    });
    document.querySelectorAll('[data-cat-count]').forEach(c => {
      const cat = c.dataset.catCount;
      if (counts[cat] !== undefined) c.textContent = String(counts[cat]);
    });
  }
  document.addEventListener('click', e => {
    const pill = e.target.closest('[data-perfil-filter]');
    if (!pill) return;
    applyPerfilFilter(pill.dataset.perfilFilter);
  });

  // Initial tab from hash or initialTab
  const hash = (location.hash || '').replace('#', '');
  showTab(hash || initialTab);

  // ─── Preview del panel modal (siempre disponible) ───
  const previewOverlay = document.getElementById('preview-overlay');
  const btnOpenPreview = document.getElementById('btn-open-preview');
  const btnClosePreview = document.getElementById('btn-close-preview');
  function openPreview() {
    if (previewOverlay) {
      previewOverlay.style.display = 'block';
      document.body.style.overflow = 'hidden';
      // Reset to first tab
      switchPpTab('resumen');
    }
  }
  function closePreview() {
    if (previewOverlay) {
      previewOverlay.style.display = 'none';
      document.body.style.overflow = '';
    }
  }
  btnOpenPreview && btnOpenPreview.addEventListener('click', openPreview);
  btnClosePreview && btnClosePreview.addEventListener('click', closePreview);

  // ─── Preview portal: navegación entre tabs internos ───
  function switchPpTab(tabName) {
    if (!tabName) return;
    document.querySelectorAll('.pp-app-nav[data-pp-tab]').forEach(btn => {
      btn.classList.toggle('pp-app-nav--active', btn.getAttribute('data-pp-tab') === tabName);
    });
    document.querySelectorAll('.pp-app-panel[data-pp-panel]').forEach(panel => {
      panel.classList.toggle('pp-app-panel--active', panel.getAttribute('data-pp-panel') === tabName);
    });
    const main = document.querySelector('.pp-app-main');
    if (main) main.scrollTop = 0;
  }
  document.querySelectorAll('[data-pp-tab]').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const tab = el.getAttribute('data-pp-tab');
      if (tab) switchPpTab(tab);
    });
  });
  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && previewOverlay && previewOverlay.style.display !== 'none') closePreview();
  });

  // ─── Preview portal: filtros de comisiones ───
  const ppFiltersState = { estado: 'todas', tipo: 'todos' };
  function applyPpFilters() {
    const table = document.getElementById('pp-comisiones-table');
    if (!table) return;
    const rows = table.querySelectorAll('.pp-trow:not(.pp-trow--head)');
    let visibleCount = 0;
    rows.forEach((row) => {
      const estado = row.getAttribute('data-pp-estado');
      const tipo = row.getAttribute('data-pp-tipo');
      const matchEstado = ppFiltersState.estado === 'todas' || estado === ppFiltersState.estado;
      const matchTipo = ppFiltersState.tipo === 'todos' || tipo === ppFiltersState.tipo;
      const visible = matchEstado && matchTipo;
      row.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });
    // Show empty state if no rows visible
    let empty = table.querySelector('.pp-trow--empty');
    if (visibleCount === 0) {
      if (!empty) {
        empty = document.createElement('div');
        empty.className = 'pp-trow pp-trow--empty';
        empty.innerHTML = '<span style="grid-column: 1 / -1; text-align: center; color: #888; padding: 24px 0; font-size: 0.875rem">No hay comisiones que coincidan con este filtro.</span>';
        table.appendChild(empty);
      }
    } else if (empty) {
      empty.remove();
    }
  }
  document.querySelectorAll('[data-pp-filter]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const filterType = btn.getAttribute('data-pp-filter');
      const value = btn.getAttribute('data-pp-value') || '';
      if (!filterType || !value) return;
      ppFiltersState[filterType] = value;
      // Update active state within same group
      const group = btn.closest('[data-pp-filter-group]');
      if (group) {
        group.querySelectorAll('.pp-filter').forEach((f) => f.classList.remove('pp-filter--active'));
        btn.classList.add('pp-filter--active');
      }
      applyPpFilters();
    });
  });
  // Close on overlay backdrop click
  previewOverlay && previewOverlay.addEventListener('click', (e) => {
    if (e.target === previewOverlay) closePreview();
  });
  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && previewOverlay && previewOverlay.style.display === 'flex') {
      closePreview();
    }
  });

  if (isClosed) return;

  // ─── Signature canvas ───
  // CRITICAL: el canvas vive dentro del tab 'firma' que está display:none
  // al cargar. getBoundingClientRect() retorna 0×0 en ese estado, así que
  // el resize inicial dejaba el canvas a 0×0 y los pointer events no
  // dibujaban nada. Solución: inicializar lazy cuando el tab se activa,
  // re-init en cada apertura del tab para manejar rotación / resize.
  const canvas = document.getElementById('signature-canvas');
  let hasDrawn = false;
  let signatureInitialized = false;

  function initSignature() {
    if (!canvas) return;
    const rect = canvas.getBoundingClientRect();
    if (rect.width === 0 || rect.height === 0) return; // todavía oculto
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const dpr = window.devicePixelRatio || 1;

    // Si ya tiene contenido y mismo size, no rehacer
    const targetW = Math.round(rect.width * dpr);
    const targetH = Math.round(rect.height * dpr);
    if (signatureInitialized && canvas.width === targetW && canvas.height === targetH) return;

    // Si re-init con dibujo previo: preservar imagen redibujándola
    let prevImage = null;
    if (hasDrawn && canvas.width > 0 && canvas.height > 0) {
      prevImage = canvas.toDataURL('image/png');
    }
    canvas.width = targetW;
    canvas.height = targetH;
    ctx.setTransform(1, 0, 0, 1, 0, 0); // reset matrix antes de scale
    ctx.scale(dpr, dpr);
    ctx.lineWidth = 2.2;
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
    ctx.strokeStyle = '#1a1a1a';
    if (prevImage) {
      const img = new Image();
      img.onload = () => ctx.drawImage(img, 0, 0, rect.width, rect.height);
      img.src = prevImage;
    }
    signatureInitialized = true;
  }

  if (canvas) {
    const ctx = canvas.getContext('2d');
    let drawing = false;
    function getPos(e) {
      const rect = canvas.getBoundingClientRect();
      const t = e.touches ? e.touches[0] : e;
      return { x: t.clientX - rect.left, y: t.clientY - rect.top };
    }
    function start(e) {
      // Lazy init si todavía no está listo
      if (!signatureInitialized) initSignature();
      if (!signatureInitialized) return;
      drawing = true;
      const p = getPos(e);
      ctx.beginPath();
      ctx.moveTo(p.x, p.y);
      if (e.cancelable) e.preventDefault();
    }
    function move(e) {
      if (!drawing) return;
      const p = getPos(e);
      ctx.lineTo(p.x, p.y);
      ctx.stroke();
      hasDrawn = true;
      if (e.cancelable) e.preventDefault();
    }
    function end() { drawing = false; }

    canvas.addEventListener('mousedown', start);
    canvas.addEventListener('mousemove', move);
    canvas.addEventListener('mouseup', end);
    canvas.addEventListener('mouseleave', end);
    canvas.addEventListener('touchstart', start, { passive: false });
    canvas.addEventListener('touchmove', move, { passive: false });
    canvas.addEventListener('touchend', end);

    // Re-init cuando cambia el viewport (rotación, resize)
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(initSignature, 120);
    });

    const btnClear = document.getElementById('btn-clear-sig');
    if (btnClear) btnClear.addEventListener('click', () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      hasDrawn = false;
    });
  }

  // ─── Payout method toggle ───
  const payoutRadios = document.querySelectorAll('input[name="payout-method"]');
  const payoutSections = document.querySelectorAll('.p-payout-detail[data-payout-section]');
  function syncPayoutSections() {
    let active = 'clabe';
    payoutRadios.forEach(r => { if (r.checked) active = r.value; });
    payoutSections.forEach(s => {
      s.hidden = s.dataset.payoutSection !== active;
    });
  }
  payoutRadios.forEach(r => r.addEventListener('change', syncPayoutSections));
  syncPayoutSections();

  function val(id) {
    const el = document.getElementById(id);
    return el ? (el.value || '').trim() : '';
  }

  // ─── Accept (submit for review) ───
  const btnAccept = document.getElementById('btn-accept');
  if (btnAccept) btnAccept.addEventListener('click', async () => {
    const nombre = val('sign-nombre');
    const email = val('sign-email');
    const whatsapp = val('sign-whatsapp');
    const empresa = val('sign-empresa');

    const direccion = {
      calle: val('addr-calle'),
      colonia: val('addr-colonia'),
      cp: val('addr-cp'),
      ciudad: val('addr-ciudad'),
      estado: val('addr-estado'),
    };

    let payoutMethod = 'clabe';
    payoutRadios.forEach(r => { if (r.checked) payoutMethod = r.value; });
    let payout = { method: payoutMethod };
    if (payoutMethod === 'clabe') {
      payout = {
        method: 'clabe',
        clabe: val('payout-clabe'),
        banco: val('payout-banco'),
        titular: val('payout-titular'),
        rfc: val('payout-rfc'),
      };
    } else if (payoutMethod === 'paypal') {
      payout = { method: 'paypal', email: val('payout-paypal') };
    } else if (payoutMethod === 'mercadopago') {
      payout = {
        method: 'mercadopago',
        mp_id: val('payout-mp-id'),
        titular: val('payout-mp-titular'),
      };
    }

    // Validation
    if (!nombre) { alert('Ingresa tu nombre completo'); document.getElementById('sign-nombre')?.focus(); return; }
    if (!email) { alert('Ingresa tu email para enviarte la confirmación'); document.getElementById('sign-email')?.focus(); return; }
    if (!direccion.calle || !direccion.cp || !direccion.ciudad || !direccion.estado) {
      alert('Completa la dirección del negocio (calle, CP, ciudad y estado son requeridos)');
      document.getElementById('addr-calle')?.focus();
      return;
    }
    if (payoutMethod === 'clabe') {
      if (!payout.clabe || payout.clabe.length !== 18 || !/^\d{18}$/.test(payout.clabe)) {
        alert('La CLABE debe tener exactamente 18 dígitos');
        document.getElementById('payout-clabe')?.focus();
        return;
      }
      if (!payout.banco || !payout.titular) {
        alert('Completa banco y titular de la cuenta');
        return;
      }
    } else if (payoutMethod === 'paypal') {
      if (!payout.email || !payout.email.includes('@')) {
        alert('Ingresa un email PayPal válido');
        document.getElementById('payout-paypal')?.focus();
        return;
      }
    } else if (payoutMethod === 'mercadopago') {
      if (!payout.mp_id) {
        alert('Ingresa tu email o alias de Mercado Pago');
        document.getElementById('payout-mp-id')?.focus();
        return;
      }
    }
    if (!hasDrawn) { alert('Firma con tu dedo o mouse antes de enviar'); return; }

    btnAccept.disabled = true;
    btnAccept.textContent = 'Enviando solicitud...';

    const firma_base64 = canvas ? canvas.toDataURL('image/png') : '';
    try {
      const res = await fetch('/api/partners/accept-invitation', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: invitationId,
          nombre,
          email,
          whatsapp,
          empresa,
          direccion,
          payout,
          firma_base64,
        }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'No se pudo enviar');
      // If auto-approved, reload to render certificate. Otherwise advance to step 3.
      if (data.auto_approved) {
        window.location.reload();
      } else {
        if (typeof goSwStep === 'function') goSwStep(3);
        else window.location.reload();
      }
    } catch (err) {
      alert('Hubo un error: ' + (err.message || err));
      btnAccept.disabled = false;
      btnAccept.textContent = 'Firmar y enviar al equipo SACS';
    }
  });

  // ─── Sign wizard navigation ───
  function goSwStep(n) {
    const max = 3;
    const target = Math.max(1, Math.min(max, Number(n) || 1));
    document.querySelectorAll('[data-sw-step]').forEach((el) => {
      const num = Number(el.getAttribute('data-sw-step'));
      el.classList.toggle('is-active', num === target);
      el.classList.toggle('is-done', num < target);
    });
    document.querySelectorAll('[data-sw-panel]').forEach((el) => {
      const num = Number(el.getAttribute('data-sw-panel'));
      el.classList.toggle('is-active', num === target);
    });
    // Scroll to top of the wizard
    const wizard = document.getElementById('sign-wizard');
    if (wizard) {
      const rect = wizard.getBoundingClientRect();
      window.scrollTo({ top: window.scrollY + rect.top - 90, behavior: 'smooth' });
    }
  }
  document.querySelectorAll('[data-sw-go]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const target = Number(btn.getAttribute('data-sw-go'));
      // Validate when going forward to step 2
      if (target === 2) {
        const nombre = (document.getElementById('sign-nombre')||{}).value || '';
        const email = (document.getElementById('sign-email')||{}).value || '';
        if (!nombre.trim() || !email.trim()) {
          alert('Por favor completa nombre y email antes de continuar.');
          return;
        }
      }
      goSwStep(target);
    });
  });

  // Allow clicking active stepper steps to navigate
  document.querySelectorAll('[data-sw-step]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = Number(btn.getAttribute('data-sw-step'));
      // Only allow going to steps already visited (active or done)
      if (btn.classList.contains('is-done')) goSwStep(target);
    });
  });

  // Print certificate (cert-only print mode)
  const btnPrint = document.getElementById('btn-cert-print');
  if (btnPrint) btnPrint.addEventListener('click', () => {
    document.body.classList.add('print-mode-cert');
    window.print();
    setTimeout(() => document.body.classList.remove('print-mode-cert'), 1000);
  });

  // ─── FAB: print whole document as PDF ───
  const btnFabPrint = document.getElementById('p-fab-print');
  if (btnFabPrint) btnFabPrint.addEventListener('click', () => {
    document.body.classList.add('print-mode-doc');
    window.print();
    setTimeout(() => document.body.classList.remove('print-mode-doc'), 1000);
  });

  // FAB visible solo después del 25% de scroll
  const fab = document.getElementById('p-fab');
  if (fab) {
    function onScroll() {
      const pct = (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight;
      const show = window.scrollY > 240 && pct < 0.98;
      fab.classList.toggle('is-visible', show);
      fab.setAttribute('aria-hidden', show ? 'false' : 'true');
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // ─── Decline ───
  const declineModal = document.getElementById('decline-modal');
  const btnDecline = document.getElementById('btn-decline');
  const btnCloseDecline = document.getElementById('btn-close-decline');
  const btnCancelDecline = document.getElementById('btn-cancel-decline');
  const btnConfirmDecline = document.getElementById('btn-confirm-decline');

  function openDecline() { if (declineModal) declineModal.style.display = 'flex'; }
  function closeDecline() { if (declineModal) declineModal.style.display = 'none'; }

  btnDecline && btnDecline.addEventListener('click', openDecline);
  btnCloseDecline && btnCloseDecline.addEventListener('click', closeDecline);
  btnCancelDecline && btnCancelDecline.addEventListener('click', closeDecline);

  btnConfirmDecline && btnConfirmDecline.addEventListener('click', async () => {
    const motivoInput = document.querySelector('input[name="decline-motivo"]:checked');
    const detalleInput = document.getElementById('decline-detalle');
    const motivo = motivoInput ? motivoInput.value : '';
    const detalle = detalleInput ? detalleInput.value.trim() : '';
    if (!motivo) { alert('Selecciona un motivo'); return; }

    btnConfirmDecline.disabled = true;
    btnConfirmDecline.textContent = 'Enviando...';
    try {
      const res = await fetch('/api/partners/decline-invitation', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: invitationId, motivo, detalle }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'No se pudo enviar');
      window.location.reload();
    } catch (err) {
      alert('Error: ' + (err.message || err));
      btnConfirmDecline.disabled = false;
      btnConfirmDecline.textContent = 'Enviar respuesta';
    }
  });

  // ─── Mensual / Anual toggle (proyección de ganancias) ───
  document.querySelectorAll('.p-toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const view = btn.dataset.projectionView;
      if (!view) return;
      // Update all scopes (matrix + closing cards)
      document.querySelectorAll('[data-projection-scope]').forEach(scope => {
        scope.dataset.projectionView = view;
      });
      // Sync the active state on all toggle buttons
      document.querySelectorAll('.p-toggle-btn').forEach(b => {
        const isActive = b.dataset.projectionView === view;
        b.classList.toggle('is-active', isActive);
        b.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
    });
  });
})();
</script>
