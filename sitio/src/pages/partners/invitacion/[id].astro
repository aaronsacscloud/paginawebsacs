    color: rgba(147,180,255,0.85);
    margin-bottom: 8px;
  }
  .p-calc-title {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.6vw, 1.75rem);
    font-weight: 300;
    color: #fff;
    letter-spacing: -0.02em;
    margin: 0 0 8px;
  }
  .p-calc-lead {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.72);
    line-height: 1.6;
    margin: 0 0 28px;
  }
  .p-calc-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 28px;
  }
  @media (max-width: 720px) { .p-calc-grid { grid-template-columns: 1fr; } }
  .p-calc-input {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 16px 18px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
  }
  .p-calc-input-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }
  .p-calc-input-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
  }
  .p-calc-input-value {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.01em;
  }
  .p-calc-input-hint {
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.02em;
  }
  .p-calc-range {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 4px;
    background: rgba(255,255,255,0.12);
    border-radius: 999px;
    outline: none;
    margin: 4px 0;
  }
  .p-calc-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: #4B7BE5;
    cursor: pointer;
    border: 2px solid #fff;
    box-shadow: 0 0 0 4px rgba(75,123,229,0.18);
    transition: transform 0.15s;
  }
  .p-calc-range::-webkit-slider-thumb:hover { transform: scale(1.1); }
  .p-calc-range::-moz-range-thumb {
    width: 18px; height: 18px;
    border-radius: 50%;
    background: #4B7BE5;
    cursor: pointer;
    border: 2px solid #fff;
  }
  .p-calc-select {
    width: 100%;
    padding: 8px 12px;
    background: rgba(255,255,255,0.06);
