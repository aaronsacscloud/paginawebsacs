    border-radius: 8px;
    color: #fff;
    font-size: 0.875rem;
    cursor: pointer;
  }
  .p-calc-select option { background: #1a1a1a; color: #fff; }
  .p-calc-out {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 18px;
  }
  @media (max-width: 720px) { .p-calc-out { grid-template-columns: 1fr; } }
  .p-calc-out-card {
    padding: 18px 20px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
  }
  .p-calc-out-card--featured {
    background: linear-gradient(180deg, rgba(75,123,229,0.18), rgba(75,123,229,0.04));
    border-color: rgba(75,123,229,0.35);
