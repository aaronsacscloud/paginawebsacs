  .p-calc-out-card--featured {
    background: linear-gradient(180deg, rgba(75,123,229,0.18), rgba(75,123,229,0.04));
    border-color: rgba(75,123,229,0.35);
  }
  .p-calc-out-card--total {
    background: linear-gradient(180deg, rgba(42,140,95,0.20), rgba(42,140,95,0.04));
    border-color: rgba(42,140,95,0.40);
  }
  .p-calc-out-label {
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.62);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .p-calc-out-amount {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.6vw, 1.75rem);
