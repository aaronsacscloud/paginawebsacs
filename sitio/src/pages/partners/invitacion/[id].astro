    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .p-projection-closing-detail {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.5;
    margin-top: 6px;
  }
  .p-projection-closing-bottom {
    margin: 0;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
