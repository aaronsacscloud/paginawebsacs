  }
  @media (max-width: 720px) { .p-why-stats { grid-template-columns: repeat(2, 1fr); } }
  .p-why-stat {
    padding: 24px 16px;
    border-right: 1px solid #e5e5e5;
    text-align: left;
  }
  .p-why-stat:last-child { border-right: none; }
  @media (max-width: 720px) {
    .p-why-stat:nth-child(2) { border-right: none; }
