  }

  /* ─── Bienvenida storytelling (p-bw-*) ─────────────────────── */
  .p-bw-section {
    padding: 64px 0;
    border-top: 1px solid #ececec;
  }
  .p-bw-section--alt {
    background: #FAFAF8;
    margin: 0 -32px;
    padding: 64px 32px;
  }
  .p-bw-section--dark {
    background: #1A1A1A;
    color: #fff;
    margin: 0 -32px;
    padding: 72px 32px;
  }
  @media (max-width: 640px) {
    .p-bw-section { padding: 40px 0; }
    .p-bw-section--alt, .p-bw-section--dark { margin: 0 -20px; padding: 48px 20px; }
  }

  .p-bw-eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .p-bw-eyebrow--light { color: #93b4ff; }

  .p-bw-title {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 3.4vw, 2.375rem);
    font-weight: 300;
    color: #1A1A1A;
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin: 0 0 20px;
  }
  .p-bw-title--light { color: #fff; }

  .p-bw-lead {
    font-size: 1.0625rem;
    color: #555;
    line-height: 1.7;
    margin: 0 0 16px;
    max-width: 640px;
  }
  .p-bw-lead strong { color: #1a1a1a; }
  .p-bw-lead--light { color: rgba(255,255,255,0.78); }
  .p-bw-lead--light strong { color: #fff; }

  .p-bw-bullets {
    display: flex; flex-direction: column; gap: 12px;
    margin-top: 24px;
  }
  .p-bw-bullet {
    display: flex; gap: 12px;
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.55;
  }
  .p-bw-bullet-mark {
    color: #4B7BE5;
    font-weight: 700;
    flex-shrink: 0;
  }
  .p-bw-bullet strong { color: #1a1a1a; }

  /* Grid 2 col responsive */
  .p-bw-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 48px;
    align-items: start;
    margin-bottom: 32px;
  }
  .p-bw-grid--reverse { grid-template-columns: 1.4fr 1fr; }
  @media (max-width: 768px) {
    .p-bw-grid, .p-bw-grid--reverse { grid-template-columns: 1fr; gap: 24px; }
  }

  /* Pillars (triple impacto) */
  .p-bw-pillars {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-top: 32px;
  }
  .p-bw-pillar {
    padding: 24px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 10px;
  }
  .p-bw-pillar-num {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: #4B7BE5;
    letter-spacing: 0.04em;
    margin-bottom: 14px;
  }
  .p-bw-pillar-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: #1A1A1A;
    margin-bottom: 8px;
    letter-spacing: -0.005em;
  }
  .p-bw-pillar-detail {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.55;
  }

  /* Diff grid */
  .p-bw-diff-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 18px;
    margin-top: 32px;
  }
  .p-bw-diff {
    padding: 0 0 0 16px;
    border-left: 2px solid #4B7BE5;
  }
  .p-bw-diff-head {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1A1A1A;
    margin-bottom: 8px;
  }
  .p-bw-diff p {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.6;
    margin: 0;
  }

  /* Verticals — Squareup-style: image-first, generous spacing */
  .p-bw-verticals {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    margin-top: 48px;
  }
  @media (max-width: 720px) {
    .p-bw-verticals {
      grid-template-columns: 1fr;
      gap: 24px;
      margin-top: 36px;
    }
  }
  .p-bw-vertical {
    position: relative;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 1px 2px rgba(0,0,0,0.04);
  }
  .p-bw-vertical:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.08);
  }
  .p-bw-vertical-media {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: #f4f2ee;
  }
  .p-bw-vertical-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .p-bw-vertical:hover .p-bw-vertical-media img {
    transform: scale(1.04);
  }
  .p-bw-vertical-rank {
    position: absolute;
    top: 16px;
    left: 16px;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #1A1A1A;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 6px 10px;
    border-radius: 6px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }
  .p-bw-vertical-body {
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  @media (max-width: 720px) {
    .p-bw-vertical-body { padding: 22px 22px 26px; }
  }
  .p-bw-vertical-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.7rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    margin-bottom: 12px;
  }
  .p-bw-vertical-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent, #4B7BE5);
    flex-shrink: 0;
  }
  .p-bw-vertical-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: #1A1A1A;
    margin: 0 0 20px;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  @media (max-width: 720px) {
    .p-bw-vertical-name { font-size: 1.3125rem; margin-bottom: 16px; }
  }
  .p-bw-vertical-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }
  .p-bw-vertical-chip {
    font-size: 0.75rem;
    padding: 7px 12px;
    background: #FAFAF8;
    color: #1A1A1A;
    border: 1px solid #ececea;
    border-radius: 8px;
    font-weight: 500;
    letter-spacing: -0.005em;
    line-height: 1.2;
    transition: background 0.18s, border-color 0.18s, color 0.18s;
  }
  .p-bw-vertical:hover .p-bw-vertical-chip {
    background: var(--accent-bg, rgba(75, 123, 229, 0.06));
    border-color: transparent;
    color: var(--accent, #4B7BE5);
  }
  .p-bw-vertical-foot {
    margin-top: auto;
    padding-top: 12px;
    font-size: 0.75rem;
    color: #999;
    font-weight: 500;
    letter-spacing: 0.005em;
    border-top: 1px solid #f0f0ee;
  }
  .p-bw-vertical-detail {
    font-size: 0.8125rem;
    color: #666;
    line-height: 1.5;
  }

  /* +70 más callout */
  .p-bw-verticals-more {
    margin-top: 28px;
    padding: 24px;
    background: linear-gradient(135deg, #FAFAF8 0%, #F4F4F2 100%);
    border: 1px dashed #d4d4d2;
    border-radius: 12px;
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }
  .p-bw-verticals-more-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #4B7BE5;
    color: #fff;
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 300;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .p-bw-verticals-more-body { flex: 1; }
  .p-bw-verticals-more-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: #1A1A1A;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .p-bw-verticals-more-text {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.6;
  }
  .p-bw-verticals-more-link {
    display: inline-block;
    margin-left: 6px;
    color: #4B7BE5;
    text-decoration: none;
    font-weight: 500;
  }
  .p-bw-verticals-more-link:hover { text-decoration: underline; }
  @media (max-width: 640px) {
    .p-bw-verticals-more {
      flex-direction: column;
      gap: 14px;
      padding: 20px;
    }
    .p-bw-verticals-more-icon { width: 40px; height: 40px; font-size: 1.5rem; }
  }

  /* Cases (clientes) */
  .p-bw-cases {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-top: 28px;
  }
  .p-bw-case {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 10px;
    overflow: hidden;
  }
  .p-bw-case-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
    background: #f5f5f5;
  }
  .p-bw-case-name {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1A1A1A;
    padding: 14px 16px 4px;
  }
  .p-bw-case-meta {
    font-size: 0.75rem;
    color: #888;
    padding: 0 16px 16px;
  }

  /* History (dark section) */
  .p-bw-history-img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    display: block;
  }
  .p-bw-history-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,0.12);
  }
  .p-bw-history-stat-num {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 3vw, 2.125rem);
    font-weight: 300;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 6px;
  }
  .p-bw-history-stat-label {
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.55);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  /* ─── Visión 1,000 embajadores ─── */
  .p-bw-vision {
    margin: 56px 0 0;
    padding: 64px 32px;
    background: linear-gradient(135deg, #4B7BE5 0%, #6C5CE7 50%, #1A1A1A 100%);
    border-radius: 16px;
    color: #fff;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .p-bw-vision::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 20%, rgba(255,255,255,0.10), transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(255,255,255,0.06), transparent 50%);
    pointer-events: none;
  }
  .p-bw-vision > * { position: relative; z-index: 1; }
  .p-bw-vision-eyebrow {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(255,255,255,0.14);
    color: rgba(255,255,255,0.92);
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .p-bw-vision-title {
    font-family: var(--font-display);
    margin: 0 0 20px;
    color: #fff;
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .p-bw-vision-num {
    display: block;
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 200;
    background: linear-gradient(120deg, #fff 0%, #B5D0FF 60%, #B49EFF 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .p-bw-vision-after {
    display: block;
    font-size: clamp(1.25rem, 2.6vw, 1.875rem);
    font-weight: 400;
    color: rgba(255,255,255,0.85);
    margin-top: 8px;
  }
  .p-bw-vision-lead {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: rgba(255,255,255,0.78);
    max-width: 580px;
    margin: 0 auto 36px;
    font-weight: 300;
  }

  .p-bw-tracker {
    max-width: 620px;
    margin: 0 auto;
    padding: 24px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px;
    backdrop-filter: blur(8px);
  }
  .p-bw-tracker-row {
    display: grid;
    grid-template-columns: 160px 1fr 100px;
    gap: 14px;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .p-bw-tracker-row:last-child { border-bottom: none; }
  .p-bw-tracker-row--soon { opacity: 0.55; }
  .p-bw-tracker-label {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.85);
    font-weight: 500;
    text-align: left;
  }
  .p-bw-tracker-bar {
    height: 8px;
    background: rgba(255,255,255,0.10);
    border-radius: 999px;
    overflow: hidden;
  }
  .p-bw-tracker-fill {
    height: 100%;
    background: linear-gradient(90deg, #6CD6C2 0%, #4B7BE5 100%);
    border-radius: 999px;
    transition: width 0.6s ease-out;
  }
  .p-bw-tracker-stat {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.75);
    text-align: right;
    font-family: var(--font-display);
  }
  .p-bw-tracker-stat strong { color: #fff; font-weight: 600; font-size: 1rem; }
  @media (max-width: 640px) {
    .p-bw-vision { margin: 32px 0 0; padding: 48px 20px; }
    .p-bw-tracker { padding: 18px; }
    .p-bw-tracker-row { grid-template-columns: 1fr; gap: 6px; padding: 12px 0; }
    .p-bw-tracker-stat { text-align: left; }
  }

  /* ─── 10% para impacto ─── */
  .p-bw-impact {
    margin: 32px 0 0;
    padding: 56px 36px;
    background: linear-gradient(180deg, #FAFAF8 0%, #fff 100%);
    border: 1px solid #ececec;
    border-radius: 16px;
  }
  .p-bw-impact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }
  @media (max-width: 768px) {
    .p-bw-impact { padding: 40px 24px; }
    .p-bw-impact-grid { grid-template-columns: 1fr; gap: 28px; }
  }
  .p-bw-impact-eyebrow {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(42,181,160,0.12);
    color: #1A8F7A;
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .p-bw-impact-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.8vw, 2rem);
    font-weight: 400;
    color: #1A1A1A;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .p-bw-impact-lead {
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.65;
    margin: 0 0 14px;
  }
  .p-bw-impact-lead strong { color: #1A1A1A; }

  .p-bw-impact-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .p-bw-impact-card {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 10px;
    padding: 18px;
    transition: transform 0.18s, border-color 0.18s;
  }
  .p-bw-impact-card:hover {
    transform: translateY(-2px);
    border-color: #2AB5A0;
  }
  .p-bw-impact-card-num {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 300;
    color: #1A8F7A;
    letter-spacing: -0.025em;
    line-height: 1;
    margin-bottom: 8px;
  }
  .p-bw-impact-card-label {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 600;
    color: #1A1A1A;
    margin-bottom: 6px;
  }
  .p-bw-impact-card-detail {
    font-size: 0.75rem;
    color: #666;
    line-height: 1.5;
  }

  .p-bw-impact-note {
    margin-top: 28px;
    padding: 14px 18px;
    background: rgba(75,123,229,0.08);
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 8px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.875rem;
    color: #444;
    line-height: 1.55;
  }
  .p-bw-impact-note > span:first-child { font-size: 1.125rem; flex-shrink: 0; }

  /* CTA final */
  .p-bw-cta {
    margin-top: 48px;
    padding: 48px 32px;
    background: linear-gradient(120deg, rgba(75,123,229,0.06), rgba(108,92,231,0.04));
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 14px;
    text-align: center;
  }
  .p-bw-cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.4vw, 1.625rem);
    font-weight: 500;
    color: #1A1A1A;
    margin: 0 0 12px;
    letter-spacing: -0.015em;
  }
  .p-bw-cta-lead {
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.55;
    max-width: 460px;
    margin: 0 auto 22px;
  }
  .p-bw-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 26px;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 8px;
    font-size: 0.9375rem;
    font-weight: 600;
    transition: background 0.15s;
  }
  .p-bw-cta-btn:hover { background: #4B7BE5; }

  /* ─── Contenido y puntos (tab "Contenido") ─────────────────── */
  .p-content-howto {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
    margin: 32px 0;
  }
  .p-content-howto-item {
    display: flex; gap: 14px;
    padding: 18px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 10px;
  }
  .p-content-howto-num {
    flex-shrink: 0;
    width: 30px; height: 30px;
    border-radius: 50%;
    background: #fff;
    color: #4B7BE5;
    border: 1px solid #4B7BE5;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.875rem;
  }
  .p-content-howto-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 4px;
    letter-spacing: -0.005em;
  }
  .p-content-howto-detail {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.55;
    margin: 0;
  }

  .p-content-h3 {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.4vw, 1.625rem);
    font-weight: 500;
    color: #1A1A1A;
    margin: 48px 0 18px;
    letter-spacing: -0.015em;
  }

  .p-content-types-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    margin-bottom: 36px;
  }
  .p-content-type-card {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 12px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.18s;
  }
  .p-content-type-card:hover { border-color: #cfd6e2; }
  .p-content-type-card--bonus {
    background: linear-gradient(180deg, rgba(75,123,229,0.04), #fff);
    border-color: #4B7BE5;
  }
  .p-content-type-img-wrap {
    margin: -20px -20px 16px;
    height: 160px;
    overflow: hidden;
    border-radius: 12px 12px 0 0;
    background: #f5f5f5;
  }
  .p-content-type-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .p-content-type-head {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid #f0f0f0;
  }
  .p-content-type-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1A1A1A;
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }
  .p-content-type-meta {
    font-size: 0.6875rem;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .p-content-type-pts {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 300;
    color: #4B7BE5;
    letter-spacing: -0.02em;
    line-height: 1;
    flex-shrink: 0;
  }
  .p-content-type-pts span {
    font-size: 0.75rem;
    color: #999;
    margin-left: 2px;
    font-weight: 400;
  }
  .p-content-type-desc {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.55;
    margin: 0;
  }
  .p-content-type-ideas-label {
    font-size: 0.625rem;
    font-weight: 700;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    margin-bottom: 4px;
  }
  .p-content-type-ideas ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .p-content-type-ideas li {
    position: relative;
    padding-left: 14px;
    font-size: 0.8125rem;
    color: #666;
    line-height: 1.45;
  }
  .p-content-type-ideas li::before {
    content: '·';
    position: absolute;
    left: 4px;
    color: #4B7BE5;
    font-weight: 700;
  }
  .p-content-type-platforms {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding-top: 8px;
    border-top: 1px solid #f5f5f5;
  }
  .p-content-type-platform {
    font-size: 0.6875rem;
    padding: 3px 9px;
    background: #f5f5f7;
    color: #666;
    border-radius: 999px;
    font-weight: 500;
  }
  .p-content-type-refs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    font-size: 0.75rem;
    color: #888;
  }
  .p-content-type-refs-label {
    font-weight: 600;
  }
  .p-content-type-ref {
    color: #4B7BE5;
    text-decoration: none;
  }
  .p-content-type-ref:hover { text-decoration: underline; }

  .p-content-notes {
    margin-top: 20px;
    padding: 24px;
    background: #FAFAF8;
    border: 1px solid #ececec;
    border-radius: 12px;
  }
  .p-content-notes-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 12px;
    letter-spacing: -0.005em;
  }
  .p-content-notes ul {
    margin: 0;
    padding-left: 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .p-content-notes li {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.55;
  }
  .p-content-notes li strong { color: #1a1a1a; }

  /* ─── Proceso (Cómo funciona) ─────────────────────── */
  .p-proc-steps {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 32px;
  }
  .p-proc-step {
    display: flex;
    gap: 18px;
    padding: 22px 24px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 14px;
    transition: border-color 0.18s, transform 0.18s;
  }
  .p-proc-step:hover {
    border-color: #cfd6e2;
    transform: translateY(-1px);
  }
  .p-proc-step-num {
    flex-shrink: 0;
    width: 38px; height: 38px;
    border-radius: 50%;
    background: #1a1a1a;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1rem;
  }
  .p-proc-step-body {
    flex: 1;
    min-width: 0;
  }
  .p-proc-step-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .p-proc-step-detail {
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.6;
    margin: 0 0 10px;
  }
  .p-proc-step-detail strong { color: #1a1a1a; font-weight: 700; }
  .p-proc-step-detail code {
    background: #f5f5f7;
    padding: 1px 6px;
    border-radius: 4px;
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 0.8125rem;
    color: #4B7BE5;
  }
  .p-proc-step-meta {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .p-proc-meta-pill {
    display: inline-block;
    padding: 4px 10px;
    background: rgba(75,123,229,0.10);
    color: #3764c4;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: 999px;
  }
  .p-proc-meta-pill--alt {
    background: rgba(42,181,160,0.10);
    color: #1A8F7A;
  }
  .p-proc-preview-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 6px;
    padding: 10px 16px;
    background: #1a1a1a;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .p-proc-preview-btn:hover { background: #4B7BE5; }

  .p-proc-cta {
    margin-top: 36px;
    text-align: center;
    padding: 28px;
    background: linear-gradient(120deg, rgba(75,123,229,0.06), rgba(108,92,231,0.04));
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 16px;
  }
  .p-proc-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 26px;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9375rem;
    transition: background 0.15s;
  }
  .p-proc-cta-btn:hover { background: #4B7BE5; }
  .p-proc-cta-arrow { font-size: 1.125rem; }

  @media (max-width: 640px) {
    .p-proc-step { padding: 18px 16px; gap: 14px; }
    .p-proc-step-num { width: 32px; height: 32px; font-size: 0.875rem; }
    .p-proc-step-title { font-size: 1rem; }
    .p-proc-step-detail { font-size: 0.875rem; }
  }

  /* ─── Preview modal del panel de partner ─────────────── */
  .p-preview-overlay {
    position: fixed;
    inset: 0;
    background: rgba(20,20,30,0.65);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    overflow-y: auto;
  }
  .p-preview-modal {
    width: 100%;
    max-width: 980px;
    max-height: 92vh;
    overflow-y: auto;
    background: #fff;
    border-radius: 18px;
    box-shadow: 0 30px 80px -20px rgba(0,0,0,0.30);
    display: flex;
    flex-direction: column;
  }
  .p-preview-header {
    position: sticky;
    top: 0;
    background: #fff;
    padding: 20px 24px;
    border-bottom: 1px solid #ececec;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    border-radius: 18px 18px 0 0;
    z-index: 1;
  }
  .p-preview-eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 6px;
  }
  .p-preview-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a1a;
    letter-spacing: -0.01em;
  }
  .p-preview-close {
    background: transparent;
    border: 1px solid #ddd;
    border-radius: 50%;
    width: 36px; height: 36px;
    cursor: pointer;
    font-size: 1.125rem;
    color: #666;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .p-preview-close:hover { border-color: #1a1a1a; color: #1a1a1a; }

  .p-preview-body {
    padding: 22px;
  }
  .p-preview-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
    margin-top: 22px;
  }
  .p-preview-feat {
    padding: 14px 16px;
    background: #fafafa;
    border: 1px solid #ececec;
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .p-preview-feat strong {
    font-family: var(--font-display);
    font-size: 0.875rem;
    color: #1a1a1a;
  }
  .p-preview-feat span {
    font-size: 0.8125rem;
    color: #666;
    line-height: 1.5;
  }

  /* ── Portal mockup (visual) ── */
  .pp-mock {
    background: #f5f6f8;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid #e5e7eb;
    box-shadow: 0 12px 32px -12px rgba(0,0,0,0.12);
    font-family: var(--font-body);
    color: #1a1a1a;
  }
  .pp-mock-topbar {
    background: #fff;
    padding: 10px 18px;
    border-bottom: 1px solid #ececec;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.8125rem;
  }
  .pp-mock-brand {
    font-family: 'Clash Display', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: #1a1a1a;
    letter-spacing: -0.02em;
  }
  .pp-mock-sep { color: #ccc; }
  .pp-mock-subtitle { color: #888; font-size: 0.75rem; font-weight: 500; }
  .pp-mock-username { color: #444; font-size: 0.75rem; font-weight: 600; }

  .pp-mock-body { display: flex; }
  .pp-mock-sidebar {
    width: 180px;
    background: #fff;
    border-right: 1px solid #ececec;
    padding: 14px 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-height: 360px;
  }
  .pp-mock-side-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    border-radius: 7px;
    font-size: 0.8125rem;
    color: #555;
    font-weight: 500;
  }
  .pp-mock-side-item--active {
    background: #1a1a1a;
    color: #fff;
  }
  .pp-mock-side-item--accent { color: #4B7BE5; }

  .pp-mock-main {
    flex: 1;
    padding: 22px 24px;
    background: #f5f6f8;
    overflow: hidden;
  }
  .pp-mock-h1 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 4px;
    letter-spacing: -0.015em;
  }
  .pp-mock-lead { font-size: 0.8125rem; color: #666; margin-bottom: 18px; }
  .pp-mock-h2 {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 22px 0 10px;
  }

  .pp-mock-kpi-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 10px;
  }
  .pp-mock-kpi {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 10px;
    padding: 14px;
  }
  .pp-mock-kpi-lbl {
    font-size: 0.625rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
    margin-bottom: 6px;
  }
  .pp-mock-kpi-val {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 800;
    color: #1a1a1a;
    line-height: 1.1;
    letter-spacing: -0.015em;
  }
  .pp-mock-kpi-hint {
    font-size: 0.6875rem;
    color: #999;
    margin-top: 4px;
  }

  .pp-mock-table {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 10px;
    overflow: hidden;
    font-size: 0.8125rem;
  }
  .pp-mock-trow {
    display: grid;
    grid-template-columns: 1.4fr 1fr 0.8fr;
    gap: 10px;
    padding: 10px 14px;
    border-bottom: 1px solid #f5f5f5;
    align-items: center;
  }
  .pp-mock-trow:last-child { border-bottom: none; }
  .pp-mock-trow--head {
    font-size: 0.625rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
    background: #fafafa;
  }
  .pp-mock-tag {
    display: inline-block;
    padding: 3px 8px;
    background: #f5f5f7;
    color: #666;
    border-radius: 999px;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-style: normal;
  }
  .pp-mock-tag--ok    { background: rgba(42,181,160,0.12); color: #1A8F7A; }
  .pp-mock-tag--blue  { background: rgba(75,123,229,0.12); color: #3764c4; }

  /* Mobile mockup: ocultar sidebar para que entre todo */
  @media (max-width: 640px) {
    .pp-mock-sidebar { display: none; }
    .pp-mock-main { padding: 16px; }
    .pp-mock-kpi-row { grid-template-columns: 1fr 1fr; }
    .pp-mock-trow { grid-template-columns: 1fr 1fr; }
    .pp-mock-trow > span:nth-child(3) { display: none; }
    .p-preview-modal { max-height: 96vh; border-radius: 14px; }
    .p-preview-body { padding: 14px; }
  }

  /* Sign form */
  .p-sign-form { padding: 56px 0 24px; max-width: 720px; margin: 0 auto; }
  @media (max-width: 640px) {
    .p-sign-form { padding: 24px 0 24px; }
  }

  /* Sección numerada (Tus datos / Dirección / Cobro / Firma) */
  .p-sign-section {
    margin-top: 36px;
    padding: 24px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 14px;
  }
  .p-sign-section-head {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid #f1f1f1;
  }
  .p-sign-section-num {
    width: 26px; height: 26px;
    border-radius: 50%;
    background: #1a1a1a; color: #fff;
    display: inline-flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-size: 0.8125rem; font-weight: 800;
  }
  .p-sign-section-title {
    font-family: var(--font-display);
    font-size: 1.05rem; font-weight: 700;
    color: #1a1a1a;
    letter-spacing: -0.01em;
  }
  .p-sign-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-top: 0;
  }
  .p-sign-section .p-sign-fields { margin-top: 0; }
  .p-sign-field--full { grid-column: 1 / -1; }
  .p-sign-optional {
    font-size: 0.6875rem; color: #bbb;
    text-transform: none; letter-spacing: 0; font-weight: 500;
    margin-left: 4px;
  }
  @media (max-width: 640px) {
    .p-sign-fields { grid-template-columns: 1fr; }
    .p-sign-section { padding: 18px; }
  }

  /* Payout method radios */
  .p-payout-methods {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
    margin-bottom: 18px;
  }
  @media (max-width: 640px) {
    .p-payout-methods { grid-template-columns: 1fr; }
  }
  .p-payout-opt {
    position: relative;
    display: flex; align-items: flex-start; gap: 10px;
    padding: 14px;
    background: #fafafa;
    border: 1.5px solid #ececec;
    border-radius: 10px;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .p-payout-opt:hover { border-color: #d0d0d0; }
  .p-payout-opt input[type="radio"] {
    margin: 2px 0 0;
