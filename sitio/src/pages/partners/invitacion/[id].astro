  }

  /* ─── Bienvenida storytelling (p-bw-*) ─────────────────────── */
  .p-bw-section {
    padding: 64px 0;
    border-top: 1px solid #ececec;
  }
  .p-bw-section--alt {
    background: #FAFAF8;
    margin: 0 -32px;
    padding: 64px 32px;
  }
  .p-bw-section--dark {
    background: #1A1A1A;
    color: #fff;
    margin: 0 -32px;
    padding: 72px 32px;
  }
  @media (max-width: 640px) {
    .p-bw-section { padding: 40px 0; }
    .p-bw-section--alt, .p-bw-section--dark { margin: 0 -20px; padding: 48px 20px; }
  }

  .p-bw-eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .p-bw-eyebrow--light { color: #93b4ff; }

  .p-bw-title {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 3.4vw, 2.375rem);
    font-weight: 300;
    color: #1A1A1A;
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin: 0 0 20px;
  }
  .p-bw-title--light { color: #fff; }

  .p-bw-lead {
    font-size: 1.0625rem;
    color: #555;
    line-height: 1.7;
    margin: 0 0 16px;
    max-width: 640px;
  }
  .p-bw-lead strong { color: #1a1a1a; }
  .p-bw-lead--light { color: rgba(255,255,255,0.78); }
  .p-bw-lead--light strong { color: #fff; }

  .p-bw-bullets {
    display: flex; flex-direction: column; gap: 12px;
    margin-top: 24px;
  }
  .p-bw-bullet {
    display: flex; gap: 12px;
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.55;
  }
  .p-bw-bullet-mark {
    color: #4B7BE5;
    font-weight: 700;
    flex-shrink: 0;
  }
  .p-bw-bullet strong { color: #1a1a1a; }

  /* Grid 2 col responsive */
  .p-bw-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 48px;
    align-items: start;
    margin-bottom: 32px;
  }
  .p-bw-grid--reverse { grid-template-columns: 1.4fr 1fr; }
  @media (max-width: 768px) {
    .p-bw-grid, .p-bw-grid--reverse { grid-template-columns: 1fr; gap: 24px; }
  }

  /* Pillars (triple impacto) */
  .p-bw-pillars {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-top: 32px;
  }
  .p-bw-pillar {
    padding: 24px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 10px;
  }
  .p-bw-pillar-num {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: #4B7BE5;
    letter-spacing: 0.04em;
    margin-bottom: 14px;
  }
  .p-bw-pillar-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: #1A1A1A;
    margin-bottom: 8px;
    letter-spacing: -0.005em;
  }
  .p-bw-pillar-detail {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.55;
  }

  /* Diff grid */
  .p-bw-diff-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 18px;
    margin-top: 32px;
  }
  .p-bw-diff {
    padding: 0 0 0 16px;
    border-left: 2px solid #4B7BE5;
  }
  .p-bw-diff-head {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1A1A1A;
    margin-bottom: 8px;
  }
  .p-bw-diff p {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.6;
    margin: 0;
  }

  /* Verticals — Squareup-style: image-first, generous spacing */
  .p-bw-verticals {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    margin-top: 48px;
  }
  @media (max-width: 720px) {
    .p-bw-verticals {
      grid-template-columns: 1fr;
      gap: 24px;
      margin-top: 36px;
    }
  }
  .p-bw-vertical {
    position: relative;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 1px 2px rgba(0,0,0,0.04);
  }
  .p-bw-vertical:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.08);
  }
  .p-bw-vertical-media {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: #f4f2ee;
  }
  .p-bw-vertical-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .p-bw-vertical:hover .p-bw-vertical-media img {
    transform: scale(1.04);
  }
  .p-bw-vertical-rank {
    position: absolute;
    top: 16px;
    left: 16px;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #1A1A1A;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 6px 10px;
