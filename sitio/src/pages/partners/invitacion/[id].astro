  .p-matrix-td--clients {
    text-align: left;
    padding-left: 22px;
    font-size: 0.875rem;
    color: rgba(26,26,46,0.7);
    background: #fafafa;
  }
  .p-matrix-td--clients strong {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: #1a1a1a;
    margin-right: 6px;
