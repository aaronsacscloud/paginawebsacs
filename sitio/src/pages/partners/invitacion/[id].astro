  /* ─── Sign wizard stepper ─── */
  .p-sw-stepper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin: 24px 0 40px;
  }
  .p-sw-step {
    display: flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 4px;
    font-family: inherit;
    color: #999;
    transition: color 0.15s;
  }
  .p-sw-step:disabled { cursor: default; opacity: 0.6; }
  .p-sw-step:not(:disabled):hover { color: #666; }
  .p-sw-step-num {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: #ececec;
    color: #999;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 700;
    transition: background 0.15s, color 0.15s;
  }
  .p-sw-step-label {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: -0.005em;
  }
  .p-sw-step.is-active { color: #1a1a1a; }
  .p-sw-step.is-active .p-sw-step-num { background: #1a1a1a; color: #fff; }
  .p-sw-step.is-done { color: #1A8F7A; }
  .p-sw-step.is-done .p-sw-step-num { background: #2AB5A0; color: #fff; }
  .p-sw-step-line { flex: 0 1 60px; height: 1px; background: #ececec; }
  @media (max-width: 640px) {
    .p-sw-step-label { display: none; }
    .p-sw-step-line { flex: 0 1 30px; }
  }

  .p-sw-panel { display: none; }
  .p-sw-panel.is-active { display: block; }
  .p-sw-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  /* ─── Contract document ─── */
  .p-contract {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 14px;
