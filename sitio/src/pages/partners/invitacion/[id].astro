  .p-contract-meta {
    font-size: 0.8125rem;
    color: #888;
  }
  .p-contract-meta strong { color: #1a1a1a; font-weight: 600; }
  .p-contract-doc {
    max-height: 480px;
    overflow-y: auto;
    padding-right: 14px;
    font-size: 0.875rem;
    line-height: 1.7;
    color: #333;
  }
  .p-contract-doc p { margin: 0 0 14px; }
  .p-contract-doc h4 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 22px 0 10px;
    letter-spacing: -0.005em;
  }
  .p-contract-doc ul { margin: 0 0 14px; padding-left: 22px; }
  .p-contract-doc li { margin-bottom: 6px; }
  .p-contract-doc strong { color: #1a1a1a; font-weight: 600; }
  .p-contract-doc a { color: #4B7BE5; }
  .p-contract-accept {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-top: 24px;
