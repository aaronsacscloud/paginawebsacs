  .p-faq-item:hover { border-color: #cfd6e2; }
  .p-faq-item.is-open { border-color: #4B7BE5; }
  .p-faq-q {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    background: transparent;
