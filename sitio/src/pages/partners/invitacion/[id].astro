  /* ─── SECCIÓN 10 · Firma + CTA sticky ─── */
  @media (max-width: 640px) {
    .p-sw-stepper {
      gap: 8px !important;
      margin: 16px 0 28px !important;
    }
    .p-sw-step-num {
      width: 32px !important;
      height: 32px !important;
