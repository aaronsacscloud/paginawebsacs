  /* Dark template overrides for projection */
  .p-dark .p-demo-card { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.08); }
  .p-dark .p-demo-card-amount, .p-dark .p-demo-card-annual { color: #fff; }
  .p-dark .p-demo-card-meta, .p-dark .p-demo-card-period, .p-dark .p-demo-card-hint { color: rgba(255,255,255,0.55); }
  .p-dark .p-demo-card-annual { border-color: rgba(255,255,255,0.1); }
  .p-dark .p-matrix { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.08); }
  .p-dark .p-matrix-th, .p-dark .p-matrix-td { border-color: rgba(255,255,255,0.06); }
  .p-dark .p-matrix-th { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.7); }
  .p-dark .p-matrix-td--clients { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.7); }
  .p-dark .p-matrix-td--clients strong, .p-dark .p-matrix-amount, .p-dark .p-matrix-plan-name { color: #fff; }
  .p-dark .p-matrix-sub, .p-dark .p-matrix-plan-price { color: rgba(255,255,255,0.45); }
  .p-dark .p-matrix-note { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.65); }

  /* ¿Por qué SACS? */
  .p-why-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
