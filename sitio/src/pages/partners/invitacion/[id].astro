}

const beneficios: any[] = Array.isArray(invitation.beneficios) ? invitation.beneficios : [];
const compromisos: any[] = Array.isArray(invitation.compromisos) ? invitation.compromisos : [];
const tabulador: any = invitation.tabulador && typeof invitation.tabulador === 'object' ? invitation.tabulador : {};

// ─── Especialidad de nicho (por invitación, mismo patrón que escalonado) ───
// Config viva en tabulador.especialidad. Cuando está activa, la invitación se
// re-enfoca al giro elegido (ej. papelerías): badge en el hero, pitch del
// nicho y la sección de verticales se convierte en "Tu especialidad" con las
// suites del giro. Las reglas de comisión NO cambian — solo el posicionamiento.
const esp = especialidadDe(invitation);
const espSector = esp && esp.sectorIconId
  ? businessSectors.find((s: any) => s.iconId === esp.sectorIconId) || null
  : null;

// ─── Paquete Escalonado de Licencias (modo interno, por invitación) ───
// Config viva en tabulador.escalonado. El partner compra al mayoreo un paquete
// de licencias Fideliza (inversión escalonada) y las revende al precio público
// ($14k/año). Sus ganancias se basan en la REVENTA del paquete, no en la
// comisión del 50% — esa aplica solo cuando agota su paquete. Es un EXTRA: si
// no está activo, la invitación se comporta exactamente igual que antes.
const escCfg: any = tabulador && typeof tabulador.escalonado === 'object' ? tabulador.escalonado : null;
const escalonadoOn = !!(escCfg && escCfg.enabled && Array.isArray(escCfg.tiers) && escCfg.tiers.length > 0);
const escResale = Number(escCfg?.resale_price) > 0 ? Number(escCfg.resale_price) : 14000;
const ESC_COMISION_PCT = Number(comisionPct) > 0 ? Number(comisionPct) : 50; // comisión de referencia para la comparación
const escTiers = (escalonadoOn ? escCfg.tiers : [])
  .map((t: any) => {
    const price = Number(t.price || 0);
    const licenses = Number(t.licenses || 0);
    if (price <= 0 || licenses <= 0) return null;
    const grossResale = escResale * licenses;                 // valor de reventa total
    const netProfit = grossResale - price;                    // ganancia neta tras pagar el paquete
    const perLicenseCost = Math.round(price / licenses);      // costo mayoreo por licencia
    const perLicenseMargin = Math.round(escResale - price / licenses); // margen por licencia revendida
    const commissionEquiv = Math.round(escResale * (ESC_COMISION_PCT / 100)) * licenses; // lo mismo con comisión %
    const extraVsCommission = netProfit - commissionEquiv;    // cuánto MÁS rinde el paquete vs comisión
    const roiPct = price > 0 ? Math.round((netProfit / price) * 100) : 0;
    return { price, licenses, grossResale, netProfit, perLicenseCost, perLicenseMargin, commissionEquiv, extraVsCommission, roiPct };
  })
  .filter(Boolean)
  .sort((a: any, b: any) => a.price - b.price);
const escBest = escTiers.length > 0 ? escTiers[escTiers.length - 1] : null;

