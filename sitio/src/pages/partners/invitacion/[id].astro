  /* ─── SECCIÓN 2 · Embudo + App preview ─── */
  @media (max-width: 480px) {
    .p-funnel {
      padding: 36px 20px !important;
      margin: 32px 0 12px;
    }
    .p-funnel-title { font-size: 1.75rem !important; }
    .p-funnel-lead {
      font-size: 0.9375rem !important;
      margin-bottom: 32px !important;
    }
