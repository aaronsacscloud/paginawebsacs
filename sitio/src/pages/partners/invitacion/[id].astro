  /* ─── FAQ inline ───────────────────────────────────── */
  .p-faq {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 8px;
  }
  .p-faq-item {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.18s;
  }
  .p-faq-item:hover { border-color: #cfd6e2; }
  .p-faq-item.is-open { border-color: #4B7BE5; }
  .p-faq-q {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    background: transparent;
    border: 0;
    cursor: pointer;
    text-align: left;
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 500;
    color: #1a1a1a;
    letter-spacing: -0.005em;
