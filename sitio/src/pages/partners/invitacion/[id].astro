  }
  .p-why-stat-num {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 300;
    color: #1a1a1a;
    line-height: 1;
    letter-spacing: -0.025em;
    margin-bottom: 6px;
  }
  .p-why-stat-label {
    font-size: 0.6875rem; font-weight: 600;
    color: #999;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .p-why-pillars {
    display: grid;
