        ) : isDeclined ? (
          <div class="p-signed p-signed--declined">
            <div class="p-signed-eyebrow">Rechazada</div>
            <div class="p-signed-title">Gracias por tu respuesta.</div>
            <div class="p-signed-sub">Tu feedback nos ayuda a mejorar el programa. Si cambias de opinión, escríbenos a partners@sacscloud.com y reactivamos tu invitación.</div>
            {invitation.decline_motivo && (
              <div class="p-signed-meta">Motivo: <strong>{invitation.decline_motivo}</strong>{invitation.decline_detalle ? ` · ${invitation.decline_detalle}` : ''}</div>
            )}
          </div>
        ) : isExpired ? (
          <div class="p-signed p-signed--expired">
            <div class="p-signed-eyebrow">Vencida</div>
            <div class="p-signed-title">Esta invitación venció el {vigenciaLarga}.</div>
            <div class="p-signed-sub">Si todavía te interesa el programa, contáctanos y te enviamos una invitación renovada.</div>
            <div class="p-signed-cta-row">
              <a class="p-signed-cta" href={`https://wa.me/5215512345678?text=${encodeURIComponent(`Hola, mi invitación de partner ${invitation.numero || ''} venció. Me gustaría renovarla.`)}`} target="_blank" rel="noopener">Renovar invitación</a>
            </div>
          </div>
        ) : (
          <div class="p-sign-form">
            <div class="p-section-head p-section-head--center">
              <div class="p-section-eyebrow">Último paso</div>
              <h2 class="p-section-title">Acepta y firma tu invitación</h2>
              <p class="p-section-lead">
                Al firmar enviamos tu solicitud al equipo SACS para revisión. En cuanto la aprobemos te llegará un correo con tus credenciales del programa <strong>{tipoLabel[tipo] || tipo}</strong>.
              </p>
            </div>

            <div class="p-sign-section">
              <div class="p-sign-section-head">
                <span class="p-sign-section-num">1</span>
                <span class="p-sign-section-title">Tus datos</span>
              </div>
              <div class="p-sign-fields">
                <label class="p-sign-field">
                  <span>Nombre completo</span>
                  <input type="text" id="sign-nombre" class="p-input" placeholder="Ej. Mariana López" value={invitation.nombre || ''} />
                </label>
                <label class="p-sign-field">
                  <span>Email</span>
                  <input type="email" id="sign-email" class="p-input" placeholder="tu@correo.com" value={invitation.email || ''} />
                </label>
                <label class="p-sign-field">
                  <span>WhatsApp</span>
                  <input type="tel" id="sign-whatsapp" class="p-input" placeholder="55 1234 5678" value={invitation.whatsapp || ''} />
                </label>
                <label class="p-sign-field">
                  <span>Empresa o razón social <span class="p-sign-optional">(opcional)</span></span>
                  <input type="text" id="sign-empresa" class="p-input" placeholder="Ej. Mariana López Studio S.A. de C.V." value={invitation.empresa || ''} />
                </label>
              </div>
            </div>

            <div class="p-sign-section">
              <div class="p-sign-section-head">
                <span class="p-sign-section-num">2</span>
                <span class="p-sign-section-title">Dirección del negocio</span>
              </div>
              <div class="p-sign-fields">
                <label class="p-sign-field p-sign-field--full">
                  <span>Calle y número</span>
                  <input type="text" id="addr-calle" class="p-input" placeholder="Av. Insurgentes Sur 1234, Int. 5B" />
                </label>
                <label class="p-sign-field">
                  <span>Colonia</span>
                  <input type="text" id="addr-colonia" class="p-input" placeholder="Del Valle" />
                </label>
                <label class="p-sign-field">
                  <span>Código postal</span>
                  <input type="text" id="addr-cp" class="p-input" placeholder="03100" inputmode="numeric" maxlength="5" />
                </label>
                <label class="p-sign-field">
                  <span>Ciudad / Alcaldía</span>
                  <input type="text" id="addr-ciudad" class="p-input" placeholder="Benito Juárez" />
                </label>
                <label class="p-sign-field">
                  <span>Estado</span>
                  <input type="text" id="addr-estado" class="p-input" placeholder="CDMX" />
                </label>
              </div>
            </div>

            <div class="p-sign-section">
              <div class="p-sign-section-head">
                <span class="p-sign-section-num">3</span>
                <span class="p-sign-section-title">Cómo recibes tus comisiones</span>
              </div>
              <div class="p-payout-methods" role="radiogroup" aria-label="Método de cobro">
                <label class="p-payout-opt">
                  <input type="radio" name="payout-method" value="clabe" checked />
                  <span class="p-payout-opt-body">
                    <span class="p-payout-opt-title">CLABE / Transferencia</span>
                    <span class="p-payout-opt-sub">Depósito directo a banco mexicano</span>
                  </span>
                </label>
                <label class="p-payout-opt">
                  <input type="radio" name="payout-method" value="paypal" />
                  <span class="p-payout-opt-body">
                    <span class="p-payout-opt-title">PayPal</span>
                    <span class="p-payout-opt-sub">Recibe en cualquier moneda</span>
                  </span>
                </label>
                <label class="p-payout-opt">
                  <input type="radio" name="payout-method" value="mercadopago" />
                  <span class="p-payout-opt-body">
                    <span class="p-payout-opt-title">Mercado Pago</span>
                    <span class="p-payout-opt-sub">Saldo MP / cuenta vinculada</span>
                  </span>
                </label>
              </div>

              {/* Detalle por método */}
              <div class="p-sign-fields p-payout-detail" data-payout-section="clabe">
                <label class="p-sign-field">
                  <span>CLABE Interbancaria (18 dígitos)</span>
                  <input type="text" id="payout-clabe" class="p-input" placeholder="012180012345678901" inputmode="numeric" maxlength="18" />
                </label>
                <label class="p-sign-field">
                  <span>Banco</span>
                  <input type="text" id="payout-banco" class="p-input" placeholder="Ej. BBVA, Santander, Banorte..." />
                </label>
                <label class="p-sign-field">
                  <span>Titular de la cuenta</span>
                  <input type="text" id="payout-titular" class="p-input" placeholder="Como aparece en el estado de cuenta" />
                </label>
                <label class="p-sign-field">
                  <span>RFC <span class="p-sign-optional">(opcional)</span></span>
                  <input type="text" id="payout-rfc" class="p-input" placeholder="XAXX010101000" maxlength="13" />
                </label>
              </div>

              <div class="p-sign-fields p-payout-detail" data-payout-section="paypal" hidden>
                <label class="p-sign-field p-sign-field--full">
                  <span>Email de PayPal</span>
                  <input type="email" id="payout-paypal" class="p-input" placeholder="tu@paypal.com" />
                </label>
              </div>

              <div class="p-sign-fields p-payout-detail" data-payout-section="mercadopago" hidden>
                <label class="p-sign-field">
                  <span>Email o alias Mercado Pago</span>
                  <input type="text" id="payout-mp-id" class="p-input" placeholder="tu@correo.com o alias.mp" />
                </label>
                <label class="p-sign-field">
                  <span>Titular de la cuenta MP</span>
                  <input type="text" id="payout-mp-titular" class="p-input" placeholder="Tu nombre completo en MP" />
                </label>
              </div>
            </div>

            <div class="p-sign-section">
              <div class="p-sign-section-head">
                <span class="p-sign-section-num">4</span>
                <span class="p-sign-section-title">Firma de aceptación</span>
              </div>
              <div class="p-sign-canvas-wrap">
                <div class="p-sign-canvas-label">Firma con el dedo o el mouse</div>
                <canvas id="signature-canvas" class="p-sign-canvas"></canvas>
                <div class="p-sign-canvas-actions">
                  <button type="button" class="p-btn p-btn--ghost" id="btn-clear-sig">Limpiar firma</button>
                </div>
              </div>
            </div>

            <div class="p-sign-legal">
              Al aceptar y firmar confirmas que has leído y aceptas los
              <a href="/terminos" target="_blank" rel="noopener">Términos y condiciones</a> y el
              <a href="/privacidad" target="_blank" rel="noopener">Aviso de privacidad</a>.
              Tu solicitud queda en revisión por el equipo SACS antes de la activación.
            </div>

            <div class="p-sign-actions">
              <button type="button" class="p-btn p-btn--primary" id="btn-accept">Enviar solicitud al equipo SACS</button>
              <button type="button" class="p-btn p-btn--ghost" id="btn-decline">No me interesa por ahora</button>
            </div>
          </div>
        )}
      </section>

      <!-- Footer -->
      <div class="p-footer">
        <div class="p-footer-brand">
          <span class="p-footer-logo">Sacs</span>
          <span class="p-footer-tagline">Sistema operativo para retailers</span>
        </div>
        <div class="p-footer-contact">www.sacscloud.com · partners@sacscloud.com</div>
      </div>
    </div>
  </div>
</div>

<!-- Decline modal -->
{!isClosed && !isExpired && (
<div class="p-modal-overlay no-print" id="decline-modal" style="display:none">
  <div class="p-modal">
    <div class="p-modal-header">
      <span class="p-modal-title">¿Por qué no es para ti?</span>
      <button type="button" class="p-modal-close" id="btn-close-decline">✕</button>
    </div>
    <div class="p-modal-body">
      <p class="p-modal-text">Tu respuesta nos ayuda a mejorar el programa. Selecciona el motivo principal:</p>
      <div class="p-decline-reasons">
        <label class="p-decline-reason"><input type="radio" name="decline-motivo" value="no_tengo_audiencia" /> <span>No tengo audiencia o red para recomendar SACS</span></label>
        <label class="p-decline-reason"><input type="radio" name="decline-motivo" value="comision_baja" /> <span>La comisión no me parece atractiva</span></label>
        <label class="p-decline-reason"><input type="radio" name="decline-motivo" value="compromiso_alto" /> <span>El compromiso de contenido es muy alto</span></label>
        <label class="p-decline-reason"><input type="radio" name="decline-motivo" value="timing" /> <span>No es buen momento, lo veo más adelante</span></label>
        <label class="p-decline-reason"><input type="radio" name="decline-motivo" value="otro" /> <span>Otro motivo</span></label>
      </div>
      <label class="p-sign-field" style="margin-top:14px">
        <span>Detalle (opcional)</span>
        <textarea id="decline-detalle" class="p-input" rows="3" placeholder="Cuéntanos más..."></textarea>
      </label>
    </div>
    <div class="p-modal-footer">
      <button class="p-btn p-btn--ghost" id="btn-cancel-decline" type="button">Cancelar</button>
      <button class="p-btn p-btn--primary" id="btn-confirm-decline" type="button">Enviar respuesta</button>
    </div>
  </div>
</div>
)}

</BaseLayout>

<style is:global>
  /* Página enfocada — bareLayout en BaseLayout ya omite Nav/Footer.
     Reset por si algún global aplica margin/padding al body o main. */
  body, main { padding: 0 !important; margin: 0 !important; }
</style>

<style>
  /* ════════════════════════════════════════════════
     Partner invitation public page — typographic,
     Squarespace-style with editorial gradients.
     Brand accent: #4B7BE5 (partner blue).
     ════════════════════════════════════════════════ */

  .p-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 0;
    min-height: 100vh;
    background: #fafaf8;
  }
  .p-layout-sidebar {
    position: sticky;
    top: 0;
    align-self: start;
    height: 100vh;
    overflow-y: auto;
    background: #fff;
    border-right: 1px solid #e5e5e5;
    scrollbar-width: thin;
  }
  .p-layout-sidebar::-webkit-scrollbar { width: 6px; }
  .p-layout-sidebar::-webkit-scrollbar-thumb { background: #e0e0e0; border-radius: 3px; }

  .p-page { padding: 0 0 80px; }
  .p-container { max-width: 760px; margin: 0 auto; padding: 0 32px; }

  @media (max-width: 1023px) {
    .p-layout { grid-template-columns: 1fr; }
    .p-layout-sidebar { display: none; }
    .p-container { padding: 0 20px; }
  }

  /* ─── Mobile sticky tab nav (visible solo ≤1023px) ─────────────
     Reemplaza la sidebar oculta en móvil. Pills con scroll horizontal
     para que el partner pueda saltar entre Bienvenida → Cómo funciona
     → Términos → ... → Aceptar y firmar desde cualquier punto. */
  .p-mobnav {
    display: none;
  }
  @media (max-width: 1023px) {
    .p-mobnav {
      display: block;
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(250,250,248,0.96);
      -webkit-backdrop-filter: blur(8px);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid #ececec;
    }
    .p-mobnav-inner {
      display: flex;
      gap: 4px;
      overflow-x: auto;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      padding: 10px 16px;
      scroll-snap-type: x proximity;
    }
    .p-mobnav-inner::-webkit-scrollbar { display: none; }
    .p-mobnav-tab {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 9px 14px;
      border-radius: 999px;
      background: transparent;
      color: #777;
      text-decoration: none;
      font-size: 0.8125rem;
      font-weight: 500;
      letter-spacing: 0.005em;
      white-space: nowrap;
      scroll-snap-align: center;
      transition: background 0.15s, color 0.15s;
    }
    .p-mobnav-tab:hover { color: #1a1a1a; }
    .p-mobnav-tab--active {
      background: #1a1a1a;
      color: #fff;
    }
    .p-mobnav-tab--active .p-mobnav-tab-num {
      color: rgba(255,255,255,0.55);
    }
    .p-mobnav-tab-num {
      font-family: var(--font-display);
      font-size: 0.6875rem;
      font-weight: 500;
      color: #bbb;
      letter-spacing: 0.04em;
    }
  }
  /* Hide mobnav on print */
  @media print { .p-mobnav { display: none !important; } }

  /* Tab switcher */
  .p-tab-panel { display: none; animation: tabFade 220ms ease; padding-bottom: 64px; }
  .p-tab-panel.is-active { display: block; }
  @keyframes tabFade { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) {
    .p-tab-panel { animation: none; }
  }

  /* Header */
  .p-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 32px 0 20px;
    border-bottom: 1px solid #f0f0f0;
    margin-bottom: 24px;
  }
  @media (max-width: 640px) {
    .p-header {
      padding: 16px 0 14px;
      margin-bottom: 18px;
    }
    .p-header-brand { gap: 8px; }
    .p-logo-text { font-size: 1.375rem !important; }
    .p-logo-tag { font-size: 0.5625rem; padding: 3px 8px; }
    .p-numero { font-size: 0.875rem; }
    .p-fecha { font-size: 0.6875rem; }
  }
  .p-header-brand { display: flex; align-items: center; gap: 10px; }
  .p-logo-text { font-family: var(--font-logo, var(--font-display)); font-size: 1.75rem; font-weight: 700; color: #1a1a1a; }
  .p-logo-tag {
    font-size: 0.625rem; font-weight: 700; color: #4B7BE5;
    background: rgba(75,123,229,0.10);
    padding: 4px 10px; border-radius: 4px;
    text-transform: uppercase; letter-spacing: 0.1em;
  }
  .p-header-meta { text-align: right; }
  .p-numero { font-family: var(--font-display); font-size: 1.0625rem; font-weight: 700; color: #1a1a1a; letter-spacing: -0.005em; }
  .p-fecha { font-size: 0.75rem; color: #999; margin-top: 2px; }

  /* Status pill */
  .p-status {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 5px 11px 5px 10px; border-radius: 999px;
    font-size: 0.625rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    margin-bottom: 8px; line-height: 1;
  }
  .p-status-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
  .p-status--active { background: rgba(75,123,229,0.10); color: #3764c4; }
  .p-status--active .p-status-dot { background: #4B7BE5; }
  .p-status--accepted { background: rgba(42,181,160,0.12); color: #1e8471; }
  .p-status--accepted .p-status-dot { background: #2AB5A0; }
  .p-status--declined { background: rgba(229,75,75,0.10); color: #b93333; }
  .p-status--declined .p-status-dot { background: #E54B4B; }
  .p-status--expired { background: rgba(153,153,153,0.12); color: #666; }
  .p-status--expired .p-status-dot { background: #999; }

  /* Hero */
  .p-hero { padding: 56px 0 64px; }
  @media (max-width: 640px) {
    .p-hero { padding: 28px 0 36px; }
    .p-hero-eyebrow { margin-bottom: 14px; font-size: 0.625rem; letter-spacing: 0.14em; }
    .p-hero-title { margin: 0 0 20px; line-height: 1.05; }
    .p-hero-sub { font-size: 1rem; margin: 0 0 28px; }
    .p-hero-stats { padding: 18px 0; gap: 12px; margin-bottom: 20px; }
    .p-hero-quick { margin-top: 4px; }
    .p-hero-quick-row { font-size: 0.8125rem; }
  }
  .p-hero-eyebrow {
    font-size: 0.6875rem; font-weight: 700; color: #4B7BE5;
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 20px;
  }
  .p-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6.5vw, 4.5rem);
    font-weight: 200;
    color: #1a1a1a;
    letter-spacing: -0.035em;
    line-height: 1.02;
    margin: 0 0 28px;
  }
  .p-hero-title-soft { color: rgba(26,26,46,0.5); font-weight: 200; }
  .p-hero-title-strong {
    font-weight: 600;
    background: linear-gradient(120deg, #4B7BE5 0%, #6C5CE7 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .p-hero-sub {
    font-size: 1.125rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    max-width: 560px;
    margin: 0 0 40px;
  }

  .p-hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    padding: 24px 0;
    border-top: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
    margin-bottom: 28px;
  }
  .p-hero-stat { display: flex; flex-direction: column; gap: 4px; }
  .p-hero-stat-num {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 300;
    color: #1a1a1a;
    line-height: 1;
    letter-spacing: -0.025em;
  }
  .p-hero-stat-pct { font-size: 1rem; color: #4B7BE5; margin-left: 2px; font-weight: 400; }
  .p-hero-stat-label {
    font-size: 0.6875rem; font-weight: 600;
    color: #999;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  @media (max-width: 640px) {
    .p-hero-stats { grid-template-columns: 1fr; gap: 14px; }
    .p-hero-stat-num { font-size: 1.875rem; }
  }

  .p-hero-quick {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 8px;
  }
  .p-hero-quick-row {
    display: flex; align-items: flex-start; gap: 10px;
    font-size: 0.875rem;
    color: rgba(26,26,46,0.7);
    line-height: 1.55;
  }
  .p-hero-quick-icon {
    flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center;
    width: 28px; height: 28px;
    background: rgba(75,123,229,0.10);
    color: #4B7BE5;
    border-radius: 50%;
  }

  /* Section heads (used across tabs) */
  .p-section-head { padding: 56px 0 36px; max-width: 620px; }
  .p-section-head--center { text-align: center; margin: 0 auto; }
  .p-section-eyebrow {
    font-size: 0.6875rem; font-weight: 700; color: #4B7BE5;
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 14px;
  }
  .p-section-title {
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 4.5vw, 2.75rem);
    font-weight: 300;
    color: #1a1a1a;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0 0 16px;
  }
  .p-section-lead {
    font-size: 1rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    margin: 0;
  }
  @media (max-width: 640px) {
    .p-section-head { padding: 28px 0 24px; }
    .p-section-eyebrow { margin-bottom: 10px; }
    .p-section-title { margin-bottom: 12px; }
    .p-section-lead { font-size: 0.9375rem; line-height: 1.55; }
    .p-tab-panel { padding-bottom: 40px; }
  }

  /* Index nav under hero */
  .p-tab-intro-nav {
    display: flex; flex-direction: column; gap: 0;
    border-top: 1px solid #e5e5e5;
    margin-top: 24px;
  }
  .p-tab-intro-link {
    display: flex; justify-content: space-between; align-items: center;
    padding: 22px 0;
    color: #1a1a1a; text-decoration: none;
    border-bottom: 1px solid #e5e5e5;
    transition: color 0.2s ease;
  }
  .p-tab-intro-link:hover { color: #4B7BE5; }
  .p-tab-intro-link-label {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 400;
    letter-spacing: -0.005em;
  }
  .p-tab-intro-link-arrow {
    font-size: 1rem; color: #aaa;
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .p-tab-intro-link:hover .p-tab-intro-link-arrow {
    color: #4B7BE5; transform: translateX(6px);
  }
  @media (max-width: 640px) {
    .p-tab-intro-nav { margin-top: 16px; }
    .p-tab-intro-link { padding: 16px 0; }
    .p-tab-intro-link-label { font-size: 1rem; }
  }

  /* Benefits */
  .p-benefits-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-top: 8px;
  }
  @media (max-width: 640px) { .p-benefits-grid { grid-template-columns: 1fr; } }

  .p-benefit-card {
    padding: 28px 24px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .p-benefit-card:hover { border-color: #4B7BE5; transform: translateY(-2px); }
  .p-benefit-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px;
    background: linear-gradient(135deg, rgba(75,123,229,0.12), rgba(108,92,231,0.10));
    color: #4B7BE5;
    border-radius: 12px;
    margin-bottom: 16px;
  }
  .p-benefit-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 6px;
    letter-spacing: -0.005em;
  }
  .p-benefit-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
  }

  /* Terms */
  .p-terms {
    display: flex; flex-direction: column;
    border-top: 1px solid #e5e5e5;
    margin-top: 8px;
  }
  .p-term-row {
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px;
    padding: 22px 0;
    border-bottom: 1px solid #e5e5e5;
  }
  .p-term-row--big { padding: 32px 0; }
  .p-term-info { flex: 1; min-width: 0; }
  .p-term-label {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: #1a1a1a;
    margin-bottom: 4px;
    letter-spacing: -0.005em;
  }
  .p-term-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.6);
    line-height: 1.5;
  }
  .p-term-value {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: #1a1a1a;
    flex-shrink: 0;
    text-align: right;
    letter-spacing: -0.01em;
  }
  .p-term-value--accent {
    font-size: 2rem;
    font-weight: 300;
    background: linear-gradient(120deg, #4B7BE5 0%, #6C5CE7 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  /* Pill compacto para "Incluido" en filas de beneficios */
  .p-term-value--pill {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    background: rgba(42,181,160,0.12);
    color: #1A8F7A;
    padding: 5px 12px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    -webkit-text-fill-color: initial;
  }
  /* Variante con énfasis: para beneficios con valor monetario explícito
     (ej. Plan Fideliza "Vale $14,000/año · Gratis") */
  .p-term-value--pill-emph {
    background: linear-gradient(120deg, rgba(75,123,229,0.14), rgba(108,92,231,0.10));
    color: #3764c4;
    padding: 7px 14px;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: none;
    border: 1px solid rgba(75,123,229,0.20);
  }
  /* Variante para "Próximamente" — feature anunciada pero aún no activa */
  .p-term-value--pill-soon {
    background: rgba(232,168,56,0.12);
    color: #a06600;
    border: 1px solid rgba(232,168,56,0.25);
    -webkit-text-fill-color: initial;
  }
  /* Eyebrow para subgrupos dentro de Términos (1·Lo que ganas, 2·SACS te entrega, 3·Costos) */
  .p-terms-group-eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 32px 0 4px;
  }
  .p-terms-group-eyebrow:first-of-type {
    margin-top: 12px;
  }

  /* ─── Funnel de conversión — Squarespace style: timeline vertical limpio ─── */
  .p-funnel {
    margin: 72px 0 24px;
    padding: 88px 64px;
    background: #FAFAF8;
    border-radius: 2px;
  }

  .p-funnel-eyebrow {
    display: inline-block;
    color: #4B7BE5;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    margin-bottom: 32px;
    background: none;
    padding: 0;
  }
  .p-funnel-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.6vw, 2.875rem);
    font-weight: 300;
    line-height: 1.15;
    color: #1A1A1A;
    margin: 0 0 32px;
    letter-spacing: -0.025em;
    max-width: 720px;
  }
  .p-funnel-title-accent {
    color: #4B7BE5;
    font-weight: 400;
    background: none;
    -webkit-text-fill-color: initial;
  }
  .p-funnel-lead {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: #6A6A6A;
    margin: 0 0 72px;
    max-width: 620px;
    font-weight: 300;
  }

  /* Timeline vertical: lista ordenada con línea conectora */
  .p-funnel-flow {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 720px;
    position: relative;
  }
  /* Línea vertical detrás de los números */
  .p-funnel-flow::before {
    content: '';
    position: absolute;
    top: 14px;
    bottom: 14px;
    left: 17px;
    width: 1px;
    background: #E5E5E0;
  }
  .p-funnel-step {
    position: relative;
    display: flex;
    gap: 28px;
    padding: 0 0 40px;
  }
  .p-funnel-step--last { padding-bottom: 0; }

  .p-funnel-step-num {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: #FAFAF8;          /* match section bg para "tapar" la línea */
    color: #4B7BE5;
    border: 1px solid #4B7BE5;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.9375rem;
  }
  .p-funnel-step-content {
    flex: 1;
    min-width: 0;
    padding-top: 4px;
  }
  .p-funnel-step-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .p-funnel-step-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: #1A1A1A;
    letter-spacing: -0.015em;
    margin: 0;
    line-height: 1.2;
  }
  .p-funnel-step-tag {
    color: #4B7BE5;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .p-funnel-step-detail {
    font-size: 0.9375rem;
    color: #6A6A6A;
    line-height: 1.6;
    margin: 0;
    font-weight: 400;
    max-width: 520px;
  }

  /* Tools list — minimal columns con bullets sutiles */
  .p-funnel-tools {
    margin-top: 80px;
    padding-top: 48px;
    border-top: 1px solid #E5E5E0;
    max-width: 760px;
  }
  .p-funnel-tools-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 500;
    color: #1A1A1A;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 28px;
  }
  .p-funnel-tools-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px 48px;
  }
  .p-funnel-tools-list li {
    position: relative;
    padding-left: 20px;
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.55;
    font-weight: 400;
  }
  .p-funnel-tools-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 11px;
    width: 8px;
    height: 1px;
    background: #4B7BE5;
  }

  @media (max-width: 768px) {
    .p-funnel { padding: 56px 28px; margin: 48px 0 16px; }
    .p-funnel-title { margin-bottom: 24px; }
    .p-funnel-lead { margin-bottom: 48px; }
    .p-funnel-step { gap: 18px; padding-bottom: 32px; }
    .p-funnel-flow::before { left: 17px; }
    .p-funnel-tools { margin-top: 56px; padding-top: 36px; }
    .p-funnel-tools-list { grid-template-columns: 1fr; gap: 12px; }
  }

  .p-terms-extra {
    margin-top: 36px;
    padding: 24px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
  }
  .p-terms-extra-title {
    font-size: 0.625rem; font-weight: 700; color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
    margin-bottom: 10px;
  }
  .p-terms-extra-text {
    font-size: 0.875rem;
    color: rgba(26,26,46,0.7);
    line-height: 1.6;
    margin: 0;
    white-space: pre-line;
  }

  /* Compromisos */
  .p-commits {
    display: flex; flex-direction: column;
    border-top: 1px solid #e5e5e5;
    margin-top: 8px;
  }
  .p-commit-row {
    display: flex; align-items: flex-start; gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid #e5e5e5;
  }
  .p-commit-num {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: #4B7BE5;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    width: 28px;
    padding-top: 4px;
  }
  .p-commit-content { flex: 1; min-width: 0; }
  .p-commit-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 500;
    color: #1a1a1a;
    margin-bottom: 6px;
    letter-spacing: -0.005em;
  }
  .p-commit-detail {
    font-size: 0.875rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
  }
  .p-commit-frequency {
    display: inline-block; margin-top: 10px;
    padding: 3px 9px;
    font-size: 0.625rem; font-weight: 600;
    color: #4B7BE5;
    background: rgba(75,123,229,0.10);
    border-radius: 999px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .p-commit-note {
    display: flex; align-items: flex-start; gap: 10px;
    margin-top: 28px;
    padding: 16px 18px;
    background: rgba(75,123,229,0.05);
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 10px;
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.75);
    line-height: 1.55;
  }
  .p-commit-note svg { flex-shrink: 0; color: #4B7BE5; margin-top: 1px; }

  /* ─── ¿Por qué te conviene cumplir? — rationale block ─── */
  .p-commit-rationale {
    margin-top: 32px;
    padding: 36px 32px;
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d3f 100%);
    color: #fff;
    border-radius: 20px;
  }
  .p-commit-rationale-eyebrow {
    font-size: 0.6875rem; font-weight: 700;
    color: #93b4ff;
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 14px;
  }
  .p-commit-rationale-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 300;
    color: #fff;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0 0 16px;
  }
  .p-commit-rationale-text {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    margin: 0 0 14px;
    max-width: 620px;
  }
  .p-commit-rationale-text strong { color: #fff; font-weight: 600; }
  .p-commit-rationale-stack {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin: 22px 0 24px;
  }
  @media (max-width: 720px) { .p-commit-rationale-stack { grid-template-columns: 1fr; } }

  .p-commit-rationale-card {
    padding: 20px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    display: flex; flex-direction: column; gap: 6px;
  }
  .p-commit-rationale-card--ceiling {
    background: linear-gradient(135deg, rgba(75,123,229,0.18), rgba(108,92,231,0.12));
    border-color: rgba(108,92,231,0.30);
  }
  .p-commit-rationale-card-label {
    font-size: 0.625rem; font-weight: 700;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.12em; text-transform: uppercase;
    line-height: 1.4;
  }
  .p-commit-rationale-card--ceiling .p-commit-rationale-card-label { color: #93b4ff; }
  .p-commit-rationale-card-amount {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4.5vw, 2.5rem);
    font-weight: 200;
    color: #fff;
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 4px 0 4px;
  }
  .p-commit-rationale-card--ceiling .p-commit-rationale-card-amount {
    background: linear-gradient(120deg, #93b4ff 0%, #c4b5fd 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .p-commit-rationale-card-detail {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.5;
  }
  .p-commit-rationale-cta {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 6px;
    padding: 12px 20px;
    background: #fff;
    color: #1a1a1a;
    text-decoration: none;
    border-radius: 10px;
    font-size: 0.875rem;
    font-weight: 600;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .p-commit-rationale-cta:hover {
    background: #93b4ff;
    color: #1a1a1a;
    text-decoration: none;
    transform: translateY(-1px);
  }
  .p-commit-rationale-cta-arrow { transition: transform 0.15s ease; }
  .p-commit-rationale-cta:hover .p-commit-rationale-cta-arrow { transform: translateX(4px); }


  /* Tabulador / Payouts */
  .p-payout-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-top: 8px;
  }
  @media (max-width: 720px) { .p-payout-grid { grid-template-columns: 1fr; } }

  .p-payout-card {
    padding: 28px 22px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    display: flex; flex-direction: column; gap: 8px;
  }
  .p-payout-card--featured {
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d3f 100%);
    color: #fff;
    border: none;
  }
  .p-payout-step {
    font-size: 0.625rem; font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  .p-payout-card--featured .p-payout-step { color: #93b4ff; }
  .p-payout-amount {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 300;
    color: #1a1a1a;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .p-payout-card--featured .p-payout-amount { color: #fff; }
  .p-payout-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: #1a1a1a;
    letter-spacing: -0.005em;
  }
  .p-payout-card--featured .p-payout-name { color: #fff; }
  .p-payout-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.6);
    line-height: 1.5;
    margin-top: 4px;
  }
  .p-payout-card--featured .p-payout-detail { color: rgba(255,255,255,0.65); }

  .p-payout-notes {
    margin-top: 28px;
    padding: 22px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
  }
  .p-payout-notes-title {
    font-size: 0.625rem; font-weight: 700; color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
    margin-bottom: 10px;
  }
  .p-payout-notes p {
    margin: 0;
    font-size: 0.875rem;
    color: rgba(26,26,46,0.7);
    line-height: 1.6;
  }

  /* Landing card */
  .p-landing {
    margin-top: 32px;
    padding: 28px;
    background: linear-gradient(120deg, rgba(75,123,229,0.06), rgba(108,92,231,0.04));
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 16px;
    text-align: center;
  }
  .p-landing-eyebrow {
    font-size: 0.6875rem; font-weight: 700; color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
    margin-bottom: 12px;
  }
  .p-landing-url {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 500;
    color: #1a1a1a;
    word-break: break-all;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .p-landing-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    margin: 0 auto;
    max-width: 460px;
  }

  /* ─── Portal de partner — qué ve el partner y desde dónde ─── */
  .p-portal {
    margin-top: 40px;
    padding: 32px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 16px;
  }
  .p-portal-eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .p-portal-title {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.6vw, 1.75rem);
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 14px;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .p-portal-lead {
    font-size: 0.9375rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.6;
    margin: 0 0 28px;
    max-width: 640px;
  }
  .p-portal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px;
    margin-bottom: 22px;
  }
  .p-portal-card {
    background: #fafafa;
    border: 1px solid #f0f0f0;
    border-radius: 12px;
    padding: 18px;
  }
  .p-portal-card-ic {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(75,123,229,0.10);
    color: #4B7BE5;
    border-radius: 9px;
    margin-bottom: 12px;
  }
  .p-portal-card-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .p-portal-card-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.6);
    line-height: 1.55;
  }
  .p-portal-note {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 14px 16px;
    background: rgba(42,181,160,0.08);
    border-left: 3px solid #2AB5A0;
    border-radius: 6px;
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.75);
    line-height: 1.55;
  }
  .p-portal-note svg {
    flex-shrink: 0;
    color: #1A8F7A;
    margin-top: 2px;
  }
  @media (max-width: 640px) {
    .p-portal { padding: 22px; }
    .p-portal-grid { grid-template-columns: 1fr; }
  }

  /* ─── Tu potencial — proyección de ganancias ─── */
  .p-projection-block { margin: 8px 0 56px; }

  /* Toggle Mensual / Anual */
  .p-projection-toggle {
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    background: #fafafa;
    border: 1px solid #e5e5e5;
    border-radius: 14px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .p-toggle-btn {
    display: flex; flex-direction: column; gap: 1px;
    padding: 10px 18px;
    background: transparent;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    color: rgba(26,26,46,0.6);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .p-toggle-btn:hover { color: #1a1a1a; }
  .p-toggle-btn.is-active {
    background: #1a1a1a;
    color: #fff;
  }
  .p-toggle-btn-label {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: -0.005em;
  }
  .p-toggle-btn-hint {
    font-size: 0.625rem;
    font-weight: 500;
    opacity: 0.75;
    letter-spacing: 0.02em;
  }

