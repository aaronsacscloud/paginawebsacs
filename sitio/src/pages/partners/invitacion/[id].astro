  /* ─── SECCIÓN 5 · Contenido y puntos ─── */
  @media (max-width: 600px) {
    .p-cat-tabs {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .p-cat-tabs::-webkit-scrollbar { display: none; }
    .p-cat-tab {
      flex: 0 0 auto !important;
      min-width: max-content !important;
      min-height: 44px;
    }
