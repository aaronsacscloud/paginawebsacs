  // Mini-header (índice) + bullets de bienvenida (antes hardcodeados en español)
  'mi.sub.std':  { es: 'Tu invitación al programa de partners SACS · <strong>{pct}% de comisión</strong> sobre cada venta directa.', en: 'Your invitation to the SACS partner program · <strong>{pct}% commission</strong> on every direct sale.', fr: 'Votre invitation au programme partenaires SACS · <strong>{pct}% de commission</strong> sur chaque vente directe.', it: 'Il tuo invito al programma partner SACS · <strong>{pct}% di commissione</strong> su ogni vendita diretta.', pt: 'Seu convite ao programa de parceiros SACS · <strong>{pct}% de comissão</strong> sobre cada venda direta.' },
  'mi.sub.esc':  { es: 'Tu invitación al programa de partners SACS · <strong>paquete de licencias Fideliza al mayoreo</strong> para revender.', en: 'Your invitation to the SACS partner program · <strong>wholesale Fideliza license package</strong> to resell.', fr: 'Votre invitation au programme partenaires SACS · <strong>pack de licences Fideliza en gros</strong> à revendre.', it: 'Il tuo invito al programma partner SACS · <strong>pacchetto di licenze Fideliza all\'ingrosso</strong> da rivendere.', pt: 'Seu convite ao programa de parceiros SACS · <strong>pacote de licenças Fideliza no atacado</strong> para revender.' },
  'bw.b1.std':   { es: '<strong>Comisiones que sí valen el esfuerzo.</strong> {pct}% sobre cada venta directa + comisión recurrente. Todo el seguimiento del lead visible en tu portal.', en: '<strong>Commissions worth the effort.</strong> {pct}% on every direct sale + recurring commission. Full lead tracking visible in your portal.', fr: '<strong>Des commissions qui valent l\'effort.</strong> {pct}% sur chaque vente directe + commission récurrente. Tout le suivi du lead visible dans votre portail.', it: '<strong>Commissioni che valgono lo sforzo.</strong> {pct}% su ogni vendita diretta + commissione ricorrente. Tutto il tracciamento del lead nel tuo portale.', pt: '<strong>Comissões que valem o esforço.</strong> {pct}% sobre cada venda direta + comissão recorrente. Todo o acompanhamento do lead no seu portal.' },
  'bw.b1.esc':   { es: '<strong>Reventa de licencias al mayoreo.</strong> Compras tu paquete de licencias Fideliza y las revendes a precio público — te quedas con todo el margen. Al agotar tu paquete, ganas {pct}% de comisión sobre nuevas ventas.', en: '<strong>Wholesale license resale.</strong> You buy your Fideliza license package and resell at public price — you keep the full margin. Once your package sells out, you earn {pct}% commission on new sales.', fr: '<strong>Revente de licences en gros.</strong> Vous achetez votre pack de licences Fideliza et le revendez au prix public — vous gardez toute la marge. Une fois le pack épuisé, vous gagnez {pct}% de commission sur les nouvelles ventes.', it: '<strong>Rivendita di licenze all\'ingrosso.</strong> Compri il tuo pacchetto di licenze Fideliza e le rivendi a prezzo pubblico — tieni tutto il margine. Esaurito il pacchetto, guadagni il {pct}% di commissione sulle nuove vendite.', pt: '<strong>Revenda de licenças no atacado.</strong> Você compra seu pacote de licenças Fideliza e revende a preço público — fica com toda a margem. Ao esgotar o pacote, ganha {pct}% de comissão sobre novas vendas.' },
  'bw.b2':       { es: '<strong>Tres formas de sumar puntos.</strong> Contenido publicado, acciones de promoción o actividades filantrópicas.', en: '<strong>Three ways to earn points.</strong> Published content, promotional actions or philanthropic activities.', fr: '<strong>Trois façons de cumuler des points.</strong> Contenu publié, actions de promotion ou activités philanthropiques.', it: '<strong>Tre modi per accumulare punti.</strong> Contenuti pubblicati, azioni di promozione o attività filantropiche.', pt: '<strong>Três formas de somar pontos.</strong> Conteúdo publicado, ações de promoção ou atividades filantrópicas.' },
  'bw.b3':       { es: '<strong>Plan Fideliza gratis ($14k/año).</strong> Para que uses SACS en tu propio negocio o como demo en vivo.', en: '<strong>Free Fideliza Plan ($14k/year).</strong> So you can use SACS in your own business or as a live demo.', fr: '<strong>Plan Fideliza gratuit (14k$/an).</strong> Pour utiliser SACS dans votre propre entreprise ou comme démo en direct.', it: '<strong>Piano Fideliza gratis ($14k/anno).</strong> Per usare SACS nella tua attività o come demo dal vivo.', pt: '<strong>Plano Fideliza grátis ($14k/ano).</strong> Para usar a SACS no seu próprio negócio ou como demo ao vivo.' },
  'bw.b4':       { es: '<strong>Pagos puntuales cada 30 días.</strong> Transparente. Sin letras chicas. Sin "depende de…".', en: '<strong>On-time payments every 30 days.</strong> Transparent. No fine print. No "it depends…".', fr: '<strong>Paiements ponctuels tous les 30 jours.</strong> Transparent. Sans petits caractères. Sans « ça dépend… ».', it: '<strong>Pagamenti puntuali ogni 30 giorni.</strong> Trasparente. Senza clausole in piccolo. Senza "dipende…".', pt: '<strong>Pagamentos pontuais a cada 30 dias.</strong> Transparente. Sem letras miúdas. Sem "depende de…".' },

  // Embudo
  'fun.eyebrow': { es: 'Cómo se cierra cada venta', en: 'How each sale closes', fr: 'Comment chaque vente se conclut', it: 'Come si chiude ogni vendita', pt: 'Como cada venda fecha' },
  'fun.title':   { es: 'Embudo y seguimiento de ventas', en: 'Sales funnel & follow-up', fr: 'Entonnoir et suivi des ventes', it: 'Funnel e follow-up vendite', pt: 'Funil e acompanhamento de vendas' },
  'fun.lead':    { es: 'Tú recomiendas — SACS opera el embudo de conversión completo: nurturing, llamadas, demos, onboarding y soporte. Tú ganas tu <strong>50% de comisión</strong> cuando el cliente cierra, pero desde el día uno ves <strong>en tu portal cada paso</strong>: quién hizo click, quién agendó una demo, quién se inscribió a la prueba gratis y dónde está cada lead en el embudo.', en: 'You recommend — SACS runs the full conversion funnel: nurturing, calls, demos, onboarding and support. You earn your <strong>50% commission</strong> when the client closes, but from day one you see <strong>every step in your portal</strong>: who clicked, who scheduled a demo, who signed up for the free trial and where each lead stands in the funnel.', fr: 'Vous recommandez — SACS gère l\'entonnoir de conversion complet : nurturing, appels, démos, onboarding et support. Vous gagnez votre <strong>commission de 50%</strong> quand le client conclut, mais dès le premier jour vous voyez <strong>chaque étape dans votre portail</strong> : qui a cliqué, qui a planifié une démo, qui s\'est inscrit à l\'essai gratuit et où en est chaque lead dans l\'entonnoir.', it: 'Tu raccomandi — SACS gestisce l\'intero funnel di conversione: nurturing, chiamate, demo, onboarding e supporto. Guadagni la tua <strong>commissione del 50%</strong> quando il cliente chiude, ma dal primo giorno vedi <strong>ogni passo nel tuo portale</strong>: chi ha cliccato, chi ha prenotato una demo, chi si è iscritto alla prova gratuita e dove si trova ogni lead nel funnel.', pt: 'Você recomenda — a SACS opera o funil de conversão completo: nutrição, chamadas, demos, onboarding e suporte. Você ganha sua <strong>comissão de 50%</strong> quando o cliente fecha, mas desde o primeiro dia você vê <strong>cada passo no seu portal</strong>: quem clicou, quem agendou uma demo, quem se cadastrou no teste grátis e onde está cada lead no funil.' },

  // Compromisos
  'commits.eyebrow': { es: 'Lo que esperamos de ti', en: 'What we expect from you', fr: 'Ce que nous attendons de vous', it: 'Cosa ci aspettiamo da te', pt: 'O que esperamos de você' },
  'commits.title':   { es: 'Tus compromisos como partner', en: 'Your commitments as a partner', fr: 'Vos engagements en tant que partenaire', it: 'I tuoi impegni come partner', pt: 'Seus compromissos como parceiro' },
  'commits.lead':    { es: 'Para mantener tus beneficios activos, esto es lo que necesitamos de tu lado.', en: 'To keep your benefits active, this is what we need from your side.', fr: 'Pour maintenir vos avantages actifs, voici ce dont nous avons besoin de votre côté.', it: 'Per mantenere attivi i tuoi benefici, ecco cosa ci serve da te.', pt: 'Para manter seus benefícios ativos, isto é o que precisamos do seu lado.' },

  // Contenido y puntos
  'cnt.eyebrow':  { es: 'Cómo te mantienes activo', en: 'How you stay active', fr: 'Comment rester actif', it: 'Come resti attivo', pt: 'Como você se mantém ativo' },
  'cnt.title':    { es: 'Sistema de puntos: 100/mes', en: 'Points system: 100/month', fr: 'Système de points : 100/mois', it: 'Sistema di punti: 100/mese', pt: 'Sistema de pontos: 100/mês' },
  'cnt.lead':     { es: 'Para mantener tu plan activo cada mes acumulas <strong>100 puntos</strong>. Hay <strong>tres formas</strong> de sumarlos: contenido publicado, acciones de apoyo de marketing o actividades filantrópicas. Mezcla la combinación que mejor te quede.', en: 'To keep your plan active each month you accumulate <strong>100 points</strong>. There are <strong>three ways</strong> to earn them: published content, marketing support actions, or philanthropic activities. Mix whichever combination works best for you.', fr: 'Pour garder votre plan actif chaque mois, vous accumulez <strong>100 points</strong>. Il y a <strong>trois façons</strong> de les gagner : contenu publié, actions de soutien marketing ou activités philanthropiques. Mélangez la combinaison qui vous convient le mieux.', it: 'Per mantenere attivo il tuo piano ogni mese accumuli <strong>100 punti</strong>. Ci sono <strong>tre modi</strong> per guadagnarli: contenuti pubblicati, azioni di supporto marketing o attività filantropiche. Mescola la combinazione che ti si adatta meglio.', pt: 'Para manter seu plano ativo cada mês você acumula <strong>100 pontos</strong>. Há <strong>três formas</strong> de somá-los: conteúdo publicado, ações de apoio de marketing ou atividades filantrópicas. Misture a combinação que melhor se ajustar a você.' },
  'cnt.h3':       { es: 'Las 3 formas de sumar puntos', en: 'The 3 ways to earn points', fr: 'Les 3 façons de gagner des points', it: 'I 3 modi per guadagnare punti', pt: 'As 3 formas de somar pontos' },
  'cnt.sublead':  { es: 'Primero elige tu perfil — cada uno tiene acciones diferentes. Después combina contenido, apoyo y filantropía para llegar a los 100 puntos al mes.', en: 'First choose your profile — each one has different actions. Then combine content, support and philanthropy to reach 100 points per month.', fr: 'Choisissez d\'abord votre profil — chacun a des actions différentes. Ensuite, combinez contenu, soutien et philanthropie pour atteindre 100 points par mois.', it: 'Prima scegli il tuo profilo — ognuno ha azioni diverse. Poi combina contenuti, supporto e filantropia per arrivare a 100 punti al mese.', pt: 'Primeiro escolha seu perfil — cada um tem ações diferentes. Depois combine conteúdo, apoio e filantropia para chegar aos 100 pontos por mês.' },

  // Lo que puedes ganar
  'comp.eyebrow': { es: 'Lo que puedes ganar', en: 'What you can earn', fr: 'Ce que vous pouvez gagner', it: 'Quanto puoi guadagnare', pt: 'O que você pode ganhar' },
  'comp.title':   { es: 'El tabulador y la proyección de tus ingresos.', en: 'The fee schedule and income projection.', fr: 'La grille des rémunérations et la projection de revenus.', it: 'Il tariffario e la proiezione dei tuoi guadagni.', pt: 'A tabela e a projeção dos seus ganhos.' },
  'comp.lead':    { es: 'Dos vistas en una: el <strong>tabulador</strong> con cuánto te paga cada acción del proceso y la <strong>proyección</strong> de lo que se acumula según el ritmo que mantengas. Números reales — basados en precios públicos de SACS, no en escenarios inflados.', en: 'Two views in one: the <strong>fee schedule</strong> showing how much each step pays, and the <strong>projection</strong> of what accumulates based on your pace. Real numbers — based on public SACS prices, not inflated scenarios.', fr: 'Deux vues en une : la <strong>grille</strong> de rémunération par action et la <strong>projection</strong> de ce qui s\'accumule selon votre rythme. Chiffres réels — basés sur les prix publics de SACS, pas sur des scénarios gonflés.', it: 'Due viste in una: il <strong>tariffario</strong> con quanto ti paga ogni azione del processo e la <strong>proiezione</strong> di quello che si accumula al tuo ritmo. Numeri reali — basati sui prezzi pubblici di SACS, non su scenari gonfiati.', pt: 'Duas vistas em uma: a <strong>tabela</strong> com quanto te paga cada ação do processo e a <strong>projeção</strong> do que se acumula conforme seu ritmo. Números reais — baseados nos preços públicos da SACS, não em cenários inflados.' },

  // Proceso de inscripción
  'proc.eyebrow': { es: 'El proceso, paso a paso', en: 'The process, step by step', fr: 'Le processus, étape par étape', it: 'Il processo, passo dopo passo', pt: 'O processo, passo a passo' },
  'proc.title':   { es: 'Proceso de inscripción', en: 'Enrollment process', fr: 'Processus d\'inscription', it: 'Processo di iscrizione', pt: 'Processo de inscrição' },
  'proc.lead':    { es: 'Desde que firmas tu invitación hasta que cobras tu primera comisión. Sin sorpresas, sin letras chicas.', en: 'From signing your invitation to receiving your first commission. No surprises, no fine print.', fr: 'De la signature de votre invitation à votre première commission. Sans surprises, sans petits caractères.', it: 'Da quando firmi il tuo invito a quando incassi la prima commissione. Nessuna sorpresa, nessuna clausola in piccolo.', pt: 'Desde quando você assina seu convite até receber sua primeira comissão. Sem surpresas, sem letras miúdas.' },

  // Phase E · funnel + strikes + glossary body

  // Funnel section (in Embudo tab)
  'fun.bar.eyebrow': { es: '⚡ El embudo está hecho · tú solo recomiendas', en: '⚡ The funnel is built · you just recommend', fr: '⚡ L\'entonnoir est prêt · vous n\'avez qu\'à recommander', it: '⚡ Il funnel è fatto · tu basta che raccomandi', pt: '⚡ O funil está pronto · você só recomenda' },
  'fun.bar.title':   { es: 'No vendes — recomiendas. <br/><span class="p-funnel-title-accent">SACS hace el resto.</span>', en: 'You don\'t sell — you recommend. <br/><span class="p-funnel-title-accent">SACS handles the rest.</span>', fr: 'Vous ne vendez pas — vous recommandez. <br/><span class="p-funnel-title-accent">SACS s\'occupe du reste.</span>', it: 'Non vendi — raccomandi. <br/><span class="p-funnel-title-accent">SACS fa il resto.</span>', pt: 'Você não vende — recomenda. <br/><span class="p-funnel-title-accent">A SACS faz o resto.</span>' },
  'fun.bar.lead':    { es: 'Tenemos un embudo completo de conversión optimizado en cada paso. Cuando alguien llega por tu link, nuestro equipo y nuestra automatización se encargan: emails de seguimiento, llamadas, videos paso a paso, recordatorios. Tú solo compartes — nosotros convertimos, te avisamos en tiempo real, y te pagamos.', en: 'We have a complete conversion funnel optimized at every step. When someone arrives via your link, our team and automation take over: follow-up emails, calls, step-by-step videos, reminders. You just share — we convert, alert you in real time, and pay you.', fr: 'Nous avons un entonnoir de conversion complet optimisé à chaque étape. Quand quelqu\'un arrive via votre lien, notre équipe et notre automatisation prennent le relais : emails de suivi, appels, vidéos étape par étape, rappels. Vous ne faites que partager — nous convertissons, nous vous prévenons en temps réel et nous vous payons.', it: 'Abbiamo un funnel di conversione completo, ottimizzato in ogni step. Quando qualcuno arriva dal tuo link, il nostro team e la nostra automazione si occupano di tutto: email di follow-up, chiamate, video passo passo, promemoria. Tu condividi — noi convertiamo, ti avvisiamo in tempo reale, e ti paghiamo.', pt: 'Temos um funil de conversão completo otimizado em cada etapa. Quando alguém chega pelo seu link, nossa equipe e automação assumem: e-mails de follow-up, chamadas, vídeos passo a passo, lembretes. Você só compartilha — nós convertemos, te avisamos em tempo real e te pagamos.' },
  'fun.s1.t': { es: 'Atracción', en: 'Attract', fr: 'Attraction', it: 'Attrazione', pt: 'Atração' },
  'fun.s1.tag': { es: 'Tu trabajo · visible en portal', en: 'Your job · visible in portal', fr: 'Votre travail · visible dans le portail', it: 'Il tuo lavoro · visibile in portale', pt: 'Seu trabalho · visível no portal' },
  'fun.s1.d': { es: 'Compartes tu link único en redes, WhatsApp, email o video. <strong>En tu portal ves</strong> cuántos clicks recibió tu link, de dónde llegan (orgánico, redes, paid) y qué piezas convierten más.', en: 'You share your unique link on social media, WhatsApp, email or video. <strong>In your portal you see</strong> how many clicks your link received, where they come from (organic, social, paid) and which pieces convert best.', fr: 'Vous partagez votre lien unique sur les réseaux, WhatsApp, email ou vidéo. <strong>Dans votre portail vous voyez</strong> combien de clics votre lien a reçus, d\'où ils viennent (organique, social, payant) et quels contenus convertissent le mieux.', it: 'Condividi il tuo link unico su social, WhatsApp, email o video. <strong>Nel tuo portale vedi</strong> quanti click ha ricevuto il tuo link, da dove arrivano (organico, social, paid) e quali contenuti convertono di più.', pt: 'Você compartilha seu link único nas redes, WhatsApp, e-mail ou vídeo. <strong>No seu portal você vê</strong> quantos cliques seu link recebeu, de onde vêm (orgânico, redes, paid) e quais peças convertem mais.' },
  'fun.s2.t': { es: 'Captura', en: 'Capture', fr: 'Capture', it: 'Cattura', pt: 'Captura' },
  'fun.s2.tag': { es: 'Automático · atribuido a ti', en: 'Automatic · attributed to you', fr: 'Automatique · attribué à vous', it: 'Automatico · attribuito a te', pt: 'Automático · atribuído a você' },
  'fun.s2.d': { es: 'El prospecto llega a tu landing personalizada. Atribución automática vía cookie de 90 días. <strong>En tu portal aparece</strong> como nuevo lead con su giro, ubicación y origen de tráfico.', en: 'The prospect lands on your personalized page. Automatic attribution via 90-day cookie. <strong>In your portal they appear</strong> as a new lead with their sector, location and traffic source.', fr: 'Le prospect arrive sur votre page personnalisée. Attribution automatique via cookie de 90 jours. <strong>Dans votre portail il apparaît</strong> comme nouveau lead avec son secteur, sa localisation et la source de trafic.', it: 'Il prospect arriva sulla tua landing personalizzata. Attribuzione automatica via cookie 90 giorni. <strong>Nel tuo portale appare</strong> come nuovo lead con il suo settore, ubicazione e origine del traffico.', pt: 'O prospecto chega na sua landing personalizada. Atribuição automática via cookie de 90 dias. <strong>No seu portal aparece</strong> como novo lead com seu segmento, localização e origem de tráfego.' },
  'fun.s3.t': { es: 'Activación', en: 'Activation', fr: 'Activation', it: 'Attivazione', pt: 'Ativação' },
  'fun.s3.tag': { es: 'SACS opera · tú ves todo', en: 'SACS operates · you see everything', fr: 'SACS opère · vous voyez tout', it: 'SACS opera · tu vedi tutto', pt: 'A SACS opera · você vê tudo' },
  'fun.s3.d': { es: 'El lead se registra a la prueba gratis o agenda demo con un AE de SACS. <strong>En tu portal lo ves al instante</strong>: nombre del negocio, tamaño, fecha de la demo, AE asignado y notas de la primera conversación. No te paga directamente, pero ya sabes que tu link está trabajando.', en: 'The lead signs up for the free trial or schedules a demo with a SACS AE. <strong>In your portal you see it instantly</strong>: business name, size, demo date, assigned AE and notes from the first conversation. It doesn\'t pay you directly, but you already know your link is working.', fr: 'Le lead s\'inscrit à l\'essai gratuit ou planifie une démo avec un AE SACS. <strong>Dans votre portail vous le voyez instantanément</strong> : nom de l\'entreprise, taille, date de démo, AE assigné et notes de la première conversation. Il ne vous paie pas directement, mais vous savez déjà que votre lien fonctionne.', it: 'Il lead si iscrive alla prova gratuita o prenota una demo con un AE di SACS. <strong>Nel tuo portale lo vedi all\'istante</strong>: nome dell\'attività, dimensione, data della demo, AE assegnato e note della prima conversazione. Non ti paga direttamente, ma sai già che il tuo link sta funzionando.', pt: 'O lead se cadastra no teste grátis ou agenda demo com um AE da SACS. <strong>No seu portal você vê na hora</strong>: nome do negócio, tamanho, data da demo, AE atribuído e notas da primeira conversa. Não te paga diretamente, mas já sabe que seu link está funcionando.' },
  'fun.s4.t': { es: 'Nurturing', en: 'Nurturing', fr: 'Nurturing', it: 'Nurturing', pt: 'Nurturing' },
  'fun.s4.tag': { es: 'SACS lo opera · tú haces seguimiento', en: 'SACS runs it · you track', fr: 'SACS le gère · vous suivez', it: 'SACS lo gestisce · tu segui', pt: 'A SACS opera · você acompanha' },
  'fun.s4.d': { es: 'Emails, WhatsApp, llamadas, videos paso a paso, tour del producto. <strong>En tu portal ves cada interacción</strong> con tu lead: emails enviados, mensajes abiertos, llamadas hechas, en qué fase del proceso está y cuándo es la próxima acción del AE.', en: 'Emails, WhatsApp, calls, step-by-step videos, product tour. <strong>In your portal you see every interaction</strong> with your lead: emails sent, messages opened, calls made, what stage they\'re in and the AE\'s next scheduled action.', fr: 'Emails, WhatsApp, appels, vidéos étape par étape, tour du produit. <strong>Dans votre portail vous voyez chaque interaction</strong> avec votre lead : emails envoyés, messages ouverts, appels effectués, à quelle étape il est et la prochaine action prévue par l\'AE.', it: 'Email, WhatsApp, chiamate, video passo passo, tour del prodotto. <strong>Nel tuo portale vedi ogni interazione</strong> con il tuo lead: email inviate, messaggi aperti, chiamate fatte, in quale fase si trova e quale sarà la prossima azione dell\'AE.', pt: 'E-mails, WhatsApp, chamadas, vídeos passo a passo, tour do produto. <strong>No seu portal você vê cada interação</strong> com seu lead: e-mails enviados, mensagens abertas, chamadas feitas, em que fase está e qual a próxima ação do AE.' },
  'fun.s5.t': { es: 'Conversión + Pago', en: 'Conversion + Payment', fr: 'Conversion + Paiement', it: 'Conversione + Pagamento', pt: 'Conversão + Pagamento' },
  'fun.s5.tag': { es: 'Tú cobras · 50% directo', en: 'You get paid · 50% direct', fr: 'Vous êtes payé · 50% direct', it: 'Tu incassi · 50% diretto', pt: 'Você recebe · 50% direto' },
  'fun.s5.d': { es: 'Cliente cierra y paga su primera factura. <strong>Tu 50% de comisión se acredita en tu portal al instante</strong> y se liquida a tu CLABE el día 1 del mes siguiente. Ves la venta exacta, el plan contratado, el monto que te toca y la fecha de liquidación.', en: 'Client closes and pays their first invoice. <strong>Your 50% commission credits to your portal instantly</strong> and settles to your CLABE on the 1st of the following month. You see the exact sale, plan contracted, amount due to you and settlement date.', fr: 'Le client conclut et paye sa première facture. <strong>Votre commission de 50% est créditée sur votre portail instantanément</strong> et est versée à votre CLABE le 1er du mois suivant. Vous voyez la vente exacte, le plan contractualisé, le montant qui vous revient et la date de règlement.', it: 'Il cliente chiude e paga la prima fattura. <strong>La tua commissione del 50% viene accreditata sul tuo portale all\'istante</strong> e liquidata sulla tua CLABE il giorno 1 del mese successivo. Vedi la vendita esatta, il piano contrattato, l\'importo che ti spetta e la data di liquidazione.', pt: 'O cliente fecha e paga a primeira nota fiscal. <strong>Sua comissão de 50% é creditada no seu portal na hora</strong> e liquidada na sua CLABE no dia 1 do mês seguinte. Você vê a venda exata, o plano contratado, o valor que te cabe e a data de liquidação.' },
  'fun.s6.t': { es: 'Onboarding + Migración', en: 'Onboarding + Data migration', fr: 'Onboarding + Migration', it: 'Onboarding + Migrazione', pt: 'Onboarding + Migração' },
  'fun.s6.tag': { es: 'SACS lo implementa', en: 'SACS implements it', fr: 'SACS implémente', it: 'SACS lo implementa', pt: 'A SACS implementa' },
  'fun.s6.d': { es: 'Sesión de implementación 1:1 con el cliente, migración de datos desde su sistema anterior (productos, inventario, clientes, ventas históricas) sin que pierdan información. Configuración del POS, tienda en línea, facturación y capacitación del equipo. <strong>Sin costo extra para el cliente.</strong>', en: '1:1 implementation session with the client, data migration from their previous system (products, inventory, customers, historical sales) without losing information. POS, online store, billing setup and team training. <strong>No extra cost for the client.</strong>', fr: 'Session d\'implémentation 1:1 avec le client, migration des données depuis leur ancien système (produits, inventaire, clients, ventes historiques) sans perte d\'information. Configuration POS, boutique en ligne, facturation et formation de l\'équipe. <strong>Sans coût supplémentaire pour le client.</strong>', it: 'Sessione di implementazione 1:1 con il cliente, migrazione dati dal sistema precedente (prodotti, inventario, clienti, vendite storiche) senza perdere informazioni. Setup POS, negozio online, fatturazione e formazione del team. <strong>Nessun costo extra per il cliente.</strong>', pt: 'Sessão de implementação 1:1 com o cliente, migração de dados do sistema anterior (produtos, inventário, clientes, vendas históricas) sem perder informação. Setup do POS, loja online, faturamento e treinamento da equipe. <strong>Sem custo extra para o cliente.</strong>' },
  'fun.s7.t': { es: 'Soporte continuo + Academia', en: 'Ongoing support + Academy', fr: 'Support continu + Académie', it: 'Supporto continuo + Academy', pt: 'Suporte contínuo + Academia' },
  'fun.s7.tag': { es: 'SACS lo retiene', en: 'SACS retains them', fr: 'SACS les fidélise', it: 'SACS lo trattiene', pt: 'A SACS retém' },
  'fun.s7.d': { es: 'Soporte <strong>24/7</strong> con un equipo de datos real (no chatbot). Acceso a la <strong>Academia SACS</strong> con cursos por giro y por módulo. <strong>Workshops mensuales</strong> de actualizaciones y mejores prácticas. El cliente se queda y tiene una buena experiencia — tu comisión recurrente sigue año tras año.', en: '<strong>24/7 support</strong> with a real data team (not a chatbot). Access to <strong>SACS Academy</strong> with courses by sector and module. <strong>Monthly workshops</strong> on updates and best practices. The client stays and has a great experience — your recurring commission keeps coming year after year.', fr: 'Support <strong>24/7</strong> avec une vraie équipe data (pas un chatbot). Accès à l\'<strong>Académie SACS</strong> avec cours par secteur et par module. <strong>Workshops mensuels</strong> sur les nouveautés et les bonnes pratiques. Le client reste et vit une bonne expérience — votre commission récurrente continue année après année.', it: 'Supporto <strong>24/7</strong> con un vero team dati (non chatbot). Accesso all\'<strong>Academy SACS</strong> con corsi per settore e modulo. <strong>Workshop mensili</strong> di aggiornamenti e best practice. Il cliente resta e vive una buona esperienza — la tua commissione ricorrente continua anno dopo anno.', pt: 'Suporte <strong>24/7</strong> com um time de dados real (não chatbot). Acesso à <strong>Academia SACS</strong> com cursos por segmento e por módulo. <strong>Workshops mensais</strong> de atualizações e melhores práticas. O cliente fica e tem uma boa experiência — sua comissão recorrente continua ano após ano.' },
  'fun.bar.flow.aria': { es: 'Flujo del embudo SACS', en: 'SACS funnel flow', fr: 'Flux de l\'entonnoir SACS', it: 'Flusso del funnel SACS', pt: 'Fluxo do funil SACS' },
  'fun.promise':  { es: '<strong>El cliente nunca queda solo.</strong> Tú recomiendas, SACS lo cierra, lo implementa y lo cuida. Esto significa que tu reputación está protegida — no vas a tener clientes molestos preguntándote por qué no funciona algo. Y el cliente se queda años, lo que mantiene tu comisión recurrente.', en: '<strong>The client is never left alone.</strong> You recommend, SACS closes, implements and cares for them. This means your reputation is protected — you won\'t have upset clients asking why something doesn\'t work. And the client stays for years, keeping your recurring commission alive.', fr: '<strong>Le client n\'est jamais laissé seul.</strong> Vous recommandez, SACS conclut, implémente et prend soin. Votre réputation est protégée — vous n\'aurez pas de clients mécontents qui vous demandent pourquoi ça ne marche pas. Et le client reste pendant des années, ce qui maintient votre commission récurrente.', it: '<strong>Il cliente non resta mai solo.</strong> Tu raccomandi, SACS chiude, implementa e si prende cura. La tua reputazione è protetta — non avrai clienti scontenti che ti chiedono perché qualcosa non funziona. E il cliente resta per anni, mantenendo viva la tua commissione ricorrente.', pt: '<strong>O cliente nunca fica sozinho.</strong> Você recomenda, a SACS fecha, implementa e cuida. Sua reputação está protegida — você não vai ter clientes irritados perguntando por que algo não funciona. E o cliente fica por anos, mantendo sua comissão recorrente.' },

  // 3-strikes block
  'str.eyebrow': { es: '⚠ Qué pasa si no cumples', en: '⚠ What happens if you don\'t meet it', fr: '⚠ Que se passe-t-il si vous ne respectez pas', it: '⚠ Cosa succede se non rispetti', pt: '⚠ O que acontece se você não cumprir' },
  'str.title':   { es: '3 meses sin cumplir tus 100 puntos = baja del programa.', en: '3 months without hitting your 100 points = removal from the program.', fr: '3 mois sans atteindre vos 100 points = exclusion du programme.', it: '3 mesi senza raggiungere i 100 punti = rimozione dal programma.', pt: '3 meses sem cumprir seus 100 pontos = baixa do programa.' },
  'str.lead':    { es: 'La meta de 100 puntos al mes es la señal de que sigues activo. Si la incumples <strong>tres meses consecutivos</strong>, se da de baja al partner del programa de manera automática.', en: 'The 100-points monthly goal is the signal that you\'re still active. If you miss it for <strong>three consecutive months</strong>, the partner is automatically removed from the program.', fr: 'L\'objectif de 100 points par mois est le signal que vous êtes actif. Si vous le manquez <strong>trois mois consécutifs</strong>, le partenaire est automatiquement exclu du programme.', it: 'L\'obiettivo dei 100 punti al mese è il segnale che sei ancora attivo. Se non lo raggiungi per <strong>tre mesi consecutivi</strong>, il partner viene rimosso automaticamente dal programma.', pt: 'A meta de 100 pontos por mês é o sinal de que você segue ativo. Se você não cumprir por <strong>três meses consecutivos</strong>, o parceiro é dado baixa do programa de forma automática.' },
  'str.s1.t': { es: 'Primer mes sin cumplir', en: 'First month missing target', fr: 'Premier mois manqué', it: 'Primo mese mancato', pt: 'Primeiro mês sem cumprir' },
  'str.s1.d': { es: 'Aviso por correo + recordatorio en tu portal. Sin penalización. El déficit se carga al mes siguiente.', en: 'Email warning + reminder on your portal. No penalty. The deficit carries over to the next month.', fr: 'Avertissement par email + rappel sur votre portail. Pas de pénalité. Le déficit est reporté au mois suivant.', it: 'Avviso via email + promemoria sul tuo portale. Nessuna penalità. Il deficit si riporta al mese successivo.', pt: 'Aviso por e-mail + lembrete no seu portal. Sem penalidade. O déficit é transportado para o mês seguinte.' },
  'str.s2.t': { es: 'Segundo mes consecutivo', en: 'Second consecutive month', fr: 'Deuxième mois consécutif', it: 'Secondo mese consecutivo', pt: 'Segundo mês consecutivo' },
  'str.s2.d': { es: 'Aviso urgente + llamada del equipo SACS para entender qué pasa y ajustar el plan contigo.', en: 'Urgent warning + a call from the SACS team to understand what\'s happening and adjust the plan with you.', fr: 'Avertissement urgent + un appel de l\'équipe SACS pour comprendre ce qui se passe et ajuster le plan avec vous.', it: 'Avviso urgente + chiamata del team SACS per capire cosa succede e aggiustare il piano con te.', pt: 'Aviso urgente + ligação da equipe SACS para entender o que está acontecendo e ajustar o plano com você.' },
  'str.s3.t': { es: 'Tercer mes consecutivo', en: 'Third consecutive month', fr: 'Troisième mois consécutif', it: 'Terzo mese consecutivo', pt: 'Terceiro mês consecutivo' },
  'str.s3.d': { es: 'Baja automática del programa. Se desactiva tu link, se cierran los beneficios y se cancelan los pagos de comisiones futuras. Excepciones: cartera consolidada y casos de protección (cláusula 6-bis).', en: 'Automatic removal from the program. Your link is deactivated, benefits end and future commission payments are canceled. Exceptions: consolidated portfolio and protection cases (clause 6-bis).', fr: 'Exclusion automatique du programme. Votre lien est désactivé, les avantages prennent fin et les paiements de commissions futures sont annulés. Exceptions : portefeuille consolidé et cas de protection (clause 6-bis).', it: 'Rimozione automatica dal programma. Il tuo link viene disattivato, i benefici si chiudono e i pagamenti di commissioni future vengono cancellati. Eccezioni: portafoglio consolidato e casi di protezione (clausola 6-bis).', pt: 'Baixa automática do programa. Seu link é desativado, os benefícios são encerrados e pagamentos de comissões futuras são cancelados. Exceções: carteira consolidada e casos de proteção (cláusula 6-bis).' },
  'str.pay.title': { es: 'Sobre los pagos de comisión', en: 'About commission payments', fr: 'À propos des paiements de commissions', it: 'Sui pagamenti di commissione', pt: 'Sobre os pagamentos de comissão' },
  'str.pay.body':  { es: 'Las comisiones <strong>solo se pagan mientras el partner está activo en el programa</strong>. Si te dan de baja por incumplimiento (3 meses sin meta) o por cualquier otra causa, los pagos pendientes y las comisiones recurrentes que vinieran de tus clientes ya cerrados se <strong>cancelan al momento de la baja</strong>. Por eso cumplir es directamente cuidar tu propio ingreso. <strong>Excepciones:</strong> cartera consolidada (100 cuentas activas), pausa notificada, incapacidad o fallecimiento — ver cláusula 6-bis del contrato.', en: 'Commissions <strong>are only paid while the partner is active in the program</strong>. If you\'re removed for non-compliance (3 months without target) or for any other reason, pending payments and recurring commissions from your already-closed clients are <strong>canceled at the moment of removal</strong>. That\'s why staying active directly protects your income. <strong>Exceptions:</strong> consolidated portfolio (100 active accounts), notified pause, incapacity or death — see clause 6-bis of the agreement.', fr: 'Les commissions <strong>ne sont versées que tant que le partenaire est actif dans le programme</strong>. Si vous êtes exclu pour non-conformité (3 mois sans objectif) ou pour toute autre raison, les paiements en attente et les commissions récurrentes de vos clients déjà conclus sont <strong>annulés au moment de l\'exclusion</strong>. C\'est pourquoi rester actif protège directement votre revenu. <strong>Exceptions :</strong> portefeuille consolidé (100 comptes actifs), pause notifiée, incapacité ou décès — voir la clause 6-bis du contrat.', it: 'Le commissioni <strong>vengono pagate solo finché il partner è attivo nel programma</strong>. Se vieni rimosso per inadempienza (3 mesi senza obiettivo) o per qualsiasi altro motivo, i pagamenti in sospeso e le commissioni ricorrenti dai tuoi clienti già chiusi vengono <strong>annullati al momento della rimozione</strong>. Per questo restare attivo protegge direttamente il tuo reddito. <strong>Eccezioni:</strong> portafoglio consolidato (100 conti attivi), pausa notificata, incapacità o decesso — vedi clausola 6-bis del contratto.', pt: 'As comissões <strong>só são pagas enquanto o parceiro está ativo no programa</strong>. Se você for dado baixa por descumprimento (3 meses sem meta) ou por qualquer outra causa, os pagamentos pendentes e as comissões recorrentes dos seus clientes já fechados são <strong>cancelados no momento da baixa</strong>. Por isso cumprir é cuidar diretamente da sua própria renda. <strong>Exceções:</strong> carteira consolidada (100 contas ativas), pausa notificada, incapacidade ou falecimento — ver cláusula 6-bis do contrato.' },

  // Glossary body — 12 dt+dd pairs
  'glos.cfdi.t':       { es: 'CFDI 4.0', en: 'CFDI 4.0', fr: 'CFDI 4.0', it: 'CFDI 4.0', pt: 'CFDI 4.0' },
  'glos.cfdi.d':       { es: 'Comprobante Fiscal Digital por Internet — la factura electrónica obligatoria en México (regulada por el SAT). SACS la genera automáticamente.', en: 'Digital Tax Receipt — Mexico\'s mandatory electronic invoice (regulated by the SAT). SACS generates it automatically.', fr: 'Comprobante Fiscal Digital — la facture électronique obligatoire au Mexique (régulée par le SAT). SACS la génère automatiquement.', it: 'Comprobante Fiscal Digital — la fattura elettronica obbligatoria in Messico (regolata dal SAT). SACS la genera automaticamente.', pt: 'Comprobante Fiscal Digital — a nota fiscal eletrônica obrigatória no México (regulada pelo SAT). A SACS gera automaticamente.' },
  'glos.mxn.t':        { es: 'MXN · Pesos mexicanos', en: 'MXN · Mexican pesos', fr: 'MXN · Pesos mexicains', it: 'MXN · Pesi messicani', pt: 'MXN · Pesos mexicanos' },
  'glos.mxn.d':        { es: 'Moneda de pago oficial del programa. Si tu país usa otra moneda, los pagos se hacen vía transferencia internacional con la conversión del día.', en: 'Official payment currency of the program. If your country uses another currency, payments are sent via international transfer at the day\'s conversion rate.', fr: 'Monnaie officielle de paiement du programme. Si votre pays utilise une autre monnaie, les paiements sont effectués par virement international au taux du jour.', it: 'Valuta ufficiale di pagamento del programma. Se il tuo paese usa un\'altra valuta, i pagamenti avvengono tramite bonifico internazionale al cambio del giorno.', pt: 'Moeda oficial de pagamento do programa. Se seu país usa outra moeda, os pagamentos são feitos por transferência internacional na conversão do dia.' },
  'glos.suc.t':        { es: 'Sucursal activa', en: 'Active store', fr: 'Boutique active', it: 'Negozio attivo', pt: 'Loja ativa' },
  'glos.suc.d':        { es: 'Una sucursal vendida en cualquier plan de SACS y con su primera factura cobrada. La cuota mínima anual son 10 sucursales activas; también es la unidad que desbloquea los hitos de la red de partner (5, 10, 20, 50+).', en: 'A store sold on any SACS plan with its first invoice paid. The minimum annual quota is 10 active stores; it\'s also the unit that unlocks partner network milestones (5, 10, 20, 50+).', fr: 'Une boutique vendue sur n\'importe quel plan SACS avec sa première facture payée. Le quota annuel minimum est de 10 boutiques actives ; c\'est aussi l\'unité qui débloque les paliers du réseau de partenaires (5, 10, 20, 50+).', it: 'Un negozio venduto su qualsiasi piano SACS con la prima fattura incassata. La quota minima annua è di 10 negozi attivi; è anche l\'unità che sblocca i milestone della rete partner (5, 10, 20, 50+).', pt: 'Uma loja vendida em qualquer plano da SACS com sua primeira nota fiscal paga. A cota mínima anual é de 10 lojas ativas; também é a unidade que desbloqueia os marcos da rede de parceiros (5, 10, 20, 50+).' },
  'glos.red.t':        { es: 'Red de partner / Network expansion', en: 'Partner network / Network expansion', fr: 'Réseau de partenaire / Expansion du réseau', it: 'Rete di partner / Espansione di rete', pt: 'Rede de parceiro / Expansão de rede' },
  'glos.red.d':        { es: 'Sistema de sub-niveles por el cual un partner se convierte en Master Partner Nv 1-4 según sus sucursales activas vendidas: 5 → Nv 1 (5 invitaciones), 10 → Nv 2 (10), 20 → Nv 3 (20), 50+ → Nv 4 (ilimitado). El partner invitado conserva íntegro su 50% directo; el Master Partner gana adicional un 10% sobre todo lo que su red venda, pagado por SACS. Master Partner Nv 4 sostenido 12 meses abre el Nivel 04 · Founder Circle.', en: 'Sub-level system whereby a partner becomes Master Partner Nv 1-4 based on their active stores sold: 5 → Nv 1 (5 invitations), 10 → Nv 2 (10), 20 → Nv 3 (20), 50+ → Nv 4 (unlimited). The invited partner keeps their full 50% direct commission; the Master Partner additionally earns a 10% override on everything their network sells, paid by SACS. Master Partner Nv 4 sustained 12 months unlocks Level 04 · Founder Circle.', fr: 'Système de sous-niveaux par lequel un partenaire devient Master Partner Nv 1-4 selon ses boutiques actives vendues : 5 → Nv 1 (5 invitations), 10 → Nv 2 (10), 20 → Nv 3 (20), 50+ → Nv 4 (illimité). Le partenaire invité conserve l\'intégralité de ses 50% directs ; le Master Partner gagne en plus un override de 10% sur tout ce que son réseau vend, payé par SACS. Master Partner Nv 4 maintenu 12 mois ouvre le Niveau 04 · Founder Circle.', it: 'Sistema di sotto-livelli con cui un partner diventa Master Partner Nv 1-4 in base ai suoi negozi attivi venduti: 5 → Nv 1 (5 inviti), 10 → Nv 2 (10), 20 → Nv 3 (20), 50+ → Nv 4 (illimitato). Il partner invitato mantiene integro il suo 50% diretto; il Master Partner guadagna in più un 10% override su tutto ciò che vende la sua rete, pagato da SACS. Master Partner Nv 4 sostenuto 12 mesi apre il Livello 04 · Founder Circle.', pt: 'Sistema de sub-níveis pelo qual um parceiro se torna Master Partner Nv 1-4 conforme suas lojas ativas vendidas: 5 → Nv 1 (5 convites), 10 → Nv 2 (10), 20 → Nv 3 (20), 50+ → Nv 4 (ilimitado). O parceiro convidado mantém íntegros seus 50% diretos; o Master Partner ganha adicional um 10% sobre tudo o que sua rede vende, pago pela SACS. Master Partner Nv 4 sustentado 12 meses abre o Nível 04 · Founder Circle.' },
  'glos.demo.t':       { es: 'Demo válido', en: 'Valid demo', fr: 'Démo valide', it: 'Demo valida', pt: 'Demo válida' },
  'glos.demo.d':       { es: 'Sesión de demostración con el tomador de decisión presente. Cada demo agendada por un lead que llegó por tu link aparece en tu portal con la fecha, el AE asignado y la fase del seguimiento.', en: 'Demo session with the decision-maker present. Each demo scheduled by a lead arriving via your link appears in your portal with the date, assigned AE and follow-up stage.', fr: 'Session de démonstration avec le décideur présent. Chaque démo planifiée par un lead arrivant par votre lien apparaît dans votre portail avec la date, l\'AE assigné et l\'étape de suivi.', it: 'Sessione dimostrativa con il decisore presente. Ogni demo prenotata da un lead che arriva dal tuo link appare nel tuo portale con la data, l\'AE assegnato e la fase di follow-up.', pt: 'Sessão de demonstração com o tomador de decisão presente. Cada demo agendada por um lead que chegou pelo seu link aparece no seu portal com a data, o AE atribuído e a fase do acompanhamento.' },
  'glos.attr.t':       { es: 'Atribución', en: 'Attribution', fr: 'Attribution', it: 'Attribuzione', pt: 'Atribuição' },
  'glos.attr.d':       { es: 'El sistema que conecta un prospecto con tu link único. Cuando alguien entra por sacscloud.com/p/tu-slug y se registra, queda permanentemente atribuido a ti.', en: 'The system that connects a prospect to your unique link. When someone enters via sacscloud.com/p/your-slug and registers, they\'re permanently attributed to you.', fr: 'Le système qui connecte un prospect à votre lien unique. Quand quelqu\'un arrive par sacscloud.com/p/votre-slug et s\'inscrit, il vous est attribué de façon permanente.', it: 'Il sistema che collega un prospect al tuo link unico. Quando qualcuno entra da sacscloud.com/p/tuo-slug e si registra, ti viene attribuito in modo permanente.', pt: 'O sistema que conecta um prospecto ao seu link único. Quando alguém entra por sacscloud.com/p/seu-slug e se cadastra, fica permanentemente atribuído a você.' },
  'glos.rec.t':        { es: 'Comisión recurrente', en: 'Recurring commission', fr: 'Commission récurrente', it: 'Commissione ricorrente', pt: 'Comissão recorrente' },
  'glos.rec.d':        { es: 'Tu porcentaje sobre cada cobro que SACS le hace al cliente — mes a mes o año a año mientras el cliente siga pagando, no solo en la primera factura.', en: 'Your percentage on every charge SACS makes to the client — month after month or year after year while the client keeps paying, not only on the first invoice.', fr: 'Votre pourcentage sur chaque facturation que SACS fait au client — mois après mois ou année après année tant que le client continue à payer, pas seulement sur la première facture.', it: 'La tua percentuale su ogni addebito che SACS fa al cliente — mese dopo mese o anno dopo anno finché il cliente paga, non solo sulla prima fattura.', pt: 'Sua porcentagem sobre cada cobrança que a SACS faz ao cliente — mês a mês ou ano a ano enquanto o cliente continuar pagando, não só na primeira nota.' },
  'glos.ret.t':        { es: 'Retainer', en: 'Retainer', fr: 'Retainer', it: 'Retainer', pt: 'Retainer' },
  'glos.ret.d':        { es: 'Cobro mensual recurrente por un servicio de consultoría continua (ej. consultor en IA que revisa los datos del cliente cada 30 días).', en: 'Recurring monthly fee for an ongoing consulting service (e.g. an AI consultant who reviews the client\'s data every 30 days).', fr: 'Honoraires mensuels récurrents pour un service de conseil continu (ex. consultant IA qui revoit les données du client tous les 30 jours).', it: 'Compenso mensile ricorrente per un servizio di consulenza continuativa (es. consulente IA che rivede i dati del cliente ogni 30 giorni).', pt: 'Cobrança mensal recorrente por um serviço de consultoria contínua (ex. consultor em IA que revisa os dados do cliente a cada 30 dias).' },
  'glos.b2b.t':        { es: 'B2B', en: 'B2B', fr: 'B2B', it: 'B2B', pt: 'B2B' },
  'glos.b2b.d':        { es: 'Business-to-business: ventas de empresa a empresa. Distinto a B2C, que sería empresa a consumidor final.', en: 'Business-to-business: company-to-company sales. Different from B2C, which is company to end consumer.', fr: 'Business-to-business : ventes d\'entreprise à entreprise. Différent du B2C, qui est entreprise à consommateur final.', it: 'Business-to-business: vendite tra aziende. Diverso dal B2C, che è azienda verso consumatore finale.', pt: 'Business-to-business: vendas de empresa para empresa. Diferente de B2C, que é empresa para consumidor final.' },
  'glos.fid.t':        { es: 'Plan Fideliza', en: 'Fideliza Plan', fr: 'Plan Fideliza', it: 'Piano Fideliza', pt: 'Plano Fideliza' },
  'glos.fid.d':        { es: 'Uno de los 4 planes de SACS — incluye POS, inventario multi-sucursal, e-commerce, CRM, lealtad y marketing. Costo público: $14,000 MXN/año. Para partners: gratis.', en: 'One of SACS\' 4 plans — includes POS, multi-store inventory, e-commerce, CRM, loyalty and marketing. Public price: $14,000 MXN/year. For partners: free.', fr: 'L\'un des 4 plans SACS — inclut POS, inventaire multi-magasin, e-commerce, CRM, fidélité et marketing. Prix public : 14 000 MXN/an. Pour les partenaires : gratuit.', it: 'Uno dei 4 piani SACS — include POS, inventario multi-negozio, e-commerce, CRM, fedeltà e marketing. Prezzo pubblico: $14.000 MXN/anno. Per i partner: gratis.', pt: 'Um dos 4 planos da SACS — inclui POS, inventário multi-loja, e-commerce, CRM, fidelidade e marketing. Preço público: $14.000 MXN/ano. Para parceiros: grátis.' },
  'glos.pt.t':         { es: 'Punto del programa', en: 'Program point', fr: 'Point du programme', it: 'Punto del programma', pt: 'Ponto do programa' },
  'glos.pt.d':         { es: 'Unidad de medida de tu actividad mensual. Cada acción (contenido, apoyo, filantropía) vale puntos según esfuerzo. Meta: 100 al mes para mantenerte activo.', en: 'Unit of measure for your monthly activity. Each action (content, support, philanthropy) is worth points by effort. Goal: 100 per month to stay active.', fr: 'Unité de mesure de votre activité mensuelle. Chaque action (contenu, soutien, philanthropie) vaut des points selon l\'effort. Objectif : 100 par mois pour rester actif.', it: 'Unità di misura della tua attività mensile. Ogni azione (contenuti, supporto, filantropia) vale punti secondo lo sforzo. Obiettivo: 100 al mese per rimanere attivo.', pt: 'Unidade de medida da sua atividade mensal. Cada ação (conteúdo, apoio, filantropia) vale pontos conforme o esforço. Meta: 100 por mês para se manter ativo.' },
  'glos.3s.t':         { es: '3-strike rule', en: '3-strike rule', fr: 'Règle des 3 strikes', it: 'Regola dei 3 strike', pt: 'Regra dos 3 strikes' },
  'glos.3s.d':         { es: 'Si fallas 3 meses consecutivos en alcanzar los 100 puntos, se da de baja al partner del programa y se cancelan los pagos de comisiones futuras. Excepciones: cartera consolidada y casos de protección (cláusula 6-bis).', en: 'If you miss the 100-point goal 3 consecutive months, the partner is removed from the program and future commission payments are canceled. Exceptions: consolidated portfolio and protection cases (clause 6-bis).', fr: 'Si vous manquez l\'objectif de 100 points 3 mois consécutifs, le partenaire est exclu du programme et les paiements de commissions futurs sont annulés. Exceptions : portefeuille consolidé et cas de protection (clause 6-bis).', it: 'Se non raggiungi l\'obiettivo dei 100 punti per 3 mesi consecutivi, il partner viene rimosso dal programma e i pagamenti di commissioni future vengono annullati. Eccezioni: portafoglio consolidato e casi di protezione (clausola 6-bis).', pt: 'Se você falhar 3 meses consecutivos em atingir 100 pontos, o parceiro é dado baixa do programa e os pagamentos de comissões futuras são cancelados. Exceções: carteira consolidada e casos de proteção (cláusula 6-bis).' },
  'glos.cert.t':       { es: 'Cuota de certificación', en: 'Certification fee', fr: 'Frais de certification', it: 'Quota di certificazione', pt: 'Taxa de certificação' },
  'glos.cert.d':       { es: 'Pago único que SACS te cobra una sola vez para certificarte en una especialidad. Una vez certificado, el 100% de lo que cobres al cliente por servicios profesionales es tuyo.', en: 'One-time fee SACS charges you once to certify you in a specialty. Once certified, 100% of what you charge the client for professional services is yours.', fr: 'Paiement unique que SACS facture une seule fois pour vous certifier dans une spécialité. Une fois certifié, 100% de ce que vous facturez au client pour les services professionnels vous revient.', it: 'Pagamento unico che SACS ti addebita una sola volta per certificarti in una specialità. Una volta certificato, il 100% di quello che fatturi al cliente per i servizi professionali è tuo.', pt: 'Pagamento único que a SACS te cobra uma só vez para te certificar numa especialidade. Uma vez certificado, 100% do que você cobra do cliente por serviços profissionais é seu.' },

  // Phase F · FAQ
  'faq.eyebrow':  { es: '4 · Las preguntas que todos tienen', en: '4 · The questions everyone has', fr: '4 · Les questions que tout le monde se pose', it: '4 · Le domande che tutti hanno', pt: '4 · As perguntas que todos têm' },
  'faq.lead':     { es: 'Lo que la gente piensa antes de firmar pero no siempre pregunta. Respuestas honestas, no marketing.', en: 'What people think before signing but don\'t always ask. Honest answers, no marketing fluff.', fr: 'Ce que les gens pensent avant de signer mais ne demandent pas toujours. Réponses honnêtes, pas de marketing.', it: 'Quello che la gente pensa prima di firmare ma non sempre chiede. Risposte oneste, niente marketing.', pt: 'O que as pessoas pensam antes de assinar mas nem sempre perguntam. Respostas honestas, sem marketing.' },
  'faq.q1.q': { es: '¿Y si no tengo audiencia o apenas estoy empezando?', en: 'What if I have no audience or am just starting out?', fr: 'Et si je n\'ai pas d\'audience ou si je débute ?', it: 'E se non ho un pubblico o sto appena iniziando?', pt: 'E se eu não tiver audiência ou estiver começando?' },
  'faq.q1.a': { es: 'No necesitas ser un creador con miles de seguidores. La mayoría de nuestros mejores partners son dueños de negocio que recomiendan SACS a otros dueños de su mismo giro. Tu credibilidad operacional vale más que el tamaño de tu audiencia. Y si no logras hacer puntos por contenido, las acciones de apoyo (demos, eventos, intros) y las filantrópicas suman igual.', en: 'You don\'t need to be a creator with thousands of followers. Most of our best partners are business owners recommending SACS to other owners in their sector. Your operational credibility outweighs the size of your audience. And if you can\'t earn points through content, support actions (demos, events, intros) and philanthropy count the same.', fr: 'Pas besoin d\'être un créateur avec des milliers de followers. La plupart de nos meilleurs partenaires sont des chefs d\'entreprise qui recommandent SACS à d\'autres chefs d\'entreprise de leur secteur. Votre crédibilité opérationnelle pèse plus que la taille de votre audience. Et si vous n\'arrivez pas à gagner de points via le contenu, les actions de soutien (démos, événements, introductions) et la philanthropie comptent autant.', it: 'Non devi essere un creator con migliaia di follower. La maggior parte dei nostri partner migliori sono titolari di attività che raccomandano SACS ad altri titolari del loro settore. La tua credibilità operativa conta più della dimensione del tuo pubblico. E se non riesci a guadagnare punti con i contenuti, le azioni di supporto (demo, eventi, introduzioni) e la filantropia contano allo stesso modo.', pt: 'Você não precisa ser um criador com milhares de seguidores. A maioria dos nossos melhores parceiros são donos de negócio que recomendam a SACS a outros donos do mesmo segmento. Sua credibilidade operacional pesa mais que o tamanho da sua audiência. E se não conseguir somar pontos com conteúdo, as ações de apoio (demos, eventos, intros) e a filantropia somam igual.' },
  'faq.q2.q': { es: '¿Qué pasa si en 3 meses todavía no he cerrado ninguna venta?', en: 'What if after 3 months I still haven\'t closed any sale?', fr: 'Et si après 3 mois je n\'ai toujours pas conclu de vente ?', it: 'E se dopo 3 mesi non ho ancora chiuso nessuna vendita?', pt: 'E se em 3 meses eu ainda não tiver fechado nenhuma venda?' },
  'faq.q2.a': { es: 'No pasa nada con tu permanencia mientras sigas cumpliendo tus 100 puntos al mes (contenido, apoyo o filantropía). La cuota anual de 10 sucursales es a 12 meses con un plan de recuperación de 90 días extra si no se alcanza. Cerrar una venta puede tomar 60-90 días — es normal en B2B.', en: 'Your standing is fine as long as you keep hitting your 100 points per month (content, support or philanthropy). The annual 10-store quota is over 12 months with an extra 90-day recovery plan if not reached. Closing a sale can take 60-90 days — that\'s normal in B2B.', fr: 'Votre statut reste intact tant que vous atteignez vos 100 points par mois (contenu, soutien ou philanthropie). Le quota annuel de 10 boutiques s\'étale sur 12 mois avec un plan de récupération de 90 jours supplémentaires si non atteint. Conclure une vente peut prendre 60-90 jours — c\'est normal en B2B.', it: 'La tua posizione è a posto finché continui a fare i tuoi 100 punti al mese (contenuti, supporto o filantropia). La quota annua di 10 negozi è su 12 mesi con un piano di recupero di 90 giorni in più se non raggiunta. Chiudere una vendita può richiedere 60-90 giorni — è normale nel B2B.', pt: 'Sua permanência fica tranquila enquanto você cumprir seus 100 pontos por mês (conteúdo, apoio ou filantropia). A cota anual de 10 lojas é em 12 meses com um plano de recuperação de 90 dias extras se não alcançada. Fechar uma venda pode levar 60-90 dias — é normal no B2B.' },
  'faq.q3.q': { es: '¿Mi cliente sabrá que viene por mí?', en: 'Will my client know they came through me?', fr: 'Mon client saura-t-il qu\'il vient grâce à moi ?', it: 'Il mio cliente saprà che viene tramite me?', pt: 'Meu cliente vai saber que veio por mim?' },
  'faq.q3.a': { es: 'Sí — la atribución es transparente y va en ambas direcciones. El cliente entra por tu link único y sabe que tú lo trajiste. Tú ves cada paso de su proceso desde tu portal. SACS nunca le oculta tu rol al cliente ni te oculta el cliente a ti.', en: 'Yes — attribution is transparent in both directions. The client comes through your unique link and knows you brought them. You see every step of their process from your portal. SACS never hides your role from the client or hides the client from you.', fr: 'Oui — l\'attribution est transparente dans les deux sens. Le client arrive par votre lien unique et sait que vous l\'avez amené. Vous voyez chaque étape de son parcours depuis votre portail. SACS ne cache jamais votre rôle au client ni le client à vous.', it: 'Sì — l\'attribuzione è trasparente in entrambe le direzioni. Il cliente entra dal tuo link unico e sa che l\'hai portato tu. Tu vedi ogni passo del suo processo dal tuo portale. SACS non nasconde mai il tuo ruolo al cliente né il cliente a te.', pt: 'Sim — a atribuição é transparente em ambas as direções. O cliente entra pelo seu link único e sabe que você o trouxe. Você vê cada passo do processo dele pelo seu portal. A SACS nunca esconde seu papel do cliente nem o cliente de você.' },
  'faq.q4.q': { es: '¿Qué tengo que invertir además de mi tiempo?', en: 'What do I have to invest besides my time?', fr: 'Que dois-je investir au-delà de mon temps ?', it: 'Cosa devo investire oltre al mio tempo?', pt: 'O que tenho que investir além do meu tempo?' },
  'faq.q4.a': { es: 'Cero. Plan Fideliza activo en tu cuenta SACS sin costo, materiales de marca, capacitaciones y soporte sin cargo. Solo si decides certificarte (opcional) hay una cuota única que va de $7,500 a $21,000 MXN. Esa cert te permite cobrar servicios profesionales con el 100% del cobro para ti.', en: 'Zero. Fideliza Plan active in your SACS account at no cost, brand materials, training and support free of charge. Only if you choose to get certified (optional) is there a one-time fee from $7,500 to $21,000 MXN. That cert lets you charge professional services with 100% of the billing for you.', fr: 'Rien. Plan Fideliza actif dans votre compte SACS sans frais, supports de marque, formations et accompagnement gratuits. Uniquement si vous choisissez de vous certifier (optionnel) il y a un paiement unique de 7 500 à 21 000 MXN. Cette certification vous permet de facturer des services professionnels avec 100% de la facturation pour vous.', it: 'Zero. Piano Fideliza attivo nel tuo account SACS senza costi, materiali di brand, formazione e supporto gratis. Solo se scegli di certificarti (opzionale) c\'è una quota unica da $7.500 a $21.000 MXN. Quella certificazione ti permette di fatturare servizi professionali con il 100% della fattura per te.', pt: 'Zero. Plano Fideliza ativo na sua conta SACS sem custo, materiais de marca, capacitação e suporte sem cobrança. Só se você escolher se certificar (opcional) há uma taxa única de $7.500 a $21.000 MXN. Essa certificação te permite cobrar serviços profissionais com 100% da cobrança para você.' },
  'faq.q5.q': { es: '¿Cuándo cobro mi primera comisión?', en: 'When do I get my first commission?', fr: 'Quand vais-je toucher ma première commission ?', it: 'Quando incasso la mia prima commissione?', pt: 'Quando recebo minha primeira comissão?' },
  'faq.q5.a': { es: 'Cada lead que llega por tu link queda registrado en tu portal con todo su seguimiento — clicks, prueba gratis activada, demo agendada, contactos con el equipo, fase del embudo. Tu <strong>50% de comisión se acredita cuando el cliente cierra y paga su primera factura</strong>, y se liquida a tu CLABE el día 1 del mes siguiente con desglose detallado por concepto, cliente y fecha.', en: 'Every lead that arrives via your link is recorded in your portal with full tracking — clicks, activated free trial, scheduled demo, team contacts, funnel stage. Your <strong>50% commission credits when the client closes and pays their first invoice</strong>, and settles to your CLABE on the 1st of the following month with detailed breakdown by concept, client and date.', fr: 'Chaque lead arrivant par votre lien est enregistré dans votre portail avec un suivi complet — clics, essai gratuit activé, démo planifiée, contacts avec l\'équipe, étape du funnel. Votre <strong>commission de 50% est créditée quand le client conclut et paye sa première facture</strong>, et est versée à votre CLABE le 1er du mois suivant avec un détail complet par concept, client et date.', it: 'Ogni lead che arriva dal tuo link viene registrato nel tuo portale con il tracciamento completo — click, prova gratuita attivata, demo prenotata, contatti con il team, fase del funnel. La tua <strong>commissione del 50% viene accreditata quando il cliente chiude e paga la prima fattura</strong>, e viene liquidata sulla tua CLABE il giorno 1 del mese successivo con dettaglio completo per concetto, cliente e data.', pt: 'Cada lead que chega pelo seu link fica registrado no seu portal com todo o acompanhamento — cliques, teste grátis ativado, demo agendada, contatos com o time, fase do funil. Sua <strong>comissão de 50% é creditada quando o cliente fecha e paga a primeira nota fiscal</strong>, e é liquidada na sua CLABE no dia 1 do mês seguinte com detalhamento completo por conceito, cliente e data.' },
  'faq.q6.q': { es: '¿Si SACS sube de precio, baja mi comisión?', en: 'If SACS raises prices, does my commission shrink?', fr: 'Si SACS augmente ses prix, ma commission baisse-t-elle ?', it: 'Se SACS aumenta i prezzi, la mia commissione cala?', pt: 'Se a SACS subir os preços, minha comissão cai?' },
  'faq.q6.a': { es: 'No. Tu comisión es porcentaje, no monto fijo — si SACS sube, tu comisión sube proporcionalmente. Tu porcentaje queda fijo en el contrato; los precios de la lista pública pueden variar pero tu trato es el que firmaste.', en: 'No. Your commission is a percentage, not a fixed amount — if SACS goes up, your commission goes up proportionally. Your percentage is fixed in the contract; public list prices may vary but your deal is the one you signed.', fr: 'Non. Votre commission est un pourcentage, pas un montant fixe — si SACS augmente, votre commission augmente proportionnellement. Votre pourcentage est fixé dans le contrat ; les prix publics peuvent varier mais votre accord est celui que vous avez signé.', it: 'No. La tua commissione è una percentuale, non un importo fisso — se SACS aumenta, la tua commissione aumenta proporzionalmente. La tua percentuale è fissa nel contratto; i prezzi della lista pubblica possono variare ma il tuo accordo è quello che hai firmato.', pt: 'Não. Sua comissão é porcentagem, não valor fixo — se a SACS sobe, sua comissão sobe proporcionalmente. Sua porcentagem fica fixa no contrato; os preços da lista pública podem variar mas seu trato é o que você assinou.' },
  'faq.q7.q': { es: '¿Me puedo dar de baja cuando quiera?', en: 'Can I leave the program whenever I want?', fr: 'Puis-je quitter le programme quand je veux ?', it: 'Posso uscire dal programma quando voglio?', pt: 'Posso sair do programa quando quiser?' },
  'faq.q7.a': { es: 'Sí, con 30 días de aviso por escrito. Las comisiones recurrentes que vinieran de tus clientes activos se cancelan al momento de la baja — por eso la cláusula es real, no decorativa. Mientras estás activo, los pagos siguen.', en: 'Yes, with 30 days written notice. Recurring commissions from your active clients are canceled at the moment of departure — that\'s why the clause is real, not decorative. While you\'re active, payments continue.', fr: 'Oui, avec un préavis écrit de 30 jours. Les commissions récurrentes provenant de vos clients actifs sont annulées au moment du départ — c\'est pourquoi la clause est réelle, pas décorative. Tant que vous êtes actif, les paiements continuent.', it: 'Sì, con 30 giorni di preavviso scritto. Le commissioni ricorrenti dai tuoi clienti attivi vengono annullate al momento dell\'uscita — per questo la clausola è reale, non decorativa. Finché sei attivo, i pagamenti continuano.', pt: 'Sim, com 30 dias de aviso por escrito. As comissões recorrentes dos seus clientes ativos são canceladas no momento da baixa — por isso a cláusula é real, não decorativa. Enquanto você estiver ativo, os pagamentos continuam.' },
  'faq.q8.q': { es: '¿Y si me cambio de país o de giro?', en: 'And if I move to another country or change sectors?', fr: 'Et si je change de pays ou de secteur ?', it: 'E se cambio paese o settore?', pt: 'E se eu mudar de país ou de setor?' },
  'faq.q8.a': { es: 'No es problema. SACS opera en 12 países y los partners tienen flexibilidad — puedes pivotar tu enfoque mientras sigas cumpliendo los compromisos. Avísanos para actualizar tu perfil y recalibrar las palabras clave que te enviamos cada mes.', en: 'No problem. SACS operates in 12 countries and partners have flexibility — you can pivot your focus while still meeting commitments. Let us know to update your profile and recalibrate the keywords we send each month.', fr: 'Pas de problème. SACS opère dans 12 pays et les partenaires ont de la flexibilité — vous pouvez pivoter tant que vous respectez les engagements. Prévenez-nous pour mettre à jour votre profil et recalibrer les mots-clés mensuels.', it: 'Nessun problema. SACS opera in 12 paesi e i partner hanno flessibilità — puoi cambiare focus finché rispetti gli impegni. Avvisaci per aggiornare il tuo profilo e ricalibrare le parole chiave mensili.', pt: 'Sem problema. A SACS opera em 12 países e os parceiros têm flexibilidade — você pode pivotar seu foco enquanto continuar cumprindo os compromissos. Nos avise para atualizar seu perfil e recalibrar as palavras-chave mensais.' },

  // Category labels + descriptions (Contenido / Apoyo / Filantropía)
  'cat.contenido.l':  { es: 'Contenido',         en: 'Content',          fr: 'Contenu',         it: 'Contenuti',       pt: 'Conteúdo' },
  'cat.contenido.d':  { es: 'Piezas que produces y publicas en tus redes para posicionar SACS y tu marca personal.', en: 'Pieces you produce and publish on your channels to position SACS and your personal brand.', fr: 'Pièces que vous produisez et publiez sur vos canaux pour positionner SACS et votre marque personnelle.', it: 'Pezzi che produci e pubblichi sui tuoi canali per posizionare SACS e il tuo brand personale.', pt: 'Peças que você produz e publica nas suas redes para posicionar a SACS e sua marca pessoal.' },
  'cat.apoyo.l':      { es: 'Acciones de apoyo', en: 'Support actions',  fr: 'Actions de soutien', it: 'Azioni di supporto', pt: 'Ações de apoio' },
  'cat.apoyo.d':      { es: 'Acciones de marketing y crecimiento que extienden a SACS sin ser contenido publicado: demos en eventos, reseñas, intros, activaciones in situ.', en: 'Marketing and growth actions that extend SACS without being published content: event demos, reviews, intros, on-site activations.', fr: 'Actions de marketing et de croissance qui étendent SACS sans être du contenu publié : démos lors d\'événements, avis, introductions, activations sur site.', it: 'Azioni di marketing e crescita che estendono SACS senza essere contenuti pubblicati: demo in eventi, recensioni, introduzioni, attivazioni in loco.', pt: 'Ações de marketing e crescimento que estendem a SACS sem serem conteúdo publicado: demos em eventos, avaliações, intros, ativações no local.' },
  'cat.filantropia.l':{ es: 'Filantropía',       en: 'Philanthropy',     fr: 'Philanthropie',   it: 'Filantropia',     pt: 'Filantropia' },
  'cat.filantropia.d':{ es: 'Acciones para ayudar a personas o animales — voluntariado, refugios, comedores, jornadas, mentorías. Documentadas con foto/video.', en: 'Actions to help people or animals — volunteering, shelters, kitchens, drives, mentoring. Documented with photo/video.', fr: 'Actions pour aider les personnes ou animaux — bénévolat, refuges, cantines, journées, mentorat. Documentées avec photo/vidéo.', it: 'Azioni per aiutare persone o animali — volontariato, rifugi, mense, giornate, mentoring. Documentate con foto/video.', pt: 'Ações para ajudar pessoas ou animais — voluntariado, abrigos, refeitórios, jornadas, mentorias. Documentadas com foto/vídeo.' },

  // 4 howto steps in Contenido
  'cnt.h1.t': { es: 'Eliges la mezcla', en: 'You pick the mix', fr: 'Vous choisissez le mix', it: 'Scegli il mix', pt: 'Você escolhe a mistura' },
  'cnt.h1.d': { es: 'Contenido en redes, acciones de apoyo (demos, eventos, intros) o filantropía (refugios, comedores, mentorías). Combinas como prefieras.', en: 'Content on social, support actions (demos, events, intros) or philanthropy (shelters, kitchens, mentoring). Mix as you prefer.', fr: 'Contenu sur les réseaux, actions de soutien (démos, événements, intros) ou philanthropie (refuges, cantines, mentorat). Combinez comme vous voulez.', it: 'Contenuti sui social, azioni di supporto (demo, eventi, intro) o filantropia (rifugi, mense, mentoring). Mescola come preferisci.', pt: 'Conteúdo nas redes, ações de apoio (demos, eventos, intros) ou filantropia (abrigos, refeitórios, mentorias). Combina como preferir.' },
  'cnt.h2.t': { es: 'Subes la prueba a tu panel', en: 'Upload the proof to your panel', fr: 'Envoyez la preuve sur votre portail', it: 'Carichi la prova sul tuo pannello', pt: 'Envia a evidência no seu painel' },
  'cnt.h2.d': { es: 'Tab "Reportar actividad" en tu portal — link, foto o video según el tipo. Toma menos de 1 minuto por acción.', en: '"Report activity" tab in your portal — link, photo or video depending on the type. Takes less than 1 minute per action.', fr: 'Onglet « Reporter une activité » sur votre portail — lien, photo ou vidéo selon le type. Moins d\'une minute par action.', it: 'Tab "Segnala attività" nel tuo portale — link, foto o video secondo il tipo. Meno di 1 minuto per azione.', pt: 'Aba "Reportar atividade" no seu portal — link, foto ou vídeo conforme o tipo. Leva menos de 1 minuto por ação.' },
  'cnt.h3.t': { es: 'SACS valida y otorga puntos', en: 'SACS validates and awards points', fr: 'SACS valide et attribue des points', it: 'SACS valida e assegna punti', pt: 'A SACS valida e dá pontos' },
  'cnt.h3.d': { es: 'En 24-48h hábiles. Si pasas de 100 puntos en el mes, el excedente se acumula al siguiente mes.', en: 'Within 24-48 business hours. If you exceed 100 points in the month, the surplus carries over to the next month.', fr: 'Sous 24-48h ouvrées. Si vous dépassez 100 points dans le mois, le surplus est reporté au mois suivant.', it: 'In 24-48h lavorative. Se superi 100 punti nel mese, l\'eccedenza si riporta al mese successivo.', pt: 'Em 24-48h úteis. Se passar de 100 pontos no mês, o excedente acumula no mês seguinte.' },
  'cnt.h4.t': { es: 'Te mantienes activo en el programa', en: 'You stay active in the program', fr: 'Vous restez actif dans le programme', it: 'Resti attivo nel programma', pt: 'Você se mantém ativo no programa' },
  'cnt.h4.d': { es: 'Cumplir 100 pts/mes es la señal de que sigues participando. Sin reporte en el panel, no se acreditan puntos ni se mantienen los beneficios.', en: 'Meeting 100 pts/month is the signal that you\'re still participating. No report in the panel, no points credited and benefits won\'t hold.', fr: 'Atteindre 100 pts/mois est le signal que vous participez toujours. Pas de rapport sur le portail, pas de points crédités et les avantages ne tiennent pas.', it: 'Raggiungere 100 punti/mese è il segnale che continui a partecipare. Senza report sul pannello, nessun punto viene accreditato e i benefici non si mantengono.', pt: 'Cumprir 100 pts/mês é o sinal de que você segue participando. Sem reporte no painel, não há pontos creditados nem benefícios mantidos.' },

  // Notas finales del tab contenido (Detalles importantes)
  'cnt.notes.title': { es: 'Detalles importantes', en: 'Important details', fr: 'Détails importants', it: 'Dettagli importanti', pt: 'Detalhes importantes' },
  'cnt.notes.acumulacion': { es: '<strong>Acumulación:</strong> si en abril haces 160 puntos, llegas a mayo con 60 puntos ya hechos.', en: '<strong>Carry-over:</strong> if in April you hit 160 points, you start May with 60 points already done.', fr: '<strong>Report :</strong> si en avril vous faites 160 points, vous commencez mai avec 60 points déjà faits.', it: '<strong>Accumulo:</strong> se ad aprile fai 160 punti, arrivi a maggio con 60 punti già fatti.', pt: '<strong>Acúmulo:</strong> se em abril você fizer 160 pontos, chega a maio com 60 pontos já feitos.' },
  'cnt.notes.bonus': { es: '<strong>Bonus serie:</strong> entregar 10 episodios juntos te da 600 puntos (60 × 10), te ahorras rounds de aprobación y aseguras una serie cohesiva.', en: '<strong>Series bonus:</strong> delivering 10 episodes together earns you 600 points (60 × 10), saves you approval rounds and ensures a cohesive series.', fr: '<strong>Bonus série :</strong> livrer 10 épisodes ensemble vous donne 600 points (60 × 10), vous évite des cycles d\'approbation et assure une série cohérente.', it: '<strong>Bonus serie:</strong> consegnare 10 episodi insieme ti dà 600 punti (60 × 10), ti risparmi i round di approvazione e garantisci una serie coesa.', pt: '<strong>Bônus série:</strong> entregar 10 episódios juntos te dá 600 pontos (60 × 10), economiza rounds de aprovação e garante uma série coesa.' },
  'cnt.notes.calidad': { es: '<strong>Calidad sobre cantidad:</strong> si rechazamos contenido, te explicamos por qué para que el próximo sí cuente.', en: '<strong>Quality over quantity:</strong> if we reject content, we explain why so the next one counts.', fr: '<strong>Qualité sur quantité :</strong> si nous rejetons un contenu, nous expliquons pourquoi pour que le prochain compte.', it: '<strong>Qualità sulla quantità:</strong> se rifiutiamo contenuti, ti spieghiamo il perché così il prossimo conta.', pt: '<strong>Qualidade acima de quantidade:</strong> se recusarmos conteúdo, explicamos o porquê para que o próximo conte.' },
  'cnt.notes.keywords': { es: '<strong>Palabras clave:</strong> SACS te las envía cada mes 1 — no son obligatorias, pero te dan ventaja para SEO conjunto.', en: '<strong>Keywords:</strong> SACS sends them on the 1st of each month — not mandatory, but they give you a joint SEO edge.', fr: '<strong>Mots-clés :</strong> SACS vous les envoie le 1er de chaque mois — pas obligatoires, mais ils vous donnent un avantage SEO commun.', it: '<strong>Parole chiave:</strong> SACS te le invia il 1° di ogni mese — non sono obbligatorie, ma ti danno un vantaggio SEO congiunto.', pt: '<strong>Palavras-chave:</strong> a SACS te envia no dia 1 de cada mês — não são obrigatórias, mas dão vantagem de SEO conjunto.' },
  'cnt.notes.penal': { es: '<strong>Sin penalización:</strong> si un mes no llegas a 100, no pasa nada. Si tres meses seguidos &lt; 50, agendamos una llamada para ajustar.', en: '<strong>No penalty:</strong> if you miss 100 in a month, nothing happens. If three months in a row &lt; 50, we book a call to adjust.', fr: '<strong>Pas de pénalité :</strong> si un mois vous n\'atteignez pas 100, rien ne se passe. Si trois mois d\'affilée &lt; 50, nous planifions un appel pour ajuster.', it: '<strong>Nessuna penalità:</strong> se un mese non arrivi a 100, non succede niente. Se per tre mesi consecutivi &lt; 50, fissiamo una call per aggiustare.', pt: '<strong>Sem penalidade:</strong> se um mês não chegar a 100, não passa nada. Se três meses seguidos &lt; 50, agendamos uma chamada para ajustar.' },

  // Card meta labels + ideas/platforms label
  'card.effort':       { es: 'esfuerzo', en: 'effort', fr: 'effort', it: 'sforzo', pt: 'esforço' },
  'card.examples':     { es: 'Ejemplos:', en: 'Examples:', fr: 'Exemples :', it: 'Esempi:', pt: 'Exemplos:' },
  'card.see_examples': { es: 'Ver ejemplos:', en: 'See examples:', fr: 'Voir les exemples :', it: 'Vedi esempi:', pt: 'Ver exemplos:' },
  'card.empty':        { es: 'Sin acciones específicas para este perfil en esta categoría — cambia el perfil o explora otro tab.', en: 'No actions specific to this profile in this category — change profile or explore another tab.', fr: 'Aucune action spécifique à ce profil dans cette catégorie — changez de profil ou explorez un autre onglet.', it: 'Nessuna azione specifica per questo profilo in questa categoria — cambia profilo o esplora un\'altra tab.', pt: 'Sem ações específicas para este perfil nesta categoria — mude o perfil ou explore outra aba.' },

  // Certificaciones · cert hero, sección, unlock, CTA, card labels
  'cert.hero.eyebrow':   { es: 'Capítulo siguiente', en: 'Next chapter', fr: 'Chapitre suivant', it: 'Prossimo capitolo', pt: 'Próximo capítulo' },
  'cert.hero.title':     { es: 'De partner a consultor certificado.', en: 'From partner to certified consultant.', fr: 'De partenaire à consultant certifié.', it: 'Da partner a consulente certificato.', pt: 'De parceiro a consultor certificado.' },
  'cert.section.eyebrow':{ es: '3 · Sube de nivel con certificaciones', en: '3 · Level up with certifications', fr: '3 · Montez en niveau avec les certifications', it: '3 · Sali di livello con le certificazioni', pt: '3 · Suba de nível com certificações' },
  'cert.section.lead':   { es: 'La comisión por venta es el piso. Si quieres ganar más, certifícate y empieza a cobrar servicios profesionales a tus clientes. <strong>Te quedas con el 100% de lo que cobras al cliente</strong> — SACS solo cobra una vez la cuota de la certificación. Te certificamos, te entregamos tu diploma y badge oficial, y desde ese momento puedes ofrecer el servicio.', en: 'The sales commission is your floor. If you want to earn more, get certified and start charging professional services to your clients. <strong>You keep 100% of what you charge the client</strong> — SACS only charges the certification fee once. We certify you, hand you your diploma and official badge, and from that moment you can offer the service.', fr: 'La commission sur ventes est votre plancher. Pour gagner plus, certifiez-vous et facturez des services professionnels à vos clients. <strong>Vous gardez 100% de ce que vous facturez au client</strong> — SACS ne facture qu\'une seule fois les frais de certification. Nous vous certifions, vous remettons votre diplôme et badge officiel, et dès ce moment vous pouvez proposer le service.', it: 'La commissione sulle vendite è la base. Per guadagnare di più, certificati e inizia a fatturare servizi professionali ai tuoi clienti. <strong>Tieni il 100% di quello che fatturi al cliente</strong> — SACS addebita solo una volta la quota della certificazione. Ti certifichiamo, ti consegniamo il diploma e badge ufficiale, e da quel momento puoi offrire il servizio.', pt: 'A comissão sobre vendas é o piso. Se quiser ganhar mais, certifique-se e comece a cobrar serviços profissionais dos seus clientes. <strong>Você fica com 100% do que cobra do cliente</strong> — a SACS só cobra uma vez a taxa da certificação. Te certificamos, te entregamos o diploma e o badge oficial, e a partir daí você pode oferecer o serviço.' },

  'cert.fee.lbl':        { es: 'Cuota de certificación · pago único', en: 'Certification fee · one-time payment', fr: 'Frais de certification · paiement unique', it: 'Quota di certificazione · pagamento unico', pt: 'Taxa de certificação · pagamento único' },
  'cert.charge.lbl':     { es: 'Lo que cobras al cliente', en: 'What you charge the client', fr: 'Ce que vous facturez au client', it: 'Quanto fatturi al cliente', pt: 'Quanto você cobra do cliente' },
  'cert.keep.text':      { es: 'para ti — SACS no cobra comisión sobre lo que tú cobres al cliente.', en: 'for you — SACS doesn\'t take commission on what you charge the client.', fr: 'pour vous — SACS ne prend pas de commission sur ce que vous facturez au client.', it: 'per te — SACS non prende commissione su quello che fatturi al cliente.', pt: 'para você — a SACS não cobra comissão sobre o que você cobra do cliente.' },

  // Cert unlock 4 items
  'cert.u.eyebrow': { es: 'Cómo funciona', en: 'How it works', fr: 'Comment ça marche', it: 'Come funziona', pt: 'Como funciona' },
  'cert.u1.t': { es: 'Pagas una vez la certificación', en: 'You pay once for the certification', fr: 'Vous payez la certification une seule fois', it: 'Paghi una volta la certificazione', pt: 'Você paga a certificação uma só vez' },
  'cert.u1.d': { es: 'Cuota única que va de $7,500 a $21,000 MXN según el curso. Es la única vez que SACS te cobra por este programa de capacitación.', en: 'One-time fee from $7,500 to $21,000 MXN depending on the course. This is the only time SACS charges you for this training program.', fr: 'Frais uniques de 7 500 à 21 000 MXN selon le cours. C\'est la seule fois que SACS vous facture pour ce programme de formation.', it: 'Quota unica da $7.500 a $21.000 MXN a seconda del corso. È l\'unica volta che SACS ti addebita per questo programma di formazione.', pt: 'Taxa única de $7.500 a $21.000 MXN dependendo do curso. É a única vez que a SACS te cobra por este programa de capacitação.' },
  'cert.u2.t': { es: 'Te certificamos y entregamos diploma', en: 'We certify you and deliver the diploma', fr: 'Nous vous certifions et remettons le diplôme', it: 'Ti certifichiamo e ti consegniamo il diploma', pt: 'Te certificamos e entregamos diploma' },
  'cert.u2.d': { es: 'Sesiones en vivo, materiales y casos prácticos. Al aprobar el examen recibes tu diploma digital + badge oficial visible en tu portal y comunicación con clientes.', en: 'Live sessions, materials and case studies. Upon passing the exam you receive your digital diploma + official badge visible on your portal and client communications.', fr: 'Sessions en direct, supports et cas pratiques. À la réussite de l\'examen, vous recevez votre diplôme numérique + badge officiel visible sur votre portail et dans vos communications client.', it: 'Sessioni live, materiali e casi pratici. Dopo aver superato l\'esame ricevi il tuo diploma digitale + badge ufficiale visibile sul tuo portale e nelle comunicazioni con i clienti.', pt: 'Sessões ao vivo, materiais e casos práticos. Ao aprovar o exame você recebe seu diploma digital + badge oficial visível no seu portal e na comunicação com clientes.' },
  'cert.u3.t': { es: 'Empiezas a ofrecer el servicio', en: 'You start offering the service', fr: 'Vous commencez à proposer le service', it: 'Inizi a offrire il servizio', pt: 'Você começa a oferecer o serviço' },
  'cert.u3.d': { es: 'Con el badge de partner certificado puedes vender el servicio a tus propios clientes y a leads que SACS te asigna. Cobras por proyecto o retainer mensual según el caso.', en: 'With the certified partner badge you can sell the service to your own clients and to leads that SACS assigns you. Charge per project or monthly retainer depending on the case.', fr: 'Avec le badge de partenaire certifié vous pouvez vendre le service à vos propres clients et aux leads que SACS vous assigne. Facturez par projet ou en retainer mensuel selon le cas.', it: 'Con il badge di partner certificato puoi vendere il servizio ai tuoi clienti e ai lead che SACS ti assegna. Fatturi per progetto o retainer mensile secondo il caso.', pt: 'Com o badge de parceiro certificado você pode vender o serviço para seus próprios clientes e leads que a SACS te atribui. Cobra por projeto ou retainer mensal conforme o caso.' },
  'cert.u4.t': { es: 'Te quedas con el 100% de lo cobrado', en: 'You keep 100% of what you charge', fr: 'Vous gardez 100% de ce que vous facturez', it: 'Tieni il 100% di quanto fatturi', pt: 'Você fica com 100% do que cobra' },
  'cert.u4.d': { es: 'Lo que el cliente te paga por implementación, migración, automatización o consultoría es 100% para ti. Esto se suma a tus comisiones SACS por venta de licencias.', en: 'What the client pays you for implementation, migration, automation or consulting is 100% yours. This adds on top of your SACS commissions on license sales.', fr: 'Ce que le client vous paye pour implémentation, migration, automatisation ou conseil est 100% pour vous. Cela s\'ajoute à vos commissions SACS sur les ventes de licences.', it: 'Quello che il cliente ti paga per implementazione, migrazione, automazione o consulenza è il 100% tuo. Si somma alle tue commissioni SACS sulle vendite di licenze.', pt: 'O que o cliente te paga por implementação, migração, automação ou consultoria é 100% seu. Isso soma sobre suas comissões SACS por venda de licenças.' },
  'cert.cta.eyebrow': { es: 'Cuando estés listo', en: 'When you\'re ready', fr: 'Quand vous êtes prêt', it: 'Quando sei pronto', pt: 'Quando estiver pronto' },
  'cert.cta.body':    { es: 'Las certificaciones se ofrecen desde el panel de partners. No hay prisa — empieza cuando ya cerraste un par de clientes y quieras llevar tu rol al siguiente nivel.', en: 'Certifications are offered from the partners portal. No rush — start when you\'ve closed a couple of clients and want to take your role to the next level.', fr: 'Les certifications sont proposées depuis le portail partenaires. Pas de hâte — commencez quand vous avez conclu quelques clients et voulez passer au niveau supérieur.', it: 'Le certificazioni si offrono dal portale partner. Nessuna fretta — inizia quando hai chiuso un paio di clienti e vuoi portare il tuo ruolo al livello successivo.', pt: 'As certificações são oferecidas do portal de parceiros. Sem pressa — comece quando já tiver fechado alguns clientes e quiser levar seu papel ao próximo nível.' },

  // Comp tab section eyebrows + projection labels
  'comp.tab1.eyebrow': { es: '1 · Tabulador de recompensas', en: '1 · Reward fee schedule', fr: '1 · Grille de rémunération', it: '1 · Tariffario delle ricompense', pt: '1 · Tabela de recompensas' },
  'comp.tab1.lead':    { es: 'Dos fuentes de ingreso: lo que ganas por <strong>tus propias ventas</strong> y lo que ganas por las <strong>ventas de tu red</strong> cuando llegues a Master Partner.', en: 'Two income streams: what you earn from <strong>your own sales</strong> and what you earn from your <strong>network\'s sales</strong> once you reach Master Partner.', fr: 'Deux sources de revenus : ce que vous gagnez sur <strong>vos propres ventes</strong> et ce que vous gagnez sur les <strong>ventes de votre réseau</strong> une fois Master Partner.', it: 'Due fonti di reddito: ciò che guadagni dalle <strong>tue vendite</strong> e ciò che guadagni dalle <strong>vendite della tua rete</strong> una volta raggiunto Master Partner.', pt: 'Duas fontes de receita: o que você ganha por <strong>suas próprias vendas</strong> e o que ganha pelas <strong>vendas da sua rede</strong> ao chegar a Master Partner.' },
  'comp.payout.direct.name':   { es: 'Venta directa', en: 'Direct sale', fr: 'Vente directe', it: 'Vendita diretta', pt: 'Venda direta' },
  'comp.payout.direct.detail': { es: 'Comisión sobre el cobro de la primera factura de cada cliente cerrado por tu link único. Mientras el cliente siga activo, mantienes comisión recurrente sobre las renovaciones.', en: 'Commission on the first invoice of every client closed through your unique link. While the client stays active, you keep recurring commission on renewals.', fr: 'Commission sur la première facture de chaque client conclu via votre lien unique. Tant que le client reste actif, vous gardez la commission récurrente sur les renouvellements.', it: 'Commissione sulla prima fattura di ogni cliente chiuso tramite il tuo link unico. Finché il cliente resta attivo, mantieni la commissione ricorrente sui rinnovi.', pt: 'Comissão sobre a primeira nota fiscal de cada cliente fechado pelo seu link único. Enquanto o cliente seguir ativo, mantém comissão recorrente sobre as renovações.' },
  'comp.payout.override.step':   { es: 'Paso 2 · al ser Master Partner', en: 'Step 2 · once Master Partner', fr: 'Étape 2 · une fois Master Partner', it: 'Step 2 · da Master Partner', pt: 'Passo 2 · ao ser Master Partner' },
  'comp.payout.override.name':   { es: 'Comisión sobre tu red', en: 'Network override', fr: 'Override de votre réseau', it: 'Override sulla tua rete', pt: 'Override sobre sua rede' },
  'comp.payout.override.detail': { es: 'A partir de 5 sucursales activas vendidas (Master Partner Nv 1), desbloqueas un <strong>10% sobre todo lo que tu red de partners invitados venda</strong>. Pagado por SACS, sin descontar nada del 50% directo de tu invitado. Tu red escala — tu ingreso escala con ella.', en: 'From 5 active stores sold (Master Partner Nv 1), you unlock a <strong>10% on everything your invited partner network sells</strong>. Paid by SACS, with nothing deducted from your invitee\'s 50% direct. Your network scales — your income scales with it.', fr: 'À partir de 5 boutiques actives vendues (Master Partner Nv 1), vous débloquez un <strong>10% sur tout ce que vend votre réseau de partenaires invités</strong>. Payé par SACS, sans rien déduire des 50% directs de votre invité. Votre réseau grandit — vos revenus aussi.', it: 'A partire da 5 negozi attivi venduti (Master Partner Nv 1), sblocchi un <strong>10% su tutto ciò che vende la tua rete di partner invitati</strong>. Pagato da SACS, senza scalare nulla dal 50% diretto del tuo invitato. La tua rete cresce — il tuo reddito cresce con essa.', pt: 'A partir de 5 lojas ativas vendidas (Master Partner Nv 1), você desbloqueia um <strong>10% sobre tudo o que sua rede de parceiros convidados vende</strong>. Pago pela SACS, sem descontar nada dos 50% diretos do seu convidado. Sua rede escala — seu ingresso escala com ela.' },
  'comp.payout.override.cta':    { es: 'Ver detalles en "Expande tu red" →', en: 'See details in "Expand your network" →', fr: 'Voir détails dans « Étendez votre réseau » →', it: 'Vedi dettagli in "Espandi la tua rete" →', pt: 'Ver detalhes em "Expanda sua rede" →' },
  'comp.payout.shared.name': { es: 'Venta compartida (con apoyo de SACS)', en: 'Shared sale (with SACS support)', fr: 'Vente partagée (avec l\'appui de SACS)', it: 'Vendita condivisa (con supporto SACS)', pt: 'Venda compartilhada (com apoio da SACS)' },
  'comp.payout.shared.detail': { es: 'Cuando tienes el prospecto pero pides a un ejecutivo o consultor de SACS que te apoye en la reunión, cita o presentación para cerrar, ganas <strong>30% sobre la primera factura</strong> (en vez del 50% de la venta propia). La comisión recurrente por renovación se conserva igual. Ideal cuando quieres asegurar el cierre con respaldo del equipo.', en: 'When you have the prospect but ask a SACS executive or consultant to support you in the meeting, appointment or presentation to close, you earn <strong>30% on the first invoice</strong> (instead of 50% for an own sale). The recurring renewal commission stays the same. Ideal when you want to secure the close with the team\'s backing.', fr: 'Quand vous avez le prospect mais demandez à un cadre ou consultant de SACS de vous appuyer lors de la réunion, du rendez-vous ou de la présentation pour conclure, vous gagnez <strong>30% sur la première facture</strong> (au lieu de 50% pour une vente propre). La commission récurrente de renouvellement reste la même. Idéal pour sécuriser la conclusion avec le soutien de l\'équipe.', it: 'Quando hai il prospect ma chiedi a un dirigente o consulente di SACS di supportarti nella riunione, nell\'appuntamento o nella presentazione per chiudere, guadagni <strong>30% sulla prima fattura</strong> (invece del 50% della vendita propria). La commissione ricorrente di rinnovo resta uguale. Ideale quando vuoi assicurare la chiusura con il supporto del team.', pt: 'Quando você tem o prospecto mas pede a um executivo ou consultor da SACS que te apoie na reunião, visita ou apresentação para fechar, você ganha <strong>30% sobre a primeira fatura</strong> (em vez dos 50% da venda própria). A comissão recorrente de renovação permanece igual. Ideal quando quer garantir o fechamento com o respaldo do time.' },
  'comp.tab2.eyebrow': { es: '2 · Tu potencial', en: '2 · Your potential', fr: '2 · Votre potentiel', it: '2 · Il tuo potenziale', pt: '2 · Seu potencial' },
  'comp.tab2.lead':    { es: 'Cada cliente cerrado por tu link se traduce en tu 50% de comisión directa más recurrente. Estas son las matemáticas, basadas en tu porcentaje y los precios públicos de SACS.', en: 'Every client closed via your link translates to your 50% direct commission plus recurring. Here\'s the math, based on your percentage and SACS\' public prices.', fr: 'Chaque client conclu via votre lien se traduit par votre commission directe de 50% plus la récurrente. Voici les calculs, basés sur votre pourcentage et les prix publics de SACS.', it: 'Ogni cliente chiuso tramite il tuo link si traduce nella tua commissione diretta del 50% più ricorrente. Ecco la matematica, basata sulla tua percentuale e sui prezzi pubblici di SACS.', pt: 'Cada cliente fechado pelo seu link se traduz em sua comissão direta de 50% mais recorrente. Esta é a matemática, baseada no seu percentual e nos preços públicos da SACS.' },

