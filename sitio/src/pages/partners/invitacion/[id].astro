    .p-bw-vertical-body { padding: 22px 22px 26px; }
  }
  .p-bw-vertical-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.7rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    margin-bottom: 12px;
  }
  .p-bw-vertical-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent, #4B7BE5);
    flex-shrink: 0;
  }
  .p-bw-vertical-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: #1A1A1A;
    margin: 0 0 20px;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  @media (max-width: 720px) {
    .p-bw-vertical-name { font-size: 1.3125rem; margin-bottom: 16px; }
  }
  /* Módulos: lista elegante, no chips */
  .p-bw-vertical-modules {
    list-style: none;
    margin: 0 0 24px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .p-bw-vertical-module {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .p-bw-vertical-module-bullet {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent, #4B7BE5);
    margin-top: 9px;
    box-shadow: 0 0 0 3px var(--accent-bg, rgba(75, 123, 229, 0.12));
  }
  .p-bw-vertical-module-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
    flex: 1;
  }
  .p-bw-vertical-module-text strong {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1A1A1A;
    letter-spacing: -0.005em;
    line-height: 1.35;
  }
  .p-bw-vertical-module-text span {
    font-size: 0.8125rem;
    color: #666;
    line-height: 1.55;
  }
  .p-bw-vertical-foot {
    margin-top: auto;
    padding-top: 18px;
    font-size: 0.75rem;
    color: #999;
    font-weight: 500;
    letter-spacing: 0.005em;
    border-top: 1px solid #f0f0ee;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .p-bw-vertical-link {
    color: var(--accent, #4B7BE5);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.75rem;
    transition: opacity 0.18s;
  }
  .p-bw-vertical-link:hover { opacity: 0.7; }
  .p-bw-vertical-detail {
    font-size: 0.8125rem;
    color: #666;
    line-height: 1.5;
  }

  /* +70 más callout */
  .p-bw-verticals-more {
    margin-top: 28px;
    padding: 24px;
    background: linear-gradient(135deg, #FAFAF8 0%, #F4F4F2 100%);
    border: 1px dashed #d4d4d2;
    border-radius: 12px;
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }
  .p-bw-verticals-more-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #4B7BE5;
    color: #fff;
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 300;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .p-bw-verticals-more-body { flex: 1; }
  .p-bw-verticals-more-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: #1A1A1A;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .p-bw-verticals-more-text {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.6;
  }
  .p-bw-verticals-more-link {
    display: inline-block;
    margin-left: 6px;
    color: #4B7BE5;
    text-decoration: none;
    font-weight: 500;
  }
  .p-bw-verticals-more-link:hover { text-decoration: underline; }
  @media (max-width: 640px) {
    .p-bw-verticals-more {
      flex-direction: column;
      gap: 14px;
      padding: 20px;
    }
    .p-bw-verticals-more-icon { width: 40px; height: 40px; font-size: 1.5rem; }
  }

  /* Cases (clientes) */
  .p-bw-cases {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-top: 28px;
  }
  .p-bw-case {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 10px;
    overflow: hidden;
  }
  .p-bw-case-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
    background: #f5f5f5;
  }
  .p-bw-case-name {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1A1A1A;
    padding: 14px 16px 4px;
  }
  .p-bw-case-meta {
    font-size: 0.75rem;
    color: #888;
    padding: 0 16px 16px;
  }

  /* History (dark section) */
  .p-bw-history-img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    display: block;
  }
  .p-bw-history-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,0.12);
  }
  .p-bw-history-stat-num {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 3vw, 2.125rem);
    font-weight: 300;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 6px;
  }
  .p-bw-history-stat-label {
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.55);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  /* ─── Visión 1,000 embajadores ─── */
  .p-bw-vision {
    margin: 56px 0 0;
    padding: 64px 32px;
    background: linear-gradient(135deg, #4B7BE5 0%, #6C5CE7 50%, #1A1A1A 100%);
    border-radius: 16px;
    color: #fff;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .p-bw-vision::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 20%, rgba(255,255,255,0.10), transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(255,255,255,0.06), transparent 50%);
    pointer-events: none;
  }
  .p-bw-vision > * { position: relative; z-index: 1; }
  .p-bw-vision-eyebrow {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(255,255,255,0.14);
    color: rgba(255,255,255,0.92);
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .p-bw-vision-title {
    font-family: var(--font-display);
    margin: 0 0 20px;
    color: #fff;
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .p-bw-vision-num {
    display: block;
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 200;
    background: linear-gradient(120deg, #fff 0%, #B5D0FF 60%, #B49EFF 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .p-bw-vision-after {
    display: block;
    font-size: clamp(1.25rem, 2.6vw, 1.875rem);
    font-weight: 400;
    color: rgba(255,255,255,0.85);
    margin-top: 8px;
  }
  .p-bw-vision-lead {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: rgba(255,255,255,0.78);
    max-width: 580px;
    margin: 0 auto 36px;
    font-weight: 300;
  }

  .p-bw-tracker {
    max-width: 620px;
    margin: 0 auto;
    padding: 24px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px;
    backdrop-filter: blur(8px);
  }
  .p-bw-tracker-row {
    display: grid;
    grid-template-columns: 160px 1fr 100px;
    gap: 14px;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .p-bw-tracker-row:last-child { border-bottom: none; }
  .p-bw-tracker-row--soon { opacity: 0.55; }
  .p-bw-tracker-label {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.85);
    font-weight: 500;
    text-align: left;
  }
  .p-bw-tracker-bar {
    height: 8px;
    background: rgba(255,255,255,0.10);
    border-radius: 999px;
    overflow: hidden;
  }
  .p-bw-tracker-fill {
    height: 100%;
    background: linear-gradient(90deg, #6CD6C2 0%, #4B7BE5 100%);
    border-radius: 999px;
    transition: width 0.6s ease-out;
  }
  .p-bw-tracker-stat {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.75);
    text-align: right;
    font-family: var(--font-display);
  }
  .p-bw-tracker-stat strong { color: #fff; font-weight: 600; font-size: 1rem; }

  /* Group label dentro del tracker */
  .p-bw-tracker-group {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    padding: 14px 0 6px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 4px;
  }
  .p-bw-tracker-group:first-child { padding-top: 0; }

  /* Total row */
  .p-bw-tracker-total {
    margin-top: 18px;
    padding: 16px 18px;
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 10px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
  }
  .p-bw-tracker-total-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
  }
  .p-bw-tracker-total-num {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: #fff;
    font-weight: 500;
  }
  .p-bw-tracker-total-num strong {
    font-size: 1.75rem;
    font-weight: 600;
    color: #fff;
    margin-right: 4px;
  }
  .p-bw-tracker-total-num span {
    color: rgba(255,255,255,0.7);
    font-size: 0.875rem;
  }

  @media (max-width: 640px) {
    .p-bw-vision { margin: 32px 0 0; padding: 48px 20px; }
    .p-bw-tracker { padding: 18px; }
    .p-bw-tracker-row { grid-template-columns: 1fr; gap: 6px; padding: 12px 0; }
    .p-bw-tracker-stat { text-align: left; }
    .p-bw-tracker-total { flex-direction: column; align-items: flex-start; gap: 4px; }
    .p-bw-tracker-total-num { font-size: 1rem; }
    .p-bw-tracker-total-num strong { font-size: 1.5rem; }
  }

  /* ─── 10% para impacto ─── */
  .p-bw-impact {
    margin: 32px 0 0;
    padding: 72px 56px;
    background: linear-gradient(180deg, #FAFAF8 0%, #fff 100%);
    border: 1px solid #ececec;
    border-radius: 16px;
    text-align: center;
  }
  @media (max-width: 768px) {
    .p-bw-impact { padding: 48px 24px; }
  }
  .p-bw-impact-eyebrow {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(42,181,160,0.12);
    color: #1A8F7A;
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .p-bw-impact-title {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 3.2vw, 2.375rem);
    font-weight: 400;
    color: #1A1A1A;
    margin: 0 auto 24px;
    letter-spacing: -0.02em;
    line-height: 1.2;
    max-width: 720px;
  }
  .p-bw-impact-lead {
    font-size: 1rem;
    color: #555;
    line-height: 1.7;
    margin: 0 auto 18px;
    max-width: 640px;
  }
  .p-bw-impact-lead strong { color: #1A1A1A; font-weight: 600; }
  @media (max-width: 768px) {
    .p-bw-impact-lead { font-size: 0.9375rem; }
  }

  /* CTA final */
  .p-bw-cta {
    margin-top: 48px;
    padding: 48px 32px;
    background: linear-gradient(120deg, rgba(75,123,229,0.06), rgba(108,92,231,0.04));
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 14px;
    text-align: center;
  }
  .p-bw-cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.4vw, 1.625rem);
    font-weight: 500;
    color: #1A1A1A;
    margin: 0 0 12px;
    letter-spacing: -0.015em;
  }
  .p-bw-cta-lead {
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.55;
    max-width: 460px;
    margin: 0 auto 22px;
  }
  .p-bw-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 26px;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 8px;
    font-size: 0.9375rem;
    font-weight: 600;
    transition: background 0.15s;
  }
  .p-bw-cta-btn:hover { background: #4B7BE5; }

  /* ─── Contenido y puntos (tab "Contenido") ─────────────────── */
  .p-content-howto {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
    margin: 32px 0;
  }
  .p-content-howto-item {
    display: flex; gap: 14px;
    padding: 18px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 10px;
  }
  .p-content-howto-num {
    flex-shrink: 0;
    width: 30px; height: 30px;
    border-radius: 50%;
    background: #fff;
    color: #4B7BE5;
    border: 1px solid #4B7BE5;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.875rem;
  }
  .p-content-howto-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 4px;
    letter-spacing: -0.005em;
  }
  .p-content-howto-detail {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.55;
    margin: 0;
  }

  .p-content-h3 {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.4vw, 1.625rem);
    font-weight: 500;
    color: #1A1A1A;
    margin: 48px 0 18px;
    letter-spacing: -0.015em;
  }

  .p-content-types-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    margin-bottom: 36px;
  }
  .p-content-type-card {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 12px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.18s;
  }
  .p-content-type-card:hover { border-color: #cfd6e2; }
  .p-content-type-card--bonus {
    background: linear-gradient(180deg, rgba(75,123,229,0.04), #fff);
    border-color: #4B7BE5;
  }
  .p-content-type-img-wrap {
    margin: -20px -20px 16px;
    height: 160px;
    overflow: hidden;
    border-radius: 12px 12px 0 0;
    background: #f5f5f5;
  }
  .p-content-type-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .p-content-type-head {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid #f0f0f0;
  }
  .p-content-type-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1A1A1A;
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }
  .p-content-type-meta {
    font-size: 0.6875rem;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .p-content-type-pts {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 300;
    color: #4B7BE5;
    letter-spacing: -0.02em;
    line-height: 1;
    flex-shrink: 0;
  }
  .p-content-type-pts span {
    font-size: 0.75rem;
    color: #999;
    margin-left: 2px;
    font-weight: 400;
  }
  .p-content-type-desc {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.55;
    margin: 0;
  }
  .p-content-type-ideas-label {
    font-size: 0.625rem;
    font-weight: 700;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    margin-bottom: 4px;
  }
  .p-content-type-ideas ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .p-content-type-ideas li {
    position: relative;
    padding-left: 14px;
    font-size: 0.8125rem;
    color: #666;
    line-height: 1.45;
  }
  .p-content-type-ideas li::before {
    content: '·';
    position: absolute;
    left: 4px;
    color: #4B7BE5;
    font-weight: 700;
  }
  .p-content-type-platforms {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding-top: 8px;
    border-top: 1px solid #f5f5f5;
  }
  .p-content-type-platform {
    font-size: 0.6875rem;
    padding: 3px 9px;
    background: #f5f5f7;
    color: #666;
    border-radius: 999px;
    font-weight: 500;
  }
  .p-content-type-refs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    font-size: 0.75rem;
    color: #888;
  }
  .p-content-type-refs-label {
    font-weight: 600;
  }
  .p-content-type-ref {
    color: #4B7BE5;
    text-decoration: none;
  }
  .p-content-type-ref:hover { text-decoration: underline; }

  .p-content-notes {
    margin-top: 20px;
    padding: 24px;
    background: #FAFAF8;
    border: 1px solid #ececec;
    border-radius: 12px;
  }
  .p-content-notes-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 12px;
    letter-spacing: -0.005em;
  }
  .p-content-notes ul {
    margin: 0;
    padding-left: 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .p-content-notes li {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.55;
  }
  .p-content-notes li strong { color: #1a1a1a; }

  /* ─── Proceso (Cómo funciona) ─────────────────────── */
  .p-proc-steps {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 32px;
  }
  .p-proc-step {
    display: flex;
    gap: 18px;
    padding: 22px 24px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 14px;
    transition: border-color 0.18s, transform 0.18s;
  }
  .p-proc-step:hover {
    border-color: #cfd6e2;
    transform: translateY(-1px);
  }
  .p-proc-step-num {
    flex-shrink: 0;
    width: 38px; height: 38px;
    border-radius: 50%;
    background: #1a1a1a;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1rem;
  }
  .p-proc-step-body {
    flex: 1;
    min-width: 0;
  }
  .p-proc-step-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .p-proc-step-detail {
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.6;
    margin: 0 0 10px;
  }
  .p-proc-step-detail strong { color: #1a1a1a; font-weight: 700; }
  .p-proc-step-detail code {
    background: #f5f5f7;
    padding: 1px 6px;
    border-radius: 4px;
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 0.8125rem;
    color: #4B7BE5;
  }
  .p-proc-step-meta {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .p-proc-meta-pill {
    display: inline-block;
    padding: 4px 10px;
    background: rgba(75,123,229,0.10);
    color: #3764c4;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: 999px;
  }
  .p-proc-meta-pill--alt {
    background: rgba(42,181,160,0.10);
    color: #1A8F7A;
  }
  .p-proc-preview-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 6px;
    padding: 10px 16px;
    background: #1a1a1a;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .p-proc-preview-btn:hover { background: #4B7BE5; }

  .p-proc-cta {
    margin-top: 36px;
    text-align: center;
    padding: 28px;
    background: linear-gradient(120deg, rgba(75,123,229,0.06), rgba(108,92,231,0.04));
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 16px;
  }
  .p-proc-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 26px;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9375rem;
    transition: background 0.15s;
  }
  .p-proc-cta-btn:hover { background: #4B7BE5; }
  .p-proc-cta-arrow { font-size: 1.125rem; }

  @media (max-width: 640px) {
    .p-proc-step { padding: 18px 16px; gap: 14px; }
    .p-proc-step-num { width: 32px; height: 32px; font-size: 0.875rem; }
    .p-proc-step-title { font-size: 1rem; }
    .p-proc-step-detail { font-size: 0.875rem; }
  }

  /* ═══════════════════════════════════════════════════
     PREVIEW PORTAL · full-screen + 6 tabs navegables
     ═══════════════════════════════════════════════════ */
  .p-preview-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15,15,20,0.85);
    z-index: 9999;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .pp-app {
    min-height: 100vh;
    background: #f5f6f8;
    font-family: var(--font-body);
    color: #1a1a1a;
    display: flex;
    flex-direction: column;
  }

  /* Topbar */
  .pp-app-topbar {
    background: #fff;
    border-bottom: 1px solid #ececec;
    padding: 12px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .pp-app-topbar-left { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .pp-app-brand {
    font-family: 'Clash Display', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a1a;
    letter-spacing: -0.02em;
  }
  .pp-app-sep { color: #ccc; }
  .pp-app-subtitle { color: #888; font-size: 0.875rem; font-weight: 500; }
  .pp-app-preview-pill {
    margin-left: 6px;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #4B7BE5;
    background: rgba(75,123,229,0.10);
    padding: 4px 10px;
    border-radius: 999px;
  }
  .pp-app-topbar-right { display: flex; align-items: center; gap: 12px; }
  .pp-app-username { font-size: 0.875rem; color: #444; font-weight: 500; }
  .pp-app-avatar {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: linear-gradient(135deg, #4B7BE5, #6C5CE7);
    color: #fff;
    font-size: 0.8125rem;
    font-weight: 600;
    display: flex; align-items: center; justify-content: center;
  }
  .pp-app-close {
    background: #1a1a1a;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 8px 14px;
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .pp-app-close:hover { background: #000; }

  /* Body: sidebar + main */
  .pp-app-body { display: flex; flex: 1; min-height: 0; }

  /* Sidebar */
  .pp-app-sidebar {
    width: 240px;
    background: #fff;
    border-right: 1px solid #ececec;
    padding: 18px 14px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex-shrink: 0;
  }
  .pp-app-nav {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-radius: 8px;
    font-size: 0.875rem;
    color: #555;
    font-weight: 500;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.15s, color 0.15s;
    text-decoration: none;
    font-family: inherit;
    width: 100%;
  }
  .pp-app-nav:hover { background: #f5f5f7; color: #1a1a1a; }
  .pp-app-nav--active { background: #1a1a1a; color: #fff; }
  .pp-app-nav--active:hover { background: #1a1a1a; color: #fff; }
  .pp-app-nav-badge {
    margin-left: auto;
    background: #f0f0ee;
    color: #888;
    font-size: 0.6875rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 999px;
    font-style: normal;
  }
  .pp-app-nav--active .pp-app-nav-badge { background: rgba(255,255,255,0.18); color: #fff; }
  .pp-app-nav-ext { margin-left: auto; color: #4B7BE5; font-size: 0.75rem; }
  .pp-app-nav--external { color: #4B7BE5; }
  .pp-app-side-divider {
    height: 1px; background: #ececec; margin: 12px 4px;
  }
  .pp-app-sidebar-foot {
    margin-top: auto;
    padding: 14px;
    border-top: 1px solid #f0f0ee;
    background: #fafafa;
    border-radius: 8px;
  }
  .pp-app-foot-name { font-size: 0.875rem; font-weight: 600; color: #1a1a1a; }
  .pp-app-foot-meta { font-size: 0.75rem; color: #888; margin-top: 2px; }

  /* Main */
  .pp-app-main {
    flex: 1;
    padding: 32px 40px;
    overflow-y: auto;
    min-width: 0;
  }
  .pp-app-panel { display: none; }
  .pp-app-panel--active { display: block; }

  /* Tutorial banner */
  .pp-tut {
    display: flex;
    gap: 14px;
    padding: 16px 20px;
    background: linear-gradient(135deg, rgba(75,123,229,0.06), rgba(108,92,231,0.04));
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 12px;
    margin-bottom: 24px;
    align-items: flex-start;
  }
  .pp-tut-icon {
    flex-shrink: 0;
    font-size: 1.25rem;
    line-height: 1.4;
  }
  .pp-tut-body {
    font-size: 0.875rem;
    color: #444;
    line-height: 1.6;
  }
  .pp-tut-body strong { color: #1a1a1a; font-weight: 600; }
  .pp-tut-body em.pp-tag { font-size: 0.625rem; padding: 2px 8px; }

  /* Headings inside portal */
  .pp-h1 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 4px;
    letter-spacing: -0.02em;
  }
  .pp-lead { font-size: 0.9375rem; color: #666; margin-bottom: 28px; }
  .pp-h2 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 32px 0 14px;
    letter-spacing: -0.01em;
  }
  .pp-h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 12px;
    letter-spacing: -0.005em;
  }

  /* KPI row + cards */
  .pp-kpi-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-bottom: 16px;
  }
  .pp-kpi-row--3 { grid-template-columns: repeat(3, 1fr); }
  .pp-kpi {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 12px;
    padding: 18px 18px 16px;
    border-left: 3px solid var(--accent, #ececec);
  }
  .pp-kpi-lbl {
    font-size: 0.625rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .pp-kpi-val {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1.05;
    letter-spacing: -0.025em;
  }
  .pp-kpi-hint {
    font-size: 0.75rem;
    color: #888;
    margin-top: 6px;
  }

  /* Annotation note */
  .pp-note {
    margin: 14px 0 24px;
    padding: 14px 18px;
    background: #fafaf8;
    border-left: 3px solid #4B7BE5;
    border-radius: 0 8px 8px 0;
    font-size: 0.8125rem;
    color: #555;
    line-height: 1.6;
  }
  .pp-note strong { color: #1a1a1a; }
  .pp-note--inline {
    margin: 12px 0 0;
    font-size: 0.75rem;
    padding: 10px 12px;
  }

  /* Tables */
  .pp-table {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 12px;
    overflow: hidden;
    font-size: 0.875rem;
  }
  .pp-trow {
    display: grid;
    grid-template-columns: 2fr 1fr 1.2fr 1fr;
    gap: 14px;
    padding: 14px 18px;
    border-bottom: 1px solid #f5f5f5;
    align-items: center;
  }
  .pp-table--5col .pp-trow {
    grid-template-columns: 1.2fr 1.5fr 1.4fr 1fr 0.8fr;
  }
  .pp-trow:last-child { border-bottom: none; }
  .pp-trow--head {
    font-size: 0.625rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    background: #fafafa;
  }
  .pp-trow--cancelled { opacity: 0.5; text-decoration: line-through; }
  .pp-trow--cancelled em.pp-tag { text-decoration: none; opacity: 1; }
  .pp-cell-meta {
    font-size: 0.75rem;
    color: #888;
    font-style: normal;
  }
  .pp-tag {
    display: inline-block;
    padding: 3px 9px;
    background: #f5f5f7;
    color: #666;
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-style: normal;
    line-height: 1.4;
  }
  .pp-tag--ok    { background: rgba(42,181,160,0.14); color: #1A8F7A; }
  .pp-tag--blue  { background: rgba(75,123,229,0.14); color: #3764c4; }
  .pp-tag--amber { background: rgba(232,168,56,0.16); color: #b07b15; }
  .pp-tag--err   { background: rgba(220,38,38,0.12); color: #c62828; }
  .pp-link { color: #4B7BE5; font-size: 0.875rem; font-weight: 500; text-decoration: none; display: inline-block; margin-top: 14px; }
  .pp-link:hover { text-decoration: underline; }

  /* Bars (top fuentes) */
  .pp-bars { display: flex; flex-direction: column; gap: 10px; }
  .pp-bar {
    display: grid;
    grid-template-columns: 2fr 3fr 80px;
    gap: 14px;
    align-items: center;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 10px;
    padding: 12px 16px;
  }
  .pp-bar-lbl { font-size: 0.875rem; color: #1a1a1a; font-weight: 500; }
  .pp-bar-fill {
    height: 8px;
    background: #f0f0ee;
    border-radius: 999px;
    position: relative;
    overflow: hidden;
  }
  .pp-bar-fill::after {
    content: '';
    position: absolute;
    inset: 0;
    width: var(--w, 0);
    background: linear-gradient(90deg, #6CD6C2 0%, #4B7BE5 100%);
    border-radius: 999px;
  }
  .pp-bar-num { font-size: 0.875rem; color: #555; text-align: right; font-weight: 600; }

  /* Filters */
  .pp-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
    align-items: center;
  }
  .pp-filter {
    padding: 6px 12px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 8px;
    font-size: 0.8125rem;
    color: #666;
    font-weight: 500;
    cursor: pointer;
  }
  .pp-filter--active { background: #1a1a1a; color: #fff; border-color: #1a1a1a; }
  .pp-filter-sep { width: 1px; height: 20px; background: #ececec; margin: 0 4px; }
  .pp-foot-stats {
    margin-top: 18px;
    padding: 12px 16px;
    background: #fafafa;
    border-radius: 8px;
    font-size: 0.8125rem;
    color: #555;
  }
  .pp-foot-stats strong { color: #1a1a1a; }

  /* Payouts */
  .pp-payout {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 12px;
    padding: 18px 22px;
    margin-bottom: 12px;
  }
  .pp-payout--next {
    background: linear-gradient(135deg, rgba(75,123,229,0.06), rgba(42,181,160,0.04));
    border-color: rgba(75,123,229,0.25);
  }
  .pp-payout-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 10px;
  }
  .pp-payout-eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .pp-payout-date {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: #1a1a1a;
    letter-spacing: -0.005em;
  }
  .pp-payout-ref { font-size: 0.75rem; color: #999; margin-top: 2px; font-family: 'Courier New', monospace; }
  .pp-payout-amount {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 600;
    color: #1A8F7A;
    letter-spacing: -0.02em;
  }
  .pp-payout--next .pp-payout-amount { color: #4B7BE5; }
  .pp-payout-detail { font-size: 0.875rem; color: #666; }
  .pp-payout-detail summary { cursor: pointer; color: #4B7BE5; font-weight: 500; }
  .pp-payout-list {
    list-style: none;
    margin: 12px 0 0;
    padding: 12px 14px;
    background: #fafafa;
    border-radius: 8px;
  }
  .pp-payout-list li {
    display: flex;
    justify-content: space-between;
    padding: 6px 0;
    border-bottom: 1px dashed #ececec;
    font-size: 0.8125rem;
    color: #444;
    gap: 12px;
  }
  .pp-payout-list li:last-child { border-bottom: none; }

  /* Funnel */
  .pp-funnel {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .pp-funnel-step {
    flex: 1;
    min-width: 120px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 12px;
    padding: 14px 12px;
    text-align: center;
  }
  .pp-funnel-step--win {
    background: linear-gradient(135deg, rgba(42,181,160,0.10), rgba(75,123,229,0.06));
    border-color: rgba(42,181,160,0.30);
  }
  .pp-funnel-num {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1;
    letter-spacing: -0.025em;
  }
  .pp-funnel-step--win .pp-funnel-num { color: #1A8F7A; }
  .pp-funnel-lbl {
    font-size: 0.6875rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
    margin-top: 6px;
  }
  .pp-funnel-arrow { color: #ccc; font-size: 1.25rem; }

  /* Mi link tab */
  .pp-link-card {
    background: #1a1a1a;
    color: #fff;
    border-radius: 14px;
    padding: 22px 24px;
    margin-bottom: 28px;
  }
  .pp-link-url {
    font-family: 'Courier New', monospace;
    font-size: 1rem;
    margin-bottom: 14px;
    word-break: break-all;
  }
  .pp-link-url-protocol { color: rgba(255,255,255,0.5); }
  .pp-link-url-path { color: #fff; }
  .pp-link-url-path strong { color: #6CD6C2; font-weight: 700; }
  .pp-link-actions { display: flex; gap: 8px; flex-wrap: wrap; }

  .pp-link-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 20px;
    margin-bottom: 28px;
  }
  .pp-link-block {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 12px;
    padding: 20px;
  }
  .pp-share-row { display: flex; flex-wrap: wrap; gap: 8px; }
  .pp-share {
    background: #fafafa;
    border: 1px solid #ececec;
    color: #1a1a1a;
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .pp-share:hover { background: #f0f0ee; }
  .pp-qr {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 8px;
    padding: 16px;
    aspect-ratio: 1;
    max-width: 220px;
    margin: 0 auto;
  }
  .pp-qr-pattern {
    width: 100%; height: 100%;
    position: relative;
    background:
      linear-gradient(90deg, #1a1a1a 50%, transparent 50%),
      linear-gradient(0deg, #1a1a1a 50%, transparent 50%),
      #fff;
    background-size: 12px 12px;
    background-blend-mode: multiply;
  }
  .pp-qr-eye {
    position: absolute;
    width: 38px; height: 38px;
    background: #1a1a1a;
    border: 6px solid #fff;
    box-shadow: inset 0 0 0 4px #1a1a1a, inset 0 0 0 8px #fff, inset 0 0 0 13px #1a1a1a;
  }
  .pp-qr-eye--tl { top: 0; left: 0; }
  .pp-qr-eye--tr { top: 0; right: 0; }
  .pp-qr-eye--bl { bottom: 0; left: 0; }

  .pp-templates {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  .pp-template {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 12px;
    padding: 16px 18px;
  }
  .pp-template-head {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 10px;
  }
  .pp-template-body {
    background: #fafaf8;
    border: 1px solid #f0f0ee;
    border-radius: 8px;
    padding: 12px 14px;
    font-size: 0.8125rem;
    color: #555;
    line-height: 1.55;
    margin-bottom: 12px;
  }

  /* Mi perfil tab */
  .pp-perfil-section {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 12px;
    padding: 24px 26px;
    margin-bottom: 18px;
  }
  .pp-perfil-section--highlight {
    background: linear-gradient(135deg, rgba(42,181,160,0.06), rgba(75,123,229,0.04));
    border-color: rgba(42,181,160,0.25);
  }
  .pp-section-sub {
    font-size: 0.8125rem;
    color: #888;
    margin: -8px 0 16px;
  }
  .pp-form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .pp-field { display: flex; flex-direction: column; gap: 5px; }
  .pp-field--full { grid-column: 1 / -1; }
  .pp-field > span {
    font-size: 0.6875rem;
    font-weight: 600;
    color: #888;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .pp-field input,
  .pp-field select {
    padding: 11px 14px;
    font-family: inherit;
    font-size: 0.875rem;
    color: #1a1a1a;
    border: 1px solid #ececec;
    border-radius: 8px;
    background: #fafaf8;
    outline: none;
  }
  .pp-field input:focus,
  .pp-field select:focus { border-color: #4B7BE5; background: #fff; }
  .pp-field input[readOnly] { color: #555; }

  /* Payout method radios (in perfil) */
  .pp-payout-methods {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .pp-method {
    display: flex;
    gap: 14px;
    padding: 16px 18px;
    border: 1.5px solid #ececec;
    border-radius: 10px;
    background: #fafafa;
    cursor: pointer;
    align-items: flex-start;
  }
  .pp-method--active { border-color: #1a1a1a; background: #fff; }
  .pp-method input[type="radio"] {
    margin-top: 2px;
    accent-color: #1a1a1a;
    flex-shrink: 0;
  }
  .pp-method-body { flex: 1; }
  .pp-method-head {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .pp-method-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .pp-method-note {
    grid-column: 1 / -1;
    font-size: 0.75rem;
    color: #888;
    margin: 4px 0 0;
  }

  .pp-firma-display {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 18px;
    align-items: center;
  }
  .pp-firma-box {
    border: 1px solid #ececec;
    border-radius: 8px;
    padding: 14px;
    background: #fafaf8;
  }
  .pp-firma-meta {
    font-size: 0.8125rem;
    color: #555;
    line-height: 1.7;
  }
  .pp-firma-meta strong { color: #1a1a1a; font-weight: 600; }
  .pp-firma-meta a { display: inline-block; margin-top: 8px; }

  .pp-fideliza-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    background: rgba(255,255,255,0.7);
    border-radius: 10px;
    margin-top: 4px;
  }
  .pp-fideliza-status {
    font-family: var(--font-display);
    font-weight: 600;
    color: #1A8F7A;
    margin-bottom: 4px;
  }
  .pp-fideliza-renew { font-size: 0.8125rem; color: #666; }

  /* Buttons inside portal */
  .pp-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px 16px;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    text-decoration: none;
  }
  .pp-btn--primary { background: #fff; color: #1a1a1a; }
  .pp-link-card .pp-btn--primary { background: #6CD6C2; color: #1a1a1a; }
  .pp-link-card .pp-btn--primary:hover { background: #5fc4b1; }
  .pp-btn--ghost { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.25); }
  .pp-perfil-section .pp-btn--primary { background: #1a1a1a; color: #fff; }
  .pp-perfil-section .pp-btn--ghost { background: #fafafa; color: #1a1a1a; border: 1px solid #ececec; }

  /* Mobile */
  @media (max-width: 980px) {
    .pp-app-sidebar { width: 200px; padding: 14px 8px; }
    .pp-app-main { padding: 24px 24px; }
    .pp-app-nav { font-size: 0.8125rem; padding: 8px 10px; }
    .pp-kpi-row { grid-template-columns: 1fr 1fr; }
    .pp-kpi-row--3 { grid-template-columns: 1fr 1fr; }
    .pp-link-grid { grid-template-columns: 1fr; }
