// Resumen accionable "Pagas → Recibes → Ganas" (claridad arriba del documento).
const flowPay = (escalonadoOn && escTiers.length > 0)
  ? tt('flow.pay.from').split('{m}').join(fmtMoney(escTiers[0].price))
  : esDeCobro
    ? tt('flow.pay.once').split('{m}').join(costoEntradaStr)
    : tt('flow.pay.free');
const flowGet = escalonadoOn ? tt('flow.get.esc') : tt('flow.get.std');
const flowEarn = (escalonadoOn && escBest)
  ? tt('flow.earn.esc').split('{m}').join(fmtMoney(escBest.netProfit))
  : tt('flow.earn.std').split('{pct}').join(String(comisionPct));

const isAccepted = invitation.estado === 'accepted';
const isDeclined = invitation.estado === 'declined' || invitation.estado === 'cancelled';
const isCancelled = invitation.estado === 'cancelled';
const CANCEL_T: Record<string, { eyebrow: string; title: string; sub: string }> = {
