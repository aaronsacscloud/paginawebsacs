                .split('{perPartner}').join(String(ex.storesPerPartner))
                .split('{gross}').join(ex.grossStr);
              return (
                <article class={`p-network-ex-card p-network-ex-card--${i + 1}${i === 3 ? ' p-network-ex-card--builder' : ''}`}>
                  <div class="p-network-ex-head">
                    <span class="p-network-ex-num">0{i + 1}</span>
                    <span class="p-network-ex-tier">{ex.suffix}</span>
                  </div>
                  <div class="p-network-ex-partners">
                    <span class="p-network-ex-partners-num">{ex.partners}{i === 3 ? '+' : ''}</span>
                    <span class="p-network-ex-partners-lbl">{tt('red.ex.partners')}</span>
                  </div>
                  <div class="p-network-ex-amount">
                    <span class="p-network-ex-amount-num">{ex.annualStr}</span>
                    <span class="p-network-ex-amount-period">{tt('red.ex.year')}</span>
                  </div>
                  <div class="p-network-ex-monthly">≈ {ex.monthlyStr} {tt('red.ex.month')} {tt('red.ex.suffix')}</div>
                  <p class="p-network-ex-detail" set:html={detail}></p>
                </article>
              );
            })}
          </div>

          <p class="p-network-ex-legal">{tt('red.ex.legal')}</p>
        </div>

        {/* ── #10 Storyboard de invitación ── */}
        <div class="p-network-story">
          <div class="p-section-eyebrow">{tt('red.story.eyebrow')}</div>
          <h3 class="p-network-how-title" style="margin-bottom:24px">{tt('red.story.title')}</h3>
          <div class="p-network-story-grid">
            {[
              { img: 'red-story-1', lbl: 's1.lbl', cap: 's1.cap' },
              { img: 'red-story-2', lbl: 's2.lbl', cap: 's2.cap' },
              { img: 'red-story-3', lbl: 's3.lbl', cap: 's3.cap' },
            ].map(s => (
              <figure class="p-network-story-fig">
                <img src={`/images/network-expansion/${s.img}.webp`} alt={tt(`red.story.${s.lbl}`)} loading="lazy" width="1200" height="800" />
                <figcaption>
                  <span class="p-network-story-lbl">{tt(`red.story.${s.lbl}`)}</span>
                  <span class="p-network-story-cap">{tt(`red.story.${s.cap}`)}</span>
                </figcaption>
              </figure>
            ))}
          </div>
        </div>

        {/* ── #4 Closing wide arriba del CTA dorado ── */}
        <div class="p-network-closing">
          <img src="/images/network-expansion/red-closing.webp" alt="" loading="lazy" width="1600" height="900" />
        </div>

        <div class="p-cert-readiness" style="margin-top:24px">
          <svg class="p-cert-readiness-seal" width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="22" cy="22" r="20.5" stroke="#c9a96b" stroke-width="0.75" opacity="0.6"/>
            <circle cx="22" cy="22" r="16" stroke="#c9a96b" stroke-width="0.5" opacity="0.4"/>
            <text x="22" y="27" text-anchor="middle" font-family="Georgia, serif" font-size="14" font-style="italic" fill="#c9a96b" letter-spacing="-0.02em">N</text>
          </svg>
          <div class="p-cert-readiness-rule"></div>
          <span class="p-cert-readiness-eyebrow">{tt('red.cta.eyebrow')}</span>
          <p class="p-cert-readiness-body">{tt('red.cta.body')}</p>
        </div>
      </section>


      <!-- TAB: FIRMA -->
      <section id="firma" class={`p-tab-panel${initialTab === 'firma' ? ' is-active' : ''}`} data-tab="firma">
        {isAccepted ? (
          <div class="p-cert-wrap">
            <div class="p-cert-actions">
              <button type="button" class="p-cert-btn p-cert-btn--primary" id="btn-cert-print" title="Descargar como PDF (Cmd+P → Guardar como PDF)">Descargar certificado</button>
              <a href="/partner/portal" class="p-cert-btn p-cert-btn--secondary">Entrar al portal de partners →</a>
            </div>

            <div class="p-cert" id="partner-certificate">
              <div class="p-cert-border">
                <div class="p-cert-header">
                  <div class="p-cert-brand">Sacs</div>
                  <div class="p-cert-program">Programa Partners</div>
                </div>

                <div class="p-cert-body">
                  <div class="p-cert-eyebrow">Certificado de</div>
                  <div class="p-cert-title">{tipoLabel[tipo] || 'Embajador'} SACS</div>
                  <div class="p-cert-divider"></div>
                  <div class="p-cert-otorgado">Se otorga a</div>
                  <div class="p-cert-name">{invitation.aceptado_por || invitation.nombre}</div>
                  <div class="p-cert-statement">
                    Por su compromiso con la transformación del comercio y por
                    haber sido formalmente aceptado en el programa
                    <strong> {tipoLabel[tipo] || 'Embajador'} SACS</strong>,
                    contando con todos los beneficios, derechos y responsabilidades
                    establecidos en el acuerdo firmado.
                  </div>
                </div>

                <div class="p-cert-footer">
                  <div class="p-cert-meta">
                    <div class="p-cert-meta-block">
                      <div class="p-cert-meta-lbl">Folio</div>
                      <div class="p-cert-meta-val">{invitation.numero || 'PA-XXX'}</div>
                    </div>
                    <div class="p-cert-meta-block">
                      <div class="p-cert-meta-lbl">Fecha de aprobación</div>
                      <div class="p-cert-meta-val">{fmtDate(invitation.aceptado_fecha) || '—'}</div>
                    </div>
                    <div class="p-cert-meta-block">
                      <div class="p-cert-meta-lbl">Comisión</div>
                      <div class="p-cert-meta-val">{comisionPct}%</div>
                    </div>
                  </div>
                  <div class="p-cert-signatures">
                    {meta.firma_base64 && (
                      <div class="p-cert-sig">
                        <img src={meta.firma_base64} alt="Firma del partner" class="p-cert-sig-img" />
                        <div class="p-cert-sig-line"></div>
                        <div class="p-cert-sig-name">{invitation.aceptado_por || invitation.nombre}</div>
                        <div class="p-cert-sig-role">Partner</div>
                      </div>
                    )}
                    <div class="p-cert-sig">
                      <div class="p-cert-sig-mark">SACS</div>
                      <div class="p-cert-sig-line"></div>
                      <div class="p-cert-sig-name">Aaron Herzberg</div>
                      <div class="p-cert-sig-role">Founder · SACS</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="p-cert-next">
              <h3 class="p-cert-next-title">Siguiente paso</h3>
              <p class="p-cert-next-lead">
                Ya tienes acceso a tu portal de partner. Ahí ves comisiones, prospectos,
                pagos, tu link único, brand kit y tu cuenta SACS Plan Fideliza incluida.
              </p>
              <p class="p-cert-next-creds">
                Te enviamos al correo <strong>{invitation.email}</strong> tus credenciales
                de acceso y un link para crear tu contraseña.
              </p>
              <a href="/partner/portal" class="p-cert-cta">Ir a mi portal de partner →</a>
            </div>
          </div>
        ) : isSubmitted ? (
          <div class="p-signed p-signed--submitted">
            <div class="p-signed-eyebrow">{tt('sign.review.eyebrow')}</div>
            <div class="p-signed-title">Recibimos tu solicitud, {invitation.aceptado_por || invitation.nombre}.</div>
            <div class="p-signed-sub">
              Nuestro equipo está revisando tus datos. Te contactaremos en las próximas <strong>24-48 horas hábiles</strong> para activar tu programa <strong>{tipoLabel[tipo] || tipo}</strong> y enviarte tus credenciales por correo.
            </div>
            {meta.firma_base64 && (
              <img src={meta.firma_base64} alt="Firma" class="p-signed-img" />
            )}
            {invitation.aceptado_por && (
              <div class="p-signed-label">Solicitud firmada por {invitation.aceptado_por}</div>
            )}
            {invitation.aceptado_fecha && (
              <div class="p-signed-date">{fmtDate(invitation.aceptado_fecha)}</div>
            )}
            <div class="p-signed-meta" style="margin-top:18px">
              ¿Algún cambio? Responde el correo de confirmación o escribe a <a href="mailto:partners@sacscloud.com">partners@sacscloud.com</a>.
            </div>
          </div>
        ) : isDeclined ? (
          <div class="p-signed p-signed--declined">
            <div class="p-signed-eyebrow">{isCancelled ? cancelT.eyebrow : tt('sign.declined.eyebrow')}</div>
            <div class="p-signed-title">{isCancelled ? cancelT.title : tt('sign.declined.title')}</div>
            <div class="p-signed-sub">{isCancelled ? cancelT.sub : tt('sign.declined.sub')}</div>
            {!isCancelled && invitation.decline_motivo && (
              <div class="p-signed-meta">Motivo: <strong>{invitation.decline_motivo}</strong>{invitation.decline_detalle ? ` · ${invitation.decline_detalle}` : ''}</div>
            )}
            {isCancelled && (
              <div class="p-signed-cta-row">
                <a class="p-signed-cta" href={`https://wa.me/5215536634392?text=${encodeURIComponent(`Hola, mi invitación de partner ${invitation.numero || ''} aparece cancelada. ¿Podemos revisarla?`)}`} target="_blank" rel="noopener">Contactar a SACS</a>
              </div>
            )}
          </div>
        ) : isExpired ? (
          <div class="p-signed p-signed--expired">
            <div class="p-signed-eyebrow">{tt('sign.expired.eyebrow')}</div>
            <div class="p-signed-title">Esta invitación venció el {vigenciaLarga}.</div>
            <div class="p-signed-sub">{tt('sign.expired.sub')}</div>
            <div class="p-signed-cta-row">
              <a class="p-signed-cta" href={`https://wa.me/5215536634392?text=${encodeURIComponent(`Hola, mi invitación de partner ${invitation.numero || ''} venció. Me gustaría renovarla.`)}`} target="_blank" rel="noopener">Renovar invitación</a>
            </div>
          </div>
        ) : (
          <div class="p-sign-form" id="sign-wizard">
            <div class="p-section-head p-section-head--center">
              <div class="p-section-eyebrow">{tt('sign.eyebrow')}</div>
              <h2 class="p-section-title">{tt('sign.title')}</h2>
              <p class="p-section-lead" set:html={invitation.auto_approve ? tt('sign.lead.auto') : tt('sign.lead.manual')}></p>
            </div>

            <!-- Hero photo anchor -->
            <div class="p-tab-hero">
              <img src="/images/partner-tabs/firma.webp" alt="Apretón de manos cerrando un acuerdo" loading="lazy" width="1600" height="900" class="p-tab-hero-img" />
              <div class="p-tab-hero-overlay">
                <div class="p-tab-hero-eyebrow">Bienvenido al equipo</div>
                <h2 class="p-tab-hero-title">El siguiente paso es contigo.</h2>
              </div>
            </div>

            {/* Stepper */}
            <div class="p-sw-stepper" role="tablist" aria-label="Pasos de aceptación">
              <button type="button" class="p-sw-step is-active" data-sw-step="1" role="tab" aria-selected="true">
                <span class="p-sw-step-num">1</span>
                <span class="p-sw-step-label">{tt('sign.step1')}</span>
              </button>
              <span class="p-sw-step-line"></span>
              <button type="button" class="p-sw-step" data-sw-step="2" role="tab" aria-selected="false">
                <span class="p-sw-step-num">2</span>
                <span class="p-sw-step-label">{tt('sign.step2')}</span>
              </button>
              <span class="p-sw-step-line"></span>
              <button type="button" class="p-sw-step" data-sw-step="3" role="tab" aria-selected="false" disabled>
                <span class="p-sw-step-num">3</span>
                <span class="p-sw-step-label">{invitation.auto_approve ? tt('sign.step3.auto') : tt('sign.step3.manual')}</span>
              </button>
            </div>

            {/* ─────── PASO 1 — Tus datos ─────── */}
            <div class="p-sw-panel is-active" data-sw-panel="1">
            <div class="p-sign-section">
              <div class="p-sign-section-head">
                <span class="p-sign-section-num">1</span>
                <span class="p-sign-section-title">{tt('sign.s.data')}</span>
              </div>
              <div class="p-sign-fields">
                <label class="p-sign-field">
                  <span>{tt('f.name')}</span>
                  <input type="text" id="sign-nombre" class="p-input" placeholder="Ej. Mariana López" value={invitation.nombre || ''} />
                </label>
                <label class="p-sign-field">
                  <span>{tt('f.email')}</span>
                  <input type="email" id="sign-email" class="p-input" placeholder="tu@correo.com" value={invitation.email || ''} />
                </label>
                <label class="p-sign-field">
                  <span>{tt('f.whatsapp')}</span>
                  <input type="tel" id="sign-whatsapp" class="p-input" placeholder="55 1234 5678" value={invitation.whatsapp || ''} />
                </label>
                <label class="p-sign-field">
                  <span>{tt('f.company')} <span class="p-sign-optional">{tt('f.optional')}</span></span>
                  <input type="text" id="sign-empresa" class="p-input" placeholder="Ej. Mariana López Studio S.A. de C.V." value={invitation.empresa || ''} />
                </label>
              </div>
            </div>

            <div class="p-sign-section">
              <div class="p-sign-section-head">
                <span class="p-sign-section-num">2</span>
                <span class="p-sign-section-title">{tt('sign.s.address')}</span>
              </div>
              <div class="p-sign-fields">
                <label class="p-sign-field p-sign-field--full">
                  <span>{tt('f.street')}</span>
                  <input type="text" id="addr-calle" class="p-input" placeholder="Av. Insurgentes Sur 1234, Int. 5B" />
                </label>
                <label class="p-sign-field">
                  <span>{tt('f.colonia')}</span>
                  <input type="text" id="addr-colonia" class="p-input" placeholder="Del Valle" />
                </label>
                <label class="p-sign-field">
                  <span>{tt('f.cp')}</span>
                  <input type="text" id="addr-cp" class="p-input" placeholder="03100" inputmode="numeric" maxlength="5" />
                </label>
                <label class="p-sign-field">
                  <span>{tt('f.city')}</span>
                  <input type="text" id="addr-ciudad" class="p-input" placeholder="Benito Juárez" />
                </label>
                <label class="p-sign-field">
                  <span>{tt('f.state')}</span>
                  <input type="text" id="addr-estado" class="p-input" placeholder="CDMX" />
                </label>
              </div>
            </div>

            <div class="p-sign-section">
              <div class="p-sign-section-head">
                <span class="p-sign-section-num">3</span>
                <span class="p-sign-section-title">{tt('sign.s.payment')}</span>
              </div>
              <div class="p-payout-methods" role="radiogroup" aria-label={tt('f.payout.method')}>
                <label class="p-payout-opt">
                  <input type="radio" name="payout-method" value="clabe" checked />
                  <span class="p-payout-opt-body">
                    <span class="p-payout-opt-title">{tt('f.clabe')}</span>
                    <span class="p-payout-opt-sub">{tt('f.clabe.sub')}</span>
                  </span>
                </label>
                <label class="p-payout-opt">
                  <input type="radio" name="payout-method" value="paypal" />
                  <span class="p-payout-opt-body">
                    <span class="p-payout-opt-title">PayPal</span>
                    <span class="p-payout-opt-sub">{tt('f.paypal.sub')}</span>
                  </span>
                </label>
                <label class="p-payout-opt">
                  <input type="radio" name="payout-method" value="mercadopago" />
                  <span class="p-payout-opt-body">
                    <span class="p-payout-opt-title">Mercado Pago</span>
                    <span class="p-payout-opt-sub">{tt('f.mp.sub')}</span>
                  </span>
                </label>
              </div>

              {/* Detalle por método */}
              <div class="p-sign-fields p-payout-detail" data-payout-section="clabe">
                <label class="p-sign-field">
                  <span>{tt('f.clabe.full')}</span>
                  <input type="text" id="payout-clabe" class="p-input" placeholder="012180012345678901" inputmode="numeric" maxlength="18" />
                </label>
                <label class="p-sign-field">
                  <span>{tt('f.bank')}</span>
                  <input type="text" id="payout-banco" class="p-input" placeholder="Ej. BBVA, Santander, Banorte..." />
                </label>
                <label class="p-sign-field">
                  <span>{tt('f.holder')}</span>
                  <input type="text" id="payout-titular" class="p-input" placeholder="Como aparece en el estado de cuenta" />
                </label>
                <label class="p-sign-field">
                  <span>{tt('f.rfc')} <span class="p-sign-optional">{tt('f.optional')}</span></span>
                  <input type="text" id="payout-rfc" class="p-input" placeholder="XAXX010101000" maxlength="13" />
                </label>
              </div>

              <div class="p-sign-fields p-payout-detail" data-payout-section="paypal" hidden>
                <label class="p-sign-field p-sign-field--full">
                  <span>{tt('f.paypal.email')}</span>
                  <input type="email" id="payout-paypal" class="p-input" placeholder="tu@paypal.com" />
                </label>
              </div>

              <div class="p-sign-fields p-payout-detail" data-payout-section="mercadopago" hidden>
                <label class="p-sign-field">
                  <span>{tt('f.mp.email')}</span>
                  <input type="text" id="payout-mp-id" class="p-input" placeholder="tu@correo.com o alias.mp" />
                </label>
                <label class="p-sign-field">
                  <span>{tt('f.mp.holder')}</span>
                  <input type="text" id="payout-mp-titular" class="p-input" placeholder="Tu nombre completo en MP" />
                </label>
              </div>
            </div>

            <div class="p-sign-section">
              <div class="p-sign-section-head">
                <span class="p-sign-section-num">4</span>
                <span class="p-sign-section-title">{tt('sign.s.beneficiarios')} <span class="p-sign-optional">{tt('f.optional')}</span></span>
              </div>
              <p class="p-sign-hint">{tt('sign.benef.help')}</p>
              <div id="benef-list">
                {[0, 1, 2].map((i) => (
                  <div class="p-sign-fields benef-row" data-benef-row={i} hidden={i > 0}>
                    <label class="p-sign-field p-sign-field--full">
                      <span>{tt('f.benef.nombre')}</span>
                      <input type="text" class="p-input benef-nombre" placeholder="Ej. Mariana López García" />
                    </label>
                    <label class="p-sign-field">
                      <span>{tt('f.benef.parentesco')} <span class="p-sign-optional">{tt('f.optional')}</span></span>
                      <input type="text" class="p-input benef-parentesco" placeholder="Ej. cónyuge, hijo/a, socio/a" />
                    </label>
                    <label class="p-sign-field">
                      <span>{tt('f.benef.pct')}</span>
                      <input type="number" class="p-input benef-pct" min="0" max="100" step="1" inputmode="numeric" placeholder="0" />
                    </label>
                    {i > 0 && (
                      <button type="button" class="benef-remove" data-benef-remove={i}>{tt('sign.benef.remove')}</button>
                    )}
                  </div>
                ))}
              </div>
              <div class="benef-foot">
                <button type="button" class="benef-add" id="benef-add">{tt('sign.benef.add')}</button>
                <span class="benef-sum" id="benef-sum" hidden>{tt('sign.benef.sum')}: <strong id="benef-sum-val">0</strong>%</span>
              </div>
            </div>

            <div class="p-sw-nav">
              <button type="button" class="p-btn p-btn--ghost" id="btn-decline">{tt('sign.btn.decline')}</button>
              <button type="button" class="p-btn p-btn--primary" data-sw-go="2">{tt('f.next')}</button>
            </div>
            </div>
            {/* ─────── /PASO 1 ─────── */}

            {/* ─────── PASO 2 — Contrato + firma ─────── */}
            <div class="p-sw-panel" data-sw-panel="2">
              <div class="p-contract">
                <div class="p-contract-head">
                  <div class="p-contract-eyebrow">{tt('ct.eyebrow')}</div>
                  <h3 class="p-contract-title">{ctTitleHtml}</h3>
                  <div class="p-contract-meta">{tt('ct.meta')} · <strong>{numeroStr}</strong> · <strong>{vigenciaLarga}</strong></div>
                  {isLocalized && (
                    <div class="p-contract-legal-notice">{tt('ct.legal_notice')}</div>
                  )}
                </div>

                <div class="p-contract-doc">
                  <p set:html={ctIntroHtml}></p>

                  <h4>{tt('ct.h1')}</h4>
                  <p set:html={ctP1Html}></p>

                  <h4>{tt('ct.h2')}</h4>
                  <ul>
                    <li set:html={ctP21Html}></li>
                    <li set:html={tt('ct.p2.compartida')}></li>
                    <li set:html={tt('ct.p2.2')}></li>
                    <li set:html={tt('ct.p2.3')}></li>
                    <li set:html={ctP24Html}></li>
                  </ul>

                  <h4>{tt('ct.h2b')}</h4>
                  <p set:html={tt('ct.p2b.tipos')}></p>
                  <p set:html={tt('ct.p2b.panel')}></p>
                  <p set:html={tt('ct.p2b.acomp')}></p>

                  <h4>{tt('ct.h3')}</h4>
                  <p set:html={tt('ct.p3')}></p>

                  <h4>{tt('ct.h4')}</h4>
                  <ul>
                    <li set:html={tt('ct.p4.1')}></li>
                    <li set:html={tt('ct.p4.2')}></li>
                    <li set:html={tt('ct.p4.3')}></li>
                    <li set:html={tt('ct.p4.4')}></li>
                    <li set:html={tt('ct.p4.5')}></li>
                  </ul>

                  <h4>{tt('ct.h5')}</h4>
                  <ul>
                    <li set:html={tt('ct.p5.1')}></li>
                    <li set:html={tt('ct.p5.2')}></li>
                    <li set:html={tt('ct.p5.3')}></li>
                    <li set:html={tt('ct.p5.4')}></li>
                    <li set:html={tt('ct.p5.5')}></li>
                    <li set:html={tt('ct.p5.6')}></li>
                  </ul>

                  <h4>{tt('ct.h6')}</h4>
                  <p set:html={tt('ct.p6.intro')}></p>
                  <ul>
                    <li set:html={tt('ct.p6.c1')}></li>
                    <li set:html={tt('ct.p6.c2')}></li>
                    <li set:html={tt('ct.p6.c3')}></li>
                    <li set:html={tt('ct.p6.c4')}></li>
                    <li set:html={tt('ct.p6.c5')}></li>
                    <li set:html={tt('ct.p6.c6')}></li>
