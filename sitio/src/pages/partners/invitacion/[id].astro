          </div>
        ) : isExpired ? (
          <div class="p-signed p-signed--expired">
            <div class="p-signed-eyebrow">Vencida</div>
            <div class="p-signed-title">Esta invitación venció el {vigenciaLarga}.</div>
            <div class="p-signed-sub">Si todavía te interesa el programa, contáctanos y te enviamos una invitación renovada.</div>
            <div class="p-signed-cta-row">
              <a class="p-signed-cta" href={`https://wa.me/5215512345678?text=${encodeURIComponent(`Hola, mi invitación de partner ${invitation.numero || ''} venció. Me gustaría renovarla.`)}`} target="_blank" rel="noopener">Renovar invitación</a>
            </div>
          </div>
        ) : (
          <div class="p-sign-form">
            <div class="p-section-head p-section-head--center">
              <div class="p-section-eyebrow">Último paso</div>
              <h2 class="p-section-title">Acepta y firma tu invitación</h2>
              <p class="p-section-lead">
                Al firmar enviamos tu solicitud al equipo SACS para revisión. En cuanto la aprobemos te llegará un correo con tus credenciales del programa <strong>{tipoLabel[tipo] || tipo}</strong>.
              </p>
            </div>

            <div class="p-sign-section">
              <div class="p-sign-section-head">
                <span class="p-sign-section-num">1</span>
                <span class="p-sign-section-title">Tus datos</span>
              </div>
              <div class="p-sign-fields">
                <label class="p-sign-field">
                  <span>Nombre completo</span>
                  <input type="text" id="sign-nombre" class="p-input" placeholder="Ej. Mariana López" value={invitation.nombre || ''} />
                </label>
                <label class="p-sign-field">
                  <span>Email</span>
                  <input type="email" id="sign-email" class="p-input" placeholder="tu@correo.com" value={invitation.email || ''} />
                </label>
                <label class="p-sign-field">
                  <span>WhatsApp</span>
                  <input type="tel" id="sign-whatsapp" class="p-input" placeholder="55 1234 5678" value={invitation.whatsapp || ''} />
                </label>
                <label class="p-sign-field">
                  <span>Empresa o razón social <span class="p-sign-optional">(opcional)</span></span>
                  <input type="text" id="sign-empresa" class="p-input" placeholder="Ej. Mariana López Studio S.A. de C.V." value={invitation.empresa || ''} />
                </label>
              </div>
            </div>

            <div class="p-sign-section">
              <div class="p-sign-section-head">
                <span class="p-sign-section-num">2</span>
                <span class="p-sign-section-title">Dirección del negocio</span>
              </div>
              <div class="p-sign-fields">
                <label class="p-sign-field p-sign-field--full">
                  <span>Calle y número</span>
                  <input type="text" id="addr-calle" class="p-input" placeholder="Av. Insurgentes Sur 1234, Int. 5B" />
                </label>
                <label class="p-sign-field">
                  <span>Colonia</span>
                  <input type="text" id="addr-colonia" class="p-input" placeholder="Del Valle" />
                </label>
                <label class="p-sign-field">
                  <span>Código postal</span>
                  <input type="text" id="addr-cp" class="p-input" placeholder="03100" inputmode="numeric" maxlength="5" />
                </label>
                <label class="p-sign-field">
                  <span>Ciudad / Alcaldía</span>
                  <input type="text" id="addr-ciudad" class="p-input" placeholder="Benito Juárez" />
                </label>
                <label class="p-sign-field">
                  <span>Estado</span>
                  <input type="text" id="addr-estado" class="p-input" placeholder="CDMX" />
                </label>
              </div>
            </div>

            <div class="p-sign-section">
              <div class="p-sign-section-head">
                <span class="p-sign-section-num">3</span>
                <span class="p-sign-section-title">Cómo recibes tus comisiones</span>
              </div>
              <div class="p-payout-methods" role="radiogroup" aria-label="Método de cobro">
                <label class="p-payout-opt">
                  <input type="radio" name="payout-method" value="clabe" checked />
                  <span class="p-payout-opt-body">
                    <span class="p-payout-opt-title">CLABE / Transferencia</span>
                    <span class="p-payout-opt-sub">Depósito directo a banco mexicano</span>
                  </span>
                </label>
                <label class="p-payout-opt">
                  <input type="radio" name="payout-method" value="paypal" />
                  <span class="p-payout-opt-body">
                    <span class="p-payout-opt-title">PayPal</span>
                    <span class="p-payout-opt-sub">Recibe en cualquier moneda</span>
                  </span>
                </label>
                <label class="p-payout-opt">
                  <input type="radio" name="payout-method" value="mercadopago" />
                  <span class="p-payout-opt-body">
                    <span class="p-payout-opt-title">Mercado Pago</span>
                    <span class="p-payout-opt-sub">Saldo MP / cuenta vinculada</span>
                  </span>
                </label>
              </div>

              {/* Detalle por método */}
              <div class="p-sign-fields p-payout-detail" data-payout-section="clabe">
                <label class="p-sign-field">
                  <span>CLABE Interbancaria (18 dígitos)</span>
                  <input type="text" id="payout-clabe" class="p-input" placeholder="012180012345678901" inputmode="numeric" maxlength="18" />
                </label>
                <label class="p-sign-field">
                  <span>Banco</span>
                  <input type="text" id="payout-banco" class="p-input" placeholder="Ej. BBVA, Santander, Banorte..." />
                </label>
                <label class="p-sign-field">
                  <span>Titular de la cuenta</span>
                  <input type="text" id="payout-titular" class="p-input" placeholder="Como aparece en el estado de cuenta" />
                </label>
                <label class="p-sign-field">
                  <span>RFC <span class="p-sign-optional">(opcional)</span></span>
                  <input type="text" id="payout-rfc" class="p-input" placeholder="XAXX010101000" maxlength="13" />
                </label>
              </div>

              <div class="p-sign-fields p-payout-detail" data-payout-section="paypal" hidden>
                <label class="p-sign-field p-sign-field--full">
                  <span>Email de PayPal</span>
                  <input type="email" id="payout-paypal" class="p-input" placeholder="tu@paypal.com" />
                </label>
              </div>

              <div class="p-sign-fields p-payout-detail" data-payout-section="mercadopago" hidden>
                <label class="p-sign-field">
                  <span>Email o alias Mercado Pago</span>
                  <input type="text" id="payout-mp-id" class="p-input" placeholder="tu@correo.com o alias.mp" />
                </label>
                <label class="p-sign-field">
                  <span>Titular de la cuenta MP</span>
                  <input type="text" id="payout-mp-titular" class="p-input" placeholder="Tu nombre completo en MP" />
                </label>
              </div>
            </div>

            <div class="p-sign-section">
              <div class="p-sign-section-head">
                <span class="p-sign-section-num">4</span>
                <span class="p-sign-section-title">Firma de aceptación</span>
              </div>
              <div class="p-sign-canvas-wrap">
                <div class="p-sign-canvas-label">Firma con el dedo o el mouse</div>
                <canvas id="signature-canvas" class="p-sign-canvas"></canvas>
                <div class="p-sign-canvas-actions">
                  <button type="button" class="p-btn p-btn--ghost" id="btn-clear-sig">Limpiar firma</button>
                </div>
              </div>
            </div>

            <div class="p-sign-legal">
              Al aceptar y firmar confirmas que has leído y aceptas los
              <a href="/terminos" target="_blank" rel="noopener">Términos y condiciones</a> y el
              <a href="/privacidad" target="_blank" rel="noopener">Aviso de privacidad</a>.
              Tu solicitud queda en revisión por el equipo SACS antes de la activación.
            </div>

            <div class="p-sign-actions">
              <button type="button" class="p-btn p-btn--primary" id="btn-accept">Enviar solicitud al equipo SACS</button>
              <button type="button" class="p-btn p-btn--ghost" id="btn-decline">No me interesa por ahora</button>
            </div>
          </div>
        )}
      </section>

      <!-- Footer -->
      <div class="p-footer">
        <div class="p-footer-brand">
          <span class="p-footer-logo">Sacs</span>
          <span class="p-footer-tagline">Sistema operativo para retailers</span>
        </div>
        <div class="p-footer-contact">www.sacscloud.com · partners@sacscloud.com</div>
      </div>
    </div>
  </div>
</div>

<!-- Decline modal -->
{!isClosed && !isExpired && (
<div class="p-modal-overlay no-print" id="decline-modal" style="display:none">
  <div class="p-modal">
    <div class="p-modal-header">
      <span class="p-modal-title">¿Por qué no es para ti?</span>
      <button type="button" class="p-modal-close" id="btn-close-decline">✕</button>
    </div>
    <div class="p-modal-body">
      <p class="p-modal-text">Tu respuesta nos ayuda a mejorar el programa. Selecciona el motivo principal:</p>
      <div class="p-decline-reasons">
        <label class="p-decline-reason"><input type="radio" name="decline-motivo" value="no_tengo_audiencia" /> <span>No tengo audiencia o red para recomendar SACS</span></label>
        <label class="p-decline-reason"><input type="radio" name="decline-motivo" value="comision_baja" /> <span>La comisión no me parece atractiva</span></label>
        <label class="p-decline-reason"><input type="radio" name="decline-motivo" value="compromiso_alto" /> <span>El compromiso de contenido es muy alto</span></label>
        <label class="p-decline-reason"><input type="radio" name="decline-motivo" value="timing" /> <span>No es buen momento, lo veo más adelante</span></label>
        <label class="p-decline-reason"><input type="radio" name="decline-motivo" value="otro" /> <span>Otro motivo</span></label>
      </div>
      <label class="p-sign-field" style="margin-top:14px">
        <span>Detalle (opcional)</span>
        <textarea id="decline-detalle" class="p-input" rows="3" placeholder="Cuéntanos más..."></textarea>
      </label>
    </div>
    <div class="p-modal-footer">
      <button class="p-btn p-btn--ghost" id="btn-cancel-decline" type="button">Cancelar</button>
      <button class="p-btn p-btn--primary" id="btn-confirm-decline" type="button">Enviar respuesta</button>
    </div>
  </div>
</div>
)}

</BaseLayout>

<style is:global>
  /* Página enfocada — bareLayout en BaseLayout ya omite Nav/Footer.
     Reset por si algún global aplica margin/padding al body o main. */
  body, main { padding: 0 !important; margin: 0 !important; }
</style>

<style>
  /* ════════════════════════════════════════════════
     Partner invitation public page — typographic,
     Squarespace-style with editorial gradients.
     Brand accent: #4B7BE5 (partner blue).
     ════════════════════════════════════════════════ */

  .p-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 0;
    min-height: 100vh;
    background: #fafaf8;
  }
  .p-layout-sidebar {
    position: sticky;
    top: 0;
    align-self: start;
    height: 100vh;
    overflow-y: auto;
    background: #fff;
    border-right: 1px solid #e5e5e5;
    scrollbar-width: thin;
  }
  .p-layout-sidebar::-webkit-scrollbar { width: 6px; }
  .p-layout-sidebar::-webkit-scrollbar-thumb { background: #e0e0e0; border-radius: 3px; }

  .p-page { padding: 0 0 80px; }
  .p-container { max-width: 760px; margin: 0 auto; padding: 0 32px; }

  @media (max-width: 1023px) {
    .p-layout { grid-template-columns: 1fr; }
    .p-layout-sidebar { display: none; }
    .p-container { padding: 0 20px; }
  }

  /* ─── Mobile sticky tab nav (visible solo ≤1023px) ─────────────
     Reemplaza la sidebar oculta en móvil. Pills con scroll horizontal
     para que el partner pueda saltar entre Bienvenida → Cómo funciona
     → Términos → ... → Aceptar y firmar desde cualquier punto. */
  .p-mobnav {
    display: none;
  }
  @media (max-width: 1023px) {
    .p-mobnav {
      display: block;
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(250,250,248,0.96);
      -webkit-backdrop-filter: blur(8px);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid #ececec;
    }
    .p-mobnav-inner {
      display: flex;
      gap: 4px;
      overflow-x: auto;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      padding: 10px 16px;
      scroll-snap-type: x proximity;
    }
    .p-mobnav-inner::-webkit-scrollbar { display: none; }
    .p-mobnav-tab {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 9px 14px;
      border-radius: 999px;
      background: transparent;
      color: #777;
      text-decoration: none;
      font-size: 0.8125rem;
      font-weight: 500;
      letter-spacing: 0.005em;
      white-space: nowrap;
      scroll-snap-align: center;
      transition: background 0.15s, color 0.15s;
    }
    .p-mobnav-tab:hover { color: #1a1a1a; }
    .p-mobnav-tab--active {
      background: #1a1a1a;
      color: #fff;
    }
    .p-mobnav-tab--active .p-mobnav-tab-num {
      color: rgba(255,255,255,0.55);
    }
    .p-mobnav-tab-num {
      font-family: var(--font-display);
      font-size: 0.6875rem;
      font-weight: 500;
      color: #bbb;
      letter-spacing: 0.04em;
    }
  }
  /* Hide mobnav on print */
  @media print { .p-mobnav { display: none !important; } }

  /* Tab switcher */
  .p-tab-panel { display: none; animation: tabFade 220ms ease; padding-bottom: 64px; }
  .p-tab-panel.is-active { display: block; }
  @keyframes tabFade { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) {
    .p-tab-panel { animation: none; }
  }

  /* Header */
  .p-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 32px 0 20px;
    border-bottom: 1px solid #f0f0f0;
    margin-bottom: 24px;
  }
  @media (max-width: 640px) {
    .p-header {
      padding: 16px 0 14px;
      margin-bottom: 18px;
    }
    .p-header-brand { gap: 8px; }
    .p-logo-text { font-size: 1.375rem !important; }
    .p-logo-tag { font-size: 0.5625rem; padding: 3px 8px; }
    .p-numero { font-size: 0.875rem; }
    .p-fecha { font-size: 0.6875rem; }
  }
  .p-header-brand { display: flex; align-items: center; gap: 10px; }
  .p-logo-text { font-family: var(--font-logo, var(--font-display)); font-size: 1.75rem; font-weight: 700; color: #1a1a1a; }
  .p-logo-tag {
    font-size: 0.625rem; font-weight: 700; color: #4B7BE5;
    background: rgba(75,123,229,0.10);
    padding: 4px 10px; border-radius: 4px;
    text-transform: uppercase; letter-spacing: 0.1em;
  }
  .p-header-meta { text-align: right; }
  .p-numero { font-family: var(--font-display); font-size: 1.0625rem; font-weight: 700; color: #1a1a1a; letter-spacing: -0.005em; }
  .p-fecha { font-size: 0.75rem; color: #999; margin-top: 2px; }

  /* Status pill */
  .p-status {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 5px 11px 5px 10px; border-radius: 999px;
    font-size: 0.625rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    margin-bottom: 8px; line-height: 1;
  }
  .p-status-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
  .p-status--active { background: rgba(75,123,229,0.10); color: #3764c4; }
  .p-status--active .p-status-dot { background: #4B7BE5; }
  .p-status--accepted { background: rgba(42,181,160,0.12); color: #1e8471; }
  .p-status--accepted .p-status-dot { background: #2AB5A0; }
  .p-status--declined { background: rgba(229,75,75,0.10); color: #b93333; }
  .p-status--declined .p-status-dot { background: #E54B4B; }
  .p-status--expired { background: rgba(153,153,153,0.12); color: #666; }
  .p-status--expired .p-status-dot { background: #999; }

  /* Hero */
  .p-hero { padding: 56px 0 64px; }
  @media (max-width: 640px) {
    .p-hero { padding: 28px 0 36px; }
    .p-hero-eyebrow { margin-bottom: 14px; font-size: 0.625rem; letter-spacing: 0.14em; }
    .p-hero-title { margin: 0 0 20px; line-height: 1.05; }
    .p-hero-sub { font-size: 1rem; margin: 0 0 28px; }
    .p-hero-stats { padding: 18px 0; gap: 12px; margin-bottom: 20px; }
    .p-hero-quick { margin-top: 4px; }
    .p-hero-quick-row { font-size: 0.8125rem; }
  }
  .p-hero-eyebrow {
    font-size: 0.6875rem; font-weight: 700; color: #4B7BE5;
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 20px;
  }
  .p-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6.5vw, 4.5rem);
    font-weight: 200;
    color: #1a1a1a;
    letter-spacing: -0.035em;
    line-height: 1.02;
    margin: 0 0 28px;
  }
  .p-hero-title-soft { color: rgba(26,26,46,0.5); font-weight: 200; }
  .p-hero-title-strong {
    font-weight: 600;
    background: linear-gradient(120deg, #4B7BE5 0%, #6C5CE7 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .p-hero-sub {
    font-size: 1.125rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    max-width: 560px;
    margin: 0 0 40px;
  }

  .p-hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    padding: 24px 0;
    border-top: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
    margin-bottom: 28px;
  }
  .p-hero-stat { display: flex; flex-direction: column; gap: 4px; }
  .p-hero-stat-num {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 300;
    color: #1a1a1a;
    line-height: 1;
    letter-spacing: -0.025em;
  }
  .p-hero-stat-pct { font-size: 1rem; color: #4B7BE5; margin-left: 2px; font-weight: 400; }
  .p-hero-stat-label {
    font-size: 0.6875rem; font-weight: 600;
    color: #999;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  @media (max-width: 640px) {
    .p-hero-stats { grid-template-columns: 1fr; gap: 14px; }
    .p-hero-stat-num { font-size: 1.875rem; }
  }

  .p-hero-quick {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 8px;
  }
  .p-hero-quick-row {
    display: flex; align-items: flex-start; gap: 10px;
    font-size: 0.875rem;
    color: rgba(26,26,46,0.7);
    line-height: 1.55;
  }
  .p-hero-quick-icon {
    flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center;
    width: 28px; height: 28px;
    background: rgba(75,123,229,0.10);
    color: #4B7BE5;
    border-radius: 50%;
  }

  /* Section heads (used across tabs) */
  .p-section-head { padding: 56px 0 36px; max-width: 620px; }
  .p-section-head--center { text-align: center; margin: 0 auto; }
  .p-section-eyebrow {
    font-size: 0.6875rem; font-weight: 700; color: #4B7BE5;
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 14px;
  }
  .p-section-title {
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 4.5vw, 2.75rem);
    font-weight: 300;
    color: #1a1a1a;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0 0 16px;
  }
  .p-section-lead {
    font-size: 1rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    margin: 0;
  }
  @media (max-width: 640px) {
    .p-section-head { padding: 28px 0 24px; }
    .p-section-eyebrow { margin-bottom: 10px; }
    .p-section-title { margin-bottom: 12px; }
    .p-section-lead { font-size: 0.9375rem; line-height: 1.55; }
    .p-tab-panel { padding-bottom: 40px; }
  }

  /* Index nav under hero */
  .p-tab-intro-nav {
    display: flex; flex-direction: column; gap: 0;
    border-top: 1px solid #e5e5e5;
    margin-top: 24px;
  }
  .p-tab-intro-link {
    display: flex; justify-content: space-between; align-items: center;
    padding: 22px 0;
    color: #1a1a1a; text-decoration: none;
    border-bottom: 1px solid #e5e5e5;
    transition: color 0.2s ease;
  }
  .p-tab-intro-link:hover { color: #4B7BE5; }
  .p-tab-intro-link-label {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 400;
    letter-spacing: -0.005em;
  }
  .p-tab-intro-link-arrow {
    font-size: 1rem; color: #aaa;
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .p-tab-intro-link:hover .p-tab-intro-link-arrow {
    color: #4B7BE5; transform: translateX(6px);
  }
  @media (max-width: 640px) {
    .p-tab-intro-nav { margin-top: 16px; }
    .p-tab-intro-link { padding: 16px 0; }
    .p-tab-intro-link-label { font-size: 1rem; }
  }

  /* Benefits */
  .p-benefits-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-top: 8px;
  }
  @media (max-width: 640px) { .p-benefits-grid { grid-template-columns: 1fr; } }

  .p-benefit-card {
    padding: 28px 24px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .p-benefit-card:hover { border-color: #4B7BE5; transform: translateY(-2px); }
  .p-benefit-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px;
    background: linear-gradient(135deg, rgba(75,123,229,0.12), rgba(108,92,231,0.10));
    color: #4B7BE5;
    border-radius: 12px;
    margin-bottom: 16px;
  }
  .p-benefit-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 6px;
    letter-spacing: -0.005em;
  }
  .p-benefit-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
  }

  /* Terms */
  .p-terms {
    display: flex; flex-direction: column;
    border-top: 1px solid #e5e5e5;
    margin-top: 8px;
  }
  .p-term-row {
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px;
    padding: 22px 0;
    border-bottom: 1px solid #e5e5e5;
  }
  .p-term-row--big { padding: 32px 0; }
  .p-term-info { flex: 1; min-width: 0; }
  .p-term-label {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: #1a1a1a;
    margin-bottom: 4px;
    letter-spacing: -0.005em;
  }
  .p-term-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.6);
    line-height: 1.5;
  }
  .p-term-value {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: #1a1a1a;
    flex-shrink: 0;
    text-align: right;
    letter-spacing: -0.01em;
  }
  .p-term-value--accent {
    font-size: 2rem;
    font-weight: 300;
    background: linear-gradient(120deg, #4B7BE5 0%, #6C5CE7 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  /* Pill compacto para "Incluido" en filas de beneficios */
  .p-term-value--pill {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    background: rgba(42,181,160,0.12);
    color: #1A8F7A;
    padding: 5px 12px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    -webkit-text-fill-color: initial;
  }
  /* Variante con énfasis: para beneficios con valor monetario explícito
     (ej. Plan Fideliza "Vale $14,000/año · Gratis") */
  .p-term-value--pill-emph {
    background: linear-gradient(120deg, rgba(75,123,229,0.14), rgba(108,92,231,0.10));
    color: #3764c4;
    padding: 7px 14px;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: none;
    border: 1px solid rgba(75,123,229,0.20);
  }
  /* Variante para "Próximamente" — feature anunciada pero aún no activa */
  .p-term-value--pill-soon {
    background: rgba(232,168,56,0.12);
    color: #a06600;
    border: 1px solid rgba(232,168,56,0.25);
    -webkit-text-fill-color: initial;
  }
  /* Eyebrow para subgrupos dentro de Términos (1·Lo que ganas, 2·SACS te entrega, 3·Costos) */
  .p-terms-group-eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 32px 0 4px;
  }
  .p-terms-group-eyebrow:first-of-type {
    margin-top: 12px;
  }

  /* ─── Funnel de conversión — Squarespace style: timeline vertical limpio ─── */
  .p-funnel {
    margin: 72px 0 24px;
    padding: 88px 64px;
    background: #FAFAF8;
    border-radius: 2px;
  }

  .p-funnel-eyebrow {
    display: inline-block;
    color: #4B7BE5;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    margin-bottom: 32px;
    background: none;
    padding: 0;
  }
  .p-funnel-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.6vw, 2.875rem);
    font-weight: 300;
    line-height: 1.15;
    color: #1A1A1A;
    margin: 0 0 32px;
    letter-spacing: -0.025em;
    max-width: 720px;
  }
  .p-funnel-title-accent {
    color: #4B7BE5;
    font-weight: 400;
    background: none;
    -webkit-text-fill-color: initial;
  }
  .p-funnel-lead {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: #6A6A6A;
    margin: 0 0 72px;
    max-width: 620px;
    font-weight: 300;
  }

  /* Timeline vertical: lista ordenada con línea conectora */
  .p-funnel-flow {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 720px;
    position: relative;
  }
  /* Línea vertical detrás de los números */
  .p-funnel-flow::before {
    content: '';
    position: absolute;
    top: 14px;
    bottom: 14px;
    left: 17px;
    width: 1px;
    background: #E5E5E0;
  }
  .p-funnel-step {
    position: relative;
    display: flex;
    gap: 28px;
    padding: 0 0 40px;
  }
  .p-funnel-step--last { padding-bottom: 0; }

  .p-funnel-step-num {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: #FAFAF8;          /* match section bg para "tapar" la línea */
    color: #4B7BE5;
    border: 1px solid #4B7BE5;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.9375rem;
  }
  .p-funnel-step-content {
    flex: 1;
    min-width: 0;
    padding-top: 4px;
  }
  .p-funnel-step-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .p-funnel-step-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: #1A1A1A;
    letter-spacing: -0.015em;
    margin: 0;
    line-height: 1.2;
  }
  .p-funnel-step-tag {
    color: #4B7BE5;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .p-funnel-step-detail {
    font-size: 0.9375rem;
    color: #6A6A6A;
    line-height: 1.6;
    margin: 0;
    font-weight: 400;
    max-width: 520px;
  }

  /* Tools list — minimal columns con bullets sutiles */
  .p-funnel-tools {
    margin-top: 80px;
    padding-top: 48px;
    border-top: 1px solid #E5E5E0;
    max-width: 760px;
  }
  .p-funnel-tools-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 500;
    color: #1A1A1A;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 28px;
  }
  .p-funnel-tools-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px 48px;
  }
  .p-funnel-tools-list li {
    position: relative;
    padding-left: 20px;
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.55;
    font-weight: 400;
  }
  .p-funnel-tools-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 11px;
    width: 8px;
    height: 1px;
    background: #4B7BE5;
  }

  @media (max-width: 768px) {
    .p-funnel { padding: 56px 28px; margin: 48px 0 16px; }
    .p-funnel-title { margin-bottom: 24px; }
    .p-funnel-lead { margin-bottom: 48px; }
    .p-funnel-step { gap: 18px; padding-bottom: 32px; }
    .p-funnel-flow::before { left: 17px; }
    .p-funnel-tools { margin-top: 56px; padding-top: 36px; }
    .p-funnel-tools-list { grid-template-columns: 1fr; gap: 12px; }
  }

  .p-terms-extra {
    margin-top: 36px;
    padding: 24px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
  }
  .p-terms-extra-title {
    font-size: 0.625rem; font-weight: 700; color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
    margin-bottom: 10px;
  }
  .p-terms-extra-text {
    font-size: 0.875rem;
    color: rgba(26,26,46,0.7);
    line-height: 1.6;
    margin: 0;
    white-space: pre-line;
  }

  /* Compromisos */
  .p-commits {
    display: flex; flex-direction: column;
    border-top: 1px solid #e5e5e5;
    margin-top: 8px;
  }
  .p-commit-row {
    display: flex; align-items: flex-start; gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid #e5e5e5;
  }
  .p-commit-num {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: #4B7BE5;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    width: 28px;
    padding-top: 4px;
  }
  .p-commit-content { flex: 1; min-width: 0; }
  .p-commit-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 500;
    color: #1a1a1a;
    margin-bottom: 6px;
    letter-spacing: -0.005em;
  }
  .p-commit-detail {
    font-size: 0.875rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
  }
  .p-commit-frequency {
    display: inline-block; margin-top: 10px;
    padding: 3px 9px;
    font-size: 0.625rem; font-weight: 600;
    color: #4B7BE5;
    background: rgba(75,123,229,0.10);
    border-radius: 999px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .p-commit-note {
    display: flex; align-items: flex-start; gap: 10px;
    margin-top: 28px;
    padding: 16px 18px;
    background: rgba(75,123,229,0.05);
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 10px;
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.75);
    line-height: 1.55;
  }
  .p-commit-note svg { flex-shrink: 0; color: #4B7BE5; margin-top: 1px; }

  /* ─── ¿Por qué te conviene cumplir? — rationale block ─── */
  .p-commit-rationale {
    margin-top: 32px;
    padding: 36px 32px;
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d3f 100%);
    color: #fff;
    border-radius: 20px;
  }
  .p-commit-rationale-eyebrow {
    font-size: 0.6875rem; font-weight: 700;
    color: #93b4ff;
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 14px;
  }
  .p-commit-rationale-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 300;
    color: #fff;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0 0 16px;
  }
  .p-commit-rationale-text {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    margin: 0 0 14px;
    max-width: 620px;
  }
  .p-commit-rationale-text strong { color: #fff; font-weight: 600; }
  .p-commit-rationale-stack {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin: 22px 0 24px;
  }
  @media (max-width: 720px) { .p-commit-rationale-stack { grid-template-columns: 1fr; } }

  .p-commit-rationale-card {
    padding: 20px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    display: flex; flex-direction: column; gap: 6px;
  }
  .p-commit-rationale-card--ceiling {
    background: linear-gradient(135deg, rgba(75,123,229,0.18), rgba(108,92,231,0.12));
    border-color: rgba(108,92,231,0.30);
  }
  .p-commit-rationale-card-label {
    font-size: 0.625rem; font-weight: 700;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.12em; text-transform: uppercase;
    line-height: 1.4;
  }
  .p-commit-rationale-card--ceiling .p-commit-rationale-card-label { color: #93b4ff; }
  .p-commit-rationale-card-amount {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4.5vw, 2.5rem);
    font-weight: 200;
    color: #fff;
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 4px 0 4px;
  }
  .p-commit-rationale-card--ceiling .p-commit-rationale-card-amount {
    background: linear-gradient(120deg, #93b4ff 0%, #c4b5fd 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .p-commit-rationale-card-detail {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.5;
  }
  .p-commit-rationale-cta {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 6px;
    padding: 12px 20px;
    background: #fff;
    color: #1a1a1a;
    text-decoration: none;
    border-radius: 10px;
    font-size: 0.875rem;
    font-weight: 600;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .p-commit-rationale-cta:hover {
    background: #93b4ff;
    color: #1a1a1a;
    text-decoration: none;
    transform: translateY(-1px);
  }
  .p-commit-rationale-cta-arrow { transition: transform 0.15s ease; }
  .p-commit-rationale-cta:hover .p-commit-rationale-cta-arrow { transform: translateX(4px); }


  /* Tabulador / Payouts */
  .p-payout-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-top: 8px;
  }
  @media (max-width: 720px) { .p-payout-grid { grid-template-columns: 1fr; } }

  .p-payout-card {
    padding: 28px 22px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    display: flex; flex-direction: column; gap: 8px;
  }
  .p-payout-card--featured {
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d3f 100%);
    color: #fff;
    border: none;
  }
  .p-payout-step {
    font-size: 0.625rem; font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  .p-payout-card--featured .p-payout-step { color: #93b4ff; }
  .p-payout-amount {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 300;
    color: #1a1a1a;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .p-payout-card--featured .p-payout-amount { color: #fff; }
  .p-payout-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: #1a1a1a;
    letter-spacing: -0.005em;
  }
  .p-payout-card--featured .p-payout-name { color: #fff; }
  .p-payout-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.6);
    line-height: 1.5;
    margin-top: 4px;
  }
  .p-payout-card--featured .p-payout-detail { color: rgba(255,255,255,0.65); }

  .p-payout-notes {
    margin-top: 28px;
    padding: 22px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
  }
  .p-payout-notes-title {
    font-size: 0.625rem; font-weight: 700; color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
    margin-bottom: 10px;
  }
  .p-payout-notes p {
    margin: 0;
    font-size: 0.875rem;
    color: rgba(26,26,46,0.7);
    line-height: 1.6;
  }

  /* Landing card */
  .p-landing {
    margin-top: 32px;
    padding: 28px;
    background: linear-gradient(120deg, rgba(75,123,229,0.06), rgba(108,92,231,0.04));
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 16px;
    text-align: center;
  }
  .p-landing-eyebrow {
    font-size: 0.6875rem; font-weight: 700; color: #4B7BE5;
    letter-spacing: 0.14em; text-transform: uppercase;
    margin-bottom: 12px;
  }
  .p-landing-url {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 500;
    color: #1a1a1a;
    word-break: break-all;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .p-landing-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    margin: 0 auto;
    max-width: 460px;
  }

  /* ─── Portal de partner — qué ve el partner y desde dónde ─── */
  .p-portal {
    margin-top: 40px;
    padding: 32px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 16px;
  }
  .p-portal-eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .p-portal-title {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.6vw, 1.75rem);
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 14px;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .p-portal-lead {
    font-size: 0.9375rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.6;
    margin: 0 0 28px;
    max-width: 640px;
  }
  .p-portal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px;
    margin-bottom: 22px;
  }
  .p-portal-card {
    background: #fafafa;
    border: 1px solid #f0f0f0;
    border-radius: 12px;
    padding: 18px;
  }
  .p-portal-card-ic {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(75,123,229,0.10);
    color: #4B7BE5;
    border-radius: 9px;
    margin-bottom: 12px;
  }
  .p-portal-card-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .p-portal-card-detail {
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.6);
    line-height: 1.55;
  }
  .p-portal-note {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 14px 16px;
    background: rgba(42,181,160,0.08);
    border-left: 3px solid #2AB5A0;
    border-radius: 6px;
    font-size: 0.8125rem;
    color: rgba(26,26,46,0.75);
    line-height: 1.55;
  }
  .p-portal-note svg {
    flex-shrink: 0;
    color: #1A8F7A;
    margin-top: 2px;
  }
  @media (max-width: 640px) {
    .p-portal { padding: 22px; }
    .p-portal-grid { grid-template-columns: 1fr; }
  }

  /* ─── Tu potencial — proyección de ganancias ─── */
  .p-projection-block { margin: 8px 0 56px; }

  /* Toggle Mensual / Anual */
  .p-projection-toggle {
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    background: #fafafa;
    border: 1px solid #e5e5e5;
    border-radius: 14px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .p-toggle-btn {
    display: flex; flex-direction: column; gap: 1px;
    padding: 10px 18px;
    background: transparent;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    color: rgba(26,26,46,0.6);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .p-toggle-btn:hover { color: #1a1a1a; }
  .p-toggle-btn.is-active {
    background: #1a1a1a;
    color: #fff;
  }
  .p-toggle-btn-label {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: -0.005em;
  }
  .p-toggle-btn-hint {
    font-size: 0.625rem;
    font-weight: 500;
    opacity: 0.75;
    letter-spacing: 0.02em;
  }

  /* Show/hide based on data-projection-scope view state */
  [data-projection-scope] .p-view-anual { display: none; }
  [data-projection-scope][data-projection-view="anual"] .p-view-mensual { display: none; }
  [data-projection-scope][data-projection-view="anual"] .p-view-anual { display: block; }

  .p-projection-eyebrow {
    font-size: 0.625rem; font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 12px;
  }
  .p-projection-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 300;
    color: #1a1a1a;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 12px;
  }
  .p-projection-lead {
    font-size: 0.9375rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    margin: 0 0 28px;
    max-width: 600px;
  }
  .p-projection-lead strong { color: #1a1a1a; font-weight: 600; }

  /* Demo cards row */
  .p-demo-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 720px) { .p-demo-cards { grid-template-columns: 1fr; } }
  .p-demo-card {
    padding: 24px 22px;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    display: flex; flex-direction: column; gap: 4px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .p-demo-card:hover { border-color: #4B7BE5; transform: translateY(-2px); }
  .p-demo-card--featured {
    background: linear-gradient(135deg, rgba(75,123,229,0.10), rgba(108,92,231,0.06));
    border-color: rgba(75,123,229,0.35);
  }
  .p-demo-card-label {
    font-size: 0.6875rem; font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.12em; text-transform: uppercase;
  }
  .p-demo-card-meta {
    font-size: 0.75rem;
    color: rgba(26,26,46,0.6);
    margin-bottom: 14px;
  }
  .p-demo-card-amount {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 300;
    color: #1a1a1a;
    line-height: 1;
    letter-spacing: -0.025em;
  }
  .p-demo-card-period {
    font-size: 0.75rem;
    color: rgba(26,26,46,0.55);
    margin-top: 2px;
  }
  .p-demo-card-annual {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid #e5e5e5;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #1a1a1a;
  }
  .p-demo-card-hint {
    font-size: 0.6875rem;
    color: rgba(26,26,46,0.5);
    font-style: italic;
    margin-top: 4px;
  }
  .p-demo-card--featured .p-demo-card-annual { border-color: rgba(75,123,229,0.25); }

  /* Sales matrix */
  .p-matrix-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 0 -8px;
    padding: 0 8px;
    scrollbar-width: thin;
  }
  .p-matrix-wrap::-webkit-scrollbar { height: 6px; }
  .p-matrix-wrap::-webkit-scrollbar-thumb { background: #e0e0e0; border-radius: 3px; }
  .p-matrix {
    width: 100%; min-width: 560px;
    border-collapse: collapse;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 16px;
    overflow: hidden;
  }
  .p-matrix-th, .p-matrix-td {
    padding: 14px 12px;
    text-align: center;
    font-size: 0.875rem;
    border-bottom: 1px solid #f0f0f0;
    border-right: 1px solid #f0f0f0;
  }
  .p-matrix-th:last-child, .p-matrix-td:last-child { border-right: none; }
  .p-matrix-th {
    background: #fafafa;
    font-weight: 500;
    color: rgba(26,26,46,0.7);
    border-bottom: 1px solid #e5e5e5;
    padding: 18px 12px;
  }
  .p-matrix-th--clients {
    text-align: left;
    padding-left: 22px;
    font-size: 0.625rem;
    font-weight: 700;
    color: #999;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .p-matrix-plan-name {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 2px;
    letter-spacing: -0.005em;
  }
  .p-matrix-plan-price {
    font-size: 0.6875rem;
    color: #999;
    font-weight: 500;
  }
  .p-matrix-th--featured {
    background: linear-gradient(180deg, rgba(108,92,231,0.10), rgba(108,92,231,0.04));
  }
  .p-matrix-th--featured .p-matrix-plan-name { color: #6C5CE7; }
  .p-matrix-td--clients {
    text-align: left;
    padding-left: 22px;
    font-size: 0.875rem;
    color: rgba(26,26,46,0.7);
    background: #fafafa;
  }
  .p-matrix-td--clients strong {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: #1a1a1a;
    margin-right: 6px;
    letter-spacing: -0.01em;
  }
  .p-matrix-amount {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 1.1;
    letter-spacing: -0.005em;
  }
  .p-matrix-sub {
    font-size: 0.625rem;
    color: rgba(26,26,46,0.45);
    margin-top: 1px;
    letter-spacing: 0.05em;
  }
  .p-matrix-row--big .p-matrix-amount { font-size: 1.25rem; font-weight: 500; }
  .p-matrix-row--big .p-matrix-td--clients strong { font-size: 1.5rem; color: #4B7BE5; }
  .p-matrix-td--featured {
    background: rgba(108,92,231,0.04);
  }
  .p-matrix-td--featured .p-matrix-amount {
    color: #6C5CE7;
    font-weight: 600;
  }
  .p-matrix tbody tr:last-child .p-matrix-th, .p-matrix tbody tr:last-child .p-matrix-td { border-bottom: none; }
  .p-matrix tbody tr:hover { background: rgba(75,123,229,0.02); }

  .p-matrix-note {
    display: flex; align-items: flex-start; gap: 10px;
    margin-top: 18px;
    padding: 14px 16px;
    background: #fafafa;
    border-radius: 10px;
    font-size: 0.75rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
  }
  .p-matrix-note svg { flex-shrink: 0; color: #4B7BE5; margin-top: 2px; }

  /* Closing big number */
  .p-projection-closing {
    margin-top: 24px;
    padding: 36px 32px;
    background: #1a1a1a;
    color: #fff;
    border-radius: 20px;
  }
  .p-projection-closing-eyebrow {
    font-size: 0.6875rem; font-weight: 700;
    color: #93b4ff;
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 24px;
  }
  .p-projection-closing-stack {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }
  @media (max-width: 720px) { .p-projection-closing-stack { grid-template-columns: 1fr; gap: 24px; } }

  .p-projection-closing-card {
    display: flex; flex-direction: column; gap: 6px;
    padding: 22px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
  }
  .p-projection-closing-card--ceiling {
    background: linear-gradient(135deg, rgba(75,123,229,0.18), rgba(108,92,231,0.12));
    border-color: rgba(108,92,231,0.30);
  }
  .p-projection-closing-label {
    font-size: 0.625rem; font-weight: 700;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  .p-projection-closing-card--ceiling .p-projection-closing-label { color: #93b4ff; }
  .p-projection-closing-amount {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3.25rem);
    font-weight: 200;
    color: #fff;
    letter-spacing: -0.035em;
    line-height: 1;
    margin: 6px 0 4px;
  }
  .p-projection-closing-card--ceiling .p-projection-closing-amount {
    background: linear-gradient(120deg, #93b4ff 0%, #c4b5fd 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .p-projection-closing-detail {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.5;
    margin-top: 6px;
  }
  .p-projection-closing-bottom {
    margin: 0;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.55;
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 20px;
  }
  .p-projection-closing-bottom strong { color: #fff; font-weight: 600; }

  /* Dark template overrides for projection */
  .p-dark .p-demo-card { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.08); }
  .p-dark .p-demo-card-amount, .p-dark .p-demo-card-annual { color: #fff; }
  .p-dark .p-demo-card-meta, .p-dark .p-demo-card-period, .p-dark .p-demo-card-hint { color: rgba(255,255,255,0.55); }
  .p-dark .p-demo-card-annual { border-color: rgba(255,255,255,0.1); }
  .p-dark .p-matrix { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.08); }
  .p-dark .p-matrix-th, .p-dark .p-matrix-td { border-color: rgba(255,255,255,0.06); }
  .p-dark .p-matrix-th { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.7); }
  .p-dark .p-matrix-td--clients { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.7); }
  .p-dark .p-matrix-td--clients strong, .p-dark .p-matrix-amount, .p-dark .p-matrix-plan-name { color: #fff; }
  .p-dark .p-matrix-sub, .p-dark .p-matrix-plan-price { color: rgba(255,255,255,0.45); }
  .p-dark .p-matrix-note { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.65); }

  /* ¿Por qué SACS? */
  .p-why-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
    margin: 8px 0 36px;
  }
  @media (max-width: 720px) { .p-why-stats { grid-template-columns: repeat(2, 1fr); } }
  .p-why-stat {
    padding: 24px 16px;
    border-right: 1px solid #e5e5e5;
    text-align: left;
  }
  .p-why-stat:last-child { border-right: none; }
  @media (max-width: 720px) {
    .p-why-stat:nth-child(2) { border-right: none; }
    .p-why-stat:nth-child(1), .p-why-stat:nth-child(2) { border-bottom: 1px solid #e5e5e5; }
  }
  .p-why-stat-num {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 300;
    color: #1a1a1a;
    line-height: 1;
    letter-spacing: -0.025em;
    margin-bottom: 6px;
  }
  .p-why-stat-label {
    font-size: 0.6875rem; font-weight: 600;
    color: #999;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .p-why-pillars {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px 24px;
    margin-bottom: 40px;
  }
  @media (max-width: 720px) { .p-why-pillars { grid-template-columns: 1fr; } }

  .p-why-pillar { display: flex; flex-direction: column; gap: 4px; }
  .p-why-pillar-letter {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 200;
    color: #4B7BE5;
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .p-why-pillar-word {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-top: 4px;
    letter-spacing: -0.005em;
  }
  .p-why-pillar p {
    font-size: 0.875rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    margin: 6px 0 0;
  }

  .p-why-closing {
    display: flex; flex-direction: column; gap: 10px;
    padding: 28px;
    background: #1a1a1a;
    color: #fff;
    border-radius: 16px;
  }
  .p-why-closing strong {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: -0.01em;
  }
  .p-why-closing span {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
  }

  /* ─── Bienvenida storytelling (p-bw-*) ─────────────────────── */
  .p-bw-section {
    padding: 64px 0;
    border-top: 1px solid #ececec;
  }
  .p-bw-section--alt {
    background: #FAFAF8;
    margin: 0 -32px;
    padding: 64px 32px;
  }
  .p-bw-section--dark {
    background: #1A1A1A;
    color: #fff;
    margin: 0 -32px;
    padding: 72px 32px;
  }
  @media (max-width: 640px) {
    .p-bw-section { padding: 40px 0; }
    .p-bw-section--alt, .p-bw-section--dark { margin: 0 -20px; padding: 48px 20px; }
  }

  .p-bw-eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    color: #4B7BE5;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .p-bw-eyebrow--light { color: #93b4ff; }

  .p-bw-title {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 3.4vw, 2.375rem);
    font-weight: 300;
    color: #1A1A1A;
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin: 0 0 20px;
  }
  .p-bw-title--light { color: #fff; }

  .p-bw-lead {
    font-size: 1.0625rem;
    color: #555;
    line-height: 1.7;
    margin: 0 0 16px;
    max-width: 640px;
  }
  .p-bw-lead strong { color: #1a1a1a; }
  .p-bw-lead--light { color: rgba(255,255,255,0.78); }
  .p-bw-lead--light strong { color: #fff; }

  .p-bw-bullets {
    display: flex; flex-direction: column; gap: 12px;
    margin-top: 24px;
  }
  .p-bw-bullet {
    display: flex; gap: 12px;
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.55;
  }
  .p-bw-bullet-mark {
    color: #4B7BE5;
    font-weight: 700;
    flex-shrink: 0;
  }
  .p-bw-bullet strong { color: #1a1a1a; }

  /* Grid 2 col responsive */
  .p-bw-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 48px;
    align-items: start;
    margin-bottom: 32px;
  }
  .p-bw-grid--reverse { grid-template-columns: 1.4fr 1fr; }
  @media (max-width: 768px) {
    .p-bw-grid, .p-bw-grid--reverse { grid-template-columns: 1fr; gap: 24px; }
  }

  /* Pillars (triple impacto) */
  .p-bw-pillars {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-top: 32px;
  }
  .p-bw-pillar {
    padding: 24px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 10px;
  }
  .p-bw-pillar-num {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: #4B7BE5;
    letter-spacing: 0.04em;
    margin-bottom: 14px;
  }
  .p-bw-pillar-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: #1A1A1A;
    margin-bottom: 8px;
    letter-spacing: -0.005em;
  }
  .p-bw-pillar-detail {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.55;
  }

  /* Diff grid */
  .p-bw-diff-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 18px;
    margin-top: 32px;
  }
  .p-bw-diff {
    padding: 0 0 0 16px;
    border-left: 2px solid #4B7BE5;
  }
  .p-bw-diff-head {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1A1A1A;
    margin-bottom: 8px;
  }
  .p-bw-diff p {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.6;
    margin: 0;
  }

  /* Verticals — Squareup-style: image-first, generous spacing */
  .p-bw-verticals {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    margin-top: 48px;
  }
  @media (max-width: 720px) {
    .p-bw-verticals {
      grid-template-columns: 1fr;
      gap: 24px;
      margin-top: 36px;
    }
  }
  .p-bw-vertical {
    position: relative;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 1px 2px rgba(0,0,0,0.04);
  }
  .p-bw-vertical:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.08);
  }
  .p-bw-vertical-media {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: #f4f2ee;
  }
  .p-bw-vertical-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .p-bw-vertical:hover .p-bw-vertical-media img {
    transform: scale(1.04);
  }
  .p-bw-vertical-rank {
    position: absolute;
    top: 16px;
    left: 16px;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #1A1A1A;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 6px 10px;
    border-radius: 6px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }
  .p-bw-vertical-body {
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  @media (max-width: 720px) {
    .p-bw-vertical-body { padding: 22px 22px 26px; }
  }
  .p-bw-vertical-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.7rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    margin-bottom: 12px;
  }
  .p-bw-vertical-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent, #4B7BE5);
    flex-shrink: 0;
  }
  .p-bw-vertical-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: #1A1A1A;
    margin: 0 0 20px;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  @media (max-width: 720px) {
    .p-bw-vertical-name { font-size: 1.3125rem; margin-bottom: 16px; }
  }
  /* Módulos: lista elegante, no chips */
  .p-bw-vertical-modules {
    list-style: none;
    margin: 0 0 24px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .p-bw-vertical-module {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .p-bw-vertical-module-bullet {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent, #4B7BE5);
    margin-top: 9px;
    box-shadow: 0 0 0 3px var(--accent-bg, rgba(75, 123, 229, 0.12));
  }
  .p-bw-vertical-module-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
    flex: 1;
  }
  .p-bw-vertical-module-text strong {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1A1A1A;
    letter-spacing: -0.005em;
    line-height: 1.35;
  }
  .p-bw-vertical-module-text span {
    font-size: 0.8125rem;
    color: #666;
    line-height: 1.55;
  }
  .p-bw-vertical-foot {
    margin-top: auto;
    padding-top: 18px;
    font-size: 0.75rem;
    color: #999;
    font-weight: 500;
    letter-spacing: 0.005em;
    border-top: 1px solid #f0f0ee;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .p-bw-vertical-link {
    color: var(--accent, #4B7BE5);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.75rem;
    transition: opacity 0.18s;
  }
  .p-bw-vertical-link:hover { opacity: 0.7; }
  .p-bw-vertical-detail {
    font-size: 0.8125rem;
    color: #666;
    line-height: 1.5;
  }

  /* +70 más callout */
  .p-bw-verticals-more {
    margin-top: 28px;
    padding: 24px;
    background: linear-gradient(135deg, #FAFAF8 0%, #F4F4F2 100%);
    border: 1px dashed #d4d4d2;
    border-radius: 12px;
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }
  .p-bw-verticals-more-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #4B7BE5;
    color: #fff;
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 300;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .p-bw-verticals-more-body { flex: 1; }
  .p-bw-verticals-more-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: #1A1A1A;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .p-bw-verticals-more-text {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.6;
  }
  .p-bw-verticals-more-link {
    display: inline-block;
    margin-left: 6px;
    color: #4B7BE5;
    text-decoration: none;
    font-weight: 500;
  }
  .p-bw-verticals-more-link:hover { text-decoration: underline; }
  @media (max-width: 640px) {
    .p-bw-verticals-more {
      flex-direction: column;
      gap: 14px;
      padding: 20px;
    }
    .p-bw-verticals-more-icon { width: 40px; height: 40px; font-size: 1.5rem; }
  }

  /* Cases (clientes) */
  .p-bw-cases {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-top: 28px;
  }
  .p-bw-case {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 10px;
    overflow: hidden;
  }
  .p-bw-case-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
    background: #f5f5f5;
  }
  .p-bw-case-name {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1A1A1A;
    padding: 14px 16px 4px;
  }
  .p-bw-case-meta {
    font-size: 0.75rem;
    color: #888;
    padding: 0 16px 16px;
  }

  /* History (dark section) */
  .p-bw-history-img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    display: block;
  }
  .p-bw-history-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,0.12);
  }
  .p-bw-history-stat-num {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 3vw, 2.125rem);
    font-weight: 300;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 6px;
  }
  .p-bw-history-stat-label {
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.55);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  /* ─── Visión 1,000 embajadores ─── */
  .p-bw-vision {
    margin: 56px 0 0;
    padding: 64px 32px;
    background: linear-gradient(135deg, #4B7BE5 0%, #6C5CE7 50%, #1A1A1A 100%);
    border-radius: 16px;
    color: #fff;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .p-bw-vision::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 20%, rgba(255,255,255,0.10), transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(255,255,255,0.06), transparent 50%);
    pointer-events: none;
  }
  .p-bw-vision > * { position: relative; z-index: 1; }
  .p-bw-vision-eyebrow {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(255,255,255,0.14);
    color: rgba(255,255,255,0.92);
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .p-bw-vision-title {
    font-family: var(--font-display);
    margin: 0 0 20px;
    color: #fff;
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .p-bw-vision-num {
    display: block;
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 200;
    background: linear-gradient(120deg, #fff 0%, #B5D0FF 60%, #B49EFF 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .p-bw-vision-after {
    display: block;
    font-size: clamp(1.25rem, 2.6vw, 1.875rem);
    font-weight: 400;
    color: rgba(255,255,255,0.85);
    margin-top: 8px;
  }
  .p-bw-vision-lead {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: rgba(255,255,255,0.78);
    max-width: 580px;
    margin: 0 auto 36px;
    font-weight: 300;
  }

  .p-bw-tracker {
    max-width: 620px;
    margin: 0 auto;
    padding: 24px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px;
    backdrop-filter: blur(8px);
  }
  .p-bw-tracker-row {
    display: grid;
    grid-template-columns: 160px 1fr 100px;
    gap: 14px;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .p-bw-tracker-row:last-child { border-bottom: none; }
  .p-bw-tracker-row--soon { opacity: 0.55; }
  .p-bw-tracker-label {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.85);
    font-weight: 500;
    text-align: left;
  }
  .p-bw-tracker-bar {
    height: 8px;
    background: rgba(255,255,255,0.10);
    border-radius: 999px;
    overflow: hidden;
  }
  .p-bw-tracker-fill {
    height: 100%;
    background: linear-gradient(90deg, #6CD6C2 0%, #4B7BE5 100%);
    border-radius: 999px;
    transition: width 0.6s ease-out;
  }
  .p-bw-tracker-stat {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.75);
    text-align: right;
    font-family: var(--font-display);
  }
  .p-bw-tracker-stat strong { color: #fff; font-weight: 600; font-size: 1rem; }

  /* Group label dentro del tracker */
  .p-bw-tracker-group {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    padding: 14px 0 6px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 4px;
  }
  .p-bw-tracker-group:first-child { padding-top: 0; }

  /* Total row */
  .p-bw-tracker-total {
    margin-top: 18px;
    padding: 16px 18px;
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 10px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
  }
  .p-bw-tracker-total-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
  }
  .p-bw-tracker-total-num {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: #fff;
    font-weight: 500;
  }
  .p-bw-tracker-total-num strong {
    font-size: 1.75rem;
    font-weight: 600;
    color: #fff;
    margin-right: 4px;
  }
  .p-bw-tracker-total-num span {
    color: rgba(255,255,255,0.7);
    font-size: 0.875rem;
  }

  @media (max-width: 640px) {
    .p-bw-vision { margin: 32px 0 0; padding: 48px 20px; }
    .p-bw-tracker { padding: 18px; }
    .p-bw-tracker-row { grid-template-columns: 1fr; gap: 6px; padding: 12px 0; }
    .p-bw-tracker-stat { text-align: left; }
    .p-bw-tracker-total { flex-direction: column; align-items: flex-start; gap: 4px; }
    .p-bw-tracker-total-num { font-size: 1rem; }
    .p-bw-tracker-total-num strong { font-size: 1.5rem; }
  }

  /* ─── 10% para impacto ─── */
  .p-bw-impact {
    margin: 32px 0 0;
    padding: 72px 56px;
    background: linear-gradient(180deg, #FAFAF8 0%, #fff 100%);
    border: 1px solid #ececec;
    border-radius: 16px;
    text-align: center;
  }
  @media (max-width: 768px) {
    .p-bw-impact { padding: 48px 24px; }
  }
  .p-bw-impact-eyebrow {
    display: inline-block;
    padding: 6px 14px;
    background: rgba(42,181,160,0.12);
    color: #1A8F7A;
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .p-bw-impact-title {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 3.2vw, 2.375rem);
    font-weight: 400;
    color: #1A1A1A;
    margin: 0 auto 24px;
    letter-spacing: -0.02em;
    line-height: 1.2;
    max-width: 720px;
  }
  .p-bw-impact-lead {
    font-size: 1rem;
    color: #555;
    line-height: 1.7;
    margin: 0 auto 18px;
    max-width: 640px;
  }
  .p-bw-impact-lead strong { color: #1A1A1A; font-weight: 600; }
  @media (max-width: 768px) {
    .p-bw-impact-lead { font-size: 0.9375rem; }
  }

  /* CTA final */
  .p-bw-cta {
    margin-top: 48px;
    padding: 48px 32px;
    background: linear-gradient(120deg, rgba(75,123,229,0.06), rgba(108,92,231,0.04));
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 14px;
    text-align: center;
  }
  .p-bw-cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.4vw, 1.625rem);
    font-weight: 500;
    color: #1A1A1A;
    margin: 0 0 12px;
    letter-spacing: -0.015em;
  }
  .p-bw-cta-lead {
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.55;
    max-width: 460px;
    margin: 0 auto 22px;
  }
  .p-bw-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 26px;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 8px;
    font-size: 0.9375rem;
    font-weight: 600;
    transition: background 0.15s;
  }
  .p-bw-cta-btn:hover { background: #4B7BE5; }

  /* ─── Contenido y puntos (tab "Contenido") ─────────────────── */
  .p-content-howto {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
    margin: 32px 0;
  }
  .p-content-howto-item {
    display: flex; gap: 14px;
    padding: 18px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 10px;
  }
  .p-content-howto-num {
    flex-shrink: 0;
    width: 30px; height: 30px;
    border-radius: 50%;
    background: #fff;
    color: #4B7BE5;
    border: 1px solid #4B7BE5;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.875rem;
  }
  .p-content-howto-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 4px;
    letter-spacing: -0.005em;
  }
  .p-content-howto-detail {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.55;
    margin: 0;
  }

  .p-content-h3 {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.4vw, 1.625rem);
    font-weight: 500;
    color: #1A1A1A;
    margin: 48px 0 18px;
    letter-spacing: -0.015em;
  }

  .p-content-types-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    margin-bottom: 36px;
  }
  .p-content-type-card {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 12px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.18s;
  }
  .p-content-type-card:hover { border-color: #cfd6e2; }
  .p-content-type-card--bonus {
    background: linear-gradient(180deg, rgba(75,123,229,0.04), #fff);
    border-color: #4B7BE5;
  }
  .p-content-type-img-wrap {
    margin: -20px -20px 16px;
    height: 160px;
    overflow: hidden;
    border-radius: 12px 12px 0 0;
    background: #f5f5f5;
  }
  .p-content-type-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .p-content-type-head {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid #f0f0f0;
  }
  .p-content-type-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1A1A1A;
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }
  .p-content-type-meta {
    font-size: 0.6875rem;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .p-content-type-pts {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 300;
    color: #4B7BE5;
    letter-spacing: -0.02em;
    line-height: 1;
    flex-shrink: 0;
  }
  .p-content-type-pts span {
    font-size: 0.75rem;
    color: #999;
    margin-left: 2px;
    font-weight: 400;
  }
  .p-content-type-desc {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.55;
    margin: 0;
  }
  .p-content-type-ideas-label {
    font-size: 0.625rem;
    font-weight: 700;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    margin-bottom: 4px;
  }
  .p-content-type-ideas ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .p-content-type-ideas li {
    position: relative;
    padding-left: 14px;
    font-size: 0.8125rem;
    color: #666;
    line-height: 1.45;
  }
  .p-content-type-ideas li::before {
    content: '·';
    position: absolute;
    left: 4px;
    color: #4B7BE5;
    font-weight: 700;
  }
  .p-content-type-platforms {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding-top: 8px;
    border-top: 1px solid #f5f5f5;
  }
  .p-content-type-platform {
    font-size: 0.6875rem;
    padding: 3px 9px;
    background: #f5f5f7;
    color: #666;
    border-radius: 999px;
    font-weight: 500;
  }
  .p-content-type-refs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    font-size: 0.75rem;
    color: #888;
  }
  .p-content-type-refs-label {
    font-weight: 600;
  }
  .p-content-type-ref {
    color: #4B7BE5;
    text-decoration: none;
  }
  .p-content-type-ref:hover { text-decoration: underline; }

  .p-content-notes {
    margin-top: 20px;
    padding: 24px;
    background: #FAFAF8;
    border: 1px solid #ececec;
    border-radius: 12px;
  }
  .p-content-notes-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 12px;
    letter-spacing: -0.005em;
  }
  .p-content-notes ul {
    margin: 0;
    padding-left: 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .p-content-notes li {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.55;
  }
  .p-content-notes li strong { color: #1a1a1a; }

  /* ─── Proceso (Cómo funciona) ─────────────────────── */
  .p-proc-steps {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 32px;
  }
  .p-proc-step {
    display: flex;
    gap: 18px;
    padding: 22px 24px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 14px;
    transition: border-color 0.18s, transform 0.18s;
  }
  .p-proc-step:hover {
    border-color: #cfd6e2;
    transform: translateY(-1px);
  }
  .p-proc-step-num {
    flex-shrink: 0;
    width: 38px; height: 38px;
    border-radius: 50%;
    background: #1a1a1a;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1rem;
  }
  .p-proc-step-body {
    flex: 1;
    min-width: 0;
  }
  .p-proc-step-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }
  .p-proc-step-detail {
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.6;
    margin: 0 0 10px;
  }
  .p-proc-step-detail strong { color: #1a1a1a; font-weight: 700; }
  .p-proc-step-detail code {
    background: #f5f5f7;
    padding: 1px 6px;
    border-radius: 4px;
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 0.8125rem;
    color: #4B7BE5;
  }
  .p-proc-step-meta {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .p-proc-meta-pill {
    display: inline-block;
    padding: 4px 10px;
    background: rgba(75,123,229,0.10);
    color: #3764c4;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: 999px;
  }
  .p-proc-meta-pill--alt {
    background: rgba(42,181,160,0.10);
    color: #1A8F7A;
  }
  .p-proc-preview-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 6px;
    padding: 10px 16px;
    background: #1a1a1a;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .p-proc-preview-btn:hover { background: #4B7BE5; }

  .p-proc-cta {
    margin-top: 36px;
    text-align: center;
    padding: 28px;
    background: linear-gradient(120deg, rgba(75,123,229,0.06), rgba(108,92,231,0.04));
    border: 1px solid rgba(75,123,229,0.18);
    border-radius: 16px;
  }
  .p-proc-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 26px;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9375rem;
    transition: background 0.15s;
  }
  .p-proc-cta-btn:hover { background: #4B7BE5; }
  .p-proc-cta-arrow { font-size: 1.125rem; }

  @media (max-width: 640px) {
    .p-proc-step { padding: 18px 16px; gap: 14px; }
    .p-proc-step-num { width: 32px; height: 32px; font-size: 0.875rem; }
    .p-proc-step-title { font-size: 1rem; }
    .p-proc-step-detail { font-size: 0.875rem; }
  }

  /* ═══════════════════════════════════════════════════
     PREVIEW PORTAL · full-screen + 6 tabs navegables
     ═══════════════════════════════════════════════════ */
  .p-preview-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15,15,20,0.85);
    z-index: 9999;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .pp-app {
    min-height: 100vh;
    background: #f5f6f8;
    font-family: var(--font-body);
    color: #1a1a1a;
    display: flex;
    flex-direction: column;
  }

  /* Topbar */
  .pp-app-topbar {
    background: #fff;
    border-bottom: 1px solid #ececec;
    padding: 12px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .pp-app-topbar-left { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .pp-app-brand {
    font-family: 'Clash Display', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a1a;
    letter-spacing: -0.02em;
  }
  .pp-app-sep { color: #ccc; }
  .pp-app-subtitle { color: #888; font-size: 0.875rem; font-weight: 500; }
  .pp-app-preview-pill {
    margin-left: 6px;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #4B7BE5;
    background: rgba(75,123,229,0.10);
    padding: 4px 10px;
    border-radius: 999px;
  }
  .pp-app-topbar-right { display: flex; align-items: center; gap: 12px; }
  .pp-app-username { font-size: 0.875rem; color: #444; font-weight: 500; }
  .pp-app-avatar {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: linear-gradient(135deg, #4B7BE5, #6C5CE7);
    color: #fff;
    font-size: 0.8125rem;
    font-weight: 600;
    display: flex; align-items: center; justify-content: center;
  }
  .pp-app-close {
    background: #1a1a1a;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 8px 14px;
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .pp-app-close:hover { background: #000; }

  /* Body: sidebar + main */
  .pp-app-body { display: flex; flex: 1; min-height: 0; }

  /* Sidebar */
  .pp-app-sidebar {
    width: 240px;
    background: #fff;
    border-right: 1px solid #ececec;
    padding: 18px 14px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex-shrink: 0;
  }
  .pp-app-nav {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 16px;
    border-radius: 8px;
    font-size: 0.875rem;
    color: #555;
    font-weight: 500;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.15s, color 0.15s;
    text-decoration: none;
    font-family: inherit;
    width: 100%;
    letter-spacing: -0.005em;
  }
  .pp-app-nav:hover { background: #f5f5f7; color: #1a1a1a; }
  .pp-app-nav--active { background: #1a1a1a; color: #fff; }
  .pp-app-nav--active:hover { background: #1a1a1a; color: #fff; }
  .pp-app-nav-badge {
    margin-left: auto;
    background: #f0f0ee;
    color: #888;
    font-size: 0.6875rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 999px;
    font-style: normal;
  }
  .pp-app-nav--active .pp-app-nav-badge { background: rgba(255,255,255,0.18); color: #fff; }
  .pp-app-nav-ext { margin-left: auto; color: #4B7BE5; font-size: 0.75rem; }
  .pp-app-nav--external { color: #4B7BE5; }
  .pp-app-side-divider {
    height: 1px; background: #ececec; margin: 12px 4px;
  }
  .pp-app-sidebar-foot {
    margin-top: auto;
    padding: 14px;
    border-top: 1px solid #f0f0ee;
    background: #fafafa;
    border-radius: 8px;
  }
  .pp-app-foot-name { font-size: 0.875rem; font-weight: 600; color: #1a1a1a; }
  .pp-app-foot-meta { font-size: 0.75rem; color: #888; margin-top: 2px; }

  /* Main — Squareup-style: generous whitespace, max-width container */
  .pp-app-main {
    flex: 1;
    padding: 56px 64px 96px;
    overflow-y: auto;
    overflow-x: hidden;
    min-width: 0;
    background: #fafafa;
  }
  .pp-app-panel { display: none; max-width: 1040px; margin: 0 auto; }
  .pp-app-panel--active { display: block; }

  /* Tutorial banner — más sutil, menos invasivo */
  .pp-tut {
    display: flex;
    gap: 14px;
    padding: 18px 22px;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 14px;
    margin-bottom: 48px;
    align-items: flex-start;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-tut-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    background: #1a1a1a;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    font-style: italic;
    margin-top: 2px;
  }
  .pp-info-i {
    font-style: italic;
    font-weight: 700;
  }
  .pp-tut-body {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.65;
    flex: 1;
    padding-top: 4px;
  }
  .pp-tut-body strong { color: #1a1a1a; font-weight: 600; }
  .pp-tut-body em.pp-tag { font-size: 0.6875rem; padding: 2px 8px; vertical-align: middle; }

  /* Headings — más respiro, jerarquía clara */
  .pp-h1 {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 500;
    color: #1a1a1a;
    margin: 0 0 8px;
    letter-spacing: -0.025em;
    line-height: 1.15;
  }
  .pp-lead {
    font-size: 1rem;
    color: #888;
    margin-bottom: 56px;
    line-height: 1.5;
  }
  .pp-h2 {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 500;
    color: #1a1a1a;
    margin: 64px 0 24px;
    letter-spacing: -0.02em;
  }
  .pp-h2:first-of-type { margin-top: 0; }
  .pp-h3 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 500;
    color: #1a1a1a;
    margin: 0 0 16px;
    letter-spacing: -0.015em;
  }

  /* KPI row — auto-fit + más padding + sombra sutil */
  .pp-kpi-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 8px;
  }
  .pp-kpi-row--3 { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
  .pp-kpi {
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 14px;
    padding: 28px 26px;
    position: relative;
    transition: box-shadow 0.2s, transform 0.2s;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-kpi::before {
    content: '';
    position: absolute;
    top: 26px;
    left: 26px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent, #ececec);
  }
  .pp-kpi-lbl {
    font-size: 0.6875rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    margin-bottom: 14px;
    padding-left: 16px;
  }
  .pp-kpi-val {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 1;
    letter-spacing: -0.035em;
  }
  .pp-kpi-hint {
    font-size: 0.8125rem;
    color: #999;
    margin-top: 10px;
    line-height: 1.4;
  }

  /* Annotation note — más limpia, menos fondo */
  .pp-note {
    margin: 24px 0 0;
    padding: 16px 22px;
    background: rgba(75,123,229,0.04);
    border-radius: 10px;
    font-size: 0.875rem;
    color: #555;
    line-height: 1.65;
    display: flex;
    gap: 4px;
  }
  .pp-note strong { color: #1a1a1a; font-weight: 600; }
  .pp-note--inline {
    margin: 16px 0 0;
    font-size: 0.8125rem;
    padding: 12px 16px;
    background: #fafafa;
  }

  /* Tables — más respiro entre rows, sin border duro */
  .pp-table {
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 14px;
    overflow: hidden;
    font-size: 0.875rem;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-trow {
    display: grid;
    grid-template-columns: 2fr 1fr 1.2fr 1fr;
    gap: 18px;
    padding: 18px 24px;
    border-bottom: 1px solid #f5f5f5;
    align-items: center;
  }
  .pp-table--5col .pp-trow {
    grid-template-columns: 1.4fr 1.4fr 1.3fr 1fr 0.7fr;
  }
  .pp-trow:last-child { border-bottom: none; }
  .pp-trow--head {
    font-size: 0.6875rem;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    background: #fafafa;
    padding: 14px 24px;
  }
  .pp-trow--cancelled { opacity: 0.45; }
  .pp-trow--cancelled span:not(:has(em)) { text-decoration: line-through; }
  .pp-trow--cancelled em.pp-tag { opacity: 1; }
  .pp-cell-meta {
    font-size: 0.8125rem;
    color: #888;
    font-style: normal;
    margin-top: 2px;
    display: inline-block;
  }
  .pp-tag {
    display: inline-block;
    padding: 4px 10px;
    background: #f5f5f7;
    color: #666;
    border-radius: 999px;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-style: normal;
    line-height: 1.4;
  }
  .pp-tag--ok    { background: rgba(42,181,160,0.12); color: #1A8F7A; }
  .pp-tag--blue  { background: rgba(75,123,229,0.12); color: #3764c4; }
  .pp-tag--amber { background: rgba(232,168,56,0.14); color: #b07b15; }
  .pp-tag--err   { background: rgba(220,38,38,0.10); color: #c62828; }
  .pp-link {
    color: #4B7BE5;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    display: inline-block;
    margin-top: 20px;
  }
  .pp-link:hover { text-decoration: underline; }

  /* Bars (top fuentes) — más espacio */
  .pp-bars { display: flex; flex-direction: column; gap: 14px; }
  .pp-bar {
    display: grid;
    grid-template-columns: 2fr 3fr 90px;
    gap: 20px;
    align-items: center;
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 12px;
    padding: 18px 22px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-bar-lbl { font-size: 0.9375rem; color: #1a1a1a; font-weight: 500; }
  .pp-bar-fill {
    height: 8px;
    background: #f5f5f3;
    border-radius: 999px;
    position: relative;
    overflow: hidden;
  }
  .pp-bar-fill::after {
    content: '';
    position: absolute;
    inset: 0;
    width: var(--w, 0);
    background: linear-gradient(90deg, #6CD6C2 0%, #4B7BE5 100%);
    border-radius: 999px;
  }
  .pp-bar-num { font-size: 0.875rem; color: #555; text-align: right; font-weight: 600; }

  /* Filters — más limpios */
  .pp-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
    align-items: center;
  }
  .pp-filters:last-of-type { margin-bottom: 28px; }
  .pp-filters-lbl {
    font-size: 0.6875rem;
    font-weight: 600;
    color: #999;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-right: 6px;
  }
  .pp-filter {
    padding: 8px 14px;
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 999px;
    font-size: 0.8125rem;
    color: #666;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    font-family: inherit;
  }
  .pp-filter:hover { background: #fafafa; color: #1a1a1a; }
  .pp-filter--active { background: #1a1a1a; color: #fff; border-color: #1a1a1a; }
  .pp-filter--active:hover { background: #1a1a1a; color: #fff; }
  .pp-filter-sep { width: 1px; height: 20px; background: #ececec; margin: 0 6px; }
  .pp-foot-stats {
    margin-top: 28px;
    padding: 16px 22px;
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 12px;
    font-size: 0.875rem;
    color: #666;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-foot-stats strong { color: #1a1a1a; }

  /* Payouts — Squareup style cards */
  .pp-payout {
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 14px;
    padding: 24px 28px;
    margin-bottom: 14px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-payout--next {
    background: linear-gradient(135deg, rgba(75,123,229,0.05), rgba(42,181,160,0.03));
    border-color: rgba(75,123,229,0.20);
    margin-bottom: 28px;
  }
  .pp-payout-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 12px;
  }
  .pp-payout-eyebrow {
    font-size: 0.6875rem;
    font-weight: 600;
    color: #4B7BE5;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .pp-payout-date {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: #1a1a1a;
    letter-spacing: -0.015em;
  }
  .pp-payout-ref {
    font-size: 0.75rem;
    color: #aaa;
    margin-top: 4px;
    font-family: 'SF Mono', 'Courier New', monospace;
  }
  .pp-payout-amount {
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 500;
    color: #1A8F7A;
    letter-spacing: -0.025em;
  }
  .pp-payout--next .pp-payout-amount { color: #4B7BE5; }
  .pp-payout-detail { font-size: 0.875rem; color: #666; line-height: 1.5; }
  .pp-payout-detail summary {
    cursor: pointer;
    color: #4B7BE5;
    font-weight: 500;
    padding: 4px 0;
    list-style-position: inside;
  }
  .pp-payout-list {
    list-style: none;
    margin: 14px 0 0;
    padding: 16px 18px;
    background: #fafafa;
    border-radius: 10px;
  }
  .pp-payout-list li {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px dashed #ececec;
    font-size: 0.8125rem;
    color: #444;
    gap: 12px;
  }
  .pp-payout-list li:last-child { border-bottom: none; }
  .pp-payout-list--detail li {
    align-items: flex-start;
    padding: 12px 0;
  }
  .pp-payout-list--detail li > div:first-child {
    flex: 1;
    line-height: 1.5;
  }
  .pp-payout-list--detail li strong {
    color: #1a1a1a;
    white-space: nowrap;
    flex-shrink: 0;
    text-align: right;
    font-size: 0.9375rem;
  }
  .pp-payout-list--detail .pp-cell-meta {
    display: block;
    margin-top: 4px;
    line-height: 1.5;
  }

  .pp-payout-meta-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    padding: 14px 0;
    margin: 12px 0;
    border-top: 1px solid #f0f0ee;
    border-bottom: 1px solid #f0f0ee;
  }
  .pp-meta-lbl {
    font-size: 0.625rem;
    font-weight: 600;
    color: #999;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .pp-meta-val {
    font-size: 0.875rem;
    color: #1a1a1a;
    font-weight: 500;
  }
  .pp-meta-val a { color: #4B7BE5; text-decoration: none; }
  .pp-meta-val a:hover { text-decoration: underline; }

  /* Funnel — más generoso */
  .pp-funnel {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }
  .pp-funnel-step {
    flex: 1;
    min-width: 130px;
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 14px;
    padding: 22px 16px;
    text-align: center;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-funnel-step--win {
    background: linear-gradient(135deg, rgba(42,181,160,0.08), rgba(75,123,229,0.04));
    border-color: rgba(42,181,160,0.25);
  }
  .pp-funnel-num {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 1;
    letter-spacing: -0.035em;
  }
  .pp-funnel-step--win .pp-funnel-num { color: #1A8F7A; }
  .pp-funnel-lbl {
    font-size: 0.6875rem;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    margin-top: 10px;
  }
  .pp-funnel-arrow { color: #d0d0d0; font-size: 1.25rem; flex-shrink: 0; }

  /* Mi link tab — Squareup style */
  .pp-link-card {
    background: #1a1a1a;
    color: #fff;
    border-radius: 16px;
    padding: 32px 36px;
    margin-bottom: 40px;
  }
  .pp-link-url {
    font-family: 'SF Mono', 'Courier New', monospace;
    font-size: 1.125rem;
    margin-bottom: 22px;
    word-break: break-all;
    line-height: 1.5;
  }
  .pp-link-url-protocol { color: rgba(255,255,255,0.45); }
  .pp-link-url-path { color: #fff; }
  .pp-link-url-path strong { color: #6CD6C2; font-weight: 600; }
  .pp-link-actions { display: flex; gap: 10px; flex-wrap: wrap; }

  .pp-link-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 24px;
    margin-bottom: 40px;
  }
  .pp-link-block {
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 14px;
    padding: 28px 28px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-share-row { display: flex; flex-wrap: wrap; gap: 10px; }
  .pp-share {
    background: #fafafa;
    border: 1px solid #f0f0ee;
    color: #1a1a1a;
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.15s, border-color 0.15s;
  }
  .pp-share:hover { background: #fff; border-color: #d4d4d2; }
  .pp-qr {
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 10px;
    padding: 18px;
    aspect-ratio: 1;
    max-width: 220px;
    margin: 0 auto;
  }
  .pp-qr-pattern {
    width: 100%; height: 100%;
    position: relative;
    background:
      linear-gradient(90deg, #1a1a1a 50%, transparent 50%),
      linear-gradient(0deg, #1a1a1a 50%, transparent 50%),
      #fff;
    background-size: 12px 12px;
    background-blend-mode: multiply;
  }
  .pp-qr-eye {
    position: absolute;
    width: 38px; height: 38px;
    background: #1a1a1a;
    border: 6px solid #fff;
    box-shadow: inset 0 0 0 4px #1a1a1a, inset 0 0 0 8px #fff, inset 0 0 0 13px #1a1a1a;
  }
  .pp-qr-eye--tl { top: 0; left: 0; }
  .pp-qr-eye--tr { top: 0; right: 0; }
  .pp-qr-eye--bl { bottom: 0; left: 0; }

  .pp-templates {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .pp-template {
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 14px;
    padding: 22px 24px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-template-head {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 14px;
  }
  .pp-template-body {
    background: #fafaf8;
    border-radius: 10px;
    padding: 16px 18px;
    font-size: 0.8125rem;
    color: #555;
    line-height: 1.6;
    margin-bottom: 14px;
  }

  /* Mi perfil tab — más respiro entre secciones */
  .pp-perfil-section {
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 14px;
    padding: 32px 36px;
    margin-bottom: 22px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-perfil-section--highlight {
    background: linear-gradient(135deg, rgba(42,181,160,0.05), rgba(75,123,229,0.03));
    border-color: rgba(42,181,160,0.20);
  }
  .pp-section-sub {
    font-size: 0.875rem;
    color: #888;
    margin: -8px 0 24px;
    line-height: 1.5;
  }
  .pp-form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .pp-field { display: flex; flex-direction: column; gap: 8px; }
  .pp-field--full { grid-column: 1 / -1; }
  .pp-field > span {
    font-size: 0.6875rem;
    font-weight: 600;
    color: #999;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .pp-field input,
  .pp-field select {
    padding: 13px 16px;
    font-family: inherit;
    font-size: 0.9375rem;
    color: #1a1a1a;
    border: 1px solid #ececec;
    border-radius: 10px;
    background: #fafafa;
    outline: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .pp-field input:focus,
  .pp-field select:focus { border-color: #4B7BE5; background: #fff; }
  .pp-field input[readOnly] { color: #555; }

  /* Payout method radios (in perfil) */
  .pp-payout-methods {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .pp-method {
    display: flex;
    gap: 16px;
    padding: 22px 24px;
    border: 1px solid #f0f0ee;
    border-radius: 12px;
    background: #fafafa;
    cursor: pointer;
    align-items: flex-start;
    transition: border-color 0.15s, background 0.15s;
  }
  .pp-method:hover { border-color: #d4d4d2; }
  .pp-method--active { border-color: #1a1a1a; background: #fff; box-shadow: 0 1px 2px rgba(0,0,0,0.02); }
  .pp-method input[type="radio"] {
    margin-top: 4px;
    accent-color: #1a1a1a;
    flex-shrink: 0;
    width: 16px; height: 16px;
  }
  .pp-method-body { flex: 1; }
  .pp-method-head {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .pp-method-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .pp-method-note {
    grid-column: 1 / -1;
    font-size: 0.8125rem;
    color: #888;
    margin: 6px 0 0;
    line-height: 1.5;
  }

  .pp-firma-display {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 18px;
    align-items: center;
  }
  .pp-firma-box {
    border: 1px solid #ececec;
    border-radius: 8px;
    padding: 14px;
    background: #fafaf8;
  }
  .pp-firma-meta {
    font-size: 0.8125rem;
    color: #555;
    line-height: 1.7;
  }
  .pp-firma-meta strong { color: #1a1a1a; font-weight: 600; }
  .pp-firma-meta a { display: inline-block; margin-top: 8px; }

  .pp-fideliza-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    background: rgba(255,255,255,0.7);
    border-radius: 10px;
    margin-top: 4px;
  }
  .pp-fideliza-status {
    font-family: var(--font-display);
    font-weight: 600;
    color: #1A8F7A;
    margin-bottom: 4px;
  }
  .pp-fideliza-renew { font-size: 0.8125rem; color: #666; }

  /* Buttons inside portal */
  .pp-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px 16px;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    text-decoration: none;
  }
  .pp-btn--primary { background: #fff; color: #1a1a1a; }
  .pp-link-card .pp-btn--primary { background: #6CD6C2; color: #1a1a1a; }
  .pp-link-card .pp-btn--primary:hover { background: #5fc4b1; }
  .pp-btn--ghost { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.25); }
  .pp-perfil-section .pp-btn--primary { background: #1a1a1a; color: #fff; }
  .pp-perfil-section .pp-btn--ghost { background: #fafafa; color: #1a1a1a; border: 1px solid #ececec; }

  /* Brand kit panel */
  .pp-bk-logos {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 12px;
  }
  .pp-bk-logo {
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 14px;
    padding: 22px 24px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-bk-logo-preview {
    aspect-ratio: 16/9;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }
  .pp-bk-logo-meta { margin-bottom: 14px; }
  .pp-bk-logo-meta strong {
    display: block;
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 4px;
  }
  .pp-bk-logo-meta span {
    font-size: 0.8125rem;
    color: #888;
  }
  .pp-bk-logo-actions { display: flex; gap: 8px; }
  .pp-bk-logo-actions .pp-btn {
    background: #fafafa;
    color: #1a1a1a;
    border: 1px solid #f0f0ee;
    font-size: 0.8125rem;
    padding: 8px 12px;
  }

  .pp-bk-colors {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 14px;
  }
  .pp-bk-color {
    aspect-ratio: 1;
    border-radius: 14px;
    padding: 18px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 4px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-bk-color strong {
    font-family: 'SF Mono', 'Courier New', monospace;
    font-size: 0.875rem;
    font-weight: 600;
  }
  .pp-bk-color span { font-size: 0.75rem; opacity: 0.85; }

  .pp-bk-fonts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .pp-bk-font {
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 14px;
    padding: 32px 28px 24px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-bk-font-meta { margin-top: 18px; padding-top: 14px; border-top: 1px solid #f0f0ee; }
  .pp-bk-font-meta strong {
    display: block;
    font-family: var(--font-display);
    font-size: 0.875rem;
    color: #1a1a1a;
    margin-bottom: 4px;
  }
  .pp-bk-font-meta span { font-size: 0.75rem; color: #888; }

  .pp-bk-templates {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
  }
  .pp-bk-template {
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-bk-template-preview {
    width: 100%;
    overflow: hidden;
    display: flex;
  }
  .pp-bk-template-meta { padding: 16px 18px; }
  .pp-bk-template-meta strong {
    display: block;
    font-family: var(--font-display);
    font-size: 0.875rem;
    color: #1a1a1a;
    margin-bottom: 4px;
  }
  .pp-bk-template-meta span { font-size: 0.75rem; color: #888; }

  /* Cuenta SACS panel */
  .pp-cuenta-plan {
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d44 100%);
    color: #fff;
    border-radius: 16px;
    padding: 32px 36px;
    margin-bottom: 32px;
  }
  .pp-cuenta-plan-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 18px;
    flex-wrap: wrap;
  }
  .pp-cuenta-plan-eyebrow {
    font-size: 0.6875rem;
    font-weight: 600;
    color: #6CD6C2;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .pp-cuenta-plan-name {
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 500;
    color: #fff;
    margin-bottom: 6px;
    letter-spacing: -0.025em;
  }
  .pp-cuenta-plan-meta {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
  }
  .pp-cuenta-plan .pp-btn { flex-shrink: 0; }

  .pp-quick-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .pp-quick {
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 14px;
    padding: 24px 22px;
    text-decoration: none;
    color: #1a1a1a;
    transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-quick:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0,0,0,0.06);
    border-color: #d4d4d2;
  }
  .pp-quick-icon {
    font-size: 1.75rem;
    line-height: 1;
    margin-bottom: 14px;
  }
  .pp-quick-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 4px;
  }
  .pp-quick-desc {
    font-size: 0.8125rem;
    color: #888;
  }

  /* ─── Tu cuenta SACS · access card ─── */
  .pp-access-card {
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 14px;
    padding: 28px 32px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-access-row {
    display: grid;
    grid-template-columns: 200px 1fr auto;
    gap: 24px;
    align-items: center;
    padding: 16px 0;
    border-bottom: 1px solid #f5f5f3;
  }
  .pp-access-row:last-of-type { border-bottom: none; }
  .pp-access-lbl {
    font-size: 0.75rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }
  .pp-access-val {
    font-size: 0.9375rem;
    color: #1a1a1a;
    font-weight: 500;
  }
  .pp-access-val--mono {
    font-family: 'SF Mono', 'Courier New', monospace;
    font-size: 0.875rem;
    letter-spacing: -0.005em;
  }
  .pp-access-val a { color: #4B7BE5; text-decoration: none; }
  .pp-access-val a:hover { text-decoration: underline; }
  .pp-access-cta {
    display: block;
    margin-top: 18px;
    padding: 14px 20px;
    background: #1a1a1a;
    color: #fff;
    border-radius: 10px;
    text-align: center;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9375rem;
    transition: background 0.15s;
  }
  .pp-access-cta:hover { background: #000; }

  /* ─── Vigencia grid ─── */
  .pp-vig-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .pp-vig-card {
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 14px;
    padding: 24px 26px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-vig-card--accent {
    background: linear-gradient(135deg, rgba(42,181,160,0.05), rgba(75,123,229,0.03));
    border-color: rgba(42,181,160,0.20);
  }
  .pp-vig-lbl {
    font-size: 0.6875rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    margin-bottom: 12px;
  }
  .pp-vig-val {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 1;
    letter-spacing: -0.025em;
    margin-bottom: 8px;
  }
  .pp-vig-card--accent .pp-vig-val { color: #1A8F7A; }
  .pp-vig-hint { font-size: 0.8125rem; color: #888; line-height: 1.4; }

  /* ─── Lo que incluye Plan Fideliza ─── */
  .pp-incl-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .pp-incl {
    display: flex;
    gap: 14px;
    padding: 18px 22px;
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 12px;
    align-items: flex-start;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-incl-check {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    background: rgba(42,181,160,0.12);
    color: #1A8F7A;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.75rem;
    margin-top: 2px;
  }
  .pp-incl-body { flex: 1; min-width: 0; }
  .pp-incl-body strong {
    display: block;
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 4px;
    letter-spacing: -0.005em;
  }
  .pp-incl-body span {
    font-size: 0.8125rem;
    color: #666;
    line-height: 1.55;
    display: block;
  }

  /* ─── Mi participación ─── */
  .pp-part-status {
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 16px;
    padding: 32px 36px;
    margin-bottom: 32px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-part-status-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    margin-bottom: 22px;
    flex-wrap: wrap;
  }
  .pp-part-status-eyebrow {
    font-size: 0.75rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .pp-part-status-num {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: #888;
    font-weight: 400;
  }
  .pp-part-status-num strong {
    font-size: 3rem;
    font-weight: 500;
    color: #1a1a1a;
    letter-spacing: -0.035em;
    line-height: 1;
    display: inline-block;
    margin-right: 6px;
  }
  .pp-part-status-meta {
    text-align: right;
    color: #666;
    font-size: 0.9375rem;
  }
  .pp-part-status-meta strong { color: #1a1a1a; }
  .pp-part-bar {
    position: relative;
    height: 12px;
    background: #f5f5f3;
    border-radius: 999px;
    overflow: visible;
  }
  .pp-part-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #6CD6C2 0%, #4B7BE5 100%);
    border-radius: 999px;
    transition: width 0.6s ease-out;
  }
  .pp-part-bar-mark {
    position: absolute;
    top: -4px;
    width: 2px;
    height: 20px;
    background: #1a1a1a;
    transform: translateX(-1px);
  }
  .pp-part-status-foot {
    margin-top: 14px;
    font-size: 0.8125rem;
    color: #888;
  }

  .pp-puntos-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .pp-puntos-card {
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 12px;
    padding: 20px 22px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
  }
  .pp-puntos-pts {
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 12px;
  }
  .pp-puntos-name {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 4px;
  }
  .pp-puntos-desc { font-size: 0.75rem; color: #888; line-height: 1.4; }

  .pp-trow--add {
    background: #fafafa;
  }
  .pp-trow--add > span {
    grid-column: 1 / -1 !important;
  }

  /* ─── Actualizaciones ─── */
  .pp-actu-next {
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d44 100%);
    color: #fff;
    border-radius: 16px;
    padding: 32px 36px;
    margin-bottom: 32px;
  }
  .pp-actu-next-eyebrow {
    font-size: 0.6875rem;
    font-weight: 600;
    color: #6CD6C2;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .pp-actu-next-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 32px;
    align-items: start;
  }
  .pp-actu-next-date {
    font-size: 0.8125rem;
    color: #6CD6C2;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .pp-actu-next-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: #fff;
    margin-bottom: 14px;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }
  .pp-actu-next-desc {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    margin-bottom: 18px;
  }
  .pp-actu-next-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.65);
  }
  .pp-actu-next-meta strong { color: #fff; font-weight: 500; }
  .pp-actu-next-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: stretch;
  }
  .pp-actu-next-actions .pp-btn { width: 100%; justify-content: center; }

  .pp-rec-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .pp-rec {
    background: #fff;
    border: 1px solid #f0f0ee;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(0,0,0,0.02);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .pp-rec:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0,0,0,0.06);
  }
  .pp-rec-thumb {
    aspect-ratio: 16/9;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pp-rec-play {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(255,255,255,0.95);
    color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    backdrop-filter: blur(4px);
  }
  .pp-rec-duration {
    position: absolute;
    bottom: 12px;
    right: 12px;
    background: rgba(0,0,0,0.65);
    color: #fff;
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 4px 8px;
    border-radius: 6px;
  }
  .pp-rec-body {
    padding: 18px 20px 20px;
  }
  .pp-rec-month {
    font-size: 0.6875rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .pp-rec-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 14px;
    letter-spacing: -0.005em;
    line-height: 1.35;
  }
  .pp-rec-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  /* Mobile */
  @media (max-width: 1100px) {
    .pp-app-main { padding: 48px 40px 80px; }
  }
  @media (max-width: 900px) {
    .pp-app-sidebar { width: 220px; padding: 18px 12px; }
    .pp-app-main { padding: 40px 32px 64px; }
    .pp-link-grid { grid-template-columns: 1fr; }
    .pp-templates { grid-template-columns: 1fr; }
    .pp-h1 { font-size: 1.875rem; }
    .pp-h2 { font-size: 1.25rem; margin-top: 48px; }
    .pp-perfil-section { padding: 26px 28px; }
    .pp-payout-meta-grid { grid-template-columns: repeat(2, 1fr); }
    .pp-bk-logos, .pp-bk-fonts { grid-template-columns: 1fr; }
    .pp-bk-templates { grid-template-columns: 1fr 1fr; }
    .pp-bk-colors { grid-template-columns: repeat(3, 1fr); }
    .pp-quick-grid { grid-template-columns: 1fr 1fr; }
    .pp-vig-grid { grid-template-columns: 1fr; }
    .pp-incl-grid { grid-template-columns: 1fr; }
    .pp-puntos-grid { grid-template-columns: repeat(2, 1fr); }
    .pp-actu-next-grid { grid-template-columns: 1fr; gap: 22px; }
    .pp-rec-grid { grid-template-columns: 1fr 1fr; }
    .pp-access-row { grid-template-columns: 1fr; gap: 8px; }
    .pp-access-row > div:last-of-type { justify-self: start; }
  }
  @media (max-width: 720px) {
    .pp-app-topbar { padding: 12px 16px; flex-wrap: wrap; gap: 10px; }
    .pp-app-preview-pill { display: none; }
    .pp-app-username { display: none; }
    .pp-app-body { flex-direction: column; }
    .pp-app-sidebar {
      width: 100%;
      flex-direction: row;
      overflow-x: auto;
      gap: 6px;
      border-right: none;
      border-bottom: 1px solid #ececec;
      padding: 12px 16px;
    }
    .pp-app-nav { white-space: nowrap; flex-shrink: 0; padding: 8px 16px; font-size: 0.8125rem; }
