    gap: 20px;
    margin-bottom: 24px;
  }
  @media (max-width: 720px) { .p-projection-closing-stack { grid-template-columns: 1fr; gap: 24px; } }

  .p-projection-closing-card {
    display: flex; flex-direction: column; gap: 6px;
    padding: 22px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
  }
  .p-projection-closing-card--ceiling {
    background: linear-gradient(135deg, rgba(75,123,229,0.18), rgba(108,92,231,0.12));
    border-color: rgba(108,92,231,0.30);
  }
  .p-projection-closing-label {
    font-size: 0.625rem; font-weight: 700;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  .p-projection-closing-card--ceiling .p-projection-closing-label { color: #93b4ff; }
  .p-projection-closing-amount {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3.25rem);
    font-weight: 200;
    color: #fff;
    letter-spacing: -0.035em;
    line-height: 1;
    margin: 6px 0 4px;
  }
  .p-projection-closing-card--ceiling .p-projection-closing-amount {
    background: linear-gradient(120deg, #93b4ff 0%, #c4b5fd 100%);
