---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { supabase } from '../../../lib/supabase';
import PartnerSidebar from '../../../components/partner/PartnerSidebar.astro';

export const prerender = false;

const { id } = Astro.params;
const isAdminMode = Astro.url.searchParams.has('admin');

const { data: invitation } = await supabase
  .from('partner_invitations')
  .select('*')
  .eq('id', id)
  .maybeSingle();

if (!invitation) return Astro.redirect('/404');

// Auto-expire if vigencia passed
const isExpired = invitation.vigencia && new Date(invitation.vigencia) < new Date();
if (isExpired && invitation.estado === 'sent') {
  await supabase.from('partner_invitations').update({ estado: 'expired' }).eq('id', id);
  invitation.estado = 'expired';
}

// Mark as viewed (first opening, not by admin)
if (invitation.estado === 'draft' || invitation.estado === 'sent') {
  if (!isAdminMode && invitation.estado === 'sent') {
    // Track view via activity (non-blocking)
    try {
      await supabase.from('activities').insert({
        tipo: 'sistema',
        titulo: `Invitación de partner vista por prospecto`,
        metadata: { partner_invitation_id: id, partner_invitation_numero: invitation.numero },
        automatico: true,
      });
    } catch {}
  }
}

// Parse meta from notas (firma_base64 etc.)
const NOTAS_SEP = '\n---META---\n';
const notasIdx = (invitation.notas || '').indexOf(NOTAS_SEP);
const meta = notasIdx >= 0 ? (() => {
  try { return JSON.parse(invitation.notas.slice(notasIdx + NOTAS_SEP.length)); } catch { return {}; }
})() : {};

const template = invitation.template || 'modern';
const tipo = invitation.tipo || 'embajador';
const moneda = invitation.moneda || 'MXN';
const comisionPct = Number(invitation.comision_pct ?? 50);
const costoUnico = Number(invitation.costo_unico ?? 0);
const costoMensual = Number(invitation.costo_mensual ?? 0);

const beneficios: any[] = Array.isArray(invitation.beneficios) ? invitation.beneficios : [];
const compromisos: any[] = Array.isArray(invitation.compromisos) ? invitation.compromisos : [];
const tabulador: any = invitation.tabulador && typeof invitation.tabulador === 'object' ? invitation.tabulador : {};

const isAccepted = invitation.estado === 'accepted';
const isDeclined = invitation.estado === 'declined';
const isSubmitted = invitation.estado === 'submitted_for_review';
const isClosed = isAccepted || isDeclined || isSubmitted;

const fmt = (n: number) => n === 0 ? 'Gratis' : '$' + Math.round(n).toLocaleString('es-MX');
const fmtMoney = (n: number) => '$' + Math.round(n).toLocaleString('es-MX');
const fmtDate = (d: string | null) => {
  if (!d) return '';
  const date = new Date(d.length === 10 ? d + 'T12:00:00' : d);
  if (isNaN(date.getTime())) return '';
  const day = date.getDate();
  const month = date.toLocaleDateString('es-MX', { month: 'short' }).replace('.', '');
  const year = date.getFullYear();
  return `${day}/${month}/${year}`;
};
const fmtDateLong = (d: string | null) => {
  if (!d) return '';
  const date = new Date(d.length === 10 ? d + 'T12:00:00' : d);
  if (isNaN(date.getTime())) return '';
  const day = date.getDate();
  const month = date.toLocaleDateString('es-MX', { month: 'long' });
  const year = date.getFullYear();
  return `${day} de ${month} de ${year}`;
};

const fechaCreado = fmtDate(invitation.created_at);
const vigenciaFecha = fmtDate(invitation.vigencia);
const vigenciaLarga = fmtDateLong(invitation.vigencia);

const tipoLabel: Record<string, string> = {
  embajador: 'Embajador SACS',
  distribuidor: 'Distribuidor Autorizado',
  integrador: 'Integrador Certificado',
  reseller: 'Reseller',
  consultor: 'Consultor Partner',
};
const tipoTagline: Record<string, string> = {
  embajador: 'Difunde, recomienda y crece con SACS. Tu voz mueve marcas.',
  distribuidor: 'Vende SACS a tu red. Comisiones recurrentes mientras estén activos.',
  integrador: 'Implementa SACS en clientes B2B. Soporte técnico y handoff cualificado.',
  reseller: 'Modelo white-label para vender SACS bajo tu marca o canal.',
  consultor: 'Asesora a clientes en su transformación digital con SACS.',
};

const heroEyebrow = `Invitación · Programa Partners`;
const heroTitle = invitation.nombre;
const heroSubtitle = tipoTagline[tipo] || '';

const tabsDef = [
  { id: 'bienvenida', label: 'Bienvenida', show: true },
  { id: 'proceso',    label: 'Cómo funciona', show: true },
  { id: 'terminos', label: 'Términos', show: true },
  { id: 'compromisos', label: 'Compromisos', show: compromisos.length > 0 },
  { id: 'tabulador', label: 'Tabulador', show: Object.keys(tabulador).length > 0 },
  { id: 'potencial', label: 'Tu potencial', show: comisionPct > 0 },
  { id: 'porque', label: '¿Por qué SACS?', show: true },
  { id: 'firma', label: isAccepted ? 'Firmada' : (isDeclined ? 'Rechazada' : (isSubmitted ? 'En revisión' : 'Aceptar y firmar')), show: true },
];
const visibleTabs = tabsDef.filter(t => t.show).map(({ id, label }) => ({ id, label }));
const initialTab = isClosed ? 'firma' : 'bienvenida';

// ─── Projection data: SACS plan pricing (MXN) y escenarios ───
// monthly = precio público mensual del plan
// annualTotal = precio público anual del plan (con descuento de 2 meses)
const SACS_PLANS = [
  { id: 'vende',      name: 'Vende',      monthly: 600,  annualTotal: 6000,  accent: '#94A3B8', tagline: 'Para marcas que arrancan' },
  { id: 'controla',   name: 'Controla',   monthly: 900,  annualTotal: 9000,  accent: '#4B7BE5', tagline: 'Multi-sucursal con orden' },
  { id: 'fideliza',   name: 'Fideliza',   monthly: 1400, annualTotal: 14000, accent: '#6C5CE7', tagline: 'Más popular',   highlighted: true },
  { id: 'automatiza', name: 'Automatiza', monthly: 5900, annualTotal: 59000, accent: '#1a1a1a', tagline: 'Operación con IA' },
];
const CLIENT_TIERS = [10, 20, 50, 100, 200, 500];

// Escenarios de actividad mensual: usuarios que se registran a prueba gratis
// (entran por tu link único) y demos completadas (asisten al demo válido).
const DEMO_SCENARIOS = [
  { label: 'Conservador', pruebas_gratis: 4,  completadas: 2,  hint: '~5 horas/mes de difusión' },
  { label: 'Realista',    pruebas_gratis: 10, completadas: 6,  hint: '~10 horas/mes de difusión' },
  { label: 'Ambicioso',   pruebas_gratis: 25, completadas: 15, hint: 'Tiempo completo' },
];

const ratePartner = comisionPct / 100;
// Defaults: $500 por prueba gratis, $300 por demo completada — tomados del
// tabulador si vienen, si no usamos los valores por defecto del programa.
const bonusPruebaGratis = Number(tabulador.prueba_gratis ?? 500);
const bonusCompletada   = Number(tabulador.demo_completada ?? 300);

// Per-cell calculation: clientes × precio_plan × comision%
function calcSale(planPrice: number, clients: number) {
  return Math.round(planPrice * clients * ratePartner);
}
function calcDemoMonthly(s: typeof DEMO_SCENARIOS[0]) {
  return s.pruebas_gratis * bonusPruebaGratis + s.completadas * bonusCompletada;
}

// Big closing number — best case fideliza × 100 (realista) y automatiza × 500 (techo)
const realisticClosingMonthly = calcSale(SACS_PLANS[2].monthly,     100); // Fideliza × 100 mensual
const realisticClosingAnnual  = calcSale(SACS_PLANS[2].annualTotal, 100); // Fideliza × 100 anual
const ceilingClosingMonthly   = calcSale(SACS_PLANS[3].monthly,     500); // Automatiza × 500 mensual
const ceilingClosingAnnual    = calcSale(SACS_PLANS[3].annualTotal, 500); // Automatiza × 500 anual

// Cuota mínima anual: 10 sucursales — usado en la sección "¿Por qué te conviene cumplir?"
const minQuotaFidelizaAnnual   = calcSale(SACS_PLANS[2].annualTotal, 10); // 10 × Fideliza anual
const minQuotaAutomatizaAnnual = calcSale(SACS_PLANS[3].annualTotal, 10); // 10 × Automatiza anual

const beneficioIcons: Record<string, string> = {
  gift: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>',
  percent: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>',
  academy: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>',
  community: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>',
  reward: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>',
  leads: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>',
  broadcast: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 11-5.8-1.6"/></svg>',
  calendar: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
  link: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>',
  dashboard: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>',
  wallet: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 010-4h14v4"/><path d="M3 5v14a2 2 0 002 2h16v-5"/><path d="M18 12a2 2 0 000 4h4v-4z"/></svg>',
  default: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>',
};

const partnerLandingUrl = invitation.slug_landing
  ? `https://www.sacscloud.com/p/${invitation.slug_landing}`
  : `https://www.sacscloud.com/p/${(invitation.numero || '').toLowerCase()}`;
---

<BaseLayout
  title={`Invitación Partner ${invitation.numero || ''} — SACS`}
  description={`Programa de partners SACS para ${invitation.nombre}`}
  noindex={true}
  bareLayout={true}
>

<div class:list={['p-layout', `p-layout--${template}`]}>
  <aside class="p-layout-sidebar no-print">
    <PartnerSidebar
      tabs={visibleTabs}
      initialTab={initialTab}
      numero={invitation.numero}
      nombre={invitation.nombre}
      tipo={tipo}
      comisionPct={comisionPct}
      template={template}
      isAccepted={isAccepted}
      isDeclined={isDeclined}
      isExpired={!!isExpired}
      vigenciaFecha={vigenciaFecha}
    />
  </aside>

  <div class:list={['p-page', `p-${template}`]} id="partner-doc" data-initial-tab={initialTab}>
    <div class="p-container">

      <!-- Header -->
      <div class="p-header">
        <div class="p-header-brand">
          <span class="p-logo-text">Sacs</span>
          <span class="p-logo-tag">Partners</span>
        </div>
        <div class="p-header-meta">
          {isAccepted && <span class="p-status p-status--accepted"><span class="p-status-dot"></span>Firmada</span>}
          {isDeclined && <span class="p-status p-status--declined"><span class="p-status-dot"></span>Rechazada</span>}
          {isExpired && !isClosed && <span class="p-status p-status--expired"><span class="p-status-dot"></span>Vencida</span>}
          {!isExpired && !isClosed && <span class="p-status p-status--active"><span class="p-status-dot"></span>Activa</span>}
          <div class="p-numero">{invitation.numero}</div>
          <div class="p-fecha">Emitida {fechaCreado}</div>
          {!isClosed && !isExpired && vigenciaFecha && (
            <div class="p-fecha">Vigente hasta {vigenciaFecha}</div>
          )}
        </div>
      </div>

      <!-- TAB: BIENVENIDA -->
      <section class="p-tab-panel" data-tab="bienvenida">
        <div class="p-hero">
          <div class="p-hero-eyebrow">{heroEyebrow}</div>
          <h1 class="p-hero-title">
            {invitation.nombre},<br/>
            <span class="p-hero-title-soft">queremos que seas</span><br/>
            <span class="p-hero-title-strong">{tipoLabel[tipo] || tipo}</span>.
          </h1>
          <p class="p-hero-sub">{heroSubtitle}</p>

          <div class="p-hero-stats">
            <div class="p-hero-stat">
              <div class="p-hero-stat-num">{comisionPct}<span class="p-hero-stat-pct">%</span></div>
              <div class="p-hero-stat-label">Comisión por venta directa</div>
            </div>
            {(bonusPruebaGratis > 0 || bonusCompletada > 0) ? (
              <div class="p-hero-stat">
                <div class="p-hero-stat-num">{bonusPruebaGratis > 0 ? fmtMoney(bonusPruebaGratis) : fmtMoney(bonusCompletada)}</div>
                <div class="p-hero-stat-label">{bonusPruebaGratis > 0 ? 'Por prueba gratis activada' : 'Por demo completada'}</div>
              </div>
            ) : (costoMensual > 0 || costoUnico > 0) ? (
              <div class="p-hero-stat">
                <div class="p-hero-stat-num">{costoMensual > 0 ? fmtMoney(costoMensual) : fmtMoney(costoUnico)}</div>
                <div class="p-hero-stat-label">{costoMensual > 0 ? 'Cuota mensual' : 'Cuota única'}</div>
              </div>
            ) : (
              <div class="p-hero-stat">
                <div class="p-hero-stat-num">Sin costo</div>
                <div class="p-hero-stat-label">Acceso al programa</div>
              </div>
            )}
            <div class="p-hero-stat">
              <div class="p-hero-stat-num">3K+</div>
              <div class="p-hero-stat-label">Marcas en la red SACS</div>
            </div>
          </div>

          <div class="p-hero-quick">
            <div class="p-hero-quick-row">
              <span class="p-hero-quick-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span>Lo que sigue: revisa beneficios, términos y firma cuando estés listo.</span>
            </div>
          </div>
        </div>

        <!-- Index -->
        <div class="p-tab-intro-nav">
          {visibleTabs.filter(t => t.id !== 'bienvenida' && t.id !== 'firma').map(t => (
            <a href={`#${t.id}`} class="p-tab-intro-link" data-tab-link={t.id}>
              <span class="p-tab-intro-link-label">{t.label}</span>
              <span class="p-tab-intro-link-arrow">→</span>
            </a>
          ))}
        </div>
      </section>

      <!-- TAB: PROCESO / Cómo funciona -->
      <section class="p-tab-panel" data-tab="proceso">
        <div class="p-section-head">
          <div class="p-section-eyebrow">El proceso, paso a paso</div>
          <h2 class="p-section-title">Cómo funciona ser partner SACS</h2>
          <p class="p-section-lead">
            Desde que firmas tu invitación hasta que cobras tu primera comisión.
            Sin sorpresas, sin letras chicas.
          </p>
        </div>

        <div class="p-proc-steps">
          <!-- Step 1 -->
          <div class="p-proc-step">
            <div class="p-proc-step-num">1</div>
            <div class="p-proc-step-body">
              <div class="p-proc-step-title">Llena el formulario y firma</div>
              <p class="p-proc-step-detail">
                Datos personales, dirección del negocio, datos de cobro
                (CLABE, PayPal o Mercado Pago) y firma digital. Te toma
                <strong>~5 minutos</strong>. Una vez enviado, queda en revisión.
              </p>
              <div class="p-proc-step-meta">
                <span class="p-proc-meta-pill">~5 min</span>
              </div>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="p-proc-step">
            <div class="p-proc-step-num">2</div>
            <div class="p-proc-step-body">
              <div class="p-proc-step-title">Revisión por el equipo SACS</div>
              <p class="p-proc-step-detail">
                Validamos tus datos, confirmamos vigencia y comisión, y revisamos
                tu información de cobro. Si falta algo, te escribimos por correo.
                Tiempo de respuesta: <strong>3 a 5 días hábiles</strong>.
              </p>
              <div class="p-proc-step-meta">
                <span class="p-proc-meta-pill">3–5 días hábiles</span>
              </div>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="p-proc-step">
            <div class="p-proc-step-num">3</div>
            <div class="p-proc-step-body">
              <div class="p-proc-step-title">Aprobación + tu link único</div>
              <p class="p-proc-step-detail">
                Te enviamos por <strong>correo y WhatsApp</strong> tu código
                de partner, tu link único (ej. <code>sacscloud.com/p/tu-nombre</code>)
                y un link para crear tu contraseña del portal. Cualquier prospecto
                que llegue por tu link queda atribuido a ti automáticamente.
              </p>
              <div class="p-proc-step-meta">
                <span class="p-proc-meta-pill p-proc-meta-pill--alt">Email + WhatsApp</span>
              </div>
            </div>
          </div>

          <!-- Step 4 — Panel preview -->
          <div class="p-proc-step">
            <div class="p-proc-step-num">4</div>
            <div class="p-proc-step-body">
              <div class="p-proc-step-title">Tu panel personal de partner</div>
              <p class="p-proc-step-detail">
                Entras a tu portal con tu correo y contraseña — desde laptop,
                tablet o teléfono. Ves todo lo que está pasando con tu link en
                tiempo real: comisiones, pagos, prospectos, brand kit.
              </p>
              <button type="button" class="p-proc-preview-btn" id="btn-open-preview">
                Ver preview del panel →
              </button>
            </div>
          </div>

          <!-- Step 5 -->
          <div class="p-proc-step">
            <div class="p-proc-step-num">5</div>
            <div class="p-proc-step-body">
              <div class="p-proc-step-title">Reunión de onboarding 1-on-1</div>
              <p class="p-proc-step-detail">
                Sesión privada de <strong>45 minutos</strong> donde te enseñamos
                la plataforma SACS, dónde encontrar cada cosa, cómo aprenderla,
                y resolvemos cualquier duda. Activamos tu cuenta SACS en plan
                Fideliza para tu propio negocio (valor $14,000 MXN/año).
              </p>
              <div class="p-proc-step-meta">
                <span class="p-proc-meta-pill">45 min · 1-on-1</span>
              </div>
            </div>
          </div>

          <!-- Step 6 -->
          <div class="p-proc-step">
            <div class="p-proc-step-num">6</div>
            <div class="p-proc-step-body">
              <div class="p-proc-step-title">Reuniones trimestrales</div>
              <p class="p-proc-step-detail">
                Cada 3 meses revisamos juntos cómo va tu programa: mejores
                prácticas, contenido que funcionó, nuevos materiales, feedback
                directo al equipo de producto. Es donde el modelo se mejora —
                con tu voz incluida.
              </p>
              <div class="p-proc-step-meta">
                <span class="p-proc-meta-pill p-proc-meta-pill--alt">Cada 3 meses</span>
              </div>
            </div>
          </div>
        </div>

        <div class="p-proc-cta">
          <a href="#firma" class="p-proc-cta-btn" data-tab-link="firma">
            Estoy listo · ir a firmar
            <span class="p-proc-cta-arrow">→</span>
          </a>
        </div>
      </section>

      <!-- Modal: Preview del panel de partner -->
      <div class="p-preview-overlay" id="preview-overlay" style="display:none">
        <div class="p-preview-modal">
          <div class="p-preview-header">
            <div>
              <div class="p-preview-eyebrow">Preview · Portal de partner</div>
              <div class="p-preview-title">Esto es lo que vas a ver al entrar</div>
            </div>
            <button type="button" class="p-preview-close" id="btn-close-preview" aria-label="Cerrar">✕</button>
          </div>

          <div class="p-preview-body">
            {/* Mockup visual del panel */}
            <div class="pp-mock">
              {/* Topbar */}
              <div class="pp-mock-topbar">
                <span class="pp-mock-brand">Sacs</span>
                <span class="pp-mock-sep">·</span>
                <span class="pp-mock-subtitle">Portal de partner</span>
                <div style="flex:1"></div>
                <span class="pp-mock-username">{invitation.nombre}</span>
              </div>

              <div class="pp-mock-body">
                {/* Sidebar */}
                <aside class="pp-mock-sidebar">
                  <div class="pp-mock-side-item pp-mock-side-item--active">
                    <span>📊</span><span>Resumen</span>
                  </div>
                  <div class="pp-mock-side-item"><span>💰</span><span>Comisiones</span></div>
