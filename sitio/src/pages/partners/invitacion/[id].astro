    gap: 32px 24px;
    margin-bottom: 40px;
  }
  @media (max-width: 720px) { .p-why-pillars { grid-template-columns: 1fr; } }

  .p-why-pillar { display: flex; flex-direction: column; gap: 4px; }
  .p-why-pillar-letter {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 200;
    color: #4B7BE5;
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .p-why-pillar-word {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-top: 4px;
    letter-spacing: -0.005em;
  }
  .p-why-pillar p {
    font-size: 0.875rem;
    color: rgba(26,26,46,0.65);
