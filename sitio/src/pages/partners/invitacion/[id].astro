  I18N['who.note'] = {
    es: `<strong>Mismo programa, mismas oportunidades, sin límite de crecimiento.</strong> Donde sea que arranques, inviertes en tu paquete de licencias Fideliza al mayoreo (desde ${minStr}) y las revendes a precio público quedándote con el margen — más pagos cada 30 días y la red de partners SACS detrás tuyo.`,
