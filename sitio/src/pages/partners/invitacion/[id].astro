  .p-input:focus { border-color: #4B7BE5; box-shadow: 0 0 0 3px rgba(75,123,229,0.10); }
  textarea.p-input { resize: vertical; min-height: 80px; }

  .p-sign-canvas-wrap {
    padding: 18px;
    background: #fafafa;
    border: 1px solid #ececec;
    border-radius: 12px;
  }
  .p-sign-canvas-label {
    font-size: 0.6875rem; font-weight: 600;
    color: #999;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .p-sign-canvas {
    width: 100%; height: 180px;
    background: #fafaf8;
    border: 1px dashed #d0d0d0;
    border-radius: 8px;
    cursor: crosshair;
    touch-action: none;
    display: block;
  }
  .p-sign-canvas-actions {
    display: flex; justify-content: flex-end;
    margin-top: 10px;
  }

  .p-sign-legal {
    margin-top: 18px;
    font-size: 0.75rem;
    color: rgba(26,26,46,0.55);
    line-height: 1.55;
  }
  .p-sign-legal a { color: #4B7BE5; text-decoration: none; }
  .p-sign-legal a:hover { text-decoration: underline; }

  .p-sign-actions {
    display: flex; flex-direction: column; gap: 10px;
    margin-top: 24px;
  }

  /* Buttons */
  .p-btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 14px 22px;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 10px;
    border: 1px solid transparent;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }
  .p-btn--primary {
    background: #1a1a1a;
    color: #fff;
    padding: 16px 24px;
    font-size: 0.9375rem;
  }
  .p-btn--primary:hover { background: #4B7BE5; color: #fff; transform: translateY(-1px); }
  .p-btn--ghost {
    background: transparent;
    color: rgba(26,26,46,0.65);
    border-color: #e5e5e5;
  }
  .p-btn--ghost:hover { color: #1a1a1a; border-color: #1a1a1a; }

  /* Signed state */
  .p-signed {
    padding: 56px 0;
    text-align: center;
    max-width: 540px;
    margin: 0 auto;
  }
  .p-signed-eyebrow {
    font-size: 0.6875rem; font-weight: 700; color: #2AB5A0;
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 18px;
  }
  .p-signed--declined .p-signed-eyebrow { color: #b93333; }
  .p-signed--expired .p-signed-eyebrow { color: #888; }
  .p-signed-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 300;
    color: #1a1a1a;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 16px;
  }
  .p-signed-sub {
    font-size: 1rem;
    color: rgba(26,26,46,0.65);
    line-height: 1.55;
    margin-bottom: 28px;
  }
  .p-signed-img {
    max-width: 240px; height: auto;
    margin: 0 auto 12px;
    display: block;
  }
  .p-signed-label { font-size: 0.875rem; font-weight: 600; color: #1a1a1a; }
  .p-signed-date { font-size: 0.75rem; color: #999; margin-top: 2px; }
  .p-signed-meta {
    margin-top: 16px;
    font-size: 0.875rem;
    color: rgba(26,26,46,0.65);
  }
  .p-signed-cta-row {
    margin-top: 24px;
    display: inline-flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .p-signed-cta {
    display: inline-block;
    padding: 14px 28px;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9375rem;
    transition: background 0.15s ease;
  }
  .p-signed-cta:hover { background: #4B7BE5; color: #fff; }
  .p-signed-cta-secondary {
    display: inline-block;
    padding: 14px 28px;
    background: transparent;
    color: #1a1a1a;
    text-decoration: none;
    border: 1px solid #e5e5e5;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9375rem;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .p-signed-cta-secondary:hover { border-color: #1a1a1a; color: #1a1a1a; text-decoration: none; }

  /* Footer */
  .p-footer {
    display: flex; justify-content: space-between; align-items: center;
    padding: 32px 0;
    border-top: 1px solid #e5e5e5;
    margin-top: 48px;
    flex-wrap: wrap; gap: 12px;
  }
  .p-footer-brand { display: flex; align-items: baseline; gap: 10px; }
  .p-footer-logo { font-family: var(--font-logo, var(--font-display)); font-size: 1.125rem; font-weight: 700; color: #1a1a1a; }
  .p-footer-tagline { font-size: 0.75rem; color: #999; }
  .p-footer-contact { font-size: 0.75rem; color: #999; letter-spacing: 0.01em; }
  @media (max-width: 640px) {
    .p-footer { padding: 24px 0; margin-top: 32px; flex-direction: column; align-items: flex-start; gap: 8px; }
    .p-footer-contact { font-size: 0.6875rem; }
  }

  /* Modal */
  .p-modal-overlay {
    position: fixed; inset: 0; z-index: 1000;
    background: rgba(0,0,0,0.5);
    display: flex; align-items: center; justify-content: center;
    padding: 24px;
  }
  .p-modal {
    background: #fff;
    width: 100%; max-width: 500px;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.2);
    display: flex; flex-direction: column;
  }
  .p-modal-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 20px 24px;
    border-bottom: 1px solid #f0f0f0;
  }
  .p-modal-title { font-family: var(--font-display); font-size: 1rem; font-weight: 600; color: #1a1a1a; }
  .p-modal-close {
    background: transparent; border: none; cursor: pointer;
    font-size: 1rem; color: #999;
    padding: 4px 8px;
  }
  .p-modal-body { padding: 24px; }
  .p-modal-text { margin: 0 0 16px; font-size: 0.875rem; color: rgba(26,26,46,0.65); line-height: 1.55; }
  .p-decline-reasons { display: flex; flex-direction: column; gap: 8px; }
  .p-decline-reason {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 12px 14px;
    background: #fafafa;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    font-size: 0.875rem;
    color: rgba(26,26,46,0.75);
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .p-decline-reason:hover { border-color: #4B7BE5; background: rgba(75,123,229,0.04); }
  .p-decline-reason input { margin-top: 2px; }
  .p-modal-footer {
    display: flex; gap: 10px; justify-content: flex-end;
    padding: 16px 24px;
    border-top: 1px solid #f0f0f0;
    background: #fafafa;
  }

  /* Dark template overrides */
  .p-dark, .p-dark .p-container { background: #0f1115; color: #fff; }
  .p-dark .p-header { border-color: rgba(255,255,255,0.08); }
  .p-dark .p-logo-text, .p-dark .p-numero, .p-dark .p-section-title,
  .p-dark .p-hero-title, .p-dark .p-benefit-title, .p-dark .p-term-label,
  .p-dark .p-term-value, .p-dark .p-commit-title, .p-dark .p-payout-amount,
  .p-dark .p-payout-name, .p-dark .p-why-stat-num, .p-dark .p-why-pillar-word,
  .p-dark .p-signed-title, .p-dark .p-signed-label, .p-dark .p-landing-url,
  .p-dark .p-footer-logo { color: #fff; }
  .p-dark .p-section-lead, .p-dark .p-hero-sub, .p-dark .p-benefit-detail,
  .p-dark .p-term-detail, .p-dark .p-commit-detail, .p-dark .p-payout-detail,
  .p-dark .p-why-pillar p, .p-dark .p-signed-sub, .p-dark .p-landing-detail,
  .p-dark .p-payout-notes p, .p-dark .p-terms-extra-text { color: rgba(255,255,255,0.65); }
  .p-dark .p-fecha, .p-dark .p-hero-stat-label, .p-dark .p-why-stat-label,
  .p-dark .p-tab-intro-link-arrow, .p-dark .p-footer-tagline, .p-dark .p-footer-contact,
  .p-dark .p-sign-canvas-label, .p-dark .p-sign-field > span,
  .p-dark .p-signed-date { color: rgba(255,255,255,0.45); }
  .p-dark .p-terms, .p-dark .p-term-row, .p-dark .p-commits, .p-dark .p-commit-row,
  .p-dark .p-tab-intro-nav, .p-dark .p-tab-intro-link, .p-dark .p-hero-stats,
  .p-dark .p-why-stats, .p-dark .p-why-stat, .p-dark .p-footer { border-color: rgba(255,255,255,0.08); }
  .p-dark .p-benefit-card, .p-dark .p-payout-card:not(.p-payout-card--featured),
  .p-dark .p-payout-notes, .p-dark .p-terms-extra { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.08); }
  .p-dark .p-tab-intro-link { color: #fff; }
  .p-dark .p-tab-intro-link:hover { color: #93b4ff; }
  .p-dark .p-input { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.1); color: #fff; }
  .p-dark .p-input:focus { border-color: #93b4ff; box-shadow: 0 0 0 3px rgba(147,180,255,0.15); }
  .p-dark .p-sign-canvas-wrap { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.08); }
  .p-dark .p-sign-canvas { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.15); }
  .p-dark .p-btn--primary { background: #fff; color: #1a1a1a; }
  .p-dark .p-btn--primary:hover { background: #4B7BE5; color: #fff; }
  .p-dark .p-btn--ghost { color: rgba(255,255,255,0.7); border-color: rgba(255,255,255,0.15); }
  .p-dark .p-btn--ghost:hover { color: #fff; border-color: #fff; }

  /* ─── Perfiles en filas alternadas (estilo certificaciones) ── */
  .p-perfil-rows {
    display: flex;
    flex-direction: column;
    gap: 18px;
    margin: 28px 0 18px;
  }
  .p-perfil-row {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: 0;
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 14px;
    overflow: hidden;
    transition: border-color 0.18s, transform 0.18s, box-shadow 0.18s;
  }
  .p-perfil-row:hover {
    border-color: #cfd6e2;
    transform: translateY(-1px);
    box-shadow: 0 10px 28px -16px rgba(26,26,46,0.18);
  }
  .p-perfil-row--reverse { grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr); }
  .p-perfil-row--reverse .p-perfil-row-media { order: 2; }
  .p-perfil-row--reverse .p-perfil-row-body  { order: 1; }

  .p-perfil-row-media {
    position: relative;
    overflow: hidden;
    background: #f5f5f5;
    min-height: 100%;
  }
  .p-perfil-row-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .p-perfil-row-tag {
    position: absolute;
    top: 14px; left: 14px;
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: #fff;
    background: rgba(26,26,26,0.80);
    padding: 5px 11px;
    border-radius: 999px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .p-perfil-row-body {
    padding: 28px 30px 26px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    justify-content: center;
  }
  .p-perfil-row-num {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    color: #4B7BE5;
    letter-spacing: 0.10em;
    margin-bottom: -2px;
  }
  .p-perfil-row-title {
    font-family: var(--font-display);
    font-size: clamp(1.0625rem, 1.8vw, 1.25rem);
    font-weight: 600;
    color: #1a1a1a;
    margin: 0;
    letter-spacing: -0.015em;
    line-height: 1.25;
  }
  .p-perfil-row-desc {
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.6;
    margin: 0;
  }
  .p-perfil-row-from {
    margin-top: 6px;
    padding-top: 12px;
    border-top: 1px solid #f0f0f0;
    font-size: 0.6875rem;
    font-weight: 600;
    color: #4B7BE5;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  @media (max-width: 720px) {
    .p-perfil-row,
    .p-perfil-row--reverse {
      grid-template-columns: 1fr;
    }
    .p-perfil-row--reverse .p-perfil-row-media { order: 0; }
    .p-perfil-row--reverse .p-perfil-row-body  { order: 0; }
    .p-perfil-row-media { aspect-ratio: 16 / 10; min-height: 0; }
    .p-perfil-row-body { padding: 22px 22px 22px; }
  }

  .p-paths-note {
    margin: 18px 0 24px;
    padding: 16px 22px;
    background: #fff;
    border: 1px solid #ececec;
    border-left: 3px solid #4B7BE5;
    border-radius: 10px;
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.6;
  }
  .p-paths-note strong { color: #1a1a1a; font-weight: 600; }

  /* ─── Language switcher · select dropdown bonito ─── */
  .p-langswitch {
    display: flex;
    justify-content: flex-end;
    padding: 10px 32px 0;
  }
  @media (max-width: 1023px) { .p-langswitch { padding: 10px 20px 0; } }
  .p-langswitch-wrap {
    position: relative;
    display: inline-block;
    pointer-events: auto;
  }
  /* Visible "current" pill */
  .p-langswitch-current {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 12px 7px 11px;
    background: #1a1a1a;
    color: #fff;
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    border: 1px solid #1a1a1a;
    pointer-events: none;
    transition: background 0.15s;
  }
  .p-langswitch-wrap:hover .p-langswitch-current { background: #333; }
  .p-langswitch-flag { font-size: 1rem; line-height: 1; }
  .p-langswitch-code { line-height: 1; }
  .p-langswitch-caret { opacity: 0.7; margin-left: 2px; }
  /* Select transparente encima del pill, captura clicks */
  .p-langswitch-select {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    border: none;
    background: transparent;
    appearance: none;
    -webkit-appearance: none;
  }
  .p-langswitch-select:focus + .p-langswitch-current,
  .p-langswitch-select:focus-visible + .p-langswitch-current {
    outline: 2px solid #4B7BE5;
    outline-offset: 2px;
  }
  /* Reordenar: select primero (z-index encima) + visual current debajo */
  .p-langswitch-wrap { display: inline-flex; }
  .p-langswitch-wrap > .p-langswitch-select { order: 1; }
  .p-langswitch-wrap > .p-langswitch-current { order: 0; }
  @media (max-width: 640px) {
    .p-langswitch-current { padding: 8px 14px 8px 12px; font-size: 0.8125rem; min-height: 36px; }
    .p-langswitch-flag { font-size: 1.0625rem; }
  }

  /* ─── Aviso legal del contrato (vista localizada) ─── */
  .p-contract-legal-notice {
    margin-top: 12px;
    padding: 10px 14px;
    background: rgba(180, 130, 40, 0.08);
    border: 1px solid rgba(180, 130, 40, 0.22);
    border-radius: 8px;
    font-size: 0.75rem;
    color: #6b4d18;
    line-height: 1.45;
  }

  /* ─── Banner localizado (cuando lang ≠ es) ─────────── */
  .p-localized-banner {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    padding: 12px 16px;
    background: rgba(75,123,229,0.13);
    border: 1px solid rgba(75,123,229,0.38);
    border-left: 3px solid #4B7BE5;
    border-radius: 10px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #1a4a85;
    line-height: 1.45;
  }
  .p-localized-icon { font-size: 1rem; flex-shrink: 0; }

  /* ─── TL;DR · resumen rápido ─────────────────────── */
  .p-tldr {
    margin: 28px 0 0;
    padding: 24px 28px;
    background: linear-gradient(135deg, rgba(75,123,229,0.06), rgba(75,123,229,0.02));
    border: 1px solid rgba(75,123,229,0.20);
    border-left: 3px solid #4B7BE5;
    border-radius: 14px;
  }
  .p-tldr-eyebrow {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: #4B7BE5;
    margin-bottom: 4px;
  }
  .p-tldr-title {
    font-family: var(--font-display);
    font-size: clamp(1.0625rem, 2vw, 1.25rem);
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 14px;
    letter-spacing: -0.01em;
  }
  .p-tldr-list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: tldr;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .p-tldr-list li {
    counter-increment: tldr;
    position: relative;
    padding-left: 32px;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: #1a1a1a;
  }
  .p-tldr-list li::before {
    content: counter(tldr);
    position: absolute;
    left: 0; top: 0;
    width: 22px; height: 22px;
    border-radius: 50%;
    background: #4B7BE5;
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    display: flex; align-items: center; justify-content: center;
  }
  .p-tldr-list li strong { font-weight: 600; color: #1a1a1a; }
  @media (max-width: 600px) { .p-tldr { padding: 20px 22px; } }

  /* ─── Glosario · términos al pie ───────────────────── */
  .p-glos {
    max-width: 760px;
    margin: 48px auto 24px;
    padding: 0 32px;
  }
  @media (max-width: 1023px) { .p-glos { padding: 0 20px; } }
  .p-glos details {
    background: #fff;
    border: 1px solid #ececec;
    border-radius: 14px;
    overflow: hidden;
  }
  .p-glos-summary {
    list-style: none;
    cursor: pointer;
    padding: 18px 22px;
    display: flex;
    align-items: center;
    gap: 14px;
    transition: background 0.18s;
  }
  .p-glos-summary::-webkit-details-marker { display: none; }
  .p-glos-summary:hover { background: #fafaf8; }
  .p-glos-eyebrow {
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: #4B7BE5;
  }
  .p-glos-title {
    flex: 1;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: #1a1a1a;
    letter-spacing: -0.005em;
  }
  .p-glos-toggle {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 300;
    color: #888;
    width: 22px; height: 22px;
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.22s;
  }
  details[open] .p-glos-toggle { transform: rotate(45deg); color: #4B7BE5; }
  .p-glos-body {
    padding: 4px 22px 22px;
    border-top: 1px solid #f0f0f0;
  }
  .p-glos-list {
    margin: 0; padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px 28px;
  }
  @media (max-width: 720px) { .p-glos-list { grid-template-columns: 1fr; } }
  .p-glos-item dt {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 4px;
    letter-spacing: -0.005em;
  }
  .p-glos-item dd {
    margin: 0;
    font-size: 0.8125rem;
    color: #555;
    line-height: 1.55;
  }

  /* ─── FAB: botones flotantes (WhatsApp + Print) ───── */
  .p-fab {
    position: fixed;
    bottom: 22px;
    right: 22px;
    z-index: 60;
    display: flex;
    flex-direction: column;
    gap: 10px;
    opacity: 0;
    transform: translateY(12px);
    pointer-events: none;
    transition: opacity 0.22s, transform 0.22s;
  }
  .p-fab.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .p-fab-btn {
    width: 52px; height: 52px;
    border-radius: 50%;
    border: 0;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 20px -4px rgba(26,26,46,0.30);
    transition: transform 0.18s, box-shadow 0.18s;
    color: #fff;
    text-decoration: none;
  }
  .p-fab-btn:hover {
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 12px 28px -4px rgba(26,26,46,0.40);
  }
  .p-fab-btn--wa {
    background: #25D366;
  }
  .p-fab-btn--print {
    background: #1a1a1a;
  }
  @media (max-width: 600px) {
    .p-fab { bottom: 16px; right: 16px; }
    .p-fab-btn { width: 48px; height: 48px; }
  }

  /* ─── Carta del founder ─────────────────────────────── */
  .p-letter {
    margin: 28px 0 0;
    padding: 32px 36px 30px;
    background: linear-gradient(180deg, #fafaf8 0%, #fff 100%);
    border: 1px solid #ececec;
    border-radius: 16px;
    position: relative;
  }
  .p-letter-eyebrow {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #4B7BE5;
    margin-bottom: 16px;
  }
  .p-letter-body {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    color: #1a1a1a;
    line-height: 1.65;
    font-weight: 400;
  }
  .p-letter-body p { margin: 0 0 14px; }
  .p-letter-body p strong { font-weight: 600; }
  .p-letter-greeting { font-weight: 500; font-style: italic; }
  .p-letter-cierre { color: #555; }
  .p-letter-sig {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 22px;
    padding-top: 22px;
    border-top: 1px solid #ececec;
  }
  .p-letter-sig-mark {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: #1a1a1a;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }
  .p-letter-sig-name {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1a1a1a;
    letter-spacing: -0.005em;
  }
  .p-letter-sig-role {
    font-size: 0.75rem;
    color: #888;
    margin-top: 2px;
  }
  @media (max-width: 600px) {
    .p-letter { padding: 24px 22px 22px; }
    .p-letter-body { font-size: 0.9375rem; }
  }

  /* ─── Muro de partners ─────────────────────────────── */
  .p-wall {
    display: grid;
    grid-template-columns: repeat(10, 1fr);
    gap: 6px;
    margin: 24px 0 14px;
  }
  @media (max-width: 1024px) { .p-wall { grid-template-columns: repeat(8, 1fr); } }
  @media (max-width: 720px)  { .p-wall { grid-template-columns: repeat(6, 1fr); gap: 4px; } }
  @media (max-width: 480px)  { .p-wall { grid-template-columns: repeat(5, 1fr); } }
  .p-wall-cell {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 8px;
    background: #f5f5f5;
    transition: transform 0.18s, box-shadow 0.18s;
  }
  .p-wall-cell:hover {
    transform: scale(1.04);
    box-shadow: 0 8px 18px -8px rgba(26,26,46,0.30);
    z-index: 1;
  }
  .p-wall-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
