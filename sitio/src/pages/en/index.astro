---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import { t } from '../../i18n/utils';

const locale = 'en';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'SACS',
  url: 'https://www.sacscloud.com',
  description: t('meta.siteDescription', locale),
  inLanguage: 'en-US',
};
---

<BaseLayout
  title={t('meta.siteTitle', locale)}
  description={t('meta.siteDescription', locale)}
  structuredData={websiteSchema}
  locale={locale}
>
  <Hero
    eyebrow={t('hero.eyebrow', locale)}
    title={t('hero.title', locale)}
    subtitle={t('hero.subtitle', locale)}
    primaryCTA={{ label: t('cta.startFree', locale), href: '/en/free-trial' }}
    secondaryCTA={{ label: t('cta.bookDemo', locale), href: '/en/contact' }}
  />
  <!-- ═══ CTA: Still have questions? + Cards ═══ -->
  <section class="cta-doubts-section" id="cta-doubts-section">
    <div class="cta-doubts-sticky">
      <div class="cta-doubts-content">
        <h2 class="cta-doubts-text" id="cta-doubts-text">{t('doubts.title', locale)}</h2>
        <div class="xpand-row" id="xpand-row">
          <a href="/en/contact" class="xpand-card xpand-card--demo">
            <div class="xpand-card-bg xpand-bg--demo"></div>
            <div class="xpand-card-overlay"></div>
            <h3 class="xpand-card-title">{t('cards.demoTitle', locale)}</h3>
            <div class="xpand-card-reveal">
              <p class="xpand-card-desc">{t('cards.demoDesc', locale)}</p>
              <span class="xpand-card-cta">{t('cards.demoCta', locale)} <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 10h10M12 6l4 4-4 4"/></svg></span>
            </div>
          </a>
          <a href="/en/free-trial" class="xpand-card xpand-card--start">
            <div class="xpand-card-bg xpand-bg--start"></div>
            <div class="xpand-card-overlay"></div>
            <h3 class="xpand-card-title">{t('cards.startTitle', locale)}</h3>
            <div class="xpand-card-reveal">
              <p class="xpand-card-desc">{t('cards.startDesc', locale)}</p>
              <span class="xpand-card-cta">{t('cards.startCta', locale)} <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 10h10M12 6l4 4-4 4"/></svg></span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Blog Section ═══ -->
  <section class="blog-home-section">
    <div class="blog-home-container">
      <div class="blog-home-header">
        <span class="blog-home-eyebrow">{t('blog.eyebrow', locale)}</span>
        <h2 class="blog-home-title">{t('blog.title', locale)}</h2>
        <p class="blog-home-subtitle">{t('blog.subtitle', locale)}</p>
      </div>
      <div class="blog-home-footer">
        <a href="/blog" class="blog-home-all-link">{t('blog.viewAll', locale)} <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
      </div>
    </div>
  </section>

  <FAQAccordion />
  <FinalCTA />
</BaseLayout>

<style>
  /* Reuse styles from Spanish homepage via global.css cascade */
  .cta-doubts-section {
    position: relative;
    height: 400vh;
    background: #0f0f1a;
  }
  .cta-doubts-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .cta-doubts-content {
    position: relative;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    transition: transform 0.1s linear;
  }
  .cta-doubts-text {
    font-family: var(--font-display);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    color: #fff;
    margin: 0;
    font-size: clamp(3rem, 8vw, 6rem);
    transform: scale(var(--cta-scale, 8));
    transform-origin: center center;
    text-align: center;
  }
  .xpand-row {
    width: 100%;
    display: flex;
    gap: 12px;
    height: 420px;
    opacity: 0;
    transform: translateY(60px);
    transition: opacity 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .xpand-row.visible { opacity: 1; transform: translateY(0); }
  .xpand-card {
    position: relative; flex: 1; border-radius: 20px; overflow: hidden;
    text-decoration: none; display: flex; flex-direction: column;
    justify-content: flex-end; padding: 40px; cursor: pointer;
    transition: flex 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .xpand-row:hover .xpand-card { flex: 0.6; }
  .xpand-row .xpand-card:hover { flex: 1.8; }
  .xpand-card-bg { position: absolute; inset: 0; transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1); }
  .xpand-card:hover .xpand-card-bg { transform: scale(1.05); }
  .xpand-bg--demo { background: linear-gradient(150deg, #3B5BDB 0%, #2B4AC0 50%, #1a2f6d 100%); }
  .xpand-bg--start { background: linear-gradient(150deg, #f5f5f7 0%, #e8e8ed 50%, #dcdce2 100%); }
  .xpand-card-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.1) 50%, transparent 100%); pointer-events: none; }
  .xpand-card-title {
    position: relative; z-index: 1; font-family: var(--font-display); font-weight: 800;
    font-size: clamp(2rem, 4vw, 3.5rem); letter-spacing: -0.04em; line-height: 1;
    color: #fff; margin: 0; text-transform: uppercase;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .xpand-card:hover .xpand-card-title { transform: translateY(-8px); }
  .xpand-card--start .xpand-card-title { color: #0f0f1a; }
  .xpand-card-reveal {
    position: relative; z-index: 1; max-height: 0; opacity: 0; overflow: hidden;
    transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease 0.1s;
  }
  .xpand-card:hover .xpand-card-reveal { max-height: 160px; opacity: 1; }
  .xpand-card-desc { font-size: 1rem; line-height: 1.5; color: rgba(255,255,255,0.6); margin: 16px 0 20px; max-width: 340px; }
  .xpand-card--start .xpand-card-desc { color: rgba(15,15,26,0.55); }
  .xpand-card-cta {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-display); font-weight: 700; font-size: 1rem;
    padding: 12px 24px; border-radius: 6px; transition: gap 0.3s ease;
  }
  .xpand-card:hover .xpand-card-cta { gap: 12px; }
  .xpand-card--demo .xpand-card-cta { color: #3B5BDB; background: #fff; }
  .xpand-card--start .xpand-card-cta { color: #fff; background: #0f0f1a; }

  .blog-home-section { padding: clamp(80px, 10vw, 140px) 0; background: #fff; }
  .blog-home-container { max-width: 1200px; margin: 0 auto; padding: 0 clamp(20px, 4vw, 48px); }
  .blog-home-header { text-align: center; margin-bottom: 48px; }
  .blog-home-eyebrow { font-family: var(--font-body); font-size: 0.8125rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-primary); display: block; margin-bottom: 12px; }
  .blog-home-title { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; color: var(--color-text-primary); letter-spacing: -0.03em; line-height: 1.1; margin: 0 0 12px; }
  .blog-home-subtitle { font-family: var(--font-body); font-size: clamp(1rem, 1.5vw, 1.125rem); color: var(--color-text-secondary); margin: 0; }
  .blog-home-footer { text-align: center; margin-top: 40px; }
  .blog-home-all-link { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-size: 15px; font-weight: 700; color: var(--color-primary); text-decoration: none; padding: 12px 28px; border: 1.5px solid var(--color-primary); border-radius: 100px; transition: background 0.2s ease, color 0.2s ease; }
  .blog-home-all-link:hover { background: var(--color-primary); color: #fff; text-decoration: none; }

  @media (max-width: 767px) {
    .cta-doubts-section { height: 300vh; }
    .cta-doubts-text { font-size: clamp(1.75rem, 7vw, 2.5rem); }
    .xpand-row { flex-direction: column; height: auto; gap: 12px; }
    .xpand-card { min-height: 240px; padding: 28px; border-radius: 16px; }
    .xpand-row:hover .xpand-card { flex: 1; }
    .xpand-row .xpand-card:hover { flex: 1; }
    .xpand-card-reveal { max-height: none; opacity: 1; }
    .xpand-card-title { font-size: clamp(1.75rem, 7vw, 2.5rem); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-doubts-text { transform: scale(1) !important; }
    .cta-doubts-section { height: auto; }
    .xpand-row { opacity: 1; transform: none; }
  }
</style>

<script>
  {
    const section = document.getElementById('cta-doubts-section');
    const text = document.getElementById('cta-doubts-text');
    const row = document.getElementById('xpand-row');

    if (section && text && row) {
      const SCALE_START = 8;
      const SCALE_END = 1;
      let ticking = false;

      const update = () => {
        const rect = section.getBoundingClientRect();
        const sectionH = section.offsetHeight;
        const vh = window.innerHeight;
        const scrolled = -rect.top;
        const totalScroll = sectionH - vh;
        const textProgress = Math.max(0, Math.min(1, scrolled / (totalScroll * 0.6)));
        const eased = 1 - Math.pow(1 - textProgress, 3);
        const scale = SCALE_START - (SCALE_START - SCALE_END) * eased;
        text.style.setProperty('--cta-scale', String(scale));
        const cardsProgress = Math.max(0, Math.min(1, (scrolled / totalScroll - 0.55) / 0.25));
        if (cardsProgress > 0) { row.classList.add('visible'); } else { row.classList.remove('visible'); }
        const content = document.querySelector('.cta-doubts-content') as HTMLElement;
        if (content && cardsProgress > 0) {
          content.style.transform = `translateY(-${cardsProgress * 15}vh)`;
        } else if (content) { content.style.transform = ''; }
        ticking = false;
      };

      window.addEventListener('scroll', () => {
        if (!ticking) { requestAnimationFrame(update); ticking = true; }
      }, { passive: true });
      update();
    }
  }
</script>
