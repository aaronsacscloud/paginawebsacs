---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';
const locale = 'en';
---
<BaseLayout
  title="Free Trial — Sacs"
  description="Start your 7-day free trial. All features included. No credit card required."
  locale={locale}
>
<section style="padding: clamp(120px, 12vw, 180px) 24px 80px; text-align: center;">
  <div style="max-width: 800px; margin: 0 auto;">
    <h1 style="font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: 800; color: var(--color-text-primary); letter-spacing: -0.04em; margin: 0 0 16px;">Start your free trial</h1>
    <p style="font-family: var(--font-body); font-size: 1.125rem; color: var(--color-text-secondary); margin: 0 0 40px;">7 days with all features. No credit card required.</p>
    <a href="/en/contact" style="display: inline-block; font-family: var(--font-body); font-size: 1rem; font-weight: 700; color: #fff; background: var(--color-primary); padding: 14px 32px; border-radius: 8px; text-decoration: none;">{t('cta.bookDemo', locale)}</a>
    <p style="font-family: var(--font-body); font-size: 0.875rem; color: var(--color-text-tertiary); margin-top: 24px;">Sign up page coming soon. <a href="/prueba-gratis" style="color: var(--color-primary);">Sign up in Spanish</a></p>
  </div>
</section>
</BaseLayout>
