---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABanner from '../components/CTABanner.astro';
import { caseStudies } from '../data/testimonials';
---

<BaseLayout
  title="Casos de éxito"
  description="Conoce cómo retailers mexicanos usan SACS para optimizar operaciones, reducir merma y crecer con propósito."
>
  <section class="cases-hero section">
    <div class="container">
      <div class="cases-header">
        <span class="eyebrow badge badge-teal">Historias reales</span>
        <h1 class="display-l">Retailers que crecen con SACS</h1>
        <p class="body-large">
          Cada negocio tiene su historia. Estas son algunas de las empresas
          que transformaron su operación con SACS.
        </p>
      </div>
    </div>
  </section>

  {caseStudies.map((c, i) => (
    <section class:list={['case-detail', 'section', { alt: i % 2 === 1 }]}>
      <div class="container case-grid">
        <div class="case-content">
          <div class="case-meta">
            <h3>{c.name}</h3>
            <p class="body-small">{c.industry} · {c.location}</p>
          </div>
          <div class="case-body">
            <div class="case-section">
              <h4>El reto</h4>
              <p>{c.challenge}</p>
            </div>
            <div class="case-section">
              <h4>El resultado</h4>
              <p>{c.result}</p>
            </div>
            <blockquote class="case-quote">
              <p>"{c.quote}"</p>
              <cite>— {c.name}, {c.role}</cite>
            </blockquote>
          </div>
        </div>
        <div class="case-stat-card">
          <p class="display-xl case-stat-number">{c.stat}</p>
          <p class="body-small">{c.statLabel}</p>
        </div>
      </div>
    </section>
  ))}

  <CTABanner
    title="¿Quieres ser el siguiente caso de éxito?"
    subtitle="Agenda una reunión y descubre cómo SACS puede transformar tu operación."
  />
</BaseLayout>

<style>
  .cases-hero {
    padding-top: calc(72px + var(--space-16));
    padding-bottom: var(--space-8);
  }

  .cases-header {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
  }

  .cases-header .badge {
    margin-bottom: var(--space-5);
  }

  .cases-header h1 {
    margin-bottom: var(--space-4);
  }

  .cases-header .body-large {
    color: var(--color-text-secondary);
  }

  .case-detail.alt {
    background: var(--color-bg-secondary);
  }

  .case-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .case-grid {
      grid-template-columns: 1.5fr 1fr;
    }
  }

  .case-meta {
    margin-bottom: var(--space-6);
  }

  .case-meta h3 {
    margin-bottom: var(--space-1);
  }

  .case-meta .body-small {
    color: var(--color-text-tertiary);
  }

  .case-section {
    margin-bottom: var(--space-5);
  }

  .case-section h4 {
    margin-bottom: var(--space-2);
    color: var(--color-primary);
  }

  .case-section p {
    color: var(--color-text-secondary);
  }

  .case-quote {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-5);
    margin-top: var(--space-6);
  }

  .case-quote p {
    font-style: italic;
    color: var(--color-text-primary);
    font-size: 1.125rem;
    line-height: 1.6;
    margin-bottom: var(--space-2);
  }

  .case-quote cite {
    font-size: 0.875rem;
    color: var(--color-text-tertiary);
    font-style: normal;
  }

  .case-stat-card {
    background: var(--color-bg-card);
    border-radius: var(--radius-2xl);
    padding: var(--space-12);
    text-align: center;
    border: 1px solid var(--color-border-light);
  }

  .case-stat-number {
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .case-stat-card .body-small {
    color: var(--color-text-tertiary);
  }
</style>
