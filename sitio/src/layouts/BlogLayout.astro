---
import BaseLayout from './BaseLayout.astro';
import StructuredData from '../components/StructuredData.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author?: string;
  image?: string;
  tags?: string[];
}

const { title, description, pubDate, author = 'SACS', image, tags = [] } = Astro.props;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  datePublished: pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name: author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'SACS',
    url: 'https://sacs.com.mx',
  },
  ...(image && { image: `https://sacs.com.mx${image}` }),
  keywords: tags.join(', '),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Blog',
      item: 'https://sacs.com.mx/blog',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: title,
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  type="article"
  structuredData={[articleSchema, breadcrumbSchema]}
>
  <article class="blog-article section">
    <div class="container blog-container">
      <header class="blog-header">
        <div class="blog-meta">
          <time datetime={pubDate.toISOString()}>
            {pubDate.toLocaleDateString('es-MX', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          {tags.length > 0 && (
            <div class="blog-tags">
              {tags.map((tag) => (
                <span class="badge badge-blue">{tag}</span>
              ))}
            </div>
          )}
        </div>
        <h1>{title}</h1>
        <p class="body-large blog-description">{description}</p>
        {image && (
          <img src={image} alt={title} class="blog-hero-img" width="720" height="400" loading="eager" />
        )}
      </header>

      <div class="blog-content">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-container {
    max-width: 720px;
  }

  .blog-header {
    margin-bottom: var(--space-12);
    padding-top: var(--space-16);
  }

  .blog-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    color: var(--color-text-tertiary);
    font-size: 0.875rem;
  }

  .blog-tags {
    display: flex;
    gap: var(--space-2);
  }

  .blog-description {
    color: var(--color-text-secondary);
    margin-top: var(--space-4);
  }

  .blog-content :global(h2) {
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
  }

  .blog-content :global(h3) {
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .blog-content :global(p) {
    margin-bottom: var(--space-5);
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin-bottom: var(--space-5);
    padding-left: var(--space-6);
  }

  .blog-content :global(li) {
    margin-bottom: var(--space-2);
  }

  .blog-content :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding-left: var(--space-5);
    margin-block: var(--space-6);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .blog-content :global(pre) {
    background: var(--color-bg-dark);
    color: #fff;
    padding: var(--space-5);
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin-bottom: var(--space-5);
  }

  .blog-content :global(code) {
    font-size: 0.875em;
  }

  .blog-hero-img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-xl);
    margin-top: var(--space-8);
    object-fit: cover;
  }

  .blog-content :global(img) {
    border-radius: var(--radius-lg);
    margin-block: var(--space-6);
  }
</style>
