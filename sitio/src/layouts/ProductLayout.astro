---
import BaseLayout from './BaseLayout.astro';
import ProductSubnav from '../components/ProductSubnav.astro';
import type { PillarId } from '../data/product';

interface Props {
  title: string;
  description: string;
  currentSlug: string;
  currentPillar: PillarId;
  noindex?: boolean;
  preloadImage?: string;
}

const { title, description, currentSlug, currentPillar, noindex, preloadImage } = Astro.props;
---

<BaseLayout title={title} description={description} noindex={noindex} preloadImage={preloadImage}>
  <ProductSubnav currentSlug={currentSlug} currentPillar={currentPillar} />
  <slot />
</BaseLayout>
