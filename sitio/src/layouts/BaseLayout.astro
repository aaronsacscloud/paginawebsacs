---
import SEO from '../components/SEO.astro';
import StructuredData from '../components/StructuredData.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import PageTracker from '../components/PageTracker.astro';
import '../styles/global.css';
import { getLangFromUrl, getHreflangLinks, t } from '../i18n/utils';
import type { Locale } from '../i18n/config';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  locale?: Locale;
  preloadImage?: string;
  /** Cuando true, omite Nav/Footer/WhatsApp/PageTracker — para experiencias enfocadas
      (cotizaciones, invitaciones, acuses, etc.) sin chrome de marketing. */
  bareLayout?: boolean;
  /** Path al manifest PWA. Si presente, agrega los meta tags necesarios para install. */
  manifestUrl?: string;
  /** Color del theme PWA (status bar). Default azul SACS. */
  themeColor?: string;
}

const { title, description, image, type, noindex, structuredData, preloadImage, bareLayout = false, manifestUrl, themeColor = '#4B7BE5' } = Astro.props;
const locale = Astro.props.locale || getLangFromUrl(Astro.url);
const hreflangLinks = getHreflangLinks(Astro.url.pathname);

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'SACS',
  url: 'https://sacs.com.mx',
  logo: 'https://sacs.com.mx/logo.png',
  description: 'Sistema operativo empresarial para retailers conscientes en México.',
  areaServed: {
    '@type': 'Country',
    name: 'MX',
  },
  sameAs: [],
};

const allSchemas = structuredData
  ? Array.isArray(structuredData)
    ? [orgSchema, ...structuredData]
    : [orgSchema, structuredData]
  : [orgSchema];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/PlusJakartaSans-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Sora-ExtraBold.woff2" as="font" type="font/woff2" crossorigin />
    <!-- Preload hero image (above-fold, LCP element) -->
    <link rel="preload" href={preloadImage || '/images/hero-sacs-store.webp'} as="image" type="image/webp" />

    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
    />

    <StructuredData data={allSchemas} />

    <!-- Microsoft Clarity -->
    <script is:inline>
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "wad8td38cy");
    </script>

    <!-- TikTok Pixel -->
    <script is:inline>
    !function (w, d, t) {
      w.TiktokAnalyticsObject=t;var ttq=w[t]=w[t]||[];ttq.methods=["page","track","identify","instances","debug","on","off","once","ready","alias","group","enableCookie","disableCookie","holdConsent","revokeConsent","grantConsent"],ttq.setAndDefer=function(t,e){t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}};for(var i=0;i<ttq.methods.length;i++)ttq.setAndDefer(ttq,ttq.methods[i]);ttq.instance=function(t){for(var e=ttq._i[t]||[],n=0;n<ttq.methods.length;n++)ttq.setAndDefer(e,ttq.methods[n]);return e},ttq.load=function(e,n){var r="https://analytics.tiktok.com/i18n/pixel/events.js",o=n&&n.partner;ttq._i=ttq._i||{},ttq._i[e]=[],ttq._i[e]._u=r,ttq._t=ttq._t||{},ttq._t[e]=+new Date,ttq._o=ttq._o||{},ttq._o[e]=n||{};var a=document.createElement("script");a.type="text/javascript",a.async=!0,a.src=r+"?sdkid="+e+"&lib="+t;var s=document.getElementsByTagName("script")[0];s.parentNode.insertBefore(a,s)};
      ttq.load('CUT9GN3C77UAVCG32N00');
      ttq.page();
      // Enhanced matching: if visitor has email from previous session
      try {
        var v = localStorage.getItem('sacs_visitor_email');
        if (v) ttq.identify({ email: v });
      } catch(e) {}
    }(window, document, 'ttq');
    </script>

    <!-- Partner attribution strip hydration -->
    <script is:inline>
    (function() {
      try {
        // Lee cookie sacs_ref_name (formato: encoded "Nombre|Tipo")
        var m = document.cookie.match(/(?:^|;\s*)sacs_ref_name=([^;]+)/);
        if (!m) return;
        var val = decodeURIComponent(m[1]);
        var parts = val.split('|');
        var name = parts[0] || '';
        var tipo = parts[1] || 'Partner SACS';
        if (!name) return;

        // El strip aparece cada vez que el visitante entra (no se persiste el dismiss).
        // El botón X solo lo oculta para la página actual.

        function init() {
          var strip = document.getElementById('partner-strip');
          if (!strip) return;
          var nameEl = document.getElementById('partner-strip-name');
          var tipoEl = document.getElementById('partner-strip-tipo');
          var closeBtn = document.getElementById('partner-strip-close');
          if (nameEl) nameEl.textContent = name;
          if (tipoEl) tipoEl.textContent = ' · ' + tipo + ' oficial';
          strip.hidden = false;
          document.body.classList.add('has-partner-strip');
          if (closeBtn) {
            closeBtn.addEventListener('click', function() {
              strip.style.transition = 'transform 0.25s ease, opacity 0.25s ease';
              strip.style.transform = 'translateY(-100%)';
              strip.style.opacity = '0';
              setTimeout(function() {
                strip.hidden = true;
                document.body.classList.remove('has-partner-strip');
              }, 260);
            });
          }
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      } catch (e) { /* ignore */ }
    })();
    </script>

    <!-- Font face declarations -->
    <style is:inline>
      @font-face {
        font-family: 'Plus Jakarta Sans';
        src: url('/fonts/PlusJakartaSans-Light.woff2') format('woff2');
        font-weight: 300;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Plus Jakarta Sans';
        src: url('/fonts/PlusJakartaSans-Regular.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Plus Jakarta Sans';
        src: url('/fonts/PlusJakartaSans-Medium.woff2') format('woff2');
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Plus Jakarta Sans';
        src: url('/fonts/PlusJakartaSans-SemiBold.woff2') format('woff2');
        font-weight: 600;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Plus Jakarta Sans';
        src: url('/fonts/PlusJakartaSans-Bold.woff2') format('woff2');
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Plus Jakarta Sans';
        src: url('/fonts/PlusJakartaSans-ExtraBold.woff2') format('woff2');
        font-weight: 800;
        font-style: normal;
        font-display: swap;
      }
      /* Sora */
      @font-face {
        font-family: 'Sora';
        src: url('/fonts/Sora-Regular.woff2') format('woff2');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Sora';
        src: url('/fonts/Sora-Medium.woff2') format('woff2');
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Sora';
        src: url('/fonts/Sora-SemiBold.woff2') format('woff2');
        font-weight: 600;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Sora';
        src: url('/fonts/Sora-Bold.woff2') format('woff2');
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'Sora';
        src: url('/fonts/Sora-ExtraBold.woff2') format('woff2');
        font-weight: 800;
        font-style: normal;
        font-display: swap;
      }
      /* Clash Display (wordmark) */
      @font-face {
        font-family: 'Clash Display';
        src: url('/fonts/ClashDisplay-Bold.woff2') format('woff2');
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }

      /* Critical: hide nav dropdowns & mobile menu before component CSS loads */
      .mega-dropdown { visibility: hidden; opacity: 0; position: absolute; }
      .mega-backdrop { display: none; }
      .mega-backdrop.active { display: block; }
      .mobile-menu { display: none; }
      .mobile-menu.open { display: block; }
      .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; height: 71px; background: #fff; }
      .nav-inner { display: flex; align-items: center; height: 100%; }
      .wa-bar { opacity: 0; pointer-events: none; }
    </style>

    {manifestUrl && (
      <>
        <link rel="manifest" href={manifestUrl} />
        <meta name="theme-color" content={themeColor} />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-status-bar-style" content="default" />
        <meta name="apple-mobile-web-app-title" content="SACS Partner" />
        <link rel="apple-touch-icon" href="/favicon.svg" />
      </>
    )}
  </head>
  <body class={bareLayout ? 'is-bare' : undefined}>
    {!bareLayout && (
      <a href="#main-content" class="skip-link">{t('common.skipToContent', locale)}</a>
    )}

    {/* Partner attribution toast · bottom-center · se hidrata client-side desde cookie sacs_ref_name */}
    {!bareLayout && (
      <div id="partner-strip" class="partner-strip" hidden>
        <div class="partner-strip-inner">
          <span class="partner-strip-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </span>
          <div class="partner-strip-text">
            <div class="partner-strip-text-line">Te recomendó</div>
            <strong id="partner-strip-name"></strong>
            <span class="partner-strip-text-sub" id="partner-strip-tipo"></span>
          </div>
          <button id="partner-strip-close" class="partner-strip-close" aria-label="Cerrar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
      </div>
    )}

    {!bareLayout && <Nav locale={locale} />}
    <main id="main-content">
      <slot />
    </main>
    {!bareLayout && <Footer locale={locale} />}
    {!bareLayout && <WhatsAppButton locale={locale} />}
    {!bareLayout && <PageTracker />}

    <!-- Coming soon modal -->
    <div class="cs-modal-overlay" id="cs-modal" aria-hidden="true">
      <div class="cs-modal">
        <button class="cs-modal-close" id="cs-modal-close" aria-label={t('modal.close', locale)}>&times;</button>
        <div class="cs-modal-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <h2 class="cs-modal-title">{t('modal.title', locale)}</h2>
        <p class="cs-modal-subtitle">{t('modal.subtitle', locale)}</p>
        <p class="cs-modal-desc">{t('modal.desc', locale)}</p>
        <a href="/contacto" class="cs-modal-btn">{t('modal.cta', locale)}</a>
      </div>
    </div>

    <style>
      /* Partner attribution toast — bottom-center, no intrusivo */
      .partner-strip {
        position: fixed;
        left: 50%;
        bottom: 24px;
        transform: translateX(-50%);
        z-index: 1001;
        background: #fff;
        color: #1a1a1a;
        padding: 14px 16px 14px 18px;
        font-family: var(--font-body, system-ui);
        font-size: 0.8125rem;
        font-weight: 500;
        line-height: 1.4;
        border-radius: 14px;
        box-shadow: 0 20px 50px -10px rgba(0,0,0,0.18), 0 8px 16px -6px rgba(0,0,0,0.06);
        border: 1px solid rgba(75,123,229,0.18);
        max-width: calc(100vw - 32px);
        animation: pstrip-slide-up 0.45s cubic-bezier(0.16, 1, 0.3, 1);
        letter-spacing: -0.005em;
      }
      .partner-strip[hidden] { display: none !important; }
      @keyframes pstrip-slide-up {
        from { transform: translate(-50%, calc(100% + 24px)); opacity: 0; }
        to   { transform: translate(-50%, 0); opacity: 1; }
      }
      .partner-strip-inner {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .partner-strip-icon {
        flex-shrink: 0;
        width: 36px; height: 36px;
        border-radius: 50%;
        background: rgba(75,123,229,0.10);
        color: #4B7BE5;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      .partner-strip-text {
        flex: 1;
        min-width: 0;
      }
      .partner-strip-text-line {
        font-size: 11px;
        color: #737373;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-bottom: 2px;
      }
      .partner-strip-text strong {
        font-weight: 700;
        color: #1a1a1a;
        font-size: 13px;
      }
      .partner-strip-text-sub {
        font-size: 12px;
        color: #737373;
      }
      .partner-strip-close {
        flex-shrink: 0;
        background: transparent;
        border: none;
        color: #a3a3a3;
        line-height: 1;
        cursor: pointer;
        padding: 8px;
        border-radius: 8px;
        font-family: inherit;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: color 0.15s, background 0.15s;
      }
      .partner-strip-close:hover {
        background: #f5f5f3;
        color: #1a1a1a;
      }
      @media (max-width: 640px) {
        .partner-strip {
          bottom: 16px;
          padding: 12px 12px 12px 14px;
          font-size: 12px;
        }
        .partner-strip-icon { width: 32px; height: 32px; }
      }

      .cs-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 10000;
        background: rgba(0,0,0,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.25s ease, visibility 0.25s ease;
        padding: 24px;
      }
      .cs-modal-overlay.is-open {
        opacity: 1;
        visibility: visible;
      }
      .cs-modal {
        background: #fff;
        border-radius: 20px;
        padding: 48px 40px;
        max-width: 420px;
        width: 100%;
        text-align: center;
        position: relative;
        transform: scale(0.95) translateY(10px);
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
      }
      .cs-modal-overlay.is-open .cs-modal {
        transform: scale(1) translateY(0);
      }
      .cs-modal-close {
        position: absolute;
        top: 16px;
        right: 20px;
        background: none;
        border: none;
        font-size: 1.5rem;
        color: var(--color-text-tertiary);
        cursor: pointer;
        line-height: 1;
        padding: 4px;
      }
      .cs-modal-close:hover {
        color: var(--color-text-primary);
      }
      .cs-modal-icon {
        margin-bottom: 16px;
      }
      .cs-modal-title {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--color-text-primary);
        letter-spacing: -0.03em;
        margin: 0 0 4px;
      }
      .cs-modal-subtitle {
        font-family: var(--font-body);
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--color-primary);
        margin: 0 0 16px;
      }
      .cs-modal-desc {
        font-family: var(--font-body);
        font-size: 0.875rem;
        color: var(--color-text-secondary);
        line-height: 1.6;
        margin: 0 0 24px;
      }
      .cs-modal-btn {
        display: inline-block;
        font-family: var(--font-body);
        font-size: 0.875rem;
        font-weight: 700;
        color: #fff;
        background: var(--color-primary);
        padding: 12px 28px;
        border-radius: 8px;
        text-decoration: none;
        transition: background 0.2s ease;
      }
      .cs-modal-btn:hover {
        background: var(--color-primary-hover);
        text-decoration: none;
      }
      @media (max-width: 480px) {
        .cs-modal {
          padding: 36px 28px;
        }
      }
    </style>

    <script>
      {
        const modal = document.getElementById('cs-modal');
        const closeBtn = document.getElementById('cs-modal-close');

        // Links that should trigger the modal
        const comingSoonSelectors = [
          'a[href="#"]',
          'a[href="/nosotros"]',
          'a[href="/manifiesto"]',
          'a[href="/componentes"]',
        ];

        const links = document.querySelectorAll(comingSoonSelectors.join(','));

        links.forEach(link => {
          link.addEventListener('click', (e) => {
            e.preventDefault();
            if (modal) modal.classList.add('is-open');
          });
        });

        if (closeBtn && modal) {
          closeBtn.addEventListener('click', () => modal.classList.remove('is-open'));
          modal.addEventListener('click', (e) => {
            if (e.target === modal) modal.classList.remove('is-open');
          });
          document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') modal.classList.remove('is-open');
          });
        }
      }
    </script>

    <!-- TikTok: track CTA clicks globally + UTM persistence -->
    <script is:inline>
    try {
      // ─── Persist UTMs across pages ───
      var params = new URLSearchParams(window.location.search);
      var utmKeys = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term','ttclid'];
      var hasUtm = false;
      utmKeys.forEach(function(k) {
        var v = params.get(k);
        if (v) { sessionStorage.setItem(k, v); hasUtm = true; }
      });

      // Append stored UTMs to /prueba-gratis and /registro links
      document.addEventListener('click', function(e) {
        var el = e.target;
        while (el && el !== document) {
          if (el.tagName === 'A' && el.href) {
            // ─── Track "Prueba gratis" clicks ───
            if (el.href.indexOf('/prueba-gratis') > -1) {
              if (typeof ttq !== 'undefined') {
                ttq.track('ClickButton', { content_id: 'prueba-gratis', content_name: 'cta-prueba-7-dias', content_type: 'product' });
              }
              // Append UTMs
              var stored = new URLSearchParams();
              utmKeys.forEach(function(k) {
                var sv = sessionStorage.getItem(k);
                if (sv) stored.set(k, sv);
              });
              var qs = stored.toString();
              if (qs && el.href.indexOf('utm_') === -1) {
                el.href = el.href + (el.href.indexOf('?') > -1 ? '&' : '?') + qs;
              }
            }
            // ─── Track "Agenda demo" clicks ───
            if (el.href.indexOf('/contacto') > -1) {
              if (typeof ttq !== 'undefined') {
                ttq.track('ClickButton', { content_id: 'agenda-demo', content_name: 'agenda-demo', content_type: 'product' });
              }
            }
            break;
          }
          el = el.parentElement;
        }
      });
    } catch(e) {}
    </script>
  </body>
</html>
